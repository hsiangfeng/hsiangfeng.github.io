[{"data":1,"prerenderedAt":667},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190919\u002F503019302\u002F":3,"page:\u002Fphp\u002F20190919\u002F503019302\u002F":4,"alt:\u002Fphp\u002F20190919\u002F503019302\u002F":3,"prev-next:\u002Fphp\u002F20190919\u002F503019302\u002F":644,"related:\u002Fphp\u002F20190919\u002F503019302\u002F":653},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":625,"date":626,"description":627,"extension":628,"lang":629,"meta":630,"navigation":75,"path":631,"readingMinutes":632,"seo":633,"standalone":634,"stem":635,"tags":636,"tldr":641,"updated":641,"url":642,"__hash__":643},"content\u002F從基礎學習 ThinkPHP\u002FDay18-從基礎學習-ThinkPHP-Model-基礎操作-4.md","Day18-從基礎學習 ThinkPHP-Model 基礎操作(4)","503019302",{"type":9,"value":10,"toc":617},"minimark",[11,15,24,27,33,94,102,105,112,119,122,177,180,187,194,232,238,247,290,293,298,301,304,319,350,364,449,460,466,469,475,479,485,518,521,546,549,552,559,586,589,613],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,23],"p",{},"haha",[20,21,22],"del",{},"我像荒唐鏡一樣跳走了，現在又跳回來了","打我啊笨蛋(被扁)，接下來這邊會針對查詢稍微做一下補充，例如該如何使用 Model 條件式查詢，查詢之後又該如何排序呢?",[12,25,26],{"id":26},"前世",[16,28,29,32],{},[20,30,31],{},"先讓我們回到前世，阿不是","，先讓我們回顧一下前面的 Model 基礎操作，我們理解可以使用 get()、all() 來做單一查詢 or 列出資料清單：",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-php shiki shiki-themes github-dark-high-contrast","$user = aboutModel::get($id);\n\n$user = aboutModel::all();\n","php","",[41,42,43,70,77],"code",{"__ignoreMap":39},[44,45,48,52,56,60,63,67],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sMAXC","$user ",[44,53,55],{"class":54},"sWyjQ","=",[44,57,59],{"class":58},"sCcAr"," aboutModel",[44,61,62],{"class":54},"::",[44,64,66],{"class":65},"sj_SG","get",[44,68,69],{"class":50},"($id);\n",[44,71,73],{"class":46,"line":72},2,[44,74,76],{"emptyLinePlaceholder":75},true,"\n",[44,78,80,82,84,86,88,91],{"class":46,"line":79},3,[44,81,51],{"class":50},[44,83,55],{"class":54},[44,85,59],{"class":58},[44,87,62],{"class":54},[44,89,90],{"class":65},"all",[44,92,93],{"class":50},"();\n",[16,95,96,97,101],{},"但是 ",[98,99,100],"strong",{},"Model 基礎操作"," 系列卻沒有講到條件與排序的動作，所以這邊將會介紹其他的 Model 基礎操作。",[12,103,104],{"id":104},"條件式查詢",[16,106,107,108,111],{},"接下來的範例我會將程式碼撰寫於 ",[41,109,110],{},"about\u002Fcontroller\u002Findex.php"," 中。",[16,113,114,115,118],{},"經過前兩篇的資料操作系列，我們可以理解到如果使用 Model 操作資料是一件多麼方便的事情，所以這邊將會介紹該如何使用 Model 的條件式查詢，其實也就是帶上 ",[41,116,117],{},"where()"," 方法而已，但是這邊將會搭配使用前面所學的資料操作技巧，也就是構造器。",[16,120,121],{},"那麼首先我這邊舉例我要篩選 user 資料表中班上同學的身高，然後我要找身高大於 170 公分的同學：",[34,123,125],{"className":36,"code":124,"language":38,"meta":39,"style":39},"$user = aboutModel::where('height', '>', 170)->select();\necho $user;\n",[41,126,127,169],{"__ignoreMap":39},[44,128,129,131,133,135,137,140,143,147,150,153,155,158,161,164,167],{"class":46,"line":47},[44,130,51],{"class":50},[44,132,55],{"class":54},[44,134,59],{"class":58},[44,136,62],{"class":54},[44,138,139],{"class":65},"where",[44,141,142],{"class":50},"(",[44,144,146],{"class":145},"sTRMh","'height'",[44,148,149],{"class":50},", ",[44,151,152],{"class":145},"'>'",[44,154,149],{"class":50},[44,156,157],{"class":58},"170",[44,159,160],{"class":50},")",[44,162,163],{"class":54},"->",[44,165,166],{"class":65},"select",[44,168,93],{"class":50},[44,170,171,174],{"class":46,"line":72},[44,172,173],{"class":58},"echo",[44,175,176],{"class":50}," $user;\n",[16,178,179],{},"那麼結果就會像這樣子是一個陣列物件 ↓",[16,181,182],{},[183,184],"img",{"alt":185,"src":186},"陣列物件","https:\u002F\u002Fi.imgur.com\u002FOZMuhST.png",[16,188,189,190,193],{},"當然也可以不使用構造器的方式來製作條件篩選，也就是使用 ",[41,191,192],{},"all()"," 方法來製作：",[34,195,197],{"className":36,"code":196,"language":38,"meta":39,"style":39},"$user = aboutModel::all(['name' => 'QQ先生']);\necho $user;\n",[41,198,199,226],{"__ignoreMap":39},[44,200,201,203,205,207,209,211,214,217,220,223],{"class":46,"line":47},[44,202,51],{"class":50},[44,204,55],{"class":54},[44,206,59],{"class":58},[44,208,62],{"class":54},[44,210,90],{"class":65},[44,212,213],{"class":50},"([",[44,215,216],{"class":145},"'name'",[44,218,219],{"class":54}," =>",[44,221,222],{"class":145}," 'QQ先生'",[44,224,225],{"class":50},"]);\n",[44,227,228,230],{"class":46,"line":72},[44,229,173],{"class":58},[44,231,176],{"class":50},[16,233,234],{},[183,235],{"alt":236,"src":237},"回傳陣列","https:\u002F\u002Fi.imgur.com\u002FLGzhxA6.png",[16,239,240,241,243,244,246],{},"使用 ",[41,242,192],{}," 方法去做條件篩選的方式是帶入陣列條件，但是如果想要查詢多筆資料呢?用 ",[41,245,192],{}," 可不可以?",[34,248,250],{"className":36,"code":249,"language":38,"meta":39,"style":39},"$user = aboutModel::all(['name' => 'QQ先生','name' => '王小明']);\necho $user;\n",[41,251,252,284],{"__ignoreMap":39},[44,253,254,256,258,260,262,264,266,268,270,272,275,277,279,282],{"class":46,"line":47},[44,255,51],{"class":50},[44,257,55],{"class":54},[44,259,59],{"class":58},[44,261,62],{"class":54},[44,263,90],{"class":65},[44,265,213],{"class":50},[44,267,216],{"class":145},[44,269,219],{"class":54},[44,271,222],{"class":145},[44,273,274],{"class":50},",",[44,276,216],{"class":145},[44,278,219],{"class":54},[44,280,281],{"class":145}," '王小明'",[44,283,225],{"class":50},[44,285,286,288],{"class":46,"line":72},[44,287,173],{"class":58},[44,289,176],{"class":50},[16,291,292],{},"那我們就直接來看查詢後的結果 ↓",[16,294,295],{},[183,296],{"alt":297,"src":237},"QQ 先生消失了",[16,299,300],{},"所以由此可知，如果想要做比較複雜的條件查詢，那麼我會建議使用構造器去撰寫，你也會比較直覺且好維護。",[12,302,303],{"id":303},"刪除資料",[16,305,306,307,310,311,314,315,318],{},"接下來這邊將會講解刪除方法的使用方式，也就是 ",[41,308,309],{},"delete()","，在使用刪除方法時，建議請依照主鍵也就是 ",[41,312,313],{},"key"," 來做判斷，否則可能會發生",[98,316,317],{},"誤刪資料的事件","，那麼刪除方的法非常簡單：",[34,320,322],{"className":36,"code":321,"language":38,"meta":39,"style":39},"$user = aboutModel::get($id);\n$user->delete();\n",[41,323,324,338],{"__ignoreMap":39},[44,325,326,328,330,332,334,336],{"class":46,"line":47},[44,327,51],{"class":50},[44,329,55],{"class":54},[44,331,59],{"class":58},[44,333,62],{"class":54},[44,335,66],{"class":65},[44,337,69],{"class":50},[44,339,340,343,345,348],{"class":46,"line":72},[44,341,342],{"class":50},"$user",[44,344,163],{"class":54},[44,346,347],{"class":65},"delete",[44,349,93],{"class":50},[16,351,352,353,355,356,359,360,363],{},"你沒有看錯就是這麼簡潔，當你成功刪除後 ",[41,354,309],{}," 將會回傳一個布林值 (",[41,357,358],{},"true"," or ",[41,361,362],{},"false",")，所以我們可以依照它回傳的值進而判斷是否刪除成功：",[34,365,367],{"className":36,"code":366,"language":38,"meta":39,"style":39},"$user = aboutModel::get($id);\nif ($user->delete()) {\n  return '刪除成功'.$user->id;\n} else {\n  return $user->getError();\n}\n",[41,368,369,383,398,416,428,443],{"__ignoreMap":39},[44,370,371,373,375,377,379,381],{"class":46,"line":47},[44,372,51],{"class":50},[44,374,55],{"class":54},[44,376,59],{"class":58},[44,378,62],{"class":54},[44,380,66],{"class":65},[44,382,69],{"class":50},[44,384,385,388,391,393,395],{"class":46,"line":72},[44,386,387],{"class":54},"if",[44,389,390],{"class":50}," ($user",[44,392,163],{"class":54},[44,394,347],{"class":65},[44,396,397],{"class":50},"()) {\n",[44,399,400,403,406,409,411,413],{"class":46,"line":79},[44,401,402],{"class":54},"  return",[44,404,405],{"class":145}," '刪除成功'",[44,407,408],{"class":54},".",[44,410,342],{"class":50},[44,412,163],{"class":54},[44,414,415],{"class":50},"id;\n",[44,417,419,422,425],{"class":46,"line":418},4,[44,420,421],{"class":50},"} ",[44,423,424],{"class":54},"else",[44,426,427],{"class":50}," {\n",[44,429,431,433,436,438,441],{"class":46,"line":430},5,[44,432,402],{"class":54},[44,434,435],{"class":50}," $user",[44,437,163],{"class":54},[44,439,440],{"class":65},"getError",[44,442,93],{"class":50},[44,444,446],{"class":46,"line":445},6,[44,447,448],{"class":50},"}\n",[16,450,451,452,455,456,459],{},"那麼我這邊路由已經先註冊好了 ",[41,453,454],{},"Route::get('\u002Fabout\u002Fdelete\u002F:id', 'about\u002Findex\u002Fdelete');","，接下來直接訪問路由就可以直接刪除特定的資料，例如我現在想要刪除 ",[44,457,458],{},"QQ 先生"," ↓",[16,461,462],{},[183,463],{"alt":464,"src":465},"刪除成功","https:\u002F\u002Fi.imgur.com\u002FvZrrbbg.png",[16,467,468],{},"當然我們也可以來看一下資料表確定 QQ 先生真的已經被刪除了 ↓",[16,470,471],{},[183,472],{"alt":473,"src":474},"QQ 先生真的 QQ 了","https:\u002F\u002Fi.imgur.com\u002Foc0dIJd.png",[12,476,478],{"id":477},"輸出-json","輸出 JSON",[16,480,481,482,484],{},"最後這邊補充輸出 JSON 格式的方式，這邊我將會使用 ",[41,483,192],{}," 方法來撰寫，另外由於現在前後端分離的關係，現在大多都是採用 API 開發輸出 JSON 格式，所以 JSON 格式的輸出就格外的重要，但是寫法其實也很簡單，因為 ThinkPHP 本身也有提供該方法，只需要這樣寫即可：",[34,486,488],{"className":36,"code":487,"language":38,"meta":39,"style":39},"$user = aboutModel::all();\nreturn $user->toJson();\n",[41,489,490,504],{"__ignoreMap":39},[44,491,492,494,496,498,500,502],{"class":46,"line":47},[44,493,51],{"class":50},[44,495,55],{"class":54},[44,497,59],{"class":58},[44,499,62],{"class":54},[44,501,90],{"class":65},[44,503,93],{"class":50},[44,505,506,509,511,513,516],{"class":46,"line":72},[44,507,508],{"class":54},"return",[44,510,435],{"class":50},[44,512,163],{"class":54},[44,514,515],{"class":65},"toJson",[44,517,93],{"class":50},[16,519,520],{},"另外 ThinkPHP 也有更簡潔的寫法，但是簡潔寫法本身呢…就是原本的寫法，原本寫法就是輸出 JSON 格式：",[34,522,524],{"className":36,"code":523,"language":38,"meta":39,"style":39},"$user = aboutModel::all();\nreturn $user;\n",[41,525,526,540],{"__ignoreMap":39},[44,527,528,530,532,534,536,538],{"class":46,"line":47},[44,529,51],{"class":50},[44,531,55],{"class":54},[44,533,59],{"class":58},[44,535,62],{"class":54},[44,537,90],{"class":65},[44,539,93],{"class":50},[44,541,542,544],{"class":46,"line":72},[44,543,508],{"class":54},[44,545,176],{"class":50},[16,547,548],{},"但是我覺得這邊還是告知一下有這種寫法會比較好。",[12,550,551],{"id":551},"結尾",[16,553,554,555,558],{},"最後如果你有發生 ",[41,556,557],{},"rying to get property 'name' of non-object"," 的錯誤訊息，那代表是我前面章節的路由註冊上較不妥的關係，主要是這一隻路由導致錯誤：",[34,560,562],{"className":36,"code":561,"language":38,"meta":39,"style":39},"Route::get('\u002Fabout\u002F:id', 'about\u002Findex\u002Fselect');\n",[41,563,564],{"__ignoreMap":39},[44,56