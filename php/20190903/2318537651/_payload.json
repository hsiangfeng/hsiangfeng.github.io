[{"data":1,"prerenderedAt":366},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190903\u002F2318537651\u002F":3,"page:\u002Fphp\u002F20190903\u002F2318537651\u002F":4,"alt:\u002Fphp\u002F20190903\u002F2318537651\u002F":3,"prev-next:\u002Fphp\u002F20190903\u002F2318537651\u002F":343,"related:\u002Fphp\u002F20190903\u002F2318537651\u002F":352},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F03\u002Fthinkphp-day-02-mysql-database-basics\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":324,"date":325,"description":18,"extension":326,"lang":327,"meta":328,"navigation":329,"path":330,"readingMinutes":331,"seo":332,"standalone":333,"stem":334,"tags":335,"tldr":340,"updated":340,"url":341,"__hash__":342},"content\u002F從基礎學習 ThinkPHP\u002FDay2-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料庫篇.md","Day2-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料庫篇","2318537651",{"type":9,"value":10,"toc":315},"minimark",[11,15,19,22,30,37,40,46,49,52,64,93,99,106,136,142,145,151,154,160,163,166,175,181,184,190,205,210,216,222,229,234,241,244,247,311],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"歡迎來到 ThinkPHP 系列的第一篇勇者大人，首先第一篇至第四篇我們將會學習基礎的 SQL 操作與指令，等到我們學習完這些基礎的指令操作後，就開始正式進入 ThinkPHP，所以就讓我們來開始學習吧!",[12,20,21],{"id":21},"起手式",[16,23,24,25,29],{},"前一篇 ",[26,27,28],"strong",{},"介紹篇"," 有講到我們將會使用 XAMPP 這個超~~方便的快速架站工具包，但是由於有許多前輩都已經介紹過 XAMPP 的安裝流程與操作，所以我這邊就不在多做介紹安裝流程等等，那麼我就不在多說廢話直接進入內建的 phpMyAdmin 吧!",[16,31,32],{},[33,34],"img",{"alt":35,"src":36},"進入方法可點擊 XAMPP 上的 Admin 按鈕","https:\u002F\u002Fi.imgur.com\u002FtAOVeiK.png",[16,38,39],{},"進入 phpMyAdmin 後，點擊上方 SQL 的標籤切換至 SQL 的頁面，接下來我們就要來開始準備認識基礎的資料庫操作指令囉~",[16,41,42],{},[33,43],{"alt":44,"src":45},"SQL","https:\u002F\u002Fi.imgur.com\u002FYTjcuc9.png",[16,47,48],{},"這邊我額外補充 phpMyAdmin 是什麼神奇的東東，一般來講我們在操控 MySQL 大多都是透過 CMD，那 phpMyAdmin 是以 PHP 為基礎開發的 Web GUI 介面，最主要是可以讓操作者直接透過該介面執行各種 SQL 指令與動作，而它的功能其實非常~強大的，但是我這邊並不會針對該介面多做介紹僅會帶過而已，畢竟我們只是要學習 SQL 而已。",[12,50,51],{"id":51},"建立資料庫",[16,53,54,55,58,59,63],{},"一般網站開發上都會有一個地方是專門存放網站的資料，而那個地方就是 ",[26,56,57],{},"資料庫"," ，我們可以將資料庫想像成是銀行的保險庫，所以我們第一個要學習的語法就是建立資料庫，假設我今天要建立一個資料庫叫做 ",[60,61,62],"code",{},"it_think_sql"," 那麼就會使用以下語法：",[65,66,71],"pre",{"className":67,"code":68,"language":69,"meta":70,"style":70},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE DATABASE it_think_sql;\n","sql","",[60,72,73],{"__ignoreMap":70},[74,75,78,82,85,89],"span",{"class":76,"line":77},"line",1,[74,79,81],{"class":80},"sWyjQ","CREATE",[74,83,84],{"class":80}," DATABASE",[74,86,88],{"class":87},"sj_SG"," it_think_sql",[74,90,92],{"class":91},"sMAXC",";\n",[16,94,95,96],{},"※指令說明: ",[60,97,98],{},"CREATE DATABASE [資料庫名稱];",[16,100,101,102,105],{},"另外這邊還要輸入以下指令，這個指令是替資料庫設置編碼與排序，否則通常預設會是 ",[60,103,104],{},"latin1_swedish_ci","，如果你沒有做這個動作，那麼導致存進去的資料是亂碼！所以請務必要記得設置該資料庫編碼與排序唷~",[65,107,109],{"className":67,"code":108,"language":69,"meta":70,"style":70},"ALTER DATABASE it_think_sql CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;\n",[60,110,111],{"__ignoreMap":70},[74,112,113,116,118,121,124,127,130,133],{"class":76,"line":77},[74,114,115],{"class":80},"ALTER",[74,117,84],{"class":80},[74,119,120],{"class":91}," it_think_sql ",[74,122,123],{"class":80},"CHARACTER",[74,125,126],{"class":80}," SET",[74,128,129],{"class":91}," utf8mb4 ",[74,131,132],{"class":80},"COLLATE",[74,134,135],{"class":91}," utf8mb4_general_ci;\n",[16,137,138,139],{},"※ 指令說明: ",[60,140,141],{},"ALTER DATABASE [資料庫名稱] CHARACTER SET [字元集] collate [排序規則];",[16,143,144],{},"使用 phpMyAdmin 還有一個好處，我們可以直接一次塞入上面兩行 SQL 指令一次執行完畢，減少我們執行完後又要在執行另一段，否則原本我們透過 CMD 執行的話是要一行一行的執行 ↓",[16,146,147],{},[33,148],{"alt":149,"src":150},"SQL 指令","https:\u002F\u002Fi.imgur.com\u002F4NM7kOB.png",[16,152,153],{},"執行完畢後，我們可以在左側資料庫列表看到剛剛新增的資料庫 ↓",[16,155,156],{},[33,157],{"alt":158,"src":159},"成功新增資料庫","https:\u002F\u002Fi.imgur.com\u002FrFQO11p.png",[12,161,162],{"id":162},"列出資料庫清單",[16,164,165],{},"有時候我們會希望看目前有哪些資料庫，那以情景來舉例的話，假設我是銀行的總行，我非常多分行，但是我想知道我目前有哪些分行保險庫，那麼我們就可以使用以下語法來查詢目前我們有哪些保險庫：",[65,167,169],{"className":67,"code":168,"language":69,"meta":70,"style":70},"SHOW databases;\n",[60,170,171],{"__ignoreMap":70},[74,172,173],{"class":76,"line":77},[74,174,168],{"class":91},[16,176,177],{},[33,178],{"alt":179,"src":180},"列出所有資料庫","https:\u002F\u002Fi.imgur.com\u002Fp3ZyFWQ.png",[12,182,183],{"id":183},"刪除資料庫",[16,185,186,187,189],{},"我們接續上面的銀行情景，假設我有一間分行要收掉，而那個分行剛剛好叫做 ",[60,188,62],{}," (剛開就收掉，哭哭)，那我們自然就要輸入刪除的語法來刪除這間分行，所以就會使用以下語法：",[65,191,193],{"className":67,"code":192,"language":69,"meta":70,"style":70},"DROP DATABASE it_think_sql;\n",[60,194,195],{"__ignoreMap":70},[74,196,197,200,202],{"class":76,"line":77},[74,198,199],{"class":80},"DROP",[74,201,84],{"class":80},[74,203,204],{"class":91}," it_think_sql;\n",[16,206,138,207],{},[60,208,209],{},"DROP DATABASE [資料庫名稱]",[16,211,212,213,215],{},"當你輸入執行完畢之後，就可以看到左側資料庫列表的 ",[60,214,62],{}," 被刪除囉 ↓",[16,217,218],{},[33,219],{"alt":220,"src":221},"刪除 it_think_sql","https:\u002F\u002Fi.imgur.com\u002FMepXCS5.png",[16,223,224,225,228],{},"當然你也可以試著輸入 ",[60,226,227],{},"SHOW DATABASE;"," 來驗證是不是真的被刪除了 ↓",[16,230,231],{},[33,232],{"alt":179,"src":233},"https:\u002F\u002Fi.imgur.com\u002FMgsfEh6.png",[16,235,236,237,240],{},"※ 最後我這邊要提醒一件事情，",[26,238,239],{},"刪除"," 這個動作往往是非常危險的，你如果依照本一路操作下來就會發現在執行刪除的 SQL 指令時，你並不會得到任何提示訊息(有些 GUI 還會問你真的要刪除該資料庫嗎?)，它會立刻刪除你指定的資料庫，所以在刪除資料庫之前，請務必做好備份以及 double check 以防誤刪自己非常重要的資料唷!",[12,242,243],{"id":243},"結尾",[16,245,246],{},"最後讓我們來整理一下本篇所講到的 SQL 指令",[248,249,250,263],"table",{},[251,252,253],"thead",{},[254,255,256,260],"tr",{},[257,258,259],"th",{},"操作功能",[257,261,262],{},"SQL 語法",[264,265,266,277,296,302],"tbody",{},[254,267,268,271],{},[269,270,51],"td",{},[269,272,273,274],{},"CREATE DATABASE ",[74,275,276],{},"資料庫名稱",[254,278,279,282],{},[269,280,281],{},"設置資料庫編碼與排序",[269,283,284,285,287,288,291,292,295],{},"ALTER DATABASE ",[74,286,276],{}," CHARACTER SET ",[74,289,290],{},"字元集"," COLLATE ",[74,293,294],{},"排序規則",";",[254,297,298,300],{},[269,299,179],{},[269,301,227],{},[254,303,304,306],{},[269,305,183],{},[269,307,308,309],{},"DROP DATABASE ",[74,310,276],{},[312,313,314],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":70,"searchDepth":316,"depth":316,"links":317},2,[318,319,320,321,322,323],{"id":14,"depth":316,"text":14},{"id":21,"depth":316,"text":21},{"id":51,"depth":316,"text":51},{"id":162,"depth":316,"text":162},{"id":183,"depth":316,"text":183},{"id":243,"depth":316,"text":243},"PHP","2019-09-03 08:35:58","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday2-thinkphp-mysql","3",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay2-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料庫篇",[324,336,337,338,339],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190903\u002F2318537651\u002F","0YT8Q706mn-Uun4xPcB1Sxl863RoqjHZI5gvrUiiDNw",{"newer":344,"older":348},{"url":345,"title":346,"date":347},"\u002Fphp\u002F20190904\u002F1799668484\u002F","Day3-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料表篇","2019-09-04 09:02:58",{"url":349,"title":350,"date":351},"\u002Fphp\u002F20190902\u002F536097622\u002F","Day1-從基礎學習 ThinkPHP-介紹","2019-09-02 11:28:58",[353,358,362],{"url":354,"title":355,"date":356,"readingMinutes":357},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41","2",{"url":359,"title":360,"date":361,"readingMinutes":357},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個