[{"data":1,"prerenderedAt":864},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190904\u002F1799668484\u002F":3,"page:\u002Fphp\u002F20190904\u002F1799668484\u002F":4,"alt:\u002Fphp\u002F20190904\u002F1799668484\u002F":3,"prev-next:\u002Fphp\u002F20190904\u002F1799668484\u002F":840,"related:\u002Fphp\u002F20190904\u002F1799668484\u002F":849},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F04\u002Fthinkphp-day-03-mysql-tables\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":821,"date":822,"description":18,"extension":823,"lang":824,"meta":825,"navigation":826,"path":827,"readingMinutes":828,"seo":829,"standalone":830,"stem":831,"tags":832,"tldr":837,"updated":837,"url":838,"__hash__":839},"content\u002F從基礎學習 ThinkPHP\u002FDay3-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料表篇.md","Day3-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料表篇","1799668484",{"type":9,"value":10,"toc":809},"minimark",[11,15,19,22,25,148,158,161,168,171,324,327,371,374,419,425,432,438,444,447,454,463,469,474,477,487,512,517,523,529,542,564,567,573,576,582,602,607,614,620,623,629,632,638,663,668,671,676,679,682,687,690,693,698,701,704,805],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇我們已經學習了基礎的資料庫操作，但是資料庫底下還有一個東西叫做資料表，而資料表就是存放資料的地方，你可以把它想像成表格或是筆記本概念，所以這一篇就要來學習資料表的基礎 SQL 指令操作。",[12,20,21],{"id":21},"資料型態",[16,23,24],{},"學習資料表相關語法之前，我們必須先來認識一下常見的資料表的資料欄位型態有哪些，一般來講我個人常用的資料欄位型態有以下(以下僅列我常用的資料型態)：",[26,27,28,50,73,93,122,131],"ul",{},[29,30,31,35],"li",{},[32,33,34],"code",{},"VARCHAR",[26,36,37],{},[29,38,39,40,43,44,46,47,49],{},"另一個常見的是 ",[32,41,42],{},"CHAR","，但 ",[32,45,42],{}," 是屬於固定長度的字串，如果字串長度會變動的話建議使用 ",[32,48,34],{},"。",[29,51,52,55],{},[32,53,54],{},"TEXT",[26,56,57],{},[29,58,59,60,62,63,66,67,70,71,49],{},"最常見用於留言板上，但是除了 ",[32,61,54],{}," 還有另外兩個資料型態 ",[32,64,65],{},"MEDIUMTEXT","、",[32,68,69],{},"LOGNTEXT","，而我個人常用 ",[32,72,54],{},[29,74,75,78],{},[32,76,77],{},"INT",[26,79,80,83],{},[29,81,82],{},"正整數，就是沒有小數點的意思",[29,84,85,86,89,90,92],{},"另一個是 ",[32,87,88],{},"SMALLINT","，比較適合用於小數值的欄位，但是基本上我比較常用 ",[32,91,77],{}," (偷懶)。",[29,94,95,98],{},[32,96,97],{},"FLOAT",[26,99,100,103],{},[29,101,102],{},"浮點數，例如：3.14759....",[29,104,105,106,109,110,112,113,115,116,118,119,121],{},"還有另一個是 ",[32,107,108],{},"DOUBLE"," 與 ",[32,111,97],{}," 類同，但 ",[32,114,108],{}," 所消耗的空間是 ",[32,117,97],{}," 兩倍，因為精密度較高，但是一般來講使用 ",[32,120,97],{}," 就夠了。",[29,123,124,126],{},[32,125,42],{},[26,127,128],{},[29,129,130],{},"上面已經介紹過哩。",[29,132,133,136],{},[32,134,135],{},"TIMESTAMP",[26,137,138,145],{},[29,139,140,141,144],{},"時間戳，以 ",[32,142,143],{},"YYYY-MM-DD HH:MM:SS"," 格式作為時間戳記。",[29,146,147],{},"如果你沒特別去指定時間，它會自動依照目前的時間做紀錄。",[16,149,150,151,49],{},"以上只是僅列我使用過 & 常用的資料型態，如果你想更了解的資料型態的各種說明，我會建議可以看這一位前輩寫的文章會有更詳細的說明 → ",[152,153,157],"a",{"href":154,"rel":155},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10203456?sc=iThelpR",[156],"nofollow","常用的資料型態",[12,159,160],{"id":160},"建立資料表",[16,162,163,164,167],{},"首先我們在前一篇已經建立一個資料庫叫做 ",[32,165,166],{},"it_think_sql","，前面情景我們是使用銀行來做比喻，那這邊也是一樣。",[16,169,170],{},"一般來講銀行裡面都會有一個一個的小型保險櫃，如果你沒有做規劃的話，那就只是一個鐵盒而已，所以為了替將來要儲存進來的資料做好規劃，那麼我們就要新增一張資料表來保存資料，所以假設我們今天要建立一個班上同學的身高體重紀錄表，那就會使用以下的語法來建立資料表：",[172,173,178],"pre",{"className":174,"code":175,"language":176,"meta":177,"style":177},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE hw_table (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  weight int(5) NOT NULL default 0,\n  height float(5) NOT NULL default 0,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql","",[32,179,180,200,225,253,277,300,309],{"__ignoreMap":177},[181,182,185,189,192,196],"span",{"class":183,"line":184},"line",1,[181,186,188],{"class":187},"sWyjQ","CREATE",[181,190,191],{"class":187}," TABLE",[181,193,195],{"class":194},"sj_SG"," hw_table",[181,197,199],{"class":198},"sMAXC"," (\n",[181,201,203,206,209,212,216,219,222],{"class":183,"line":202},2,[181,204,205],{"class":198},"  id ",[181,207,208],{"class":187},"int",[181,210,211],{"class":198},"(",[181,213,215],{"class":214},"sCcAr","10",[181,217,218],{"class":198},") ",[181,220,221],{"class":187},"NOT NULL",[181,223,224],{"class":198}," auto_increment,\n",[181,226,228,231,234,236,239,241,243,246,250],{"class":183,"line":227},3,[181,229,230],{"class":187},"  name",[181,232,233],{"class":187}," varchar",[181,235,211],{"class":198},[181,237,238],{"class":214},"5",[181,240,218],{"class":198},[181,242,221],{"class":187},[181,244,245],{"class":187}," default",[181,247,249],{"class":248},"sTRMh"," ''",[181,251,252],{"class":198},",\n",[181,254,256,259,262,264,266,268,270,272,275],{"class":183,"line":255},4,[181,257,258],{"class":187},"  weight",[181,260,261],{"class":187}," int",[181,263,211],{"class":198},[181,265,238],{"class":214},[181,267,218],{"class":198},[181,269,221],{"class":187},[181,271,245],{"class":187},[181,273,274],{"class":214}," 0",[181,276,252],{"class":198},[181,278,280,283,286,288,290,292,294,296,298],{"class":183,"line":279},5,[181,281,282],{"class":198},"  height ",[181,284,285],{"class":187},"float",[181,287,211],{"class":198},[181,289,238],{"class":214},[181,291,218],{"class":198},[181,293,221],{"class":187},[181,295,245],{"class":187},[181,297,274],{"class":214},[181,299,252],{"class":198},[181,301,303,306],{"class":183,"line":302},6,[181,304,305],{"class":187},"  PRIMARY KEY",[181,307,308],{"class":198}," (id)\n",[181,310,312,315,318,321],{"class":183,"line":311},7,[181,313,314],{"class":198},") AUTO_INCREMENT",[181,316,317],{"class":187},"=",[181,319,320],{"class":214},"1",[181,322,323],{"class":198},";\n",[16,325,326],{},"看到一些陌生的東西時，莫帕莫驚慌，因為我會介紹，首先讓我們認識一下上面幾個英文單字 ↓",[26,328,329,334,340,346,355],{},[29,330,331,333],{},[32,332,221],{}," - 意旨此欄位不得為空。",[29,335,336,339],{},[32,337,338],{},"auto_increment"," - 自動填入。",[29,341,342,345],{},[32,343,344],{},"default"," - 預設值，後面就是預設的資料 or 值。",[29,347,348,351,352,49],{},[32,349,350],{},"PRIMARY KEY"," - 設置索引值，也就是 ",[32,353,354],{},"Key",[29,356,357,360,361,363,364,367,368,370],{},[32,358,359],{},"AUTO_INCREMENT"," - 自動遞增，並於數字 ",[32,362,320],{}," 開始，所以 ",[32,365,366],{},"id"," 欄位將會自己從 ",[32,369,320],{}," 開始計算。",[16,372,373],{},"※ 指令說明:",[172,375,377],{"className":174,"code":376,"language":176,"meta":177,"style":177},"CREATE TABLE  '資料表名稱' (\n  欄位名稱1 資料類型 欄位設定選項\n  欄位名稱2 資料類型 欄位設定選項\n  ...\n  索引 欄位\n)\n",[32,378,379,394,399,404,409,414],{"__ignoreMap":177},[181,380,381,383,385,388,391],{"class":183,"line":184},[181,382,188],{"class":187},[181,384,191],{"class":187},[181,386,387],{"class":198},"  '",[181,389,390],{"class":194},"資料表名稱",[181,392,393],{"class":198},"' (\n",[181,395,396],{"class":183,"line":202},[181,397,398],{"class":198},"  欄位名稱1 資料類型 欄位設定選項\n",[181,400,401],{"class":183,"line":227},[181,402,403],{"class":198},"  欄位名稱2 資料類型 欄位設定選項\n",[181,405,406],{"class":183,"line":255},[181,407,408],{"class":198},"  ...\n",[181,410,411],{"class":183,"line":279},[181,412,413],{"class":198},"  索引 欄位\n",[181,415,416],{"class":183,"line":302},[181,417,418],{"class":198},")\n",[16,420,421,422,424],{},"但是這邊要注意一件事情，在你執行上面 SQL 指令時，請務必確認自己正在 ",[32,423,166],{}," 底下，否則資料表極有可能建立在別的地方 or 無法建立唷!",[16,426,427],{},[428,429],"img",{"alt":430,"src":431},"SQL 執行位置","https:\u002F\u002Fi.imgur.com\u002FerNMyPr.png",[16,433,434,435,437],{},"當執行成功後就可以看到 ",[32,436,166],{}," 裡面多了一張資料表 ↓",[16,439,440],{},[428,441],{"alt":442,"src":443},"新增成功","https:\u002F\u002Fi.imgur.com\u002FcOM2FlW.png",[12,445,446],{"id":446},"查詢資料表欄位資訊",[16,448,449,450,453],{},"資料表也有與資料庫查詢清單類似的語法，最主要是用於查詢特定資料表欄位的資訊，讓我們來試著查詢剛剛新增的 ",[32,451,452],{},"hw_table"," 資料表欄位資訊看看：",[172,455,457],{"className":174,"code":456,"language":176,"meta":177,"style":177},"DESCRIBE hw_table;\n",[32,458,459],{"__ignoreMap":177},[181,460,461],{"class":183,"line":184},[181,462,456],{"class":198},[16,464,465,466],{},"※ 指令說明: ",[32,467,468],{},"DESCRIBE [資料表名稱];",[16,470,471],{},[428,472],{"alt":446,"src":473},"https:\u002F\u002Fi.imgur.com\u002FABIJq4u.png",[12,475,476],{"id":476},"更新資料表欄位",[16,478,479,480,483,484,486],{},"有建立資料表以及查詢資料表欄位，那麼就一定會有更新資料欄位的方式，假設我們要將資料欄位中的 ",[32,481,482],{},"weight"," 欄位改成 ",[32,485,285],{}," 的資料型態，那麼語法就會像下面這樣撰寫：",[172,488,490],{"className":174,"code":489,"language":176,"meta":177,"style":177},"ALTER TABLE hw_table CHANGE COLUMN weight weight float;\n",[32,491,492],{"__ignoreMap":177},[181,493,494,497,499,502,504,507,510],{"class":183,"line":184},[181,495,496],{"class":187},"ALTER",[181,498,191],{"class":187},[181,500,501],{"class":198}," hw_table CHANGE COLUMN ",[181,503,482],{"class":187},[181,505,506],{"class":187}," weight",[181,508,509],{"class":187}," float",[181,511,323],{"class":198},[16,513,465,514],{},[32,515,516],{},"ALTER TABLE [資料表名稱] CHANGE COLUMN [要修改的欄位名稱] [新的欄位名稱] [新的欄位型態];",[16,518,519,520,522],{},"接下來我們可以試著使用剛剛所學到的 ",[32,521,468],{}," 語法來看看資料欄位有沒有成功被修改 ↓",[16,524,525],{},[428,526],{"alt":527,"src":528},"修改結果","https:\u002F\u002Fi.imgur.com\u002FYALm6HV.png",[16,530,531,532,534,535,538,539,541],{},"同理，如果我們要更改名稱 ",[32,533,482],{}," → ",[32,536,537],{},"itweight"," 並且資料型態變成 ",[32,540,208],{},"，那麼只需要依照上面的語法來做變化即可達到需求：",[172,543,545],{"className":174,"code":544,"language":176,"meta":177,"style":177},"ALTER TABLE hw_table CHANGE COLUMN weight itweight int;\n",[32,546,547],{"__ignoreMap":177},[181,548,549,551,553,555,557,560,562],{"class":183,"line":184},[181,550,496],{"class":187},[181,552,191],{"class":187},[181,554,501],{"class":198},[181,556,482],{"class":187},[181,558,559],{"class":198}," itweight ",[181,561,208],{"class":187},[181,563,323],{"class":198},[16,565,566],{},"當然結果就會像我們預期的一樣 ↓",[16,568,569],{},[428,570],{"alt":571,"src":572},"修改成功","https:\u002F\u002Fi.imgur.com\u002FZMzMvsX.png",[12,574,575],{"id":575},"刪除資料表欄位",[16,577,578,579,581],{},"最後就是刪除資料欄位，假設我們要把剛剛修改的 ",[32,580,537],{}," 資料欄位刪除，那就會使用到刪除資料欄位語法，但是你會發現刪除語法與更新語法非常的相似，所以在使用時，請務必小心輸入(打錯字就 GG 了)：",[172,583,585],{"className":174,"code":584,"language":176,"meta":177,"style":177},"ALTER TABLE hw_table DROP COLUMN itweight;\n",[32,586,587],{"__ignoreMap":177},[181,588,589,591,593,596,599],{"class":183,"line":184},[181,590,496],{"class":187},[181,592,191],{"class":187},[181,594,595],{"class":198}," hw_table ",[181,597,598],{"class":187},"DROP",[181,600,601],{"class":198}," COLUMN itweight;\n",[16,603,465,604],{},[32,605,606],{},"ALTER TABLE [資料表名稱] DROP COLUMN [欄位名稱];",[16,608,609,610,613],{},"那我就直接使用 ",[32,611,612],{},"DESCRIBE hw_table;"," 來看執行後的結果，一般來講在 phpMyAdmin 執行該語法時，是會跳出提示訊息的唷 ↓",[16,615,616],{},[428,617],{"alt":618,"src":619},"提示訊息(圖中指令小寫請忽略)","https:\u002F\u002Fi.imgur.com\u002F0k3qdyb.png",[16,621,622],{},"原因我在前面有講過，刪除語法本身是一個非常危險的動作，所以它才會跟你確認　「你真的要刪除這個欄位嗎？」 ↓",[16,624,625],{},[428,626],{"alt":627,"src":628},"刪除成功(圖中指令小寫請忽略)","https:\u002F\u002Fi.imgur.com\u002FIbzyzLr.png",[12,630,631],{"id":631},"新增資料欄位",[16,633,634,635,637],{},"你會發現我將新增資料欄位語法放在後面，主要是為了展示建立資料表後，可以很順利地更新資料欄位 → 查詢欄位以及刪除資料欄位，那麼接下來就是介紹新增資料欄位的語法，你會發現新增資料欄位的語法與更新資料欄位語法也是非常相像，所以我這邊就不多說廢話直接上程式碼!讓我們把剛剛刪除的 ",[32,636,482],{}," 給復原吧~",[172,639,641],{"className":174,"code":640,"language":176,"meta":177,"style":177},"ALTER TABLE hw_table ADD COLUMN weight int;\n",[32,642,643],{"__ignoreMap":177},[181,644,645,647,649,651,654,657,659,661],{"class":183,"line":184},[181,646,496],{"class":187},[181,648,191],{"class":187},[181,650,595],{"class":198},[181,652,653],{"class":187},"ADD",[181,655,656],{"class":198}," COLUMN ",[181,658,482],{"class":187},[181,660,261],{"class":187},[181,662,323],{"class":198},[16,664,465,665],{},[32,666,667],{},"ALTER TABLE [資料表名稱] ADD COLUMN [欄位名稱] [資料型態];",[16,669,670],{},"那麼我們這樣就成功將剛剛被刪除的資料欄位新增回來囉~",[16,672,673],{},[428,674],{"alt":442,"src":675},"https:\u002F\u002Fi.imgur.com\u002FBKZ1Fh0.png",[12,677,678],{"id":678},"刪除資料表",[16,680,681],{},"老生常談這個語法很危險，所以請務必小心使用，那我這邊就不做示範，避免影響後面的章節操作，直接提供語法說明就可以囉~",[16,683,465,684],{},[32,685,686],{},"DROP TABLE [資料表名稱];",[12,688,689],{"id":689},"清空資料表",[16,691,692],{},"這個語法類似刪除，但是它主要是清空資料表內的所有資料，那麼由於我們目前資料表內並沒有塞入任何資料，所以就算執行了也不會有任何問題，只是執行該語法之後，它會保留資料表的資料結構以及欄位，簡單來講就是只有裡面的資料會消失而已：",[16,694,465,695],{},[32,696,697],{},"TRUNCATE TABLE [資料表名稱];",[12,699,700],{"id":700},"結尾",[16,702,703],{},"最後讓我們整理一下本篇所講到的 SQL 指令",[705,706,707,720],"table",{},[708,709,710],"thead",{},[711,712,713,717],"tr",{},[714,715,716],"th",{},"操作功能",[714,718,719],{},"SQL 語法",[721,722,723,731,741,761,773,787,796],"tbody",{},[711,724,725,728],{},[726,727,160],"td",{},[726,729,730],{},"CREATE TABLE '資料表名稱' (   欄位名稱1 資料類型 欄位設定選項   欄位名稱2 資料類型 欄位設定選項   ...   索引 欄位 )",[711,732,733,735],{},[726,734,446],{},[726,736,737,738,740],{},"DESCRIBE ",[181,739,390],{},";",[711,742,743,745],{},[726,744,476],{},[726,746,747,748,750,751,754,755,754,758,740],{},"ALTER TABLE ",[181,749,390],{}," CHANGE COLUMN ",[181,752,753],{},"要修改的欄位名稱"," ",[181,756,757],{},"新的欄位名稱",[181,759,760],{},"新的欄位型態",[711,762,763,765],{},[726,764,575],{},[726,766,747,767,769,770,740],{},[181,768,390],{}," DROP COLUMN ",[181,771,772],{},"欄位名稱",[711,774,775,778],{},[726,776,777],{},"新增資料表欄位",[726,779,747,780,782,783,754,785,740],{},[181,781,390],{}," ADD COLUMN ",[181,784,772],{},[181,786,21],{},[711,788,789,791],{},[726,790,678],{},[726,792,793,794,740],{},"DROP TABLE ",[181,795,390],{},[711,797,798,800],{},[726,799,689],{},[726,801,802,803,740],{},"TRUNCATE TABLE ",[181,804,390],{},[806,807,808],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var