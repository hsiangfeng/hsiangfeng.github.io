\n",[64,65,66],"h3",{"id":66},"查看框架版本號",[34,68,70],{"className":36,"code":69,"language":38,"meta":39,"style":39},"php think version\n",[26,71,72],{"__ignoreMap":39},[43,73,74,76,78],{"class":45,"line":46},[43,75,38],{"class":49},[43,77,52],{"class":49},[43,79,80],{"class":49}," version\n",[16,82,83],{},[84,85],"img",{"alt":86,"src":87},"框架版本號","https:\u002F\u002Fi.imgur.com\u002Fy5grdMh.png",[64,89,91],{"id":90},"查看-think-控制台版本號","查看 Think 控制台版本號",[34,93,95],{"className":36,"code":94,"language":38,"meta":39,"style":39},"php think -V\n",[26,96,97],{"__ignoreMap":39},[43,98,99,101,103,107],{"class":45,"line":46},[43,100,38],{"class":49},[43,102,52],{"class":49},[43,104,106],{"class":105},"sWyjQ"," -",[43,108,109],{"class":49},"V\n",[16,111,112],{},[84,113],{"alt":114,"src":115},"控制台版本號","https:\u002F\u002Fi.imgur.com\u002F05fCjzc.png",[16,117,118,119,122,123,126],{},"這邊要注意 ",[26,120,121],{},"-V"," ≠ ",[26,124,125],{},"version"," 這是兩種不同的東西",[64,128,129],{"id":129},"開啟本地伺服器",[34,131,133],{"className":36,"code":132,"language":38,"meta":39,"style":39},"php think run\n",[26,134,135],{"__ignoreMap":39},[43,136,137,139,141],{"class":45,"line":46},[43,138,38],{"class":49},[43,140,52],{"class":49},[43,142,143],{"class":49}," run\n",[16,145,146],{},"這個就不用多作介紹了，前面章節非常常使用，當你執行後就會開啟一個本地端伺服器。",[64,148,149],{"id":149},"清理暫存",[34,151,153],{"className":36,"code":152,"language":38,"meta":39,"style":39},"php think clear\n",[26,154,155],{"__ignoreMap":39},[43,156,157,159,161],{"class":45,"line":46},[43,158,38],{"class":49},[43,160,52],{"class":49},[43,162,163],{"class":49}," clear\n",[16,165,166,169,170,173],{},[26,167,168],{},"clear"," 會清除 ",[26,171,172],{},"runtime"," 資料夾內所有檔案。",[64,175,177],{"id":176},"建立-controller","建立 Controller",[34,179,181],{"className":36,"code":180,"language":38,"meta":39,"style":39},"php think make:controller [路徑]\n",[26,182,183],{"__ignoreMap":39},[43,184,185,187,189,192,195,198,200,203],{"class":45,"line":46},[43,186,38],{"class":49},[43,188,52],{"class":49},[43,190,191],{"class":49}," make",[43,193,194],{"class":55},":",[43,196,197],{"class":49},"controller",[43,199,56],{"class":55},[43,201,202],{"class":49},"路徑",[43,204,62],{"class":55},[16,206,207,208,211,212,215],{},"這個指令後面只要帶上路徑，就可以自動生成了，例如 ",[26,209,210],{},"message\u002Findex","，它就會建立一個 message 資料夾，然後底下有 ",[26,213,214],{},"controller\u002Findex.php","。",[64,217,219],{"id":218},"建立-model","建立 Model",[34,221,223],{"className":36,"code":222,"language":38,"meta":39,"style":39},"php think make:MODEL [路徑]\n",[26,224,225],{"__ignoreMap":39},[43,226,227,229,231,233,235,238,240,242],{"class":45,"line":46},[43,228,38],{"class":49},[43,230,52],{"class":49},[43,232,191],{"class":49},[43,234,194],{"class":55},[43,236,237],{"class":49},"MODEL",[43,239,56],{"class":55},[43,241,202],{"class":49},[43,243,62],{"class":55},[16,245,246],{},"與建立 Controller 的狀況是一樣的。",[64,248,249],{"id":249},"查看目前所有路由",[34,251,253],{"className":36,"code":252,"language":38,"meta":39,"style":39},"php think route:list\n",[26,254,255],{"__ignoreMap":39},[43,256,257,259,261,264,266],{"class":45,"line":46},[43,258,38],{"class":49},[43,260,52],{"class":49},[43,262,263],{"class":49}," route",[43,265,194],{"class":55},[43,267,268],{"class":49},"list\n",[16,270,271],{},"執行後你可以看到所有已經註冊的路由 ↓",[16,273,274],{},[84,275],{"alt":276,"src":277},"所有路由","https:\u002F\u002Fi.imgur.com\u002FQN7XoDU.png",[64,279,280],{"id":280},"列出所有指令",[34,282,284],{"className":36,"code":283,"language":38,"meta":39,"style":39},"php think\n",[26,285,286],{"__ignoreMap":39},[43,287,288,290],{"class":45,"line":46},[43,289,38],{"class":49},[43,291,292],{"class":49}," think\n",[16,294,295],{},[84,296],{"alt":297,"src":298},"所有指令","https:\u002F\u002Fi.imgur.com\u002FCqxKF1o.png",[12,300,301],{"id":301},"資料庫遷移",[16,303,304,305,308,309,311,312,314],{},"接下來這邊會稍微介紹一下 ThinkPHP 中其中一個擴展包，也就是 ",[26,306,307],{},"think-migration","，",[26,310,307],{}," 主要是幫助我們轉移資料庫，但是如果要使用的話，必須先透過 composer 安裝，那為什麼會特別講到 ",[26,313,307],{}," 呢?最主要是以往我們轉移資料庫時，大多都是使用 SQL 檔來轉移 ↓",[16,316,317],{},[84,318],{"alt":319,"src":320},"SQL","https:\u002F\u002Fi.imgur.com\u002FEExhNv0.png",[16,322,323,324,326,327,329,330,332,333,335],{},"但是對於 ",[26,325,307],{}," 不用太過於害怕，因為 ",[26,328,307],{}," 就是資料庫，一般來講我們對於資料庫是沒有辦法使用 SQL 來做版本控制，所以 ",[26,331,307],{}," 是會加入 Git 版本控制的，而且如果今天需求如果從 MySQL 轉到別的資料庫也不用太擔心，通常只需要微調一下就可以哩，那麼就先讓我們來安裝 ",[26,334,307],{}," 吧：",[34,337,339],{"className":36,"code":338,"language":38,"meta":39,"style":39},"composer require topthink\u002Fthink-migration=2.0.*\n",[26,340,341],{"__ignoreMap":39},[43,342,343,346,349,352,355,358,361,364,367,370,373],{"class":45,"line":46},[43,344,345],{"class":49},"composer",[43,347,348],{"class":105}," require",[43,350,351],{"class":49}," topthink",[43,353,354],{"class":105},"\u002F",[43,356,357],{"class":49},"think",[43,359,360],{"class":105},"-",[43,362,363],{"class":49},"migration",[43,365,366],{"class":105},"=",[43,368,369],{"class":49},"2.0",[43,371,372],{"class":105},".",[43,374,375],{"class":105},"*\n",[16,377,378],{},[84,379],{"alt":307,"src":380},"https:\u002F\u002Fi.imgur.com\u002F84ZHLIc.png",[16,382,383,384,387,388,390],{},"注意接下來操作請務必設定好 database.php，否則會無法操作，接下來我們可以使用 ",[26,385,386],{},"php think"," 來看看 ",[26,389,307],{}," 有哪些指令 ↓",[16,392,393],{},[84,394],{"alt":363,"src":395},"https:\u002F\u002Fi.imgur.com\u002FMxirz1P.png",[16,397,398,399,402,403,402,406,402,409,402,412,402,415,418,419,421],{},"接下來我們要將我們的資料庫做遷移的動作，基本上我們有六張資料表，分別為 ",[26,400,401],{},"hw_table","、",[26,404,405],{},"think_account",[26,407,408],{},"think_db",[26,410,411],{},"think_message",[26,413,414],{},"think_new_user",[26,416,417],{},"think_user","，但是這邊要注意一件事情，我們在建立遷移資料表的時候，必須首字大寫，並採用駝峰制，拿 ",[26,420,401],{}," 做舉例，那指令就會是：",[34,423,425],{"className":36,"code":424,"language":38,"meta":39,"style":39},"php think migrate:create HwTable\n",[26,426,427],{"__ignoreMap":39},[43,428,429,431,433,436,438,441],{"class":45,"line":46},[43,430,38],{"class":49},[43,432,52],{"class":49},[43,434,435],{"class":49}," migrate",[43,437,194],{"class":55},[43,439,440],{"class":49},"create",[43,442,443],{"class":49}," HwTable\n",[16,445,446],{},"所以由此可知我們六張資料表的建立遷移的指令如下：",[34,448,450],{"className":36,"code":449,"language":38,"meta":39,"style":39},"php think migrate:create HwTable\nphp think migrate:create ThinkAccount\nphp think migrate:create ThinkDb\nphp think migrate:create ThinkMessage\nphp think migrate:create ThinkNewUser\nphp think migrate:create ThinkUser\n",[26,451,452,466,482,498,514,530],{"__ignoreMap":39},[43,453,454,456,458,460,462,464],{"class":45,"line":46},[43,455,38],{"class":49},[43,457,52],{"class":49},[43,459,435],{"class":49},[43,461,194],{"class":55},[43,463,440],{"class":49},[43,465,443],{"class":49},[43,467,469,471,473,475,477,479],{"class":45,"line":468},2,[43,470,38],{"class":49},[43,472,52],{"class":49},[43,474,435],{"class":49},[43,476,194],{"class":55},[43,478,440],{"class":49},[43,480,481],{"class":49}," ThinkAccount\n",[43,483,485,487,489,491,493,495],{"class":45,"line":484},3,[43,486,38],{"class":49},[43,488,52],{"class":49},[43,490,435],{"class":49},[43,492,194],{"class":55},[43,494,440],{"class":49},[43,496,497],{"class":49}," ThinkDb\n",[43,499,501,503,505,507,509,511],{"class":45,"line":500},4,[43,502,38],{"class":49},[43,504,52],{"class":49},[43,506,435],{"class":49},[43,508,194],{"class":55},[43,510,440],{"class":49},[43,512,513],{"class":49}," ThinkMessage\n",[43,515,517,519,521,523,525,527],{"class":45,"line":516},5,[43,518,38],{"class":49},[43,520,52],{"class":49},[43,522,435],{"class":49},[43,524,194],{"class":55},[43,526,440],{"class":49},[43,528,529],{"class":49}," ThinkNewUser\n",[43,531,533,535,537,539,541,543],{"class":45,"line":532},6,[43,534,38],{"class":49},[43,536,52],{"class":49},[43,538,435],{"class":49},[43,540,194],{"class":55},[43,542,440],{"class":49},[43,544,545],{"class":49}," ThinkUser\n",[16,547,548],{},"所以我們會有這幾張遷移檔案 ↓",[16,550,551],{},[84,552],{"alt":553,"src":554},"遷移檔案","https:\u002F\u002Fi.imgur.com\u002FEab23kZ.png",[16,556,557,558,561],{},"建立完成後可以輸入 ",[26,559,560],{},"php think migrate:status"," 來看間一資料檔案狀況如何 ↓",[16,563,564],{},[84,565],{"alt":566,"src":567},"migrate:status","https:\u002F\u002Fi.imgur.com\u002FJzcaKY1.png",[16,569,570],{},"另外如果你是參照本篇操作也是使用 XAMPP 的話，應該會出現以下錯誤：",[34,572,576],{"className":573,"code":574,"language":575,"meta":39,"style":39},"language-sql shiki shiki-themes github-dark-high-contrast","[InvalidArgumentException]\nThere was a problem creating the schema table: SQLSTATE[42000]: Syntax error or acce\nss violation: 1067 Invalid default value for 'end_time'\n","sql",[26,577,578,583,603],{"__ignoreMap":39},[43,579,580],{"class":45,"line":46},[43,581,582],{"class":55},"[InvalidArgumentException]\n",[43,584,585,588,591,594,597,600],{"class":45,"line":468},[43,586,587],{"class":55},"There was a problem creating the ",[43,589,590],{"class":105},"schema",[43,592,593],{"class":105}," table",[43,595,596],{"class":55},": SQLSTATE[42000]: Syntax error ",[43,598,599],{"class":105},"or",[43,601,602],{"class":55}," acce\n",[43,604,605,608,611,614,617,620,623],{"class":45,"line":484},[43,606,607],{"class":55},"ss violation: ",[43,609,610],{"class":49},"1067",[43,612,613],{"class":55}," Invalid ",[43,615,616],{"class":105},"default",[43,618,619],{"class":105}," value",[43,621,622],{"class":105}," for",[43,624,626],{"class":625},"sTRMh"," 'end_time'\n",[16,628,629,630,633],{},"這個問題你只需要打開 ",[26,631,632],{},"my.ini"," 進入設定檔 ↓",[16,635,636],{},[84,637],{"alt":632,"src":638},"https:\u002F\u002Fi.imgur.com\u002FuM68JPF.png",[16,640,641,642,645,646,649,650,653],{},"接下來搜尋 ",[26,643,644],{},"sql_mode","，將原本的 ",[26,647,648],{},"sql_mode=NO_ZERO_IN_DATE,NO_ZERO_DATE,NO_ENGINE_SUBSTITUTION"," 修改成 ",[26,651,652],{},"sql_mode="," 然後重啟即可解決~",[16,655,656],{},[84,657],{"alt":632,"src":658},"https:\u002F\u002Fi.imgur.com\u002FpO525Sj.png",[64,660,662],{"id":661},"migration-檔案","migration 檔案",[16,664,665,666,669],{},"剛剛建立的 migration 預設內容非常空虛，你只會看到裡面只有 ",[26,667,668],{},"change()"," ↓",[16,671,672],{},[84,673],{"alt":674