783,785],"h3",{"id":784},"cssjs-檔案不見","CSS、JS 檔案不見",[16,787,788,789,792,793,796],{},"主要原因是原本在 ",[50,790,791],{},"public\u002Fstatic"," 底下有一個 ",[50,794,795],{},".gitignore","，將它刪除後重新佈署 Heroku 就解決了。",[782,798,800],{"id":799},"數據填充後發生-call-to-undefined-function-mb_substr","數據填充後發生 Call to undefined function mb_substr()",[16,802,803,804,807,808,811],{},"只需要打開 composer.json，然後在 ",[50,805,806],{},"require"," 中加入 ",[50,809,810],{},"\"mbstring\": \"*\""," 再重新佈署就可以了，那這個原因是 Heroku 環境沒有這個擴充，所以我們要透過 composer.json 來靠知 Heroku 我們需要這個東東。",[16,813,814,815,817,818,821,822,825],{},"加入 ",[50,816,810],{}," 後記得執行一下 ",[50,819,820],{},"composer update"," 否則你 ",[50,823,824],{},"push"," 上 Heroku 是沒有效果的。",[782,827,828],{"id":828},"驗證碼消失",[16,830,831],{},"你應該會發現驗證碼無法出現 ↓",[16,833,834],{},[82,835],{"alt":828,"src":836},"https:\u002F\u002Fi.imgur.com\u002Fc7K71c6.png",[16,838,839,840,843],{},"而且訪問驗證碼路徑時會出現這個錯誤訊息 ",[50,841,842],{},"Call to undefined function think\\captcha\\imagecreate()","。",[16,845,846,847,807,849,852],{},"解決方法是在 composer.json，然後在 ",[50,848,806],{},[50,850,851],{},"\"ext-gd\": \"*\""," 即可解決 ↓",[16,854,855],{},[82,856],{"alt":857,"src":858},"成功顯示驗證碼","https:\u002F\u002Fi.imgur.com\u002FRwoJQ8k.png",[782,860,861],{"id":861},"新增文章沒有新增時間",[16,863,864,865,868,869,871,872,875,876,878],{},"由於 ",[50,866,867],{},"only one TIMESTAMP column with CURRENT_TIMESTAMP in DEFAULT or ON UPDATE clause"," 的關係，所以我們無法透過 ",[50,870,396],{}," 自動取得建立時間，所以我針對儲存文章的方法，也就是 ",[50,873,874],{},"save()"," 做了微調，只需要在 ",[50,877,874],{}," 的方法修改成這樣即可：",[43,880,882],{"className":238,"code":881,"language":240,"meta":48,"style":48},"\npublic function save()\n{\n    if(!Session::get('id')) {\n        Session::flash('error', '請登入後在操作此動作。');\n        return $this->redirect('\u002Fmessage\u002Fuser\u002Flogin');\n    }\n    $content = new indexModel();\n    $contentData = input();\n    $content->create_time = date('Y-m-d H:i:s'); \u002F\u002F 主要加入這一行即可加入建立時間\n    $content->email = Session::get('email');\n    if($content->a