[{"data":1,"prerenderedAt":1270},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20191001\u002F106986397\u002F":3,"page:\u002Fphp\u002F20191001\u002F106986397\u002F":4,"alt:\u002Fphp\u002F20191001\u002F106986397\u002F":3,"prev-next:\u002Fphp\u002F20191001\u002F106986397\u002F":1246,"related:\u002Fphp\u002F20191001\u002F106986397\u002F":1255},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1228,"date":1229,"description":18,"extension":1230,"lang":1231,"meta":1232,"navigation":888,"path":1233,"readingMinutes":1234,"seo":1235,"standalone":1236,"stem":1237,"tags":1238,"tldr":1243,"updated":1243,"url":1244,"__hash__":1245},"content\u002F從基礎學習 ThinkPHP\u002FDay30-從基礎學習-ThinkPHP-部屬 Heroku.md","Day30-從基礎學習 ThinkPHP-部屬 Heroku","106986397",{"type":9,"value":10,"toc":1214},"minimark",[11,15,19,23,26,35,39,42,72,79,86,93,98,109,115,122,132,135,154,161,167,170,179,185,191,196,203,209,212,223,230,233,236,284,291,391,409,750,756,762,769,775,778,781,786,797,801,812,826,829,832,837,844,853,859,862,879,1158,1161,1164,1167,1173,1180,1187,1194,1202,1210],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來這一篇將會介紹如何將我們前面章節所做好的 ThinkPHP 系統部屬到 Heroku 囉~",[12,20,22],{"id":21},"heroku","Heroku",[16,24,25],{},"Heroku 算是滿多人愛用的服務，我個人也很愛用，但是這邊就不多做介紹，畢竟滿多人已經介紹過了，所以我就直接提供其他前輩寫的相關參考文章囉~",[16,27,28],{},[29,30,34],"a",{"href":31,"rel":32},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10196129",[33],"nofollow","發布網站到 Heroku",[12,36,38],{"id":37},"thinkphp-部屬-heroku","ThinkPHP 部屬 Heroku",[16,40,41],{},"首先移動到專案目錄下分別輸入以下指令：",[43,44,49],"pre",{"className":45,"code":46,"language":47,"meta":48,"style":48},"language-git shiki shiki-themes github-dark-high-contrast","git init\ngit add .\ngit commit -m 'first'\n","git","",[50,51,52,60,66],"code",{"__ignoreMap":48},[53,54,57],"span",{"class":55,"line":56},"line",1,[53,58,59],{},"git init\n",[53,61,63],{"class":55,"line":62},2,[53,64,65],{},"git add .\n",[53,67,69],{"class":55,"line":68},3,[53,70,71],{},"git commit -m 'first'\n",[16,73,74,75,78],{},"我們要先建立一個 Heroku 主機，新增的指令是 ",[50,76,77],{},"heroku create","(注意這個步驟請在專案目錄下操作) ↓",[16,80,81],{},[82,83],"img",{"alt":84,"src":85},"建立主機","https:\u002F\u002Fi.imgur.com\u002FUZ9k3Cr.png",[16,87,88,89,92],{},"此時我們可以在 Heroku 後台看到剛剛建立叫 ",[50,90,91],{},"obscure-mountain-83772"," 的主機 ↓",[16,94,95],{},[82,96],{"alt":91,"src":97},"https:\u002F\u002Fi.imgur.com\u002Fivm7sfm.png",[16,99,100,101,104,105,108],{},"接下來只需要輸入 ",[50,102,103],{},"git push heroku master"," 就會被部屬上去到 Heroku，但是這時候你若訪問網址應該會出現 ",[50,106,107],{},"403 Forbidden"," ↓",[16,110,111],{},[82,112],{"alt":113,"src":114},"403","https:\u002F\u002Fi.imgur.com\u002FItVtgWy.png",[16,116,117,118,121],{},"這個問題是 Heorku　我們並沒有將預設路徑改為 public 資料夾，所以接下來再專案根目錄底下建立一個檔案叫 ",[50,119,120],{},"Procfile","，內容填入：",[43,123,126],{"className":124,"code":125,"language":120,"meta":48,"style":48},"language-Procfile shiki shiki-themes github-dark-high-contrast","web: vendor\u002Fbin\u002Fheroku-php-apache2 public\n",[50,127,128],{"__ignoreMap":48},[53,129,130],{"class":55,"line":56},[53,131,125],{},[16,133,134],{},"接下來在執行以下動作即可：",[43,136,138],{"className":45,"code":137,"language":47,"meta":48,"style":48},"git add .\ngit commit -m \"add to procfile\"\ngit push heroku master\n",[50,139,140,144,149],{"__ignoreMap":48},[53,141,142],{"class":55,"line":56},[53,143,65],{},[53,145,146],{"class":55,"line":62},[53,147,148],{},"git commit -m \"add to procfile\"\n",[53,150,151],{"class":55,"line":68},[53,152,153],{},"git push heroku master\n",[16,155,156,157,160],{},"這時候我們訪問 ",[50,158,159],{},"https:\u002F\u002Fobscure-mountain-83772.herokuapp.com\u002F"," 就可以看到 ThinkPHP 了 ↓",[16,162,163],{},[82,164],{"alt":165,"src":166},"ThinkPHP","https:\u002F\u002Fi.imgur.com\u002Fztxt2vq.png",[12,168,169],{"id":169},"建立資料庫",[16,171,172,173,178],{},"接下來這時候我們 ",[29,174,177],{"href":175,"rel":176},"https:\u002F\u002Fobscure-mountain-83772.herokuapp.com\u002Fmessage\u002F",[33],"訪問留言板"," 的頁面會發生錯誤 ↓",[16,180,181],{},[82,182],{"alt":183,"src":184},"錯誤訊息","https:\u002F\u002Fi.imgur.com\u002Fg2Dpgwx.png",[16,186,187,188,108],{},"這是因為我們還沒建立資料庫導致，所以我們要來建立資料庫，首先輸入 heroku 建立資料庫的指令 ",[50,189,190],{},"heroku addons:add cleardb",[16,192,193],{},[82,194],{"alt":169,"src":195},"https:\u002F\u002Fi.imgur.com\u002FxXQAOxZ.png",[16,197,198,199,202],{},"接下來輸入 ",[50,200,201],{},"heroku config"," 查看資料庫相關位址 ↓",[16,204,205],{},[82,206],{"alt":207,"src":208},"config","https:\u002F\u002Fi.imgur.com\u002FVGzbjNj.png",[16,210,211],{},"這一串的意思如下：",[43,213,217],{"className":214,"code":215,"language":216,"meta":48,"style":48},"language-mysql shiki shiki-themes github-dark-high-contrast","mysql:\u002F\u002F[username]:[password]@[host]\u002F[database name]?reconnect=true\n","mysql",[50,218,219],{"__ignoreMap":48},[53,220,221],{"class":55,"line":56},[53,222,215],{},[16,224,225,226,229],{},"所以依照上述將相關資料填入至專案 ",[50,227,228],{},"config\u002Fdatabase.php"," 中，然後再重新 push 這樣就完成哩~",[12,231,232],{"id":232},"遷移資料庫",[16,234,235],{},"接下來我們必須將資料表與預設資料給加入到資料庫內，這時候就會使用前一篇所學的 migration、seeds，這時候只需要在指令視窗分別輸入：",[43,237,241],{"className":238,"code":239,"language":240,"meta":48,"style":48},"language-php shiki shiki-themes github-dark-high-contrast","heroku run php think migrate:run\nheroku run php think seed:run\n","php",[50,242,243,267],{"__ignoreMap":48},[53,244,245,248,251,254,257,260,264],{"class":55,"line":56},[53,246,21],{"class":247},"sCcAr",[53,249,250],{"class":247}," run",[53,252,253],{"class":247}," php",[53,255,256],{"class":247}," think",[53,258,259],{"class":247}," migrate",[53,261,263],{"class":262},"sMAXC",":",[53,265,266],{"class":247},"run\n",[53,268,269,271,273,275,277,280,282],{"class":55,"line":62},[53,270,21],{"class":247},[53,272,250],{"class":247},[53,274,253],{"class":247},[53,276,256],{"class":247},[53,278,279],{"class":247}," seed",[53,281,263],{"class":262},[53,283,266],{"class":247},[16,285,286,287,290],{},"但是你輸入 ",[50,288,289],{},"heroku run php think migrate:run"," 應該會發生以下錯誤：",[43,292,294],{"className":238,"code":293,"language":240,"meta":48,"style":48},"  [PDOException]\n  SQLSTATE[HY000]: General error: 1293 Incorrect table definition; there can be only one TIMESTAMP column with CURRENT_TIMESTAMP in DEFAULT or ON UPDATE clause\n",[50,295,296,307],{"__ignoreMap":48},[53,297,298,301,304],{"class":55,"line":56},[53,299,300],{"class":262},"  [",[53,302,303],{"class":247},"PDOException",[53,305,306],{"class":262},"]\n",[53,308,309,312,315,318,321,324,327,330,333,336,339,342,345,348,351,354,357,360,363,366,369,372,375,378,382,385,388],{"class":55,"line":62},[53,310,311],{"class":247},"  SQLSTATE",[53,313,314],{"class":262},"[",[53,316,317],{"class":247},"HY000",[53,319,320],{"class":262},"]: ",[53,322,323],{"class":247},"General",[53,325,326],{"class":247}," error",[53,328,329],{"class":262},": ",[53,331,332],{"class":247},"1293",[53,334,335],{"class":247}," Incorrect",[53,337,338],{"class":247}," table",[53,340,341],{"class":247}," definition",[53,343,344],{"class":262},"; ",[53,346,347],{"class":247},"there",[53,349,350],{"class":247}," can",[53,352,353],{"class":247}," be",[53,355,356],{"class":247}," only",[53,358,359],{"class":247}," one",[53,361,362],{"class":247}," TIMESTAMP",[53,364,365],{"class":247}," column",[53,367,368],{"class":247}," with",[53,370,371],{"class":247}," CURRENT_TIMESTAMP",[53,373,374],{"class":247}," in",[53,376,377],{"class":247}," DEFAULT",[53,379,381],{"class":380},"sWyjQ"," or",[53,383,384],{"class":247}," ON",[53,386,387],{"class":247}," UPDATE",[53,389,390],{"class":247}," clause\n",[16,392,393,394,397,398,401,402,405,406,408],{},"這個原因是出在資料庫內只能有一個 ",[50,395,396],{},"CURRENT_TIMESTAMP","，所以要修改一下 ",[50,399,400],{},"think_message","，由於預設 phinx 的 ",[50,403,404],{},"timestamp"," 格式是默認 ",[50,407,396],{},"，所以要改成這樣：",[43,410,412],{"className":238,"code":411,"language":240,"meta":48,"style":48},"public function up()\n{\n    $table = $this->table('message');\n    $table->addColumn('ti