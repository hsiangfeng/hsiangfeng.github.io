[{"data":1,"prerenderedAt":725},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190925\u002F1108470009\u002F":3,"page:\u002Fphp\u002F20190925\u002F1108470009\u002F":4,"alt:\u002Fphp\u002F20190925\u002F1108470009\u002F":3,"prev-next:\u002Fphp\u002F20190925\u002F1108470009\u002F":702,"related:\u002Fphp\u002F20190925\u002F1108470009\u002F":711},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":684,"date":685,"description":18,"extension":686,"lang":687,"meta":688,"navigation":63,"path":689,"readingMinutes":690,"seo":691,"standalone":692,"stem":693,"tags":694,"tldr":699,"updated":699,"url":700,"__hash__":701},"content\u002F從基礎學習 ThinkPHP\u002FDay24-從基礎學習-ThinkPHP-表單驗證-2.md","Day24-從基礎學習 ThinkPHP-表單驗證(2)","1108470009",{"type":9,"value":10,"toc":678},"minimark",[11,15,19,22,25,238,241,248,275,278,455,466,472,479,485,488,494,500,506,509,512,580,587,638,649,652,671,674],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇我們已經將基礎的表單驗證給完成，但是其實只介紹一半，所以我將文章拆成了兩個部分，接下來讓我們繼續學習表單驗證吧!",[12,20,21],{"id":21},"傳送表單錯誤訊息至前端",[16,23,24],{},"首先先讓我們回顧一下前一篇我們所撰寫的程式碼寫到哪裡：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-php shiki shiki-themes github-dark-high-contrast","protected $batchValidate = true;\n\npublic function add() {\n    $user = new userModel;\n    $userData = input();\n    $result = $this->validate($userData, 'User');\n    if(true !== $result) {\n        return json($result);\n    }\n    if($user->save($userData)){\n        return '新增成功';\n    } else {\n        return $user->getError();\n    }\n}\n","php","",[33,34,35,58,65,81,97,111,138,156,168,174,190,200,212,227,232],"code",{"__ignoreMap":31},[36,37,40,44,48,51,55],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sWyjQ","protected",[36,45,47],{"class":46},"sMAXC"," $batchValidate ",[36,49,50],{"class":42},"=",[36,52,54],{"class":53},"sCcAr"," true",[36,56,5