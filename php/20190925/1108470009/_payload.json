},[36,435,436,438,440,442,444],{"class":38,"line":229},[36,437,161],{"class":42},[36,439,219],{"class":46},[36,441,124],{"class":42},[36,443,224],{"class":76},[36,445,110],{"class":46},[36,447,448],{"class":38,"line":234},[36,449,173],{"class":46},[36,451,453],{"class":38,"line":452},16,[36,454,237],{"class":46},[16,456,457,458,461,462,465],{},"接下來就可以直接去前端模板渲染錯誤訊息，如果要在 HTML 上渲染 ",[33,459,460],{},"Session"," 的方式是使用 ",[33,463,464],{},"{$Request.session.xxx}","，那資料會是一個物件，所以我們必須指定名稱，否則會出現錯誤，那該如何指定呢?我們前面有將錯誤訊息轉成 JSON 輸出在畫面上過 ↓",[16,467,468],{},[244,469],{"alt":470,"src":471},"JSON","https:\u002F\u002Fi.imgur.com\u002F8cZ3kLk.png",[16,473,474,475,478],{},"所以我們就要這樣填 ",[33,476,477],{},"{$Request.session.error.email}","，其他錯誤訊息以此類推，結果就會像這樣 ↓",[16,480,481],{},[244,482],{"alt":483,"src":484},"HTML","https:\u002F\u002Fi.imgur.com\u002FRVM6eHc.png",[16,486,487],{},"接下來讓我們重新整理一下畫面，然後只填寫 Email 欄位就送出表單看會發生何事 ↓",[16,489,490],{},[244,491],{"alt":492,"src":493},"錯誤訊息","https:\u002F\u002Fi.imgur.com\u002FW5zYyaU.png",[16,495,496,497,499],{},"那由於 ",[33,498,269],{}," 好處就是使用一次就會被刪除的特性，所以我們只要按一下 F5 錯誤訊息就永遠不存在了~~ ↓",[16,501,502],{},[244,503],{"alt":504,"src":505},"一去不復返","https:\u002F\u002Fi.imgur.com\u002FSsSUgNZ.png",[12,507,508],{"id":508},"簡化模板輸出",[16,510,511],{},"另外這邊有一個地方可以簡化撰寫，我在前面並沒有提供程式碼，原本顯示註冊控制器的方法是這樣撰寫：",[26,513,515],{"className":28,"code":514,"language":30,"meta":31,"style":31},"public function getSignup()\n{\n    $this->assign(\"title\", \"註冊頁面\");\n    return $this->fetch('signup');\n}\n",[33,516,517,529,534,557,576],{"__ignoreMap":31},[36,518,519,521,523,526],{"class":38,"line":39},[36,520,70],{"class":42},[36,522,73],{"class":42},[36,524,525],{"class":76}," getSignup",[36,527,528],{"class":46},"()\n",[36,530,531],{"class":38,"line":60},[36,532,533],{"class":46},"{\n",[36,535,536,539,541,544,546,549,552,555],{"class":38,"line":67},[36,537,538],{"class":53},"    $this",[36,540,124],{"class":42},[36,542,543],{"class":76},"assign",[36,545,146],{"class":46},[36,547,548],{"class":133},"\"title\"",[36,550,551],{"class":46},", ",[36,553,554],{"class":133},"\"註冊頁面\"",[36,556,137],{"class":46},[36,558,559,562,564,566,569,571,574],{"class":38,"line":83},[36,560,561],{"class":42},"    return",[36,563,121],{"class":53},[36,565,124],{"class":42},[36,567,568],{"class":76},"fetch",[36,570,146],{"class":46},[36,572,573],{"class":133},"'signup'",[36,575,137],{"class":46},[36,577,578],{"class":38,"line":99},[36,579,237],{"class":46},[16,581,582,583,586],{},"這邊 ThinkPHP 提供了一個叫做快捷函數的方法，可以幫助我們快速的渲染指定模板，也就是 ",[33,584,585],{},"View()"," 方法，所以我們可以簡化成這樣：",[26,588,590],{"className":28,"code":589,"language":30,"meta":31,"style":31},"public function getSignup()\n{\n    return View('signup')->assign(\"title\", \"註冊頁面\");\n}\n",[33,591,592,602,606,634],{"__ignoreMap":31},[36,593,594,596,598,600],{"class":38,"line":39},[36,595,70],{"class":42},[36,597,73],{"class":42},[36,599,525],{"class":76},[36,601,528],{"class":46},[36,603,604],{"class":38,"line":60},[36,605,533],{"class":46},[36,607,608,610,613,615,617,620,622,624,626,628,630,632],{"class":38,"line":67},[36,609,561],{"class":42},[36,611,612],{"class":76}," View",[36,614,146],{"class":46},[36,616,573],{"class":133},[36,618,619],{"class":46},")",[36,621,124],{"class":42},[36,623,543],{"class":76},[36,625,146],{"class":46},[36,627,548],{"class":133},[36,629,551],{"class":46},[36,631,554],{"class":133},[36,633,137],{"class":46},[36,635,636],{"class":38,"line":83},[36,637,237],{"class":46},[16,639,640,641,644,645,648],{},"不要懷疑就是這麼簡化，只需要一行就可以輸出資料到我們要模板，如果不想要用這種寫法 ",[33,642,643],{},"$this->fetch('signup');","，則也可以改用 ",[33,646,647],{},"return View('signup')","，所以也提供寫法給各位參考。",[12,650,651],{"id":651},"結尾",[16,653,654,655,658,659,662,663,666,667,670],{},"這一章節我一度卡在 Session 的引入，因為看文件是寫引入 ",[33,656,657],{},"use think\\Session","，但是引入後當我使用 ",[33,660,661],{},"Session::flash()"," 卻會發生 ",[33,664,665],{},"Non-static method think\\Session::flash() should not be called statically","，後來改用 ",[33,668,669],{},"use think\\facade\\Session;"," 就解決了，這邊就只需要注意一下這一點就是了。",[16,672,673],{},"下一篇會來講表單 Token 唷~",[675,676,677],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":31,"searchDepth":60,"depth":60,"links":679},[680,681,682,683],{"id":14,"depth":60,"text":14},{"id":21,"depth":60,"text":21},{"id":508,"depth":60,"text":508},{"id":651,"depth":60,"text":651},"PHP","2019-09-25 00:00:05","md","zh-Hant",{},"\u002Fthinkphp\u002Fday24-thinkphp-2","2",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay24-從基礎學習-ThinkPHP-表單驗證-2",[684,695,696,697,698],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190925\u002F1108470009\u002F","cPwY5r03PKzkg0Cu4cUAlvm9SK6V86BGoWH__PcuN9k",{"newer":703,"older":707},{"url":704,"title":705,"date":706},"\u002Fjavascript\u002F20190925\u002F2798516984\u002F","EP.10 RE：從零開始的學習 JS 生活-第十日之條件式判斷","2019-09-25 00:00:10",{"url":708,"title":709,"date":710},"\u002Fother\u002F20190924\u002F3446878284\u002F","Window PowerShell美化(Windows Terminal)","2019-09-24 13:53:52",[712,716,720],{"url":713,"title":714,"date":715,"readingMinutes":690},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41",{"url":717,"title":718,"date":719,"readingMinutes":690},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":721,"title":722,"date":723,"readingMinutes":724},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01","3",1784011730203]