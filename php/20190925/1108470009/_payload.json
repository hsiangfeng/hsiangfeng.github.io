" {\n",[36,213,215,217,220,222,225],{"class":38,"line":214},13,[36,216,161],{"class":42},[36,218,219],{"class":46}," $user",[36,221,124],{"class":42},[36,223,224],{"class":76},"getError",[36,226,110],{"class":46},[36,228,230],{"class":38,"line":229},14,[36,231,173],{"class":46},[36,233,235],{"class":38,"line":234},15,[36,236,237],{"class":46},"}\n",[16,239,240],{},"我們寫到當沒有驗證通過時，會回傳一個 JSON 畫面 ↓",[16,242,243],{},[244,245],"img",{"alt":246,"src":247},"批量驗證","https:\u002F\u002Fi.imgur.com\u002FOcYYHT2.png",[16,249,250,251,254,255,258,259,262,263,266,267,270,271,274],{},"那麼這一篇開始我們將會嘗試將驗證錯誤訊息傳送至前端，傳送方式其實本身並不困難，我們可以簡單想是透過 ",[33,252,253],{},"assign()"," 將參數往前端傳，然後使用 ",[33,256,257],{},"fetch()"," 來指定模板，但是這個做法其實並不正確，因為如果你是使用這種做法會導致 URL 不正常，所以正確做法應該要使用 ",[33,260,261],{},"redirect()"," 來重新轉址，那你可能會問「那錯誤訊息呢?」，所以這邊就會使用到 ThinkPHP 所提供快閃功能，也就是 ",[33,264,265],{},"Session::flash"," 方法來傳送錯誤訊息，但是 ",[33,268,269],{},"flash"," 是基於 ",[33,272,273],{},"session"," 函式庫所製作，所以前面會有一小段起手式要寫，所以就我們來看看該如何寫吧!",[16,276,277],{},"首先一開始我們要先引入 Session：",[26,279,281],{"className":28,"code":280,"language":30,"meta":31,"style":31},"use think\\facade\\Session; \u002F\u002F 請不要引入 use think\\Session; 會出現錯誤\n\npublic function add() {\n    $user = new userModel;\n    $userData = input();\n    $result = $this->validate($userData, 'User');\n    if(true !== $result) {\n        Session::flash('error', $result); \u002F\u002F 儲存錯誤訊息\n        $this->redirect('\u002Fuser\u002Fsignup');\n    }\n    if($user->save($userData)){\n        return '新增成功';\n    } else {\n        return $user->getError();\n    }\n}\n",[33,282,283,298,302,312,324,334,352,364,385,402,406,418,426,434,446,450],{"__ignoreMap":31},[36,284,285,288,291,294],{"class":38,"line":39},[36,286,287],{"class":42},"use",[36,289,290],{"class":53}," think\\facade\\Session",[36,292,293],{"class":46},"; ",[36,295,297],{"class":296},"sQrFR","\u002F\u002F 請不要引入 use think\\Session; 會出現錯誤\n",[36,299,300],{"class":38,"line":60},[36,301,64],{"emptyLinePlaceholder":63},[36,303