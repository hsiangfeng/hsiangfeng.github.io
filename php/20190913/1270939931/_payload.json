[{"data":1,"prerenderedAt":667},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190913\u002F1270939931\u002F":3,"page:\u002Fphp\u002F20190913\u002F1270939931\u002F":4,"alt:\u002Fphp\u002F20190913\u002F1270939931\u002F":3,"prev-next:\u002Fphp\u002F20190913\u002F1270939931\u002F":644,"related:\u002Fphp\u002F20190913\u002F1270939931\u002F":653},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":624,"date":625,"description":626,"extension":627,"lang":628,"meta":629,"navigation":630,"path":631,"readingMinutes":632,"seo":633,"standalone":634,"stem":635,"tags":636,"tldr":641,"updated":641,"url":642,"__hash__":643},"content\u002F從基礎學習 ThinkPHP\u002FDay12-從基礎學習-ThinkPHP-Route.md","Day12-從基礎學習 ThinkPHP-Route","1270939931",{"type":9,"value":10,"toc":617},"minimark",[11,15,19,23,26,33,36,44,50,53,58,69,75,86,92,98,103,107,117,120,167,170,192,195,319,328,345,370,373,404,411,436,439,445,448,472,478,484,487,496,499,551,557,560,585,592,598,601,604,607,613],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面了解基礎的 MVC 架構與基本的定義，這邊就來實際操作一下，但是在那之前還要再了解一個東西，也就是 Route，對於現今的開發來講 Route 是非常重要的基礎。",[12,20,22],{"id":21},"route","Route",[16,24,25],{},"我先前有寫過關於 Route 類似文章介紹，所以這邊就不再細說直接提供 Link 給各位參考，雖然範例是以 Express.js 為主，但是在觀念上算是大同小異的。",[16,27,28],{},[29,30,32],"a",{"href":31},"\u002Fnodejs\u002F20190630\u002F931792585\u002F","全端勇士之路 Node.js 基礎學習-Express Route 篇",[12,34,35],{"id":35},"起手式",[16,37,38,39,43],{},"首先 ThinkPHP 在專案初始化的時候，就已經先幫我們預設準備了一些預設 Route，所以我們可以打開 ",[40,41,42],"code",{},"project\u002Froute\u002Frouter.php"," 來看看它替我們準備了什麼 ↓",[16,45,46],{},[47,48],"img",{"alt":22,"src":49},"https:\u002F\u002Fi.imgur.com\u002FG3E8FrI.png",[16,51,52],{},"一開始我們可以看到 router.php 裡面有一些基礎的 Route 設置 ↓",[16,54,55],{},[47,56],{"alt":22,"src":57},"https:\u002F\u002Fi.imgur.com\u002FiJBga2W.png",[16,59,60,61,64,65,68],{},"由此可知當我們輸入 ",[40,62,63],{},"http:\u002F\u002Flocalhost:8000\u002Fthink"," 就會得到返回的值，也就是 ",[40,66,67],{},"hello,ThinkPHP5!"," ↓",[16,70,71],{},[47,72],{"alt":73,"src":74},"ThinkPHP5","https:\u002F\u002Fi.imgur.com\u002FHsfuCZ0.png",[16,76,77,78,81,82,85],{},"那麼如果輸入 ",[40,79,80],{},"http:\u002F\u002Flocalhost:8000\u002Fhello\u002F:name"," 呢?注意這邊後面所帶入的是動態路由 (",[40,83,84],{},":name",") 所以你若不輸入資料將會導致錯誤 ↓",[16,87,88],{},[47,89],{"alt":90,"src":91},"動態路由","https:\u002F\u002Fi.imgur.com\u002Fr6fTxlf.png",[16,93,94,95,68],{},"所以正確的輸入方式是這樣 ",[40,96,97],{},"http:\u002F\u002Flocalhost:8000\u002Fhello\u002FRay",[16,99,100],{},[47,101],{"alt":90,"src":102},"https:\u002F\u002Fi.imgur.com\u002F5oJJcNe.png",[12,104,106],{"id":105},"route-介紹","Route 介紹",[16,108,109,110,113,114],{},"依照官方文檔說明，基礎的 Route 定義是 ",[40,111,112],{},"Route::rule('Route 表達式', 'Route 地址', '請求類型');","，但是這樣寫我個人覺得滿難理解的，所以我整理成這樣 ",[40,115,116],{},"Route::rule('訪問 URL', 'Controller', 'HTTP request');",[16,118,119],{},"所以依照範例來講，我們可以這樣寫：",[121,122,127],"pre",{"className":123,"code":124,"language":125,"meta":126,"style":126},"language-php shiki shiki-themes github-dark-high-contrast","Route::rule('hello\u002F:name', 'index\u002Fhello', 'GET');\n","php","",[40,128,129],{"__ignoreMap":126},[130,131,134,137,141,145,149,153,156,159,161,164],"span",{"class":132,"line":133},"line",1,[130,135,22],{"class":136},"sCcAr",[130,138,140],{"class":139},"sWyjQ","::",[130,142,144],{"class":143},"sj_SG","rule",[130,146,148],{"class":147},"sMAXC","(",[130,150,152],{"class":151},"sTRMh","'hello\u002F:name'",[130,154,155],{"class":147},", ",[130,157,158],{"class":151},"'index\u002Fhello'",[130,160,155],{"class":147},[130,162,163],{"class":151},"'GET'",[130,165,166],{"class":147},");\n",[16,168,169],{},"而 ThinkPHP 可以接受的 Route 類型有以下",[171,172,173,177,180,183,186,189],"ul",{},[174,175,176],"li",{},"GET",[174,178,179],{},"POST",[174,181,182],{},"PUT",[174,184,185],{},"DELETE",[174,187,188],{},"PATCH",[174,190,191],{},"＊ - 萬用請求",[16,193,194],{},"可是你會發現官方所提供的範例與我寫的是不同的版本，其實官方所寫的可以說是簡化版的 Route，我個人也比較偏好於簡化版 Route 設置，所以就算改成以下這種寫法也是沒有問題的：",[121,196,198],{"className":123,"code":197,"language":125,"meta":126,"style":126},"Route::get('hello\u002F:name', 'index\u002Fhello');\nRoute::post('hello\u002F:name', 'index\u002Fhello');\nRoute::put('hello\u002F:name', 'index\u002Fhello');\nRoute::delete('hello\u002F:name', 'index\u002Fhello');\nRoute::patch('hello\u002F:name', 'index\u002Fhello');\nRoute::any('hello\u002F:name', 'index\u002Fhello');\n",[40,199,200,219,239,259,279,299],{"__ignoreMap":126},[130,201,202,204,206,209,211,213,215,217],{"class":132,"line":133},[130,203,22],{"class":136},[130,205,140],{"class":139},[130,207,208],{"class":143},"get",[130,210,148],{"class":147},[130,212,152],{"class":151},[130,214,155],{"class":147},[130,216,158],{"class":151},[130,218,166],{"class":147},[130,220,222,224,226,229,231,233,235,237],{"class":132,"line":221},2,[130,223,22],{"class":136},[130,225,140],{"class":139},[130,227,228],{"class":143},"post",[130,230,148],{"class":147},[130,232,152],{"class":151},[130,234,155],{"class":147},[130,236,158],{"class":151},[130,238,166],{"class":147},[130,240,242,244,246,249,251,253,255,257],{"class":132,"line":241},3,[130,243,22],{"class":136},[130,245,140],{"class":139},[130,247,248],{"class":143},"put",[130,250,148],{"class":147},[130,252,152],{"class":151},[130,254,155],{"class":147},[130,256,158],{"class":151},[130,258,166],{"class":147},[130,260,262,264,266,269,271,273,275,277],{"class":132,"line":261},4,[130,263,22],{"class":136},[130,265,140],{"class":139},[130,267,268],{"class":143},"delete",[130,270,148],{"class":147},[130,272,152],{"class":151},[130,274,155],{"class":147},[130,276,158],{"class":151},[130,278,166],{"class":147},[130,280,282,284,286,289,291,293,295,297],{"class":132,"line":281},5,[130,283,22],{"class":136},[130,285,140],{"class":139},[130,287,288],{"class":143},"patch",[130,290,148],{"class":147},[130,292,152],{"class":151},[130,294,155],{"class":147},[130,296,158],{"class":151},[130,298,166],{"class":147},[130,300,302,304,306,309,311,313,315,317],{"class":132,"line":301},6,[130,303,22],{"class":136},[130,305,140],{"class":139},[130,307,308],{"class":143},"any",[130,310,148],{"class":147},[130,312,152],{"class":151},[130,314,155],{"class":147},[130,316,158],{"class":151},[130,318,166],{"class":147},[16,320,321,322,324,325,327],{},"最後來講解一下 Route 的設置，因為官方文檔的這個說明 ",[40,323,112],{},"，說真的會讓人看不懂，所以我才會整理成這樣 ",[40,326,116],{},"。",[16,329,330,331,334,335,337,338,340,341,344],{},"那另外就拿 ",[40,332,333],{},"Route::get('hello\u002F:name', 'index\u002Fhello');"," 做一下介紹，",[40,336,333],{}," 第一個參數所代表的就是 URL，也就是 ",[40,339,80],{},"，而第二個參數 ",[40,342,343],{},"index\u002Fhello"," 則是欲訪問的 Controller，所以結果就是這樣：",[121,346,348],{"className":123,"code":347,"language":125,"meta":126,"style":126},"Route::get('[Route URL]', 'Controller');\n",[40,349,350],{"__ignoreMap":126},[130,351,352,354,356,358,360,363,365,368],{"class":132,"line":133},[130,353,22],{"class":136},[130,355,140],{"class":139},[130,357,208],{"class":143},[130,359,148],{"class":147},[130,361,362],{"class":151},"'[Route URL]'",[130,364,155],{"class":147},[130,366,367],{"class":151},"'Controller'",[130,369,166],{"class":147},[16,371,372],{},"所以簡化版會比手冊的寫法還要容易理解，只需要這樣看就可以懂了：",[121,374,376],{"className":123,"code":375,"language":125,"meta":126,"style":126},"Route::[HTTP request]('[Route URL]', 'Controller');\n",[40,377,378],{"__ignoreMap":126},[130,379,380,382,384,387,390,393,396,398,400,402],{"class":132,"line":133},[130,381,22],{"class":136},[130,383,140],{"class":139},[130,385,386],{"class":147},"[",[130,388,389],{"class":136},"HTTP",[130,391,392],{"class":136}," request",[130,394,395],{"class":147},"](",[130,397,362],{"class":151},[130,399,155],{"class":147},[130,401,367],{"class":151},[130,403,166],{"class":147},[16,405,406,407,410],{},"當我們瞭解上述觀念之後，就可以試著新增一個 Route，例如我希望訪問 ",[40,408,409],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fqq123"," 會出現 about Controller 底下的 index：",[121,412,414],{"className":123,"code":413,"language":125,"meta":126,"style":126},"Route::get('\u002Fabout\u002Fqq123', 'about\u002Findex\u002Findex');\n",[40,415,416],{"__ignoreMap":126},[130,417,418,420,422,424,426,429,431,434],{"class":132,"line":133},[130,419,22],{"class":136},[130,421,140],{"class":139},[130,423,208],{"class":143},[130,425,148],{"class":147},[130,427,428],{"class":151},"'\u002Fabout\u002Fqq123'",[130,430,155],{"class":147},[130,432,433],{"class":151},"'about\u002Findex\u002Findex'",[130,435,166],{"class":147},[16,437,438],{},"那麼當我們訪問該路由就可以得到預期的結果 ↓",[16,440,441],{},[47,442],{"alt":443,"src":444},"About","https:\u002F\u002Fi.imgur.com\u002FRMKPex6.png",[16,446,447],{},"這邊要注意路由註冊的時候不要打這樣：",[121,449,451],{"className":123,"code":450,"language":125,"meta":126,"style":126},"Route::get('\u002Fabout\u002Fqq123', 'about\u002Findex');\n",[40,452,453],{"__ignoreMap":126},[130,454,455,457,459,461,463,465,467,470],{"class":132,"line":133},[130,456,22],{"class":136},[130,458,140],{"class":139},[130,460,208],{"class":143},[130,462,148],{"class":147},[130,464,428],{"class":151},[130,466,155],{"class":147},[130,468,469],{"class":151},"'about\u002Findex'",[130,471,166],{"class":147},[16,473,474,475,477],{},"這樣子當你瀏覽 ",[40,476,409],{},"時，只會導致出現錯誤 ↓",[16,479,480],{},[47,481],{"alt":482,"src":483},"Error","https:\u002F\u002Fi.imgur.com\u002FmMAVDis.png",[16,485,486],{},"最後提供一個口訣給各位了解該如何正確註冊路由，假設我要註冊 index 的路由：",[16,488,489,493,494,327],{},[490,491,492],"strong",{},"註冊 Route 到 about 的 index 控制器，然後是裡面的 index 方法","，所以就是 ",[40,495,433],{},[16,497,498],{},"那麼為了驗證以上口訣，我稍微替 about 的 index Controller 新增另一段程式碼：",[121,500,502],{"className":123,"code":501,"language":125,"meta":126,"style":126},"public function sayhi ($name = 'undefined')\n    {\n        return 'Hi：' . $name;\n    }\n",[40,503,504,527,532,546],{"__ignoreMap":126},[130,505,506,509,512,515,518,521,524],{"class":132,"line":133},[130,507,508],{"class":139},"public",[130,510,511],{"class":139}," function",[130,513,514],{"class":143}," sayhi",[130,516,517],{"class":147}," ($name ",[130,519,520],{"class":139},"=",[130,522,523],{"class":151}," 'undefined'",[130,525,526],{"class":147},")\n",[130,528,529],{"class":132,"line":221},[130,530,531],{"class":147},"    {\n",[130,533,534,537,540,543],{"class":132,"line":241},[130,535,536],{"class":139},"        return",[130,538,539],{"class":151}," 'Hi：'",[130,541,542],{"class":139}," .",[130,544,545],{"class":147}," $name;\n",[130,547,548],{"class":132,"line":261},[130,549,550],{"class":147},"    }\n",[16,552,553,554],{},"那麼再來一次口訣 ",[490,555,556],{},"註冊 Route 到 about 的 index 控制器，然後是裡面的 sayhi 方法",[16,558,559],{},"所以路由就這樣註冊即可：",[121,561,563],{"className":123,"code":562,"language":125,"meta":126,"style":126},"Route::get('\u002Fabout\u002Fsayhi', 'about\u002Findex\u002Fsayhi');\n",[40,564,565],{"__ignoreMap":126},[130,566,567,569,571,573,575,578,580,583],{"class":132,"line":133},[130,568,22],{"class":136},[130,570,140],{"class":139},[130,572,208],{"class":143},[130,574,148],{"class":147},[130,576,577],{"class":151},"'\u002Fabout\u002Fsayhi'",[130,579,155],{"class":147},[130,581,582],{"class":151},"'about\u002Findex\u002Fsayhi'",[130,584,166],{"class":147},[16,586,587,588,591],{},"這樣子當你訪問 ",[40,589,590],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fsayhi"," 就可以看到成果了 ↓",[16,593,594],{},[47,595],{"alt":596,"src":597},"Hi：undefined","https:\u002F\u002Fi.imgur.com\u002FshwjqEo.png",[12,599,600],{"id":600},"結尾",[16,602,603],{},"路由註冊這部分如果沒弄懂的話，其實滿容易搞不清該如何註冊到自己要的控制器與方法內，在撰寫本篇文章的時候，自己也稍微卡了一下，真的是功力不夠阿~(嘆)",[16,605,606],{},"另外這個路由觀念也與我先前介紹 MVC 模式章節也有關聯唷 ↓",[16,608,609],{},[47,610],{"alt":611,"src":612},"流程架構圖","https:\u002F\u002Fi.imgur.com\u002FZ6cu71b.png",[614,615,616],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":126,"searchDepth":221,"depth":221,"links":618},[619,620,621,622,623],{"id":14,"depth":221,"text":14},{"id":21,"depth":221,"text":22},{"id":35,"depth":221,"text":35},{"id":105,"depth":221,"text":106},{"id":600,"depth":221,"text":600},"PHP","2019-09-13 00:01:52","前面了解基礎的 MVC 架構與基本的定義，這邊就來實際操作一下，但是在那之前還要再了解一個東西，也就是 Route，對於現今的開發來講 Route 是非常重要的基礎","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday12-thinkphp-route","2",{"title":6,"description":626},false,"從基礎學習 ThinkPHP\u002FDay12-從基礎學習-ThinkPHP-Route",[624,637,638,639,640],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190913\u002F1270939931\u002F","l1cgGVZy3GGqWHXvO-O_zJ56OMbR7W-qnXuKcFeU0w8",{"newer":645,"older":649},{"url":646,"title":647,"date":648},"\u002Fphp\u002F20190914\u002F278976166\u002F","Day13-從基礎學習 ThinkPHP-Model 基礎操作(1)","2019-09-14 00:09:41",{"url":650,"title":651,"date":652},"\u002Fphp\u002F20190912\u002F1469012740\u002F","Day11-從基礎學習 ThinkPHP-Model","2019-09-12 00:03:18",[654,658,662],{"url":655,"title":656,"date":657,"readingMinutes":632},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41",{"url":659,"title":660,"date":661,"readingMinutes":632},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":663,"title":664,"date":665,"readingMinutes":666},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01","3",1784010307879]