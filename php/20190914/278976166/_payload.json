},[43,196,172],{"class":49},[43,198,158],{"class":175},[43,200,178],{"class":67},[43,202,203],{"class":128},"'\u002Fabout\u002Fcreate'",[43,205,184],{"class":67},[43,207,208],{"class":128},"'about\u002Findex\u002Fcreate'",[43,210,190],{"class":67},[16,212,213,214,217,218,221,222,225],{},"接下來要建立一個 HTML 頁面讓我們可以渲染畫面，並傳送資料到 ",[29,215,216],{},"about\u002Findex\u002Fcreate","，首先在 ",[29,219,220],{},"about\u002Fview"," 底下建立一個資料夾以及 HTML 檔案 ",[29,223,224],{},"index\u002Findex.html","，而 HTML 內容如下：",[34,227,231],{"className":228,"code":229,"language":230,"meta":39,"style":39},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \u003Ctitle>{$title}\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>{$title}\u003C\u002Fh1>\n  \u003Cform action=\"\u002Fabout\u002Fcreate\" method=\"post\">\n    \u003Cdiv>\n      \u003Clabel for=\"name\">姓名\u003C\u002Flabel>\n      \u003Cinput type=\"text\" name=\"name\" id=\"name\">\n    \u003C\u002Fdiv>\n    \u003Cdiv>\n      \u003Clabel for=\"height\">身高\u003C\u002Flabel>\n      \u003Cinput type=\"text\" name=\"height\" id=\"height\">\n    \u003C\u002Fdiv>\n    \u003Cdiv>\n      \u003Clabel for=\"weight\">體重\u003C\u002Flabel>\n      \u003Cinput type=\"text\" name=\"weight\" id=\"weight\">\n    \u003C\u002Fdiv>\n    \u003Cinput type=\"submit\" value=\"送出\">\n  \u003C\u002Fform>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html",[29,232,233,248,265,274,292,316,339,353,362,371,385,411,422,446,477,487,496,517,544,553,562,583,610,619,643,653,662],{"__ignoreMap":39},[43,234,235,238,242,245],{"class":45,"line":46},[43,236,237],{"class":67},"\u003C!",[43,239,241],{"class":240},"syv7_","DOCTYPE",[43,243,244],{"class":106}," html",[43,246,247],{"class":67},">\n",[43,249,250