,665,356],{"class":67},[43,667,229],{"class":239},[43,669,246],{"class":67},[12,671,672],{"id":672},"控制器",[16,674,675],{},"接下來這邊將會新增兩個控制器方法，一個是專門吐顯示表單的 Controller function，另一個則是接收 Form 資料的 Controller function。",[16,677,678],{},"首先是顯示表單頁面的 Crotroller function，並且指定我們要渲染的 HTML 檔案：",[34,680,682],{"className":36,"code":681,"language":38,"meta":39,"style":39},"public function user () {\n  $title = '新增資料';\n\n  $this->assign('title',$title);\n  return $this -> fetch('index');\n}\n",[29,683,684,698,710,714,733,754],{"__ignoreMap":39},[43,685,686,689,692,695],{"class":45,"line":46},[43,687,688],{"class":49},"public",[43,690,691],{"class":49}," function",[43,693,694],{"class":174}," user",[43,696,697],{"class":67}," () {\n",[43,699,700,703,705,708],{"class":45,"line":57},[43,701,702],{"class":67},"  $title ",[43,704,124],{"class":49},[43,706,707],{"class":127}," '新增資料'",[43,709,68],{"class":67},[43,711,712],{"class":45,"line":71},[43,713,75],{"emptyLinePlaceholder":74},[43,715,716,719,722,725,727,730],{"class":45,"line":78},[43,717,718],{"class":53},"  $this",[43,720,721],{"class":49},"->",[43,723,724],{"class":174},"assign",[43,726,177],{"class":67},[43,728,729],{"class":127},"'title'",[43,731,732],{"class":67},",$title);\n",[43,734,735,738,741,744,747,749,752],{"class":45,"line":89},[43,736,737],{"class":49},"  return",[43,739,740],{"class":53}," $this",[43,742,743],{"class":49}," ->",[43,745,746],{"class":174}," fetch",[43,748,177],{"class":67},[43,750,751],{"class":127},"'index'",[43,753,189],{"class":67},[43,755,756],{"class":45,"line":94},[43,757,136],{"class":67},[16,759,760,761,764],{},"透過 ThinkPHP 提供的 ",[29,762,763],{},"assign()"," 方法，可以讓我們將變數資料傳到表單畫面上面去，接下來就可以開啟瀏覽器來看成果啦~ ↓",[16,766,767],{},[768,769],"img",{"alt":770,"src":771},"表單畫面呈現","https:\u002F\u002Fi.imgur.com\u002FVeyFx0d.png",[16,773,774],{},"那麼畫面製作完成後，就是要來製作接收資料的 Controller function，首先先來製作一段簡易的測試程式碼，稍後後面會在針對程式碼做講解：",[34,776,778],{"className":36,"code":777,"language":38,"meta":39,"style":39},"public function create ($name, $height, $weight) {\n    return '姓名：'.$name.'\u003Cbr\u002F>'.'身高：'.$height.'\u003Cbr\u002F>'.'體重：'.$weight;\n}\n",[29,779,780,792,835],{"__ignoreMap":39},[43,781,782,784,786,789],{"class":45,"line":46},[43,783,688],{"class":49},[43,785,691],{"class":49},[43,787,788],{"class":174}," create",[43,790,791],{"class":67}," ($name, $height, $weight) {\n",[43,793,794,797,800,803,806,808,811,813,816,818,821,823,825,827,830,832],{"class":45,"line":57},[43,795,796],{"class":49},"    return",[43,798,799],{"class":127}," '姓名：'",[43,801,802],{"class":49},".",[43,804,805],{"class":67},"$name",[43,807,802],{"class":49},[43,809,810],{"class":127},"'\u003Cbr\u002F>'",[43,812,802],{"class":49},[43,814,815],{"class":127},"'身高：'",[43,817,802],{"class":49},[43,819,820],{"class":67},"$height",[43,822,802],{"class":49},[43,824,810],{"class":127},[43,826,802],{"class":49},[43,828,829],{"class":127},"'體重：'",[43,831,802],{"class":49},[43,833,834],{"class":67},"$weight;\n",[43,836,837],{"class":45,"line":71},[43,838,136],{"class":67},[16,840,841],{},"接下來讓我們回到表單畫面，並輸入欄位資料之後送出 ↓",[16,843,844],{},[768,845],{"alt":846,"src":847},"送出表單","https:\u002F\u002Fi.imgur.com\u002Fybnutj4.png",[16,849,850],{},"正常來講你會看到你剛剛送出表單的資料 ↓",[16,852,853],{},[768,854],{"alt":855,"src":856},"回傳結果","https:\u002F\u002Fi.imgur.com\u002FDPxEd7U.png",[16,858,859],{},"從上面流程我們可以看到我們已經成功的將資料傳給後端 & 後端回傳資料結果到畫面上給我們，那麼這原理是如何運作的呢? Controller 又是如何抓取表單欄位資料?",[16,861,862,863,865,866,868,869,872,873,875,876,879],{},"首先 ThinkPHP 在你傳送 ",[29,864,391],{}," 表單的時候，會去擷取你 ",[29,867,452],{}," 欄位的 ",[29,870,871],{},"name"," 名稱，而這 ",[29,874,871],{}," 名稱剛好會對應到 ",[29,877,878],{},"function"," 後面的參數，所以我只要寫上相對應的變數名稱就可以成功取得表單欄位資料哩~",[12,881,882],{"id":882},"結尾",[16,884,885,886,889,890,893],{},"寫 JavaScript 習慣了一度稍微卡一下子在 ",[29,887,888],{},"return '姓名：'.$name.'\u003Cbr\u002F>'.'身高：'.$height.'\u003Cbr\u002F>'.'體重：'.$weight;"," 上，我一直寫成 ",[29,891,892],{},"return '姓名：' + $name + '\u003Cbr\u002F>'+ '身高：' + $height + '\u003Cbr\u002F>' + '體重：' 