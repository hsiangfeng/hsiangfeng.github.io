779],{"className":36,"code":778,"language":38,"meta":39,"style":39},"public function create ($name, $height, $weight) {\n    return '姓名：'.$name.'\u003Cbr\u002F>'.'身高：'.$height.'\u003Cbr\u002F>'.'體重：'.$weight;\n}\n",[29,780,781,793,836],{"__ignoreMap":39},[43,782,783,785,787,790],{"class":45,"line":46},[43,784,689],{"class":49},[43,786,692],{"class":49},[43,788,789],{"class":175}," create",[43,791,792],{"class":67}," ($name, $height, $weight) {\n",[43,794,795,798,801,804,807,809,812,814,817,819,822,824,826,828,831,833],{"class":45,"line":57},[43,796,797],{"class":49},"    return",[43,799,800],{"class":128}," '姓名：'",[43,802,803],{"class":49},".",[43,805,806],{"class":67},"$name",[43,808,803],{"class":49},[43,810,811],{"class":128},"'\u003Cbr\u002F>'",[43,813,803],{"class":49},[43,815,816],{"class":128},"'身高：'",[43,818,803],{"class":49},[43,820,821],{"class":67},"$height",[43,823,803],{"class":49},[43,825,811],{"class":128},[43,827,803],{"class":49},[43,829,830],{"class":128},"'體重：'",[43,832,803],{"class":49},[43,834,835],{"class":67},"$weight;\n",[43,837,838],{"class":45,"line":71},[43,839,137],{"class":67},[16,841,842],{},"接下來讓我們回到表單畫面，並輸入欄位資料之後送出 ↓",[16,844,845],{},[769,846],{"alt":847,"src":848},"送出表單","https:\u002F\u002Fi.imgur.com\u002Fybnutj4.png",[16,850,851],{},"正常來講你會看到你剛剛送出表單的資料 ↓",[16,853,854],{},[769,855],{"alt":856,"src":857},"回傳結果","https:\u002F\u002Fi.imgur.com\u002FDPxEd7U.png",[16,859,860],{},"從上面流程我們可以看到我們已經成功的將資料傳給後端 & 後端回傳資料結果到畫面上給我們，那麼這原理是如何運作的呢? Controller 又是如何抓取表單欄位資料?",[16,862,863,864,866,867,869,870,873,874,876,877,880],{},"首先 ThinkPHP 在你傳送 ",[29,865,392],{}," 表單的時候，會去擷取你 ",[29,868,453],{}," 欄位的 ",[29,871,872],{},"name"," 名稱，而這 ",[29,875,872],{}," 名稱剛好會對應到 ",[29,878,879],{},"function"," 後面的參數，所以我只要寫上相對應的變數名稱就可以成功取得表單欄位資料哩~",[12,882,883],{"id":883},"結尾",[16,885,886,887,890,891,894],{},"寫 JavaScript 習慣了一度稍微卡一下子在 ",[29,888,889],{},"return '姓名：'.$name.'\u003Cbr\u002F>'.'身高：'.$height.'\u003Cbr\u002F>'.'體重：'.$weight;"," 上，我一直寫成 ",[29,892,893],{},"re