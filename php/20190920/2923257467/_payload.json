,722,723],{"class":84},"[__ONEFORALL__] \u002F\u002F 注意是使用 [] 包覆\n",[78,725,726],{"class":80,"line":119},[78,727,444],{"class":84},[16,729,730,731,734],{},"那 getAllUser.html 的引入 layout 這邊呢?則會使用 ",[49,732,733],{},"replace"," 告知 ThinkPHP 我們將會解析替換哪一段，所以就會這樣寫：",[69,736,738],{"className":71,"code":737,"language":73,"meta":74,"style":74},"{layout name=\"layout\" replace=\"[__ONEFORALL__]\" \u002F}\n\u003Ch1>{$title}\u003C\u002Fh1>\n{volist name=\"user\" id=\"list\"}\n\u003Cul>\n  \u003Cli>姓名:{$list.name}\u003C\u002Fli>\n  \u003Cli>體重:{$list.weight}\u003C\u002Fli>\n  \u003Cli>身高:{$list.height}\u003C\u002Fli>\n\u003C\u002Ful>\n{\u002Fvolist}\n",[49,739,740,745,757,761,769,781,793,805,813],{"__ignoreMap":74},[78,741,742],{"class":80,"line":81},[78,743,744],{"class":84},"{layout name=\"layout\" replace=\"[__ONEFORALL__]\" \u002F}\n",[78,746,747,749,751,753,755],{"class":80,"line":99},[78,748,102],{"class":84},[78,750,268],{"class":88},[78,752,205],{"class":84},[78,754,268],{"class":88},[78,756,96],{"class":84},[78,758,759],{"class":80,"line":119},[78,760,279],{"class":84},[78,762,763,765,767],{"class":80,"line":129},[78,764,102],{"class":84},[78,766,286],{"class":88},[78,768,96],{"class":84},[78,770,771,773,775,777,779],{"class":80,"line":148},[78,772,132],{"class":84},[78,774,295],{"class":88},[78,776,298],{"class":84},[78,778,295],{"class":88},[78,780,96],{"class":84},[78,782,783,785,787,789,791],{"class":80,"line":173},[78,784,132],{"class":84},[78,786,295],{"class":88},[78,788,311],{"class":84},[78,790,295],{"class":88},[78,792,96],{"class":84},[78,794,795,797,799,801,803],{"class":80,"line":197},[78,796,132],{"class":84},[78,798,295],{"class":88},[78,800,324],{"class":84},[78,802,295],{"class":88},[78,804,96],{"class":84},[78,806,807,809,811],{"class":80,"line":212},[78,808,215],{"class":84},[78,810,286],{"class":88},[78,812,96],{"class":84},[78,814,815],{"class":80,"line":222},[78,816,341],{"class":84},[16,818,819],{},"就結果來講一樣可以成功引入 layout ↓",[16,821,822],{},[32,823],{"alt":824,"src":825},"成功引入","https:\u002F\u002Fi.imgur.com\u002FDlAGx5T.png",[16,827,828,829,832,833,840],{},"另外也可以透過 ",[49,830,831],{},"config\u002Ftemplate.php"," 做調整，而且也可以使用 Controller 來控制要輸出哪一個 layout，詳細可以看官方的",[834,835,839],"a",{"href":836,"rel":837},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354079",[838],"nofollow","開發者手冊","，我這邊只是介紹其中常見的作法而已。",[12,842,843],{"id":843},"結尾",[16,845,846],{},"透過這一篇可以知道 ThinkPHP 本身內建的模板引擎其實還滿夠用的，如果不是特殊需求，大致上都會推薦使用內建模板引擎就好，下一篇將會來介紹該如何 ThinkPHP + Bootstrap，剛好可以銜接使用這一篇 Layout 的技巧，這樣子在效果上更能看出所以然。",[848,849,850],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}",{"title":74,"searchDepth":99,"depth":99,"links":852},[853,854,855,856,857],{"id":14,"depth":99,"text":14},{"id":21,"depth":99,"text":22},{"id":344,"depth":99,"text":345},{"id":468,"depth":99,"text":469},{"id":843,"depth":99,"text":843},"PHP","2019-09-20 09:52:03","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday19-thinkphp-layout","3",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay19-從基礎學習-ThinkPHP-Layout",[858,870,871,872,873],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190920\u002F2923257467\u002F","HRJB4ovlzvylAQnMNIOz