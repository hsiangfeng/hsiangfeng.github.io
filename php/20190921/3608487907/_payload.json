[{"data":1,"prerenderedAt":338},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190921\u002F3608487907\u002F":3,"page:\u002Fphp\u002F20190921\u002F3608487907\u002F":4,"alt:\u002Fphp\u002F20190921\u002F3608487907\u002F":3,"prev-next:\u002Fphp\u002F20190921\u002F3608487907\u002F":315,"related:\u002Fphp\u002F20190921\u002F3608487907\u002F":324},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F21\u002Fthinkphp-day-20-import-bootstrap\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":296,"date":297,"description":18,"extension":298,"lang":299,"meta":300,"navigation":301,"path":302,"readingMinutes":303,"seo":304,"standalone":305,"stem":306,"tags":307,"tldr":312,"updated":312,"url":313,"__hash__":314},"content\u002F從基礎學習 ThinkPHP\u002FDay20-從基礎學習-ThinkPHP-引入-Bootstrap.md","Day20-從基礎學習 ThinkPHP-引入 Bootstrap","3608487907",{"type":9,"value":10,"toc":287},"minimark",[11,15,19,22,33,40,48,53,57,69,74,78,81,88,132,136,139,145,148,154,157,163,166,173,182,188,199,208,213,216,222,225,231,234,264,267,273,276,283],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"終於要輪到準備引入第三方資源，這一篇我將會搭配上一篇所介紹的 Layout，進而凸顯有沒有成功引入 Layout 的差異。",[12,20,21],{"id":21},"起手式",[16,23,24,25,32],{},"首先先讓我們去 Bootstrap 下載資源(",[26,27,31],"a",{"href":28,"rel":29},"https:\u002F\u002Fbootstrap.hexschool.com\u002F",[30],"nofollow","網址",")，進入 Bootstrap 後點選 Download ↓",[16,34,35],{},[36,37],"img",{"alt":38,"src":39},"Bootstrap","https:\u002F\u002Fi.imgur.com\u002F9BTDXhW.png",[16,41,42,43,47],{},"接下來拉到下方，點一下 ",[44,45,46],"strong",{},"下載 Bootstrap","，此時就會下載了 ↓",[16,49,50],{},[36,51],{"alt":46,"src":52},"https:\u002F\u002Fi.imgur.com\u002FShALHxE.png",[12,54,56],{"id":55},"放置-bootstrap","放置 Bootstrap",[16,58,59,60,64,65,68],{},"下載好的 Bootstrap 應該要放在哪裡呢?要放在 ",[61,62,63],"code",{},"public\u002Fstatic"," 底下，",[61,66,67],{},"static"," 是專門放靜態資源的地方，注意我這邊將會使用 min 版 ↓",[16,70,71],{},[36,72],{"alt":38,"src":73},"https:\u002F\u002Fi.imgur.com\u002Fc94Wgql.png",[12,75,77],{"id":76},"引入-bootstrap","引入 Bootstrap",[16,79,80],{},"接下來該如何引入 Bootstrap 到我們製作好的 Layout 呢?",[16,82,83,84,87],{},"首先打開 header.html，並在 ",[61,85,86],{},"\u003Chead>"," 中輸入 Bootstrap 路徑即可(注意要使用絕對路徑)：",[89,90,95],"pre",{"className":91,"code":92,"language":93,"meta":94,"style":94},"language-html shiki shiki-themes github-dark-high-contrast","\u003Clink rel=\"stylesheet\" href=\"\u002Fstatic\u002Fbootstrap.min.css\">\n","html","",[61,96,97],{"__ignoreMap":94},[98,99,102,106,110,114,117,121,124,126,129],"span",{"class":100,"line":101},"line",1,[98,103,105],{"class":104},"sMAXC","\u003C",[98,107,109],{"class":108},"sKpQp","link",[98,111,113],{"class":112},"sCcAr"," rel",[98,115,116],{"class":104},"=",[98,118,120],{"class":119},"sTRMh","\"stylesheet\"",[98,122,123],{"class":112}," href",[98,125,116],{"class":104},[98,127,128],{"class":119},"\"\u002Fstatic\u002Fbootstrap.min.css\"",[98,130,131],{"class":104},">\n",[12,133,135],{"id":134},"使用-bootstrap","使用 Bootstrap",[16,137,138],{},"這邊我們找一個 Bootstrap 元件來當作範例試試看，例如我加入 navbar 元件進去 header.html ↓",[16,140,141],{},[36,142],{"alt":143,"src":144},"navbar 元件","https:\u002F\u002Fi.imgur.com\u002FM1Uy0Fa.png",[16,146,147],{},"接下來我們就可以來看看效果有沒有出來啦~ ↓",[16,149,150],{},[36,151],{"alt":152,"src":153},"成功使用 Bootstrap","https:\u002F\u002Fi.imgur.com\u002FEPcaapl.png",[16,155,156],{},"所以我們就可以來稍微美化一下這個清單 ↓",[16,158,159],{},[36,160],{"alt":161,"src":162},"資料清單","https:\u002F\u002Fi.imgur.com\u002F7q3tKOO.png",[12,164,165],{"id":165},"簡化引入",[16,167,168,169,172],{},"當然 ThinkPHP 也有提供簡化的引入方式，可以將原本這一串 ",[61,170,171],{},"\u003Clink rel=\"stylesheet\" href=\"\u002Fstatic\u002Fbootstrap.min.css\">"," 變得短一點點，只需要這樣寫即可：",[89,174,176],{"className":91,"code":175,"language":93,"meta":94,"style":94},"{load href=\"\u002Fstatic\u002Fbootstrap.min.css\"}\n",[61,177,178],{"__ignoreMap":94},[98,179,180],{"class":100,"line":101},[98,181,175],{"class":104},[16,183,184],{},[36,185],{"alt":186,"src":187},"簡化寫法","https:\u002F\u002Fi.imgur.com\u002Feb2MU68.png",[16,189,190,191,194,195,198],{},"如果你覺得這種寫法會讓你搞不清楚引入的東西的話， ThinkPHP 還有提供另外兩個標籤可以使用，分別為 ",[61,192,193],{},"js","、",[61,196,197],{},"css","，假設 CSS 部分的話，就可以這樣寫：",[89,200,202],{"className":91,"code":201,"language":93,"meta":94,"style":94},"{css href=\"\u002Fstatic\u002Fbootstrap.min.css\"}\n",[61,203,204],{"__ignoreMap":94},[98,205,206],{"class":100,"line":101},[98,207,201],{"class":104},[16,209,210],{},[36,211],{"alt":197,"src":212},"https:\u002F\u002Fi.imgur.com\u002FoUmtGEH.png",[16,214,215],{},"結果會有影響嗎?其實並不會，效果一樣有 ↓",[16,217,218],{},[36,219],{"alt":220,"src":221},"沒有變化","https:\u002F\u002Fi.imgur.com\u002FUmyijFn.png",[16,223,224],{},"那其他的套件，例如 jQuery、Bootstrap.min.js 都是採用相同的方式引入，所以我這邊就不多作介紹囉(完整範例會附上)。",[16,226,227],{},[36,228],{"alt":229,"src":230},"後來稍微做一下分類，不然太亂了","https:\u002F\u002Fi.imgur.com\u002FFzuyooR.png",[16,232,233],{},"最後 ThinkPHP 也有支援同時加載多個資源，例如我要同時加載 Bootstrap 的 JS 以及其他 JS 部分，就可以這樣寫：",[89,235,237],{"className":91,"code":236,"language":93,"meta":94,"style":94},"  {js href=\"\u002Fstatic\u002Fjs\u002Fjquery-3.3.1.slim.min.js,\u002Fstatic\u002Fjs\u002Fpopper.min.js,\u002Fstatic\u002Fjs\u002Fbootstrap.min.js\"}\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n",[61,238,239,244,255],{"__ignoreMap":94},[98,240,241],{"class":100,"line":101},[98,242,243],{"class":104},"  {js href=\"\u002Fstatic\u002Fjs\u002Fjquery-3.3.1.slim.min.js,\u002Fstatic\u002Fjs\u002Fpopper.min.js,\u002Fstatic\u002Fjs\u002Fbootstrap.min.js\"}\n",[98,245,247,250,253],{"class":100,"line":246},2,[98,248,249],{"class":104},"\u003C\u002F",[98,251,252],{"class":108},"body",[98,254,131],{"class":104},[98,256,258,260,262],{"class":100,"line":257},3,[98,259,249],{"class":104},[98,261,93],{"class":108},[98,263,131],{"class":104},[16,265,266],{},"但是我覺得滿麻煩的，因為這種寫法不能夠有斷行或空格，如果你有斷行或空格將會導致無法正常引入，這一點要注意一下，所以這樣子做就可以一次引入所有 JS 檔 ↓",[16,268,269],{},[36,270],{"alt":271,"src":272},"正常引入","https:\u002F\u002Fi.imgur.com\u002FVILFghK.png",[12,274,275],{"id":275},"結尾",[16,277,278,279,282],{},"這一篇我們學會了如何引入第三方資源到 ThinkPHP 框架內，這樣子後面若想做美化就可以很輕鬆地使用 Bootstrap，只需要在 HTML 最前面宣告 ",[61,280,281],{},"{layout name=\"layout\" \u002F}"," 剩下就可以交給 ThinkPHP 了，那麼下一篇預計將會來介紹 ThinkPHP 內建的標籤。",[284,285,286],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":94,"searchDepth":246,"depth":246,"links":288},[289,290,291,292,293,294,295],{"id":14,"depth":246,"text":14},{"id":21,"depth":246,"text":21},{"id":55,"depth":246,"text":56},{"id":76,"depth":246,"text":77},{"id":134,"depth":246,"text":135},{"id":165,"depth":246,"text":165},{"id":275,"depth":246,"text":275},"PHP","2019-09-21 00:01:05","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday20-thinkphp-bootstrap","2",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay20-從基礎學習-ThinkPHP-引入-Bootstrap",[296,308,309,310,311],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190921\u002F3608487907\u002F","KnQnlYRqA03XsU3eWFSGHwDxS4RB1oWMSGvzn-ykpXo",{"newer":316,"older":320},{"url":317,"title":318,"date":319},"\u002Fjavascript\u002F20190921\u002F1280863990\u002F","EP.6 RE：從零開始的學習 JS 生活-第六日之運算子","2019-09-21 00:01:15",{"url":321,"title":322,"date":323},"\u002Fphp\u002F20190920\u002F2923257467\u002F","Day19-從基礎學習 ThinkPHP-Layout","2019-09-20 09:52:03",[325,329,333],{"url":326,"title":327,"date":328,"readingMinutes":303},"\u002Fphp\u002F20220417\u002F3990325618\u002F"