[{"data":1,"prerenderedAt":224},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20220417\u002F3990325618\u002F":3,"page:\u002Fphp\u002F20220417\u002F3990325618\u002F":4,"alt:\u002Fphp\u002F20220417\u002F3990325618\u002F":3,"prev-next:\u002Fphp\u002F20220417\u002F3990325618\u002F":200,"related:\u002Fphp\u002F20220417\u002F3990325618\u002F":209},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":182,"date":183,"description":18,"extension":184,"lang":185,"meta":186,"navigation":187,"path":188,"readingMinutes":189,"seo":190,"standalone":191,"stem":192,"tags":193,"tldr":197,"updated":197,"url":198,"__hash__":199},"content\u002FPHP\u002FMac-XAMPP-Apache-一直無法啟動解決方式.md","Mac XAMPP Apache 一直無法啟動解決方式","3990325618",{"type":9,"value":10,"toc":172},"minimark",[11,15,19,23,32,35,42,45,49,52,58,61,67,71,79,82,88,91,97,100,104,107,113,116,121,126,129,132,138,142,145,151,154,160,163,166,169],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"XAMPP 可以堪稱是非常好用的 PHP 一鍵整合架站工具，但是最近不知道為什麼 MySQL Database 可以正常啟動，但是 Apache Web Server 卻一直無法啟動，因此紀錄一下原因。",[12,20,22],{"id":21},"xampp","XAMPP",[16,24,25,26,31],{},"XAMPP 非常適合拿來學習用，包含我先前寫的 「",[27,28,30],"a",{"href":29},"\u002Fphp\u002F20190902\u002F536097622\u002F","從基礎學習 ThinkPHP","」也都是採用 XAMPP 快速架站學習。",[16,33,34],{},"那麼這陣子不知道為什麼一啟動 XAMPP 的 Apache Web Server 總是卡在啟動中",[16,36,37],{},[38,39],"img",{"alt":40,"src":41},"Starting...","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E6%88%AA%E5%9C%96%202022-04-17%2014.38.24.png",[16,43,44],{},"但是問題可能性太多，所以只能紀錄排除問題的思維。",[12,46,48],{"id":47},"error-log","Error Log",[16,50,51],{},"首先第一步驟透過錯誤 Error Log 尋找無法啟用 Apache Web Server 的原因，這邊你可以點一下 Configure",[16,53,54],{},[38,55],{"alt":56,"src":57},"Configure","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F202204171442.png",[16,59,60],{},"接下來再按一下「Open Error Log」就可以看到相關錯誤原因了",[16,62,63],{},[38,64],{"alt":65,"src":66},"Open Error Log","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_42.png",[12,68,70],{"id":69},"_80-prot-被佔用","80 Prot 被佔用",[16,72,73,74,78],{},"如果是 80 Prot 被佔用的話，則可以參考這一篇 「",[27,75,77],{"href":76},"\u002Fother\u002F20220117\u002F241830554\u002F","Mac 系統 Port 號被佔用的解決方式","」 來嘗試解決。",[16,80,81],{},"或者你可以透過 Configure 直接修改 Apache Web Server Prot 號",[16,83,84],{},[38,85],{"alt":86,"src":87},"Prot","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_45.png",[16,89,90],{},"但我這邊狀況比較特別是儘管我已經修改成 5500 Prot 依然是無法正常開啟 Apache Web Server",[16,92,93],{},[38,94],{"alt":95,"src":96},"修改 Prot","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_46.png",[16,98,99],{},"所以我又改回原本的 80 Prot。",[12,101,103],{"id":102},"刪除背景-httpd","刪除背景 httpd",[16,105,106],{},"如果上面都無效的話，另一種方式則是透過 Mac 活動監視器來解決，打開活動監視器後搜尋 httpd",[16,108,109],{},[38,110],{"alt":111,"src":112},"httpd","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_50.png",[16,114,115],{},"如果有找到的話，將下方 httpd 全部強制停止",[16,117,118],{},[38,119],{"alt":111,"src":120},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_51.png",[16,122,123],{},[38,124],{"alt":111,"src":125},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_52.png",[16,127,128],{},"接下來再去啟動 Apache Web Server 或許就可正常運作了。",[16,130,131],{},"但很可惜我依然無法正常運作，因為我根本沒有搜尋到 httpd",[16,133,134],{},[38,135],{"alt":136,"src":137},"沒搜尋到 httpd","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E6%88%AA%E5%9C%96%202022-04-17%2014.52.52.png",[12,139,141],{"id":140},"docker-影響","Docker 影響",[16,143,144],{},"後來我突然想起來我的電腦有在跑 Docker，而且剛好又是佔用 80 Port，我就試著將 Docker 整個關閉",[16,146,147],{},[38,148],{"alt":149,"src":150},"Quit Docker Desktop","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_17_14_54.png",[16,152,153],{},"然後再去啟動 Apache Web Server，果不其然真的是 Docker 影響到 Apache Web Server 導致無法開啟",[16,155,156],{},[38,157],{"alt":158,"src":159},"成功啟動","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fphp\u002F%E6%88%AA%E5%9C%96%202022-04-17%2014.56.55.png",[16,161,162],{},"但不知道為什麼 Apache Web Server Error Log 完全沒有記錄到這個 Docker 衝突錯誤，而且也不知道為什麼我明明有調整 Prot 但依然無法啟動的原因，或許是因為 Docker 本身會與 Apache Web Server 的 httpd 衝突導致整個 Apache Web Server 無法運作。",[16,164,165],{},"但是也很奇妙的是...如果我先開啟 Apache Web Server 再去打開 Docker 是可以的，Docker 也完全不會出現任何錯誤，就算針對 Apache Web Server 按下 Restart 也是可以正常運作。",[16,167,168],{},"所以基本上研判 Docker 的啟動不能比 Apache Web Server 早，否則會有一些不明原因而導致無法開啟，但是如果你是先開啟了 Apache Web Server 之後才開 Docker，那麼接下來就算你重新啟動 Apache Web Server 或者是 Stop 再去 Start 都是可以正常的唷。",[16,170,171],{},"我不得不說這個雷實在有夠特別...",{"title":173,"searchDepth":174,"depth":174,"links":175},"",2,[176,177,178,179,180,181],{"id":14,"depth":174,"text":14},{"id":21,"depth":174,"text":22},{"id":47,"depth":174,"text":48},{"id":69,"depth":174,"text":70},{"id":102,"depth":174,"text":103},{"id":140,"depth":174,"text":141},"PHP","2022-04-17 14:32:41","md","zh-Hant",{},true,"\u002Fphp\u002Fmac-xampp-apache","2",{"title":6,"description":18},false,"PHP\u002FMac-XAMPP-Apache-一直無法啟動解決方式",[22,194,195,182,196],"Apache","Mac","障礙排除",null,"\u002Fphp\u002F20220417\u002F3990325618\u002F","soWEWtMKAekjZYUl7nseshCfXZSq3aJKwGPTDP8Z1Mg",{"newer":201,"older":205},{"url":202,"title":203,"date":204},"\u002Fjavascript\u002F20220417\u002F1632354479\u002F","JavaScript 核心觀念(76) - Promise - 鏈接技巧","2022-04-17 19:38:51",{"url":206,"title":207,"date":208},"\u002Fjavascript\u002F20220417\u002F2521435150\u002F","JavaScript 核心觀念(74) - Promise - Promise 基礎概念","2022-04-17 14:16:03",[210,214,219],{"url":211,"title":212,"date":213,"readingMinutes":189},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":215,"title":216,"date":217,"readingMinutes":218},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01","3",{"url":220,"title":221,"date":222,"readingMinutes":223},"\u002Fphp\u002F20190930\u002F81339708\u002F","Day29-從基礎學習 ThinkPHP-ThinkPHP 指令","2019-09-30 00:00:02","4",1784087371812]