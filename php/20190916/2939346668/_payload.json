ine":71},2,[36,73,43],{"class":42},[36,75,47],{"class":46},[36,77,51],{"class":50},[36,79,55],{"class":54},[36,81,82],{"class":58},"'\u002Fabout\u002F:id'",[36,84,62],{"class":54},[36,86,87],{"class":58},"'about\u002Findex\u002Fselect'",[36,89,90],{"class":54},"); ",[36,92,94],{"class":93},"sQrFR","\u002F\u002F 這是動態路由的意思，後面會做加強補充說明。\n",[12,96,97],{"id":97},"拉取單一資料",[16,99,100,101,104,105,108,109,112,113,116,117,120,121,124],{},"最基礎的查詢就是單一查詢，首先讓我們開啟 ",[33,102,103],{},"about\u002Fcontroller\u002Findex.php"," 檔案，然後我們先來製作使用 ",[33,106,107],{},"id"," 取得資料的方法，假使當我們今天訪問 URL ",[33,110,111],{},"\u002Fabout\u002F1"," 會出現資料欄位 ",[33,114,115],{},"id = 1"," 的人，",[33,118,119],{},"\u002Fabout\u002F2"," 則會出現資料欄位 ",[33,122,123],{},"id = 2"," 的人以此類推，那麼這就是所謂的動態路由，動態路由簡單來講就是會隨著我們輸入的 URL 而變化的路由。",[16,126,127,128,130,131,133],{},"這邊我們將會使用 ",[33,129,107],{}," 來查詢資料，而 Model 的部分將會使用 ",[33,132,51],{}," 方法帶入參數，所以這邊就直接附上範例程式碼會比較清楚：",[26,135,137],{"className":28,"code":136,"language":30,"meta":31,"style":31},"public function select($id) {\n    $user = aboutModel::get($id);\n    echo $user->name.'\u003Cbr\u002F>';\n    echo $user->height.'\u003Cbr\u002F>';\n    echo $user->weight.'\u003Cbr\u002F>';\n}\n",[33,138,139,153,171,195,213,231],{"__ignoreMap":31},[36,140,141,144,147,150],{"class":38,"line":39},[36,142,143],{"class":46},"public",[36,145,146],{"class":46}," function",[36,148,149],{"class":50}," select",[36,151,152],{"class":54},"($id) {\n",[36,154,155,158,161,164,166,168],{"class":38,"line":71},[36,156,157],{"class":54},"    $user ",[36,159,160],{"class":46},"=",[36,162,163],{"class":42}," aboutModel",[36,165,47],{"class":46},[36,167,51],{"class":50},[36,169,170],{"class":54},"($id);\n",[36,172,174,177,180,183,186,189,192],{"class":38,"line":173},3,[36,175,176],{"class":42},"    echo",[36,178,179],{"class":54}," $user",[36,181,182],{"class":46},"->",[36,184,185],{"class":54},"name",[36,187,188],{"class":46},".",[36,190,191],{"class":58},"'\u003Cbr\u002F>'",[36,193,194],{"class":54},";\n",[3