[{"data":1,"prerenderedAt":1141},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190917\u002F3037813271\u002F":3,"page:\u002Fphp\u002F20190917\u002F3037813271\u002F":4,"alt:\u002Fphp\u002F20190917\u002F3037813271\u002F":3,"prev-next:\u002Fphp\u002F20190917\u002F3037813271\u002F":1118,"related:\u002Fphp\u002F20190917\u002F3037813271\u002F":1127},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1099,"date":1100,"description":1101,"extension":1102,"lang":1103,"meta":1104,"navigation":95,"path":1105,"readingMinutes":1106,"seo":1107,"standalone":1108,"stem":1109,"tags":1110,"tldr":1115,"updated":1115,"url":1116,"__hash__":1117},"content\u002F從基礎學習 ThinkPHP\u002FDay16-從基礎學習-ThinkPHP-資料操作-1.md","Day16-從基礎學習 ThinkPHP-資料操作(1)","3037813271",{"type":9,"value":10,"toc":1085},"minimark",[11,15,19,22,25,52,55,62,65,181,185,192,284,302,306,313,367,374,377,421,424,431,472,475,515,518,521,768,772,779,865,868,876,879,885,888,898,955,966,1072,1075,1078,1081],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"看到這一篇想必你一定會覺得很茫然為什麼要突然從 Model 基礎操作跳到資料操作呢?主要原因是想讓你明白，其實也可以使用原生的寫法來操作資料，而且不需要透過 Model，那麼就讓我們一探究竟吧!",[12,20,21],{"id":21},"起手式",[16,23,24],{},"首先如果我們想要在 Controller 中操作 DB，那就必須引入 ThinkPHP 所提供的函式庫，否則是無法操控 DB 的：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-php shiki shiki-themes github-dark-high-contrast","use think\\Db;\n","php","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40,44,48],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sWyjQ","use",[36,45,47],{"class":46},"sCcAr"," think\\Db",[36,49,51],{"class":50},"sMAXC",";\n",[16,53,54],{},"那麼由於為了避免搞混以及我個人想保留每一段我撰寫的程式碼，所以我另外建立的一個資料夾叫做 dbexample 並建立相關檔案，內容部分就不額外提供 ↓",[16,56,57],{},[58,59],"img",{"alt":60,"src":61},"資料夾","https:\u002F\u002Fi.imgur.com\u002FSXsSo3p.png",[16,63,64],{},"最主要的 Controller 初始內容會提供在這裡：",[26,66,68],{"className":28,"code":67,"language":30,"meta":31,"style":31},"\u003C?php\nnamespace app\\dbexample\\controller;\n\nuse think\\Controller;\n\nuse think\\Db;\n\nclass Index extends Controller\n{\n    public function index()\n    {\n    }\n}\n",[33,69,70,78,90,97,107,112,121,126,141,147,163,169,175],{"__ignoreMap":31},[36,71,72,75],{"class":38,"line":39},[36,73,74],{"class":42},"\u003C?",[36,76,77],{"class":46},"php\n",[36,79,81,84,88],{"class":38,"line":80},2,[36,82,83],{"class":42},"namespace",[36,85,87],{"class":86},"s_sBn"," app\\dbexample\\controller",[36,89,51],{"class":50},[36,91,93],{"class":38,"line":92},3,[36,94,96],{"emptyLinePlaceholder":95},true,"\n",[36,98,100,102,105],{"class":38,"line":99},4,[36,101,43],{"class":42},[36,103,104],{"class":46}," think\\Controller",[36,106,51],{"class":50},[36,108,110],{"class":38,"line":109},5,[36,111,96],{"emptyLinePlaceholder":95},[36,113,115,117,119],{"class":38,"line":114},6,[36,116,43],{"class":42},[36,118,47],{"class":46},[36,120,51],{"class":50},[36,122,124],{"class":38,"line":123},7,[36,125,96],{"emptyLinePlaceholder":95},[36,127,129,132,135,138],{"class":38,"line":128},8,[36,130,131],{"class":42},"class",[36,133,134],{"class":86}," Index",[36,136,137],{"class":42}," extends",[36,139,140],{"class":46}," Controller\n",[36,142,144],{"class":38,"line":143},9,[36,145,146],{"class":50},"{\n",[36,148,150,153,156,160],{"class":38,"line":149},10,[36,151,152],{"class":42},"    public",[36,154,155],{"class":42}," function",[36,157,159],{"class":158},"sj_SG"," index",[36,161,162],{"class":50},"()\n",[36,164,166],{"class":38,"line":165},11,[36,167,168],{"class":50},"    {\n",[36,170,172],{"class":38,"line":171},12,[36,173,174],{"class":50},"    }\n",[36,176,178],{"class":38,"line":177},13,[36,179,180],{"class":50},"}\n",[12,182,184],{"id":183},"原生-sql","原生 SQL",[16,186,187,188,191],{},"接下來我們在前面有學過原生的 SQL 語法，首先先讓我們建立一個資料表叫 ",[33,189,190],{},"think_db","：",[26,193,197],{"className":194,"code":195,"language":196,"meta":31,"style":31},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_db (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql",[33,198,199,213,236,263,271],{"__ignoreMap":31},[36,200,201,204,207,210],{"class":38,"line":39},[36,202,203],{"class":42},"CREATE",[36,205,206],{"class":42}," TABLE",[36,208,209],{"class":158}," think_db",[36,211,212],{"class":50}," (\n",[36,214,215,218,221,224,227,230,233],{"class":38,"line":80},[36,216,217],{"class":50},"  id ",[36,219,220],{"class":42},"int",[36,222,223],{"class":50},"(",[36,225,226],{"class":46},"10",[36,228,229],{"class":50},") ",[36,231,232],{"class":42},"NOT NULL",[36,234,235],{"class":50}," auto_increment,\n",[36,237,238,241,244,246,249,251,253,256,260],{"class":38,"line":92},[36,239,240],{"class":42},"  name",[36,242,243],{"class":42}," varchar",[36,245,223],{"class":50},[36,247,248],{"class":46},"5",[36,250,229],{"class":50},[36,252,232],{"class":42},[36,254,255],{"class":42}," default",[36,257,259],{"class":258},"sTRMh"," ''",[36,261,262],{"class":50},",\n",[36,264,265,268],{"class":38,"line":99},[36,266,267],{"class":42},"  PRIMARY KEY",[36,269,270],{"class":50}," (id)\n",[36,272,273,276,279,282],{"class":38,"line":109},[36,274,275],{"class":50},") AUTO_INCREMENT",[36,277,278],{"class":42},"=",[36,280,281],{"class":46},"1",[36,283,51],{"class":50},[16,285,286,287,290,291,294,295,298,299,301],{},"那後面我們就可以開始準備在 Controller 中使用原生的語法，也就是新增、查詢、編輯、刪除等動作，但是這邊要注意一件事，我們將會透過剛剛引入的函式庫，也就是 ",[33,288,289],{},"Db"," 來撰寫原生 SQL 語法，基本語法是使用 ",[33,292,293],{},"Db::execute","，除了查詢是使用 ",[33,296,297],{},"Db::query","，其餘都是使用 ",[33,300,293],{}," 的方式。",[303,304,305],"h3",{"id":305},"新增資料",[16,307,308,309,312],{},"使用的方式很簡單，只需要在 ",[33,310,311],{},"Db::execute('SQL 指令')"," 裡面寫入 SQL 指令就可以達到我們要的效果，這邊舉例新增資料：",[26,314,316],{"className":28,"code":315,"language":30,"meta":31,"style":31},"$result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\ndump($result);\n",[33,317,318,359],{"__ignoreMap":31},[36,319,320,323,325,328,331,334,336,339,342,345,348,350,353,356],{"class":38,"line":39},[36,321,322],{"class":50},"$result ",[36,324,278],{"class":42},[36,326,327],{"class":46}," Db",[36,329,330],{"class":42},"::",[36,332,333],{"class":158},"execute",[36,335,223],{"class":50},[36,337,338],{"class":258},"'",[36,340,341],{"class":42},"INSERT INTO",[36,343,344],{"class":258}," think_db (",[36,346,347],{"class":42},"name",[36,349,229],{"class":258},[36,351,352],{"class":42},"VALUE",[36,354,355],{"class":258}," (\"王大明\")'",[36,357,358],{"class":50},");\n",[36,360,361,364],{"class":38,"line":80},[36,362,363],{"class":158},"dump",[36,365,366],{"class":50},"($result);\n",[16,368,369,370,373],{},"最後請務必記得語法結束後，要補上 ",[33,371,372],{},"dump()","，否則並不會執行你的 SQL 指令。",[303,375,376],{"id":376},"編輯資料",[26,378,380],{"className":28,"code":379,"language":30,"meta":31,"style":31},"$result = Db::execute('UPDATE think_db SET name=\"QQ 先生\"');\ndump($result);\n",[33,381,382,415],{"__ignoreMap":31},[36,383,384,386,388,390,392,394,396,398,401,404,407,410,413],{"class":38,"line":39},[36,385,322],{"class":50},[36,387,278],{"class":42},[36,389,327],{"class":46},[36,391,330],{"class":42},[36,393,333],{"class":158},[36,395,223],{"class":50},[36,397,338],{"class":258},[36,399,400],{"class":42},"UPDATE",[36,402,403],{"class":258}," think_db ",[36,405,406],{"class":42},"SET",[36,408,409],{"class":42}," name=",[36,411,412],{"class":258},"\"QQ 先生\"'",[36,414,358],{"class":50},[36,416,417,419],{"class":38,"line":80},[36,418,363],{"class":158},[36,420,366],{"class":50},[303,422,423],{"id":423},"查詢資料",[16,425,426,427,430],{},"前面有講到唯獨查詢是使用 ",[33,428,429],{},"Db::query()"," 的方式，所以在撰寫上要稍微注意一下：",[26,432,434],{"className":28,"code":433,"language":30,"meta":31,"style":31},"$result = Db::query('SELECT think_db SET name=\"QQ 先生\"');\ndump($result);\n",[33,435,436,466],{"__ignoreMap":31},[36,437,438,440,442,444,446,449,451,453,456,458,460,462,464],{"class":38,"line":39},[36,439,322],{"class":50},[36,441,278],{"class":42},[36,443,327],{"class":46},[36,445,330],{"class":42},[36,447,448],{"class":158},"query",[36,450,223],{"class":50},[36,452,338],{"class":258},[36,454,455],{"class":42},"SELECT",[36,457,403],{"class":258},[36,459,406],{"class":42},[36,461,409],{"class":42},[36,463,412],{"class":258},[36,465,358],{"class":50},[36,467,468,470],{"class":38,"line":80},[36,469,363],{"class":158},[36,471,366],{"class":50},[303,473,474],{"id":474},"刪除資料",[26,476,478],{"className":28,"code":477,"language":30,"meta":31,"style":31},"$result = Db::query('DELETE think_db SET name=\"QQ 先生\"');\ndump($result);\n",[33,479,480,509],{"__ignoreMap":31},[36,481,482,484,486,488,490,492,494,496,499,501,503,505,507],{"class":38,"line":39},[36,483,322],{"class":50},[36,485,278],{"class":42},[36,487,327],{"class":46},[36,489,330],{"class":42},[36,491,448],{"class":158},[36,493,223],{"class":50},[36,495,338],{"class":258},[36,497,498],{"class":42},"DELETE",[36,500,403],{"class":258},[36,502,406],{"class":42},[36,504,409],{"class":42},[36,506,412],{"class":258},[36,508,358],{"class":50},[36,510,511,513],{"class":38,"line":80},[36,512,363],{"class":158},[36,514,366],{"class":50},[303,516,517],{"id":517},"完整程式碼",[16,519,520],{},"那麼我們可以將上方新增、編輯、查詢以及刪除的 SQL 指令，個別包成一個 function，稍後透過路由來訪問 Controller 進而執行這些 SQL 指令：",[26,522,524],{"className":28,"code":523,"language":30,"meta":31,"style":31},"public function add() \n{\n  $result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\n  dump($result);\n}\npublic function update() \n{\n  $result = Db::execute('UPDATE think_db SET name=\"QQ 先生\" WHERE name=\"王大明\"');\n  dump($result);\n}\npublic function select() \n{\n  $result = Db::query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\n  dump($result);\n}\npublic function delete() \n{\n  $result = Db::execute('DELETE FROM think_db WHERE name=\"QQ 先生\"');\n  dump($result);\n}\n",[33,525,526,539,543,574,581,585,596,600,637,643,647,658,662,696,703,708,720,725,756,763],{"__ignoreMap":31},[36,527,528,531,533,536],{"class":38,"line":39},[36,529,530],{"class":42},"public",[36,532,155],{"class":42},[36,534,535],{"class":158}," add",[36,537,538],{"class":50},"() \n",[36,540,541],{"class":38,"line":80},[36,542,146],{"class":50},[36,544,545,548,550,552,554,556,558,560,562,564,566,568,570,572],{"class":38,"line":92},[36,546,547],{"class":50},"  $result ",[36,549,278],{"class":42},[36,551,327],{"class":46},[36,553,330],{"class":42},[36,555,333],{"class":158},[36,557,223],{"class":50},[36,559,338],{"class":258},[36,561,341],{"class":42},[36,563,344],{"class":258},[36,565,347],{"class":42},[36,567,229],{"class":258},[36,569,352],{"class":42},[36,571,355],{"class":258},[36,573,358],{"class":50},[36,575,576,579],{"class":38,"line":99},[36,577,578],{"class":158},"  dump",[36,580,366],{"class":50},[36,582,583],{"class":38,"line":109},[36,584,180],{"class":50},[36,586,587,589,591,594],{"class":38,"line":114},[36,588,530],{"class":42},[36,590,155],{"class":42},[36,592,593],{"class":158}," update",[36,595,538],{"class":50},[36,597,598],{"class":38,"line":123},[36,599,146],{"class":50},[36,601,602,604,606,608,610,612,614,616,618,620,622,624,627,630,632,635],{"class":38,"line":128},[36,603,547],{"class":50},[36,605,278],{"class":42},[36,607,327],{"class":46},[36,609,330],{"class":42},[36,611,333],{"class":158},[36,613,223],{"class":50},[36,615,338],{"class":258},[36,617,400],{"class":42},[36,619,403],{"class":258},[36,621,406],{"class":42},[36,623,409],{"class":42},[36,625,626],{"class":258},"\"QQ 先生\" ",[36,628,629],{"class":42},"WHERE",[36,631,409],{"class":42},[36,633,634],{"class":258},"\"王大明\"'",[36,636,358],{"class":50},[36,638,639,641],{"class":38,"line":143},[36,640,578],{"class":158},[36,642,366],{"class":50},[36,644,645],{"class":38,"line":149},[36,646,180],{"class":50},[36,648,649,651,653,656],{"class":38,"line":165},[36,650,530],{"class":42},[36,652,155],{"class":42},[36,654,655],{"class":158}," select",[36,657,538],{"class":50},[36,659,660],{"class":38,"line":171},[3