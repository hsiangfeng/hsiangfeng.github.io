[{"data":1,"prerenderedAt":1142},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190917\u002F3037813271\u002F":3,"page:\u002Fphp\u002F20190917\u002F3037813271\u002F":4,"alt:\u002Fphp\u002F20190917\u002F3037813271\u002F":3,"prev-next:\u002Fphp\u002F20190917\u002F3037813271\u002F":1119,"related:\u002Fphp\u002F20190917\u002F3037813271\u002F":1128},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1100,"date":1101,"description":1102,"extension":1103,"lang":1104,"meta":1105,"navigation":95,"path":1106,"readingMinutes":1107,"seo":1108,"standalone":1109,"stem":1110,"tags":1111,"tldr":1116,"updated":1116,"url":1117,"__hash__":1118},"content\u002F從基礎學習 ThinkPHP\u002FDay16-從基礎學習-ThinkPHP-資料操作-1.md","Day16-從基礎學習 ThinkPHP-資料操作(1)","3037813271",{"type":9,"value":10,"toc":1086},"minimark",[11,15,19,22,25,52,55,62,65,182,186,193,285,303,307,314,368,375,378,422,425,432,473,476,516,519,522,769,773,780,866,869,877,880,886,889,899,956,967,1073,1076,1079,1082],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"看到這一篇想必你一定會覺得很茫然為什麼要突然從 Model 基礎操作跳到資料操作呢?主要原因是想讓你明白，其實也可以使用原生的寫法來操作資料，而且不需要透過 Model，那麼就讓我們一探究竟吧!",[12,20,21],{"id":21},"起手式",[16,23,24],{},"首先如果我們想要在 Controller 中操作 DB，那就必須引入 ThinkPHP 所提供的函式庫，否則是無法操控 DB 的：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-php shiki shiki-themes github-light github-light github-dark-high-contrast","use think\\Db;\n","php","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40,44,48],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sOudu","use",[36,45,47],{"class":46},"stw71"," think\\Db",[36,49,51],{"class":50},"s8XSl",";\n",[16,53,54],{},"那麼由於為了避免搞混以及我個人想保留每一段我撰寫的程式碼，所以我另外建立的一個資料夾叫做 dbexample 並建立相關檔案，內容部分就不額外提供 ↓",[16,56,57],{},[58,59],"img",{"alt":60,"src":61},"資料夾","https:\u002F\u002Fi.imgur.com\u002FSXsSo3p.png",[16,63,64],{},"最主要的 Controller 初始內容會提供在這裡：",[26,66,68],{"className":28,"code":67,"language":30,"meta":31,"style":31},"\u003C?php\nnamespace app\\dbexample\\controller;\n\nuse think\\Controller;\n\nuse think\\Db;\n\nclass Index extends Controller\n{\n    public function index()\n    {\n    }\n}\n",[33,69,70,78,90,97,107,112,121,126,142,148,164,170,176],{"__ignoreMap":31},[36,71,72,75],{"class":38,"line":39},[36,73,74],{"class":42},"\u003C?",[36,76,77],{"class":46},"php\n",[36,79,81,84,88],{"class":38,"line":80},2,[36,82,83],{"class":42},"namespace",[36,85,87],{"class":86},"smYoP"," app\\dbexample\\controller",[36,89,51],{"class":50},[36,91,93],{"class":38,"line":92},3,[36,94,96],{"emptyLinePlaceholder":95},true,"\n",[36,98,100,102,105],{"class":38,"line":99},4,[36,101,43],{"class":42},[36,103,104],{"class":46}," think\\Controller",[36,106,51],{"class":50},[36,108,110],{"class":38,"line":109},5,[36,111,96],{"emptyLinePlaceholder":95},[36,113,115,117,119],{"class":38,"line":114},6,[36,116,43],{"class":42},[36,118,47],{"class":46},[36,120,51],{"class":50},[36,122,124],{"class":38,"line":123},7,[36,125,96],{"emptyLinePlaceholder":95},[36,127,129,132,135,138],{"class":38,"line":128},8,[36,130,131],{"class":42},"class",[36,133,134],{"class":86}," Index",[36,136,137],{"class":42}," extends",[36,139,141],{"class":140},"sK3KL"," Controller\n",[36,143,145],{"class":38,"line":144},9,[36,146,147],{"class":50},"{\n",[36,149,151,154,157,161],{"class":38,"line":150},10,[36,152,153],{"class":42},"    public",[36,155,156],{"class":42}," function",[36,158,160],{"class":159},"scAaK"," index",[36,162,163],{"class":50},"()\n",[36,165,167],{"class":38,"line":166},11,[36,168,169],{"class":50},"    {\n",[36,171,173],{"class":38,"line":172},12,[36,174,175],{"class":50},"    }\n",[36,177,179],{"class":38,"line":178},13,[36,180,181],{"class":50},"}\n",[12,183,185],{"id":184},"原生-sql","原生 SQL",[16,187,188,189,192],{},"接下來我們在前面有學過原生的 SQL 語法，首先先讓我們建立一個資料表叫 ",[33,190,191],{},"think_db","：",[26,194,198],{"className":195,"code":196,"language":197,"meta":31,"style":31},"language-sql shiki shiki-themes github-light github-light github-dark-high-contrast","CREATE TABLE think_db (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql",[33,199,200,214,237,264,272],{"__ignoreMap":31},[36,201,202,205,208,211],{"class":38,"line":39},[36,203,204],{"class":42},"CREATE",[36,206,207],{"class":42}," TABLE",[36,209,210],{"class":159}," think_db",[36,212,213],{"class":50}," (\n",[36,215,216,219,222,225,228,231,234],{"class":38,"line":80},[36,217,218],{"class":50},"  id ",[36,220,221],{"class":42},"int",[36,223,224],{"class":50},"(",[36,226,227],{"class":46},"10",[36,229,230],{"class":50},") ",[36,232,233],{"class":42},"NOT NULL",[36,235,236],{"class":50}," auto_increment,\n",[36,238,239,242,245,247,250,252,254,257,261],{"class":38,"line":92},[36,240,241],{"class":42},"  name",[36,243,244],{"class":42}," varchar",[36,246,224],{"class":50},[36,248,249],{"class":46},"5",[36,251,230],{"class":50},[36,253,233],{"class":42},[36,255,256],{"class":42}," default",[36,258,260],{"class":259},"sWayO"," ''",[36,262,263],{"class":50},",\n",[36,265,266,269],{"class":38,"line":99},[36,267,268],{"class":42},"  PRIMARY KEY",[36,270,271],{"class":50}," (id)\n",[36,273,274,277,280,283],{"class":38,"line":109},[36,275,276],{"class":50},") AUTO_INCREMENT",[36,278,279],{"class":42},"=",[36,281,282],{"class":46},"1",[36,284,51],{"class":50},[16,286,287,288,291,292,295,296,299,300,302],{},"那後面我們就可以開始準備在 Controller 中使用原生的語法，也就是新增、查詢、編輯、刪除等動作，但是這邊要注意一件事，我們將會透過剛剛引入的函式庫，也就是 ",[33,289,290],{},"Db"," 來撰寫原生 SQL 語法，基本語法是使用 ",[33,293,294],{},"Db::execute","，除了查詢是使用 ",[33,297,298],{},"Db::query","，其餘都是使用 ",[33,301,294],{}," 的方式。",[304,305,306],"h3",{"id":306},"新增資料",[16,308,309,310,313],{},"使用的方式很簡單，只需要在 ",[33,311,312],{},"Db::execute('SQL 指令')"," 裡面寫入 SQL 指令就可以達到我們要的效果，這邊舉例新增資料：",[26,315,317],{"className":28,"code":316,"language":30,"meta":31,"style":31},"$result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\ndump($result);\n",[33,318,319,360],{"__ignoreMap":31},[36,320,321,324,326,329,332,335,337,340,343,346,349,351,354,357],{"class":38,"line":39},[36,322,323],{"class":50},"$result ",[36,325,279],{"class":42},[36,327,328],{"class":46}," Db",[36,330,331],{"class":42},"::",[36,333,334],{"class":159},"execute",[36,336,224],{"class":50},[36,338,339],{"class":259},"'",[36,341,342],{"class":42},"INSERT INTO",[36,344,345],{"class":259}," think_db (",[36,347,348],{"class":42},"name",[36,350,230],{"class":259},[36,352,353],{"class":42},"VALUE",[36,355,356],{"class":259}," (\"王大明\")'",[36,358,359],{"class":50},");\n",[36,361,362,365],{"class":38,"line":80},[36,363,364],{"class":159},"dump",[36,366,367],{"class":50},"($result);\n",[16,369,370,371,374],{},"最後請務必記得語法結束後，要補上 ",[33,372,373],{},"dump()","，否則並不會執行你的 SQL 指令。",[304,376,377],{"id":377},"編輯資料",[26,379,381],{"className":28,"code":380,"language":30,"meta":31,"style":31},"$result = Db::execute('UPDATE think_db SET name=\"QQ 先生\"');\ndump($result);\n",[33,382,383,416],{"__ignoreMap":31},[36,384,385,387,389,391,393,395,397,399,402,405,408,411,414],{"class":38,"line":39},[36,386,323],{"class":50},[36,388,279],{"class":42},[36,390,328],{"class":46},[36,392,331],{"class":42},[36,394,334],{"class":159},[36,396,224],{"class":50},[36,398,339],{"class":259},[36,400,401],{"class":42},"UPDATE",[36,403,404],{"class":259}," think_db ",[36,406,407],{"class":42},"SET",[36,409,410],{"class":42}," name=",[36,412,413],{"class":259},"\"QQ 先生\"'",[36,415,359],{"class":50},[36,417,418,420],{"class":38,"line":80},[36,419,364],{"class":159},[36,421,367],{"class":50},[304,423,424],{"id":424},"查詢資料",[16,426,427,428,431],{},"前面有講到唯獨查詢是使用 ",[33,429,430],{},"Db::query()"," 的方式，所以在撰寫上要稍微注意一下：",[26,433,435],{"className":28,"code":434,"language":30,"meta":31,"style":31},"$result = Db::query('SELECT think_db SET name=\"QQ 先生\"');\ndump($result);\n",[33,436,437,467],{"__ignoreMap":31},[36,438,439,441,443,445,447,450,452,454,457,459,461,463,465],{"class":38,"line":39},[36,440,323],{"class":50},[36,442,279],{"class":42},[36,444,328],{"class":46},[36,446,331],{"class":42},[36,448,449],{"class":159},"query",[36,451,224],{"class":50},[36,453,339],{"class":259},[36,455,456],{"class":42},"SELECT",[36,458,404],{"class":259},[36,460,407],{"class":42},[36,462,410],{"class":42},[36,464,413],{"class":259},[36,466,359],{"class":50},[36,468,469,471],{"class":38,"line":80},[36,470,364],{"class":159},[36,472,367],{"class":50},[304,474,475],{"id":475},"刪除資料",[26,477,479],{"className":28,"code":478,"language":30,"meta":31,"style":31},"$result = Db::query('DELETE think_db SET name=\"QQ 先生\"');\ndump($result);\n",[33,480,481,510],{"__ignoreMap":31},[36,482,483,485,487,489,491,493,495,497,500,502,504,506,508],{"class":38,"line":39},[36,484,323],{"class":50},[36,486,279],{"class":42},[36,488,328],{"class":46},[36,490,331],{"class":42},[36,492,449],{"class":159},[36,494,224],{"class":50},[36,496,339],{"class":259},[36,498,499],{"class":42},"DELETE",[36,501,404],{"class":259},[36,503,407],{"class":42},[36,505,410],{"class":42},[36,507,413],{"class":259},[36,509,359],{"class":50},[36,511,512,514],{"class":38,"line":80},[36,513,364],{"class":159},[36,515,367],{"class":50},[304,517,518],{"id":518},"完整程式碼",[16,520,521],{},"那麼我們可以將上方新增、編輯、查詢以及刪除的 SQL 指令，個別包成一個 function，稍後透過路由來訪問 Controller 進而執行這些 SQL 指令：",[26,523,525],{"className":28,"code":524,"language":30,"meta":31,"style":31},"public function add() \n{\n  $result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\n  dump($result);\n}\npublic function update() \n{\n  $result = Db::execute('UPDATE think_db SET name=\"QQ 先生\" WHERE name=\"王大明\"');\n  dump($result);\n}\npublic function select() \n{\n  $result = Db::query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\n  dump($result);\n}\npublic function delete() \n{\n  $result = Db::execute('DELETE FROM think_db WHERE name=\"QQ 先生\"');\n  dump($result);\n}\n",[33,526,527,540,544,575,582,586,597,601,638,644,648,659,663,697,704,709,721,726,757,764],{"__ignoreMap":31},[36,528,529,532,534,537],{"class":38,"line":39},[36,530,531],{"class":42},"public",[36,533,156],{"class":42},[36,535,536],{"class":159}," add",[36,538,539],{"class":50},"() \n",[36,541,542],{"class":38,"line":80},[36,543,147],{"class":50},[36,545,546,549,551,553,555,557,559,561,563,565,567,569,571,573],{"class":38,"line":92},[36,547,548],{"class":50},"  $result ",[36,550,279],{"class":42},[36,552,328],{"class":46},[36,554,331],{"class":42},[36,556,334],{"class":159},[36,558,224],{"class":50},[36,560,339],{"class":259},[36,562,342],{"class":42},[36,564,345],{"class":259},[36,566,348],{"class":42},[36,568,230],{"class":259},[36,570,353],{"class":42},[36,572,356],{"class":259},[36,574,359],{"class":50},[36,576,577,580],{"class":38,"line":99},[36,578,579],{"class":159},"  dump",[36,581,367],{"class":50},[36,583,584],{"class":38,"line":109},[36,585,181],{"class":50},[36,587,588,590,592,595],{"class":38,"line":114},[36,589,531],{"class":42},[36,591,156],{"class":42},[36,593,594],{"class":159}," update",[36,596,539],{"class":50},[36,598,599],{"class":38,"line":123},[36,600,147],{"class":50},[36,602,603,605,607,609,611,613,615,617,619,621,623,625,628,631,633,636],{"class":38,"line":128},[36,604,548],{"class":50},[36,606,279],{"class":42},[36,608,328],{"class":46},[36,610,331],{"class":42},[36,612,334],{"class":159},[36,614,224],{"class":50},[36,616,339],{"class":259},[36,618,401],{"class":42},[36,620,404],{"class":259},[36,622,407],{"class":42},[36,624,410],{"class":42},[36,626,627],{"class":259},"\"QQ 先生\" ",[36,629,630],{"class":42},"WHERE",[36,632,410],{"class":42},[36,634,635],{"class":259},"\"王大明\"'",[36,637,359],{"class":50},[36,639,640,642],{"class":38,"line":144},[36,641,579],{"class":159},[36,643,367],{"class":50},[36,645,646],{"class":38,"line":150},[36,647,181],{"class":50},[36,649,650,652,654,657],{"class":38,"line":166},[36,651,531],{"class":42},[36,653,156],{"class":42},[36,655,656],{"class":159}," select",[36,658,539],{"class":50},[36,660,661],{"class":38,"line":172},[36,662,147],{"class":50},[36,664,665,667,669,671,673,675,677,679,681,684,687,689,691,693,695],{"class":38,"line":178},[36,666,548],{"class":50},[36,668,279],{"class":42},[36,670,328],{"class":46},[36,672,331],{"class":42},[36,674,449],{"class":159},[36,676,224],{"class":50},[36,678,339],{"class":259},[36,680,456],{"class":42},[36,682,683],{"class":42}," *",[36,685,686],{"class":42}," FROM",[36,688,404],{"class":259},[36,690,630],{"class":42},[36,692,410],{"class":42},[36,694,413],{"class":259},[36,696,359],{"class":50},[36,698,700,702],{"class":38,"line":699},14,[36,701,579],{"class":159},[36,703,367],{"class":50},[36,705,707],{"class":38,"line":706},15,[36,708,181],{"class":50},[36,710,712,714,716,719],{"class":38,"line":711},16,[36,713,531],{"class":42},[36,715,156],{"class":42},[36,717,718],{"class":159}," delete",[36,720,539],{"class":50},[36,722,724],{"class":38,"line":723},17,[36,725,147],{"class":50},[36,727,729,731,733,735,737,739,741,743,745,747,749,751,753,755],{"class":38,"line":728},18,[36,730,548],{"class":50},[36,732,279],{"class":42},[36,734,328],{"class":46},[36,736,331],{"class":42},[36,738,334],{"class":159},[36,740,224],{"class":50},[36,742,339],{"class":259},[36,744,499],{"class":42},[36,746,686],{"class":42},[36,748,404],{"class":259},[36,750,630],{"class":42},[36,752,410],{"class":42},[36,754,413],{"class":259},[36,756,359],{"class":50},[36,758,760,762],{"class":38,"line":759},19,[36,761,579],{"class":159},[36,763,367],{"class":50},[36,765,767],{"class":38,"line":766},20,[36,768,181],{"class":50},[304,770,772],{"id":771},"route","Route",[16,774,775,776,779],{},"註冊路由的部分比較沒有什麼好講的，因為只是要作範例，所以我這邊一路都使用 ",[33,777,778],{},"get"," 來註冊路由：",[26,781,783],{"className":28,"code":782,"language":30,"meta":31,"style":31},"Route::get('\u002Fdbexample\u002Fadd', 'dbexample\u002Findex\u002Fadd');\nRoute::get('\u002Fdbexample\u002Fupdate', 'dbexample\u002Findex\u002Fupdate');\nRoute::get('\u002Fdbexample\u002Fselect', 'dbexample\u002Findex\u002Fselect');\nRoute::get('\u002Fdbexample\u002Fdelete', 'dbexample\u002Findex\u002Fdelete');\n",[33,784,785,806,826,846],{"__ignoreMap":31},[36,786,787,789,791,793,795,798,801,804],{"class":38,"line":39},[36,788,772],{"class":46},[36,790,331],{"class":42},[36,792,778],{"class":159},[36,794,224],{"class":50},[36,796,797],{"class":259},"'\u002Fdbexample\u002Fadd'",[36,799,800],{"class":50},", ",[36,802,803],{"class":259},"'dbexample\u002Findex\u002Fadd'",[36,805,359],{"class":50},[36,807,808,810,812,814,816,819,821,824],{"class":38,"line":80},[36,809,772],{"class":46},[36,811,331],{"class":42},[36,813,778],{"class":159},[36,815,224],{"class":50},[36,817,818],{"class":259},"'\u002Fdbexample\u002Fupdate'",[36,820,800],{"class":50},[36,822,823],{"class":259},"'dbexample\u002Findex\u002Fupdate'",[36,825,359],{"class":50},[36,827,828,830,832,834,836,839,841,844],{"class":38,"line":92},[36,829,772],{"class":46},[36,831,331],{"class":42},[36,833,778],{"class":159},[36,835,224],{"class":50},[36,837,838],{"class":259},"'\u002Fdbexample\u002Fselect'",[36,840,800],{"class":50},[36,842,843],{"class":259},"'dbexample\u002Findex\u002Fselect'",[36,845,359],{"class":50},[36,847,848,850,852,854,856,859,861,864],{"class":38,"line":99},[36,849,772],{"class":46},[36,851,331],{"class":42},[36,853,778],{"class":159},[36,855,224],{"class":50},[36,857,858],{"class":259},"'\u002Fdbexample\u002Fdelete'",[36,860,800],{"class":50},[36,862,863],{"class":259},"'dbexample\u002Findex\u002Fdelete'",[36,865,359],{"class":50},[16,867,868],{},"接下來我會建議依照我建議的流程來瀏覽 URL，避免出現無法訪問之問題。",[26,870,875],{"className":871,"code":873,"language":874,"meta":31},[872],"language-text","建議流程：add → updata → select → delete (否則可能出現錯誤)\n","text",[33,876,873],{"__ignoreMap":31},[16,878,879],{},"那麼我這邊就只附上查詢的結果 ↓",[16,881,882],{},[58,883],{"alt":884,"src":885},"使用 query 方法所查詢的結果會返回一個陣列","https:\u002F\u002Fi.imgur.com\u002FcGE4Bss.png",[12,887,888],{"id":888},"切換資料庫連接",[16,890,891,892,894,895,898],{},"當然你也可以透過 ",[33,893,290],{}," 中其中一個方法來切換資料庫連結，也就是 ",[33,896,897],{},"Db::connect([資料庫連接])","，範例如下：",[26,900,902],{"className":28,"code":901,"language":30,"meta":31,"style":31},"$result = Db::connect('mysql:\u002F\u002Froot:123456@localhost:3306\u002Fithelp')->query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result);\n",[33,903,904,950],{"__ignoreMap":31},[36,905,906,908,910,912,914,917,919,922,925,928,930,932,934,936,938,940,942,944,946,948],{"class":38,"line":39},[36,907,323],{"class":50},[36,909,279],{"class":42},[36,911,328],{"class":46},[36,913,331],{"class":42},[36,915,916],{"class":159},"connect",[36,918,224],{"class":50},[36,920,921],{"class":259},"'mysql:\u002F\u002Froot:123456@localhost:3306\u002Fithelp'",[36,923,924],{"class":50},")",[36,926,927],{"class":42},"->",[36,929,449],{"class":159},[36,931,224],{"class":50},[36,933,339],{"class":259},[36,935,456],{"class":42},[36,937,683],{"class":42},[36,939,686],{"class":42},[36,941,404],{"class":259},[36,943,630],{"class":42},[36,945,410],{"class":42},[36,947,413],{"class":259},[36,949,359],{"class":50},[36,951,952,954],{"class":38,"line":80},[36,953,364],{"class":159},[36,955,367],{"class":50},[16,957,958,959,962,963,966],{},"但是這種方式並不是非常好，最主要會導致程式碼複雜並且難以維護，所以一般來講我們會在 ",[33,960,961],{},"application"," 底下增加一個檔案叫 config.php，並依照 ",[33,964,965],{},"project\u002Fconfig"," 底下的 database.php 內容當作範例，然後製作成一個陣列，並依照相關參數這樣傳入即可：",[26,968,970],{"className":28,"code":969,"language":30,"meta":31,"style":31},"$result1 = Db::connect('qq1')->query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result2);\n$result2 = Db::connect('qq2')->query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result2);\n",[33,971,972,1016,1023,1067],{"__ignoreMap":31},[36,973,974,977,979,981,983,985,987,990,992,994,996,998,1000,1002,1004,1006,1008,1010,1012,1014],{"class":38,"line":39},[36,975,976],{"class":50},"$result1 ",[36,978,279],{"class":42},[36,980,328],{"class":46},[36,982,331],{"class":42},[36,984,916],{"class":159},[36,986,224],{"class":50},[36,988,989],{"class":259},"'qq1'",[36,991,924],{"class":50},[36,993,927],{"class":42},[36,995,449],{"class":159},[36,997,224],{"class":50},[36,999,339],{"class":259},[36,1001,456],{"class":42},[36,1003,683],{"class":42},[36,1005,686],{"class":42},[36,1007,404],{"class":259},[36,1009,630],{"class":42},[36,1011,410],{"class":42},[36,1013,413],{"class":259},[36,1015,359],{"class":50},[36,1017,1018,1020],{"class":38,"line":80},[36,1019,364],{"class":159},[36,1021,1022],{"class":50},"($result2);\n",[36,1024,1025,1028,1030,1032,1034,1036,1038,1041,1043,1045,1047,1049,1051,1053,1055,1057,1059,1061,1063,1065],{"class":38,"line":92},[36,1026,1027],{"class":50},"$result2 ",[36,1029,279],{"class":42},[36,1031,328],{"class":46},[36,1033,331],{"class":42},[36,1035,916],{"class":159},[36,1037,224],{"class":50},[36,1039,1040],{"class":259},"'qq2'",[36,1042,924],{"class":50},[36,1044,927],{"class":42},[36,1046,449],{"class":159},[36,1048,224],{"class":50},[36,1050,339],{"class":259},[36,1052,456],{"class":42},[36,1054,683],{"class":42},[36,1056,686],{"class":42},[36,1058,404],{"class":259},[36,1060,630],{"class":42},[36,1062,410],{"class":42},[36,1064,413],{"class":259},[36,1066,359],{"class":50},[36,1068,1069,1071],{"class":38,"line":99},[36,1070,364],{"class":159},[36,1072,1022],{"class":50},[16,1074,1075],{},"那麼這就是切換資料庫連接的方式，但是上方的範例我這邊就不實作，因為這種方式我實際上並沒有開發以及使用過，而且也比較少遇到這種狀況。",[12,1077,1078],{"id":1078},"結尾",[16,1080,1081],{},"我們可以發現若不透過 Model 來操作資料是一件非常麻煩的事情，而且這些動作也不符合 MVC 觀念，畢竟沒有將 Model 的邏輯給切出來，所以當系統越來越龐大時，就會導致系統維護上的困擾。",[1083,1084,1085],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html .light .shiki span {color: var(--shiki-l