t('\u002Fdbexample\u002Fdelete', 'dbexample\u002Findex\u002Fdelete');\n",[33,783,784,805,825,845],{"__ignoreMap":31},[36,785,786,788,790,792,794,797,800,803],{"class":38,"line":39},[36,787,771],{"class":46},[36,789,330],{"class":42},[36,791,777],{"class":158},[36,793,223],{"class":50},[36,795,796],{"class":258},"'\u002Fdbexample\u002Fadd'",[36,798,799],{"class":50},", ",[36,801,802],{"class":258},"'dbexample\u002Findex\u002Fadd'",[36,804,358],{"class":50},[36,806,807,809,811,813,815,818,820,823],{"class":38,"line":80},[36,808,771],{"class":46},[36,810,330],{"class":42},[36,812,777],{"class":158},[36,814,223],{"class":50},[36,816,817],{"class":258},"'\u002Fdbexample\u002Fupdate'",[36,819,799],{"class":50},[36,821,822],{"class":258},"'dbexample\u002Findex\u002Fupdate'",[36,824,358],{"class":50},[36,826,827,829,831,833,835,838,840,843],{"class":38,"line":92},[36,828,771],{"class":46},[36,830,330],{"class":42},[36,832,777],{"class":158},[36,834,223],{"class":50},[36,836,837],{"class":258},"'\u002Fdbexample\u002Fselect'",[36,839,799],{"class":50},[36,841,842],{"class":258},"'dbexample\u002Findex\u002Fselect'",[36,844,358],{"class":50},[36,846,847,849,851,853,855,858,860,863],{"class":38,"line":99},[36,848,771],{"class":46},[36,850,330],{"class":42},[36,852,777],{"class":158},[36,854,223],{"class":50},[36,856,857],{"class":258},"'\u002Fdbexample\u002Fdelete'",[36,859,799],{"class":50},[36,861,862],{"class":258},"'dbexample\u002Findex\u002Fdelete'",[36,864,358],{"class":50},[16,866,867],{},"接下來我會建議依照我建議的流程來瀏覽 URL，避免出現無法訪問之問題。",[26,869,874],{"className":870,"code":872,"language":873,"meta":31},[871],"language-text","建議流程：add → updata → select → delete (否則可能出現錯誤)\n","text",[33,875,872],{"__ignoreMap":31},[16,877,878],{},"那麼我這邊就只附上查詢的結果 ↓",[16,880,881],{},[58,882],{"alt":883,"src":884},"使用 query 方法所查詢的結果會返回一個陣列","https:\u002F\u002Fi.imgur.com\u002FcGE4Bss.png",[12,886,887],{"id":887},"切換資料庫連接",[16,889,890,891,893,894,897],{},"當然你也可以透過 ",[33,892,289],{}," 中其中一個方法來切換資料庫連結，也就是 "