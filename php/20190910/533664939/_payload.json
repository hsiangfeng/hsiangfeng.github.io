[{"data":1,"prerenderedAt":397},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190910\u002F533664939\u002F":3,"page:\u002Fphp\u002F20190910\u002F533664939\u002F":4,"alt:\u002Fphp\u002F20190910\u002F533664939\u002F":3,"prev-next:\u002Fphp\u002F20190910\u002F533664939\u002F":374,"related:\u002Fphp\u002F20190910\u002F533664939\u002F":383},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F10\u002Fthinkphp-day-09-controller\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":356,"date":357,"description":18,"extension":358,"lang":359,"meta":360,"navigation":121,"path":361,"readingMinutes":362,"seo":363,"standalone":364,"stem":365,"tags":366,"tldr":371,"updated":371,"url":372,"__hash__":373},"content\u002F從基礎學習 ThinkPHP\u002FDay9-從基礎學習-ThinkPHP-Controller.md","Day9-從基礎學習 ThinkPHP-Controller","533664939",{"type":9,"value":10,"toc":349},"minimark",[11,15,19,23,31,38,53,59,62,69,80,184,201,207,210,213,217,220,246,251,254,320,327,333,339,342,345],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面了解了 MVC 架構之後，我們就要準備來撰寫程式碼，首先會寫的是 Controller 的部分，但是在那之前會有一些地方要先改一下設置，這樣才能方便我們開發。",[12,20,22],{"id":21},"開啟-debug-模式","開啟 Debug 模式",[16,24,25,26,30],{},"我建議在操作接下來的動作之前，先開啟 debug 模式，如果你不開啟 debug 模式你會很難找問題(就跟你寫 JavaScript 不使用 ",[27,28,29],"code",{},"console.log()"," debug 一樣)，那開啟之後你就可以看到比較詳細的錯誤訊息，這樣子對於你在開發上也會比較清楚問題在哪裡，但是要記得部屬專案時，請務必要關閉 debug 模式 唷 ↓",[16,32,33],{},[34,35],"img",{"alt":36,"src":37},"debug 模式開啟","https:\u002F\u002Fi.imgur.com\u002FAYFup2L.png",[16,39,40,41,44,45,48,49,52],{},"開啟方式很簡單，只要開啟位於專案目錄 ",[27,42,43],{},"config\u002Fapp.php"," 中，然後搜尋 ",[27,46,47],{},"app_debug"," 將該選項修改為 ",[27,50,51],{},"true"," 這樣就開啟了 debug 模式囉 ↓",[16,54,55],{},[34,56],{"alt":57,"src":58},"debug","https:\u002F\u002Fi.imgur.com\u002F9JgeL7H.png",[12,60,61],{"id":61},"起手式",[16,63,64,65,68],{},"起手式這邊我們會先學習如何定義一個 Controller，那什麼是定義呢?所謂的定義你可以想像成我們在準備要蓋東西的材料，以 JavaScript 舉例的話，就像是建立一個 ",[27,66,67],{},"function"," 的概念，所以不用想太難唷~",[16,70,71,72,75,76,79],{},"首先讓我們打開目錄到 ",[27,73,74],{},"\u002Fproject\u002Fapplication"," 下，然後在底下建立一個資料夾叫 about，並且在底下再建立一個 controller 資料夾(注意不要大寫 C)，然後也建立一個 ",[27,77,78],{},"index.php"," 檔案，初始內容則如下：",[81,82,87],"pre",{"className":83,"code":84,"language":85,"meta":86,"style":86},"language-php shiki shiki-themes github-dark-high-contrast","\u003C?php\nnamespace app\\about\\controller;\n\nclass Index\n{\n    public function index()\n    {\n        return 'About!';\n    }\n}\n","php","",[27,88,89,102,116,123,132,138,154,160,172,178],{"__ignoreMap":86},[90,91,94,98],"span",{"class":92,"line":93},"line",1,[90,95,97],{"class":96},"sWyjQ","\u003C?",[90,99,101],{"class":100},"sCcAr","php\n",[90,103,105,108,112],{"class":92,"line":104},2,[90,106,107],{"class":96},"namespace",[90,109,111],{"class":110},"s_sBn"," app\\about\\controller",[90,113,115],{"class":114},"sMAXC",";\n",[90,117,119],{"class":92,"line":118},3,[90,120,122],{"emptyLinePlaceholder":121},true,"\n",[90,124,126,129],{"class":92,"line":125},4,[90,127,128],{"class":96},"class",[90,130,131],{"class":110}," Index\n",[90,133,135],{"class":92,"line":134},5,[90,136,137],{"class":114},"{\n",[90,139,141,144,147,151],{"class":92,"line":140},6,[90,142,143],{"class":96},"    public",[90,145,146],{"class":96}," function",[90,148,150],{"class":149},"sj_SG"," index",[90,152,153],{"class":114},"()\n",[90,155,157],{"class":92,"line":156},7,[90,158,159],{"class":114},"    {\n",[90,161,163,166,170],{"class":92,"line":162},8,[90,164,165],{"class":96},"        return",[90,167,169],{"class":168},"sTRMh"," 'About!'",[90,171,115],{"class":114},[90,173,175],{"class":92,"line":174},9,[90,176,177],{"class":114},"    }\n",[90,179,181],{"class":92,"line":180},10,[90,182,183],{"class":114},"}\n",[16,185,186,187,189,190,193,194,197,198,200],{},"這邊要注意 ",[27,188,107],{}," 的意思是定義命名空間，所以不要使用預設 ",[27,191,192],{},"namespace app\\index\\controller;"," 而是要將命名空間定義成 ",[27,195,196],{},"about","，如果不這樣做，將會導致發生衝突問題，當然也會因為你的 ",[27,199,107],{}," 不正確而導致找不到 Controller 的問題發生 ↓",[16,202,203],{},[34,204],{"alt":205,"src":206},"找不到控制器","https:\u002F\u002Fi.imgur.com\u002FplEhhAA.png",[16,208,209],{},"那麼這樣子就是一個基礎的起手式定義 Controller，非常簡單吧~",[16,211,212],{},"但是我們前面有講過，在現階段開發上，我們是採用 Route 來訪問 URL，但是 Route 定義的部分將會在後面做介紹。",[12,214,216],{"id":215},"url-訪問","URL 訪問",[16,218,219],{},"在目錄結構的結尾我有稍微介紹 URL 的結構，主要會是透過 Route 來決定 URL 訪問，那麼這邊再稍微講一下 URL　的訪問相關吧！",[16,221,222,223,226,227,230,231,234,235,237,238,241,242,245],{},"首先 ThinkPHP 預設 Controller 訪問 URL 規則是這樣子 ",[27,224,225],{},"http:\u002F\u002Flocalhost:8000\u002Findex\u002Findex","，通常 ",[27,228,229],{},"index"," 可以被忽略，所以只需要輸入 ",[27,232,233],{},"http:\u002F\u002Flocalhost:8000"," 即可，但若我們想要訪問 ",[27,236,196],{}," 的 Controller 中 index 方法的話，就會變成這樣 ",[27,239,240],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Findex","，當然也可以只輸入這樣子 ",[27,243,244],{},"http:\u002F\u002Flocalhost:8000\u002Fabout"," ↓",[16,247,248],{},[34,249],{"alt":216,"src":250},"https:\u002F\u002Fi.imgur.com\u002F01ZMjh5.png",[16,252,253],{},"但是假使果我們的 about 底下還有其他 Controller呢?例如 HelloWorld.php，而以下是程式碼初始內容：",[81,255,257],{"className":83,"code":256,"language":85,"meta":86,"style":86},"\u003C?php\nnamespace app\\about\\controller;\n\nclass HelloWorld\n{\n    public function Hello()\n    {\n        return 'hello，world！';\n    }\n}\n",[27,258,259,265,273,277,284,288,299,303,312,316],{"__ignoreMap":86},[90,260,261,263],{"class":92,"line":93},[90,262,97],{"class":96},[90,264,101],{"class":100},[90,266,267,269,271],{"class":92,"line":104},[90,268,107],{"class":96},[90,270,111],{"class":110},[90,272,115],{"class":114},[90,274,275],{"class":92,"line":118},[90,276,122],{"emptyLinePlaceholder":121},[90,278,279,281],{"class":92,"line":125},[90,280,128],{"class":96},[90,282,283],{"class":110}," HelloWorld\n",[90,285,286],{"class":92,"line":134},[90,287,137],{"class":114},[90,289,290,292,294,297],{"class":92,"line":140},[90,291,143],{"class":96},[90,293,146],{"class":96},[90,295,296],{"class":149}," Hello",[90,298,153],{"class":114},[90,300,301],{"class":92,"line":156},[90,302,159],{"class":114},[90,304,305,307,310],{"class":92,"line":162},[90,306,165],{"class":96},[90,308,309],{"class":168}," 'hello，world！'",[90,311,115],{"class":114},[90,313,314],{"class":92,"line":174},[90,315,177],{"class":114},[90,317,318],{"class":92,"line":180},[90,319,183],{"class":114},[16,321,322,323,326],{},"那麼 URL 訪問的方式就會是這樣 ",[27,324,325],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fhello_world\u002Fhello","。",[16,328,329,330,245],{},"ThinkPHP 在轉換 URL 時，當遇到大寫會轉換為小寫，若是夾在中間的大寫則會轉換為底線 ",[27,331,332],{},"_",[16,334,335],{},[34,336],{"alt":337,"src":338},"hello，world","https:\u002F\u002Fi.imgur.com\u002FEwBKzhI.png",[12,340,341],{"id":341},"結尾",[16,343,344],{},"其實我們可以發現不透過 View 單純使用 Controller 也是可以呈現畫面給使用者，但是這樣子就有點不符合 MVC 的設計規範，所以這一篇只是介紹基礎的 Controller 定義方法與操作而已，後面還會有更多的 Controller 撰寫唷。",[346,347,348],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":86,"searchDepth":104,"depth":104,"links":350},[351,352,353,354,355],{"id":14,"depth":104,"text":14},{"id":21,"depth":104,"text":22},{"id":61,"depth":104,"text":61},{"id":215,"depth":104,"text":216},{"id":341,"depth":104,"text":341},"PHP","2019-09-10 00:07:30","md","