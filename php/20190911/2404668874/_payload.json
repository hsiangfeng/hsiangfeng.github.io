[{"data":1,"prerenderedAt":777},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190911\u002F2404668874\u002F":3,"page:\u002Fphp\u002F20190911\u002F2404668874\u002F":4,"alt:\u002Fphp\u002F20190911\u002F2404668874\u002F":3,"prev-next:\u002Fphp\u002F20190911\u002F2404668874\u002F":754,"related:\u002Fphp\u002F20190911\u002F2404668874\u002F":763},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":736,"date":737,"description":18,"extension":738,"lang":739,"meta":740,"navigation":285,"path":741,"readingMinutes":742,"seo":743,"standalone":744,"stem":745,"tags":746,"tldr":751,"updated":751,"url":752,"__hash__":753},"content\u002F從基礎學習 ThinkPHP\u002FDay10-從基礎學習-ThinkPHP-View.md","Day10-從基礎學習 ThinkPHP-View","2404668874",{"type":9,"value":10,"toc":729},"minimark",[11,15,19,22,30,225,228,232,243,246,252,367,378,385,392,398,401,407,419,509,515,521,524,541,656,670,676,686,692,695,698,701,716,725],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來這一篇將會介紹 MVC 中的 View，也就是視圖，前一篇我們學習了 Controller 基礎定義，那麼接下來我們就會來學習 View，最後再來學 Model，當然這邊我們也會學習一點點的 HTML Template 唷!",[12,20,21],{"id":21},"起手式",[16,23,24,25,29],{},"首先先讓我們到專案的 ",[26,27,28],"code",{},"application\\about"," 底下建立一個 view 資料夾，並也在底下建立一個 hello_world 資料夾(注意遇到大寫就轉小寫)，並且在底下建立一個 HelloWorld.html，初始 View 內容如下：",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \u003Ctitle>這是打招呼介面\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>Say Hi!\u003C\u002Fh1>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html","",[26,38,39,59,79,89,108,133,157,172,182,192,207,216],{"__ignoreMap":36},[40,