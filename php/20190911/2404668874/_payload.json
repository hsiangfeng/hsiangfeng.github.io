58],{"class":46},[40,193,195,197,200,203,205],{"class":42,"line":194},10,[40,196,94],{"class":46},[40,198,199],{"class":50},"h1",[40,201,202],{"class":46},">Say Hi!\u003C\u002F",[40,204,199],{"class":50},[40,206,58],{"class":46},[40,208,210,212,214],{"class":42,"line":209},11,[40,211,177],{"class":46},[40,213,189],{"class":50},[40,215,58],{"class":46},[40,217,219,221,223],{"class":42,"line":218},12,[40,220,177],{"class":46},[40,222,35],{"class":50},[40,224,58],{"class":46},[16,226,227],{},"那麼這樣子就是一個基礎的 View 定義，但是我們在 MVC 架構有講到，使用者是先像 Controller 請求頁面，所以我們後面會稍微搭配 Controller 講一下如何渲染畫面到我們要的 View 頁面。",[12,229,231],{"id":230},"view-渲染","View 渲染",[16,233,234,235,238,239,242],{},"前面我們了解到使用者會跟 Controller 請求頁面，所以我們要開啟 ",[26,236,237],{},"about\u002Fcontroller\u002FHelloWorld.php"," 做一下程式碼修改，如我想要丟出我們指定的頁面畫面，那就可以使用 ",[26,240,241],{},"fetch()"," 的方法。",[16,244,245],{},"通常如果撰寫時，不帶任何參數它會自動去獲取當前操作的模板名稱，例如自動去抓 index.html，但是光用說的其實滿難理解的，而且我個人偏向自己指定頁面，所以讓我們來實際撰寫試試看吧。",[16,247,248,249,251],{},"首先先開啟 ",[26,250,237],{}," 然後貼入我所提供的範例程式碼：",[31,253,257],{"className":254,"code":255,"language":256,"meta":36,"style":36},"language-php shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        return $this->fetch();\n    }\n}\n","php",[26,258,259,269,281,287,297,301,315,320,335,340,357,362],{"__ignoreMap":36},[40,260,261,265],{"class":42,"line":43},[40,262,264],{"class":263},"sOudu","\u003C?",[40,266,268],{"class":267},"stw71","php\n",[40,270,271,274,278],{"class":42,"line":61},[40,272,273],{"class":263},"namespace",[40,275,277],{"class":276},"smYoP"," app\\about\\controller",[40,279,280],{"class":46},";\n",[40,282,283],{"class":42,"line":81},[40,284,286],{"emptyLinePlaceholder":285},true,"\n",[40,288,289,292,295],{"class":42,"line":91},[40,290,291],{"class":263},"use",[40,293,294],{"class":267}," think\\Controller",[40,296,280],{"class":46},[40,298,299],{"class":42,"line":110},[40,300,286],{"emptyLinePlaceholder":285},[40,302,303,306,309,312],{"class":42,"line":135},[40,304,305],{"class":263},"class",[40,307,308],{"class":276}," HelloWorld",[40,310,311],{"class":263}," extends",[40,313,314],{"class":54}," Controller\n",[40,316,317],{"class":42,"line":159},[40,318,319],{"class":46},"{\n",[40,321,322,325,328,332],{"class":42,"line":174},[40,323,324],{"class":263},"    public",[40,326,327],{"class":263}," function",[40,329,331],{"class":330},"scAaK"," Hello",[40,333,334],{"class":46},"()\n",[40,336,337],{"class":42,"line":184},[40,338,339],{"class":46},"    {\n",[40,341,342,345,348,351,354],{"class":42,"line":194},[40,343,344],{"class":263},"        return",[40,346,347],{"class":267}," $this",[40,349,350],{"class":263},"->",[40,352,353],{"class":330},"fetch",[40,355,356],{"class":46},"();\n",[40,358,359],{"class":42,"line":209},[40,360,361],{"class":46},"    }\n",[40,363,364],{"class":42,"line":218},[40,365,366],{"class":46},"}\n",[16,368,369,370,373,374,377],{},"然後開啟 CMD 並執行 ",[26,371,372],{},"php think run","，接下來打開瀏覽器訪問 ",[26,375,376],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fhello_world\u002Fhello"," ↓",[16,379,380],{},[381,382],"img",{"alt":383,"src":384},"直接噴找不到這個模板","https:\u002F\u002Fi.imgur.com\u002FOVUbs0x.png",[16,386,387,388,391],{},"原因是因為我們沒有指定模板，而我們該 Controller function 的名稱是 ",[26,389,390],{},"Hello","，所以 ThinkPHP 就會自動去找 hello.html，但是我們底下並沒有這個檔案，所以讓我們來建立一個 hello.html，然後在訪問一次 ↓",[16,393,394],{},[381,395],{"alt":396,"src":397},"hello","https:\u002F\u002Fi.imgur.com\u002FlpP50Qd.png",[16,399,400],{},"重新訪問後就可以成功的渲染 View 畫面 ↓",[16,402,403],{},[381,404],{"alt":405,"src":406},"自動解析模板","https:\u002F\u002Fi.imgur.com\u002FzKDTuL9.png",[16,408,409,410,412,413,415,416,418],{},"但是如果我們希望訪問 ",[26,411,376],{}," 時，是跳出 HelloWorld.html 的頁面呢?那就要修改一下 ",[26,414,237],{},"，只需要將 ",[26,417,241],{}," 帶上要渲染的 HTML 檔案名稱即可，範例如下：",[31,420,422],{"className":254,"code":421,"language":256,"meta":36,"style":36},"\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        return $this->fetch('HelloWorld');\n    }\n}\n",[26,423,424,430,438,442,450,454,464,468,478,482,501,505],{"__ignoreMap":36},[40,425,426,428],{"class":42,"line":43},[40,427,264],{"class":263},[40,429,268],{"class":267},[40,431,432,434,436],{"class":42,"line":61},[40,433,273],{"class":263},[40,435,277],{"class":276},[40,437,280],{"class":46},[40,439,440],{"class":42,"line":81},[40,441,286],{"emptyLinePlaceholder":285},[40,443,444,446,448],{"class":42,"line":91},[40,445,291],{"class":263},[40,447,294],{"class":267},[40,449,280],{"class":46},[40,451,452],{"class":42,"line":110},[40,453,286],{"emptyLinePlaceholder":285},[40,455,456,458,460,462],{"class":42,"line":135},[40,457,305],{"class":263},[40,459,308],{"class":276},[40,461,311],{"class":263},[40,463,314],{"class":54},[40,465,466],{"class":42,"line":159},[40,467,319],{"class":46},[40,469,470,472,474,476],{"class":42,"line":174},[40,471,324],{"class":263},[40,473,327],{"class":263},[40,475,331],{"class":330},[40,477,334],{"class":46},[40,479,480],{"class":42,"line":184},[40,481,339],{"class":46},[40,483,484,486,488,490,492,495,498],{"class":42,"line":194},[40,485,344],{"class":263},[40,487,347],{"class":267},[40,489,350],{"class":263},[40,491,353],{"class":330},[40,493,494],{"class":46},"(",[40,496,497],{"class":75},"'HelloWorld'",[40,499,500],{"class":46},");\n",[40,502,503],{"class":42,"line":209},[40,504,361],{"class":46},[40,506,507],{"class":42,"line":218},[40,508,366],{"class":46},[16,510,511,512,514],{},"這樣當我們訪問 ",[26,513,376],{}," 時，就會自動解析 HelloWorld.html 模板 ↓",[16,516,517],{},[381,518],{"alt":519,"src":520},"HelloWorld","https:\u002F\u002Fi.imgur.com\u002FZRadyMm.png",[12,522,523],{"id":523},"模板引擎",[16,525,526,527,530,531,534,535,537,538,540],{},"ThinkPHP 本身有內建模板引擎，使用方式很簡單，只需要在 HTML 中使用 ",[26,528,529],{},"{$ }"," 包住即可使用，但是請務必記得傳送參數，否則噴錯誤，傳送參數到前端的方法是使用 ",[26,532,533],{},"assign()"," 來傳送到前端，主要是接在 ",[26,536,241],{}," 之前，讓我們打開 ",[26,539,237],{}," 然後貼入我提供的範例程式碼，如下：",[31,542,544],{"className":254,"code":543,"language":256,"meta":36,"style":36},"\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        $name = 'IT邦幫忙';\n        return $this->assign('name',$name) -> fetch(); \u002F\u002F assign('預計往前端傳的參數名稱', 值)\n    }\n}\n",[26,545,546,552,560,564,572,576,586,590,600,604,616,647,651],{"__ignoreMap":36},[40,547,548,550],{"class":42,"line":43},[40,549,264],{"class":263},[40,551,268],{"class":267},[40,553,554,556,558],{"class":42,"line":61},[40,555,273],{"class":263},[40,557,277],{"class":276},[40,559,280],{"class":46},[40,561,562],{"class":42,"line":81},[40,563,286],{"emptyLinePlaceholder":285},[40,565,566,568,570],{"class":42,"line":91},[40,567,291],{"class":263},[40,569,294],{"class":267},[40,571,280],{"class":46},[40,573,574],{"class":42,"line":110},[40,575,286],{"emptyLinePlaceholder":285},[40,577,578,580,582,584],{"class":42,"line":135},[40,579,305],{"class":263},[40,581,308],{"class":276},[40,583,311],{"class":263},[40,585,314],{"class":54},[40,587,588],{"class":42,"line":159},[40,589,319],{"class":46},[40,591,592,594,596,598],{"class":42,"line":174},[40,593,324],{"class":263},[40,595,327],{"class":263},[40,597,331],{"class":330},[40,599,334],{"class":46},[40,601,602],{"class":42,"line":184},[40,603,339],{"class":46},[40,605,606,609,611,614],{"class":42,"line":194},[40,607,608],{"class":46},"        $name ",[40,610,72],{"class":263},[40,612,613],{"class":75}," 'IT邦幫忙'",[40,615,280],{"class":46},[40,617,618,620,622,624,627,629,632,635,637,640,643],{"class":42,"line":209},[40,619,344],{"class":263},[40,621,347],{"class":267},[40,623,350],{"class":263},[40,625,626],{"class":330},"assign",[40,628,494],{"class":46},[40,630,631],{"class":75},"'name'",[40,633,634],{"class":46},",$name) ",[40,636,350],{"class":263},[40,638,639],{"class":330}," fetch",[40,641,642],{"class":46},"(); ",[40,644,646],{"class":645},"sGBqm","\u002F\u002F assign('預計往前端傳的參數名稱', 值)\n",[40,648,649],{"class":42,"line":218},[40,650,361],{"class":46},[40,652,654],{"class":42,"line":653},13,[40,655,366],{"class":46},[16,657,658,659,662,663,666,667,669],{},"接下來在打開 ",[26,660,661],{},"application\u002Fabout\u002Fview\u002Fhello_world\u002Fhello.html"," 在 body 裡面加入這一小段話 ",[26,664,665],{},"\u003Ch5>這透過 Controller 傳送的參數:是一個 Hello,{$name}！\u003C\u002Fh5>","，這時候我們重新訪問 ",[26,668,376],{}," 就可以看到結果囉 ↓",[16,671,672],{},[381,673],{"alt":674,"src":675},"IT邦幫忙","https:\u002F\u002Fi.imgur.com\u002FdKGyML8.png",[16,677,678,679,681,682,685],{},"如果你不想要使用 ",[26,680,529],{},"這種方式來做解析的話，其實 ThinkPHP 也有提供讓你修改的選項，在 ",[26,683,684],{},"config\u002Ftemplate.php"," 下可以找到相關設置 ↓",[16,687,688],{},[381,689],{"alt":690,"src":691},"template","https:\u002F\u002Fi.imgur.com\u002Fn7Pg8sC.png",[16,693,694],{},"我個人是不推薦修改這個選項，畢竟這會影響後面的維護人員的困擾。",[16,696,697],{},"最後我後面會陸續搭配 HTML Template 來講解還有哪些 HTML Template 方法可以用，基本上你想的到的 ThinkPHP 內建的 HTML Template 都有，例如常見的迴圈、判斷式等。",[12,699,700],{"id":700},"結尾",[16,702,703,704,707,708,715],{},"另外官方也有提供第三方模板引擎，類似於　",[26,705,706],{},"angularjs"," 的模板引擎，但實際具體可以參考 ",[709,710,714],"a",{"href":711,"rel":712},"https:\u002F\u002Fwww.kancloud.cn\u002Fshuai\u002Fphp-angular",[713],"nofollow","這一篇手冊","。",[16,717,718,719,724],{},"當然也有使用 twig 的模板引擎唷，",[709,720,723],{"href":721,"rel":722},"https:\u002F\u002Fgithub.com\u002Fyunwuxin\u002Fthink-twig",[713],"think-twig","，我個人是頃向原生開發就好，畢竟不確定其他的模板引擎與 ThinkPHP 會不會有相容性問題。",[726,727,728],"style",{},"html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syv7_, html code.shiki .syv7_{--shiki-light:#22863A;--shiki-default:#22863A;--shiki-dark:#72F088}html pre.shiki code .sK3KL, html code.shiki .sK3KL{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#91CBFF}html pre.shiki code .sWayO, html code.sh