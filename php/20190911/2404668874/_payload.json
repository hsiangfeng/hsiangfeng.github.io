[{"data":1,"prerenderedAt":776},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190911\u002F2404668874\u002F":3,"page:\u002Fphp\u002F20190911\u002F2404668874\u002F":4,"alt:\u002Fphp\u002F20190911\u002F2404668874\u002F":3,"prev-next:\u002Fphp\u002F20190911\u002F2404668874\u002F":753,"related:\u002Fphp\u002F20190911\u002F2404668874\u002F":762},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":735,"date":736,"description":18,"extension":737,"lang":738,"meta":739,"navigation":284,"path":740,"readingMinutes":741,"seo":742,"standalone":743,"stem":744,"tags":745,"tldr":750,"updated":750,"url":751,"__hash__":752},"content\u002F從基礎學習 ThinkPHP\u002FDay10-從基礎學習-ThinkPHP-View.md","Day10-從基礎學習 ThinkPHP-View","2404668874",{"type":9,"value":10,"toc":728},"minimark",[11,15,19,22,30,225,228,232,243,246,252,366,377,384,391,397,400,406,418,508,514,520,523,540,655,669,675,685,691,694,697,700,715,724],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來這一篇將會介紹 MVC 中的 View，也就是視圖，前一篇我們學習了 Controller 基礎定義，那麼接下來我們就會來學習 View，最後再來學 Model，當然這邊我們也會學習一點點的 HTML Template 唷!",[12,20,21],{"id":21},"起手式",[16,23,24,25,29],{},"首先先讓我們到專案的 ",[26,27,28],"code",{},"application\\about"," 底下建立一個 view 資料夾，並也在底下建立一個 hello_world 資料夾(注意遇到大寫就轉小寫)，並且在底下建立一個 HelloWorld.html，初始 View 內容如下：",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \u003Ctitle>這是打招呼介面\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>Say Hi!\u003C\u002Fh1>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html","",[26,38,39,59,79,89,108,133,157,172,182,192,207,216],{"__ignoreMap":36},[40,41,44,48,52,56],"span",{"class":42,"line":43},"line",1,[40,45,47],{"class":46},"sMAXC","\u003C!",[40,49,51],{"class":50},"sKpQp","DOCTYPE",[40,53,55],{"class":54},"sCcAr"," html",[40,57,58],{"class":46},">\n",[40,60,62,65,67,70,73,77],{"class":42,"line":61},2,[40,63,64],{"class":46},"\u003C",[40,66,35],{"class":50},[40,68,69],{"class":54}," lang",[40,71,72],{"class":46},"=",[40,74,76],{"class":75},"sTRMh","\"en\"",[40,78,58],{"class":46},[40,80,82,84,87],{"class":42,"line":81},3,[40,83,64],{"class":46},[40,85,86],{"class":50},"head",[40,88,58],{"class":46},[40,90,92,95,98,101,103,106],{"class":42,"line":91},4,[40,93,94],{"class":46},"  \u003C",[40,96,97],{"class":50},"meta",[40,99,100],{"class":54}," charset",[40,102,72],{"class":46},[40,104,105],{"class":75},"\"UTF-8\"",[40,107,58],{"class":46},[40,109,111,113,115,118,120,123,126,128,131],{"class":42,"line":110},5,[40,112,94],{"class":46},[40,114,97],{"class":50},[40,116,117],{"class":54}," name",[40,119,72],{"class":46},[40,121,122],{"class":75},"\"viewport\"",[40,124,125],{"class":54}," content",[40,127,72],{"class":46},[40,129,130],{"class":75},"\"width=device-width, initial-scale=1.0\"",[40,132,58],{"class":46},[40,134,136,138,140,143,145,148,150,152,155],{"class":42,"line":135},6,[40,137,94],{"class":46},[40,139,97],{"class":50},[40,141,142],{"class":54}," http-equiv",[40,144,72],{"class":46},[40,146,147],{"class":75},"\"X-UA-Compatible\"",[40,149,125],{"class":54},[40,151,72],{"class":46},[40,153,154],{"class":75},"\"ie=edge\"",[40,156,58],{"class":46},[40,158,160,162,165,168,170],{"class":42,"line":159},7,[40,161,94],{"class":46},[40,163,164],{"class":50},"title",[40,166,167],{"class":46},">這是打招呼介面\u003C\u002F",[40,169,164],{"class":50},[40,171,58],{"class":46},[40,173,175,178,180],{"class":42,"line":174},8,[40,176,177],{"class":46},"\u003C\u002F",[40,179,86],{"class":50},[40,181,58],{"class":46},[40,183,185,187,190],{"class":42,"line":184},9,[40,186,64],{"class":46},[40,188,189],{"class":50},"body",[40,191,58],{"class":46},[40,193,195,197,200,203,205],{"class":42,"line":194},10,[40,196,94],{"class":46},[40,198,199],{"class":50},"h1",[40,201,202],{"class":46},">Say Hi!\u003C\u002F",[40,204,199],{"class":50},[40,206,58],{"class":46},[40,208,210,212,214],{"class":42,"line":209},11,[40,211,177],{"class":46},[40,213,189],{"class":50},[40,215,58],{"class":46},[40,217,219,221,223],{"class":42,"line":218},12,[40,220,177],{"class":46},[40,222,35],{"class":50},[40,224,58],{"class":46},[16,226,227],{},"那麼這樣子就是一個基礎的 View 定義，但是我們在 MVC 架構有講到，使用者是先像 Controller 請求頁面，所以我們後面會稍微搭配 Controller 講一下如何渲染畫面到我們要的 View 頁面。",[12,229,231],{"id":230},"view-渲染","View 渲染",[16,233,234,235,238,239,242],{},"前面我們了解到使用者會跟 Controller 請求頁面，所以我們要開啟 ",[26,236,237],{},"about\u002Fcontroller\u002FHelloWorld.php"," 做一下程式碼修改，如我想要丟出我們指定的頁面畫面，那就可以使用 ",[26,240,241],{},"fetch()"," 的方法。",[16,244,245],{},"通常如果撰寫時，不帶任何參數它會自動去獲取當前操作的模板名稱，例如自動去抓 index.html，但是光用說的其實滿難理解的，而且我個人偏向自己指定頁面，所以讓我們來實際撰寫試試看吧。",[16,247,248,249,251],{},"首先先開啟 ",[26,250,237],{}," 然後貼入我所提供的範例程式碼：",[31,253,257],{"className":254,"code":255,"language":256,"meta":36,"style":36},"language-php shiki shiki-themes github-dark-high-contrast","\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        return $this->fetch();\n    }\n}\n","php",[26,258,259,268,280,286,296,300,314,319,334,339,356,361],{"__ignoreMap":36},[40,260,261,265],{"class":42,"line":43},[40,262,264],{"class":263},"sWyjQ","\u003C?",[40,266,267],{"class":54},"php\n",[40,269,270,273,277],{"class":42,"line":61},[40,271,272],{"class":263},"namespace",[40,274,276],{"class":275},"s_sBn"," app\\about\\controller",[40,278,279],{"class":46},";\n",[40,281,282],{"class":42,"line":81},[40,283,285],{"emptyLinePlaceholder":284},true,"\n",[40,287,288,291,294],{"class":42,"line":91},[40,289,290],{"class":263},"use",[40,292,293],{"class":54}," think\\Controller",[40,295,279],{"class":46},[40,297,298],{"class":42,"line":110},[40,299,285],{"emptyLinePlaceholder":284},[40,301,302,305,308,311],{"class":42,"line":135},[40,303,304],{"class":263},"class",[40,306,307],{"class":275}," HelloWorld",[40,309,310],{"class":263}," extends",[40,312,313],{"class":54}," Controller\n",[40,315,316],{"class":42,"line":159},[40,317,318],{"class":46},"{\n",[40,320,321,324,327,331],{"class":42,"line":174},[40,322,323],{"class":263},"    public",[40,325,326],{"class":263}," function",[40,328,330],{"class":329},"sj_SG"," Hello",[40,332,333],{"class":46},"()\n",[40,335,336],{"class":42,"line":184},[40,337,338],{"class":46},"    {\n",[40,340,341,344,347,350,353],{"class":42,"line":194},[40,342,343],{"class":263},"        return",[40,345,346],{"class":54}," $this",[40,348,349],{"class":263},"->",[40,351,352],{"class":329},"fetch",[40,354,355],{"class":46},"();\n",[40,357,358],{"class":42,"line":209},[40,359,360],{"class":46},"    }\n",[40,362,363],{"class":42,"line":218},[40,364,365],{"class":46},"}\n",[16,367,368,369,372,373,376],{},"然後開啟 CMD 並執行 ",[26,370,371],{},"php think run","，接下來打開瀏覽器訪問 ",[26,374,375],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fhello_world\u002Fhello"," ↓",[16,378,379],{},[380,381],"img",{"alt":382,"src":383},"直接噴找不到這個模板","https:\u002F\u002Fi.imgur.com\u002FOVUbs0x.png",[16,385,386,387,390],{},"原因是因為我們沒有指定模板，而我們該 Controller function 的名稱是 ",[26,388,389],{},"Hello","，所以 ThinkPHP 就會自動去找 hello.html，但是我們底下並沒有這個檔案，所以讓我們來建立一個 hello.html，然後在訪問一次 ↓",[16,392,393],{},[380,394],{"alt":395,"src":396},"hello","https:\u002F\u002Fi.imgur.com\u002FlpP50Qd.png",[16,398,399],{},"重新訪問後就可以成功的渲染 View 畫面 ↓",[16,401,402],{},[380,403],{"alt":404,"src":405},"自動解析模板","https:\u002F\u002Fi.imgur.com\u002FzKDTuL9.png",[16,407,408,409,411,412,414,415,417],{},"但是如果我們希望訪問 ",[26,410,375],{}," 時，是跳出 HelloWorld.html 的頁面呢?那就要修改一下 ",[26,413,237],{},"，只需要將 ",[26,416,241],{}," 帶上要渲染的 HTML 檔案名稱即可，範例如下：",[31,419,421],{"className":254,"code":420,"language":256,"meta":36,"style":36},"\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        return $this->fetch('HelloWorld');\n    }\n}\n",[26,422,423,429,437,441,449,453,463,467,477,481,500,504],{"__ignoreMap":36},[40,424,425,427],{"class":42,"line":43},[40,426,264],{"class":263},[40,428,267],{"class":54},[40,430,431,433,435],{"class":42,"line":61},[40,432,272],{"class":263},[40,434,276],{"class":275},[40,436,279],{"class":46},[40,438,439],{"class":42,"line":81},[40,440,285],{"emptyLinePlaceholder":284},[40,442,443,445,447],{"class":42,"line":91},[40,444,290],{"class":263},[40,446,293],{"class":54},[40,448,279],{"class":46},[40,450,451],{"class":42,"line":110},[40,452,285],{"emptyLinePlaceholder":284},[40,454,455,457,459,461],{"class":42,"line":135},[40,456,304],{"class":263},[40,458,307],{"class":275},[40,460,310],{"class":263},[40,462,313],{"class":54},[40,464,465],{"class":42,"line":159},[40,466,318],{"class":46},[40,468,469,471,473,475],{"class":42,"line":174},[40,470,323],{"class":263},[40,472,326],{"class":263},[40,474,330],{"class":329},[40,476,333],{"class":46},[40,478,479],{"class":42,"line":184},[40,480,338],{"class":46},[40,482,483,485,487,489,491,494,497],{"class":42,"line":194},[40,484,343],{"class":263},[40,486,346],{"class":54},[40,488,349],{"class":263},[40,490,352],{"class":329},[40,492,493],{"class":46},"(",[40,495,496],{"class":75},"'HelloWorld'",[40,498,499],{"class":46},");\n",[40,501,502],{"class":42,"line":209},[40,503,360],{"class":46},[40,505,506],{"class":42,"line":218},[40,507,365],{"class":46},[16,509,510,511,513],{},"這樣當我們訪問 ",[26,512,375],{}," 時，就會自動解析 HelloWorld.html 模板 ↓",[16,515,516],{},[380,517],{"alt":518,"src":519},"HelloWorld","https:\u002F\u002Fi.imgur.com\u002FZRadyMm.png",[12,521,522],{"id":522},"模板引擎",[16,524,525,526,529,530,533,534,536,537,539],{},"ThinkPHP 本身有內建模板引擎，使用方式很簡單，只需要在 HTML 中使用 ",[26,527,528],{},"{$ }"," 包住即可使用，但是請務必記得傳送參數，否則噴錯誤，傳送參數到前端的方法是使用 ",[26,531,532],{},"assign()"," 來傳送到前端，主要是接在 ",[26,535,241],{}," 之前，讓我們打開 ",[26,538,237],{}," 然後貼入我提供的範例程式碼，如下：",[31,541,543],{"className":254,"code":542,"language":256,"meta":36,"style":36},"\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        $name = 'IT邦幫忙';\n        return $this->assign('name',$name) -> fetch(); \u002F\u002F assign('預計往前端傳的參數名稱', 值)\n    }\n}\n",[26,544,545,551,559,563,571,575,585,589,599,603,615,646,650],{"__ignoreMap":36},[40,546,547,549],{"class":42,"line":43},[40,548,264],{"class":263},[40,550,267],{"class":54},[40,552,553,555,557],{"class":42,"line":61},[40,554,272],{"class":263},[40,556,276],{"class":275},[40,558,279],{"class":46},[40,560,561],{"class":42,"line":81},[40,562,285],{"emptyLinePlaceholder":284},[40,564,565,567,569],{"class":42,"line":91},[40,566,290],{"class":263},[40,568,293],{"class":54},[40,570,279],{"class":46},[40,572,573],{"class":42,"line":110},[40,574,285],{"emptyLinePlaceholder":284},[40,576,577,579,581,583],{"class":42,"line":135},[40,578,304],{"class":263},[40,580,307],{"class":275},[40,582,310],{"class":263},[40,584,313],{"class":54},[40,586,587],{"class":42,"line":159},[40,588,318],{"class":46},[40,590,591,593,595,597],{"class":42,"line":174},[40,592,323],{"class":263},[40,594,326],{"class":263},[40,596,330],{"class":329},[40,598,333],{"class":46},[40,600,601],{"class":42,"line":184},[40,602,338],{"class":46},[40,604,605,608,610,613],{"class":42,"line":194},[40,606,607],{"class":46},"        $name ",[40,609,72],{"class":263},[40,611,612],{"class":75}," 'IT邦幫忙'",[40,614,279],{"class":46},[40,616,617,619,621,623,626,628,631,634,636,639,642],{"class":42,"line":209},[40,618,343],{"class":263},[40,620,346],{"class":54},[40,622,349],{"class":263},[40,624,625],{"class":329},"assign",[40,627,493],{"class":46},[40,629,630],{"class":75},"'name'",[40,632,633],{"class":46},",$name) ",[40,635,349],{"class":263},[40,637,638],{"class":329}," fetch",[40,640,641],{"class":46},"(); ",[40,643,645],{"class":644},"sQrFR","\u002F\u002F assign('預計往前端傳的參數名稱', 值)\n",[40,647,648],{"class":42,"line":218},[40,649,360],{"class":46},[40,651,653],{"class":42,"line":652},13,[40,654,365],{"class":46},[16,656,657,658,661,662,665,666,668],{},"接下來在打開 ",[26,659,660],{},"application\u002Fabout\u002Fview\u002Fhello_world\u002Fhello.html"," 在 body 裡面加入這一小段話 ",[26,663,664],{},"\u003Ch5>這透過 Controller 傳送的參數:是一個 Hello,{$name}！\u003C\u002Fh5>","，這時候我們重新訪問 ",[26,667,375],{}," 就可以看到結果囉 ↓",[16,670,671],{},[380,672],{"alt":673,"src":674},"IT邦幫忙","https:\u002F\u002Fi.imgur.com\u002FdKGyML8.png",[16,676,677,678,680,681,684],{},"如果你不想要使用 ",[26,679,528],{},"這種方式來做解析的話，其實 ThinkPHP 也有提供讓你修改的選項，在 ",[26,682,683],{},"config\u002Ftemplate.php"," 下可以找到相關設置 ↓",[16,686,687],{},[380,688],{"alt":689,"src":690},"template","https:\u002F\u002Fi.imgur.com\u002Fn7Pg8sC.png",[16,692,693],{},"我個人是不推薦修改這個選項，畢竟這會影響後面的維護人員的困擾。",[16,695,696],{},"最後我後面會陸續搭配 HTML Template 來講解還有哪些 HTML Template 方法可以用，基本上你想的到的 ThinkPHP 內建的 HTML Template 都有，例如常見的迴圈、判斷式等。",[12,698,699],{"id":699},"結尾",[16,701,702,703,706,707,714],{},"另外官方也有提供第三方模板引擎，類似於　",[26,704,705],{},"angularjs"," 的模板引擎，但實際具體可以參考 ",[708,709,713],"a",{"href":710,"rel":711},"https:\u002F\u002Fwww.kancloud.cn\u002Fshuai\u002Fphp-angular",[712],"nofollow","這一篇手冊","。",[16,716,717,718,723],{},"當然也有使用 twig 的模板引擎唷，",[708,719,722],{"href":720,"rel":721},"https:\u002F\u002Fgithub.com\u002Fyunwuxin\u002Fthink-twig",[712],"think-twig","，我個人是頃向原生開發就好，畢竟不確定其他的模板引擎與 ThinkPHP 會不會有相容性問題。",[725,726,727],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-def