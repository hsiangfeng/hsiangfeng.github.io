[{"data":1,"prerenderedAt":577},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190915\u002F2341995377\u002F":3,"page:\u002Fphp\u002F20190915\u002F2341995377\u002F":4,"alt:\u002Fphp\u002F20190915\u002F2341995377\u002F":3,"prev-next:\u002Fphp\u002F20190915\u002F2341995377\u002F":554,"related:\u002Fphp\u002F20190915\u002F2341995377\u002F":563},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F15\u002Fthinkphp-day-14-model-basics-02\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":39,"date":536,"description":18,"extension":537,"lang":538,"meta":539,"navigation":540,"path":541,"readingMinutes":542,"seo":543,"standalone":544,"stem":545,"tags":546,"tldr":551,"updated":551,"url":552,"__hash__":553},"content\u002F從基礎學習 ThinkPHP\u002FDay14-從基礎學習-ThinkPHP-Model-基礎操作-2.md","Day14-從基礎學習 ThinkPHP-Model 基礎操作(2)","2341995377",{"type":9,"value":10,"toc":530},"minimark",[11,15,19,22,34,66,76,98,101,104,128,135,138,201,208,211,217,308,319,322,478,481,488,504,509,512,517,520,523,526],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇我們已經將 Model 所需要的起手式給準備得差不多了，接下來將會開始寫一些基礎的資料操作。",[12,20,21],{"id":21},"起手式",[16,23,24,25,29,30,33],{},"前一篇我們已經有建立了一個 ",[26,27,28],"code",{},"create"," 控制器方法，但是目前僅僅只是將前端往後端傳的表單資料取出來而已，現在我們要真的將資料存入到我們所建立的 ",[26,31,32],{},"think_user"," 資料表內，首先我們要在前面加入一段程式碼告知 Controller 我們要用哪一個 Model：",[35,36,41],"pre",{"className":37,"code":38,"language":39,"meta":40,"style":40},"language-PHP shiki shiki-themes github-dark-high-contrast","use app\\about\\model\\about as aboutModel;\n","PHP","",[26,42,43],{"__ignoreMap":40},[44,45,48,52,56,59,62],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sWyjQ","use",[44,53,55],{"class":54},"sCcAr"," app\\about\\model\\about",[44,57,58],{"class":50}," as",[44,60,61],{"class":54}," aboutModel",[44,63,65],{"class":64},"sMAXC",";\n",[16,67,68,69,72,73,75],{},"然後要將 ",[26,70,71],{},"aboutModel"," 給實例化，接下來只需要在 ",[26,74,28],{}," 方法下寫一段簡單的程式碼就可以達到實例化：",[35,77,81],{"className":78,"code":79,"language":80,"meta":40,"style":40},"language-php shiki shiki-themes github-dark-high-contrast","$user = new aboutModel;\n","php",[26,82,83],{"__ignoreMap":40},[44,84,85,88,91,94,96],{"class":46,"line":47},[44,86,87],{"class":64},"$user ",[44,89,90],{"class":50},"=",[44,92,93],{"class":50}," new",[44,95,61],{"class":54},[44,97,65],{"class":64},[12,99,100],{"id":100},"新增資料",[16,102,103],{},"那麼我們已經準備好實例化 Model，但是到底該怎麼樣新增資料進去資料表呢?",[16,105,106,107,110,111,110,114,117,118,121,122,124,125,127],{},"首先我們資料欄位有 ",[26,108,109],{},"name","、",[26,112,113],{},"height",[26,115,116],{},"weight"," 這三個欄位，這邊會透過一個箭頭 ",[26,119,120],{},"->"," 來指定資料欄位，在前面我並沒有解釋 ",[26,123,120],{}," 是什麼，",[26,126,120],{}," 簡單理解就是調用的意思，我調用哪個類方法、哪個類函數，這樣理解起來比較不會吃力。",[16,129,130,131,134],{},"那麼另一種呢? ",[26,132,133],{},"=>"," 這個是用來定義陣列的。",[16,136,137],{},"所以我們就可以這樣子調用資料欄位名稱並儲存進去：",[35,139,141],{"className":78,"code":140,"language":80,"meta":40,"style":40},"$user = new aboutModel;\n$user->name = $name;\n$user->height = $height;\n$user->weight = $weight;\n",[26,142,143,155,171,186],{"__ignoreMap":40},[44,144,145,147,149,151,153],{"class":46,"line":47},[44,146,87],{"class":64},[44,148,90],{"class":50},[44,150,93],{"class":50},[44,152,61],{"class":54},[44,154,65],{"class":64},[44,156,158,161,163,166,168],{"class":46,"line":157},2,[44,159,160],{"class":64},"$user",[44,162,120],{"class":50},[44,164,165],{"class":64},"name ",[44,167,90],{"class":50},[44,169,170],{"class":64}," $name;\n",[44,172,174,176,178,181,183],{"class":46,"line":173},3,[44,175,160],{"class":64},[44,177,120],{"class":50},[44,179,180],{"class":64},"height ",[44,182,90],{"class":50},[44,184,185],{"class":64}," $height;\n",[44,187,189,191,193,196,198],{"class":46,"line":188},4,[44,190,160],{"class":64},[44,192,120],{"class":50},[44,194,195],{"class":64},"weight ",[44,197,90],{"class":50},[44,199,200],{"class":64}," $weight;\n",[16,202,203,204,207],{},"白話一點的說法就是，我調用 Model 的資料欄位，並賦予值進去，最後記得加上 ",[26,205,206],{},"$user -> save();","，這是在告知 Model 我要儲存資料囉。",[16,209,210],{},"恭喜你寫完新增資料的操作了(疑?!)，真的不要懷疑就這麼簡單。",[16,212,213,214,216],{},"最後，我們該如何判斷真的有儲存資料進去資料表?由於 ",[26,215,206],{}," 會回傳布林值，所以這邊我們可以多一個判斷，來判斷資料是否成功新增：",[35,218,220],{"className":78,"code":219,"language":80,"meta":40,"style":40},"if($user -> save()) {\n  return '['.$user->name'.,ID是'.$user->id.']新增成功'\n} else {\n  $user->getError(); \u002F\u002F 輸出錯誤\n}\n",[26,221,222,239,274,285,302],{"__ignoreMap":40},[44,223,224,227,230,232,236],{"class":46,"line":47},[44,225,226],{"class":50},"if",[44,228,229],{"class":64},"($user ",[44,231,120],{"class":50},[44,233,235],{"class":234},"sj_SG"," save",[44,237,238],{"class":64},"()) {\n",[44,240,241,244,248,251,253,255,257,260,262,264,266,269,271],{"class":46,"line":157},[44,242,243],{"class":50},"  return",[44,245,247],{"class":246},"sTRMh"," '['",[44,249,250],{"class":50},".",[44,252,160],{"class":64},[44,254,120],{"class":50},[44,256,109],{"class":64},[44,258,259],{"class":246},"'.,ID是'",[44,261,250],{"class":50},[44,263,160],{"class":64},[44,265,120],{"class":50},[44,267,268],{"class":64},"id",[44,270,250],{"class":50},[44,272,273],{"class":246},"']新增成功'\n",[44,275,276,279,282],{"class":46,"line":173},[44,277,278],{"class":64},"} ",[44,280,281],{"class":50},"else",[44,283,284],{"class":64}," {\n",[44,286,287,290,292,295,298],{"class":46,"line":188},[44,288,289],{"class":64},"  $user",[44,291,120],{"class":50},[44,293,294],{"class":234},"getError",[44,296,297],{"class":64},"(); ",[44,299,301],{"class":300},"sQrFR","\u002F\u002F 輸出錯誤\n",[44,303,305],{"class":46,"line":304},5,[44,306,307],{"class":64},"}\n",[16,309,310,311,314,315,318],{},"邏輯來講就是新增成功就回傳 ",[26,312,313],{},"新增成功"," 的訊息，如果失敗就會透過 ",[26,316,317],{},"getError()"," 來輸出錯誤訊息。",[16,320,321],{},"所以完整程式碼如下：",[35,323,325],{"className":78,"code":324,"language":80,"meta":40,"style":40},"public function create ($name, $height, $weight) {\n    $user = new aboutModel;\n    $user->name = $name;\n    $user->height = $height;\n    $user->weight = $weight;\n    if($user -> save()){\n        return '名稱：'.$user->name.',ID：'.$user->id.'。\u003Cbr\u002F>新增成功';\n      }else {\n        $user->getError(); \u002F\u002F 輸出錯誤\n      }\n}\n",[26,326,327,341,354,367,379,391,406,443,453,467,473],{"__ignoreMap":40},[44,328,329,332,335,338],{"class":46,"line":47},[44,330,331],{"class":50},"public",[44,333,334],{"class":50}," function",[44,336,337],{"class":234}," create",[44,339,340],{"class":64}," ($name, $height, $weight) {\n",[44,342,343,346,348,350,352],{"class":46,"line":157},[44,344,345],{"class":64},"    $user ",[44,347,90],{"class":50},[44,349,93],{"class":50},[44,351,61],{"class":54},[44,353,65],{"class":64},[44,355,356,359,361,363,365],{"class":46,"line":173},[44,357,358],{"class":64},"    $user",[44,360,120],{"class":50},[44,362,165],{"class":64},[44,364,90],{"class":50},[44,366,170],{"class":64},[44,368,369,371,373,375,377],{"class":46,"line":188},[44,370,358],{"class":64},[44,372,120],{"class":50},[44,374,180],{"class":64},[44,376,90],{"class":50},[44,378,185],{"class":64},[44,380,381,383,385,387,389],{"class":46,"line":304},[44,382,358],{"class":64},[44,384,120],{"class":50},[44,386,195],{"class":64},[44,388,90],{"class":50},[44,390,200],{"class":64},[44,392,394,397,399,401,403],{"class":46,"line":393},6,[44,395,396],{"class":50},"    if",[44,398,229],{"class":64},[44,400,120],{"class":50},[44,402,235],{"class":234},[44,404,405],{"class":64},"()){\n",[44,407,409,412,415,417,419,421,423,425,428,430,432,434,436,438,441],{"class":46,"line":408},7,[44,410,411],{"class":50},"        return",[44,413,414],{"class":246}," '名稱：'",[44,416,250],{"class":50},[44,418,160],{"class":64},[44,420,120],{"class":50},[44,422,109],{"class":64},[44,424,250],{"class":50},[44,426,427],{"class":246},"',ID：'",[44,429,250],{"class":50},[44,431,160],{"class":64},[44,433,120],{"class":50},[44,435,268],{"class":64},[44,437,250],{"class":50},[44,439,440],{"class":246},"'。\u003Cbr\u002F>新增成功'",[44,442,65],{"class":64},[44,444,446,449,451],{"class":46,"line":445},8,[44,447,448],{"class":64},"      }",[44,450,281],{"class":50},[44,452,284],{"class":64},[44,454,456,459,461,463,465],{"class":46,"line":455},9,[44,457,458],{"class":64},"        $user",[44,460,120],{"class":50},[44,462,294],{"class":234},[44,464,297],{"class":64},[44,466,301],{"class":300},[44,468,470],{"class":46,"line":469},10,[44,471,472],{"class":64},"      }\n",[44,474,476],{"class":46,"line":475},11,[44,477,307],{"class":64},[16,479,480],{},"那接下來我們就可以嘗試看看發送表單後會得到什麼結果囉 ↓",[16,482,483],{},[484,485],"img",{"alt":486,"src":487},"大名比我還瘦...","https:\u002F\u002Fi.imgur.com\u002FpmaRDOS.png",[16,489,490,491,494,495,499,500,503],{},"如果你出現 ",[26,492,493],{},"Access denied for user 'user'@'localhost' (using password: YES)"," 的錯誤訊息，就代表你資料庫連接的帳號密碼有誤(",[496,497,498],"del",{},"我絕對不會說我撰寫過程忘記填密碼",")，這個狀況只需要到 ",[26,501,502],{},"project\u002Fconfig"," 底下的 database.php 修改即可解決。",[16,505,506],{},[484,507],{"alt":313,"src":508},"https:\u002F\u002Fi.imgur.com\u002FdKuKnJ5.png",[16,510,511],{},"最後我們也可以打開 Navicat 來看看是不是真的將資料給新增進去了 ↓",[16,513,514],{},[484,515],{"alt":313,"src":516},"https:\u002F\u002Fi.imgur.com\u002FmketglS.png",[16,518,519],{},"那麼這一篇就是在講解一個完整的新增動作~",[12,521,522],{"id":522},"結尾",[16,524,525],{},"撰寫過程一度卡在奇怪的地方，害我不得以只能重新安裝資料庫，所以自己在撰寫過程中一度卡了將近半小時，那麼下一篇就會講關於查詢資料的部分囉~",[527,528,529],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html 