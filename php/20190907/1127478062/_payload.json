[{"data":1,"prerenderedAt":442},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190907\u002F1127478062\u002F":3,"page:\u002Fphp\u002F20190907\u002F1127478062\u002F":4,"alt:\u002Fphp\u002F20190907\u002F1127478062\u002F":3,"prev-next:\u002Fphp\u002F20190907\u002F1127478062\u002F":419,"related:\u002Fphp\u002F20190907\u002F1127478062\u002F":428},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F07\u002Fthinkphp-day-06-installing-thinkphp\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":400,"date":401,"description":18,"extension":402,"lang":403,"meta":404,"navigation":405,"path":406,"readingMinutes":407,"seo":408,"standalone":409,"stem":410,"tags":411,"tldr":416,"updated":416,"url":417,"__hash__":418},"content\u002F從基礎學習 ThinkPHP\u002FDay6-從基礎學習-ThinkPHP-安裝-ThinkPHP-安裝.md","Day6-從基礎學習 ThinkPHP-安裝 ThinkPHP 安裝","1127478062",{"type":9,"value":10,"toc":391},"minimark",[11,15,19,22,25,34,37,41,49,56,59,65,72,78,84,95,101,112,118,122,125,139,144,151,283,286,292,296,299,313,320,326,340,343,349,352,355,362,365,372,378,381,384,387],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇開始我們將會要進入本篇主要重點，也就是 ThinkPHP 章節篇，那一開始我們並不會直接切入撰寫 ThinkPHP，而是先來講該如何透過 composer 安裝 ThinkPHP，當然也會微微改一下 ThinkPHP。",[12,20,21],{"id":21},"起手式",[16,23,24],{},"一開始的介紹章節大綱我就有講到，我們將會使用 composer 來安裝 ThinkPHP，所以我們必須要先進入 composer 官方網站安裝一下 composer。",[16,26,27,28],{},"composer 官方網站: ",[29,30,31],"a",{"href":31,"rel":32},"https:\u002F\u002Fgetcomposer.org\u002F",[33],"nofollow",[16,35,36],{},"由於我本身已經有安裝而安裝過程也非常容易(一直下一步就對了)，所以這邊就不在重複介紹安裝方式。",[12,38,40],{"id":39},"安裝-thinkphp-51","安裝 ThinkPHP 5.1",[16,42,43,44,48],{},"首先我們環境是使用 XAMPP 來架設，預設情況下 XAMPPP 是將 htdocs 當作 www 資料夾來使用，所以需要先開啟 CMD (我習慣使用 PowerShell)並 ",[45,46,47],"code",{},"cd"," 移動到該目錄下 ↓",[16,50,51],{},[52,53],"img",{"alt":54,"src":55},"htdocs","https:\u002F\u002Fi.imgur.com\u002Fio4Tujk.png",[16,57,58],{},"如果你是初次安裝 XAMPP 會看到底下還有其他的檔案，這些是 XAMPP 的預設檔案，可以依照個人需求選擇刪除或是建立一個 old 資料夾丟進去都是沒有問題的 ↓",[16,60,61],{},[52,62],{"alt":63,"src":64},"old","https:\u002F\u002Fi.imgur.com\u002FKqhsova.png",[16,66,67,68,71],{},"接下來回到 CMD 視窗，然後在 CMD 視窗內輸入指令： ",[45,69,70],{},"composer create-project topthink\u002Fthink itmanThinkPHP","。",[16,73,74,75],{},"※ 指令說明：　",[45,76,77],{},"composer [新增專案] [套件名稱] [專案資料夾名稱]",[16,79,80],{},[52,81],{"alt":82,"src":83},"安裝 ThinkPHP 中","https:\u002F\u002Fi.imgur.com\u002F7QxKBJx.png",[16,85,86,87,90,91,94],{},"安裝完畢後，要先移動到該專案目錄，所以讓我們輸入 ",[45,88,89],{},"cd itmanThinkPHP","，接下來輸入指令 ",[45,92,93],{},"php think run","，這樣你就成功安裝並運行 ThinkPHP 5.1 啦~~~(萬歲灑花) ↓",[16,96,97],{},[52,98],{"alt":99,"src":100},"運行專案","https:\u002F\u002Fi.imgur.com\u002FIfLy4AU.png",[16,102,103,104,107,108,111],{},"然後讓我們打開瀏覽器，並在網址列輸入 ",[45,105,106],{},"http:\u002F\u002F127.0.0.1:8000"," (通常 port 都會是 ",[45,109,110],{},"8000","，除非被占用)，此時你就可以看到 ThinkPHP 5.1 初始畫面 ↓",[16,113,114],{},[52,115],{"alt":116,"src":117},"ThinkPHP 初始畫面","https:\u002F\u002Fi.imgur.com\u002FFVFFro6.png",[12,119,121],{"id":120},"微修改-thinkphp","微修改 ThinkPHP",[16,123,124],{},"接下來讓我們來稍微做一下微修改，讓我們把 ThinkPHP 初始預設畫面稍微改變一下。",[16,126,127,128,131,132,135,136,138],{},"打開專案資料夾目錄 ",[45,129,130],{},"\\application\\index\\controller","，並找到 ",[45,133,134],{},"index.php"," 檔案，打開後可以看到 ",[45,137,134],{}," 預設內容像這樣 ↓",[16,140,141],{},[52,142],{"alt":134,"src":143},"https:\u002F\u002Fi.imgur.com\u002FWbsGbpq.png",[16,145,146,147,150],{},"我們將 ",[45,148,149],{},"public function index()"," 內容修改成以下 ：",[152,153,158],"pre",{"className":154,"code":155,"language":156,"meta":157,"style":157},"language-php shiki shiki-themes github-dark-high-contrast","public function index()\n{\n    return '\n    \u003Cstyle type=\"text\u002Fcss\">\n    *{ padding: 0; margin: 0; }\n    div{ padding: 4px 48px;}\n    a{color:#2E5CD5;cursor: pointer;text-decoration: none}\n    a:hover{text-decoration:underline; }\n    body{ background: #fff; font-family: \"Century Gothic\",\"Microsoft yahei\"; color: #333;font-size:18px;}\n    h1{ font-size: 100px; font-weight: normal; margin-bottom: 12px; }\n    p{ line-height: 1.6em; font-size: 42px }\n    \u003C\u002Fstyle>\n    \u003Cdiv style=\"padding: 24px 48px;\"> \u003Ch1>:) \u003C\u002Fh1>\n    \u003Cp> ThinkPHP V5.1\u003Cbr\u002F>\u003Cspan style=\"font-size:30px\"> IT 鐵人賽我來了! - 30 天挑戰自我 START!\u003C\u002Fspan>\n    \u003C\u002Fp>\n    \u003C\u002Fdiv>';\n}\n","php","",[45,159,160,180,186,196,202,208,214,220,226,232,238,244,250,256,262,268,277],{"__ignoreMap":157},[161,162,165,169,172,176],"span",{"class":163,"line":164},"line",1,[161,166,168],{"class":167},"sWyjQ","public",[161,170,171],{"class":167}," function",[161,173,175],{"class":174},"sj_SG"," index",[161,177,179],{"class":178},"sMAXC","()\n",[161,181,183],{"class":163,"line":182},2,[161,184,185],{"class":178},"{\n",[161,187,189,192],{"class":163,"line":188},3,[161,190,191],{"class":167},"    return",[161,193,195],{"class":194},"sTRMh"," '\n",[161,197,199],{"class":163,"line":198},4,[161,200,201],{"class":194},"    \u003Cstyle type=\"text\u002Fcss\">\n",[161,203,205],{"class":163,"line":204},5,[161,206,207],{"class":194},"    *{ padding: 0; margin: 0; }\n",[161,209,211],{"class":163,"line":210},6,[161,212,213],{"class":194},"    div{ padding: 4px 48px;}\n",[161,215,217],{"class":163,"line":216},7,[161,218,219],{"class":194},"    a{color:#2E5CD5;cursor: pointer;text-decoration: none}\n",[161,221,223],{"class":163,"line":222},8,[161,224,225],{"class":194},"    a:hover{text-decoration:underline; }\n",[161,227,229],{"class":163,"line":228},9,[161,230,231],{"class":194},"    body{ background: #fff; font-family: \"Century Gothic\",\"Microsoft yahei\"; color: #333;font-size:18px;}\n",[161,233,235],{"class":163,"line":234},10,[161,236,237],{"class":194},"    h1{ font-size: 100px; font-weight: normal; margin-bottom: 12px; }\n",[161,239,241],{"class":163,"line":240},11,[161,242,243],{"class":194},"    p{ line-height: 1.6em; font-size: 42px }\n",[161,245,247],{"class":163,"line":246},12,[161,248,249],{"class":194},"    \u003C\u002Fstyle>\n",[161,251,253],{"class":163,"line":252},13,[161,254,255],{"class":194},"    \u003Cdiv style=\"padding: 24px 48px;\"> \u003Ch1>:) \u003C\u002Fh1>\n",[161,257,259],{"class":163,"line":258},14,[161,260,261],{"class":194},"    \u003Cp> ThinkPHP V5.1\u003Cbr\u002F>\u003Cspan style=\"font-size:30px\"> IT 鐵人賽我來了! - 30 天挑戰自我 START!\u003C\u002Fspan>\n",[161,263,265],{"class":163,"line":264},15,[161,266,267],{"class":194},"    \u003C\u002Fp>\n",[161,269,271,274],{"class":163,"line":270},16,[161,272,273],{"class":194},"    \u003C\u002Fdiv>'",[161,275,276],{"class":178},";\n",[161,278,280],{"class":163,"line":279},17,[161,281,282],{"class":178},"}\n",[16,284,285],{},"修改完畢之後可以不用重啟專案，直接 F5 重新整理畫面就可以看到結果囉 ↓",[16,287,288],{},[52,289],{"alt":290,"src":291},"修改成功!","https:\u002F\u002Fi.imgur.com\u002FA09Ay46.png",[12,293,295],{"id":294},"預設-route","預設 Route",[16,297,298],{},"最後讓我們稍微翻一下預設 ThinkPHP 它還提供了什麼東西，一般情況下預設 ThinkPHP 還會幫我們建立兩個 Route，分別為：",[300,301,302,308],"ul",{},[303,304,305],"li",{},[45,306,307],{},"\u002Fthink",[303,309,310],{},[45,311,312],{},"\u002Fhello\u002F:name",[16,314,315,316,319],{},"首先第一個 Route，當你輸入 ",[45,317,318],{},"http:\u002F\u002F127.0.0.1:8000\u002Fthink"," 可以看到很簡潔的一句話 ↓",[16,321,322],{},[52,323],{"alt":324,"src":325},"預設畫面","https:\u002F\u002Fi.imgur.com\u002Faffvrzf.png",[16,327,328,329,331,332,336,337,71],{},"至於另一個 ",[45,330,312],{}," 您則可以自訂打招呼方式，而這方式也是俗稱的",[333,334,335],"strong",{},"動態路由","(後面會介紹)，例如你可以輸入: ",[45,338,339],{},"http:\u002F\u002F127.0.0.1:8000\u002F\u002Fhello\u002FRay",[16,341,342],{},"那你就會看到畫面會依照你輸入的路由來向你打招呼 ↓",[16,344,345],{},[52,346],{"alt":347,"src":348},"Hello Ray","https:\u002F\u002Fi.imgur.com\u002FqDkRhx3.png",[12,350,351],{"id":351},"另一種安裝方式",[16,353,354],{},"如果你不想透過 composer 來安裝的話，也可以到 ThinkPHP 官方網站來安裝 (但是要登入才能下載)",[16,356,357,358],{},"ThinkPHP 官方網站: ",[29,359,360],{"href":360,"rel":361},"http:\u002F\u002Fwww.thinkphp.cn\u002F",[33],[16,363,364],{},"所以我個人推薦去官方的 GitHub 下載 ↓",[16,366,367,368],{},"GitHub: ",[29,369,370],{"href":370,"rel":371},"https:\u002F\u002Fgithub.com\u002Ftop-think\u002Fthink\u002Ftree\u002F5.1",[33],[16,373,374],{},[52,375],{"alt":376,"src":377},"GitHub","https:\u002F\u002Fi.imgur.com\u002F2IJHSU7.png",[12,379,380],{"id":380},"結尾",[16,382,383],{},"終於開始像樣子進入 ThinkPHP，早期我在開發 ThinkPHP 的時候還是使用下載的方式，經過這一次的學習，其實我也順便了解原來 ThinkPHP 可以透過 composer 安裝呢~",[16,385,386],{},"那麼接下來下一篇將會針對 ThinkPHP 的目錄結構做介紹哩。",[388,389,390],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":157,"searchDepth":182,"depth":182,"links":392},[393,394,395,396,397,398,399],{"id":14,"depth":182,"text":14},{"id":21,"depth":182,"text":21},{"id":39,"depth":182,"text":40},{"id":120,"depth":182,"text":121},{"id":294,"depth":182,"text":295},{"id":351,"depth":182,"text":351},{"id":380,"depth":182,"text":380},"PHP","2019-09-07 00:01:37","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday6-thinkphp-thinkphp","2",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay6-從基礎學習-ThinkPHP-安裝-ThinkPHP-安裝",[400,412,413,414,415],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190907\u002F1127478062\u002F","Ra_ii16ZegAbWBCpB2lfYCzyGlP-hzDYxmEaciwhsSs",{"newer":420,"older":424},{"url":421,"title":422,"date":423},"\u002Fphp\u002F20190908\u002F337959933\u002F","Day7-從基礎學習 ThinkPHP-ThinkPHP 目錄結構","2019-09-08 00:08:53",{"u