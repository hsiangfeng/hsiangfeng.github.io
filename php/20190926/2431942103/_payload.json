[{"data":1,"prerenderedAt":733},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190926\u002F2431942103\u002F":3,"page:\u002Fphp\u002F20190926\u002F2431942103\u002F":4,"alt:\u002Fphp\u002F20190926\u002F2431942103\u002F":3,"prev-next:\u002Fphp\u002F20190926\u002F2431942103\u002F":710,"related:\u002Fphp\u002F20190926\u002F2431942103\u002F":719},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F26\u002Fthinkphp-day-25-form-token\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":691,"date":692,"description":18,"extension":693,"lang":694,"meta":695,"navigation":696,"path":697,"readingMinutes":698,"seo":699,"standalone":700,"stem":701,"tags":702,"tldr":707,"updated":707,"url":708,"__hash__":709},"content\u002F從基礎學習 ThinkPHP\u002FDay25-從基礎學習-ThinkPHP-表單-Token.md","Day25-從基礎學習 ThinkPHP-表單 Token","2431942103",{"type":9,"value":10,"toc":685},"minimark",[11,15,19,23,37,45,85,92,101,105,114,117,172,175,181,192,197,211,276,289,501,510,517,523,533,652,658,661,667,670,678,681],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"講完表單驗證，那麼這一篇就要來講表單 Token，表單 Token 是需要搭配前面的表單驗證才能夠使用，所以我才會將表單 Token 留在表單驗證後面，那麼就讓我們來了解什麼是表單 Token 吧!",[12,20,22],{"id":21},"表單-token-用途","表單 Token 用途",[16,24,25,26,30,31,36],{},"首先表單 Token 最主要是為了解決 CSRF 的問題，CSRF 中文又稱為 ",[27,28,29],"strong",{},"跨站請求偽造","，先前我其中一篇文章有稍微解釋過 ",[32,33,35],"a",{"href":34},"\u002Fnodejs\u002F20190704\u002F2336420619\u002F","CSRF","，所以這邊就直接節錄部分內容。",[16,38,39,40,44],{},"CSRF 簡單來講就是利用使用者瀏覽器對於網站的信任來達到攻擊，假設我們已經知道某某某 API 路徑，例如刪除帳號的API ",[41,42,43],"code",{},"https:\u002Fwww.example.com\u002Fdelete?id=XXX","，然後黑客就傳給你一個句話「快看!點這個網址可以取得一個比特幣」(屁)",[46,47,52],"pre",{"className":48,"code":49,"language":50,"meta":51,"style":51},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Ca href=\"https:\u002Fwww.example.com\u002Fdelete?id=1\">取得比特幣\u003C\u002Fa>\n","html","",[41,53,54],{"__ignoreMap":51},[55,56,59,63,66,70,73,77,80,82],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"s8XSl","\u003C",[55,64,32],{"class":65},"syv7_",[55,67,69],{"class":68},"sK3KL"," href",[55,71,72],{"class":61},"=",[55,74,76],{"class":75},"sWayO","\"https:\u002Fwww.example.com\u002Fdelete?id=1\"",[55,78,79],{"class":61},">取得比特幣\u003C\u002F",[55,81,32],{"class":65},[55,83,84],{"class":61},">\n",[16,86,87,88,91],{},"接下來你不疑有他就直接點了，當網站沒有做好 CSRF 防禦的時候，網站就只會知道說 「哦~你有我網站的 Cookie & Session，所以你要刪除 ",[41,89,90],{},"id = 1"," 的帳號是嗎?沒問題」就這樣網站不疑有他的把第一筆帳號刪除了，那麼為了避免這個狀況發生，那就要在網站上加入一個 CSRF 的防禦，當資料往後端傳送時，還必須帶上一組亂碼(類似 hash) 驗證若沒問題才會讓你執行，但是這一串數字並不是隨便帶都可以，而是要由瀏覽器觸發後端往前端傳才可以。",[16,93,94,95],{},"如果想要更詳細了解 CSRF 可以看",[32,96,100],{"href":97,"rel":98},"https:\u002F\u002Fblog.techbridge.cc\u002F2017\u002F02\u002F25\u002Fcsrf-introduction\u002F",[99],"nofollow","這一篇文章",[12,102,104],{"id":103},"thinkphp-如何解決-csrf","ThinkPHP 如何解決 CSRF",[16,106,107,108,113],{},"一般狀況下我們若是撰寫 Express.js 時，必須額外安裝套件，也就是 ",[32,109,112],{"href":110,"rel":111},"https:\u002F\u002Fgithub.com\u002Fexpressjs\u002Fcsurf",[99],"CSURF","，但是在 ThinkPHP 中本身就有提供 CSRF 的解決方式，但是必須搭配表單驗證，所以我才會將表單 Token 放在這之後才介紹。",[16,115,116],{},"而使用方式非常簡單，只需要增加一個隱藏欄位即可：",[46,118,122],{"className":119,"code":120,"language":121,"meta":51,"style":51},"language-php shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cinput type=\"hidden\" name=\"__token__\" value=\"{$Request.token}\" \u002F>\n","php",[41,123,124],{"__ignoreMap":51},[55,125,126,129,133,136,138,141,144,146,149,152,154,157,160,163,166,169],{"class":57,"line":58},[55,127,62],{"class":128},"sOudu",[55,130,132],{"class":131},"stw71","input",[55,134,135],{"class":131}," type",[55,137,72],{"class":128},[55,139,140],{"class":75},"\"hidden\"",[55,142,143],{"class":131}," name",[55,145,72],{"class":128},[55,147,148],{"class":75},"\"__token__\"",[55,150,151],{"class":131}," value",[55,153,72],{"class":128},[55,155,156],{"class":75},"\"{",[55,158,159],{"class":61},"$Request",[55,161,162],{"class":128},".",[55,164,165],{"class":131},"token",[55,167,168],{"class":75},"}\"",[55,170,171],{"class":128}," \u002F>\n",[16,173,174],{},"接下來讓我們將這一段加入到註冊頁面，此時註冊頁面就會有一個隱藏欄位在表單上 ↓",[16,176,177],{},[178,179],"img",{"alt":165,"src":180},"https:\u002F\u002Fi.imgur.com\u002FWsaiwym.png",[16,182,183,184,187,188,191],{},"當然你也可以偷懶一點只寫 ",[41,185,186],{},"{:token()}","，ThinkPHP 會幫我們自動在 HTML 上自動生成 ",[41,189,190],{},"hidden"," 欄位 ↓",[16,193,194],{},[178,195],{"alt":165,"src":196},"https:\u002F\u002Fi.imgur.com\u002FKfKdAzj.png",[16,198,199,200,203,204,207,208,210],{},"接下來我們要增加提示訊息，所以要打開表單驗證的 ",[41,201,202],{},"validate\u002FUser.php","，然後挑選任一個欄位，到時候它出現該錯誤訊息欄位的位子，例如我放在 ",[41,205,206],{},"Email"," 它就會出現在 ",[41,209,206],{}," 的錯誤訊息，所以我們來加入一段驗證看看：",[46,212,214],{"className":119,"code":213,"language":121,"meta":51,"style":51},"protected $rule = [\n    'email' => 'require|email|token',\n    'password' => 'require|min:8|max:30',\n    'gender' => 'require|number',\n];\n",[41,215,216,229,244,257,270],{"__ignoreMap":51},[55,217,218,221,224,226],{"class":57,"line":58},[55,219,220],{"class":128},"protected",[55,222,223],{"class":61}," $rule ",[55,225,72],{"class":128},[55,227,228],{"class":61}," [\n",[55,230,232,235,238,241],{"class":57,"line":231},2,[55,233,234],{"class":75},"    'email'",[55,236,237],{"class":128}," =>",[55,239,240],{"class":75}," 'require|email|token'",[55,242,243],{"class":61},",\n",[55,245,247,250,252,255],{"class":57,"line":246},3,[55,248,249],{"class":75},"    'password'",[55,251,237],{"class":128},[55,253,254],{"class":75}," 'require|min:8|max:30'",[55,256,243],{"class":61},[55,258,260,263,265,268],{"class":57,"line":259},4,[55,261,262],{"class":75},"    'gender'",[55,264,237],{"class":128},[55,266,267],{"class":75}," 'require|number'",[55,269,243],{"class":61},[55,271,273],{"class":57,"line":272},5,[55,274,275],{"class":61},"];\n",[16,277,278,279,281,282,284,285,288],{},"這樣子就會驗證 ",[41,280,165],{}," 了，但是這邊必須修改一下 Controller，否則你會發生連 ",[41,283,165],{}," 都儲存進去資料庫的窘事，所以這邊必須使用 ",[41,286,287],{},"allowField(true)"," 的方法來解決這個問題：",[46,290,292],{"className":119,"code":291,"language":121,"meta":51,"style":51},"public function add() {\n  $user = new userModel;\n  $userData = input();\n  $result = $this->validate($userData, 'User');\n  if(true !== $result) {\n      Session::flash('error', $result);\n      $this->redirect('\u002Fuser\u002Fsignup');\n  }\n  if($user->allowField(true)->save($userData)){\n      return '新增成功';\n  } else {\n      return $user->getError();\n  }\n}\n",[41,293,294,309,325,338,363,380,400,418,424,452,463,475,490,495],{"__ignoreMap":51},[55,295,296,299,302,306],{"class":57,"line":58},[55,297,298],{"class":128},"public",[55,300,301],{"class":128}," function",[55,303,305],{"class":304},"scAaK"," add",[55,307,308],{"class":61},"() {\n",[55,310,311,314,316,319,322],{"class":57,"line":231},[55,312,313],{"class":61},"  $user ",[55,315,72],{"class":128},[55,317,318],{"class":128}," new",[55,320,321],{"class":131}," userModel",[55,323,324],{"class":61},";\n",[55,326,327,330,332,335],{"class":57,"line":246},[55,328,329],{"class":61},"  $userData ",[55,331,72],{"class":128},[55,333,334],{"class":304}," input",[55,336,337],{"class":61},"();\n",[55,339,340,343,345,348,351,354,357,360],{"class":57,"line":259},[55,341,342],{"class":61},"  $result ",[55,344,72],{"class":128},[55,346,347],{"class":131}," $this",[55,349,350],{"class":128},"->",[55,352,353],{"class":304},"validate",[55,355,356],{"class":61},"($userData, ",[55,358,359],{"class":75},"'User'",[55,361,362],{"class":61},");\n",[55,364,365,368,371,374,377],{"class":57,"line":272},[55,366,367],{"class":128},"  if",[55,369,370],{"class":61},"(",[55,372,373],{"class":131},"true",[55,375,376],{"class":128}," !==",[55,378,379],{"class":61}," $result) {\n",[55,381,383,386,389,392,394,397],{"class":57,"line":382},6,[55,384,385],{"class":131},"      Session",[55,387,388],{"class":128},"::",[55,390,391],{"class":304},"flash",[55,393,370],{"class":61},[55,395,396],{"class":75},"'error'",[55,398,399],{"class":61},", $result);\n",[55,401,403,406,408,411,413,416],{"cla