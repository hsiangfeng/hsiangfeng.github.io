[{"data":1,"prerenderedAt":732},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190926\u002F2431942103\u002F":3,"page:\u002Fphp\u002F20190926\u002F2431942103\u002F":4,"alt:\u002Fphp\u002F20190926\u002F2431942103\u002F":3,"prev-next:\u002Fphp\u002F20190926\u002F2431942103\u002F":709,"related:\u002Fphp\u002F20190926\u002F2431942103\u002F":718},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F26\u002Fthinkphp-day-25-form-token\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":690,"date":691,"description":18,"extension":692,"lang":693,"meta":694,"navigation":695,"path":696,"readingMinutes":697,"seo":698,"standalone":699,"stem":700,"tags":701,"tldr":706,"updated":706,"url":707,"__hash__":708},"content\u002F從基礎學習 ThinkPHP\u002FDay25-從基礎學習-ThinkPHP-表單-Token.md","Day25-從基礎學習 ThinkPHP-表單 Token","2431942103",{"type":9,"value":10,"toc":684},"minimark",[11,15,19,23,37,45,85,92,101,105,114,117,171,174,180,191,196,210,275,288,500,509,516,522,532,651,657,660,666,669,677,680],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"講完表單驗證，那麼這一篇就要來講表單 Token，表單 Token 是需要搭配前面的表單驗證才能夠使用，所以我才會將表單 Token 留在表單驗證後面，那麼就讓我們來了解什麼是表單 Token 吧!",[12,20,22],{"id":21},"表單-token-用途","表單 Token 用途",[16,24,25,26,30,31,36],{},"首先表單 Token 最主要是為了解決 CSRF 的問題，CSRF 中文又稱為 ",[27,28,29],"strong",{},"跨站請求偽造","，先前我其中一篇文章有稍微解釋過 ",[32,33,35],"a",{"href":34},"\u002Fnodejs\u002F20190704\u002F2336420619\u002F","CSRF","，所以這邊就直接節錄部分內容。",[16,38,39,40,44],{},"CSRF 簡單來講就是利用使用者瀏覽器對於網站的信任來達到攻擊，假設我們已經知道某某某 API 路徑，例如刪除帳號的API ",[41,42,43],"code",{},"https:\u002Fwww.example.com\u002Fdelete?id=XXX","，然後黑客就傳給你一個句話「快看!點這個網址可以取得一個比特幣」(屁)",[46,47,52],"pre",{"className":48,"code":49,"language":50,"meta":51,"style":51},"language-html shiki shiki-themes github-dark-high-contrast","\u003Ca href=\"https:\u002Fwww.example.com\u002Fdelete?id=1\">取得比特幣\u003C\u002Fa>\n","html","",[41,53,54],{"__ignoreMap":51},[55,56,59,63,66,70,73,77,80,82],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"sMAXC","\u003C",[55,64,32],{"class":65},"sKpQp",[55,67,69],{"class":68},"sCcAr"," href",[55,71,72],{"class":61},"=",[55,74,76],{"class":75},"sTRMh","\"https:\u002Fwww.example.com\u002Fdelete?id=1\"",[55,78,79],{"class":61},">取得比特幣\u003C\u002F",[55,81,32],{"class":65},[55,83,84],{"class":61},">\n",[16,86,87,88,91],{},"接下來你不疑有他就直接點了，當網站沒有做好 CSRF 防禦的時候，網站就只會知道說 「哦~你有我網站的 Cookie & Session，所以你要刪除 ",[41,89,90],{},"id = 1"," 的帳號是嗎?沒問題」就這樣網站不疑有他的把第一筆帳號刪除了，那麼為了避免這個狀況發生，那就要在網站上加入一個 CSRF 的防禦，當資料往後端傳送時，還必須帶上一組亂碼(類似 hash) 驗證若沒問題才會讓你執行，但是這一串數字並不是隨便帶都可以，而是要由瀏覽器觸發後端往前端傳才可以。",[16,93,94,95],{},"如果想要更詳細了解 CSRF 可以看",[32,96,100],{"href":97,"rel":98},"https:\u002F\u002Fblog.techbridge.cc\u002F2017\u002F02\u002F25\u002Fcsrf-introduction\u002F",[99],"nofollow","這一篇文章",[12,102,104],{"id":103},"thinkphp-如何解決-csrf","ThinkPHP 如何解決 CSRF",[16,106,107,108,113],{},"一般狀況下我們若是撰寫 Express.js 時，必須額外安裝套件，也就是 ",[32,109,112],{"href":110,"rel":111},"https:\u002F\u002Fgithub.com\u002Fexpressjs\u002Fcsurf",[99],"CSURF","，但是在 ThinkPHP 中本身就有提供 CSRF 的解決方式，但是必須搭配表單驗證，所以我才會將表單 Token 放在這之後才介紹。",[16,115,116],{},"而使用方式非常簡單，只需要增加一個隱藏欄位即可：",[46,118,122],{"className":119,"code":120,"language":121,"meta":51,"style":51},"language-php shiki shiki-themes github-dark-high-contrast","\u003Cinput type=\"hidden\" name=\"__token__\" value=\"{$Request.token}\" \u002F>\n","php",[41,123,124],{"__ignoreMap":51},[55,125,126,129,132,135,137,140,143,145,148,151,153,156,159,162,165,168],{"class":57,"line":58},[55,127,62],{"class":128},"sWyjQ",[55,130,131],{"class":68},"input",[55,133,134],{"class":68}," type",[55,136,72],{"class":128},[55,138,139],{"class":75},"\"hidden\"",[55,141,142],{"class":68}," name",[55,144,72],{"class":128},[55,146,147],{"class":75},"\"__token__\"",[55,149,150],{"class":68}," value",[55,152,72],{"class":128},[55,154,155],{"class":75},"\"{",[55,157,158],{"class":61},"$Request",[55,160,161],{"class":128},".",[55,163,164],{"class":68},"token",[55,166,167],{"class":75},"}\"",[55,169,170],{"class":128}," \u002F>\n",[16,172,173],{},"接下來讓我們將這一段加入到註冊頁面，此時註冊頁面就會有一個隱藏欄位在表單上 ↓",[16,175,176],{},[177,178],"img",{"alt":164,"src":179},"https:\u002F\u002Fi.imgur.com\u002FWsaiwym.png",[16,181,182,183,186,187,190],{},"當然你也可以偷懶一點只寫 ",[41,184,185],{},"{:token()}","，ThinkPHP 會幫我們自動在 HTML 上自動生成 ",[41,188,189],{},"hidden"," 欄位 ↓",[16,192,193],{},[177,194],{"alt":164,"src":195},"https:\u002F\u002Fi.imgur.com\u002FKfKdAzj.png",[16,197,198,199,202,203,206,207,209],{},"接下來我們要增加提示訊息，所以要打開表單驗證的 ",[41,200,201],{},"validate\u002FUser.php","，然後挑選任一個欄位，到時候它出現該錯誤訊息欄位的位子，例如我放在 ",[41,204,205],{},"Email"," 它就會出現在 ",[41,208,205],{}," 的錯誤訊息，所以我們來加入一段驗證看看：",[46,211,213],{"className":119,"code":212,"language":121,"meta":51,"style":51},"protected $rule = [\n    'email' => 'require|email|token',\n    'password' => 'require|min:8|max:30',\n    'gender' => 'require|number',\n];\n",[41,214,215,228,243,256,269],{"__ignoreMap":51},[55,216,217,220,223,225],{"class":57,"line":58},[55,218,219],{"class":128},"protected",[55,221,222],{"class":61}," $rule ",[55,224,72],{"class":128},[55,226,227],{"class":61}," [\n",[55,229,231,234,237,240],{"class":57,"line":230},2,[55,232,233],{"class":75},"    'email'",[55,235,236],{"class":128}," =>",[55,238,239],{"class":75}," 'require|email|token'",[55,241,242],{"class":61},",\n",[55,244,246,249,251,254],{"class":57,"line":245},3,[55,247,248],{"class":75},"    'password'",[55,250,236],{"class":128},[55,252,253],{"class":75}," 'require|min:8|max:30'",[55,255,242],{"class":61},[55,257,259,262,264,267],{"class":57,"line":258},4,[55,260,261],{"class":75},"    'gender'",[55,263,236],{"class":128},[55,265,266],{"class":75}," 'require|number'",[55,268,242],{"class":61},[55,270,272],{"class":57,"line":271},5,[55,273,274],{"class":61},"];\n",[16,276,277,278,280,281,283,284,287],{},"這樣子就會驗證 ",[41,279,164],{}," 了，但是這邊必須修改一下 Controller，否則你會發生連 ",[41,282,164],{}," 都儲存進去資料庫的窘事，所以這邊必須使用 ",[41,285,286],{},"allowField(true)"," 的方法來解決這個問題：",[46,289,291],{"className":119,"code":290,"language":121,"meta":51,"style":51},"public function add() {\n  $user = new userModel;\n  $userData = input();\n  $result = $this->validate($userData, 'User');\n  if(true !== $result) {\n      Session::flash('error', $result);\n      $this->redirect('\u002Fuser\u002Fsignup');\n  }\n  if($user->allowField(true)->save($userData)){\n      return '新增成功';\n  } else {\n      return $user->getError();\n  }\n}\n",[41,292,293,308,324,337,362,379,399,417,423,451,462,474,489,494],{"__ignoreMap":51},[55,294,295,298,301,305],{"class":57,"line":58},[55,296,297],{"class":128},"public",[55,299,300],{"class":128}," function",[55,302,304],{"class":303},"sj_SG"," add",[55,306,307],{"class":61},"() {\n",[55,309,310,313,315,318,321],{"class":57,"line":230},[55,311,312],{"class":61},"  $user ",[55,314,72],{"class":128},[55,316,317],{"class":128}," new",[55,319,320],{"class":68}," userModel",[55,322,323],{"class":61},";\n",[55,325,326,329,331,334],{"class":57,"line":245},[55,327,328],{"class":61},"  $userData ",[55,330,72],{"class":128},[55,332,333],{"class":303}," input",[55,335,336],{"class":61},"();\n",[55,338,339,342,344,347,350,353,356,359],{"class":57,"line":258},[55,340,341],{"class":61},"  $result ",[55,343,72],{"class":128},[55,345,346],{"class":68}," $this",[55,348,349],{"class":128},"->",[55,351,352],{"class":303},"validate",[55,354,355],{"class":61},"($userData, ",[55,357,358],{"class":75},"'User'",[55,360,361],{"class":61},");\n",[55,363,364,367,370,373,376],{"class":57,"line":271},[55,365,366],{"class":128},"  if",[55,368,369],{"class":61},"(",[55,371,372],{"class":68},"true",[55,374,375],{"class":128}," !==",[55,377,378],{"class":61}," $result) {\n",[55,380,382,385,388,391,393,396],{"class":57,"line":381},6,[55,383,384],{"class":68},"      Session",[55,386,387],{"class":128},"::",[55,389,390],{"class":303},"flash",[55,392,369],{"class":61},[55,394,395],{"class":75},"'error'",[55,397,398],{"class":61},", $result);\n",[55,400,402,405,407,410,412,415],{"class":57,"line":401},7,[55,403,404],{"class":68},"      $this",[55,406,349],{"class":128},[55,408,409],{"class":303},"redirect",[55,411,369],{"class":61},[55,413,414],{"class":75},"'\u002Fuser\u002Fsignup'",[55,416,361],{"class":61},[55,418,420],{"class":57,"line":419},8,[55,421,422],{"class":61},"  }\n",[55,424,426,428,431,433,436,438,440,443,445,448],{"class":57,"line":425},9,[55,427,366],{"class":128},[55,429,430],{"class":61},"($user",[55,432,349],{"class":128},[55,434,435],{"class":303},"allowField",[55,437,369],{"class":61},[55,439,372],{"class":68},[55,441,442],{"class":61},")",[55,444,349],{"class":128},[55,446,447],{"class":303},"save",[55,449,450],{"class":61},"($userData)){\n",[55,452,454,457,460],{"class":57,"line":453},10,[55,455,456],{"class":128},"      return",[55,458,459],{"class":75}," '新增成功'",[55,461,323],{"class":61},[55,463,465,468,471],{"class":57,"line":464},11,[55,466,467],{"class":61},"  } ",[55,469,470],{"class":128},"else",[55,472,473],{"class":61}," {\n",[55,475,477,479,482,484,487],{"class":57,"line":476},12,[55,478,456],{"class":128},[55,480,481],{"class":61}," $user",[55,483,349],{"class":128},[55,485,486],{"class":303},"getError",[55,488,336],{"class":61},[55,490,492],{"class":57,"line":491},13,[55,493,422],{"class":61},[55,495,497],{"class":57,"line":496},14,[55,498,499],{"class":61},"}\n",[16,501,502,503,505,506,508],{},"當然你可能會發現有沒有加入 ",[41,504,286],{}," 感覺好像都沒差，但是如果你沒有在 Model 設置 field 的話，我個人建議要加上 ",[41,507,286],{}," 避免出現一些很奇怪的問題 (我個人也會建議加上)。",[16,510,511,512,515],{},"接下來讓我們來嘗試看看用 PostMan 打看看 ",[41,513,514],{},"http:\u002F\u002Flocalhost:8000\u002Fuser\u002Fsignup\u002Fadd"," 吧。",[16,517,518],{},[177,519],{"alt":520,"src":521},"token 無效","https:\u002F\u002Fi.imgur.com\u002FOrNdrSn.png",[16,523,524,525,527,528,531],{},"那麼這樣就可以成功防禦 CSRF 囉~但是你可能會說這個提示訊息能不能客製化，其實可以客製化訊息的，一樣打開 ",[41,526,201],{}," 加入一段客製化訊息在 ",[41,529,530],{},"protected $message"," 即可：",[46,533,535],{"className":119,"code":534,"language":121,"meta":51,"style":51},"protected $message = [\n    'email.require' => 'Email 必填',\n    'email.email'=> 'Email 格式錯誤',\n    'email.token' => 'Token 出現問題請重新整理。', \u002F\u002F Token 錯誤訊息\n    'password.require' => '密碼欄位必填',\n    'password.min' => '密碼最短長度為 8',\n    'password.max' => '密碼長度最長為 30',\n    'gender.require' => '性別必填',\n    'gender' => '性別必須為是數字'\n];\n",[41,536,537,548,560,573,590,602,614,626,638,647],{"__ignoreMap":51},[55,538,539,541,544,546],{"class":57,"line":58},[55,540,219],{"class":128},[55,542,543],{"class":61}," $message ",[55,545,72],{"class":128},[55,547,227],{"class":61},[55,549,550,553,555,558],{"class":57,"line":230},[55,551,552],{"class":75},"    'email.require'",[55,554,236],{"class":128},[55,556,557],{"class":75}," 'Email 必填'",[55,559,242],{"class":61},[55,561,562,565,568,571],{"class":57,"line":245},[55,563,564],{"class":75},"    'email.email'",[55,566,567],{"class":128},"=>",[55,569,570],{"class":75}," 'Email 格式錯誤'",[55,572,242],{"class":61},[55,574,575,578,580,583,586],{"class":57,"line":258},[55,576,577],{"class":75},"    'email.token'",[55,579,236],{"class":128},[55,581,582],{"class":75}," 'Token 出現問題請重新整理。'",[55,584,585],{"class":61},", ",[55,587,589],{"class":588},"sQrFR","\u002F\u002F Token 錯誤訊息\n",[55,591,592,595,597,600],{"class":57,"line":271},[55,593,594],{"class":75},"    'password.require'",[55,596,236],{"class":128},[55,598,599],{"class":75}," '密碼欄位必填'",[55,601,242],{"class":61},[55,603,604,607,609,612],{"class":57,"line":381},[55,605,606],{"class":75},"    'password.min'",[55,608,236],{"class":128},[55,610,611],{"class":75}," '密碼最短長度為 8'",[55,613,242],{"class":61},[55,615,616,619,621,624],{"class":57,"line":401},[55,617,618],{"class":75},"    'password.max'",[55,620,236],{"class":128},[55,622,623],{"class":75}," '密碼長度最長為 30'",[55,625,242],{"class":61},[55,627,628,631,633,636],{"class":57,"line":419},[55,629,630],{"class":75},"    'gender.require'",[55,632,236],{"class":128},[55,634,635],{"class":75}," '性別必填'",[55,637,242],{"class":61},[55,639,640,642,644],{"class":57,"line":425},[55,641,261],{"class":75},[55,643,236],{"class":128},[55,645,646],{"class":75}," '性別必須為是數字'\n",[55,648,649],{"class":57,"line":453},[55,650,274],{"class":61},[16,652,653],{},[177,654],{"alt":655,"src":656},"message","https:\u002F\u002Fi.imgur.com\u002FcXIWzaq.png",[16,658,659],{},"接下來我們再打一次就可以看到提示訊息變了 ↓",[16,661,662],{},[177,663],{"alt":664,"src":665},"Token 出現問題請重新整理。","https:\u002F\u002Fi.imgur.com\u002FiQuPl03.png",[12,667,668],{"id":668},"結尾",[16,670,671,672],{},"大致上已經將驗證方面的東西介紹差不多了，如果想了解更詳細的驗證以及如何客製化自己的驗證器，那麼我會建議看官方手冊的驗證章節會更詳細 → ",[32,673,676],{"href":674,"rel":675},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354101",[99],"官方手冊",[16,678,679],{},"下一篇將會來介紹驗證碼，驗證碼最常使用於登入了~",[681,682,683],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":51,"searchDepth":230,"depth":230,"links":685},[686,687,688,689],{"id":14,"depth":230,"text":14},{"id":21,"depth":230,"text":22},{"id":103,"depth":230,"text":104},{"id":668,"depth":230,"text":668},"PHP","2019-09-26 00:00:05","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday25-thinkphp-token","3",{"title":6,"descript