[{"data":1,"prerenderedAt":1112},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190918\u002F629335687\u002F":3,"page:\u002Fphp\u002F20190918\u002F629335687\u002F":4,"alt:\u002Fphp\u002F20190918\u002F629335687\u002F":3,"prev-next:\u002Fphp\u002F20190918\u002F629335687\u002F":1089,"related:\u002Fphp\u002F20190918\u002F629335687\u002F":1098},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F18\u002Fthinkphp-day-17-data-operations-query-builder\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1070,"date":1071,"description":18,"extension":1072,"lang":1073,"meta":1074,"navigation":1075,"path":1076,"readingMinutes":1077,"seo":1078,"standalone":1079,"stem":1080,"tags":1081,"tldr":1086,"updated":1086,"url":1087,"__hash__":1088},"content\u002F從基礎學習 ThinkPHP\u002FDay17-從基礎學習-ThinkPHP-資料操作-2.md","Day17-從基礎學習 ThinkPHP-資料操作(2)","629335687",{"type":9,"value":10,"toc":1057},"minimark",[11,15,19,22,25,33,36,48,52,55,113,116,172,175,207,210,213,220,270,279,282,285,316,322,364,367,418,421,424,427,468,471,481,648,651,658,698,701,958,961,964,1025,1042,1045,1053],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇的資料操作我們使用原生 SQL 指令來撰寫資料操作，那麼這一篇呢?這一篇我們將會使用 ThinkPHP 所提供的功能，也就是構造器來進行資料操作。",[12,20,21],{"id":21},"構造器",[16,23,24],{},"我不清楚為什麼官方會翻譯成構造器，但是簡單來講 ThinkPHP 提供一些包裝好的 SQL 指令方法，最主要可以方便我們做資料操作，而這資料操作是基於 PDO 參數綁定，PDO 可以保護系統被 SQL 注入，所以我們可以不用去撰寫特殊字符轉譯。",[16,26,27,28],{},"SQL 注入可以參考我另一篇寫的文章介紹，可能不是講得非常好，但是有一些小範例可以參考：",[29,30,32],"a",{"href":31},"\u002Fnodejs\u002F20190717\u002F3433181406\u002F","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-SQL injection",[12,34,35],{"id":35},"撰寫方式",[16,37,38,39,43,44,47],{},"由於我這邊也是希望可以保留寫法，所以一樣會在 dbexample 控制器下撰寫，但使用構造器撰寫的方法我通通會加上一個前綴詞，也就是 ",[40,41,42],"code",{},"sqlXxx","，例如新增的方法就是 ",[40,45,46],{},"sqlAdd"," 以此類推。",[49,50,51],"h3",{"id":51},"新增資料",[16,53,54],{},"構造器的寫法非常簡潔，讓我們先從新增的寫法吧!",[56,57,62],"pre",{"className":58,"code":59,"language":60,"meta":61,"style":61},"language-php shiki shiki-themes github-dark-high-contrast","Db::table('think_db')->insert(['name'=>'陳春嬌']);\n","php","",[40,63,64],{"__ignoreMap":61},[65,66,69,73,77,81,85,89,92,95,98,101,104,107,110],"span",{"class":67,"line":68},"line",1,[65,70,72],{"class":71},"sCcAr","Db",[65,74,76],{"class":75},"sWyjQ","::",[65,78,80],{"class":79},"sj_SG","table",[65,82,84],{"class":83},"sMAXC","(",[65,86,88],{"class":87},"sTRMh","'think_db'",[65,90,91],{"class":83},")",[65,93,94],{"class":75},"->",[65,96,97],{"class":79},"insert",[65,99,100],{"class":83},"([",[65,102,103],{"class":87},"'name'",[65,105,106],{"class":75},"=>",[65,108,109],{"class":87},"'陳春嬌'",[65,111,112],{"class":83},"]);\n",[16,114,115],{},"這樣子一個基礎的新增方法，我們就完成了，讓我們稍微比較一下原生 SQL 寫法以及構造器語法，下方這個是原生 SQL 語法：",[56,117,119],{"className":58,"code":118,"language":60,"meta":61,"style":61},"$result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\ndump($result);\n",[40,120,121,163],{"__ignoreMap":61},[65,122,123,126,129,132,134,137,139,142,145,148,151,154,157,160],{"class":67,"line":68},[65,124,125],{"class":83},"$result ",[65,127,128],{"class":75},"=",[65,130,131],{"class":71}," Db",[65,133,76],{"class":75},[65,135,136],{"class":79},"execute",[65,138,84],{"class":83},[65,140,141],{"class":87},"'",[65,143,144],{"class":75},"INSERT INTO",[65,146,147],{"class":87}," think_db (",[65,149,150],{"class":75},"name",[65,152,153],{"class":87},") ",[65,155,156],{"class":75},"VALUE",[65,158,159],{"class":87}," (\"王大明\")'",[65,161,162],{"class":83},");\n",[65,164,166,169],{"class":67,"line":165},2,[65,167,168],{"class":79},"dump",[65,170,171],{"class":83},"($result);\n",[16,173,174],{},"而下方這個是透過 ThinkPHP 所提供的構造器寫法：",[56,176,177],{"className":58,"code":59,"language":60,"meta":61,"style":61},[40,178,179],{"__ignoreMap":61},[65,180,181,183,185,187,189,191,193,195,197,199,201,203,205],{"class":67,"line":68},[65,182,72],{"class":71},[65,184,76],{"class":75},[65,186,80],{"class":79},[65,188,84],{"class":83},[65,190,88],{"class":87},[65,192,91],{"class":83},[65,194,94],{"class":75},[65,196,97],{"class":79},[65,198,100],{"class":83},[65,200,103],{"class":87},[65,202,106],{"class":75},[65,204,109],{"class":87},[65,206,112],{"class":83},[16,208,209],{},"相較之下語法簡潔非常多，只是多了必須指定資料表名稱，否則 ThinkPHP 不知道你要將資料新增到哪裡。",[49,211,212],{"id":212},"更新資料",[16,214,215,216,219],{},"更新的語法呢?其實也很簡單，但是會帶上一個 ",[40,217,218],{},"where"," ，也就是條件來判定要更新哪一筆資料：",[56,221,223],{"className":58,"code":222,"language":60,"meta":61,"style":61},"Db::table('think_db')->where('name','陳春嬌')->updata(['name'=>'陳秋嬌']);\n",[40,224,225],{"__ignoreMap":61},[65,226,227,229,231,233,235,237,239,241,243,245,247,250,252,254,256,259,261,263,265,268],{"class":67,"line":68},[65,228,72],{"class":71},[65,230,76],{"class":75},[65,232,80],{"class":79},[65,234,84],{"class":83},[65,236,88],{"class":87},[65,238,91],{"class":83},[65,240,94],{"class":75},[65,242,218],{"class":79},[65,244,84],{"class":83},[65,246,103],{"class":87},[65,248,249],{"class":83},",",[65,251,109],{"class":87},[65,253,91],{"class":83},[65,255,94],{"class":75},[65,257,258],{"class":79},"updata",[65,260,100],{"class":83},[65,262,103],{"class":87},[65,264,106],{"class":75},[65,266,267],{"class":87},"'陳秋嬌'",[65,269,112],{"class":83},[16,271,272,273,275,276,278],{},"請注意要先 ",[40,274,218],{}," 之後再 ",[40,277,258],{},"，否則可是會出現錯誤的唷。",[49,280,281],{"id":281},"查詢資料",[16,283,284],{},"查詢的方法可以分為查詢全部以及單一查詢，那麼我先寫查詢全部的方法：",[56,286,288],{"className":58,"code":287,"language":60,"meta":61,"style":61},"Db::table('think_db')->select(); \u002F\u002F 超簡短(?!)\n",[40,289,290],{"__ignoreMap":61},[65,291,292,294,296,298,300,302,304,306,309,312],{"class":67,"line":68},[65,293,72],{"class":71},[65,295,76],{"class":75},[65,297,80],{"class":79},[65,299,84],{"class":83},[65,301,88],{"class":87},[65,303,91],{"class":83},[65,305,94],{"class":75},[65,307,308],{"class":79},"select",[65,310,311],{"class":83},"(); ",[65,313,315],{"class":314},"sQrFR","\u002F\u002F 超簡短(?!)\n",[16,317,318,319,321],{},"那單一查詢呢?一樣是搭配上 ",[40,320,218],{}," 來做查詢：",[56,323,325],{"className":58,"code":324,"language":60,"meta":61,"style":61},"Db::table('think_db')->where('name','陳秋嬌')->select(); \u002F\u002F 還是非常簡短(?!)\n",[40,326,327],{"__ignoreMap":61},[65,328,329,331,333,335,337,339,341,343,345,347,349,351,353,355,357,359,361],{"class":67,"line":68},[65,330,72],{"class":71},[65,332,76],{"class":75},[65,334,80],{"class":79},[65,336,84],{"class":83},[65,338,88],{"class":87},[65,340,91],{"class":83},[65,342,94],{"class":75},[65,344,218],{"class":79},[65,346,84],{"class":83},[65,348,103],{"class":87},[65,350,249],{"class":83},[65,352,267],{"class":87},[65,354,91],{"class":83},[65,356,94],{"class":75},[65,358,308],{"class":79},[65,360,311],{"class":83},[65,362,363],{"class":314},"\u002F\u002F 還是非常簡短(?!)\n",[16,365,366],{},"我們也可以回顧一下前一篇我們所撰寫的單一查詢原生 SQL 語法：",[56,368,370],{"className":58,"code":369,"language":60,"meta":61,"style":61},"$result = Db::query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result);\n",[40,371,372,412],{"__ignoreMap":61},[65,373,374,376,378,380,382,385,387,389,392,395,398,401,404,407,410],{"class":67,"line":68},[65,375,125],{"class":83},[65,377,128],{"class":75},[65,379,131],{"class":71},[65,381,76],{"class":75},[65,383,384],{"class":79},"query",[65,386,84],{"class":83},[65,388,141],{"class":87},[65,390,391],{"class":75},"SELECT",[65,393,394],{"class":75}," *",[65,396,397],{"class":75}," FROM",[65,399,400],{"class":87}," think_db ",[65,402,403],{"class":75},"WHERE",[65,405,406],{"class":75}," name=",[65,408,409],{"class":87},"\"QQ 先生\"'",[65,411,162],{"class":83},[65,413,414,416],{"class":67,"line":165},[65,415,168],{"class":79},[65,417,171],{"class":83},[16,419,420],{},"可以發現透過構造器撰寫的資料操作是真的簡易非常多，但是對於基礎的 SQL 語法是必須理解，否則你會覺得很像在變魔術。",[49,422,423],{"id":423},"刪除資料",[16,425,426],{},"相信聰明的你經過上面的洗鍊就會知道該怎麼寫刪除語法，在刪除資料之前一定要先使用條件篩選來刪除資料，然後在執行刪除動作，否則可是發生悲劇的：",[56,428,430],{"className":58,"code":429,"language":60,"meta":61,"style":61},"Db::table('think_db')->where('name','陳秋嬌')->delete();\n",[40,431,432],{"__ignoreMap":61},[65,433,434,436,438,440,442,444,446,448,450,452,454,456,458,460,462,465],{"class":67,"line":68},[65,435,72],{"class":71},[65,437,76],{"class":75},[65,439,80],{"class":79},[65,441,84],{"class":83},[65,443,88],{"class":87},[65,445,91],{"class":83},[65,447,94],{"class":75},[65,449,218],{"class":79},[65,451,84],{"class":83},[65,453,103],{"class":87},[65,455,249],{"class":83},[65,457,267],{"class":87},[65,459,91],{"class":83},[65,461,94],{"class":75},[65,463,464],{"class":79},"delete",[65,466,467],{"class":83},"();\n",[49,469,470],{"id":470},"簡化語法",[16,472,473,474,476,477,480],{},"另外我們還可以將指定資料表的 ",[40,475,80],{}," 語法簡寫，可以不用帶入 ",[40,478,479],{},"think_","，而是透過設置 (database.php) 幫我們自己帶入前綴詞也這樣也是可以的：",[56,482,484],{"className":58,"code":483,"language":60,"meta":61,"style":61},"Db::table('db')->insert(['name'=>'陳春嬌']);\nDb::table('db')->where('name','陳春嬌')->updata(['name'=>'陳秋嬌']);\nDb::table('db')->select();\nDb::table('db')->where('name','陳秋嬌')->select();\nDb::table('db')->where('name','陳秋嬌')->delete();\n",[40,485,486,515,557,578,613],{"__ignoreMap":61},[65,487,488,490,492,494,496,499,501,503,505,507,509,511,513],{"class":67,"line":68},[65,489,72],{"class":71},[65,491,76],{"class":75},[65,493,80],{"class":79},[65,495,84],{"class":83},[65,497,498],{"class":87},"'db'",[65,500,91],{"class":83},[65,502,94],{"class":75},[65,504,97],{"class":79},[65,506,100],{"class":83},[65,508,103],{"class":87},[65,510,106],{"class":75},[65,512,109],{"class":87},[65,514,112],{"class":83},[65,516,517,519,521,523,525,527,529,531,533,535,537,539,541,543,545,547,549,551,553,555],{"class":67,"line":165},[65,518,72],{"class":71},[65,520,76],{"class":75},[65,522,80],{"class":79},[65,524,84],{"class":83},[65,526,498],{"class":87},[65,528,91],{"class":83},[65,530,94],{"class":75},[65,532,218],{"class":79},[65,534,84],{"class":83},[65,536,103],{"class":87},[65,538,249],{"class":83},[65,540,109],{"class":87},[65,542,91],{"class":83},[65,544,94],{"class":75},[65,546,258],{"class":79},[65,548,100],{"class":83},[65,550,103],{"class":87},[65,552,106],{"class":75},[65,5