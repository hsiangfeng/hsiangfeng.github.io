,[65,685,94],{"class":75},[65,687,97],{"class":79},[65,689,100],{"class":83},[65,691,103],{"class":87},[65,693,106],{"class":75},[65,695,109],{"class":87},[65,697,112],{"class":83},[16,699,700],{},"最後簡寫之後的完整程式碼就會像這樣這麼簡潔：",[56,702,704],{"className":58,"code":703,"language":60,"meta":61,"style":61},"public function sqlAdd()\n{\n  $db = db('db');\n  $db->insert(['name'=>'陳春嬌']);\n}\npublic function sqlUpdata()\n{\n  $db = db('db');\n  $db->where('name','陳春嬌')->updata(['name'=>'陳秋嬌']);\n}\npublic function sqlSelect()\n{\n  $db = db('db');\n  $db->where('name','陳秋嬌')->select();\n}\npublic function sqlDelete()\n{\n  $db = db('db');\n  $db->where('name','陳秋嬌')->delete();\n}\n",[40,705,706,720,725,740,759,764,776,781,796,829,834,846,851,866,891,896,908,913,928,953],{"__ignoreMap":61},[65,707,708,711,714,717],{"class":67,"line":68},[65,709,710],{"class":75},"public",[65,712,713],{"class":75}," function",[65,715,716],{"class":79}," sqlAdd",[65,718,719],{"class":83},"()\n",[65,721,722],{"class":67,"line":165},[65,723,724],{"class":83},"{\n",[65,726,727,730,732,734,736,738],{"class":67,"line":559},[65,728,729],{"class":83},"  $db ",[65,731,128],{"class":75},[65,733,672],{"class":79},[65,735,84],{"class":83},[65,737,498],{"class":87},[65,739,162],{"class":83},[65,741,742,745,747,749,751,753,755,757],{"class":67,"line":580},[65,743,744],{"class":83},"  $db",[65,746,94],{"class":75},[65,748,97],{"class":79},[65,750,100],{"class":83},[65,752,103],{"class":87},[65,754,106],{"class":75},[65,756,109],{"class":87},[65,758,112],{"class":83},[65,760,761],{"class":67,"line":615},[65,762,763],{"class":83},"}\n",[65,765,767,769,771,774],{"class":67,"line":766},6,[65,768,710],{"class":75},[65,770,713],{"class":75},[65,772,773],{"class":79}," sqlUpdata",[65,775,719],{"class":83},[65,777,779],{"class":67,"line":778},7,[65,780,724],{"class":83},[65,782,784,786,788,790,792,794],{"class":67,"line":783},8,[65,785,729],{"class":83},[65,787,128],{"class":75},[65,789,672],{"class":79},[65,791,84],{"c