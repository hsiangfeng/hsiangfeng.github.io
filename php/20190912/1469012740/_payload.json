[{"data":1,"prerenderedAt":758},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190912\u002F1469012740\u002F":3,"page:\u002Fphp\u002F20190912\u002F1469012740\u002F":4,"alt:\u002Fphp\u002F20190912\u002F1469012740\u002F":3,"prev-next:\u002Fphp\u002F20190912\u002F1469012740\u002F":735,"related:\u002Fphp\u002F20190912\u002F1469012740\u002F":744},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":718,"date":719,"description":18,"extension":720,"lang":721,"meta":722,"navigation":84,"path":723,"readingMinutes":724,"seo":725,"standalone":726,"stem":727,"tags":728,"tldr":732,"updated":732,"url":733,"__hash__":734},"content\u002F從基礎學習 ThinkPHP\u002FDay11-從基礎學習-ThinkPHP-Model.md","Day11-從基礎學習 ThinkPHP-Model","1469012740",{"type":9,"value":10,"toc":711},"minimark",[11,15,19,22,34,40,43,129,136,139,142,145,152,158,172,178,189,192,330,337,340,346,415,421,439,442,701,704,707],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一章節會稍微短一點，主要是介紹基礎的 Model 定義，但是在一般開發下是不太會針對 Model 做太多的設置，所以你會發現這一章節真的比較沒有什麼。",[12,20,21],{"id":21},"起手式",[16,23,24,25,29,30,33],{},"首先 Model 定義的方式很簡單，但是在那之前我們必須先建立 Model 資料夾，因為預設 ThinkPHP 並沒有提供 Model 資料夾，所以我們在 ",[26,27,28],"code",{},"about"," 底下建立一個 ",[26,31,32],{},"model"," 資料夾，並新增一個檔案叫做 about.php ↓",[16,35,36],{},[37,38],"img",{"alt":28,"src":39},"https:\u002F\u002Fi.imgur.com\u002F3isRFXF.png",[16,41,42],{},"那 Model 定義的方式只需要這樣子即可：",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-php shiki shiki-themes github-dark-high-contrast","\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n}\n","php","",[26,51,52,65,79,86,97,102,117,123],{"__ignoreMap":49},[53,54,57,61],"span",{"class":55,"line":56},"line",1,[53,58,60],{"class":59},"sWyjQ","\u003C?",[53,62,64],{"class":63},"sCcAr","php\n",[53,66,68,71,75],{"class":55,"line":67},2,[53,69,70],{"class":59},"namespace",[53,72,74],{"class":73},"s_sBn"," app\\about\\model",[53,76,78],{"class":77},"sMAXC",";\n",[53,80,82],{"class":55,"line":81},3,[53,83,85],{"emptyLinePlaceholder":84},true,"\n",[53,87,89,92,95],{"class":55,"line":88},4,[53,90,91],{"class":59},"use",[53,93,94],{"class":63}," think\\Model",[53,96,78],{"class":77},[53,98,100],{"class":55,"line":99},5,[53,101,85],{"emptyLinePlaceholder":84},[53,103,105,108,111,114],{"class":55,"line":104},6,[53,106,107],{"class":59},"class",[53,109,110],{"class":73}," about",[53,112,113],{"class":59}," extends",[53,115,116],{"class":63}," Model\n",[53,118,120],{"class":55,"line":119},7,[53,121,122],{"class":77},"{\n",[53,124,126],{"class":55,"line":125},8,[53,127,128],{"class":77},"}\n",[16,130,131,132,135],{},"裡面最需要注意的地方只有這一段程式碼 ",[26,133,134],{},"use think\\Model;","，這一段是在告知 ThinkPHP 我們要使用 Model 的核心庫，如果你缺少這一行就會無法正常運行唷。",[16,137,138],{},"好，恭喜你，你已經完成基礎的 Model 定義了(?!)，但是僅僅定義 Model 是不夠的，畢竟 Model 會操控 DB，所以下來我們要來設置資料庫。",[12,140,141],{"id":141},"連接資料庫",[16,143,144],{},"當我們準備好上面動作後，就要來做一下連接資料庫動作，否則 Model 是無法做任何操作 DB 的。",[16,146,147,148,151],{},"資料庫設置的檔案位於 ",[26,149,150],{},"project\u002Fconfig"," 底下的 database.php，只需要將相關欄位填入即可 ↓",[16,153,154],{},[37,155],{"alt":156,"src":157},"database","https:\u002F\u002Fi.imgur.com\u002Fh0HdCM4.png",[16,159,160,161,164,165,164,168,171],{},"基本上只需要填入 ",[26,162,163],{},"hostname","、",[26,166,167],{},"username",[26,169,170],{},"password"," 就可以了，那麼依照我的 MySQL 設置，就會這樣填入 ↓",[16,173,174],{},[37,175],{"alt":176,"src":177},"MySQL","https:\u002F\u002Fi.imgur.com\u002F6UiCius.png",[16,179,180,181,184,185,188],{},"只是有一個地方我有另外填入，也就是 ",[26,182,183],{},"prefix","，因為我建立的資料庫是有前綴的，所以才會填入 ",[26,186,187],{},"think_","。",[16,190,191],{},"接下來我們要先來新增一張資料表(後面章節會使用到)，SQL 指令我就直接給各位囉~",[44,193,197],{"className":194,"code":195,"language":196,"meta":49,"style":49},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_user (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  weight int(5) NOT NULL default 0,\n  height float(5) NOT NULL default 0,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql",[26,198,199,214,237,264,287,309,317],{"__ignoreMap":49},[53,200,201,204,207,211],{"class":55,"line":56},[53,202,203],{"class":59},"CREATE",[53,205,206],{"class":59}," TABLE",[53,208,210],{"class":209},"sj_SG"," think_user",[53,212,213],{"class":77}," (\n",[53,215,216,219,222,225,228,231,234],{"class":55,"line":67},[53,217,218],{"class":77},"  id ",[53,220,221],{"class":59},"int",[53,223,224],{"class":77},"(",[53,226,227],{"class":63},"10",[53,229,230],{"class":77},") ",[53,232,233],{"class":59},"NOT NULL",[53,235,236],{"class":77}," auto_increment,\n",[53,238,239,242,245,247,250,252,254,257,261],{"class":55,"line":81},[53,240,241],{"class":59},"  name",[53,243,244],{"class":59}," varchar",[53,246,224],{"class":77},[53,248,249],{"class":63},"5",[53,251,230],{"class":77},[53,253,233],{"class":59},[53,255,256],{"class":59}," default",[53,258,260],{"class":259},"sTRMh"," ''",[53,262,263],{"class":77},",\n",[53,265,266,269,272,274,276,278,280,282,285],{"class":55,"line":88},[53,267,268],{"class":59},"  weight",[53,270,271],{"class":59}," int",[53,273,224],{"class":77},[53,275,249],{"class":63},[53,277,230],{"class":77},[53,279,233],{"class":59},[53,281,256],{"class":59},[53,283,284],{"class":63}," 0",[53,286,263],{"class":77},[53,288,289,292,295,297,299,301,303,305,307],{"class":55,"line":99},[53,290,291],{"class":77},"  height ",[53,293,294],{"class":59},"float",[53,296,224],{"class":77},[53,298,249],{"class":63},[53,300,230],{"class":77},[53,302,233],{"class":59},[53,304,256],{"class":59},[53,306,284],{"class":63},[53,308,263],{"class":77},[53,310,311,314],{"class":55,"line":104},[53,312,313],{"class":59},"  PRIMARY KEY",[53,315,316],{"class":77}," (id)\n",[53,318,319,322,325,328],{"class":55,"line":119},[53,320,321],{"class":77},") AUTO_INCREMENT",[53,323,324],{"class":59},"=",[53,326,327],{"class":63},"1",[53,329,78],{"class":77},[16,331,332,333,336],{},"你可以發現我資料表也會加上前綴，而這等一下會幫助我們後面的操作，最主要是因為我在前面設置 database.php 時，有填入 ",[26,334,335],{},"prefix => 'think_'","，那麼資料庫在建立上就都必須加上前綴，否則 ThinkPHP 找不到唷。",[12,338,339],{"id":339},"模型指定資料表",[16,341,342,343,345],{},"接下來由於我在 database.php 有設置資料庫 & 表的前綴 ",[26,344,187],{},"，所以我們接下來再指定資料表的時候必須這樣寫 ↓",[44,347,349],{"className":46,"code":348,"language":48,"meta":49,"style":49},"\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n  protected $table = 'think_user';\n}\n",[26,350,351,357,365,369,377,381,391,395,410],{"__ignoreMap":49},[53,352,353,355],{"class":55,"line":56},[53,354,60],{"class":59},[53,356,64],{"class":63},[53,358,359,361,363],{"class":55,"line":67},[53,360,70],{"class":59},[53,362,74],{"class":73},[53,364,78],{"class":77},[53,366,367],{"class":55,"line":81},[53,368,85],{"emptyLinePlaceholder":84},[53,370,371,373,375],{"class":55,"line":88},[53,372,91],{"class":59},[53,374,94],{"class":63},[53,376,78],{"class":77},[53,378,379],{"class":55,"line":99},[53,380,85],{"emptyLinePlaceholder":84},[53,382,383,385,387,389],{"class":55,"line":104},[53,384,107],{"class":59},[53,386,110],{"class":73},[53,388,113],{"class":59},[53,390,116],{"class":63},[53,392,393],{"class":55,"line":119},[53,394,122],{"class":77},[53,396,397,400,403,405,408],{"class":55,"line":125},[53,398,399],{"class":59},"  protected",[53,401,402],{"class":77}," $table ",[53,404,324],{"class":59},[53,406,407],{"class":259}," 'think_user'",[53,409,78],{"class":77},[53,411,413],{"class":55,"line":412},9,[53,414,128],{"class":77},[16,416,417,418,420],{},"當然你也可以簡寫，ThinkPHP 會幫你帶上 ",[26,419,187],{},"，只是我個人習慣寫完整一點：",[44,422,424],{"className":46,"code":423,"language":48,"meta":49,"style":49},"protected $table = 'think_user';\n",[26,425,426],{"__ignoreMap":49},[53,427,428,431,433,435,437],{"class":55,"line":56},[53,429,430],{"class":59},"protected",[53,432,402],{"class":77},[53,434,324],{"class":59},[53,436,407],{"class":259},[53,438,78],{"class":77},[16,440,441],{},"另外如果你希望這個 Model 會連接不同的資料庫也是可以，只需要這樣寫入設定覆蓋原本的就可以了：",[44,443,445],{"className":46,"code":444,"language":48,"meta":49,"style":49},"\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n  protected $connection = [\n    \u002F\u002F 資料庫類型\n    'type' => 'mysql',\n    \u002F\u002F 資料庫 IP\n    'hostname' => '127.0.0.1',\n    \u002F\u002F 資料庫名稱\n    'database' => 'test',\n    \u002F\u002F 使用者名稱\n    'username' => 'root',\n    \u002F\u002F 密碼\n    'password' => '',\n    \u002F\u002F 資料庫端口\n    'hostport' => '',\n    \u002F\u002F 參數\n    'params' => [],\n    \u002F\u002F 編碼\n    'charset' => 'utf8',\n    \u002F\u002F 前缀\n    'prefix' => 'think_',\n    \u002F\u002F Debug 模式\n    'debug' => true,\n    ];\n}\n",[26,446,447,453,461,465,473,477,487,491,503,509,523,529,542,548,561,567,580,586,598,604,616,622,633,639,652,658,671,677,690,696],{"__ignoreMap":49},[53,448,449,451],{"class":55,"line":56},[53,450,60],{"class":59},[53,452,64],{"class":63},[53,454,455,457,459],{"class":55,"line":67},[53,456,70],{"class":59},[53,458,74],{"class":73},[53,460,78],{"class":77},[53,462,463],{"class":55,"line":81},[53,464,85],{"emptyLinePlaceholder":84},[53,466,467,469,471],{"class":55,"line":88},[53,468,91],{"class":59},[53,470,94],{"class":63},[53,472,78],{"class":77},[53,474,475],{"class":55,"line":99},[53,476,85],{"emptyLinePlaceholder":84},[53,478,479,481,483,485],{"class":55,"line":104},[53,480,107],{"class":59},[53,482,110],{"class":73},[53,484,113],{"class":59},[53,486,116],{"class":63},[53,488,489],{"class":55,"line":119},[53,490,122],{"class":77},[53,492,493,495,498,500],{"class":55,"line":125},[53,494,399],{"class":59},[53,496,497],{"class":77}," $connection ",[53,499,324],{"class":59},[53,501,502],{"class":77}," [\n",[53,504,505],{"class":55,"line":412},[53,506,508],{"class":507},"sQrFR","    \u002F\u002F 資料庫類型\n",[53,510,512,515,518,521],{"class":55,"line":511},10,[53,513,514],{"class":259},"    'type'",[53,516,517],{"class":59}," =>",[53,519,520],{"class":259}," 'mysql'",[53,522,263],{"class":77},[53,524,526],{"class":55,"line":525},11,[53,527,528],{"class":507},"    \u002F\u002F 資料庫 IP\n",[53,530,532,535,537,540],{"class":55,"line":531},12,[53,533,534],{"class":259},"    'hostname'",[53,536,517],{"class":59},[53,538,539],{"class":259}," '127.0.0.1'",[53,541,263],{"class":77},[53,543,545],{"class":55,"line":544},13,[53,546,547],{"class":507},"    \u002F\u002F 資料庫名稱\n",[53,549,551,554,556,559],{"class":55,"line":550},14,[53,552,553],{"class":259},"    'database'",[53,555,517],{"class":59},[53,557,558],{"class":259}," 'test'",[53,560,263],{"class":77},[53,562,564],{"class":55,"line":563},15,[53,565,566],{"class":507},"    \u002F\u002F 使用者名稱\n",[53,568,570,573,575,578],{"class":55,"line":569},16,[53,571,572],{"class":259},"    'username'",[53,574,517],{"class":59},[53,576,577],{"class":259}," 'root'",[53,579,263],{"class":77},[53,581,583],{"class":55,"line":582},17,[53,584,585],{"class":507},"    \u002F\u002F 密碼\n",[53,587,589,592,594,596],{"class":55,"line":588},18,[53,590,591],{"class":259},"    'password'",[53,593,517],{"class":59},[53,595,260],{"class":259},[53,597,263],{"class":77},[53,599,601],{"class":55,"line":600},19,[53,602,603],{"class":507},"    \u002F\u002F 資料庫端口\n",[53,605,607,610,612,614],{"class":55,"line":606},20,[53,608,609],{"class":259},"    'hostport'",[53,611,517],{"class":59},[53,613,260],{"class":259},[53,615,263],{"class":77},[53,617,619],{"class":55,"line":618},21,[53,620,621],{"class":507},"    \u002F\u002F 參數\n",[53,623,625,628,630],{"class":55,"line":624},22,[53,626,627],{"class":259},"    'params'",[53,629,517],{"class":59},[53,631,632],{"class":77}," [],\n",[53,634,636],{"class":55,"line":635},23,[53,637,638],{"class":507},"    \u002F\u002F 編碼\n",[53,640,642,645,647,650],{"class":55,"line":641},24,[53,643,644],{"class":259},"    'charset'",[53,646,517],{"class":59},[53,648,649],{"class":259}," 'utf8'",[53,651,263],{"class":77},[53,653,655],{"class":55,"line":654},25,[53,656,657],{"class":507},"    \u002F\u002F 前缀\n",[53,659,661,664,666,669],{"class":55,"line":660},26,[53,662,663],{"class":259},"    'prefix'",[53,665,517],{"class":59},[53,667,668],{"class":259}," 'think_'",[53,670,263],{"class":77},[53,672,674],{"class":55,"line":673},27,[53,675,676],{"class":507},"    \u002F\u002F Debug 模式\n",[53,678,680,683,685,688],{"class":55,"line":679},28,[53,681,682],{"class":259},"    'debug'",[53,684,517],{"class":59},[53,686,687],{"class":63}," true",[53,689,263],{"class":77},[53,691,693],{"class":55,"line":692},29,[53,694,695],{"class":77},"    ];\n",[53,697,699],{"class":55,"line":698},30,[53,700,128],{"class":77},[12,702,703],{"id":703},"結尾",[16,705,706],{},"這邊這樣講下來，其實非常的模糊的，所以後面章節會慢慢在搭配 Controller＋Model 的操作來加深觀念。",[708,709,710],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":49,"searchDepth":67,"depth":67,"links":712},[713,714,715,716,717],{"id":14,"depth":67,"text":14},{"id":21,"depth":67,"text":21},{"id":141,"depth":67,"text":141},{"id":339,"depth":67,"text":339},{"id":703,"depth":67,"text":703},"PHP","2019-09-12 00:03:18","md","zh-Hant",{},"\u002Fthinkphp\u002Fday11-thinkphp-model","2",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay11-從基礎學習-ThinkPHP-Model",[718,176,729,730,731],"ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190912\u002F1469012740\u002F","wLuOB9LRpCyIQmTdIUJYBi73LEbM7znSceYbeBmnfvY",{"newer":736,"older":740},{"url":737,"title":738,"date":739},"\u002Fphp\u002F20190913\u002F1270939931\u002F","Day12-從基礎學習 ThinkPHP-Route","2019-09-13 00:01:52",{"url":741,"title":742,"date":743},"\u002Fphp\u002F20190911\u002F2404668874\u002F","Day10-從基礎學習 ThinkPHP-View","2019-09-11 00:01:36",[745,749,753],{"url":746,"title":747,"date":748,"readingMinutes":724},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41",{"url":750,"title":751,"date":752,"readingMinutes":724},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":754,"title":755,"date":756,"readingMinutes":757},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01","3",1784010307857]