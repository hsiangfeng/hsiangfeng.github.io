[{"data":1,"prerenderedAt":759},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190912\u002F1469012740\u002F":3,"page:\u002Fphp\u002F20190912\u002F1469012740\u002F":4,"alt:\u002Fphp\u002F20190912\u002F1469012740\u002F":3,"prev-next:\u002Fphp\u002F20190912\u002F1469012740\u002F":736,"related:\u002Fphp\u002F20190912\u002F1469012740\u002F":745},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":719,"date":720,"description":18,"extension":721,"lang":722,"meta":723,"navigation":84,"path":724,"readingMinutes":725,"seo":726,"standalone":727,"stem":728,"tags":729,"tldr":733,"updated":733,"url":734,"__hash__":735},"content\u002F從基礎學習 ThinkPHP\u002FDay11-從基礎學習-ThinkPHP-Model.md","Day11-從基礎學習 ThinkPHP-Model","1469012740",{"type":9,"value":10,"toc":712},"minimark",[11,15,19,22,34,40,43,130,137,140,143,146,153,159,173,179,190,193,331,338,341,347,416,422,440,443,702,705,708],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一章節會稍微短一點，主要是介紹基礎的 Model 定義，但是在一般開發下是不太會針對 Model 做太多的設置，所以你會發現這一章節真的比較沒有什麼。",[12,20,21],{"id":21},"起手式",[16,23,24,25,29,30,33],{},"首先 Model 定義的方式很簡單，但是在那之前我們必須先建立 Model 資料夾，因為預設 ThinkPHP 並沒有提供 Model 資料夾，所以我們在 ",[26,27,28],"code",{},"about"," 底下建立一個 ",[26,31,32],{},"model"," 資料夾，並新增一個檔案叫做 about.php ↓",[16,35,36],{},[37,38],"img",{"alt":28,"src":39},"https:\u002F\u002Fi.imgur.com\u002F3isRFXF.png",[16,41,42],{},"那 Model 定義的方式只需要這樣子即可：",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-php shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n}\n","php","",[26,51,52,65,79,86,97,102,118,124],{"__ignoreMap":49},[53,54,57,61],"span",{"class":55,"line":56},"line",1,[53,58,60],{"class":59},"sOudu","\u003C?",[53,62,64],{"class":63},"stw71","php\n",[53,66,68,71,75],{"class":55,"line":67},2,[53,69,70],{"class":59},"namespace",[53,72,74],{"class":73},"smYoP"," app\\about\\model",[53,76,78],{"class":77},"s8XSl",";\n",[53,80,82],{"class":55,"line":81},3,[53,83,85],{"emptyLinePlaceholder":84},true,"\n",[53,87,89,92,95],{"class":55,"line":88},4,[53,90,91],{"class":59},"use",[53,93,94],{"class":63}," think\\Model",[53,96,78],{"class":77},[53,98,100],{"class":55,"line":99},5,[53,101,85],{"emptyLinePlaceholder":84},[53,103,105,108,111,114],{"class":55,"line":104},6,[53,106,107],{"class":59},"class",[53,109,110],{"class":73}," about",[53,112,113],{"class":59}," extends",[53,115,117],{"class":116},"sK3KL"," Model\n",[53,119,121],{"class":55,"line":120},7,[53,122,123],{"class":77},"{\n",[53,125,127],{"class":55,"line":126},8,[53,128,129],{"class":77},"}\n",[16,131,132,133,136],{},"裡面最需要注意的地方只有這一段程式碼 ",[26,134,135],{},"use think\\Model;","，這一段是在告知 ThinkPHP 我們要使用 Model 的核心庫，如果你缺少這一行就會無法正常運行唷。",[16,138,139],{},"好，恭喜你，你已經完成基礎的 Model 定義了(?!)，但是僅僅定義 Model 是不夠的，畢竟 Model 會操控 DB，所以下來我們要來設置資料庫。",[12,141,142],{"id":142},"連接資料庫",[16,144,145],{},"當我們準備好上面動作後，就要來做一下連接資料庫動作，否則 Model 是無法做任何操作 DB 的。",[16,147,148,149,152],{},"資料庫設置的檔案位於 ",[26,150,151],{},"project\u002Fconfig"," 底下的 database.php，只需要將相關欄位填入即可 ↓",[16,154,155],{},[37,156],{"alt":157,"src":158},"database","https:\u002F\u002Fi.imgur.com\u002Fh0HdCM4.png",[16,160,161,162,165,166,165,169,172],{},"基本上只需要填入 ",[26,163,164],{},"hostname","、",[26,167,168],{},"username",[26,170,171],{},"password"," 就可以了，那麼依照我的 MySQL 設置，就會這樣填入 ↓",[16,174,175],{},[37,176],{"alt":177,"src":178},"MySQL","https:\u002F\u002Fi.imgur.com\u002F6UiCius.png",[16,180,181,182,185,186,189],{},"只是有一個地方我有另外填入，也就是 ",[26,183,184],{},"prefix","，因為我建立的資料庫是有前綴的，所以才會填入 ",[26,187,188],{},"think_","。",[16,191,192],{},"接下來我們要先來新增一張資料表(後面章節會使用到)，SQL 指令我就直接給各位囉~",[44,194,198],{"className":195,"code":196,"language":197,"meta":49,"style":49},"language-sql shiki shiki-themes github-light github-light github-dark-high-contrast","CREATE TABLE think_user (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  weight int(5) NOT NULL default 0,\n  height float(5) NOT NULL default 0,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql",[26,199,200,215,238,265,288,310,318],{"__ignoreMap":49},[53,201,202,205,208,212],{"class":55,"line":56},[53,203,204],{"class":59},"CREATE",[53,206,207],{"class":59}," TABLE",[53,209,211],{"class":210},"scAaK"," think_user",[53,213,214],{"class":77}," (\n",[53,216,217,220,223,226,229,232,235],{"class":55,"line":67},[53,218,219],{"class":77},"  id ",[53,221,222],{"class":59},"int",[53,224,225],{"class":77},"(",[53,227,228],{"class":63},"10",[53,230,231],{"class":77},") ",[53,233,234],{"class":59},"NOT NULL",[53,236,237],{"class":77}," auto_increment,\n",[53,239,240,243,246,248,251,253,255,258,262],{"class":55,"line":81},[53,241,242],{"class":59},"  name",[53,244,245],{"class":59}," varchar",[53,247,225],{"class":77},[53,249,250],{"class":63},"5",[53,252,231],{"class":77},[53,254,234],{"class":59},[53,256,257],{"class":59}," default",[53,259,261],{"class":260},"sWayO"," ''",[53,263,264],{"class":77},",\n",[53,266,267,270,273,275,277,279,281,283,286],{"class":55,"line":88},[53,268,269],{"class":59},"  weight",[53,271,272],{"class":59}," int",[53,274,225],{"class":77},[53,276,250],{"class":63},[53,278,231],{"class":77},[53,280,234],{"class":59},[53,282,257],{"class":59},[53,284,285],{"class":63}," 0",[53,287,264],{"class":77},[53,289,290,293,296,298,300,302,304,306,308],{"class":55,"line":99},[53,291,292],{"class":77},"  height ",[53,294,295],{"class":59},"float",[53,297,225],{"class":77},[53,299,250],{"class":63},[53,301,231],{"class":77},[53,303,234],{"class":59},[53,305,257],{"class":59},[53,307,285],{"class":63},[53,309,264],{"class":77},[53,311,312,315],{"class":55,"line":104},[53,313,314],{"class":59},"  PRIMARY KEY",[53,316,317],{"class":77}," (id)\n",[53,319,320,323,326,329],{"class":55,"line":120},[53,321,322],{"class":77},") AUTO_INCREMENT",[53,324,325],{"class":59},"=",[53,327,328],{"class":63},"1",[53,330,78],{"class":77},[16,332,333,334,337],{},"你可以發現我資料表也會加上前綴，而這等一下會幫助我們後面的操作，最主要是因為我在前面設置 database.php 時，有填入 ",[26,335,336],{},"prefix => 'think_'","，那麼資料庫在建立上就都必須加上前綴，否則 ThinkPHP 找不到唷。",[12,339,340],{"id":340},"模型指定資料表",[16,342,343,344,346],{},"接下來由於我在 database.php 有設置資料庫 & 表的前綴 ",[26,345,188],{},"，所以我們接下來再指定資料表的時候必須這樣寫 ↓",[44,348,350],{"className":46,"code":349,"language":48,"meta":49,"style":49},"\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n  protected $table = 'think_user';\n}\n",[26,351,352,358,366,370,378,382,392,396,411],{"__ignoreMap":49},[53,353,354,356],{"class":55,"line":56},[53,355,60],{"class":59},[53,357,64],{"class":63},[53,359,360,362,364],{"class":55,"line":67},[53,361,70],{"class":59},[53,363,74],{"class":73},[53,365,78],{"class":77},[53,367,368],{"class":55,"line":81},[53,369,85],{"emptyLinePlaceholder":84},[53,371,372,374,376],{"class":55,"line":88},[53,373,91],{"class":59},[53,375,94],{"class":63},[53,377,78],{"class":77},[53,379,380],{"class":55,"line":99},[53,381,85],{"emptyLinePlaceholder":84},[53,383,384,386,388,390],{"class":55,"line":104},[53,385,107],{"class":59},[53,387,110],{"class":73},[53,389,113],{"class":59},[53,391,117],{"class":116},[53,393,394],{"class":55,"line":120},[53,395,123],{"class":77},[53,397,398,401,404,406,409],{"class":55,"line":126},[53,399,400],{"class":59},"  protected",[53,402,403],{"class":77}," $table ",[53,405,325],{"class":59},[53,407,408],{"class":260}," 'think_user'",[53,410,78],{"class":77},[53,412,414],{"class":55,"line":413},9,[53,415,129],{"class":77},[16,417,418,419,421],{},"當然你也可以簡寫，ThinkPHP 會幫你帶上 ",[26,420,188],{},"，只是我個人習慣寫完整一點：",[44,423,425],{"className":46,"code":424,"language":48,"meta":49,"style":49},"protected $table = 'think_user';\n",[26,426,427],{"__ignoreMap":49},[53,428,429,432,434,436,438],{"class":55,"line":56},[53,430,431],{"class":59},"protected",[53,433,403],{"class":77},[53,435,325],{"class":59},[53,437,408],{"class":260},[53,439,78],{"class":77},[16,441,442],{},"另外如果你希望這個 Model 會連接不同的資料庫也是可以，只需要這樣寫入設定覆蓋原本的就可以了：",[44,444,446],{"className":46,"code":445,"language":48,"meta":49,"style":49},"\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n  protected $connection = [\n    \u002F\u002F 資料庫類型\n    'type' => 'mysql',\n    \u002F\u002F 資料庫 IP\n    'hostname' => '127.0.0.1',\n    \u002F\u002F 資料庫名稱\n    'database' => 'test',\n    \u002F\u002F 使用者名稱\n    'username' => 'root',\n    \u002F\u002F 密碼\n    'password' => '',\n    \u002F\u002F 資料庫端口\n    'hostport' => '',\n    \u002F\u002F 參數\n    'params' => [],\n    \u002F\u002F 編碼\n    'charset' => 'utf8',\n    \u002F\u002F 前缀\n    'prefix' => 'think_',\n    \u002F\u002F Debug 模式\n    'debug' => true,\n    ];\n}\n",[26,447,448,454,462,466,474,478,488,492,504,510,524,530,543,549,562,568,581,587,599,605,617,623,634,640,653,659,672,678,691,697],{"__ignoreMap":49},[53,449,450,452],{"class":55,"line":56},[53,451,60],{"class":59},[53,453,64],{"class":63},[53,455,456,458,460],{"class":55,"line":67},[53,457,70],{"class":59},[53,459,74],{"class":73},[53,461,78],{"class":77},[53,463,464],{"class":55,"line":81},[53,465,85],{"emptyLinePlaceholder":84},[53,467,468,470,472],{"class":55,"line":88},[53,469,91],{"class":59},[53,471,94],{"class":63},[53,473,78],{"class":77},[53,475,476],{"class":55,"line":99},[53,477,85],{"emptyLinePlaceholder":84},[53,479,480,482,484,486],{"class":55,"line":104},[53,481,107],{"class":59},[53,483,110],{"class":73},[53,485,113],{"class":59},[53,487,117],{"class":116},[53,489,490],{"class":55,"line":120},[53,491,123],{"class":77},[53,493,494,496,499,501],{"class":55,"line":126},[53,495,400],{"class":59},[53,497,498],{"class":77}," $connection ",[53,500,325],{"class":59},[53,502,503],{"class":77}," [\n",[53,505,506],{"class":55,"line":413},[53,507,509],{"class":508},"sGBqm","    \u002F\u002F 資料庫類型\n",[53,511,513,516,519,522],{"class":55,"line":512},10,[53,514,515],{"class":260},"    'type'",[53,517,518],{"class":59}," =>",[53,520,521],{"class":260}," 'mysql'",[53,523,264],{"class":77},[53,525,527],{"class":55,"line":526},11,[53,528,529],{"class":508},"    \u002F\u002F 資料庫 IP\n",[53,531,533,536,538,541],{"class":55,"line":532},12,[53,534,535],{"class":260},"    'hostname'",[53,537,518],{"class":59},[53,539,540],{"class":260}," '127.0.0.1'",[53,542,264],{"class":77},[53,544,546],{"class":55,"line":545},13,[53,547,548],{"class":508},"    \u002F\u002F 資料庫名稱\n",[53,550,552,555,557,560],{"class":55,"line":551},14,[53,553,554],{"class":260},"    'database'",[53,556,518],{"class":59},[53,558,559],{"class":260}," 'test'",[53,561,264],{"class":77},[53,563,565],{"class":55,"line":564},15,[53,566,567],{"class":508},"    \u002F\u002F 使用者名稱\n",[53,569,571,574,576,579],{"class":55,"line":570},16,[53,572,573],{"class":260},"    'username'",[53,575,518],{"class":59},[53,577,578],{"class":260}," 'root'",[53,580,264],{"class":77},[53,582,584],{"class":55,"line":583},17,[53,585,586],{"class":508},"    \u002F\u002F 密碼\n",[53,588,590,593,595,597],{"class":55,"line":589},18,[53,591,592],{"class":260},"    'password'",[53,594,518],{"class":59},[53,596,261],{"class":260},[53,598,264],{"class":77},[53,600,602],{"class":55,"line":601},19,[53,603,604],{"class":508},"    \u002F\u002F 資料庫端口\n",[53,606,608,611,613,615],{"class":55,"line":607},20,[53,609,610],{"class":260},"    'hostport'",[53,612,518],{"class":59},[53,614,261],{"class":260},[53,616,264],{"class":77},[53,618,620],{"class":55,"line":619},21,[53,621,622],{"class":508},"    \u002F\u002F 參數\n",[53,624,626,629,631],{"class":55,"line":625},22,[53,627,628],{"class":260},"    'params'",[53,630,518],{"class":59},[53,632,633],{"class":77}," [],\n",[53,635,637],{"class":55,"line":636},23,[53,638,639],{"class":508},"    \u002F\u002F 編碼\n",[53,641,643,646,648,651],{"class":55,"line":642},24,[53,644,645],{"class":260},"    'charset'",[53,647,518],{"class":59},[53,649,650],{"class":260}," 'utf8'",[53,652,264],{"class":77},[53,654,656],{"class":55,"line":655},25,[53,657,658],{"class":508},"    \u002F\u002F 前缀\n",[53,660,662,665,667,670],{"class":55,"line":661},26,[53,663,664],{"class":260},"    'prefix'",[53,666,518],{"class":59},[53,668,669],{"class":260}," 'think_'",[53,671,264],{"class":77},[53,673,675],{"class":55,"line":674},27,[53,676,677],{"class":508},"    \u002F\u002F Debug 模式\n",[53,679,681,684,686,689],{"class":55,"line":680},28,[53,682,683],{"class":260},"    'debug'",[53,685,518],{"class":59},[53,687,688],{"class":63}," true",[53,690,264],{"class":77},[53,692,694],{"class":55,"line":693},29,[53,695,696],{"class":77},"    ];\n",[53,698,700],{"class":55,"line":699},30,[53,701,129],{"class":77},[12,703,704],{"id":704},"結尾",[16,706,707],{},"這邊這樣講下來，其實非常的模糊的，所以後面章節會慢慢在搭配 Controller＋Model 的操作來加深觀念。",[709,710,711],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .sK3KL, html code.shiki .sK3KL{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#91CBFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-defa