[{"data":1,"prerenderedAt":173},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20191002\u002F3041589016\u002F":3,"page:\u002Fphp\u002F20191002\u002F3041589016\u002F":4,"alt:\u002Fphp\u002F20191002\u002F3041589016\u002F":3,"prev-next:\u002Fphp\u002F20191002\u002F3041589016\u002F":149,"related:\u002Fphp\u002F20191002\u002F3041589016\u002F":158},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":130,"date":131,"description":132,"extension":133,"lang":134,"meta":135,"navigation":136,"path":137,"readingMinutes":138,"seo":139,"standalone":140,"stem":141,"tags":142,"tldr":146,"updated":146,"url":147,"__hash__":148},"content\u002F從基礎學習 ThinkPHP\u002FDay31-從基礎學習-ThinkPHP-結束只是另一個開始.md","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","3041589016",{"type":9,"value":10,"toc":122},"minimark",[11,15,19,22,29,32,40,56,60,63,66,69,72,75,82,89,96,103,110,113],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最後我選在第 31 天來當作結尾，所以這一篇主要是寫參賽結尾的感言~",[12,20,21],{"id":21},"結束只是另一個開始",[16,23,24],{},[25,26],"img",{"alt":27,"src":28},"圖源 unsplash","https:\u002F\u002Fi.imgur.com\u002FK3EVpYk.png",[16,30,31],{},"這次是我第一次參加鐵人賽，過程其實我一直很擔心自己無法完賽，畢竟我真的滿金魚腦的，深怕一個不小心就超時忘記發文 QQ",[16,33,34,35,39],{},"而且這過程我個人也滿害怕自己寫出來的文章質量太低甚至 ",[36,37,38],"del",{},"太糞","，也怕觀念不正確之類的問題，但是我想一想覺得如果一直害怕這些問題而導致後悔沒參加鐵人賽，那之後我應該會非常後悔，所以我還是嘗試挑戰看看。",[16,41,42,43,47,48,55],{},"雖然 ",[44,45,46],"span",{},"從基礎學習 ThinkPHP"," 這個系列結束了，但是並不代表學習就到此結束，畢竟資訊是永無止境的，所以我還有另一個鐵人賽主題還在跑，也就是 ",[49,50,54],"a",{"href":51,"rel":52},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F2679",[53],"nofollow","RE：從零開始的學習 JS 生活","，接下來我就可以專心在一個主題上了~",[12,57,59],{"id":58},"選擇-thinkphp-原因","選擇 ThinkPHP 原因",[16,61,62],{},"在我決定拿這個框架來參加活動時，有些人就有問我 「為什麼不選擇 Laravel 或是 Yii 而是選擇一個比較少見的 ThinkPHP?」，其實我個人認為不論是框架還是程式語言好壞並沒有一定，重點是要能夠解決問題，只要能解決問題都是好語言好框架。",[16,64,65],{},"當然另一個原因是因為自己曾經使用過 ThinkPHP，那時候就覺得還滿方便的，頗適合新手初步學習一個框架進而培養語感，安裝過程也不會很複雜，但是當時我所撰寫的版本較舊是 ThinkPHP 3.2.4，所以我才在這一次鐵人賽挑戰寫 ThinkPHP 5.1。",[16,67,68],{},"我撰寫這系列文章時，ThinkPHP 6.0 其實也發布約三個月左右，但是我個人覺得一個新東西出來至少要歷經大約半年的時間才能夠確保穩定性更不用說 ThinkPHP 6.0 與 ThinkPHP 5.1 架構又不一樣，所以我才會選擇撰寫穩定性較高的 ThinkPHP 5.1。",[12,70,71],{"id":71},"其他系列文章",[16,73,74],{},"最後我自己本身有寫過其他系列的文章，我是在 2019\u002F04\u002F11 建立我的技術部落格 (是 Ray 不是 Array)，這段期間我撰寫了滿多文章，舉凡 Gulp、Express、Webpack 以及 Koa.js，一開始我架設技術部落格的初衷只是單純要做筆記給自己看，後來因為身邊朋友希望我可以教他們如何學習一些技術，所以就乾脆將自己技術文章寫成了一個系列順便替自己回顧，所以這邊我也提供我的這些系列文章給各位參考，當然可能描述與說明上可能並不 ok，畢竟我也在努力學習(滿身菜味 XD",[16,76,77,81],{},[49,78,80],{"href":79},"\u002Ftags\u002F%E9%80%99%E6%98%AF%E5%9C%A8%E8%AC%9B-Gulp-%E4%B8%8D%E6%98%AF%E9%A3%B2%E6%96%99%E6%98%AF%E4%BB%BB%E5%8B%99%E8%87%AA%E5%8B%95%E5%8C%96%E5%B7%A5%E5%85%B7%E9%80%99%E4%BB%B6%E4%BA%8B\u002F","這是在講 Gulp 不是飲料是任務自動化工具這件事"," → 基於 Gulp 4 所撰寫的系列",[16,83,84,88],{},[49,85,87],{"href":86},"\u002Ftags\u002F%E5%85%A8%E7%AB%AF%E5%8B%87%E5%A3%AB%E4%B9%8B%E8%B7%AF-Node-js\u002F","全端勇士之路 Node.js"," → 將會結合 firebase 建立一個簡易會員系統",[16,90,91,95],{},[49,92,94],{"href":93},"\u002Ftags\u002F%E9%97%9C%E6%96%BC-Webpack-%E5%AD%B8%E7%BF%92%E9%80%99%E4%BB%B6%E5%B0%8F%E4%BA%8B\u002F","關於 Webpack 學習這件小事"," → 學習基礎的 webpack",[16,97,98,102],{},[49,99,101],{"href":100},"\u002Ftags\u002F%E9%80%99%E6%98%AF%E5%9C%A8%E8%AC%9B%E9%97%9C%E6%96%BC%E4%B8%80%E5%90%8D%E5%8F%AB-Koa-%E7%9A%84%E5%85%A8%E7%AB%AF%E5%8B%87%E5%A3%AB%E5%82%B3%E8%AA%AA\u002F","這是在講關於一名叫 Koa 的全端勇士傳說"," → 將會使用 sequelize 來連接 MySQL 製作一個簡易會員系統",[16,104,105,109],{},[49,106,108],{"href":107},"\u002Fcategories\u002Flearnexp\u002F","學習經驗"," → 這個系列裡面都是我學習過程中遇到的一些經驗分享",[16,111,112],{},"未來我應該還會規畫撰寫 Nuxt.js 的系列文章，畢竟前陣子接觸了 Nuxt.js，之後會嘗試在撰寫一個系列看看。",[16,114,115,116],{},"好的",[36,117,118,119,121],{},"那麼就到 ",[44,120,54],{}," 系列見囉",{"title":123,"searchDepth":124,"depth":124,"links":125},"",2,[126,127,128,129],{"id":14,"depth":124,"text":14},{"id":21,"depth":124,"text":21},{"id":58,"depth":124,"text":59},{"id":71,"depth":124,"text":71},"PHP","2019-10-02 00:00:02","最後我選在第 31 天來當作結尾的宣告，所以這一篇主要是寫參賽結尾的感言~","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday31-thinkphp","2",{"title":6,"description":132},false,"從基礎學習 ThinkPHP\u002FDay31-從基礎學習-ThinkPHP-結束只是另一個開始",[130,143,144,46,145],"MySQL","ThinkPHP 5.1","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20191002\u002F3041589016\u002F","ndvba_L_BcrTeffPxk4n1nyOhM6o7cdHF9BZQZCeRNI",{"newer":150,"older":154},{"url":151,"title":152,"date":153},"\u002Fjavascript\u002F20191003\u002F3790268908\u002F","EP.18 RE：從零開始的學習 JS 生活-第十八日之 localStorage","2019-10-03 00:00:01",{"url":155,"title":156,"date":157},"\u002Fjavascript\u002F20191002\u002F3941110344\u002F","EP.17 RE：從零開始的學習 JS 生活-第十七日之 Cookie","2019-10-02 00:00:01",[159,163,168],{"url":160,"title":161,"date":162,"readingMinutes":138},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41",{"url":164,"title":165,"date":166,"readingMinutes":167},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01","3",{"url":169,"title":170,"date":171,"readingMinutes":172},"\u002Fphp\u002F20190930\u002F81339708\u002F","Day29-從基礎學習 ThinkPHP-ThinkPHP 指令","2019-09-30 00:00:02","4",1784012807559]