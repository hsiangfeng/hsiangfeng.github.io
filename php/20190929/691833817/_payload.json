[{"data":1,"prerenderedAt":1286},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190929\u002F691833817\u002F":3,"page:\u002Fphp\u002F20190929\u002F691833817\u002F":4,"alt:\u002Fphp\u002F20190929\u002F691833817\u002F":3,"prev-next:\u002Fphp\u002F20190929\u002F691833817\u002F":1263,"related:\u002Fphp\u002F20190929\u002F691833817\u002F":1272},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1244,"date":1245,"description":18,"extension":1246,"lang":1247,"meta":1248,"navigation":1249,"path":1250,"readingMinutes":1251,"seo":1252,"standalone":1253,"stem":1254,"tags":1255,"tldr":1260,"updated":1260,"url":1261,"__hash__":1262},"content\u002F從基礎學習 ThinkPHP\u002FDay28-從基礎學習-ThinkPHP-製作一個留言版.md","Day28-從基礎學習 ThinkPHP-製作一個留言版","691833817",{"type":9,"value":10,"toc":1225},"minimark",[11,15,19,22,25,29,39,43,54,58,66,69,77,91,94,269,272,275,292,295,459,462,476,479,486,489,492,631,634,647,653,656,659,662,667,670,1001,1004,1007,1010,1014,1029,1032,1042,1045,1121,1124,1167,1170,1181,1185,1192,1198,1209,1215,1218,1221],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"基礎的 ThinkPHP 框架也學習差不多，這一篇將會稍微講一下製作一個留言版的部分，但是並不會講程式碼，這一篇重點在於留言版規劃，因為基本上都是結合前面所學的技巧而已，所以最後會附上 GitHub 當作參考唷。",[12,20,21],{"id":21},"留言版功能",[16,23,24],{},"首先先讓我們來規劃一下留言版可能會需要那些功能：",[26,27,28],"h3",{"id":28},"會員系統",[30,31,32,36],"ul",{},[33,34,35],"li",{},"註冊會員",[33,37,38],{},"登入會員",[26,40,42],{"id":41},"留言版-需登入","留言版 (需登入)",[30,44,45,48,51],{},[33,46,47],{},"新增留言",[33,49,50],{},"刪除留言",[33,52,53],{},"編輯留言",[26,55,57],{"id":56},"留言版-無需登入","留言版 (無需登入)",[30,59,60,63],{},[33,61,62],{},"首頁",[33,64,65],{},"觀看留言",[12,67,68],{"id":68},"會員",[16,70,71,72,76],{},"這邊我們將會直接沿用前面章節所建立的資料庫，也就是 ",[73,74,75],"code",{},"it_think_sql"," 並在底下建立一張會員資料表，會員部份會建立一個資料表專門儲存會員的資料，最主要的欄位有以下：",[30,78,79,82,85,88],{},[33,80,81],{},"帳號(採用信箱登入)",[33,83,84],{},"密碼",[33,86,87],{},"姓名",[33,89,90],{},"暱稱",[16,92,93],{},"所以我們可以依照此規劃來寫出 SQL 指令建立會員資料表：",[95,96,101],"pre",{"className":97,"code":98,"language":99,"meta":100,"style":100},"language-sql shiki shiki-themes github-light github-light github-dark-high-contrast","CREATE TABLE think_new_user (\n  id int(10) NOT NULL auto_increment,\n  email varchar(15) NOT NULL default '',\n  password varchar(32) NOT NULL default '',\n  name varchar(6) NOT NULL default '',\n  nikename varchar(6) NOT NULL default '',\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql","",[73,102,103,123,148,176,200,223,245,254],{"__ignoreMap":100},[104,105,108,112,115,119],"span",{"class":106,"line":107},"line",1,[104,109,111],{"class":110},"sOudu","CREATE",[104,113,114],{"class":110}," TABLE",[104,116,118],{"class":117},"scAaK"," think_new_user",[104,120,122],{"class":121},"s8XSl"," (\n",[104,124,126,129,132,135,139,142,145],{"class":106,"line":125},2,[104,127,128],{"class":121},"  id ",[104,130,131],{"class":110},"int",[104,133,134],{"class":121},"(",[104,136,138],{"class":137},"stw71","10",[104,140,141],{"class":121},") ",[104,143,144],{"class":110},"NOT NULL",[104,146,147],{"class":121}," auto_increment,\n",[104,149,151,154,157,159,162,164,166,169,173],{"class":106,"line":150},3,[104,152,153],{"class":121},"  email ",[104,155,156],{"class":110},"varchar",[104,158,134],{"class":121},[104,160,161],{"class":137},"15",[104,163,141],{"class":121},[104,165,144],{"class":110},[104,167,168],{"class":110}," default",[104,170,172],{"class":171},"sWayO"," ''",[104,174,175],{"class":121},",\n",[104,177,179,182,185,187,190,192,194,196,198],{"class":106,"line":178},4,[104,180,181],{"class":110},"  password",[104,183,184],{"class":110}," varchar",[104,186,134],{"class":121},[104,188,189],{"class":137},"32",[104,191,141],{"class":121},[104,193,144],{"class":110},[104,195,168],{"class":110},[104,197,172],{"class":171},[104,199,175],{"class":121},[104,201,203,206,208,210,213,215,217,219,221],{"class":106,"line":202},5,[104,204,205],{"class":110},"  name",[104,207,184],{"class":110},[104,209,134],{"class":121},[104,211,212],{"class":137},"6",[104,214,141],{"class":121},[104,216,144],{"class":110},[104,218,168],{"class":110},[104,220,172],{"class":171},[104,222,175],{"class":121},[104,224,226,229,231,233,235,237,239,241,243],{"class":106,"line":225},6,[104,227,228],{"class":121},"  nikename ",[104,230,156],{"class":110},[104,232,134],{"class":121},[104,234,212],{"class":137},[104,236,141],{"class":121},[104,238,144],{"class":110},[104,240,168],{"class":110},[104,242,172],{"class":171},[104,244,175],{"class":121},[104,246,248,251],{"class":106,"line":247},7,[104,249,250],{"class":110},"  PRIMARY KEY",[104,252,253],{"class":121}," (id)\n",[104,255,257,260,263,266],{"class":106,"line":256},8,[104,258,259],{"class":121},") AUTO_INCREMENT",[104,261,262],{"class":110},"=",[104,264,265],{"class":137},"1",[104,267,268],{"class":121},";\n",[12,270,271],{"id":271},"留言版",[16,273,274],{},"接下來建立留言版的資料表，基本上我們常見的留言板會有留言標題、內容以及作者，所以留言板最主要的欄位會有以下：",[30,276,277,280,283,286,289],{},[33,278,279],{},"標題",[33,281,282],{},"內容",[33,284,285],{},"作者",[33,287,288],{},"發布時間",[33,290,291],{},"最後修改時間",[16,293,294],{},"那麼我們就可以參考以上規劃撰寫出 SQL 指令：",[95,296,298],{"className":97,"code":297,"language":99,"meta":100,"style":100},"CREATE TABLE think_message (\n  id int(10) NOT NULL auto_increment,\n  title varchar(15) NOT NULL default '',\n  content text NOT NULL default '',\n  author varchar(6) NOT NULL default '',\n  email varchar(6) NOT NULL default '',\n  create_time timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n  last_modify_time timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n",[73,299,300,311,327,348,365,386,406,422,441,448],{"__ignoreMap":100},[104,301,302,304,306,309],{"class":106,"line":107},[104,303,111],{"class":110},[104,305,114],{"class":110},[104,307,308],{"class":117}," think_message",[104,310,122],{"class":121},[104,312,313,315,317,319,321,323,325],{"class":106,"line":125},[104,314,128],{"class":121},[104,316,131],{"class":110},[104,318,134],{"class":121},[104,320,138],{"class":137},[104,322,141],{"class":121},[104,324,144],{"class":110},[104,326,147],{"class":121},[104,328,329,332,334,336,338,340,342,344,346],{"class":106,"line":150},[104,330,331],{"class":121},"  title ",[104,333,156],{"class":110},[104,335,134],{"class":121},[104,337,161],{"class":137},[104,339,141],{"class":121},[104,341,144],{"class":110},[104,343,168],{"class":110},[104,345,172],{"class":171},[104,347,175],{"class":121},[104,349,350,353,356,359,361,363],{"class":106,"line":178},[104,351,352],{"class":121},"  content ",[104,354,355],{"class":110},"text",[104,357,358],{"class":110}," NOT NULL",[104,360,168],{"class":110},[104,362,172],{"class":171},[104,364,175],{"class":121},[104,366,367,370,372,374,376,378,380,382,384],{"class":106,"line":202},[104,368,369],{"class":121},"  author ",[104,371,156],{"class":110},[104,373,134],{"class":121},[104,375,212],{"class":137},[104,377,141],{"class":121},[104,379,144],{"class":110},[104,381,168],{"class":110},[104,383,172],{"class":171},[104,385,175],{"class":121},[104,387,388,390,392,394,396,398,400,402,404],{"class":106,"line":225},[104,389,153],{"class":121},[104,391,156],{"class":110},[104,393,134],{"class":121},[104,395,212],{"class":137},[104,397,141],{"class":121},[104,399,144],{"class":110},[104,401,168],{"class":110},[104,403,172],{"class":171},[104,405,175],{"class":121},[104,407,408,411,414,416,419],{"class":106,"line":247},[104,409,410],{"class":121},"  create_time ",[104,412,413],{"class":110},"timestamp",[104,415,358],{"class":110},[104,417,418],{"class":110}," DEFAULT",[104,420,421],{"class":121}," CURRENT_TIMESTAMP,\n",[104,423,424,427,429,431,433,436,439],{"class":106,"line":256},[104,425,426],{"class":121},"  last_modify_time ",[104,428,413],{"class":110},[104,430,358],{"class":110},[104,432,418],{"class":110},[104,434,435],{"class":121}," CURRENT_TIMESTAMP ",[104,437,438],{"class":110},"ON UPDATE",[104,440,421],{"class":121},[104,442,444,446],{"class":106,"line":443},9,[104,445,250],{"class":110},[104,447,253],{"class":121},[104,449,451,453,455,457],{"class":106,"line":450},10,[104,452,259],{"class":121},[104,454,262],{"class":110},[104,456,265],{"class":137},[104,458,268],{"class":121},[16,460,461],{},"至於上面有兩個很陌生的東西，那兩個東西是關於時間的部分，我補充一下這兩個寫法的用途：",[30,463,464,470],{},[33,465,466,469],{},[73,467,468],{},"CURRENT_TIMESTAMP"," - 會自動新增時間",[33,471,472,475],{},[73,473,474],{},"UPDATE CURRENT_TIMESTAMP"," - 資料若更新後會自動更新",[16,477,478],{},"效果就會像這樣 ↓",[16,480,481],{},[482,483],"img",{"alt":484,"src":485},"自動更新","https:\u002F\u002Fi.imgur.com\u002FBXTMEIs.png",[12,487,488],{"id":488},"路由規劃",[16,490,491],{},"接下來我們可以先規畫路由的部分，主要會有以下這幾隻：",[493,494,495,511],"table",{},[496,497,498],"thead",{},[499,500,501,505,508],"tr",{},[502,503,504],"th",{},"功能",[502,506,507],{},"路由",[502,509,510],{},"方法",[512,513,514,526,536,547,556,566,576,586,594,604,614,622],"tbody",{},[499,515,516,520,523],{},[517,518,519],"td",{},"登入畫面",[517,521,522],{},"\u002Fmessage\u002Fuser\u002Flogin",[517,524,525],{},"GET",[499,527,528,531,534],{},[517,529,530],{},"註冊畫面",[517,532,533],{},"\u002Fmessage\u002Fuser\u002Fsignup",[517,535,525],{},[499,537,538,541,544],{},[517,539,540],{},"會員註冊",[517,542,543],{},"\u002Fmessage\u002Fuser\u002Fcreate",[517,545,546],{},"POST",[499,548,549,552,554],{},[517,550,551],{},"會員登入",[517,553,522],{},[517,555,546],{},[499,557,558,561,564],{},[517,559,560],{},"會員登出",[517,562,563],{},"\u002Fmessage\u002Fuser\u002Fsignout",[517,565,546],{},[499,567,568,571,574],{},[517,569,570],{},"留言版首頁",[517,572,573],{},"\u002Fmessage\u002Findex",[517,575,525],{},[499,577,578,581,584],{},[517,579,580],{},"新增留言畫面",[517,582,583],{},"\u002Fmessage\u002Fcreate",[517,585,525],{},[499,587,588,590,592],{},[517,589,47],{},[517,591,583],{},[517,593,546],{},[499,595,596,599,602],{},[517,597,598],{},"查看留言",[517,600,601],{},"\u002Fmessage\u002Fcontent\u002F:id",[517,603,525],{},[499,605,606,609,612],{},[517,607,608],{},"顯示編輯留言",[517,610,611],{},"\u002Fmessage\u002Fedit\u002F:id",[517,613,525],{},[499,615,616,618,620],{},[517,617,53],{},[517,619,611],{},[517,621,546],{},[499,623,624,626,629],{},[517,625,50],{},[517,627,628],{},"\u002Fmessage\u002Fdelete\u002F:id",[517,630,546],{},[12,632,633],{"id":633},"application",[16,635,636,637,639,640,643,644,646],{},"接下來我們還會建立一個 message 資料夾在 ",[73,638,633],{}," 底下，這邊我們來嘗試使用新的玩意，也就是使用指令生成 Controller，打開 CMD 移動到專案目錄試著輸入 ",[73,641,642],{},"php think make:controller message\u002FIndex","，此時你應該會發現 ",[73,645,633],{}," 底下建立好了 ↓",[16,648,649],{},[482,650],{"alt":651,"src":652},"生成控制器","https:\u002F\u002Fi.imgur.com\u002Fr4G0YOu.png",[16,654,655],{},"當然你想手動建立也可以，避免出現一推預設程式碼。",[12,657,658],{"id":658},"檔案結構",[16,660,661],{},"所以留言版的檔案結構大概會變成這樣 ↓",[16,663,664],{},[482,665],{"alt":658,"src":666},"https:\u002F\u002Fi.imgur.com\u002F6uI4x1q.png",[16,668,669],{},"內容部分我就不提供了，因為太多了，而且基本上因為與前面章節大同小異，只是組合技巧而已，除了路由部分這邊我會提供：",[95,671,675],{"className":672,"code":673,"language":674,"meta":100,"style":100},"language-php shiki shiki-themes github-light github-light github-dark-high-contrast","\u002F\u002F 留言板功能\n\u002F\u002F 會員相關\n\u002F\u002F 登入畫面\nRoute::get('\u002Fmessage\u002Fuser\u002Flogin', 'message\u002Fuser\u002Findex');\n\u002F\u002F 註冊畫面\nRoute::get('\u002Fmessage\u002Fuser\u002Fsignup', 'message\u002Fuser\u002Fsignup');\n\u002F\u002F 會員註冊\nRoute::post('\u002Fmessage\u002Fuser\u002Fcreate', 'message\u002Fuser\u002Fsave');\n\u002F\u002F 會員登入\nRoute::get('\u002Fmessage\u002Fuser\u002Flogin', 'message\u002Fuser\u002Flogin');\n\u002F\u002F 會員登出\nRoute::get('\u002Fmessage\u002Fuser\u002Fsignout', 'message\u002Fuser\u002Fsignout');\n\u002F\u002F 留言版相關\n\u002F\u002F 留言版首頁\nRoute::get('\u002Fmessage\u002Findex', 'message\u002Findex\u002Findex');\n\u002F\u002F 新增留言\nRoute::get('\u002Fmessage\u002Fcreate', 'message\u002Findex\u002Fcreate');\nRoute::post('\u002Fmessage\u002Fcreate', 'message\u002Findex\u002Fsave');\n\u002F\u002F 查看留言\nRoute::get('\u002Fmessage\u002Fcontent\u002F:id', 'message\u002Findex\u002Fpost')