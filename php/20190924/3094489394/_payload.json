,{"class":38,"line":166},[36,542,543],{"class":103},"  'gender.require'",[36,545,406],{"class":42},[36,547,548],{"class":103}," '性別必填'",[36,550,107],{"class":53},[36,552,553,555,557],{"class":38,"line":313},[36,554,436],{"class":103},[36,556,406],{"class":42},[36,558,559],{"class":103}," '性別必須為是數字'\n",[36,561,562],{"class":38,"line":319},[36,563,452],{"class":53},[16,565,566],{},"這樣我們就將表單驗證給完成了。",[12,568,569],{"id":569},"控制器",[16,571,572,573,576],{},"接下來要來修改控制器，首先我們會將表單接收的方法寫到 ",[33,574,575],{},"add()"," 方法內，然後會回傳我們剛剛發送的資料：",[26,578,580],{"className":215,"code":579,"language":217,"meta":31,"style":31},"public function add($email, $password, $gender) {\n    return $email. $password. $gender;\n}\n",[33,581,582,596,615],{"__ignoreMap":31},[36,583,584,587,590,593],{"class":38,"line":39},[36,585,586],{"class":42},"public",[36,588,589],{"class":42}," function",[36,591,592],{"class":49}," add",[36,594,595],{"class":53},"($email, $password, $gender) {\n",[36,597,598,601,604,607,610,612],{"class":38,"line":57},[36,599,600],{"class":42},"    return",[36,602,603],{"class":53}," $email",[36,605,606],{"class":42},".",[36,608,609],{"class":53}," $password",[36,611,606],{"class":42},[36,613,614],{"class":53}," $gender;\n",[36,616,617],{"class":38,"line":82},[36,618,348],{"class":53},[16,620,621,622,625],{},"那麼該如何使用表單驗證呢?只需要加上一段 ",[33,623,624],{},"validate('資料','驗證器名稱')"," 即可搞定，這邊我順便接上資料庫，這樣才能夠看出真實性：",[26,627,629],{"className":215,"code":628,"language":217,"meta":31,"style":31},"public function add($email, $password, $gender) {\n  $user = new userModel;\n  $user->email = $email;\n  $user->password = $password;\n  $user->gender = $gender;\n  $result = $this->validate($user,'User');\n  if($result){\n  return $result;\n  }\n  if($user->save()){\n      return '新增成功';\n  } else {\n      return $user->getError();\n  }\n}\n",[33,630,631,641,656,672,686,699,722,730,738,743,758,768,780,796,801],{"__ignoreMap":31},[36,632,633,635,637,639],{"class":38,"line":39},[36,634,586],{"class":42},[36,