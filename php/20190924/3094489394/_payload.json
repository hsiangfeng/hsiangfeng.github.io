[{"data":1,"prerenderedAt":1367},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190924\u002F3094489394\u002F":3,"page:\u002Fphp\u002F20190924\u002F3094489394\u002F":4,"alt:\u002Fphp\u002F20190924\u002F3094489394\u002F":3,"prev-next:\u002Fphp\u002F20190924\u002F3094489394\u002F":1345,"related:\u002Fphp\u002F20190924\u002F3094489394\u002F":1354},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F24\u002Fthink-php-day-23-form-validation-01\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1327,"date":1328,"description":18,"extension":1329,"lang":1330,"meta":1331,"navigation":267,"path":1332,"readingMinutes":1333,"seo":1334,"standalone":1335,"stem":1336,"tags":1337,"tldr":1342,"updated":1342,"url":1343,"__hash__":1344},"content\u002F從基礎學習 ThinkPHP\u002FDay23-從基礎學習-ThinkPHP-表單驗證-1.md","Day23-從基礎學習 ThinkPHP-表單驗證(1)","3094489394",{"type":9,"value":10,"toc":1320},"minimark",[11,15,19,22,25,179,182,189,192,198,204,207,210,213,230,237,243,250,348,381,452,459,462,563,566,569,576,618,625,805,808,813,816,968,979,1014,1020,1026,1150,1161,1301,1307,1310,1313,1316],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"當我們送出一些表單的時候，都會有一些表單驗證的機制，那 ThinkPHP 呢?ThinkPHP 本身也有表單驗證功能，所以這一篇就會來介紹該如何使用 ThinkPHP 內建的表單驗證機制。",[12,20,21],{"id":21},"起手式",[16,23,24],{},"首先為了讓表單驗證可以看出所以然，所以這邊起頭要來建立一個新的資料表，專門存放帳號，SQL 語法就提供給各位：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_account (\n  id int(10) NOT NULL auto_increment,\n  email varchar(15) NOT NULL default '',\n  password varchar(10) NOT NULL default 0,\n  gender int(2) NOT NULL default 0,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql","",[33,34,35,55,80,108,132,155,164],"code",{"__ignoreMap":31},[36,37,40,44,47,51],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sWyjQ","CREATE",[36,45,46],{"class":42}," TABLE",[36,48,50],{"class":49},"sj_SG"," think_account",[36,52,54],{"class":53},"sMAXC"," (\n",[36,56,58,61,64,67,71,74,77],{"class":38,"line":57},2,[36,59,60],{"class":53},"  id ",[36,62,63],{"class":42},"int",[36,65,66],{"class":53},"(",[36,68,70],{"class":69},"sCcAr","10",[36,72,73],{"class":53},") ",[36,75,76],{"class":42},"NOT NULL",[36,78,79],{"class":53}," auto_increment,\n",[36,81,83,86,89,91,94,96,98,101,105],{"class":38,"line":82},3,[36,84,85],{"class":53},"  email ",[36,87,88],{"class":42},"varchar",[36,90,66],{"class":53},[36,92,93],{"class":69},"15",[36,95,73],{"class":53},[36,97,76],{"class":42},[36,99,100],{"class":42}," default",[36,102,104],{"class":103},"sTRMh"," ''",[36,106,107],{"class":53},",\n",[36,109,111,114,117,119,121,123,125,127,130],{"class":38,"line":110},4,[36,112,113],{"class":42},"  password",[36,115,116],{"class":42}," varchar",[36,118,66],{"class":53},[36,120,70],{"class":69},[36,122,73],{"class":53},[36,124,76],{"class":42},[36,126,100],{"class":42},[36,128,129],{"class":69}," 0",[36,131,107],{"class":53},[36,133,135,138,140,142,145,147,149,151,153],{"class":38,"line":134},5,[36,136,137],{"class":53},"  gender ",[36,139,63],{"class":42},[36,141,66],{"class":53},[36,143,144],{"class":69},"2",[36,146,73],{"class":53},[36,148,76],{"class":42},[36,150,100],{"class":42},[36,152,129],{"class":69},[36,154,107],{"class":53},[36,156,158,161],{"class":38,"line":157},6,[36,159,160],{"class":42},"  PRIMARY KEY",[36,162,163],{"class":53}," (id)\n",[36,165,167,170,173,176],{"class":38,"line":166},7,[36,168,169],{"class":53},") AUTO_INCREMENT",[36,171,172],{"class":42},"=",[36,174,175],{"class":69},"1",[36,177,178],{"class":53},";\n",[16,180,181],{},"然後接下來建立 user 資料夾，並於 view 底下建立兩個頁面，分別為註冊頁面 (signup.html) 與登入頁面 (signin.html)，內容我就不再額外提供 ↓",[16,183,184],{},[185,186],"img",{"alt":187,"src":188},"註冊&登入頁面","https:\u002F\u002Fi.imgur.com\u002FotFAGCe.png",[16,190,191],{},"那麼畫面就會像這樣子 ↓",[16,193,194],{},[185,195],{"alt":196,"src":197},"註冊頁面","https:\u002F\u002Fi.imgur.com\u002Fhf9tjri.png",[16,199,200],{},[185,201],{"alt":202,"src":203},"登入頁面","https:\u002F\u002Fi.imgur.com\u002F4bZYjfk.png",[16,205,206],{},"路由與控制器部分我也不再額外提供，因為這部分撰寫很多次了。",[12,208,209],{"id":209},"表單驗證",[16,211,212],{},"首先 ThinkPHP 本身就有提供表單驗證的功能，只需要引入該函式庫就可以了：",[26,214,218],{"className":215,"code":216,"language":217,"meta":31,"style":31},"language-php shiki shiki-themes github-dark-high-contrast","use think\\Validate;\n","php",[33,219,220],{"__ignoreMap":31},[36,221,222,225,228],{"class":38,"line":39},[36,223,224],{"class":42},"use",[36,226,227],{"class":69}," think\\Validate",[36,229,178],{"class":53},[16,231,232,233,236],{},"但是 ThinkPHP 在這邊的做法稍微有點不太一樣，它會需要建立一個資料夾放置驗證用的原始碼，所以就要這樣建立 ",[33,234,235],{},"user\u002Fvalidate\u002Fuser.php"," ↓",[16,238,239],{},[185,240],{"alt":241,"src":242},"validate","https:\u002F\u002Fi.imgur.com\u002FndDkxUg.png",[16,244,245,246,249],{},"那麼 ",[33,247,248],{},"user.php"," 這個檔案內容如下：",[26,251,253],{"className":215,"code":252,"language":217,"meta":31,"style":31},"\u003C?php\n\nnamespace app\\user\\validate;\n\nuse think\\Validate;\n\nclass user extends Validate\n{\n  protected $rule = [];\n  protected $message = [];\n}\n",[33,254,255,263,269,280,284,292,296,310,316,330,342],{"__ignoreMap":31},[36,256,257,260],{"class":38,"line":39},[36,258,259],{"class":42},"\u003C?",[36,261,262],{"class":69},"php\n",[36,264,265],{"class":38,"line":57},[36,266,268],{"emptyLinePlaceholder":267},true,"\n",[36,270,271,274,278],{"class":38,"line":82},[36,272,273],{"class":42},"namespace",[36,275,277],{"class":276},"s_sBn"," app\\user\\validate",[36,279,178],{"class":53},[36,281,282],{"class":38,"line":110},[36,283,268],{"emptyLinePlaceholder":267},[36,285,286,288,290],{"class":38,"line":134},[36,287,224],{"class":42},[36,289,227],{"class":69},[36,291,178],{"class":53},[36,293,294],{"class":38,"line":157},[36,295,268],{"emptyLinePlaceholder":267},[36,297,298,301,304,307],{"class":38,"line":166},[36,299,300],{"class":42},"class",[36,302,303],{"class":276}," user",[36,305,306],{"class":42}," extends",[36,308,309],{"class":69}," Validate\n",[36,311,313],{"class":38,"line":312},8,[36,314,315],{"class":53},"{\n",[36,317,319,322,325,327],{"class":38,"line":318},9,[36,320,321],{"class":42},"  protected",[36,323,324],{"class":53}," $rule ",[36,326,172],{"class":42},[36,328,329],{"class":53}," [];\n",[36,331,333,335,338,340],{"class":38,"line":332},10,[36,334,321],{"class":42},[36,336,337],{"class":53}," $message ",[36,339,172],{"class":42},[36,341,329],{"class":53},[36,343,345],{"class":38,"line":344},11,[36,346,347],{"class":53},"}\n",[16,349,350,351,354,355,358,359,361,362,364,365,354,368,354,371,374,375,377,378,380],{},"首先程式碼裡面有兩個變數 ",[33,352,353],{},"$rule","、",[33,356,357],{},"$message","，",[33,360,353],{}," 代表的是要驗證的欄位以及規則，而 ",[33,363,357],{}," 則是顯示錯誤訊息，那麼我們有需要填入的欄位共三個，分別為 ",[33,366,367],{},"email",[33,369,370],{},"password",[33,372,373],{},"gender","，另外 ",[33,376,353],{}," 是採用陣列的方式，所以就可以這樣撰寫 ",[33,379,353],{},"：",[26,382,384],{"className":215,"code":383,"language":217,"meta":31,"style":31},"protected $rule = [\n  'email' => 'require|email', \u002F\u002F 驗證 Email 格式並且要必填\n  'password' => 'require|min:8|max:30', \u002F\u002F 必填且最小長度 8 最大長度 30\n  'gender' => 'require|number',\u002F\u002F 必填，只接受 number\n];\n",[33,385,386,398,416,431,447],{"__ignoreMap":31},[36,387,388,391,393,395],{"class":38,"line":39},[36,389,390],{"class":42},"protected",[36,392,324],{"class":53},[36,394,172],{"class":42},[36,396,397],{"class":53}," [\n",[36,399,400,403,406,409,412],{"class":38,"line":57},[36,401,402],{"class":103},"  'email'",[36,404,405],{"class":42}," =>",[36,407,408],{"class":103}," 'require|email'",[36,410,411],{"class":53},", ",[36,413,415],{"class":414},"sQrFR","\u002F\u002F 驗證 Email 格式並且要必填\n",[36,417,418,421,423,426,428],{"class":38,"line":82},[36,419,420],{"class":103},"  'password'",[36,422,405],{"class":42},[36,424,425],{"class":103}," 'require|min:8|max:30'",[36,427,411],{"class":53},[36,429,430],{"class":414},"\u002F\u002F 必填且最小長度 8 最大長度 30\n",[36,432,433,436,438,441,444],{"class":38,"line":110},[36,434,435],