r.require'",[36,544,405],{"class":42},[36,546,547],{"class":103}," '性別必填'",[36,549,107],{"class":53},[36,551,552,554,556],{"class":38,"line":312},[36,553,435],{"class":103},[36,555,405],{"class":42},[36,557,558],{"class":103}," '性別必須為是數字'\n",[36,560,561],{"class":38,"line":318},[36,562,451],{"class":53},[16,564,565],{},"這樣我們就將表單驗證給完成了。",[12,567,568],{"id":568},"控制器",[16,570,571,572,575],{},"接下來要來修改控制器，首先我們會將表單接收的方法寫到 ",[33,573,574],{},"add()"," 方法內，然後會回傳我們剛剛發送的資料：",[26,577,579],{"className":215,"code":578,"language":217,"meta":31,"style":31},"public function add($email, $password, $gender) {\n    return $email. $password. $gender;\n}\n",[33,580,581,595,614],{"__ignoreMap":31},[36,582,583,586,589,592],{"class":38,"line":39},[36,584,585],{"class":42},"public",[36,587,588],{"class":42}," function",[36,590,591],{"class":49}," add",[36,593,594],{"class":53},"($email, $password, $gender) {\n",[36,596,597,600,603,606,609,611],{"class":38,"line":57},[36,598,599],{"class":42},"    return",[36,601,602],{"class":53}," $email",[36,604,605],{"class":42},".",[36,607,608],{"class":53}," $password",[36,610,605],{"class":42},[36,612,613],{"class":53}," $gender;\n",[36,615,616],{"class":38,"line":82},[36,617,347],{"class":53},[16,619,620,621,624],{},"那麼該如何使用表單驗證呢?只需要加上一段 ",[33,622,623],{},"validate('資料','驗證器名稱')"," 即可搞定，這邊我順便接上資料庫，這樣才能夠看出真實性：",[26,626,628],{"className":215,"code":627,"language":217,"meta":31,"style":31},"public function add($email, $password, $gender) {\n  $user = new userModel;\n  $user->email = $email;\n  $user->password = $password;\n  $user->gender = $gender;\n  $result = $this->validate($user,'User');\n  if($result){\n  return $result;\n  }\n  if($user->save()){\n      return '新增成功';\n  } else {\n      return $user->getError();\n  }\n}\n",[33,629,630,640,655,671,685,698,721,729,737,742,757,767,779,795,800],{"__ignoreMap":31},[36,631,632,634,636,638],{"class":38,"line":39},[36,633,585],{"class":42},[36,635,588],{"class":42},[36,637,591],{"class":49},[36,639,594],