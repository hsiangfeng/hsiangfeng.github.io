[{"data":1,"prerenderedAt":345},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190902\u002F536097622\u002F":3,"page:\u002Fphp\u002F20190902\u002F536097622\u002F":4,"alt:\u002Fphp\u002F20190902\u002F536097622\u002F":3,"prev-next:\u002Fphp\u002F20190902\u002F536097622\u002F":322,"related:\u002Fphp\u002F20190902\u002F536097622\u002F":331},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F02\u002Fthinkphp-day-01-intro\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":304,"date":305,"description":18,"extension":306,"lang":307,"meta":308,"navigation":309,"path":310,"readingMinutes":311,"seo":312,"standalone":313,"stem":314,"tags":315,"tldr":319,"updated":319,"url":320,"__hash__":321},"content\u002F從基礎學習 ThinkPHP\u002FDay1-從基礎學習-ThinkPHP-介紹.md","Day1-從基礎學習 ThinkPHP-介紹","536097622",{"type":9,"value":10,"toc":294},"minimark",[11,15,19,23,30,50,53,64,67,74,78,106,109,112,132,139,145,148,151,165,263,271,274,277,280],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"ThinkPHP 算是比較少見的框架，我會挑選 ThinkPHP 當作是一個挑戰是因為先前有寫過(被打)，但是當時寫的版本是 3.2.4，而目前版本是 5.1，這段過程 ThinkPHP 其實有非常大的改變，光系統架構上就差非常多，那麼廢話就不多說讓我們從基礎來學習 ThinkPHP 5.1 吧!",[12,20,22],{"id":21},"thinkphp-介紹","ThinkPHP 介紹",[16,24,25],{},[26,27],"img",{"alt":28,"src":29},"ThinkPHP","https:\u002F\u002Fi.imgur.com\u002FqA7aoMk.png",[16,31,32,33,37,38,41,42,45,46,49],{},"先前我所接觸 ThinkPHP 版本是 3.2.4，當時寫完的感受就是非常適合新手的一個框架，但是有些語法上是真的太過於簡潔導致開發上有許多困擾，例如跨控制器呼叫的寫法 ",[34,35,36],"code",{},"R(\"Public\u002FHeader\");"," 以及 Model 實例話是 ",[34,39,40],{},"M(\"User\");","，如果不查開發者手冊真的會不知道 ",[34,43,44],{},"R()"," & ",[34,47,48],{},"M()"," 這兩個方法到底是什麼神奇的東東，但是基本上只要看完官方所提供的開發者手冊你就可以做出一個網站沒問題。",[16,51,52],{},"後來 ThinkPHP 官方為了讓系統可以支援 PHP 7.0 以上，所以在 ThinkPHP 5 的時候將整個系統架構大翻修，個人覺得如果是稍微寫過 Laravel 的人可能會覺得有點神似(系統核心是參考 Laravel)，那麼 ThinkPHP LTS 現行版是 5.1，雖然目前最新版是 6.0 (聽說 6.0 又有重購，但我沒有特別研究)，可是還是有些許問題，所以本篇系列將會集中介紹 ThinkPHP 5.1 唷~",[16,54,55,56,63],{},"另外這邊也附上 ThinkPHP 官方的 ",[57,58,62],"a",{"href":59,"rel":60},"https:\u002F\u002Fgithub.com\u002Ftop-think\u002Fthink\u002Ftree\u002F5.1",[61],"nofollow","GitHub"," 提供給各位。",[16,65,66],{},"最後官方也有提供 ThinkPHP 完全開發手冊(是中文的唷!)，如果你的英文程度跟我一樣差，不妨可以嘗試學習這個框架看看，基本上當你學會一個框架後再去看其他框架，其實你會發現滿多雷同的地方。",[16,68,69],{},[57,70,73],{"href":71,"rel":72},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F353946",[61],"ThinkPHP 5.1 完全開發手冊",[12,75,77],{"id":76},"環境要求-安裝","環境要求 & 安裝",[79,80,81,90,98],"ul",{},[82,83,84,85],"li",{},"PHP 5.6+\n",[79,86,87],{},[82,88,89],{},"ThinkPHP 5.1 環境要求在 PHP 5.6 以上，所以如果你是 PHP 5.6 以下是無法使用的唷~",[82,91,92,93],{},"composer\n",[79,94,95],{},[82,96,97],{},"本篇文章將會採用 composer 來安裝 ThinkPHP 5.1。",[82,99,100,101],{},"XAMPP 7.x.x 以上皆可\n",[79,102,103],{},[82,104,105],{},"因為 XAMPP 內建有 MariaDB。",[12,107,108],{"id":108},"我的開發環境",[16,110,111],{},"另外我這邊提供我的開發環境給予參考。",[79,113,114,117,120,123,126,129],{},[82,115,116],{},"作業系統 - Windows  10 x64",[82,118,119],{},"XAMPP - 7.3.8",[82,121,122],{},"PHP - 7.3.8",[82,124,125],{},"phpMyAdmin - 4.9.0.1",[82,127,128],{},"Apache - 2.4.39",[82,130,131],{},"MariaDB - 10.4.6",[16,133,134,135,138],{},"另外這邊補充一個非常非常微小的雷點，如果你電腦裡面有安裝 VMWare 記得要開啟工作管理員把 ",[34,136,137],{},"vmware-hostd.exe"," 停止運作，否則你可能會發生 Apache 打不開的窘事，使用 XAMPP 來開發的好處就是錯誤訊息都會直接陳列在下方加快我們排除 ↓",[16,140,141],{},[26,142],{"alt":143,"src":144},"vmware-hostd","https:\u002F\u002Fi.imgur.com\u002F7tRXogu.png",[12,146,147],{"id":147},"章節大綱",[16,149,150],{},"由於我們將會從基礎 SQL 學習一個框架，所以將會從基礎 SQL 語法到學習使用 ThinkPHP 框架，當然本系列可能不會依照順序來做撰寫，中間會發生穿插一些基礎混搭介紹學習，這樣子就可以看出原生語法與官方所提供的函式庫上的差異唷~",[16,152,153,154,157,158,157,161,164],{},"另外本篇建議要有基礎的程式語言基礎，只要你知道 ",[34,155,156],{},"if","、",[34,159,160],{},"for",[34,162,163],{},"foreach"," 這幾種語法，那麼大致上就沒有甚麼問題哩。",[79,166,167,183,186,189,192,195,203,206,209,212,215,223,226,229,232,235,243,255],{},[82,168,169,170,173,174],{},"安裝 XAMPP (這邊我並不會多做介紹，可以參考其他前輩所撰寫的文章來安裝即可 ",[171,172],"d",{},")\n",[79,175,176],{},[82,177,178],{},[57,179,182],{"href":180,"rel":181},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10197921",[61],"XAMPP安裝與操作初步",[82,184,185],{},"基礎 SQL 指令",[82,187,188],{},"ThinkPHP 安裝",[82,190,191],{},"ThinkPHP 目錄結構",[82,193,194],{},"基本 MVC 觀念",[82,196,197,198],{},"ThinkPHP MVC\n",[79,199,200],{},[82,201,202],{},"主要會介紹如何定義基礎 Model、View、Controller。",[82,204,205],{},"ThinkPHP Route",[82,207,208],{},"ThinkPHP Model 基礎操作",[82,210,211],{},"ThinkPHP 原生 SQL 語法撰寫",[82,213,214],{},"ThinkPHP Layout",[82,216,217,218],{},"引入第三方資源\n",[79,219,220],{},[82,221,222],{},"將會介紹該如何引入第三方資源，如 Bootstrap、jQuery。",[82,224,225],{},"ThinkPHP 內建標籤",[82,227,228],{},"ThinkPHP 表單驗證",[82,230,231],{},"ThinkPHP 表單 Token",[82,233,234],{},"ThinkPHP 驗證碼",[82,236,237,238],{},"使用 ThinkPHP 製作一個會員登入登出以及註冊功能 & 留言版系統\n",[79,239,240],{},[82,241,242],{},"這一篇主要講解規劃，所以不會有太多程式碼介紹，但是最後章節將會附上 GitHub 連結。",[82,244,245,246],{},"ThinkPHP 基礎指令\n",[79,247,248],{},[82,249,250,251,254],{},"內容雖然是介紹 ThinkPHP 基礎指令，但是最主要是介紹 ",[34,252,253],{},"think-migration"," 的使用方法。",[82,256,257,258],{},"將 ThinkPHP 部屬至 Heroku\n",[79,259,260],{},[82,261,262],{},"主要會介紹如何將 ThinkPHP 部屬至 Heroku，但是也會講我部屬時遇到的一些雷點解決方法。",[16,264,265,266,270],{},"而這一整個系列文章也將會同步更新於我的部落格 → ",[57,267,269],{"href":268},"\u002F","是 Ray 不是 Array","。",[16,272,273],{},"如果文章中有不正確的地方就請多多指教了~",[16,275,276],{},"(撰寫之前一直煩惱這個章節大綱會不會很不 OK QQ)",[12,278,279],{"id":279},"結尾",[16,281,282,283,287,288,291,292],{},"本來報名的時候主題名稱是想寫 ",[284,285,286],"span",{},"替自己學一個框架","，但是感覺主題有點不是很好，在字面上怕會讓人家覺得我會介紹很多種框架的感覺，所以思考大概兩個禮拜後就決定將主題定案為 ",[284,289,290],{},"從基礎學習 ThinkPHP","，那麼接下來就讓我們從基礎 SQL 指令來替自己學習一個框架吧 ",[171,293],{},{"title":295,"searchDepth":296,"depth":296,"links":297},"",2,[298,299,300,301,302,303],{"id":14,"depth":296,"text":14},{"id":21,"depth":296,"text":22},{"id":76,"depth":296,"text":77},{"id":108,"depth":296,"text":108},{"id":147,"depth":296,"text":147},{"id":279,"depth":296,"text":279},"PHP","2019-09-02 11:28:58","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday1-thinkphp","3",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay1-從基礎學習-ThinkPHP-介紹",[304,316,317,290,318],"MySQL","ThinkPHP 5.1","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190902\u002F536097622\u002F","ysAI0J-AvLHvJPC8udL3_Sav3nPvpei0OKFEipXN9uI",{"newer":323,"older":327},{"url":324,"title":325,"date":326},"\u002Fphp\u002F20190903\u002F2318537651\u002F","Day2-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料庫篇","2019-09-03 08:35:58",{"url":328,"title":329,"date":330},"\u002Fother\u002F20190828\u002F2944044939\u002F","Slack 基礎操作","2019-08-28 08:52:12",[332,337,341],{"url":333,"title":334,"date":335,"readingMinutes":336},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41","2",{"url":338,"title":339,"date":340,"readingMinutes":336},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":342,"title":343,"date":344,"readingMinutes":311},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01",1784020399258]