[{"data":1,"prerenderedAt":841},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190906\u002F241727046\u002F":3,"page:\u002Fphp\u002F20190906\u002F241727046\u002F":4,"alt:\u002Fphp\u002F20190906\u002F241727046\u002F":3,"prev-next:\u002Fphp\u002F20190906\u002F241727046\u002F":818,"related:\u002Fphp\u002F20190906\u002F241727046\u002F":827},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":799,"date":800,"description":18,"extension":801,"lang":802,"meta":803,"navigation":804,"path":805,"readingMinutes":806,"seo":807,"standalone":808,"stem":809,"tags":810,"tldr":815,"updated":815,"url":816,"__hash__":817},"content\u002F從基礎學習 ThinkPHP\u002FDay5-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料篇-2.md","Day5-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料篇(2)","241727046",{"type":9,"value":10,"toc":781},"minimark",[11,15,19,22,25,54,60,63,70,73,80,83,192,195,201,205,213,240,245,248,253,257,271,303,308,317,323,327,337,367,372,378,381,384,405,412,439,442,448,451,454,461,488,493,499,502,505,515,518,525,545,550,553,559,562,586,591,594,599,602,612,635,640,643,649,652,655,777],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"上一篇我只講到插入、更新與刪除語法，但是唯獨查詢這個語法沒有講到，這是因為查詢的語法其實可以有非常多種組合，所以我才特別獨立出一篇來做介紹，那麼廢話就不多說，讓我們來了解為什麼我會拆出這一篇文章吧!",[12,20,21],{"id":21},"查詢全部欄位資料",[16,23,24],{},"首先先讓我們來學習最基礎 & 最簡單的語法，也就是查詢資料表內所有的資料欄位資料：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-sql shiki shiki-themes github-dark-high-contrast","SELECT * FROM hw_table;\n","sql","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40,44,47,50],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sWyjQ","SELECT",[36,45,46],{"class":42}," *",[36,48,49],{"class":42}," FROM",[36,51,53],{"class":52},"sMAXC"," hw_table;\n",[16,55,56,57],{},"※ 指令說明: ",[33,58,59],{},"SELECT * FROM [資料表名稱];",[16,61,62],{},"如果你是依照上一篇一路操作下來，那正常來講查詢的結果應該只會有一筆 ↓",[16,64,65],{},[66,67],"img",{"alt":68,"src":69},"只有一筆","https:\u002F\u002Fi.imgur.com\u002FBammqqJ.png",[12,71,72],{"id":72},"查詢",[16,74,75,76,79],{},"接下來這邊開始會稍微有有一點難，但是也是查詢中的重點，也就是條件式查詢，通常條件式查詢都會帶上 ",[33,77,78],{},"where"," 並且在這後面加上條件，那麼依照所你帶上的條件不同，就可以得到不同的答案。",[16,81,82],{},"但是在實作之前，我會建議先輸入以下指令，快速塞入幾筆範例資料，這樣子我們後面才可以看出成效：",[26,84,86],{"className":28,"code":85,"language":30,"meta":31,"style":31},"INSERT INTO hw_table (name, height, weight) VALUES ('王小明', 177.6, 70.5),('王小明', 156.6, 47.5),('陳春嬌', 172.6,46.7);\n",[33,87,88],{"__ignoreMap":31},[36,89,90,93,96,99,102,105,108,111,114,118,121,125,128,131,133,136,138,141,144,146,148,151,153,155,157,160,162,164,166,169,171,174,176,178,181,184,186,189],{"class":38,"line":39},[36,91,92],{"class":42},"INSERT INTO",[36,94,95],{"class":52}," hw_table (",[36,97,98],{"class":42},"name",[36,100,101],{"class":52},", height, ",[36,103,104],{"class":42},"weight",[36,106,107],{"class":52},") ",[36,109,110],{"class":42},"VALUES",[36,112,113],{"class":52}," (",[36,115,117],{"class":116},"sTRMh","'王小明'",[36,119,120],{"class":52},", ",[36,122,124],{"class":123},"sCcAr","177",[36,126,127],{"class":52},".",[36,129,130],{"class":123},"6",[36,132,120],{"class":52},[36,134,135],{"class":123},"70",[36,137,127],{"class":52},[36,139,140],{"class":123},"5",[36,142,143],{"class":52},"),(",[36,145,117],{"class":116},[36,147,120],{"class":52},[36,149,150],{"class":123},"156",[36,152,127],{"class":52},[36,154,130],{"class":123},[36,156,120],{"class":52},[36,158,159],{"class":123},"47",[36,161,127],{"class":52},[36,163,140],{"class":123},[36,165,143],{"class":52},[36,167,168],{"class":116},"'陳春嬌'",[36,170,120],{"class":52},[36,172,173],{"class":123},"172",[36,175,127],{"class":52},[36,177,130],{"class":123},[36,179,180],{"class":52},",",[36,182,183],{"class":123},"46",[36,185,127],{"class":52},[36,187,188],{"class":123},"7",[36,190,191],{"class":52},");\n",[16,193,194],{},"所以目前來講我們目前的資料表裡面應該會有四筆資料 ↓",[16,196,197],{},[66,198],{"alt":199,"src":200},"四筆資料","https:\u002F\u002Fi.imgur.com\u002FTmXnDpv.png",[202,203,204],"h3",{"id":204},"條件式查詢",[16,206,207,208,212],{},"首先是第一個條件式查詢，假設我們今天想要找只要是名子叫做",[209,210,211],"strong",{},"王小明","的人，那麼語法就可以這樣撰寫：",[26,214,216],{"className":28,"code":215,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table WHERE name='王小明';\n",[33,217,218],{"__ignoreMap":31},[36,219,220,222,224,226,229,232,235,237],{"class":38,"line":39},[36,221,43],{"class":42},[36,223,46],{"class":42},[36,225,49],{"class":42},[36,227,228],{"class":52}," hw_table ",[36,230,231],{"class":42},"WHERE",[36,233,234],{"class":42}," name=",[36,236,117],{"class":116},[36,238,239],{"class":52},";\n",[16,241,56,242],{},[33,243,244],{},"SELECT * FROM [資料表名稱] WHERE [條件];",[16,246,247],{},"執行後，就可以看到查詢結果只會跳出名子叫王小明的人 ↓",[16,249,250],{},[66,251],{"alt":211,"src":252},"https:\u002F\u002Fi.imgur.com\u002FUZyboyX.png",[202,254,256],{"id":255},"條件式查詢-and","條件式查詢 AND",[16,258,259,260,263,264,266,267,270],{},"如果你希望查詢的結果，可以更聚焦一點(更詳細)，假使你今天只想找體重 ",[209,261,262],{},"70.5"," 公斤然後名子剛好叫",[209,265,211],{},"的的人呢?此時我們可以帶上 ",[33,268,269],{},"and"," 來附帶其他條件進而達到我們要的查詢結果：",[26,272,274],{"className":28,"code":273,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table WHERE name='王小明' and weight='70.5';\n",[33,275,276],{"__ignoreMap":31},[36,277,278,280,282,284,286,288,290,292,295,298,301],{"class":38,"line":39},[36,279,43],{"class":42},[36,281,46],{"class":42},[36,283,49],{"class":42},[36,285,228],{"class":52},[36,287,231],{"class":42},[36,289,234],{"class":42},[36,291,117],{"class":116},[36,293,294],{"class":42}," and",[36,296,297],{"class":42}," weight=",[36,299,300],{"class":116},"'70.5'",[36,302,239],{"class":52},[16,304,56,305],{},[33,306,307],{},"SELECT * FROM [資料表名稱] WHERE [條件] and [條件];",[16,309,310,311,313,314,316],{},"這樣你就可以找到姓名叫",[209,312,211],{},"而且體重是 ",[209,315,262],{}," 公斤的人 ↓",[16,318,319],{},[66,320],{"alt":321,"src":322},"可以看到搜尋出來的結果有淡淡的橘框","https:\u002F\u002Fi.imgur.com\u002FhBCpmJT.png",[202,324,326],{"id":325},"條件式查詢-or","條件式查詢 OR",[16,328,329,330,333,334,336],{},"當今天如果我們希望可以同時查詢名子叫",[209,331,332],{},"陳春嬌","以及",[209,335,211],{},"時，就可以這樣寫：",[26,338,340],{"className":28,"code":339,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table WHERE name='陳春嬌' OR name='王小明';\n",[33,341,342],{"__ignoreMap":31},[36,343,344,346,348,350,352,354,356,358,361,363,365],{"class":38,"line":39},[36,345,43],{"class":42},[36,347,46],{"class":42},[36,349,49],{"class":42},[36,351,228],{"class":52},[36,353,231],{"class":42},[36,355,234],{"class":42},[36,357,168],{"class":116},[36,359,360],{"class":42}," OR",[36,362,234],{"class":42},[36,364,117],{"class":116},[36,366,239],{"class":52},[16,368,56,369],{},[33,370,371],{},"SELECT * FROM [資料表名稱] WHERE [條件] or [條件];",[16,373,374],{},[66,375],{"alt":376,"src":377},"OR","https:\u002F\u002Fi.imgur.com\u002FI17UzMS.png",[16,379,380],{},"當然如果其中一個不是不存在的，也不會影響查詢執行狀況，它會兩筆都列出來，所以說假使今天沒有陳春嬌這個人，但是有王小明，那麼就會只列出王小明。",[202,382,383],{"id":383},"條件式查詢補充",[16,385,386,387,390,391,394,395,394,398,394,401,404],{},"最後這邊來針對條件式查詢做一下補充，條件式查詢其實還可以加入",[209,388,389],{},"運算子","(",[33,392,393],{},"="," 、 ",[33,396,397],{},">",[33,399,400],{},"\u003C",[33,402,403],{},"!=",")，那麼什麼是運算子呢?讓我們直接來看看範例吧。",[16,406,407,408,411],{},"假設我今天想要找身高 ",[209,409,410],{},"大於 170 公分"," 的人，那就可以這樣寫：",[26,413,415],{"className":28,"code":414,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table WHERE height > 170;\n",[33,416,417],{"__ignoreMap":31},[36,418,419,421,423,425,427,429,432,434,437],{"class":38,"line":39},[36,420,43],{"class":42},[36,422,46],{"class":42},[36,424,49],{"class":42},[36,426,228],{"class":52},[36,428,231],{"class":42},[36,430,431],{"class":52}," height ",[36,433,397],{"class":42},[36,435,436],{"class":123}," 170",[36,438,239],{"class":52},[16,440,441],{},"執行後，我們就可以找到兩個身高大於 170 的人 ↓",[16,443,444],{},[66,445],{"alt":446,"src":447},"兩個人","https:\u002F\u002Fi.imgur.com\u002FPbmwDMI.png",[16,449,450],{},"剩下的運算子條件其實大同小異，所以我就不多做示範了，因為寫法都是雷同的。",[12,452,453],{"id":453},"查詢特定筆數的資料",[16,455,456,457,460],{},"那如果我今天希望在查詢時，只想查詢第 3 筆 ~ 第 4 筆的資料呢?那麼就會使用 ",[33,458,459],{},"LIMIT"," 語法：",[26,462,464],{"className":28,"code":463,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table LIMIT 2,4;\n",[33,465,466],{"__ignoreMap":31},[36,467,468,470,472,474,476,478,481,483,486],{"class":38,"line":39},[36,469,43],{"class":42},[36,471,46],{"class":42},[36,473,49],{"class":42},[36,475,228],{"class":52},[36,477,459],{"class":42},[36,479,480],{"class":123}," 2",[36,482,180],{"class":52},[36,484,485],{"class":123},"4",[36,487,239],{"class":52},[16,489,56,490],{},[33,491,492],{},"SELECT * FROM [資料表名稱] LIMIT [值1],[值2];",[16,494,495],{},[66,496],{"alt":497,"src":498},"查詢特定筆數","https:\u002F\u002Fi.imgur.com\u002FIXpr72N.png",[12,500,501],{"id":501},"查詢結果排序",[16,503,504],{},"最後讓我們來講講排序，排序是一個非常常見的做法，首先排序最主要分為兩種排序模式",[506,507,508,512],"ul",{},[509,510,511],"li",{},"遞增排序 (ASC)",[509,513,514],{},"遞減排序 (DESC)",[202,516,517],{"id":517},"查詢結果遞增排序",[16,519,520,521,524],{},"通常排序時，都會使用到一個語法，也就是 ",[33,522,523],{},"ORDER BY","，預設的排序是遞增排序，這邊就讓我們用身高來嘗試做排序看看：",[26,526,528],{"className":28,"code":527,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table ORDER BY height;\n",[33,529,530],{"__ignoreMap":31},[36,531,532,534,536,538,540,542],{"class":38,"line":39},[36,533,43],{"class":42},[36,535,46],{"class":42},[36,537,49],{"class":42},[36,539,228],{"class":52},[36,541,523],{"class":42},[36,543,544],{"class":52}," height;\n",[16,546,56,547],{},[33,548,549],{},"SELECT * FROM [資料表名稱] ORDER BY [欄位];",[16,551,552],{},"你可以看到身高由小排至大 ↓",[16,554,555],{},[66,556],{"alt":557,"src":558},"遞增排序","https:\u002F\u002Fi.imgur.com\u002FExADZGI.png",[16,560,561],{},"但是我個人是會習慣寫死，避免出現一些奇怪的問題，那遞增排序完整語法如下：",[26,563,565],{"className":28,"code":564,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table ORDER BY height ASC;\n",[33,566,567],{"__ignoreMap":31},[36,568,569,571,573,575,577,579,581,584],{"class":38,"line":39},[36,570,43],{"class":42},[36,572,46],{"class":42},[36,574,49],{"class":42},[36,576,228],{"class":52},[36,578,523],{"class":42},[36,580,431],{"class":52},[36,582,583],{"class":42},"ASC",[36,585,239],{"class":52},[16,587,56,588],{},[33,589,590],{},"SELECT * FROM [資料表名稱] ORDER BY [欄位] ASC;",[16,592,593],{},"當然結果也是會一樣 ↓",[16,595,596],{},[66,597],{"alt":557,"src":598},"https:\u002F\u002Fi.imgur.com\u002FfUCyKHl.png",[202,600,601],{"id":601},"查詢結果遞減排序",[16,603,604,605,607,608,611],{},"那麼遞減排序呢?遞減排序只需要將原本前面講的 ",[33,606,583],{}," 換成 ",[33,609,610],{},"DESC"," 即可：",[26,613,615],{"className":28,"code":614,"language":30,"meta":31,"style":31},"SELECT * FROM hw_table ORDER BY height DESC;\n",[33,616,617],{"__ignoreMap":31},[36,618,619,621,623,625,627,629,631,633],{"class":38,"line":39},[36,620,43],{"class":42},[36,622,46],{"class":42},[36,624,49],{"class":42},[36,626,228],{"class":52},[36,628,523],{"class":42},[36,630,431],{"class":52},[36,632,610],{"class":42},[36,634,239],{"class":52},[16,636,56,637],{},[33,638,639],{},"SELECT * FROM [資料表名稱] ORDER BY [欄位] DESC;",[16,641,642],{},"這樣就可以看到由大至小囉~",[16,644,645],{},[66,646],{"alt":647,"src":648},"遞減排序","https:\u002F\u002Fi.imgur.com\u002FeTBQWhE.png",[12,650,651],{"id":651},"結尾",[16,653,654],{},"最後讓我們整理一下本篇所講到的 SQL 指令吧~",[656,657,658,671],"table",{},[659,660,661],"thead",{},[662,663,664,668],"tr",{},[665,666,667],"th",{},"操作功能",[665,669,670],{},"SQL 語法",[672,673,674,686,698,711,724,739,754,766],"tbody",{},[662,675,676,679],{},[677,678,21],"td",{},[677,680,681,682,685],{},"SELECT * FROM ",[36,683,684],{},"資料表名稱",";",[662,687,688,690],{},[677,689,204],{},[677,691,681,692,694,695,685],{},[36,693,684],{}," WHERE ",[36,696,697],{},"條件",[662,699,700,702],{},[677,701,256],{},[677,703,681,704,694,706,708,709,685],{},[36,705,684],{},[36,707,697],{}," and ",[36,710,697],{},[662,712,713,715],{},[677,714,326],{},[677,716,681,717,694,719,721,722],{},[36,718,684],{},[36,720,697],{}," or ",[36,723,697],{},[662,725,726,729],{},[677,727,728],{},"條件式查詢(運算子)",[677,730,681,731,694,733,736,737,685],{},[36,732,684],{},[36,734,735],{},"欄位"," > ",[36,738,697],{},[662,740,741,743],{},[677,742,453],{},[677,744,681,745,747,748,180,751,685],{},[36,746,684],{}," LIMIT ",[36,749,750],{},"值1",[36,752,753],{},"值2",[662,755,756,758],{},[677,757,517],{},[677,759,681,760,762,763,765],{},[36,761,684],{}," ORDER BY ",[36,764,735],{}," ASC;",[662,767,768,770],{},[677,769,601],{},[677,771,681,772,762,774,776],{},[36,773,684],{},[36,775,735],{}," DESC;",[778,779,780],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":31,"searchDepth":782,"depth":782,"links":783},2,[784,785,786,793,794,798],{"id":14,"depth":782,"text":14},{"id":21,"depth":782,"text":21},{"id":72,"depth":782,"text":72,"children":787},[788,790,791,792],{"id":204,"depth":789,"text":204},3,{"id":255,"depth":789,"text":256},{"id":325,"depth":789,"text":326},{"id":383,"depth":789,"text":383},{"id":453,"depth":782,"text":453},{"id":501,"depth":782,"text":501,"children":795},[796,797],{"id":517,"depth":789,"text":517},{"id":601,"depth":789,"text":601},{"id":651,"depth":782,"text":651},"PHP","2019-09-06 00:07:55","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday5-thinkphp-mysql-2","3",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay5-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料篇-2",[799,811,812,813,814],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190906\u002F241727046\u002F","WR280eJrQYb4wC0T8hs2h1RupxfO6qLVoM2S6cAGtNA",{"newer":819,"older":823},{"url":820,"title":821,"date":822},"\u002Fphp\u002F20190907\u002F1127478062\u002F","Day6-從基礎學習 ThinkPHP-安裝 ThinkPHP 安裝","2019-09-07 00:01:37",{"url":824,"title":825,"date":826},"\u002Fphp\u002F20190905\u002F1275666548\u002F","Day4-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料篇(1)","2019-09-05 00:02:55",[828,833,837],{"url":829,"title":830,"date":831,"readingMinutes":832},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41","2",{"url":834,"title":835,"date":836,"readingMinutes":832},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":838,"title":839,"date":840,"readingMinutes":806},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01",1784020399339]