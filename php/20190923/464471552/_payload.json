0},"  內容\n",[64,79,81],{"class":66,"line":80},3,[64,82,83],{"class":70},"{\u002F比較標籤}\n",[16,85,86,87,90],{},"接下來這邊我會在 ",[34,88,89],{},"about\u002Fview"," 底下建立一個 hello.html ↓",[16,92,93],{},[94,95],"img",{"alt":96,"src":97},"hello","https:\u002F\u002Fi.imgur.com\u002F1yM6ejU.png",[16,99,100],{},"然後 Controller 會寫一小段範例程式碼：",[55,102,106],{"className":103,"code":104,"language":105,"meta":60,"style":60},"language-php shiki shiki-themes github-dark-high-contrast","public function helloeq($name){\n    return $this->assign('name',$name)->fetch('hello');\n}\n","php",[34,107,108,124,162],{"__ignoreMap":60},[64,109,110,114,117,121],{"class":66,"line":67},[64,111,113],{"class":112},"sWyjQ","public",[64,115,116],{"class":112}," function",[64,118,120],{"class":119},"sj_SG"," helloeq",[64,122,123],{"class":70},"($name){\n",[64,125,126,129,133,136,139,142,146,149,151,154,156,159],{"class":66,"line":74},[64,127,128],{"class":112},"    return",[64,130,132],{"class":131},"sCcAr"," $this",[64,134,135],{"class":112},"->",[64,137,138],{"class":119},"assign",[64,140,141],{"class":70},"(",[64,143,145],{"class":144},"sTRMh","'name'",[64,147,148],{"class":70},",$name)",[64,150,135],{"class":112},[64,152,153],{"class":119},"fetch",[64,155,141],{"class":70},[64,157,158],{"class":144},"'hello'",[64,160,161],{"class":70},");\n",[64,163,164],{"class":66,"line":80},[64,165,166],{"class":70},"}\n",[16,168,169],{},"路由部份一樣也提供給各位，這樣子等一下才不用打太多字：",[55,171,173],{"className":103,"code":172,"language":105,"meta":60,"style":60},"Route::get('\u002Fabout\u002Fhelloeq\u002F:name', 'about\u002Findex\u002Fall');\n",[34,174,175],{"__ignoreMap":60},[64,176,177,180,183,186,188,191,194,197],{"class":66,"line":67},[64,178,179],{"class":131},"Route",[64,181,182],{"class":112},"::",[64,184,185],{"class":119},"get",[64,187,141],{"class":70},[64,189,190],{"class":144},"'\u002Fabout\u002Fhelloeq\u002F:name'",[64,192,193],{"class":70},", ",[64,195,196],{"class":144},"'about\u002Findex\u002Fall'",[64,198,161],{"class":70},[16,200,201,202,205],{},"基本上當我們訪問 ",[34,203,204],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fhelloeq\u002F:name"," 就可以看到回傳的名子 ↓",[16,207,208],{},[94,209],{"alt":210,"src":211},"後端傳送值到前端","https:\u002F\u002Fi.imgur.com\u002FyDhJ47H.png",[16,213,214,215,217,218,221,222,225,226,228,229,232],{},"準備好以上動作之後就可以來撰寫 ",[34,216,36],{}," 標籤了，假設今天傳進來的值只要名子不是 ",[34,219,220],{},"Ray","，通通改顯示 ",[34,223,224],{},"你是誰?我不認識你","，如果等於 ",[34,227,220],{}," 那就顯示 ",[34,230,231],{},"管理員你好"," 等字樣，那麼我們就可以這樣撰寫 hello.html 裡面的標籤：",[55,234,236],{"className":57,"code":235,"language":59,"meta":60,"style":60},"{eq name=\"name\" value=\"Ray\"}\n  \u003Cspan>管理員你好\u003C\u002Fspan>\n{else\u002F}\n  \u003Cspan>你是誰?我不認識你\u003C\u002Fspan>\n{\u002Feq}\n",[34,237,238,243,259,264,278],{"__ignoreMap":60},[64,239,240],{"class":66,"line":67},[64,241,242],{"class":70},"{eq name=\"name\" value=\"Ray\"}\n",[64,244,245,248,251,254,256],{"class":66,"line":74},[64,246,247],{"class":70},"  \u003C",[64,249,64],{"class":250},"sKpQp",[64,252,253],{"class":70},">管理員你好\u003C\u002F",[64,255,64],{"class":250},[64,257,258],{"class":70},">\n",[64,260,261],{"class":66,"line":80},[64,262,263],{"class":70},"{else\u002F}\n",[64,265,267,269,271,274,276],{"class":66,"line":266},4,[64,268,247],{"class":70},[64,270,64],{"class":250},[64,272,273],{"class":70},">你是誰?我不認識你\u003C\u002F",[64,275,64],{"class":250},[64,277,258],{"class":70},[64,279,281],{"class":66,"line":280},5,[64,282,283],{"class":70},"{\u002Feq}\n",[16,285,286,287,289],{},"那麼首先我們先傳入 ",[34,288,220],{}," 的值，看畫面出現什麼 ↓",[16,291,292],{},[94,293],{"alt":294,"src":295},"出現管理員你好","https:\u002F\u002Fi.imgur.com\u002FlA9I0VS.png",[16,297,298,299,301,302,305],{},"如果傳入非 ",[34,300,220],{}," 的值呢?例如傳入 ",[34,303,304],{},"QQ 先生"," ↓",[16,307,308],{},[94,309],{"alt":310,"src":311},"QQ 先生 我不認識你呢~","https:\u002F\u002Fi.imgur.com\u002FrZfa1lI.png",[26,313,315],{"id":314},"neq-or-notequal-標籤","neq or notequal 標籤",[16,317,318,319,321,322,324,325,327],{},"那 ",[34,320,40],{}," 標籤呢?上面我們可以看到 ",[34,323,36],{}," 所代表的是等於，那 ",[34,326,40],{}," 則是代表不等於，我這邊就不多作範例直接提供寫法就好：",[55,329,331],{"className":57,"code":330,"language":59,"meta":60,"style":60},"{neq name=\"name\" value=\"Ray\"}\n  \u003Cspan>管理員你好\u003C\u002Fspan>\n{else\u002F}\n  \u003Cspan>你是誰?我不認識你\u003C\u002Fspan>\n{\u002Fneq}\n",[34,332,333,338,350,354,366],{"__ignoreMap":60},[64,334,335],{"class":66,"line":67},[64,336,337],{"class":70},"{neq name=\"name\" value=\"Ray\"}\n",[64,339,340,342,344,346,348],{"class":66,"line":74},[64,341,247],{"class":70},[64,343,64],{"class":250},[64,345,253],{"class":70},[64,347,64],{"class":250},[64,349,258],{"class":70},[64,351,352],{"class":66,"line":80},[64,353,263],{"class":70},[64,355,356,358,360,362,364],{"class":66,"line":266},[64,357,247],{"class":70},[64,359,64],{"class":250},[64,361,273],{"class":70},[64,363,64],{"class":250},[64,365,258],{"class":70},[64,367,368],{"class":66,"line":280},[64,369,370],{"class":70},"{\u002Fneq}\n",[26,372,373],{"id":373},"其他種比較標籤",[16,375,376],{},"接下來還有幾個標籤很常使用，也就是大於、大於等於、小於、小於等於，寫法其實都一樣的，重點還是在於脫離不了這個關係架構：",[55,378,380],{"className":57,"code":379,"language":59,"meta":60,"style":60},"{比較標籤 name=\"變數\" value=\"值\"}\n內容\n{\u002F比較標籤}\n",[34,381,382,386,391],{"__ignoreMap":60},[64,383,384],{"class":66,"line":67},[64,385,71],{"class":70},[64,387,388],{"class":66,"line":74},[64,389,390],{"class":70},"內容\n",[64,392,393],{"class":66,"line":80},[64,394,83],{"class":70},[16,396,397],{},"那麼這邊我就提供寫法不多作範例，畢竟寫法都一樣：",[16,399,400,401],{},"大於:",[34,402,403],{},"{gt name=\"變數\" value=\"值\"}內容{\u002Fgt}",[16,405,406,407],{},"大於等於：",[34,408,409],{},"{egt name=\"變數\" value=\"值\"}內容{\u002Fegt}",[16,411,412,413],{},"小於：",[34,414,415],{},"{lt name=\"變數\" value=\"值\"}內容{\u002Flt}",[16,417,418,419],{},"小於等於：",[34,420,421],{},"{elt name=\"變數\" value=\"值\"}內容{\u002Felt}",[16,423,424,425],{},"詳細作法可以看這一篇",[426,427,21],"a",{"href":428,"rel":429},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354085",[430],"nofollow",[16,432,433,434,437,438,441,442,444],{},"當然也有另一種寫法，只用 ",[34,435,436],{},"compare"," 標籤，並帶入 ",[34,439,440],{},"type"," 這種也可以，拿 ",[34,443,36],{}," 舉例來講：",[55,446,448],{"className":57,"code":447,"language":59,"meta":60,"style":60},"{compare name=\"變數\" value=\"值\" type=\"eq\"}\n  內容\n{\u002Fcompare}\n",[34,449,450,455,459],{"__ignoreMap":60},[64,451,452],{"class":66,"line":67},[64,453,454],{"class":70},"{compare name=\"變數\" value=\"值\" type=\"eq\"}\n",[64,456,457],{"class":66,"line":74},[64,458,77],{"class":70},[64,460,461],{"class":66,"line":80},[64,462,463],{"class":70},"{\u002Fcompare}\n",[16,465,466],{},"那麼以上就是比較標籤的各種寫法囉。",[12,468,469],{"id":469},"條件式標籤",[16,471,472,473,475,476,479],{},"條件式標籤會跟上面標籤有點像，但是你會看到比較熟悉的語法，例如 ",[34,474,52],{},"、",[34,477,478],{},"switch"," 這種，這邊我就不多作範例，因為效果其實與上方比較標籤很雷同...",[26,481,483],{"id":482},"if-標籤","if 標籤",[16,485,486],{},"基本上你在撰寫條件式標籤的時候，可以把它當成寫程式一樣在寫，這邊舉例將 hello.html 的比較標籤改成條件式標籤的寫法會變這樣：",[55,488,490],{"className":57,"code":489,"language":59,"meta":60,"style":60},"{if ($name == 'Ray')}\n  \u003Cspan>管理員你好\u003C\u002Fspan>\n{else \u002F}\n  \u003Cspan>你是誰?我不認識你\u003C\u002Fspan>\n{\u002Fif}\n",[34,491,492,497,509,514,526],{"__ignoreMap":60},[64,493,494],{"class":66,"line":67},[64,495,496],{"class":70},"{if ($name == 'Ray')}\n",[64,498,499,501,503,505,507],{"class":66,"line":74},[64,500,247],{"class":70},[64,502,64],{"class":250},[64,504,253],{"class":70},[64,506,64],{"class":250},[64,508,258],{"class":70},[64,510,511],{"class":66,"line":80},[64,512,513],{"class":70},"{else \u002F}\n",[64,515,516,518,520,522,524],{"class":66,"line":266},[64,517,247],{"class":70},[64,519,64],{"class":250},[64,521,273],{"class":70},[64,523,64],{"class":250},[64,525,258],{"class":70},[64,527,528],{"class":66,"line":280},[64,529,530],{"class":70},"{\u002Fif}\n",[16,532,533],{},"用條件式標籤有沒感覺到比較熟悉呢?但是你可能會說「那我寫條件式標籤就好了啊，為什麼還要寫比較標籤?」那是因為先前我維護過的系統，滿多工程師都會使用比較標籤，所以如果你已經看過這東西，那麼當你遇到的時候，也比較不會覺得莫名其妙。",[26,535,537],{"id":536},"switch-標籤","switch 標籤",[16,539,540,542,543,475,546,549,550,553],{},[34,541,478],{}," 標籤就跟我們在寫 PHP 一樣，也會有 ",[34,544,545],{},"case",[34,547,548],{},"default","，唯一最大差別就是不用 ",[34,551,552],{},"break;","，那麼寫法就像這樣：",[55,555,557],{"className":57,"code":556,"language":59,"meta":60,"style":60},"{switch $name}\n  {case Ray}\n    \u003Cspan>管理員你好\u003C\u002Fspan>\n  {\u002Fcase}\n  {default\u002F}\u003Cspan>你是誰?我不認識你\u003C\u002Fspan>\n{\u002Fswitch}\n",[34,558,559,564,569,582,587,600],{"__ignoreMap":60},[64,560,561],{"class":66,"line":67},[64,562,563],{"class":70},"{switch $name}\n",[64,565,566],{"class":66,"line":74},[64,567,568],{"class":70},"  {case Ray}\n",[64,570,571,574,576,578,580],{"class":66,"line":80},[64,572,573],{"class":70},"    \u003C",[64,575,64],{"class":250},[64,577,253],{"class":70},[64,579,64],{"class":250},[64,581,258],{"class":70},[64,583,584],{"class":66,"line":266},[64,585,586],{"class":70},"  {\u002Fcase}\n",[64,588,589,592,594,596,598],{"class":66,"line":280},[64,590,591],{"class":70},"  {default\u002F}\u003C",[64,593,64],{"class":250},[64,595,273],{"class":70},[64,597,64],{"class":250},[64,599,258],{"class":70},[64,601,603],{"class":66,"line":602},6,[64,604,605],{"class":70},"{\u002Fswitch}\n",[12,607,608],{"id":608},"結尾",[16,610,611,612,615,616,615,619,615,622,625],{},"那麼以上就是比較常見的標籤，當然還有其他內建標籤，例如範圍標籤 ",[34,613,614],{},"in"," \u002F ",[34,617,618],{},"notin",[34,620,621],{},"between",[34,623,624],{},"notbetween","，個人推薦可以看官方開發手冊會比較詳細，因為範圍標籤我個人是沒有使用過。",[16,627,628],{},[426,629,469],{"href":630,"rel":631},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354086",[430],[16,633,634],{},"最後我會將標籤盡可能放進範例裡面，這樣也方便回顧 ↓",[16,636,637],{},[94,638],{"alt":639,"src":640},"內建標籤","https:\u002F\u002Fi.imgur.com\u002FByRLoxA.png",[642,643,644],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-d