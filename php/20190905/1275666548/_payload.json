[{"data":1,"prerenderedAt":664},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190905\u002F1275666548\u002F":3,"page:\u002Fphp\u002F20190905\u002F1275666548\u002F":4,"alt:\u002Fphp\u002F20190905\u002F1275666548\u002F":3,"prev-next:\u002Fphp\u002F20190905\u002F1275666548\u002F":642,"related:\u002Fphp\u002F20190905\u002F1275666548\u002F":651},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F05\u002Fthinkphp-day-04-mysql-data-crud-01\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":623,"date":624,"description":18,"extension":625,"lang":626,"meta":627,"navigation":628,"path":629,"readingMinutes":630,"seo":631,"standalone":632,"stem":633,"tags":634,"tldr":639,"updated":639,"url":640,"__hash__":641},"content\u002F從基礎學習 ThinkPHP\u002FDay4-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料篇-1.md","Day4-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料篇(1)","1275666548",{"type":9,"value":10,"toc":614},"minimark",[11,15,19,23,26,42,45,49,57,65,135,141,144,151,154,160,163,169,175,181,184,211,218,224,227,275,278,284,288,291,323,328,331,337,354,357,360,388,393,403,406,412,418,484,487,493,499,520,527,533,536,539,542,610],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇我們已經學會基礎的資料表操作，那麼這一篇就會針對資料欄位的資料操作來做介紹，但是在前面我們要先了解一些觀念，而這觀念將會幫助我們理解對於後面的動作操作。",[12,20,22],{"id":21},"crud","CRUD",[16,24,25],{},"首先先來講講什麼是 CRUD，因為接下來很多的動作都脫離不了這四個單字，而這四個英文字母各別代表著一個意思 ↓",[27,28,29,33,36,39],"ul",{},[30,31,32],"li",{},"C - 新增 (Create)",[30,34,35],{},"R - 讀取 (Read)",[30,37,38],{},"U - 更新 (Update)",[30,40,41],{},"D - 刪除 (Delete)",[16,43,44],{},"其中更新與刪除是要小心使用的，更不用說刪除，畢竟前面已經講過 N 次了，所以接下來就來講一下該如何新增資料、讀取資料、更新資料表以及最恐怖的刪除資料。",[12,46,48],{"id":47},"新增資料-插入欄位","新增資料 (插入欄位)",[16,50,51,52,56],{},"其實正確說法是插入欄位，但我自己在習慣上是講新增資料，但是這邊還是建議必須知道正確的說法是",[53,54,55],"strong",{},"插入欄位","唷~",[16,58,59,60,64],{},"這邊將會使用前一篇所建立的 ",[61,62,63],"code",{},"hw_table"," 資料表來作範例，首先我們要新增一筆資料，是班上同學小明的身高體重，那麼就會這樣寫：",[66,67,72],"pre",{"className":68,"code":69,"language":70,"meta":71,"style":71},"language-sql shiki shiki-themes github-dark-high-contrast","INSERT INTO hw_table (name, height, weight) VALUES ('王小明', 177.6, 70.5);\n","sql","",[61,73,74],{"__ignoreMap":71},[75,76,79,83,87,90,93,96,99,102,105,109,112,116,119,122,124,127,129,132],"span",{"class":77,"line":78},"line",1,[75,80,82],{"class":81},"sWyjQ","INSERT INTO",[75,84,86],{"class":85},"sMAXC"," hw_table (",[75,88,89],{"class":81},"name",[75,91,92],{"class":85},", height, ",[75,94,95],{"class":81},"weight",[75,97,98],{"class":85},") ",[75,100,101],{"class":81},"VALUES",[75,103,104],{"class":85}," (",[75,106,108],{"class":107},"sTRMh","'王小明'",[75,110,111],{"class":85},", ",[75,113,115],{"class":114},"sCcAr","177",[75,117,118],{"class":85},".",[75,120,121],{"class":114},"6",[75,123,111],{"class":85},[75,125,126],{"class":114},"70",[75,128,118],{"class":85},[75,130,131],{"class":114},"5",[75,133,134],{"class":85},");\n",[16,136,137,138],{},"※ 指令說明: ",[61,139,140],{},"INSERT INTO [資料表名稱] (欄位名稱1,欄位名稱2,...) VALUES (值,值,...);",[16,142,143],{},"那麼一樣我們來將 SQL 指令貼入 phpmyadmin 執行看看吧 ↓",[16,145,146],{},[147,148],"img",{"alt":149,"src":150},"SQL 指令","https:\u002F\u002Fi.imgur.com\u002F9qXgFEC.png",[16,152,153],{},"執行完畢後，我們可以回到資料表來看看是否插入成功 ↓",[16,155,156],{},[147,157],{"alt":158,"src":159},"插入成功","https:\u002F\u002Fi.imgur.com\u002FRQbw0qR.png",[16,161,162],{},"但是你會發現一件事情，也就是我們剛剛輸入的體重有小數點，但是為什麼 70.5 被四捨五入變成 71?",[16,164,165],{},[147,166],{"alt":167,"src":168},"四捨五入","https:\u002F\u002Fi.imgur.com\u002F0HFi1UA.png",[16,170,171,172,174],{},"原因是出在我們在前一篇建立資料表時，",[61,173,95],{}," 欄位是設置成 INT (整數) 導致，而整數會將小數點給四捨五入 ↓",[16,176,177],{},[147,178],{"alt":179,"src":180},"整數","https:\u002F\u002Fi.imgur.com\u002FerRRHZ4.png",[16,182,183],{},"所以我們就可以活用上一篇所學的修改資料欄位技巧來解決這個問題，只需要輸入以下指令即可：",[66,185,187],{"className":68,"code":186,"language":70,"meta":71,"style":71},"ALTER TABLE hw_table CHANGE COLUMN weight weight float;\n",[61,188,189],{"__ignoreMap":71},[75,190,191,194,197,200,202,205,208],{"class":77,"line":78},[75,192,193],{"class":81},"ALTER",[75,195,196],{"class":81}," TABLE",[75,198,199],{"class":85}," hw_table CHANGE COLUMN ",[75,201,95],{"class":81},[75,203,204],{"class":81}," weight",[75,206,207],{"class":81}," float",[75,209,210],{"class":85},";\n",[16,212,213,214,217],{},"這樣就可以看到結構被修改成 ",[61,215,216],{},"FLOAT"," (浮點數) ↓",[16,219,220],{},[147,221],{"alt":222,"src":223},"浮點數","https:\u002F\u002Fi.imgur.com\u002FpDZMjxe.png",[16,225,226],{},"這時候再重新新增一筆資料進去就可以知道有沒有成功囉~",[66,228,232],{"className":229,"code":230,"language":231,"meta":71,"style":71},"language-SQL shiki shiki-themes github-dark-high-contrast","INSERT INTO hw_table (name, height, weight) VALUES ('李小美', 152.6, 69.5);\n","SQL",[61,233,234],{"__ignoreMap":71},[75,235,236,238,240,242,244,246,248,250,252,255,257,260,262,264,266,269,271,273],{"class":77,"line":78},[75,237,82],{"class":81},[75,239,86],{"class":85},[75,241,89],{"class":81},[75,243,92],{"class":85},[75,245,95],{"class":81},[75,247,98],{"class":85},[75,249,101],{"class":81},[75,251,104],{"class":85},[75,253,254],{"class":107},"'李小美'",[75,256,111],{"class":85},[75,258,259],{"class":114},"152",[75,261,118],{"class":85},[75,263,121],{"class":114},[75,265,111],{"class":85},[75,267,268],{"class":114},"69",[75,270,118],{"class":85},[75,272,131],{"class":114},[75,274,134],{"class":85},[16,276,277],{},"基本上我們可以看到欄位可以正常輸入小數點囉 ↓",[16,279,280],{},[147,281],{"alt":282,"src":283},"小數點","https:\u002F\u002Fi.imgur.com\u002FYr0kaut.png",[12,285,287],{"id":286},"更新資料-更新欄位","更新資料 (更新欄位)",[16,289,290],{},"接下來讓我們講講更新欄位，假設李小美這陣子拼命的運動導致體重從 69.5 變成 45.6 (變瘦!)，那麼更新的語法就可以這樣寫：",[66,292,294],{"className":68,"code":293,"language":70,"meta":71,"style":71},"UPDATE hw_table SET weight='45.6' WHERE name='李小美';\n",[61,295,296],{"__ignoreMap":71},[75,297,298,301,304,307,310,313,316,319,321],{"class":77,"line":78},[75,299,300],{"class":81},"UPDATE",[75,302,303],{"class":85}," hw_table ",[75,305,306],{"class":81},"SET",[75,308,309],{"class":81}," weight=",[75,311,312],{"class":107},"'45.6'",[75,314,315],{"class":81}," WHERE",[75,317,318],{"class":81}," name=",[75,320,254],{"class":107},[75,322,210],{"class":85},[16,324,137,325],{},[61,326,327],{},"UPDATE [資料表名稱] SET 欄位名稱1='值' WHERE [條件];",[16,329,330],{},"當我們執行後就可以看到李小美的體重欄位更新了~",[16,332,333],{},[147,334],{"alt":335,"src":336},"更新成功","https:\u002F\u002Fi.imgur.com\u002F7mm7ZcB.png",[16,338,339,340,343,344,347,348,350,351,353],{},"通常 ",[61,341,342],{},"WHERE"," 的條件會使用獨一無二的 ",[61,345,346],{},"key"," 來做判斷，但是我這邊只是一個範例才會使用 ",[61,349,89],{}," 來作範例，正常狀況下，是會發生同名同姓的人，那後面章節我也會針對 ",[61,352,342],{}," 來做介紹。",[12,355,356],{"id":356},"刪除資料",[16,358,359],{},"最後就是刪除資料，假設我們今天要把王小明這個同學的資料給刪除，那麼語法就這樣寫：",[66,361,363],{"className":68,"code":362,"language":70,"meta":71,"style":71},"DELETE FROM hw_table WHERE id=2;\n",[61,364,365],{"__ignoreMap":71},[75,366,367,370,373,375,377,380,383,386],{"class":77,"line":78},[75,368,369],{"class":81},"DELETE",[75,371,372],{"class":81}," FROM",[75,374,303],{"class":85},[75,376,342],{"class":81},[75,378,379],{"class":85}," id",[75,381,382],{"class":81},"=",[75,384,385],{"class":114},"2",[75,387,210],{"class":85},[16,389,137,390],{},[61,391,392],{},"DELETE FROM [資料表名稱] WHERE [條件];",[16,394,395,396,399,400,402],{},"你可以發現我這邊特意使用了 ",[61,397,398],{},"id"," 來當作條件，因為假設使用 ",[61,401,89],{}," 來刪除是有可能導致同名的人都一起掰掰唷~",[16,404,405],{},"那麼我們可以先來看看結果王小明是不是真的被刪除了 ↓",[16,407,408],{},[147,409],{"alt":410,"src":411},"刪除成功","https:\u002F\u002Fi.imgur.com\u002F9Y9Se3c.png",[16,413,414,415,417],{},"最後讓我們來試驗剛剛我講的問題，使用 ",[61,416,89],{}," 來當作條件，並且試著讓我剛剛講的情況發生，首先先插入兩筆同名同姓的學生，但身高體重不一樣，順便講一下如何插入多筆資料：",[66,419,421],{"className":68,"code":420,"language":70,"meta":71,"style":71},"INSERT INTO hw_table (name, height, weight) VALUES ('王小明', 177.6, 70.5),('王小明', 156.6, 47.5);\n",[61,422,423],{"__ignoreMap":71},[75,424,425,427,429,431,433,435,437,439,441,443,445,447,449,451,453,455,457,459,462,464,466,469,471,473,475,478,480,482],{"class":77,"line":78},[75,426,82],{"class":81},[75,428,86],{"class":85},[75,430,89],{"class":81},[75,432,92],{"class":85},[75,434,95],{"class":81},[75,436,98],{"class":85},[75,438,101],{"class":81},[75,440,104],{"class":85},[75,442,108],{"class":107},[75,444,111],{"class":85},[75,446,115],{"class":114},[75,448,118],{"class":85},[75,450,121],{"class":114},[75,452,111],{"class":85},[75,454,126],{"class":114},[75,456,118],{"class":85},[75,458,131],{"class":114},[75,460,461],{"class":85},"),(",[75,463,108],{"class":107},[75,465,111],{"class":85},[75,467,468],{"class":114},"156",[75,470,118],{"class":85},[75,472,121],{"class":114},[75,474,111],{"class":85},[75,476,477],{"class":114},"47",[75,479,118],{"class":85},[75,481,131],{"class":114},[75,483,134],{"class":85},[16,485,486],{},"如果沒有問題的話，我們就可以看到兩個同名同姓的王小明，但身高體重不同的人 ↓",[16,488,489],{},[147,490],{"alt":491,"src":492},"不同人","https:\u002F\u002Fi.imgur.com\u002FMpGTSgD.png",[16,494,495,496,498],{},"接下來我們來輸入刪除的語法，然後使用 ",[61,497,89],{}," 來當作條件，然後準備來看結果吧~",[66,500,502],{"className":68,"code":501,"language":70,"meta":71,"style":71},"DELETE FROM hw_table WHERE name='王小明';\n",[61,503,504],{"__ignoreMap":71},[75,505,506,508,510,512,514,516,518],{"class":77,"line":78},[75,507,369],{"class":81},[75,509,372],{"class":81},[75,511,303],{"class":85},[75,513,342],{"class":81},[75,515,318],{"class":81},[75,517,108],{"class":107},[75,519,210],{"class":85},[16,521,522,523,526],{},"當你輸入執行完之後，你會發現只要是叫做",[53,524,525],{},"王小明","的學生，通通都被刪除了 ↓",[16,528,529],{},[147,530],{"alt":531,"src":532},"同名被刪除了","https:\u002F\u002Fi.imgur.com\u002Fjhf017k.png",[16,534,535],{},"所以由此可知，不論是使用刪除 or 更新，在使用條件時後，請務必要使用絕對值 (key)，否則會發生悲劇唷~",[12,537,538],{"id":538},"結尾",[16,540,541],{},"最後一樣讓我們來整理一下本篇所講到的 SQL 指令",[543,544,545,558],"table",{},[546,547,548],"thead",{},[549,550,551,555],"tr",{},[552,553,554],"th",{},"操作功能",[552,556,557],{},"SQL 語法",[559,560,561,573,588,600],"tbody",{},[549,562,563,566],{},[564,565,55],"td",{},[564,567,568,569,572],{},"INSERT INTO ",[75,570,571],{},"資料表名稱"," (欄位名稱1,欄位名稱2,...) VALUES (值,值,...);",[549,574,575,578],{},[564,576,577],{},"更新欄位",[564,579,580,581,583,584,587],{},"UPDATE ",[75,582,571],{}," SET 欄位名稱1='值' WHERE ",[75,585,586],{},"條件",";",[549,589,590,592],{},[564,591,356],{},[564,593,594,595,597,598,587],{},"DELETE FROM ",[75,596,571],{}," WHERE ",[75,599,586],{},[549,601,602,605],{},[564,603,604],{},"插入多筆欄位",[564,606,568,607,609],{},[75,608,571],{}," (欄位名稱1,欄位名稱2,...) VALUES (值1,值1,...),(值2,值2,...);",[611,612,613],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":71,"searchDepth":615,"depth":615,"links":616},2,[617,618,619,620,621,622],{"id":14,"depth":615,"text":14},{"id":21,"depth":615,"text":22},{"id":47,"depth":615,"text":48},{"id":286,"depth":615,"text":287},{"id":356,"depth":615,"text":356},{"id":538,"depth":615,"text":538},"PHP","2019-09-05 00:02:55","md","zh-Hant",{},true,"\u002Fthinkphp\u002Fday4-thinkphp-mysql-1","3",{"title":6,"description":18},false,"從基礎學習 ThinkPHP\u002FDay4-從基礎學習-ThinkPHP-基礎-MySQL-學習-資料篇-1",[623,635,636,637,638],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fphp\u002F20190905\u002F1275666548\u002F","5OCIFY1b9fU45aE8acRgtWVY43pqrUd-1iD3zFVDXts",{"newer":643,"older":647},{"url":644,"title":645,"date":646},"\u002Fphp\u002F20190906\u002F241727046\u002F","Day5-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料篇(2)","2019-09-06 00:07:55",{"url":648,"title":649,"date":650},"\u002Fphp\u002F20190904\u002F1799668484\u002F","Day3-從基礎學習 ThinkPHP-基礎 MySQL 學習-資料表篇","2019-09-04 09:02:58",[652,656,660],{"url":653,"title":654,"date":655,"readingMinutes":385},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41",{"url":657,"title":658,"date":659,"readingMinutes":385},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":661,"title":662,"date":663,"readingMinutes":630},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01",1784020399313]