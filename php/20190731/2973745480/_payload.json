[{"data":1,"prerenderedAt":323},["ShallowReactive",2],{"header-locale:\u002Fphp\u002F20190731\u002F2973745480\u002F":3,"page:\u002Fphp\u002F20190731\u002F2973745480\u002F":4,"alt:\u002Fphp\u002F20190731\u002F2973745480\u002F":3,"prev-next:\u002Fphp\u002F20190731\u002F2973745480\u002F":299,"related:\u002Fphp\u002F20190731\u002F2973745480\u002F":308},"\u002Fen\u002Fphp\u002F2019\u002F07\u002F31\u002Flaravel-vue-eslint-vscode-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":281,"date":282,"description":18,"extension":283,"lang":284,"meta":285,"navigation":286,"path":287,"readingMinutes":288,"seo":289,"standalone":290,"stem":291,"tags":292,"tldr":296,"updated":296,"url":297,"__hash__":298},"content\u002FPHP\u002FLaravel-Vue-ESLint-在-VSCode-上無法靜態使用的問題.md","Laravel-Vue ESLint 在 VSCode 上無法靜態使用的問題","2973745480",{"type":9,"value":10,"toc":275},"minimark",[11,15,19,23,26,84,87,114,117,124,127,131,134,185,191,197,201,204,265,268,271],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"由於最近專案開發上會使用到 Laravel-Vue，本身自己也會使用 ESLint 來管制自己得程式碼品質，但是不知道為什麼不管怎麼甚至就是沒有反應，所以這一篇來記錄一下怎麼解決",[12,20,22],{"id":21},"eslint-安裝","ESLint 安裝",[16,24,25],{},"要使用 ESLint 之前必須先安裝相關套件",[27,28,33],"pre",{"className":29,"code":30,"language":31,"meta":32,"style":32},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save-dev eslint eslint-config-airbnb-base eslint-plugin-import eslint-plugin-vue babel-eslint\n","js","",[34,35,36],"code",{"__ignoreMap":32},[37,38,41,45,49,52,55,58,60,63,65,68,70,73,75,78,81],"span",{"class":39,"line":40},"line",1,[37,42,44],{"class":43},"sMAXC","npm install ",[37,46,48],{"class":47},"sWyjQ","--",[37,50,51],{"class":43},"save",[37,53,54],{"class":47},"-",[37,56,57],{"class":43},"dev eslint eslint",[37,59,54],{"class":47},[37,61,62],{"class":43},"config",[37,64,54],{"class":47},[37,66,67],{"class":43},"airbnb",[37,69,54],{"class":47},[37,71,72],{"class":43},"base eslint",[37,74,54],{"class":47},[37,76,77],{"class":43},"plugin",[37,79,80],{"class":47},"-import",[37,82,83],{"class":43}," eslint-plugin-vue babel-eslint\n",[16,85,86],{},"總共會安裝這些套件",[88,89,90,94,97,104,107],"ul",{},[91,92,93],"li",{},"eslint - ESLint 核心",[91,95,96],{},"eslint-config-airbnb-base - 使用 airbnb 設定檔",[91,98,99,100,103],{},"eslint-plugin-import - 這個套件主要是要解決 ES6 語法 ",[34,101,102],{},"import\u002Fexport"," 會在 ESLint 上出現錯誤(依照官方是這樣講沒錯)",[91,105,106],{},"eslint-plugin-vue - 這是由 Vue 官方所推出的 ESLint 相依套件",[91,108,109,110,113],{},"babel-eslint - babel 所推出的相依套件，如果沒裝這個可能會出現一些怪問題，例如 ESLint 不認得 ",[34,111,112],{},"import"," 語法",[16,115,116],{},"如果你跟我一樣本身是使用 VSCode 的話是可以不用特別去安裝套件，因為 VSCode 本身內建就有安裝 ESLint 套件",[16,118,119],{},[120,121],"img",{"alt":122,"src":123},"ESLint 套件","https:\u002F\u002Fi.imgur.com\u002FotxKSkA.png",[16,125,126],{},"如果發現自己沒安裝就快安裝吧~",[12,128,130],{"id":129},"packagejson","Package.json",[16,132,133],{},"安裝好後我們要在 Laravel-Vue 的 Package.json 新增兩行指令",[27,135,139],{"className":136,"code":137,"language":138,"meta":32,"style":32},"language-json shiki shiki-themes github-dark-high-contrast","\"scripts\": {\n    \"lint\": \"eslint resources\u002Fjs\u002F**\u002F*.js\",\n    \"lint-vue\": \"eslint resources\u002Fjs\u002F**\u002F*.vue\",\n},\n","json",[34,140,141,150,166,179],{"__ignoreMap":32},[37,142,143,147],{"class":39,"line":40},[37,144,146],{"class":145},"sTRMh","\"scripts\"",[37,148,149],{"class":43},": {\n",[37,151,153,157,160,163],{"class":39,"line":152},2,[37,154,156],{"class":155},"sKpQp","    \"lint\"",[37,158,159],{"class":43},": ",[37,161,162],{"class":145},"\"eslint resources\u002Fjs\u002F**\u002F*.js\"",[37,164,165],{"class":43},",\n",[37,167,169,172,174,177],{"class":39,"line":168},3,[37,170,171],{"class":155},"    \"lint-vue\"",[37,173,159],{"class":43},[37,175,176],{"class":145},"\"eslint resources\u002Fjs\u002F**\u002F*.vue\"",[37,178,165],{"class":43},[37,180,182],{"class":39,"line":181},4,[37,183,184],{"class":43},"},\n",[16,186,187,188],{},"如果你想要檢測 js 的時候就輸入 ",[34,189,190],{},"npm run lint",[16,192,193,194],{},"但是如果你試想檢測 Vue 的話就是 ",[34,195,196],{},"npm run lint-vue",[12,198,200],{"id":199},"vs-code-靜態執行-eslint","VS Code 靜態執行 ESLint",[16,202,203],{},"基本上打開 VSCode 然後將以下程式碼加入即可",[27,205,207],{"className":136,"code":206,"language":138,"meta":32,"style":32},"\"eslint.validate\": [\n    \"javascript\",\n    \"javascriptreact\",\n    { \"language\": \"vue\", \"autoFix\": true }\n]\n",[34,208,209,217,224,231,259],{"__ignoreMap":32},[37,210,211,214],{"class":39,"line":40},[37,212,213],{"class":145},"\"eslint.validate\"",[37,215,216],{"class":43},": [\n",[37,218,219,222],{"class":39,"line":152},[37,220,221],{"class":145},"    \"javascript\"",[37,223,165],{"class":43},[37,225,226,229],{"class":39,"line":168},[37,227,228],{"class":145},"    \"javascriptreact\"",[37,230,165],{"class":43},[37,232,233,236,239,241,244,247,250,252,256],{"class":39,"line":181},[37,234,235],{"class":43},"    { ",[37,237,238],{"class":155},"\"language\"",[37,240,159],{"class":43},[37,242,243],{"class":145},"\"vue\"",[37,245,246],{"class":43},", ",[37,248,249],{"class":155},"\"autoFix\"",[37,251,159],{"class":43},[37,253,255],{"class":254},"sCcAr","true",[37,257,258],{"class":43}," }\n",[37,260,262],{"class":39,"line":261},5,[37,263,264],{"class":43},"]\n",[16,266,267],{},"這樣子你就會看到滿滿的毛毛蟲了，但是這個方式如果用於 Vue Cli 開發的模式似乎會出現各種毛毛蟲無法解析路徑...",[16,269,270],{},"所以最好的解決辦法就是養成習慣寫 airbnb 的模式吧XD",[272,273,274],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":32,"searchDepth":152,"depth":152,"links":276},[277,278,279,280],{"id":14,"depth":152,"text":14},{"id":21,"depth":152,"text":22},{"id":129,"depth":152,"text":130},{"id":199,"depth":152,"text":200},"PHP","2019-07-31 14:49:14","md","zh-Hant",{},true,"\u002Fphp\u002Flaravel-vue-eslint-vscode","1",{"title":6,"description":18},false,"PHP\u002FLaravel-Vue-ESLint-在-VSCode-上無法靜態使用的問題",[281,293,294,295],"Vue","Laravel","障礙排除",null,"\u002Fphp\u002F20190731\u002F2973745480\u002F","Bg5M94cFzJeP-bxw7Jx5gN6MOOUOI_39ecsSQ1q-xUs",{"newer":300,"older":304},{"url":301,"title":302,"date":303},"\u002Fnodejs\u002F20190801\u002F449913843\u002F","無法辨識 'XXX' 詞彙是否為 Cmdlet、函數、指令檔或可執行程式的名稱","2019-08-01 10:28:33",{"url":305,"title":306,"date":307},"\u002Fhexo\u002F20190730\u002F884035779\u002F","Hexo 指令失效","2019-07-30 11:51:48",[309,314,318],{"url":310,"title":311,"date":312,"readingMinutes":313},"\u002Fphp\u002F20220417\u002F3990325618\u002F","Mac XAMPP Apache 一直無法啟動解決方式","2022-04-17 14:32:41","2",{"url":315,"title":316,"date":317,"readingMinutes":313},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":319,"title":320,"date":321,"readingMinutes":322},"\u002Fphp\u002F20191001\u002F106986397\u002F","Day30-從基礎學習 ThinkPHP-部屬 Heroku","2019-10-01 00:00:01","3",1784020399247]