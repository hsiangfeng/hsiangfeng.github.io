[{"data":1,"prerenderedAt":146},["ShallowReactive",2],{"header-locale:\u002Ftailwindcss\u002F20220405\u002F1504568293\u002F":3,"page:\u002Ftailwindcss\u002F20220405\u002F1504568293\u002F":4,"alt:\u002Ftailwindcss\u002F20220405\u002F1504568293\u002F":3,"prev-next:\u002Ftailwindcss\u002F20220405\u002F1504568293\u002F":132,"related:\u002Ftailwindcss\u002F20220405\u002F1504568293\u002F":141},"\u002Fen\u002Ftailwindcss\u002F2022\u002F04\u002F05\u002Fvscode-unknown-at-rule-tailwind-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":93,"date":114,"description":18,"extension":115,"lang":116,"meta":117,"navigation":118,"path":119,"readingMinutes":120,"seo":121,"standalone":122,"stem":123,"tags":124,"tldr":129,"updated":129,"url":130,"__hash__":131},"content\u002FTailwindCSS\u002FVSCode-噴-Unknown-at-rule-tailwind-解決方式.md","VSCode 噴 Unknown at rule @tailwind 解決方式","1504568293",{"type":9,"value":10,"toc":107},"minimark",[11,15,19,22,25,32,38,41,60,63,75,89,95,98],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"Tailwind CSS 是一款 Units 導向的 CSS 框架，它的許多優勢讓大家趨之若鶩的學習與瞭解，但是在 VSCode 開發上時常會遇到 Unknown at rule @tailwind、Unknown at rule @apply 等錯誤訊息，所以這一篇來紀錄一下解決方式。",[12,20,21],{"id":21},"解決方式",[16,23,24],{},"TailwindCSS 基本上會與 PostCSS 一起合作運作的框架，因此在身為前端開發者來講一定很常用 VSCode 開發，但是一定很常看到這個東西",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"Unknown at rule @tailwind","https:\u002F\u002Fi.imgur.com\u002FKpv9XAG.png",[16,33,34],{},[28,35],{"alt":36,"src":37},"Unknown at rule @layer","https:\u002F\u002Fi.imgur.com\u002FyKNPdIj.png",[16,39,40],{},"雖然在開發上是沒有什麼太大影響，在 TailwindCSS 官方文件也有描述到這件事情",[42,43,44],"blockquote",{},[16,45,46,47,51,52,55,56,59],{},"Tailwind CSS uses a lot of custom CSS at-rules like ",[48,49,50],"code",{},"@tailwind",", ",[48,53,54],{},"@apply",", and ",[48,57,58],{},"@screen",", and in many editors this can trigger warnings or errors where these rules aren’t recognized.",[16,61,62],{},"上面簡單來講就是 TailwindCSS 有使用到一些 TailwindCSS 自己自定義的 CSS 語法，所以在許多編譯器在會無法辨別而導致出現錯誤或警告，例如...",[64,65,66,69,72],"ul",{},[67,68,30],"li",{},[67,70,71],{},"Unknown at rule @apply",[67,73,74],{},"Unknown at rule @layer\n...\n等等",[16,76,77,78,85,86,88],{},"而我們本身使用 TailwindCSS 都會搭配 PostCSS，所以就會有一個 postcss.config.js 設定檔，這時候我們只需要替自己的 VSCode 安裝 ",[79,80,84],"a",{"href":81,"rel":82},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=csstools.postcss",[83],"nofollow","PostCSS Language Support"," 套件就可以解決 ",[48,87,30],{}," 的問題囉。",[16,90,91],{},[28,92],{"alt":93,"src":94},"TailwindCSS","https:\u002F\u002Fi.imgur.com\u002FJAuiseU.png",[12,96,97],{"id":97},"參考文獻",[64,99,100],{},[67,101,102],{},[79,103,106],{"href":104,"rel":105},"https:\u002F\u002Ftailwindcss.com\u002Fdocs\u002Feditor-setup#intelli-sense-for-vs-code",[83],"Editor Setup",{"title":108,"searchDepth":109,"depth":109,"links":110},"",2,[111,112,113],{"id":14,"depth":109,"text":14},{"id":21,"depth":109,"text":21},{"id":97,"depth":109,"text":97},"2022-04-05 23:02:50","md","zh-Hant",{},true,"\u002Ftailwindcss\u002Fvscode-unknown-at-rule-tailwind","1",{"title":6,"description":18},false,"TailwindCSS\u002FVSCode-噴-Unknown-at-rule-tailwind-解決方式",[125,126,127,128],"Tailwind CSS","PostCSS","VSCode","Unknown",null,"\u002Ftailwindcss\u002F20220405\u002F1504568293\u002F","xVjbEqlyvXdm-FhKncLrGJb0HjwwzXnYrT7Y7KJVgNU",{"newer":133,"older":137},{"url":134,"title":135,"date":136},"\u002Fnodejs\u002F20220416\u002F981471357\u002F","(29)被迫吃芒果的前端工程師 - Atlas - MongoDB 連接","2022-04-16 20:40:13",{"url":138,"title":139,"date":140},"\u002Fnodejs\u002F20220405\u002F475293919\u002F","(28)被迫吃芒果的前端工程師 - Atlas - MongoDB Compass 教學","2022-04-05 22:30:31",[142],{"url":143,"title":144,"date":145,"readingMinutes":120},"\u002Ftailwindcss\u002F20220702\u002F88023210\u002F","讓 VSCode 的 Tailwind CSS IntelliSense 套件可以用於 React JSX","2022-07-02 21:32:31",1784020407996]