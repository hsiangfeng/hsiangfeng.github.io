[{"data":1,"prerenderedAt":342},["ShallowReactive",2],{"header-locale:\u002Ftailwindcss\u002F20220702\u002F88023210\u002F":3,"page:\u002Ftailwindcss\u002F20220702\u002F88023210\u002F":4,"alt:\u002Ftailwindcss\u002F20220702\u002F88023210\u002F":3,"prev-next:\u002Ftailwindcss\u002F20220702\u002F88023210\u002F":328,"related:\u002Ftailwindcss\u002F20220702\u002F88023210\u002F":337},"\u002Fen\u002Ftailwindcss\u002F2022\u002F07\u002F02\u002Ftailwind-intellisense-vite-react-jsx\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":309,"date":310,"description":18,"extension":311,"lang":312,"meta":313,"navigation":314,"path":315,"readingMinutes":316,"seo":317,"standalone":318,"stem":319,"tags":320,"tldr":325,"updated":325,"url":326,"__hash__":327},"content\u002FTailwindCSS\u002F讓-VSCode-的-Tailwind-CSS-IntelliSense-套件可以用於-React-JSX.md","讓 VSCode 的 Tailwind CSS IntelliSense 套件可以用於 React JSX","88023210",{"type":9,"value":10,"toc":303},"minimark",[11,15,19,22,25,32,35,41,44,47,50,160,170,173,272,275,281,284,287,290,299],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"原本在 CRA(Create React App) 環境下撰寫 Tailwind CSS 時 Tailwind CSS IntelliSense 套件都滿正常的，但不知道為什麼環境轉換到 Vite for React 之後就無法正常運作，所以這一篇記錄一下解決方式。",[12,20,21],{"id":21},"事發原因",[16,23,24],{},"在原本 CRA(Create React App) 環境撰寫 Tailwind CSS 可以正常讓 Tailwind CSS IntelliSense 套件出現下拉選單",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"CRA","https:\u002F\u002Fi.imgur.com\u002FDbqgSJW.png",[16,33,34],{},"但不知道為什麼環境轉移到 Vite for React 就無效了",[16,36,37],{},[28,38],{"alt":39,"src":40},"Vite","https:\u002F\u002Fi.imgur.com\u002Fi7SYwBK.png",[16,42,43],{},"所以記錄一下解決方式",[12,45,46],{"id":46},"解決方式",[16,48,49],{},"一開始我懷疑是副檔名問題，但 Vite 環境下基本上都是 .jsx，所以這一點不可能，而 Tailwind CSS IntelliSense 會去檢測 tailwind.config.js 所以也有懷疑過是不是設定檔有問題",[51,52,57],"pre",{"className":53,"code":54,"language":55,"meta":56,"style":56},"language-js shiki shiki-themes github-dark-high-contrast","\u002F** @type {import('tailwindcss').Config} *\u002F\nmodule.exports = {\n  content: [\n    \".\u002Findex.html\",\n    \".\u002Fsrc\u002F**\u002F*.{js,ts,jsx,tsx}\",\n  ],\n  theme: {\n    extend: {},\n  },\n  plugins: [],\n}\n","js","",[58,59,60,80,100,106,116,124,130,136,142,148,154],"code",{"__ignoreMap":56},[61,62,65,69,73,77],"span",{"class":63,"line":64},"line",1,[61,66,68],{"class":67},"sQrFR","\u002F** ",[61,70,72],{"class":71},"sWyjQ","@type",[61,74,76],{"class":75},"s_sBn"," {import('tailwindcss').Config}",[61,78,79],{"class":67}," *\u002F\n",[61,81,83,87,91,94,97],{"class":63,"line":82},2,[61,84,86],{"class":85},"sCcAr","module",[61,88,90],{"class":89},"sMAXC",".",[61,92,93],{"class":85},"exports",[61,95,96],{"class":71}," =",[61,98,99],{"class":89}," {\n",[61,101,103],{"class":63,"line":102},3,[61,104,105],{"class":89},"  content: [\n",[61,107,109,113],{"class":63,"line":108},4,[61,110,112],{"class":111},"sTRMh","    \".\u002Findex.html\"",[61,114,115],{"class":89},",\n",[61,117,119,122],{"class":63,"line":118},5,[61,120,121],{"class":111},"    \".\u002Fsrc\u002F**\u002F*.{js,ts,jsx,tsx}\"",[61,123,115],{"class":89},[61,125,127],{"class":63,"line":126},6,[61,128,129],{"class":89},"  ],\n",[61,131,133],{"class":63,"line":132},7,[61,134,135],{"class":89},"  theme: {\n",[61,137,139],{"class":63,"line":138},8,[61,140,141],{"class":89},"    extend: {},\n",[61,143,145],{"class":63,"line":144},9,[61,146,147],{"class":89},"  },\n",[61,149,151],{"class":63,"line":150},10,[61,152,153],{"class":89},"  plugins: [],\n",[61,155,157],{"class":63,"line":156},11,[61,158,159],{"class":89},"}\n",[16,161,162,163],{},"但其實也是正確沒事，後來找到這一篇",[164,165,169],"a",{"href":166,"rel":167},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F63190041\u002Ftailwind-css-intellisense-does-not-provide-suggestions-in-a-reactjs-project",[168],"nofollow","Tailwind CSS IntelliSense does not provide suggestions in a ReactJS project?",[16,171,172],{},"看內文雖然是在講 CRA(Create React App) 的環境的設定，所以這讓我聯想到 Emmet 的相關設置，所以改成以下",[51,174,178],{"className":175,"code":176,"languag