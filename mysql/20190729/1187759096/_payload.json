[{"data":1,"prerenderedAt":463},["ShallowReactive",2],{"header-locale:\u002Fmysql\u002F20190729\u002F1187759096\u002F":3,"page:\u002Fmysql\u002F20190729\u002F1187759096\u002F":4,"alt:\u002Fmysql\u002F20190729\u002F1187759096\u002F":3,"prev-next:\u002Fmysql\u002F20190729\u002F1187759096\u002F":453,"related:\u002Fmysql\u002F20190729\u002F1187759096\u002F":462},"\u002Fen\u002Fmysql\u002F2019\u002F07\u002F29\u002Finstalling-mysql-8-0-17\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":22,"date":438,"description":18,"extension":439,"lang":440,"meta":441,"navigation":442,"path":443,"readingMinutes":444,"seo":445,"standalone":446,"stem":447,"tags":448,"tldr":450,"updated":450,"url":451,"__hash__":452},"content\u002FMySQL\u002FMySQL-8.0.17.0-環境安裝.md","MySQL 8.0.17.0 環境安裝","1187759096",{"type":9,"value":10,"toc":425},"minimark",[11,15,19,23,34,41,44,50,53,59,62,68,76,81,84,87,92,95,101,104,123,129,132,138,141,147,150,156,159,164,167,172,175,183,189,192,198,201,209,212,215,221,224,230,233,239,242,253,258,263,266,271,274,279,282,287,290,296,299,305,308,314,318,321,327,331,338,343,347,350,365,368,377,383,387,390,399,402,405,411,414,421],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇將會記錄 MySQL 5.7 以上的安裝流程，避免自己以後金魚腦忘記怎麼安裝",[12,20,22],{"id":21},"mysql","MySQL",[16,24,25,26,33],{},"首先開啟 MySQL 官方網站 ",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Fwww.mysql.com\u002F",[31],"nofollow","連結","，並點一下上方 DOWNLOADS",[16,35,36],{},[37,38],"img",{"alt":39,"src":40},"官方網站","https:\u002F\u002Fi.imgur.com\u002FDC6hkC1.png",[16,42,43],{},"接下來點一下 Windows",[16,45,46],{},[37,47],{"alt":48,"src":49},"Windows","https:\u002F\u002Fi.imgur.com\u002FIPXZbh0.png",[16,51,52],{},"然後在選 MySQL Install",[16,54,55],{},[37,56],{"alt":57,"src":58},"MySQL Install","https:\u002F\u002Fi.imgur.com\u002Ft5oo2Sc.png",[16,60,61],{},"接下來滾輪像下滑並下載 393.4 M 的檔案",[16,63,64],{},[37,65],{"alt":66,"src":67},"下載","https:\u002F\u002Fi.imgur.com\u002FqhMpeWu.png",[16,69,70,71,75],{},"最後點一下下方的 ",[72,73,74],"code",{},"No thanks, just start my download.","，就開始下載了",[16,77,78],{},[37,79],{"alt":74,"src":80},"https:\u002F\u002Fi.imgur.com\u002F3eZnMGo.png",[12,82,83],{"id":83},"安裝",[16,85,86],{},"下載完畢之後打開安裝檔案",[16,88,89],{},[37,90],{"alt":83,"src":91},"https:\u002F\u002Fi.imgur.com\u002FdO8h8tx.png",[16,93,94],{},"然後就會出現同意視窗",[16,96,97],{},[37,98],{"alt":99,"src":100},"同意視窗","https:\u002F\u002Fi.imgur.com\u002FINqZ2P7.png",[16,102,103],{},"這邊可以自己選擇所需要的安裝，這邊我是選擇第一個預設即可",[105,106,107,111,114,117,120],"ul",{},[108,109,110],"li",{},"Developer Defalut - 開發人員預設",[108,112,113],{},"Server only - 僅限伺服器",[108,115,116],{},"Client only - 僅限客戶端",[108,118,119],{},"Full - 完整功能",[108,121,122],{},"Custom - 自訂",[16,124,125],{},[37,126],{"alt":127,"src":128},"安裝模式","https:\u002F\u002Fi.imgur.com\u002Ff7ffX6E.png",[16,130,131],{},"接下來會跳出他所需要的相依套件，基本上你可以直接按 Next",[16,133,134],{},[37,135],{"alt":136,"src":137},"Next","https:\u002F\u002Fi.imgur.com\u002FgL7gWEl.png",[16,139,140],{},"這時候會跳出警告視窗，按下 Yes 即可",[16,142,143],{},[37,144],{"alt":145,"src":146},"yes","https:\u002F\u002Fi.imgur.com\u002FAZRUN4Q.png",[16,148,149],{},"這一步驟就直接按下 Execute 即可開始安裝(安裝過程稍微有點久，稍微等一下)",[16,151,152],{},[37,153],{"alt":154,"src":155},"Execute","https:\u002F\u002Fi.imgur.com\u002F2he8Wns.png",[16,157,158],{},"安裝完畢後就直接按 Next",[16,160,161],{},[37,162],{"alt":136,"src":163},"https:\u002F\u002Fi.imgur.com\u002FBsGMhVi.png",[16,165,166],{},"這邊直接按 Next 沒關係",[16,168,169],{},[37,170],{"alt":136,"src":171},"https:\u002F\u002Fi.imgur.com\u002FxrBd6c5.png",[16,173,174],{},"接下來這邊我是選擇第一個",[105,176,177,180],{},[108,178,179],{},"Standalone MySQL Server\u002FClassic MySQL Replication - 獨立 MySQL \u002F 經典 MySQL",[108,181,182],{},"InnoDB Cluster - InnoDB 集合",[16,184,185],{},[37,186],{"alt":187,"src":188},"Standalone MySQL Server","https:\u002F\u002Fi.imgur.com\u002FMywhRil.png",[16,190,191],{},"接下來這邊是設置 MySQL 相關參數，例如你的 Prot 等等，但是基本上不用動到設置一樣 Next 即可",[16,193,194],{},[37,195],{"alt":196,"src":197},"MySQL 相關參數","https:\u002F\u002Fi.imgur.com\u002F9B7KfNA.png",[16,199,200],{},"這邊是選擇你的身分認證的方法，基本上就是選擇第一個",[105,202,203,206],{},[108,204,205],{},"Use Strong Password Encryption for Authentication(RECOMMENDED) - 使用強密碼加密認證方法",[108,207,208],{},"Use Legacy Authentication Method(Retain MySQL5.X Compatibility) - 傳統認證方法",[16,210,211],{},"※ 注意，如果你選擇了 Use Strong Password Encryption for Authentication(RECOMMENDED) 那麼如果你跟我一樣是使用 Navicat 就會出現無法使用的問題，我在結尾有補上該如何解決",[16,213,214],{},"※ 這邊還是建議選擇 Use Legacy Authentication Method(Retain MySQL5.X Compatibility) 可以減少很多問題，也可以使用 Navicat",[16,216,217],{},[37,218],{"alt":219,"src":220},"Use Strong Password Encryption for Authenticatio","https:\u002F\u002Fi.imgur.com\u002F0f9GmTl.png",[16,222,223],{},"這邊要注意安全性問題，前面是輸入 root 密碼，這組非常重要，千萬不要外流，因為 root 帳號是 MySQL 最高權限者",[16,225,226],{},[37,227],{"alt":228,"src":229},"root","https:\u002F\u002Fi.imgur.com\u002FSaeIHig.png",[16,231,232],{},"然後新增一個使用者",[16,234,235],{},[37,236],{"alt":237,"src":238},"新增使用者","https:\u002F\u002Fi.imgur.com\u002FbsyPGWz.png",[16,240,241],{},"這邊依照自己需求去做調整",[105,243,244,247,250],{},[108,245,246],{},"UserName - 使用者帳號",[108,248,249],{},"Host - 可以登入的網域，百分比(%) 代表任何網域都可以",[108,251,252],{},"Role - 權限",[16,254,255],{},[37,256],{"alt":237,"src":257},"https:\u002F\u002Fi.imgur.com\u002Ffe3PyTI.png",[16,259,260],{},[37,261],{"alt":237,"src":262},"https:\u002F\u002Fi.imgur.com\u002FWly4TwL.png",[16,264,265],{},"接下來這邊是將 MySQL 設置為 Window 服務，但是這邊不用調整太多可以直接 Next",[16,267,268],{},[37,269],{"alt":22,"src":270},"https:\u002F\u002Fi.imgur.com\u002FfLatDCO.png",[16,272,273],{},"但是這邊有一個地方可以自己決定是否調整，也就是系統啟動時自動啟動 MySQL 服務",[16,275,276],{},[37,277],{"alt":22,"src":278},"https:\u002F\u002Fi.imgur.com\u002FiifCa11.png",[16,280,281],{},"這邊主要是 check 你剛剛的設定而已，沒問題就點 Execute",[16,283,284],{},[37,285],{"alt":154,"src":286},"https:\u002F\u002Fi.imgur.com\u002FxpRoasN.png",[16,288,289],{},"設定檔跑完就可以按下 Finish 完成",[16,291,292],{},[37,293],{"alt":294,"src":295},"Finish","https:\u002F\u002Fi.imgur.com\u002FZWflTzP.png",[16,297,298],{},"這邊只是要問你要不要再針對產品設置而已，可以點 Cancel 取消",[16,300,301],{},[37,302],{"alt":303,"src":304},"Cancel","https:\u002F\u002Fi.imgur.com\u002FpHq5fz8.png",[16,306,307],{},"接下來就點下 Yes 即可",[16,309,310],{},[37,311],{"alt":312,"src":313},"Yes","https:\u002F\u002Fi.imgur.com\u002FeLSA6Mu.png",[12,315,317],{"id":316},"如何知道自己-mysql已啟用","如何知道自己 MySQL　已啟用",[16,319,320],{},"叫出工作管理員，然後點服務找一下 MySQL 8 就可以知道狀態了",[16,322,323],{},[37,324],{"alt":325,"src":326},"Image","https:\u002F\u002Fi.imgur.com\u002FHT6uJHh.png",[12,328,330],{"id":329},"進入-mysql","進入 MySQL",[16,332,333,334,337],{},"進入 MySQL 會使用 ",[72,335,336],{},"MySQL 8.0 Command Line Client"," 點擊這個檔案，並輸入密碼就可以進入 MySQL 了",[16,339,340],{},[37,341],{"alt":336,"src":342},"https:\u002F\u002Fi.imgur.com\u002FhFyFIv7.png",[344,345,346],"h3",{"id":346},"當前使用者",[16,348,349],{},"那麼該如何查當前登入的使用者是誰，輸入以下指令即可",[351,352,356],"pre",{"className":353,"code":354,"language":21,"meta":355,"style":355},"language-mysql shiki shiki-themes github-dark-high-contrast","select user();\n","",[72,357,358],{"__ignoreMap":355},[359,360,363],"span",{"class":361,"line":362},"line",1,[359,364,354],{},[16,366,367],{},"OR",[351,369,371],{"className":353,"code":370,"language":21,"meta":355,"style":355},"SELECT CURRENT_USER();\n",[72,372,373],{"__ignoreMap":355},[359,374,375],{"class":361,"line":362},[359,376,370],{},[16,378,379],{},[37,380],{"alt":381,"src":382},"當前登入的使用者","https:\u002F\u002Fi.imgur.com\u002FpbYjtuo.png",[344,384,386],{"id":385},"查看當前-mysql-版本","查看當前 MySQL 版本",[16,388,389],{},"只需要輸入以下指令即可",[351,391,393],{"className":353,"code":392,"language":21,"meta":355,"style":355},"mysql -V\n",[72,394,395],{"__ignoreMap":355},[359,396,397],{"class":361,"line":362},[359,398,392],{},[12,400,401],{"id":401},"補充",[16,403,404],{},"由於我都習慣使用 Navicat for MySQL",[16,406,407,408],{},"但是在連結時卻出現 ",[72,409,410],{},"client does not support authentication protocol requested by server",[16,412,413],{},"那麼這問題是出在 MySQL8 的加密規則，所以如果要使用 Navicat 就要使用比較新的 Navicat 或是調整 MySQL8 加密規則，可參考以下文章調整",[16,415,416],{},[27,4