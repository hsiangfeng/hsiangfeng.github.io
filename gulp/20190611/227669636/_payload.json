[{"data":1,"prerenderedAt":254},["ShallowReactive",2],{"header-locale:\u002Fgulp\u002F20190611\u002F227669636\u002F":3,"page:\u002Fgulp\u002F20190611\u002F227669636\u002F":4,"alt:\u002Fgulp\u002F20190611\u002F227669636\u002F":3,"prev-next:\u002Fgulp\u002F20190611\u002F227669636\u002F":231,"related:\u002Fgulp\u002F20190611\u002F227669636\u002F":240},"\u002Fen\u002Fgulp\u002F2019\u002F06\u002F11\u002Fgulp-series-12-parallel-tasks\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":213,"date":214,"description":18,"extension":215,"lang":216,"meta":217,"navigation":218,"path":219,"readingMinutes":220,"seo":221,"standalone":222,"stem":223,"tags":224,"tldr":228,"updated":228,"url":229,"__hash__":230},"content\u002F這是在講 Gulp 不是飲料是任務自動化工具這件事\u002F這是在講-Gulp-不是飲料是任務自動化工具這件事：同步執行-Task.md","這是在講 Gulp 不是飲料是任務自動化工具這件事：同步執行 Task","227669636",{"type":9,"value":10,"toc":207},"minimark",[11,15,19,22,33,36,96,107,113,120,123,126,170,173,178,185,188,193,196,203],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"當我們 task 越寫越多的時候，我們通常都會希望能夠一個指令執行所有 task，不然每次都要 gulp scss、gulp babel...",[12,20,21],{"id":21},"起手式",[16,23,24,25,32],{},"早期 Gulp 3 是沒有所謂的同步執行 task，以往都是必須使用 ",[26,27,31],"a",{"href":28,"rel":29},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fgulp-sequence",[30],"nofollow","gulp-sequence"," 來達到目的，但是由於我們所撰寫的是 Gulp 4，那就不需要安裝這個套件來達到我們所需要的目的了，因為 Gulp 4 本身就已經開始支援同步執行與非同步執行的語法囉",[16,34,35],{},"那撰寫的方式如下",[37,38,43],"pre",{"className":39,"code":40,"language":41,"meta":42,"style":42},"language-js shiki shiki-themes github-dark-high-contrast","gulp.task('default',gulp.series('copyHTML','scss','babel','image'))\n","js","",[44,45,46],"code",{"__ignoreMap":42},[47,48,51,55,59,62,66,69,72,74,77,80,83,85,88,90,93],"span",{"class":49,"line":50},"line",1,[47,52,54],{"class":53},"sMAXC","gulp.",[47,56,58],{"class":57},"sj_SG","task",[47,60,61],{"class":53},"(",[47,63,65],{"class":64},"sTRMh","'default'",[47,67,68],{"class":53},",gulp.",[47,70,71],{"class":57},"series",[47,73,61],{"class":53},[47,75,76],{"class":64},"'copyHTML'",[47,78,79],{"class":53},",",[47,81,82],{"class":64},"'scss'",[47,84,79],{"class":53},[47,86,87],{"class":64},"'babel'",[47,89,79],{"class":53},[47,91,92],{"class":64},"'image'",[47,94,95],{"class":53},"))\n",[16,97,98,99,102,103,106],{},"你會發現 task 任務名稱是 ",[44,100,101],{},"default","，這個命名方式可以方面我們只輸入 ",[44,104,105],{},"gulp"," 就執行所有任務",[16,108,109],{},[110,111],"img",{"alt":101,"src":112},"https:\u002F\u002Fi.imgur.com\u002FTRThLvX.png",[16,114,115,116,119],{},"但是這邊要注意，如果你出現 ",[44,117,118],{},"TypeError: gulp.series is not a function"," 這個錯誤訊息，代表有可能你的 Gulp 版本並不是 Gulp 4 唷",[16,121,122],{},"那本身 Gulp 4 有提供兩個 api，一個是我所使用的 gulp.series，另一個則是 gulp.parallel",[16,124,125],{},"gulp.parallel 可以同時執行兩個任務的意思，例如這樣寫",[37,127,129],{"className":39,"code":128,"language":41,"meta":42,"style":42},"gulp.task('default', gulp.series('copyHTML','scss', gulp.parallel('babel','image')));\n",[44,130,131],{"__ignoreMap":42},[47,132,133,135,137,139,141,144,146,148,150,152,154,156,159,161,163,165,167],{"class":49,"line":50},[47,134,54],{"class":53},[47,136,58],{"class":57},[47,138,61],{"class":53},[47,140,65],{"class":64},[47,142,143],{"class":53},", gulp.",[47,145,71],{"class":57},[47,147,61],{"class":53},[47,149,76],{"class":64},[47,151,79],{"class":53},[47,153,82],{"class":64},[47,155,143],{"class":53},[47,157,158],{"class":57},"parallel",[47,160,61],{"class":53},[47,162,87],{"class":64},[47,164,79],{"class":53},[47,166,92],{"class":64},[47,168,169],{"class":53},")));\n",[16,171,172],{},"當你輸入 gulp 之後你可以發現這兩個任務會同時執行，然後同時結束",[16,174,175],{},[110,176],{"alt":158,"src":177},"https:\u002F\u002Fi.imgur.com\u002Fz5hqr8z.png",[16,179,180,181,184],{},"但是認真講，我自己本身也只有使用過 ",[44,182,183],{},"gulp.series"," 而已",[16,186,187],{},"如果不夠清楚可以看這張圖片",[16,189,190],{},[110,191],{"alt":105,"src":192},"https:\u002F\u002Fi.imgur.com\u002FZoTslB2.png",[12,194,195],{"id":195},"參考文獻",[16,197,198],{},[26,199,202],{"href":200,"rel":201},"https:\u002F\u002Fsegmentfault.com\u002