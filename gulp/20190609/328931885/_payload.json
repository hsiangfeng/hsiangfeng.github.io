[{"data":1,"prerenderedAt":142},["ShallowReactive",2],{"header-locale:\u002Fgulp\u002F20190609\u002F328931885\u002F":3,"page:\u002Fgulp\u002F20190609\u002F328931885\u002F":4,"alt:\u002Fgulp\u002F20190609\u002F328931885\u002F":3,"prev-next:\u002Fgulp\u002F20190609\u002F328931885\u002F":119,"related:\u002Fgulp\u002F20190609\u002F328931885\u002F":128},"\u002Fen\u002Fgulp\u002F2019\u002F06\u002F09\u002Fgulp-series-01-intro\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":31,"date":102,"description":18,"extension":103,"lang":104,"meta":105,"navigation":106,"path":107,"readingMinutes":108,"seo":109,"standalone":110,"stem":111,"tags":112,"tldr":116,"updated":116,"url":117,"__hash__":118},"content\u002F這是在講 Gulp 不是飲料是任務自動化工具這件事\u002F這是在講-Gulp-不是飲料是任務自動化工具這件事：Gulp-介紹.md","這是在講 Gulp 不是飲料是任務自動化工具這件事：Gulp 介紹","328931885",{"type":9,"value":10,"toc":95},"minimark",[11,15,19,23,26,33,36,42,46,56,59,62,72,75,78,81,88],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"在早期我接觸前端第一個靜態網頁開發工具就是 Gulp，往往許多人會把 Gulp 與 Webpack 傻傻分不清楚，當然我自己也是，在我還沒撰寫 Webpack 文章之前我只覺得 Webpack 超級像 Gulp，但是寫過一次就發現完全是不同的東西，所以這邊就來介紹一下 Gulp 是什麼東西，而且我個人也滿喜歡 Gulp 開發的:D",[12,20,22],{"id":21},"gulp-能吃嗎","Gulp 能吃嗎?",[16,24,25],{},"首先 Gulp 的代表性圖片是一杯飲料",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"Gulp","https:\u002F\u002Fi.imgur.com\u002F5JvvHSg.png",[16,34,35],{},"其實會在許多地方看到 Gulp 這個工具，那 Gulp 到底是什麼東西? Gulp 其實是一個自動化工具，它會依照任務 (task) 順序來執行，你可以把它想像成你必須把一杯飲料喝完你才能喝下一杯的概念，當然也有人會把它形容是一個水管工，因為 Gulp 可以像水管一樣一直接下去",[16,37,38],{},[29,39],{"alt":40,"src":41},"水管工","https:\u002F\u002Fi.imgur.com\u002F5WE21J3.png",[12,43,45],{"id":44},"為什麼要學-gulp","為什麼要學 Gulp?",[16,47,48,49],{},"Gulp vs Webpack 這個話題絕對是最常被拿出來做比較的，如果你真的很好奇你可以看看這篇文章 ",[50,51,55],"a",{"href":52,"rel":53},"https:\u002F\u002Fwww.cnblogs.com\u002Fiovec\u002Fp\u002F7921177.html",[54],"nofollow","前端构建工具之争——Webpack vs Gulp 谁会被拍死在沙滩上",[16,57,58],{},"對於前端開發者而言，其實多學一個技能也是替自己多一個機會，所以下一篇會正式開始講解開如何安裝及撰寫 Gulp 唷~",[16,60,61],{},"但是在那之前我們可以先準備幾個東西",[63,64,65,69],"ul",{},[66,67,68],"li",{},"nodejs",[66,70,71],{},"文字編輯器(推薦 VS Code)",[16,73,74],{},"由於 Gulp 背後的程式是 Nodejs，所以一定要記得先安裝唷~",[16,76,77],{},"(建議安裝 LTS，不要安裝 Current，避免出現一些奇怪的問題)",[16,79,80],{},"LTS: 穩定版也就是長期維護版\nCurrent: 先行版也就是目前最新版",[16,82,83],{},[50,84,87],{"href":85,"rel":86},"https:\u002F\u002Fnodejs.org\u002Fen\u002F",[54],"Nodejs官網-英文",[16,89,90],{},[50,91,94],{"href":92,"rel":93},"https:\u002F\u002Fnodejs.org\u002Fzh-tw\u002F",[54],"Nodejs官網-繁體中文",{"title":96,"searchDepth":97,"depth":97,"links":98},"",2,[99,100,101],{"id":14,"depth":97,"text":14},{"id":21,"depth":97,"text":22},{"id":44,"depth":97,"text":45},"2019-06-09 22:31:59","md","zh-Hant",{},true,"\u002Fgulp\u002Fgulp-gulp","1",{"title":6,"description":18},false,"這是在講 Gulp 不是飲料是任務自動化工具這件事\u002F這是在講-Gulp-不是飲料是任務自動化工具這件事：Gulp-介紹",[31,113,114,115],"Node.js","Gulp 4","這是在講 Gulp 不是飲料是任務自動化工具這件事",null,"\u002Fgulp\u002F20190609\u002F328931885\u002F","tvEd-Mt_a2yZ9o_YzgkptmLC4BejAKV_Xe3MkUiEaU4",{"newer":120,"older":124},{"url":121,"title":122,"date":123},"\u002Fgulp\u002F20190610\u002F1454585646\u002F","這是在講 Gulp 不是飲料是任務自動化工具這件事：Gulp 安裝篇","2019-06-10 10:09:08",{"url":125,"title":126,"date":127},"\u002Fwebpack\u002F20190609\u002F2531385750\u002F","EP-12-關於-Webpack-學習這件小事之 CSS 壓縮","2019-06-09 22:17:57",[129,134,138],{"url":130,"title":131,"date":132,"readingMinutes":133},"\u002Fgulp\u002F20221118\u002F111080074\u002F","解決使用 Gulp 發生 regeneratorRuntime is not defined 問題","2022-11-18 09:45:25","2",{"url":135,"title":136,"date":137,"readingMinutes":108},"\u002Fgulp\u002F20191220\u002F1507807439\u002F","Gulp deploy 發生 TypeError: Cannot read property 0 of null","2019-12-20 14:48:05",{"url":139,"title":140,"date":141,"readingMinutes":133},"\u002Fgulp\u002F20191213\u002F3886861343\u002F","這是在講 Gulp 不是飲料是任務自動化工具這件事之番外篇：將 Gulp deploy(部屬) Heroku","2019-12-13 21:37:33",1784012794281]