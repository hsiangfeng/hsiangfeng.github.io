[{"data":1,"prerenderedAt":211},["ShallowReactive",2],{"header-locale:\u002Fgulp\u002F20190610\u002F3799273831\u002F":3,"page:\u002Fgulp\u002F20190610\u002F3799273831\u002F":4,"alt:\u002Fgulp\u002F20190610\u002F3799273831\u002F":3,"prev-next:\u002Fgulp\u002F20190610\u002F3799273831\u002F":188,"related:\u002Fgulp\u002F20190610\u002F3799273831\u002F":197},"\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-07-simplify\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":170,"date":171,"description":18,"extension":172,"lang":173,"meta":174,"navigation":175,"path":176,"readingMinutes":177,"seo":178,"standalone":179,"stem":180,"tags":181,"tldr":185,"updated":185,"url":186,"__hash__":187},"content\u002F這是在講 Gulp 不是飲料是任務自動化工具這件事\u002F這是在講-Gulp-不是飲料是任務自動化工具這件事：簡化-Gulp-流程.md","這是在講 Gulp 不是飲料是任務自動化工具這件事：簡化 Gulp 流程","3799273831",{"type":9,"value":10,"toc":164},"minimark",[11,15,19,23,30,66,69,74,105,108,115,125,135,146,155,160],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"目前我們還沒加入 bebal 等等任務工具，但是就可以發現越來越多 require，所以這邊就來介紹該如何簡化 Gulp 流程",[12,20,22],{"id":21},"簡化-gulp-流程","簡化 Gulp 流程",[16,24,25,26],{},"首先簡化 Gulp 流程之前必須使用到一個套件叫 ",[27,28,29],"code",{},"gulp-load-plugins",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save gulp-load-plugins\n","js","",[27,38,39],{"__ignoreMap":36},[40,41,44,48,52,55,58,61,63],"span",{"class":42,"line":43},"line",1,[40,45,47],{"class":46},"sMAXC","npm install ",[40,49,51],{"class":50},"sWyjQ","--",[40,53,54],{"class":46},"save gulp",[40,56,57],{"class":50},"-",[40,59,60],{"class":46},"load",[40,62,57],{"class":50},[40,64,65],{"class":46},"plugins\n",[12,67,68],{"id":68},"使用方式",[16,70,71,73],{},[27,72,29],{}," 該如何使用呢?廢話不多說，先引入再說",[31,75,77],{"className":33,"code":76,"language":35,"meta":36,"style":36},"const $ = require('gulp-load-plugins');\n",[27,78,79],{"__ignoreMap":36},[40,80,81,84,88,91,95,98,102],{"class":42,"line":43},[40,82,83],{"class":50},"const",[40,85,87],{"class":86},"sCcAr"," $",[40,89,90],{"class":50}," =",[40,92,94],{"class":93},"sj_SG"," require",[40,96,97],{"class":46},"(",[40,99,101],{"class":100},"sTRMh","'gulp-load-plugins'",[40,103,104],{"class":46},");\n",[16,106,107],{},"接下來將下面這幾個的套件全部移除",[16,109,110],{},[111,112],"img",{"alt":113,"src":114},"移除","https:\u002F\u002Fi.imgur.com\u002FfJyp8Bh.png",[16,116,117,118,121],{},"這時候再將下面原本移除的套件加上 ",[27,119,120],{},"$.",[111,122],{"alt":123,"src":124},"$","https:\u002F\u002Fi.imgur.com\u002FrPMYSc3.png",[16,126,127,128,131,132],{},"接下來執行 ",[27,129,130],{},"gulp scss --env prod"," 有可能會出現錯誤訊息 ",[27,133,134],{},"TypeError: Cannot read property 'init' of undefined",[16,136,137,138,141,142,145],{},"只需要將 ",[27,139,140],{},"const $ = require('gulp-load-plugins');"," 改成 ",[27,143,144],{},"const $ = require('gulp-load-plugins')({lazy:false});"," 即可解決",[16,147,148,149,151,152,154],{},"通過 ",[27,150,29],{}," 我們可以發現少超多 require，但是要注意 ",[27,153,29],{}," 只支援有整合進 gulp 的(舉例套件開頭是 gulp-XXXX)",[16,156,157],{},[111,158],{"alt":29,"src":159},"https:\u002F\u002Fi.imgur.com\u002FvAA32i3.png",[161,162,163],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF