[{"data":1,"prerenderedAt":462},["ShallowReactive",2],{"header-locale:\u002Fgulp\u002F20190610\u002F1454585646\u002F":3,"page:\u002Fgulp\u002F20190610\u002F1454585646\u002F":4,"alt:\u002Fgulp\u002F20190610\u002F1454585646\u002F":3,"prev-next:\u002Fgulp\u002F20190610\u002F1454585646\u002F":438,"related:\u002Fgulp\u002F20190610\u002F1454585646\u002F":447},"\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":420,"date":421,"description":18,"extension":422,"lang":423,"meta":424,"navigation":425,"path":426,"readingMinutes":427,"seo":428,"standalone":429,"stem":430,"tags":431,"tldr":435,"updated":435,"url":436,"__hash__":437},"content\u002F這是在講 Gulp 不是飲料是任務自動化工具這件事\u002F這是在講-Gulp-不是飲料是任務自動化工具這件事：Gulp-安裝篇.md","這是在講 Gulp 不是飲料是任務自動化工具這件事：Gulp 安裝篇","1454585646",{"type":9,"value":10,"toc":412},"minimark",[11,15,19,23,26,29,38,45,48,55,58,66,69,75,79,82,92,105,111,121,131,156,159,174,181,187,190,197,203,206,212,215,224,227,253,256,271,274,280,283,289,292,301,307,313,319,322,336,339,346,349,355,358,361,364,388,408],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇已經稍微瞭解 Gulp 是什麼東西，那這篇就會開始從頭教學安裝 Gulp，另外這邊會開著 CMD 來操作許多動作，所以記得先開起來唷!",[12,20,22],{"id":21},"安裝-nodejs","安裝 Node.js",[16,24,25],{},"在前面有講到要先安裝 Node.js 才可以，所以如果才沒安裝那就快去安裝吧~",[16,27,28],{},"LTS: 穩定版也就是長期維護版\nCurrent: 先行版也就是目前最新版",[16,30,31],{},[32,33,37],"a",{"href":34,"rel":35},"https:\u002F\u002Fnodejs.org\u002Fen\u002F",[36],"nofollow","Nodejs官網-英文",[16,39,40],{},[32,41,44],{"href":42,"rel":43},"https:\u002F\u002Fnodejs.org\u002Fzh-tw\u002F",[36],"Nodejs官網-繁體中文",[16,46,47],{},"當然我個人推薦安裝 LTS 版即可",[16,49,50],{},[51,52],"img",{"alt":53,"src":54},"LTS","https:\u002F\u002Fi.imgur.com\u002FTCkPeqn.png",[16,56,57],{},"(安裝過程就是一直下一步就對了，所以過程略)",[16,59,60,61,65],{},"安裝完畢後我們可以試著輸入 ",[62,63,64],"code",{},"node -v"," 來確認是否有安裝成功",[16,67,68],{},"(我是因為某些專案開發需求才安裝 v 11.7.0，這邊可以無視它)",[16,70,71],{},[51,72],{"alt":73,"src":74},"node version","https:\u002F\u002Fi.imgur.com\u002F4g8jejV.png",[12,76,78],{"id":77},"gulp-安裝環境","Gulp 安裝環境",[16,80,81],{},"接下來我們要瞭解到一般在安裝 Gulp 的時候會分為兩個環境，分別為",[83,84,85,89],"ul",{},[86,87,88],"li",{},"Window (本機環境也就是全域環境)",[86,90,91],{},"Local  (專案環境也就是區域環境)",[16,93,94,95,98,99,104],{},"但是在準備安裝 Gulp 之前必須先輸入 ",[62,96,97],{},"npm -v"," 確定是否有 npm 套件管理工具，否則我們是無法正常安裝 Gulp，因為 Gulp 主要放在 ",[32,100,103],{"href":101,"rel":102},"https:\u002F\u002Fwww.npmjs.com\u002F",[36],"npm 平台","上",[16,106,107],{},[51,108],{"alt":109,"src":110},"npm","https:\u002F\u002Fi.imgur.com\u002FiW8MmgX.png",[16,112,113,114,117,118,120],{},"當確認有 npm 套件管理工具後我們就可以開始安裝 Gulp 到全域環境下，而全域安裝的方式就是 ",[62,115,116],{},"-g","，若沒有 ",[62,119,116],{}," 那就只會被安裝在專案中",[16,122,123,124,126,127,130],{},"(",[62,125,116],{}," = ",[62,128,129],{},"--global","，所以可以自己決定要輸入哪一種指令)",[132,133,138],"pre",{"className":134,"code":135,"language":136,"meta":137,"style":137},"language-js shiki shiki-themes github-dark-high-contrast","npm install -g gulp\n","js","",[62,139,140],{"__ignoreMap":137},[141,142,145,149,153],"span",{"class":143,"line":144},"line",1,[141,146,148],{"class":147},"sMAXC","npm install ",[141,150,152],{"class":151},"sWyjQ","-",[141,154,155],{"class":147},"g gulp\n",[16,157,158],{},"or",[132,160,162],{"className":134,"code":161,"language":136,"meta":137,"style":137},"npm install --global gulp\n",[62,163,164],{"__ignoreMap":137},[141,165,166,168,171],{"class":143,"line":144},[141,167,148],{"class":147},[141,169,170],{"class":151},"--",[141,172,173],{"class":147},"global gulp\n",[16,175,176,177,180],{},"那該如何確定是否安裝成功?只需要輸入 ",[62,178,179],{},"gulp -v"," 就可以哩",[16,182,183],{},[51,184],{"alt":185,"src":186},"gulp version","https:\u002F\u002Fi.imgur.com\u002FdLSelyN.png",[12,188,189],{"id":189},"初始化專案",[16,191,192,193,196],{},"基本準備都已經好了，但是這邊還有一個重點要做，首先我們先新增一個專案資料夾叫 ",[62,194,195],{},"Project","，然後在終端機輸入專案資料夾目錄路徑(會使用到指令 cd \"資料夾路徑\")",[16,198,199],{},[51,200],{"alt":201,"src":202},"cd","https:\u002F\u002Fi.imgur.com\u002FD4lM7qv.png",[16,204,205],{},"請務必確認已經進入專案資料夾，否則你會安裝到奇怪的地方",[16,207,208],{},[51,209],{"alt":210,"src":211},"專案資料夾","https:\u002F\u002Fi.imgur.com\u002FsPBLGha.png",[16,213,214],{},"接下來就要針對專案做初始化的動作，否則我們安裝的套件是無法作控管的",[132,216,218],{"className":134,"code":217,"language":136,"meta":137,"style":137},"npm init\n",[62,219,220],{"__ignoreMap":137},[141,221,222],{"class":143,"line":144},[141,223,217],{"class":147},[16,225,226],{},"當你輸入之後你會要輸入很多資訊，當然你可以選擇一直 Enther，全部帶入預設(基本上我都是一直 Enther)",[83,228,229,232,235,238,241,244,247,250],{},[86,230,231],{},"name: 專案的名字，預設就是該目錄名",[86,233,234],{},"description: 專案描述",[86,236,237],{},"entry point: 專案進入點",[86,239,240],{},"test command: 專案測試",[86,242,243],{},"git repository: 專案原始碼的 Git 版控位置",[86,245,246],{},"keywoard: 關鍵字",[86,248,249],{},"author: 專案作者",[86,251,252],{},"license: 專案版權",[16,254,255],{},"如果你懶得按一直按 Enter，可以這樣輸入",[132,257,259],{"className":134,"code":258,"language":136,"meta":137,"style":137},"npm init -y\n",[62,260,261],{"__ignoreMap":137},[141,262,263,266,268],{"class":143,"line":144},[141,264,265],{"class":147},"npm init ",[141,267,152],{"class":151},[141,269,270],{"class":147},"y\n",[16,272,273],{},"這樣它就會自動幫你全部帶入預設",[16,275,276],{},[51,277],{"alt":278,"src":279},"-y","https:\u002F\u002Fi.imgur.com\u002FzT5i3tB.png",[16,281,282],{},"回到專案目錄可以看到產生了一個 package.json",[16,284,285],{},[51,286],{"alt":287,"src":288},"package","https:\u002F\u002Fi.imgur.com\u002FJvNt4ge.png",[16,290,291],{},"那 package.json 是什麼?簡單來講 package.json 就是專門管制你安裝的套件檔案，舉例來講如果我安裝 gulp 若不加入 -g (全域環境) 安裝的話，預設會被安裝在 local (也就是專案環境)下",[132,293,295],{"className":134,"code":294,"language":136,"meta":137,"style":137},"npm install gulp\n",[62,296,297],{"__ignoreMap":137},[141,298,299],{"class":143,"line":144},[141,300,294],{"class":147},[16,302,303],{},[51,304],{"alt":305,"src":306},"local","https:\u002F\u002Fi.imgur.com\u002FWRX0Emk.png",[16,308,309],{},[51,310],{"alt":311,"src":312},"原本是沒有 gulp","https:\u002F\u002Fi.imgur.com\u002FjeSlL8g.png",[16,314,315],{},[51,316],{"alt":317,"src":318},"local 安裝後出現了 gulp","https:\u002F\u002Fi.imgur.com\u002FqAvDQjR.png",[16,320,321],{},"但是一般來講如果要將套件安裝在專案環境下建議要這樣子輸入才好，確保專案套件有被安裝進去",[132,323,325],{"className":134,"code":324,"language":136,"meta":137,"style":137},"npm install --save gulp\n",[62,326,327],{"__ignoreMap":137},[141,328,329,331,333],{"class":143,"line":144},[141,330,148],{"class":147},[141,332,170],{"class":151},[141,334,335],{"class":147},"save gulp\n",[16,337,338],{},"這樣套件才會被安裝儲存在 package.json 中",[16,340,341,342,345],{},"那為什麼要這樣做?原因是因為若我們如果不將套件儲存在 package.json 中，那麼再將專案資料夾交給別人的時候，人家就會無法正常運作，因為當專案轉移到別人手上時都會輸入 ",[62,343,344],{},"npm install"," 來還原專案套件",[16,347,348],{},"你可能會問我們不是會將整個專案資料夾打包起來嗎?",[16,350,351],{},[51,352],{"alt":353,"src":354},"Image","https:\u002F\u002Fi.imgur.com\u002F2cJ0mjT.png",[16,356,357],{},"沒有錯，但是某些資料夾是會被忽略，舉例 node_modules 資料夾就會被忽略不會一起打包給別人，因為這個資料夾非常非常的大，所以才會透過 package.json 來儲存專案套件",[12,359,360],{"id":360},"補充",[16,362,363],{},"由於這篇文章是屬於 Gulp 4.2.0，如果你是想要基於 Gulp 3.9.1 來開發的話，可以改輸入這樣的指令來安裝 Gulp",[132,365,367],{"className":134,"code":366,"language":136,"meta":137,"style":137},"npm install -g gulp@3.9.1\n",[62,368,369],{"__ignoreMap":137},[141,370,371,373,375,378,382,385],{"class":143,"line":144},[141,372,148],{"class":147},[141,374,152],{"class":151},[141,376,377],{"class":147},"g gulp@",[141,379,381],{"class":380},"sCcAr","3.9",[141,383,384],{"class":147},".",[141,386,387],{"class":380},"1\n",[132,389,391],{"className":134,"code":390,"language":136,"meta":137,"style":137},"npm install --save gulp@3.9.1\n",[62,392,393],{"__ignoreMap":137},[141,394,395,397,399,402,404,406],{"class":143,"line":144},[141,396,148],{"class":147},[141,398,170],{"class":151},[141,400,401],{"class":147},"save gulp@",[141,403,381],{"class":380},[141,405,384],{"class":147},[141,407,387],{"class":380},[409,410,411],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--sh