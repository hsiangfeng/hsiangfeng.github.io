.js\"\n",[16,321,322],{},"注意這邊是使用 node 來執行剛剛建立的 serve.js",[16,324,325],{},"如果你有學過 NodeJS，那麼你一定會想「這樣不是只是開啟 server 而已嗎?那 Gulp 呢?」，沒有錯，接下來這邊就是重點了",[16,327,328,329],{},"如果你希望部屬上去時 Heroku 會先 build 過一次 gulp，那麼就必須在替 package 額外再增加一行指令，也就是 ",[59,330,331],{},"build",[52,333,335],{"className":304,"code":334,"language":306,"meta":57,"style":57},"\"build\": \"gulp build --env prod\"\n",[59,336,337],{"__ignoreMap":57},[62,338,339,342,344],{"class":64,"line":65},[62,340,341],{"class":110},"\"build\"",[62,343,316],{"class":68},[62,345,346],{"class":110},"\"gulp build --env prod\"\n",[16,348,349,350],{},"當然你也可以自訂一些其他的行為，這邊你可以參考 Heroku ",[28,351,354],{"href":352,"rel":353},"https:\u002F\u002Fdevcenter.heroku.com\u002Farticles\u002Fnodejs-support#customizing-the-build-process",[32],"這一篇文章",[16,356,357],{},"接下來只需要將目前的 Gulp 丟上 Heroku 就可以運行了，這邊我就不再示範如何新增 Heroku 以及部屬 Heroku 了。",[16,359,360],{},"但是這邊有一個重點，當你部屬 Heroku 之後有可能會發生以下錯誤",[52,362,367],{"className":363,"code":365,"language":366,"meta":57},[364],"language-text","npm ERR! Failed at the project@1.0.0 build script.\n\nnpm ERR! This is probably not a problem with npm. There is likely additional logging output above.\n\nnpm ERR! A complete log of this run can be found\n","text",[59,368,365],{"__ignoreMap":57},[16,370,371],{},"以及以下訊息",[52,373,376],{"className":374,"code":375,"language":366,"meta":57},[364],"We're sorry this build is failing! You can troubleshoot common issues here:\nhttps:\u002F\u002Fdevcenter.heroku.com\u002Farticles\u002Ftroubleshooting-node-deploys\n\nSome possible problems:\n- Node version not specified in package.json\n  https:\u002F\u002Fdevcenter.heroku.com\u002Farticles\u002Fnodejs-support#specifying-a-node-js-version\n",[59,377,375],{"__ignoreMap":57},[16,379,380],{},"這個解決方式只需要在 package.json 中加入這一段就可以了",[52,382,384],{"className":304,"code":383,"language":306,"meta":57,"style":57},"\"engines\": {\n    \"node\": \"11.7.0\"\n  }\n",[59,385,386,394,405],{"__ignoreMap":57},[62,387,388,391],{"class":64,"line":65},[62,3