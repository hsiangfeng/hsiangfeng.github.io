[{"data":1,"prerenderedAt":467},["ShallowReactive",2],{"header-locale:\u002Fgulp\u002F20191213\u002F3886861343\u002F":3,"page:\u002Fgulp\u002F20191213\u002F3886861343\u002F":4,"alt:\u002Fgulp\u002F20191213\u002F3886861343\u002F":3,"prev-next:\u002Fgulp\u002F20191213\u002F3886861343\u002F":444,"related:\u002Fgulp\u002F20191213\u002F3886861343\u002F":453},"\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":427,"date":428,"description":18,"extension":429,"lang":430,"meta":431,"navigation":139,"path":432,"readingMinutes":433,"seo":434,"standalone":435,"stem":436,"tags":437,"tldr":441,"updated":441,"url":442,"__hash__":443},"content\u002F這是在講 Gulp 不是飲料是任務自動化工具這件事\u002F這是在講 Gulp 不是飲料是任務自動化工具這件事之番外篇：將 Gulp deploy(部屬) Heroku.md","這是在講 Gulp 不是飲料是任務自動化工具這件事之番外篇：將 Gulp deploy(部屬) Heroku","3886861343",{"type":9,"value":10,"toc":421},"minimark",[11,15,19,22,25,34,37,44,48,51,77,84,292,295,302,320,323,326,332,347,355,358,361,369,372,378,381,410,417],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"有一段時間沒更新這個系列文章，剛好最近需要將 Gulp 環境部屬到 Heroku，所以就乾脆寫成一個文章分類在這個系列中當作番外篇吧~",[12,20,21],{"id":21},"環境",[16,23,24],{},"這邊將會使用的環境是先前所撰寫的 Gulp 範例",[16,26,27],{},[28,29,33],"a",{"href":30,"rel":31},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FgulpSample",[32],"nofollow","gulpSample",[16,35,36],{},"此外 gulpfile 我也順便更新寫法，改成 Gulp 4 推薦的方式來處理，再分支 newGulpfile，其他的部分基本上與原本的 Gulp 3.9.1 差不了多少，所以可以直接從程式碼了解即可。",[16,38,39],{},[28,40,43],{"href":41,"rel":42},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FgulpSample\u002Fblob\u002Fcf0836a38eeedfd9fbe204ac170e6e524f577daf\u002Fgulpfile.js\u002Findex.js#L12",[32],"程式碼片段",[12,45,47],{"id":46},"server","Server",[16,49,50],{},"由於 Heroku 只是提供一個環境給我們，他並沒有伺服器，所以如果我們要將 Gulp 丟上 Heroku 的話，那麼就會需要伺服器環境，所以這邊要先安裝 Express",[52,53,58],"pre",{"className":54,"code":55,"language":56,"meta":57,"style":57},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save express morgan\n","js","",[59,60,61],"code",{"__ignoreMap":57},[62,63,66,70,74],"span",{"class":64,"line":65},"line",1,[62,67,69],{"class":68},"sMAXC","npm install ",[62,71,73],{"class":72},"sWyjQ","--",[62,75,76],{"class":68},"save express morgan\n",[16,78,79,80,83],{},"安裝完畢後再根目錄建立一個檔案叫做 ",[59,81,82],{},"serve.js"," 內容如下：",[52,85,87],{"className":54,"code":86,"language":56,"meta":57,"style":57},"const express = require('express');\nconst logger = require('morgan');\n\nconst app = express();\n\napp.use(logger('dev'));\napp.use(express.static('public')); \u002F\u002F 設置靜態資源目錄\napp.get('\u002F', (req, res) => {\n  res.sendfile('.\u002Fpublic\u002F');\n});\n\napp.listen(process.env.PORT || 3000);\n",[59,88,89,115,134,141,156,161,183,208,243,259,265,270],{"__ignoreMap":57},[62,90,91,94,98,101,105,108,112],{"class":64,"line":65},[62,92,93],{"class":72},"const",[62,95,97],{"class":96},"sCcAr"," express",[62,99,100],{"class":72}," =",[62,102,104],{"class":103},"sj_SG"," require",[62,106,107],{"class":68},"(",[62,109,111],{"class":110},"sTRMh","'express'",[62,113,114],{"class":68},");\n",[62,116,118,120,123,125,127,129,132],{"class":64,"line":117},2,[62,119,93],{"class":72},[62,121,122],{"class":96}," logger",[62,124,100],{"class":72},[62,126,104],{"class":103},[62,128,107],{"class":68},[62,130,131],{"class":110},"'morgan'",[62,133,114],{"class":68},[62,135,137],{"class":64,"line":136},3,[62,138,140],{"emptyLinePlaceholder":139},true,"\n",[62,142,144,146,149,151,153],{"class":64,"line":143},4,[62,145,93],{"class":72},[62,147,148],{"class":96}," app",[62,150,100],{"class":72},[62,152,97],{"class":103},[62,154,155],{"class":68},"();\n",[62,157,159],{"class":64,"line":158},5,[62,160,140],{"emptyLinePlaceholder":139},[62,162,164,167,170,172,175,177,180],{"class":64,"line":163},6,[62,165,166],{"class":68},"app.",[62,168,169],{"class":103},"use",[62,171,107],{"class":68},[62,173,174],{"class":103},"logger",[62,176,107],{"class":68},[62,178,179],{"class":110},"'dev'",[62,181,