:60},"-",[50,69,70],{"class":56},"gh",[50,72,67],{"class":60},[50,74,75],{"class":56},"pages\n",[12,77,78],{"id":78},"使用方式",[16,80,81,82,87],{},"我們一樣可以參考官方",[31,83,86],{"href":84,"rel":85},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fgulp-gh-pages#usage",[35],"文件範例","來撰寫就好了，只需要稍微調整即可",[41,89,91],{"className":43,"code":90,"language":45,"meta":46,"style":46},"gulp.task('deploy', () => {\n  return gulp.src('.\u002Fpublic\u002F**\u002F*')\n    .pipe($.ghPages());\n});\n",[26,92,93,118,138,156],{"__ignoreMap":46},[50,94,95,98,102,105,109,112,115],{"class":52,"line":53},[50,96,97],{"class":56},"gulp.",[50,99,101],{"class":100},"sj_SG","task",[50,103,104],{"class":56},"(",[50,106,108],{"class":107},"sTRMh","'deploy'",[50,110,111],{"class":56},", () ",[50,113,114],{"class":60},"=>",[50,116,117],{"class":56}," {\n",[50,119,121,124,127,130,132,135],{"class":52,"line":120},2,[50,122,123],{"class":60},"  return",[50,125,126],{"class":56}," gulp.",[50,128,129],{"class":100},"src",[50,131,104],{"class":56},[50,133,134],{"class":107},"'.\u002Fpublic\u002F**\u002F*'",[50,136,137],{"class":56},")\n",[50,139,141,144,147,150,153],{"class":52,"line":140},3,[50,142,143],{"class":56},"    .",[50,145,146],{"class":100},"pipe",[50,148,149],{"class":56},"($.",[50,151,152],{"class":100},"ghPages",[50,154,155],{"class":56},"());\n",[50,157,159],{"class":52,"line":158},4,[50,160,161],{"class":56},"});\n",[16,163,164,165,168],{},"這時候你可以試著輸入 ",[26,166,167],{},"gulp deploy","，這時候你應該會看到這樣子的訊息",[16,170,171],{},[172,173],"img",{"alt":174,"src":175},"deploy","https:\u002F\u002Fi.imgur.com\u002FB2iqg1U.png",[16,177,178],{},"這是因為你還沒替這個專案加入 git 版控及 GitHub 部屬，所以這邊我們要先來初始化一下這個專案資料夾",[12,180,182],{"id":181},"github","GitHub",[16,184,185],{},"首先我們先到 GitHub 開一個 repo",[16,187,188],{},[172,189],{"alt":190,"src":191},"repo","https:\u002F\u002Fi.imgur.com\u002FUNeYQfD.png",[16,193,194],{},[172,195],{"alt":190,"src":196},"https:\u002F\u002Fi.imgur.com\u002FoU9WTLg.png",[16,198,199],{},"替專案資料夾初始化",[41,201,205],{"className":202,"code":203,"language":204,"meta":46,"style":46},"language-git shiki shiki-themes github-dark-high-contrast","git init\n","git",[26,206,207],{"__ignoreMap":46},[50,208,209],{"class":52,"line":53},[50,210,203],{},[16,212,213],{},"接下來先來新增一個檔案叫 .gitignore 在根目錄，",[16,215,216],{},[172,217],{"alt":218,"src":219},"gitignore","https:\u002F\u002Fi.imgur.com\u002F39OGxBF.png",[16,221,222],{},"內容如下",[41,224,226],{"className":43,"code":225,"language":45,"meta":46,"style":46},"public\nnode_modules\n.publish\n",[26,227,228,233,238],{"__ignoreMap":46},[50,229,230],{"class":52,"line":53},[50,231,232],{"class":56},"public\n",[50,234,235],{"class":52,"line":120},[50,236,237],{"class":56},"node_modules\n",[50,239,240],{"class":52,"line":140},[50,241,242],{"class":56},".publish\n",[16,244,245,246],{},"接下來可以先看一下那些資料夾還沒被加入 git，可以輸入 ",[26,247,248],{},"git status",[16,250,251],{},[172,252],{"alt":253,"src":254},"status","https:\u002F\u002Fi.imgur.com\u002FR4YvIeY.png",[16,256,257,258,261],{},"我們可以看到這些檔案都還沒加入 git 版控，所以就輸入 ",[26,259,260],{},"git add ."," (意旨全部加入版本控制)",[16,263,264],{},[172,265],{"alt":266,"src":267},"add","https:\u002F\u002Fi.imgur.com\u002Fx9uAuBI.png",[16,269,270,271,273],{},"如果不確定是否加入可以再輸入一次 ",[26,272,248],{},"，來看看那些檔案加入版本控制了",[16,275,276],{},[172,277],{"alt":253,"src":278},"https:\u002F\u002Fi.imgur.com\u002F6WRIver.png",[16,280,281,282],{},"加入完畢後我要輸入 commit 訊息，所以這樣打 ",[26,283,284],{},"git commit -m 'first update file'",[16,286,287],{},[172,288],{"alt":289,"src":290},"commit","https:\u002F\u002Fi.imgur.com\u002FAGgXAv4.png",[16,292,293,294,297],{},"接下來輸入 GitHub 提供的指令 ",[26,295,296],{},"git remote add origin https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FgulpSample.git","，輸入之後不會有任何訊息是正常的",[16,299,300],{},[172,301],{"alt":302,"src":303},"remote","https:\u002F\u002Fi.imgur.com\u002FBoyEfLI.png",[16,305,306,307,310],{},"最後輸入 ",[26,308,309],{},"git push -u origin master","，你就上傳成功啦~",[16,312,313],{},[172,314],{"alt":315,"src":316},"push","https:\u002F\u002