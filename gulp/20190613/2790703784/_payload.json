,77],{},"很嚴格",[16,79,80],{},"光第一點其實就很常搞死我，因為我個人常常是使用 Bootstrap 4 來開發，但是 Bootstrap 4 的範例都是純 HTML 結構，所以就變成我要先做一次轉換才可以貼進去 pug 中，所以各有取捨，但是可以瞭解一下，所以這邊最後也附上 pug 官方網站及轉換器。",[16,82,83],{},[53,84,88],{"href":85,"rel":86},"https:\u002F\u002Fpugjs.org\u002Fapi\u002Fgetting-started.html",[87],"nofollow","pug 官方網站",[16,90,91],{},[53,92,95],{"href":93,"rel":94},"https:\u002F\u002Fhtml2jade.org\u002F",[87],"HTML 轉 pug",[16,97,98],{},[53,99,102],{"href":100,"rel":101},"https:\u002F\u002Fpughtml.com\u002F",[87],"pug 轉 HTML",[12,104,105],{"id":105},"起手式",[16,107,108],{},"首先我們要安裝套件，gulp 也有出 pug 專屬套件，所以只需要輸入以下語法就可以安裝哩",[110,111,116],"pre",{"className":112,"code":113,"language":114,"meta":115,"style":115},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save gulp-pug\n","js","",[117,118,119],"code",{"__ignoreMap":115},[120,121,124,128,132,135,138],"span",{"class":122,"line":123},"line",1,[120,125,127],{"class":126},"sMAXC","npm install ",[120,129,131],{"class":130},"sWyjQ","--",[120,133,134],{"class":126},"save gulp",[120,136,137],{"class":130},"-",[120,139,140],{"class":126},"pug\n",[12,142,143],{"id":143},"使用方式",[16,145,146,147,152],{},"使用方式也是非常簡單，一樣依照官方",[53,148,151],{"href":149,"rel":150},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fgulp-pug",[87],"範例文件","稍微修改即可",[110,154,156],{"className":112,"code":155,"language":114,"meta":115,"style":115},"gulp.task('pug', () => {\n  return gulp.src('.\u002Fsrc\u002F**\u002F*.pug')\n    .pipe($.pug({\n        \u002F\u002F若為false將會去除空格\n        pretty: false\n    }))\n    .pipe(gulp.dest('.\u002Fpublic\u002F'))\n});\n",[117,157,158,183,203,220,227,237,243,264],{"__ignoreMap":115},[120,159,160,163,167,170,174,177,180],{"class":122,"line":123},[120,161,162],{"class":126},"gulp.",[120,164,166],{"class":165},"sj_SG","task",[120,168,169],{"class":126},"(",[120,171,173],{"class":172},"sTRMh","'pug'",[120,175,176],{"class":126},", () ",[120,178,179],{"class":130},"=>",[120,181,182],{"class":126}," {\n",[120,184,186,189,192