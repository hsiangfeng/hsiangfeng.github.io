[{"data":1,"prerenderedAt":112},["ShallowReactive",2],{"header-locale:\u002Fvscode\u002F20211123\u002F335355052\u002F":3,"page:\u002Fvscode\u002F20211123\u002F335355052\u002F":4,"alt:\u002Fvscode\u002F20211123\u002F335355052\u002F":3,"prev-next:\u002Fvscode\u002F20211123\u002F335355052\u002F":89,"related:\u002Fvscode\u002F20211123\u002F335355052\u002F":98},"\u002Fen\u002Fvscode\u002F2021\u002F11\u002F23\u002Fvscode-relative-line-numbers\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":72,"date":73,"description":18,"extension":74,"lang":75,"meta":76,"navigation":77,"path":78,"readingMinutes":79,"seo":80,"standalone":81,"stem":82,"tags":83,"tldr":86,"updated":86,"url":87,"__hash__":88},"content\u002FVSCode\u002F將-VSCode-的程式碼行數改成相對行數.md","將 VSCode 的程式碼行數改成相對(值)行數","335355052",{"type":9,"value":10,"toc":65},"minimark",[11,15,19,22,34,37,44,47,53,56,59],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近開始已經慢慢在嘗試使用 vim\u002Fvi 在 VSCode 上面開發以及撰寫文章，所以這邊就順便紀錄一下如何開啟 VSCode 的相對行數顯示。",[12,20,21],{"id":21},"相對與絕對行數",[16,23,24,25,29,30,33],{},"基本上如果你是 Vim\u002FVi 開發者的話，一定會希望 VSCode 改成相對行數，因為在 Vim 中跳換行數都是採用相對行數的方式，例如：",[26,27,28],"code",{},"4j","、",[26,31,32],{},"V4k"," 等等，所以就紀錄一篇怎麼開啟相對(值)行數。",[16,35,36],{},"那什麼是相對與絕對呢？絕對行數就是程式碼有幾行旁邊就顯示幾行，例如：",[16,38,39],{},[40,41],"img",{"alt":42,"src":43},"絕對行數","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-11-23%2014.34.28.png",[16,45,46],{},"而相對行數則是以「光標」為基準開始上下從 0 開始相對計算",[16,48,49],{},[40,50],{"alt":51,"src":52},"相對行數","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-11-23%2014.37.18.png",[12,54,55],{"id":55},"設定方式",[16,57,58],{},"打開 VSCode 的設定，然後在搜尋設定上面搜尋「Line Numbers」，屆時你就會看到一個「Editor: Line Numbers」 將它改成「relative」就可以顯示相對行數了。",[16,60,61],{},[40,62],{"alt":63,"src":64},"relative","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-11-23%2014.39.23.png",{"title":66,"searchDepth":67,"depth":67,"links":68},"",2,[69,70,71],{"id":14,"depth":67,"text":14},{"id":21,"depth":67,"text":21},{"id":55,"depth":67,"text":55},"VSCode","2021-11-23 14:29:07","md","zh-Hant",{},true,"\u002Fvscode\u002Fvscode","1",{"title":6,"description":18},false,"VSCode\u002F將-VSCode-的程式碼行數改成相對行數",[84,85,72],"Vim","Vi",null,"\u002Fvscode\u002F20211123\u002F335355052\u002F","bptosHgX7VGeMXTdg1gRdvmwJhoZKiYPm3RHEVlj72c",{"newer":90,"older":94},{"url":91,"title":92,"date":93},"\u002Fother\u002F20211125\u002F356203095\u002F","淺談 API 與 RESTful API","2021-11-25 21:38:05",{"url":95,"title":96,"date":97},"\u002Flearnexp\u002F20211122\u002F1862504277\u002F","【91 極速開發+】課後心得","2021-11-22 17:34:18",[99,103,108],{"url":100,"title":101,"date":102,"readingMinutes":79},"\u002Fvscode\u002F20250424\u002F4258825567\u002F","VSCode 找不到 Git，安裝它或使用 \"git.path\" 設置","2025-04-24 09:52:23",{"url":104,"title":105,"date":106,"readingMinutes":107},"\u002Fvscode\u002F20240908\u002F3488366595\u002F","GitHub Copilot 好難用？說不定是你不懂 Copilot 之技巧全攻略不藏私！","2024-09-08 13:06:00","5",{"url":109,"title":110,"date":111,"readingMinutes":79},"\u002Fvscode\u002F20231026\u002F54606935\u002F","VSCode 上 Vue 自訂元件失去高亮","2023-10-26 11:03:07",1784012814812]