[{"data":1,"prerenderedAt":604},["ShallowReactive",2],{"header-locale:\u002Fvscode\u002F20210116\u002F2465721796\u002F":3,"page:\u002Fvscode\u002F20210116\u002F2465721796\u002F":4,"alt:\u002Fvscode\u002F20210116\u002F2465721796\u002F":3,"prev-next:\u002Fvscode\u002F20210116\u002F2465721796\u002F":580,"related:\u002Fvscode\u002F20210116\u002F2465721796\u002F":589},"\u002Fen\u002Fvscode\u002F2021\u002F01\u002F16\u002Flearn-vim-in-vscode-quick-start\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":562,"date":563,"description":564,"extension":565,"lang":566,"meta":567,"navigation":568,"path":569,"readingMinutes":570,"seo":571,"standalone":572,"stem":573,"tags":574,"tldr":577,"updated":577,"url":578,"__hash__":579},"content\u002FVSCode\u002F用-VSCode-來十分鐘上手-Vim-吧-入門篇.md","用 VSCode 來十分鐘快速上手學習 Vim 吧(入門篇)","2465721796",{"type":9,"value":10,"toc":550},"minimark",[11,15,19,22,25,34,37,40,43,46,49,80,83,90,98,102,119,125,182,190,194,197,238,244,250,256,268,274,278,281,288,294,297,348,351,354,369,375,378,384,387,419,426,429,478,484,491,494,535,544,547],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來將會來介紹 Vim 基本入門，但是我必須說，剛開始絕對會一直碰壁是真的，概念就像是學新的輸入法一樣。",[12,20,21],{"id":21},"安裝套件",[16,23,24],{},"基本上想讓自己更快上手 Vim 的方式就是直接將自己習慣的編輯係改成 Vim 操作模式，所以在此建議先安裝該套件",[16,26,27],{},[28,29,33],"a",{"href":30,"rel":31},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=vscodevim.vim",[32],"nofollow","VSCode Vim 套件安裝",[16,35,36],{},"(在此我是使用 VSCode 來撰寫)",[16,38,39],{},"基本上安裝完畢之後，如果本身沒有學習過 Vim 應該會頓時成為白痴，所以這一篇將會基本入門教學。",[16,41,42],{},"因此這一篇的教學基本上是基於這個套件來撰寫，可能會有一些地方與實際上的 Vim 若有一點落差，但我自己感覺上是沒差到哪裡，可能我自己曾經也有學過的關係吧。",[12,44,45],{"id":45},"模式認識",[16,47,48],{},"首先 Vim 有四種基本的模式",[50,51,52,61,69,77],"ul",{},[53,54,55,56],"li",{},"基本模式 (NORMAL)\n",[50,57,58],{},[53,59,60],{},"又稱之為一般模式、預設模式等。",[53,62,63,64],{},"輸入模式 (INSERT)\n",[50,65,66],{},[53,67,68],{},"又稱之為插入模式，也就是文字輸入模式。",[53,70,71,72],{},"選取模式 (VISMAL)\n",[50,73,74],{},[53,75,76],{},"又稱之為視覺模式，主要是用於選取文字或者是方便閱讀與強調用，但通常來講我都是用來選取文字就是了。",[53,78,79],{},"命令模式 (一個分號)",[16,81,82],{},"而這四種命令模式在切換時 VSCode 底下就會呈現相對應得切換模式。",[16,84,85],{},[86,87],"img",{"alt":88,"src":89},"輸入模式（剛好在聽歌）","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-01-16%2012.04.21.png",[16,91,92,93,97],{},"而許多行為我們都必須在特定模式下才能夠移動甚至輸入，當然初學時最常遇到的狀況就是「不知道該如何退出模式」，其實 Vim 在退出模式時非常簡單，只需要按下 ",[94,95,96],"code",{},"ESC"," 按鈕就會退出到基本模式(NORMAL)。",[12,99,101],{"id":100},"移動方向-normal","移動方向 (NORMAL)",[16,103,104,105,108,109,108,112,108,115,118],{},"以往我們都是使用鍵盤上的方向鍵來移動程式碼，但在 Vim 中是使用「基本模式(L)」然後主要透過 ",[94,106,107],{},"h","、",[94,110,111],{},"j",[94,113,114],{},"k",[94,116,117],{},"l"," 來移動，當然你還是可以使用方向鍵來移動就是了。",[16,120,121,122,124],{},"(如果一直不確定自己模式，狂按 ",[94,123,96],{}," 按鍵就對了。)",[126,127,128,142],"table",{},[129,130,131],"thead",{},[132,133,134,139],"tr",{},[135,136,138],"th",{"align":137},"center","按鍵名稱",[135,140,141],{"align":137},"操作說明",[143,144,145,155,164,173],"tbody",{},[132,146,147,152],{},[148,149,150],"td",{"align":137},[94,151,107],{},[148,153,154],{"align":137},"向左移動一個字元",[132,156,157,161],{},[148,158,159],{"align":137},[94,160,111],{},[148,162,163],{"align":137},"向下移動一行",[132,165,166,170],{},[148,167,168],{"align":137},[94,169,114],{},[148,171,172],{"align":137},"向上移動一行",[132,174,175,179],{},[148,176,177],{"align":137},[94,178,117],{},[148,180,181],{"align":137},"向右移動一個字元",[16,183,184,185,189],{},"在此要注意",[186,187,188],"strong",{},"大小寫","是有差別的唷。",[12,191,193],{"id":192},"編輯模式-insert","編輯模式 (INSERT)",[16,195,196],{},"接下來我們移動到我們要的位置之後就會開始撰寫程式碼或者是寫 MD 等等，因此就必須進入「編輯模式(INSERT)」進入該模式的方式有四種",[126,198,199,207],{},[129,200,201],{},[132,202,203,205],{},[135,204,138],{"align":137},[135,206,141],{"align":137},[143,208,209,219,228],{},[132,210,211,216],{},[148,212,213],{"align":137},[94,214,215],{},"i",[148,217,218],{"align":137},"在當前游標向前一個字元進入編輯(輸入)模式",[132,220,221,225],{},[148,222,223],{"align":137},[94,224,28],{},[148,226,227],{"align":137},"在當前游標向後一個字元進入編輯(輸入)模式",[132,229,230,235],{},[148,231,232],{"align":137},[94,233,234],{},"o",[148,236,237],{"align":137},"在跳到後一行之後在進入編輯(輸入)模式",[16,239,240],{},[86,241],{"alt":242,"src":243},"按鍵: i","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E8%9E%A2%E5%B9%95%E9%8C%84%E8%A3%BD%202021-01-16%2012.36.20.gif",[16,245,246],{},[86,247],{"alt":248,"src":249},"按鍵: a","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E8%9E%A2%E5%B9%95%E9%8C%84%E8%A3%BD%202021-01-16%2012.36.31.gif",[16,251,252],{},[86,253],{"alt":254,"src":255},"按鍵: o","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E8%9E%A2%E5%B9%95%E9%8C%84%E8%A3%BD%202021-01-16%2012.36.55.gif",[16,257,258,259,261,262,264,265,267],{},"當然退出編輯模式的方式一樣是 ",[94,260,96],{},"，只要你想退出任何模式 ",[94,263,96],{}," 狂按就對了，除此之外，我也會建議你養成習慣，退出任何模式都應該要習慣按下 ",[94,266,96],{},"，否則你會發生一個笑話就是...",[269,270,271],"blockquote",{},[16,272,273],{},"我學 Vim 到現在，還是不知道如何退出。(笑)",[12,275,277],{"id":276},"選取複製與貼上文字-vismal","選取、複製與貼上文字 (VISMAL)",[16,279,280],{},"接下來就是很常用的選取、複製以及貼上文字等技巧，而這些行為雖然我們可以透過原本的操作行為來達到也就是 CRTL + C、V (複製、貼上)，但是老話一句，都已經用了 Vim 你還不去習慣它這樣對嗎？",[16,282,283,284,287],{},"首先你要進去視覺模式之前必須按下 ",[94,285,286],{},"v"," 按鈕進入該模式，進入之後其實它的游標看不出差異，只是當你按下方向鍵的時候，你會發現文字被選取起來",[16,289,290],{},[86,291],{"alt":292,"src":293},"視覺模式","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002Fezgif.com-gif-maker.gif",[16,295,296],{},"接下來在這個模式下基本的操作如下",[126,298,299,307],{},[129,300,301],{},[132,302,303,305],{},[135,304,138],{"align":137},[135,306,141],{"align":137},[143,308,309,319,328,338],{},[132,310,311,316],{},[148,312,313],{"align":137},[94,314,315],{},"y",[148,317,318],{"align":137},"複製選取的文字",[132,320,321,325],{},[148,322,323],{"align":137},[94,324,16],{},[148,326,327],{"align":137},"貼上剛剛複製的文字",[132,329,330,335],{},[148,331,332],{"align":137},[94,333,334],{},"d",[148,336,337],{"align":137},"剪下選取的文字",[132,339,340,345],{},[148,341,342],{"align":137},[94,343,344],{},"u",[148,346,347],{"align":137},"復原剛剛的動作(ex: 刪除文字或者剪下)",[16,349,350],{},"請注意，大小寫上的操作還是非常重要的哦。",[12,352,353],{"id":353},"移動相關",[16,355,356,357,360,361,364,365,368],{},"Vim 裡面還有一個很特別好玩的東西，也就是透過指令模式來跳到指定行數，這個其實是我滿喜歡的功能之一，假使我們可能在一百多行寫程式，但當下我們可能突然需要滾到第一行時修改一些程式碼，那麼 Vim 就有支援該方式來快速跳行，首先按下電腦上的「",[94,358,359],{},"Shift"," + ",[94,362,363],{},":","」組合按鈕，可以看到下方會變成一個「",[94,366,367],{},":|","」",[16,370,371],{},[86,372],{"alt":373,"src":374},"命令模式","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-01-16%2015.59.09.png",[16,376,377],{},"接下來該如何快速移動呢？輸入在你左邊的行數按 Enter 就可以跳到該行數",[16,379,380],{},[86,381],{"alt":382,"src":383},"依照行數快速跳行","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002Fn08tb-armte(1).gif",[16,385,386],{},"那麼相信也會有人希望不想用輸入指令的方式來達到跳到當前視窗的首行或者是尾行，那麼按鍵名稱如下",[126,388,389,397],{},[129,390,391],{},[132,392,393,395],{},[135,394,138],{"align":137},[135,396,141],{"align":137},[143,398,399,409],{},[132,400,401,406],{},[148,402,403],{"align":137},[94,404,405],{},"gg",[148,407,408],{"align":137},"快速跳到當前視窗第一行 (不要懷疑就是連續按兩次 g，你可以把它想向成玩遊戲掛點了 gg 了，所以要重來？)",[132,410,411,416],{},[148,412,413],{"align":137},[94,414,415],{},"Shift + g",[148,417,418],{"align":137},"快速跳到當前視窗最後一行 (其實當按著 Shift 的時候 g 會變成大寫 G，因此這邊我才會打小寫。)",[16,420,421,422,425],{},"但是這邊要注意，以上兩個按鍵組合必須在",[186,423,424],{},"基本模式 (NORMAL)下才可以操作","。",[16,427,428],{},"除此之外你應該會好奇，那麼當前行數跳到首行與尾行呢(不是當前視窗了哦)?在此其實有三種方式",[126,430,431,439],{},[129,432,433],{},[132,434,435,437],{},[135,436,138],{"align":137},[135,438,141],{"align":137},[143,440,441,458,468],{},[132,442,443,448],{},[148,444,445],{"align":137},[94,446,447],{},"0",[148,449,450,451,453,454,457],{"align":137},"快速跳到首行第一個(不要懷疑就是 ",[94,452,447],{}," 零，不是英文 ",[94,455,456],{},"O",")",[132,459,460,465],{},[148,461,462],{"align":137},[94,463,464],{},"Shift + 6(^)",[148,466,467],{"align":137},"快速跳到首行第一個",[132,469,470,475],{},[148,471,472],{"align":137},[94,473,474],{},"Shift + 4($)",[148,476,477],{"align":137},"快速跳到尾行最後一個",[16,479,480,481,483],{},"以上操作都必須在 ",[186,482,424],{}," 下才可以唷。",[16,485,486,487,490],{},"最後這邊還有一種模式在移動上非常方便，也就是搜尋，在此搜尋是必須按下 「",[94,488,489],{},"\u002F","」 按鍵，當進入該模式之後，就可以輸入自己想要搜尋的單字(中文不支援，僅限英文。)",[16,492,493],{},"當你輸 完畢之後按下 Enther 才算是完成搜尋這個動作，然後如果你發現你並不是要這一行時，可以輸入以下指令移動到上下個搜尋結果",[126,495,496,504],{},[129,497,498],{},[132,499,500,502],{},[135,501,138],{"align":137},[135,503,141],{"align":137},[143,505,506,515,525],{},[132,507,508,512],{},[148,509,510],{"align":137},[94,511,489],{},[148,513,514],{"align":137},"進入搜尋模式(僅限英文，輸入完畢後記得按下 Enter)",[132,516,517,522],{},[148,518,519],{"align":137},[94,520,521],{},"Shift + 8(*)",[148,523,524],{"align":137},"向下查看搜尋結果",[132,526,527,532],{},[148,528,529],{"align":137},[94,530,531],{},"Shift + 3(#)",[148,533,534],{"align":137},"向上查看搜尋結果",[16,536,537,538,540,541,543],{},"當你搜尋到你要的結果之後，就可以按下 ",[94,539,215],{}," 或是 ",[94,542,28],{}," 進入編輯模式囉~",[12,545,546],{"id":546},"結語",[16,548,549],{},"基本上 Vim 在初學過程中是真的有一定難度，這一篇只是簡單入門，實際上還沒有介紹到相當多更進階的技巧，如果你有學過無蝦米的話，你應該也會有一種感覺「好像要背相當多的字根」概念一樣，而 Vim 其實也差不多，但是當你一整個習慣之後，其實不論是開發或者是撰寫文章，在移動上是非常快速的。",{"title":551,"searchDepth":552,"depth":552,"links":553},"",2,[554,555,556,557,558,559,560,561],{"id":14,"depth":552,"text":14},{"id":21,"depth":552,"text":21},{"id":45,"depth":552,"text":45},{"id":100,"depth":552,"text":101},{"id":192,"depth":552,"text":193},{"id":276,"depth":552,"text":277},{"id":353,"depth":552,"text":353},{"id":546,"depth":552,"text":546},"VSCode","2021-01-16 11:42:06","想學 Vim 但不知道從哪開始？這一篇用 VSCode 的 Vim 套件帶你十分鐘上手：四種基本模式、常用快捷鍵跟移動方式，先學會皮毛再決定要不要深入。","md","zh-Hant",{},true,"\u002Fvscode\u002Fvscode-vim","4",{"title":6,"description":564},false,"VSCode\u002F用-VSCode-來十分鐘上手-Vim-吧-入門篇",[562,575,576],"Vim","Vi",null,"\u002Fvscode\u002F20210116\u002F2465721796\u002F","9uFxM-Ts3UKq3Zkmz7nI39IbfATqyBE93XFR5vkr0Cs",{"newer":581,"older":585},{"url":582,"title":583,"date":584},"\u002Fjavascript\u002F20210117\u002F3096588885\u002F","JavaScript 核心觀念(47)-繼承與原型鍊-原型鍊的概念 - 為什麼有原型","2021-01-17 21:06:16",{"url":586,"title":587,"date":588},"\u002Fjavascript\u002F20210116\u002F1040518332\u002F","JavaScript 核心觀念(46)-函式以及 This 的運作-函式以及 This 的運作 - 課後練習","2021-01-16 10:03:19",[590,595,600],{"url":591,"title":592,"date":593,"readingMinutes":594},"\u002Fvscode\u002F20250424\u002F4258825567\u002F","VSCode 找不到 Git，安裝它或使用 \"git.path\" 設置","2025-04-24 09:52:23","1",{"url":596,"title":597,"date":598,"readingMinutes":599},"\u002Fvscode\u002F20240908\u002F3488366595\u002F","GitHub Copilot 好難用？說不定是你不懂 Copilot 之技巧全攻略不藏私！","2024-09-08 13:06:00","5",{"url":601,"title":602,"date":603,"readingMinutes":594},"\u002Fvscode\u002F20231026\u002F54606935\u002F","VSCode 上 Vue 自訂元件失去高亮","2023-10-26 11:03:07",1784012814730]