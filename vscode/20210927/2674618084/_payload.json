[{"data":1,"prerenderedAt":468},["ShallowReactive",2],{"header-locale:\u002Fvscode\u002F20210927\u002F2674618084\u002F":3,"page:\u002Fvscode\u002F20210927\u002F2674618084\u002F":4,"alt:\u002Fvscode\u002F20210927\u002F2674618084\u002F":3,"prev-next:\u002Fvscode\u002F20210927\u002F2674618084\u002F":445,"related:\u002Fvscode\u002F20210927\u002F2674618084\u002F":454},"\u002Fen\u002Fvscode\u002F2021\u002F09\u002F27\u002Fvscode-terminal-integrated-shell-osx-deprecated\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":430,"date":431,"description":18,"extension":432,"lang":433,"meta":434,"navigation":391,"path":435,"readingMinutes":436,"seo":437,"standalone":438,"stem":439,"tags":440,"tldr":442,"updated":442,"url":443,"__hash__":444},"content\u002FVSCode\u002FVSCode-terminal-integrated-shell-osx-屬性失效.md","VSCode terminal.integrated.shell.osx 屬性失效","2674618084",{"type":9,"value":10,"toc":424},"minimark",[11,15,19,22,30,33,36,50,57,67,74,145,152,155,161,164,170,176,259,265,268,332,335,404,407,420],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近 VSCode 發現終端機的 terminal.integrated.shell.osx 設置失效了，所以記錄一下問題跟解決方式。",[12,20,21],{"id":21},"事發原因",[16,23,24,25,29],{},"因為 VSCode 更新速度其實滿快的，在開發上我們都會有一些個人化的開發環境設定，剛好有一條設定檔案中的「",[26,27,28],"code",{},"\"terminal.integrated.shell.osx\": \"\u002Fbin\u002Fzsh\"","」屬性建議調整，所以就記錄一下如何調整。",[12,31,32],{"id":32},"解決方式",[16,34,35],{},"基本上依據 VSCode 提示就可以知道如何調整：",[37,38,39],"blockquote",{},[16,40,41,42,45,46,49],{},"這已被取代，設定預設殼層的新建議方式是在 ",[26,43,44],{},"#terminal.integrated.profiles.osx#"," 中建立終端設定檔，並將其設定檔名稱設為 ",[26,47,48],{},"#terminal.integrated.defaultProfile.osx#"," 中的預設值。這將會優先使用新的設定檔設定，但將來會變更。(2)",[16,51,52],{},[53,54],"img",{"alt":55,"src":56},"這已被取代","https:\u002F\u002Fi.imgur.com\u002Fl8IapHP.png",[16,58,59,60,62,63,66],{},"因此這邊只需要將 ",[26,61,28],{}," 替換成 ",[26,64,65],{},"\"terminal.integrated.defaultProfile.osx\": \"zsh\""," 就可以囉。",[16,68,69,70,73],{},"另一個屬性則是 ",[26,71,72],{},"terminal.integrated.profiles.osx"," 我覺得這個屬性滿好玩的，你還可以針對該終端機給予 icon 樣式，例如給星星：",[75,76,81],"pre",{"className":77,"code":78,"language":79,"meta":80,"style":80},"language-json shiki shiki-themes github-dark-high-contrast","\"terminal.integrated.profiles.osx\": {\n  \"bash\": {\n      \"path\": \"\u002Fbin\u002Fzsh\",\n      \"icon\": \"star\",\n  }\n},\n","json","",[26,82,83,96,105,120,133,139],{"__ignoreMap":80},[84,85,88,92],"span",{"class":86,"line":87},"line",1,[84,89,91],{"class":90},"sTRMh","\"terminal.integrated.profiles.osx\"",[84,93,95],{"class":94},"sMAXC",": {\n",[84,97,99,103],{"class":86,"line":98},2,[84,100,102],{"class":101},"sKpQp","  \"bash\"",[84,104,95],{"class":94},[84,106,108,111,114,117],{"class":86,"line":107},3,[84,109,110],{"class":101},"      \"path\"",[84,112,113],{"class":94},": ",[84,115,116],{"class":90},"\"\u002Fbin\u002Fzsh\"",[84,118,119],{"class":94},",\n",[84,121,123,126,128,131],{"class":86,"line":122},4,[84,124,125],{"class":101},"      \"icon\"",[84,127,113],{"class":94},[84,129,130],{"class":90},"\"star\"",[84,132,119],{"class":94},[84,134,136],{"class":86,"line":135},5,[84,137,138],{"class":94},"  }\n",[84,140,142],{"class":86,"line":141},6,[84,143,144],{"class":94},"},\n",[16,146,147,148],{},"原始樣式：\n",[53,149],{"alt":150,"src":151},"原始 icon","https:\u002F\u002Fi.imgur.com\u002F1AEERaJ.png",[16,153,154],{},"調整後的樣式：",[16,156,157],{},[53,158],{"alt":159,"src":160},"Star","https:\u002F\u002Fi.imgur.com\u002FcR1fxrY.png",[16,162,163],{},"而 icon 的樣式你可以在下拉選單找到，由於太多我就不列出了：",[16,165,166],{},[53,167],{"alt":168,"src":169},"icon","https:\u002F\u002Fi.imgur.com\u002Fcd1nXi0.png",[16,171,172,173,175],{},"而這個 ",[26,174,72],{}," 屬性之所以特別是因為它還可以設定多組終端資訊與樣式：",[75,177,179],{"className":77,"code":178,"language":79,"meta":80,"style":80},"\"terminal.integrated.profiles.osx\": {\n  \"bash2\": {\n      \"path\": \"\u002Fbin\u002Fbash\",\n      \"icon\": \"star\",\n  },\n  \"zsh\": {\n      \"path\": \"\u002Fbin\u002Fzsh\",\n      \"icon\": \"star\",\n  }\n},\n",[26,180,181,187,194,205,215,220,227,238,249,254],{"__ignoreMap":80},[84,182,183,185],{"class":86,"line":87},[84,184,91],{"class":90},[84,186,95],{"class":94},[84,188,189,192],{"class":86,"line":98},[84,190,191],{"class":101},"  \"bash2\"",[84,193,95],{"class":94},[84,195,196,198,200,203],{"class":86,"line":107},[84,197,110],{"class":101},[84,199,113],{"class":94},[84,201,202],{"class":90},"\"\u002Fbin\u002Fbash\"",[84,204,119],{"class":94},[84,206,207,209,211,213],{"class":86,"line":122},[84,208,125],{"class":101},[84,210,113],{"class":94},[84,212,130],{"class":90},[84,214,119],{"class":94},[84,216,217],{"class":86,"line":135},[84,218,219],{"class":94},"  },\n",[84,221,222,225],{"class":86,"line":141},[84,223,224],{"class":101},"  \"zsh\"",[84,226,95],{"class":94},[84,228,230,232,234,236],{"class":86,"line":229},7,[84,231,110],{"class":101},[84,233,113],{"class":94},[84,235,116],{"class":90},[84,237,119],{"class":94},[84,239,241,243,245,247],{"class":86,"line":240},8,[84,242,125],{"class":101},[84,244,113],{"class":94},[84,246,130],{"class":90},[84,248,119],{"class":94},[84,250,252],{"class":86,"line":251},9,[84,253,138],{"class":94},[84,255,257],{"class":86,"line":256},10,[84,258,144],{"class":94},[16,260,261],{},[53,262],{"alt":263,"src":264},"bash2","https:\u002F\u002Fi.imgur.com\u002FV7B4vvN.png",[16,266,267],{},"請注意，以上是 Mac OS 系統，如果是 Windows 則是以下：",[75,269,271],{"className":77,"code":270,"language":79,"meta":80,"style":80},"\"terminal.integrated.profiles.windows\": {\n    \"PowerShell -NoProfile\": {\n      \"source\": \"PowerShell\",\n      \"args\": [\"-NoProfile\"]\n    }\n},\n\"terminal.integrated.defaultProfile.windows\": \"my-pwsh\"\n",[26,272,273,280,287,299,313,318,322],{"__ignoreMap":80},[84,274,275,278],{"class":86,"line":87},[84,276,277],{"class":90},"\"terminal.integrated.profiles.windows\"",[84,279,95],{"class":94},[84,281,282,285],{"class":86,"line":98},[84,283,284],{"class":101},"    \"PowerShell -NoProfile\"",[84,286,95],{"class":94},[84,288,289,292,294,297],{"class":86,"line":107},[84,290,291],{"class":101},"      \"source\"",[84,293,113],{"class":94},[84,295,296],{"class":90},"\"PowerShell\"",[84,298,119],{"class":94},[84,300,301,304,307,310],{"class":86,"line":122},[84,302,303],{"class":101},"      \"args\"",[84,305,306],{"class":94},": [",[84,308,309],{"class":90},"\"-NoProfile\"",[84,311,312],{"class":94},"]\n",[84,314,315],{"class":86,"line":135},[84,316,317],{"class":94},"    }\n",[84,319,320],{"class":86,"line":141},[84,321,144],{"class":94},[84,323,324,327,329],{"class":86,"line":229},[84,325,326],{"class":90},"\"terminal.integrated.defaultProfile.windows\"",[84,328,113],{"class":94},[84,330,331],{"class":90},"\"my-pwsh\"\n",[16,333,334],{},"linux 則是：",[75,336,338],{"className":77,"code":337,"language":79,"meta":80,"style":80},"\"terminal.integrated.profiles.linux\": {\n  \"zsh (login)\": {\n    \"path\": \"zsh\",\n    \"args\": [\"-l\"]\n  }\n}\n\n\"terminal.integrated.defaultProfile.linux\": \"zsh\",\n",[26,339,340,347,354,366,378,382,387,393],{"__ignoreMap":80},[84,341,342,345],{"class":86,"line":87},[84,343,344],{"class":90},"\"terminal.integrated.profiles.linux\"",[84,346,95],{"class":94},[84,348,349,352],{"class":86,"line":98},[84,350,351],{"class":101},"  \"zsh (login)\"",[84,353,95],{"class":94},[84,355,356,359,361,364],{"class":86,"line":107},[84,357,358],{"class":101},"    \"path\"",[84,360,113],{"class":94},[84,362,363],{"class":90},"\"zsh\"",[84,365,119],{"class":94},[84,367,368,371,373,376],{"class":86,"line":122},[84,369,370],{"class":101},"    \"args\"",[84,372,306],{"class":94},[84,374,375],{"class":90},"\"-l\"",[84,377,312],{"class":94},[84,379,380],{"class":86,"line":135},[84,381,138],{"class":94},[84,383,384],{"class":86,"line":141},[84,385,386],{"class":94},"}\n",[84,388,389],{"class":86,"line":229},[84,390,392],{"emptyLinePlaceholder":391},true,"\n",[84,394,395,398,400,402],{"class":86,"line":240},[84,396,397],{"class":90},"\"terminal.integrated.defaultProfile.linux\"",[84,399,113],{"class":94},[84,401,363],{"class"