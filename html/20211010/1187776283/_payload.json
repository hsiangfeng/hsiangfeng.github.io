[{"data":1,"prerenderedAt":845},["ShallowReactive",2],{"header-locale:\u002Fhtml\u002F20211010\u002F1187776283\u002F":3,"page:\u002Fhtml\u002F20211010\u002F1187776283\u002F":4,"alt:\u002Fhtml\u002F20211010\u002F1187776283\u002F":3,"prev-next:\u002Fhtml\u002F20211010\u002F1187776283\u002F":821,"related:\u002Fhtml\u002F20211010\u002F1187776283\u002F":830},"\u002Fen\u002Fhtml\u002F2021\u002F10\u002F10\u002Fhtml-a-tag-attributes-cheatsheet\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":807,"date":808,"description":18,"extension":809,"lang":810,"meta":811,"navigation":753,"path":812,"readingMinutes":813,"seo":814,"standalone":815,"stem":816,"tags":817,"tldr":818,"updated":818,"url":819,"__hash__":820},"content\u002FHTML\u002F五分鐘掌握-HTML-a-連結屬性的開發小技巧.md","五分鐘掌握 HTML a 連結屬性的開發小技巧","1187776283",{"type":9,"value":10,"toc":795},"minimark",[11,15,19,22,25,32,35,77,80,105,108,133,140,147,152,183,190,192,197,225,228,237,240,250,252,257,260,264,268,276,280,292,325,328,439,446,448,453,464,471,594,600,697,700,704,713,717,723,786,791],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"HTML 中的超連結是我們開發上非常常使用的標籤，所以這一篇就分享一些關於 a 連結的小技巧，減少你一直打多餘的程式碼。",[12,20,21],{"id":21},"超連結基本觀念",[16,23,24],{},"為了讓許多新朋友與新手可以快速上手，所以前面會先簡單介紹一下關於 HTML 中的超連結 (HyperLink)，而超連結可以說是基本中的基本，因此你會非常常在網頁上看到，例如：",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"超連結","https:\u002F\u002Fi.imgur.com\u002FBCAXFGr.png",[16,33,34],{},"而基本寫法如下：",[36,37,42],"pre",{"className":38,"code":39,"language":40,"meta":41,"style":41},"language-html shiki shiki-themes github-dark-high-contrast","\u003Ca href=\"\u002F\">這是超連結的文字\u003C\u002Fa>\n","html","",[43,44,45],"code",{"__ignoreMap":41},[46,47,50,54,58,62,65,69,72,74],"span",{"class":48,"line":49},"line",1,[46,51,53],{"class":52},"sMAXC","\u003C",[46,55,57],{"class":56},"sKpQp","a",[46,59,61],{"class":60},"sCcAr"," href",[46,63,64],{"class":52},"=",[46,66,68],{"class":67},"sTRMh","\"\u002F\"",[46,70,71],{"class":52},">這是超連結的文字\u003C\u002F",[46,73,57],{"class":56},[46,75,76],{"class":52},">\n",[16,78,79],{},"超連結也有相當多種的寫法，例如支援電子信箱的連結：",[36,81,83],{"className":38,"code":82,"language":40,"meta":41,"style":41},"\u003Ca href=\"mailto:\">開啟電子信箱\u003C\u002Fa>\n",[43,84,85],{"__ignoreMap":41},[46,86,87,89,91,93,95,98,101,103],{"class":48,"line":49},[46,88,53],{"class":52},[46,90,57],{"class":56},[46,92,61],{"class":60},[46,94,64],{"class":52},[46,96,97],{"class":67},"\"mailto:\"",[46,99,100],{"class":52},">開啟電子信箱\u003C\u002F",[46,102,57],{"class":56},[46,104,76],{"class":52},[16,106,107],{},"還有支援當手機點到此連結就會自動撥通電話的連結：",[36,109,111],{"className":38,"code":110,"language":40,"meta":41,"style":41},"\u003Ca href=\"tel:+12345678\">點我打電話\u003C\u002Fa>\n",[43,112,113],{"__ignoreMap":41},[46,114,115,117,119,121,123,126,129,131],{"class":48,"line":49},[46,116,53],{"class":52},[46,118,57],{"class":56},[46,120,61],{"class":60},[46,122,64],{"class":52},[46,124,125],{"class":67},"\"tel:+12345678\"",[46,127,128],{"class":52},">點我打電話\u003C\u002F",[46,130,57],{"class":56},[46,132,76],{"class":52},[16,134,135,136,139],{},"當然還有一個是 ",[43,137,138],{},"ftp"," 屬性，但是現在應該很少人用了，所以就不示範囉。",[16,141,142,143,146],{},"另外超連結還有所謂的提示訊息 ",[43,144,145],{},"title"," 屬性，當使用者滑鼠停在該連結時會出現一個小提示視窗",[16,148,149],{},[28,150],{"alt":145,"src":151},"https:\u002F\u002Fi.imgur.com\u002F7diGJte.png",[36,153,155],{"className":38,"code":154,"language":40,"meta":41,"style":41},"\u003Ca href=\"\u002F\" title=\"是 Ray 不是 Array\">這是超連結的文字\u003C\u002Fa>\n",[43,156,157],{"__ignoreMap":41},[46,158,159,161,163,165,167,169,172,174,177,179,181],{"class":48,"line":49},[46,160,53],{"class":52},[46,162,57],{"class":56},[46,164,61],{"class":60},[46,166,64],{"class":52},[46,168,68],{"class":67},[46,170,171],{"class":60}," title",[46,173,64],{"class":52},[46,175,176],{"class":67},"\"是 Ray 不是 Array\"",[46,178,71],{"class":52},[46,180,57],{"class":56},[46,182,76],{"class":52},[16,184,185,186,189],{},"那麼接下來就來準備介紹重頭戲，也就是超連結裡面的 ",[43,187,188],{},"target"," 屬性。",[12,191,188],{"id":188},[16,193,194,196],{},[43,195,188],{}," 顧名思義就是超連結的目標屬性，它主要有以下參數",[198,199,200,210,215,220],"ul",{},[201,202,203,206,207,209],"li",{},[43,204,205],{},"_self"," (預設 ",[43,208,188],{},")",[201,211,212],{},[43,213,214],{},"_blank",[201,216,217],{},[43,218,219],{},"_parent",[201,221,222],{},[43,223,224],{},"_top",[226,227,205],"h3",{"id":205},[16,229,230,231,233,234,236],{},"首先先講講 ",[43,232,205],{}," 這個屬性，簡單來講就是當你點這個網址時會直接在你目前的瀏覽器分頁視窗進入到該目標，但預設的 ",[43,235,57],{}," 連結就是這個屬性",[16,238,239],{},"你可以試著點下方連結，你會發現 Codepen 另一個視窗直接進入到我的部落格",[241,242,249],"iframe",{"height":243,"style":244,"scrolling":245,"title":205,"src":246,"frameBorder":245,"loading":247,"allowTransparency":248,"allowFullScreen":248},300,"width: 100%;","no","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FrNzNdrR?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FrNzNdrR\">\n  _self\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[226,251,214],{"id":214},[16,253,254,256],{},[43,255,214],{}," 這個屬性算是非常常常使用的屬性，這個屬性的功能主要是另外開啟一個視窗，通常會是為了避免使用者離開你的網頁畫面而使用這個屬性",[16,258,259],{},"你可以試著點以下連結，你會發現直接另開一個視窗",[241,261,263],{"height":243,"style":244,"scrolling":245,"title":214,"src":262,"frameBorder":245,"loading":247,"allowTransparency":248,"allowFullScreen":248},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FQWMWmYB?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FQWMWmYB\">\n  _blank\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[226,265,267],{"id":266},"parent-與-top","parent 與 top",[16,269,270,272,273,275],{},[43,271,219],{}," 與 ",[43,274,224],{}," 這兩個屬性簡單來講都是跟巢狀視窗有關係，但實際來講這兩個屬性已經很少使用了，所以就不多做說明。",[12,277,279],{"id":278},"統一調整-target","統一調整 target",[16,281,282,283,285,286,288,289,291],{},"我們在實際開發時，往往因為 ",[43,284,57],{}," 超連結預設是 ",[43,287,205],{}," 的關係，而導致我們必須每一次要另開視窗時都必須額外寫上 ",[43,290,188],{}," 以及相關的完整連結路徑",[36,293,295],{"className":38,"code":294,"language":40,"meta":41,"style":41},"\u003Ca href=\"\u002Findex.html\" target=\"_blank\">部落格網址\u003C\u002Fa>\n",[43,296,297],{"__ignoreMap":41},[46,298,299,301,303,305,307,310,313,315,318,321,323],{"class":48,"line":49},[46,300,53],{"class":52},[46,302,57],{"class":56},[46,304,61],{"class":60},[46,306,64],{"class":52},[46,308,309],{"class":67},"\"\u002Findex.html\"",[46,311,312],{"class":60}," target",[46,314,64],{"class":52},[46,316,317],{"class":67},"\"_blank\"",[46,319,320],{"class":52},">部落格網址\u003C\u002F",[46,322,57],{"class":56},[46,324,76],{"class":52},[16,326,327],{},"當頁面上的連結超多的時候就會變得很麻煩，可能會像這樣",[36,329,331],{"className":38,"code":330,"language":40,"meta":41,"style":41},"\u003Ca href=\"\u002Findex.html\" target=\"_blank\">部落格網址首頁\u003C\u002Fa>\n\u003Ca href=\"\u002Flearnexp\u002F20200112\u002F1752686187\u002F\" target=\"_blank\">欠人教訓的提問 & 發問\u003C\u002Fa>\n\u003Ca href=\"\u002Flearnexp\u002F20210710\u002F1926104502\u002F\" target=\"_blank\">創造被動收入之前的準備與理財入門 \u003C\u002Fa>\n\u003Ca href=\"\u002Flinks\u002F\" target=\"_blank\">更多資訊\u003C\u002Fa>\n",[43,332,333,358,385,412],{"__ignoreMap":41},[46,334,335,337,339,341,343,345,347,349,351,354,356],{"class":48,"line":49},[46,336,53],{"class":52},[46,338,57],{"class":56},[46,340,61],{"class":60},[46,342,64],{"class":52},[46,344,309],{"class":67},[46,346,312],{"class":60},[46,348,64],{"class":52},[46,350,317],{"class":67},[46,352,353],{"class":52},">部落格網址首頁\u003C\u002F",[46,355,57],{"class":56},[46,357,76],{"class":52},[46,359,361,363,365,367,369,372,374,376,378,381,383],{"class":48,"line":360},2,[46,362,53],{"class":52},[46,364,57],{"class":56},[46,366,61],{"class":60},[46,368,64],{"class":52},[46,370,371],{"class":67},"\"\u002Flearnexp\u002F20200112\u002F1752686