,[53,1744,443],{"class":59},[53,1746,189],{"class":63},[53,1748,72],{"class":59},[53,1750,1751],{"class":55,"line":330},[53,1752,79],{"emptyLinePlaceholder":78},[53,1754,1755,1757,1759],{"class":55,"line":344},[53,1756,60],{"class":59},[53,1758,189],{"class":63},[53,1760,72],{"class":59},[53,1762,1763,1765,1767,1770,1772],{"class":55,"line":971},[53,1764,428],{"class":59},[53,1766,20],{"class":63},[53,1768,1769],{"class":59},">最新文章\u003C\u002F",[53,1771,20],{"class":63},[53,1773,72],{"class":59},[53,1775,1776,1778,1780,1782,1784],{"class":55,"line":981},[53,1777,428],{"class":59},[53,1779,12],{"class":63},[53,1781,1736],{"class":59},[53,1783,12],{"class":63},[53,1785,72],{"class":59},[53,1787,1788,1790,1792],{"class":55,"line":991},[53,1789,443],{"class":59},[53,1791,189],{"class":63},[53,1793,72],{"class":59},[1795,1796,1799],"callout",{"title":1797,"type":1798},"Note","note",[12,1800,1801,1802,1804,1805,539,1807,1809],{},"只是這邊要注意一件事情，有些人會把 ",[50,1803,189],{}," 拿來做 CSS 排版，這是一個錯誤的行為，如果你要排版的話正確是使用 ",[50,1806,87],{},[50,1808,189],{}," 標籤是用來區分群組區塊的。",[12,1811,1812,1814,1815,1817,1818,1820,1821,1823,1824,1826,1827,1461,1829,1831],{},[50,1813,192],{}," 跟 ",[50,1816,189],{}," 的概念非常接近，但是還是有有一定得差異，",[50,1819,192],{}," 的意思就是文章，而 ",[50,1822,189],{}," 的意思是群組區塊，所以 ",[50,1825,192],{}," 標籤通常會搭配 ",[50,1828,177],{},[50,1830,180],{}," 一起使用，像是：",[43,1833,1835],{"className":45,"code":1834,"language":47,"meta":48,"style":48},"\u003Carticle>\n  \u003Cheader>\n    \u003Ch2>文章標題\u003C\u002Fh2>\n    \u003Cp>作者\u003C\u002Fp>\n  \u003C\u002Fheader>\n  \u003Cp>文章內容\u003C\u002Fp>\n  \u003Cfooter>\n    \u003Cp>發布日期\u003C\u002Fp>\n  \u003C\u002Ffooter>\n\u003C\u002Farticle>\n",[50,1836,1837,1845,1853,1866,1879,1887,1900,1908,1921,1929],{"__ignoreMap":48},[53,1838,1839,1841,1843],{"class":55,"line":56},[53,1840,60],{"class":59},[53,1842,192],{"class":63},[53,1844,72],{"class":59},[53,1846,1847,1849,1851],{"class":55,"line":75},[53,1848,428],{"class":59},[53,1850,177],{"class":63},[53,1852,72],{"c