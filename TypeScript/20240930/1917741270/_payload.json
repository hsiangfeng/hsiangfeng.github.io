[{"data":1,"prerenderedAt":980},["ShallowReactive",2],{"header-locale:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":3,"page:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":4,"alt:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":3,"prev-next:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":957,"related:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":966},"\u002Fen\u002Ftypescript\u002F2024\u002F09\u002F30\u002Ftypescript-generics-and-vue3-generics\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":940,"date":941,"description":25,"extension":942,"lang":943,"meta":944,"navigation":529,"path":945,"readingMinutes":946,"seo":947,"standalone":948,"stem":949,"tags":950,"tldr":954,"updated":941,"url":955,"__hash__":956},"content\u002FTypeScript\u002F掌握-TypeScript-泛型（Generics）.md","掌握 TypeScript 泛型（Generics） & Vue3 泛型","1917741270",{"type":9,"value":10,"toc":935},"minimark",[11,19,23,26,30,33,73,90,114,117,174,199,206,250,256,259,265,317,333,357,377,398,404,409,420,425,440,445,454,460,486,489,573,686,692,704,708,715,726,842,852,855,891,897,908,911,916,921,931],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"TypeScript Generics","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F_0fbe4102-c5ef-4b05-8d59-c24cae6aa12c.jpg",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"泛型（Generics）是 TypeScript 中很重要的特性，它可以大幅度簡化程式碼的撰寫，並提高程式碼的可讀性，但是 TypeScript 的泛型也是初學者最難理解的部分之一，所以就來寫一篇文章來介紹 TypeScript 的泛型。",[20,27,29],{"id":28},"什麼是泛型","什麼是泛型？",[12,31,32],{},"在說明泛型之前，我們先來看一下基本常見的型別宣告：",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-ts shiki shiki-themes github-light github-light github-dark-high-contrast","const myName: string = 'Ray';\n","ts","",[41,42,43],"code",{"__ignoreMap":39},[44,45,48,52,56,59,62,65,69],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sOudu","const",[44,53,55],{"class":54},"stw71"," myName",[44,57,58],{"class":50},":",[44,60,61],{"class":54}," string",[44,63,64],{"class":50}," =",[44,66,68],{"class":67},"sWayO"," 'Ray'",[44,70,72],{"class":71},"s8XSl",";\n",[12,74,75,76,79,80,83,84,86,87,89],{},"上方的例子中，我們宣告了一個常數 ",[41,77,78],{},"myName","，並指定型別為 ",[41,81,82],{},"string","，這有助於我們在開發時，可以透過編輯器的提示來知道 ",[41,85,78],{}," 的型別為 ",[41,88,82],{},"，這樣就可以避免在開發時發生型別錯誤。",[91,92,95],"callout",{"title":93,"type":94},"Note","note",[12,96,97,98,101,102,105,106,109,110,113],{},"型別錯誤，在此是指 JavaScript 的隱含型別轉型導致的錯誤，例如：",[41,99,100],{},"1 + '1'"," 會得到 ",[41,103,104],{},"'11'","，這是因為 JavaScript 會將數字 ",[41,107,108],{},"1"," 轉換為字串 ",[41,111,112],{},"'1'","，再進行字串相加。",[12,115,116],{},"除此之外，我們也可以透過函式來指定型別：",[34,118,120],{"className":36,"code":119,"language":38,"meta":39,"style":39},"function sayHello(name: string): string {\n  return `Hello, ${name}`;\n}\n",[41,121,122,152,168],{"__ignoreMap":39},[44,123,124,127,131,134,138,140,142,145,147,149],{"class":46,"line":47},[44,125,126],{"class":50},"function",[44,128,130],{"class":129},"scAaK"," sayHello",[44,132,133],{"class":71},"(",[44,135,137],{"class":136},"syBk-","name",[44,139,58],{"class":50},[44,141,61],{"class":54},[44,143,144],{"class":71},")",[44,146,58],{"class":50},[44,148,61],{"class":54},[44,150,151],{"class":71}," {\n",[44,153,155,158,161,163,166],{"class":46,"line":154},2,[44,156,157],{"class":50},"  return",[44,159,160],{"class":67}," `Hello, ${",[44,162,137],{"class":71},[44,164,165],{"class":67},"}`",[44,167,72],{"class":71},[44,169,171],{"class":46,"line":170},3,[44,172,173],{"class":71},"}\n",[12,175,176,177,180,181,86,183,185,186,188,189,191,192,86,194,185,196,198],{},"上方的程式碼中，意思是指宣告一個函式 ",[41,178,179],{},"sayHello","，並指定參數 ",[41,182,137],{},[41,184,82],{},"，回傳值的型別也為 ",[41,187,82],{},"，這樣就可以確保在呼叫 ",[41,190,179],{}," 函式時，參數 ",[41,193,137],{},[41,195,82],{},[41,197,82],{},"。",[12,200,201,202,205],{},"但是有時候我們並不知道參數的型別，你可能會想說就用 ",[41,203,204],{},"any"," 型別",[34,207,209],{"className":36,"code":208,"language":38,"meta":39,"style":39},"function sayHello(name: any): any {\n  return `Hello, ${name}`;\n}\n",[41,210,211,234,246],{"__ignoreMap":39},[44,212,213,215,217,219,221,223,226,228,230,232],{"class":46,"line":47},[44,214,126],{"class":50},[44,216,130],{"class":129},[44,218,133],{"class":71},[44,220,137],{"class":136},[44,222,58],{"class":50},[44,224,225],{"class":54}," any",[44,227,144],{"class":71},[44,229,58],{"class":50},[44,231,225],{"class":54},[44,233,151],{"class":71},[44,235,236,238,240,242,244],{"class":46,"line":154},[44,237,157],{"class":50},[44,239,160],{"class":67},[44,241,137],{"class":71},[44,243,165],{"class":67},[44,245,72],{"class":71},[44,247,248],{"class":46,"line":170},[44,249,173],{"class":71},[12,251,252,253,255],{},"但是這樣的寫法並不安全，因為 ",[41,254,204],{}," 型別會讓 TypeScript 失去型別檢查的功能，這樣反而會增加程式碼的錯誤率以及失去使用 TypeScript 的意義。",[12,257,258],{},"那麼接下來就要來介紹泛型了，泛型是一種讓 TypeScript 可以在不指定型別的情況下，讓 TypeScript 自動推斷型別的一種特性，簡單來講泛型就是「型別參數化」。",[12,260,261,262,264],{},"什麼意思呢？就是當我們不知道參數的型別時，可以透過泛型來讓 TypeScript 自動推斷型別，這樣就可以避免使用 ",[41,263,204],{}," 型別，讓 TypeScript 保持型別檢查的功能。",[34,266,268],{"className":36,"code":267,"language":38,"meta":39,"style":39},"function sayHello\u003CT>(name: T): T {\n  return `Hello, ${name}`;\n}\n",[41,269,270,301,313],{"__ignoreMap":39},[44,271,272,274,276,279,283,286,288,290,293,295,297,299],{"class":46,"line":47},[44,273,126],{"class":50},[44,275,130],{"class":129},[44,277,278],{"class":71},"\u003C",[44,280,282],{"class":281},"smYoP","T",[44,284,285],{"class":71},">(",[44,287,137],{"class":136},[44,289,58],{"class":50},[44,291,292],{"class":281}," T",[44,294,144],{"class":71},[44,296,58],{"class":50},[44,298,292],{"class":281},[44,300,151],{"class":71},[44,302,303,305,307,309,311],{"class":46,"line":154},[44,304,157],{"class":50},[44,306,160],{"class":67},[44,308,137],{"class":71},[44,310,165],{"class":67},[44,312,72],{"class":71},[44,314,315],{"class":46,"line":170},[44,316,173],{"class":71},[12,318,319,320,323,324,326,327,329,330,332],{},"使用方式非常簡單，只要在函式名稱後面加上 ",[41,321,322],{},"\u003CT>","，這樣就可以讓 TypeScript 知道這是一個泛型函式，而 ",[41,325,282],{}," 就是型別參數，當我們呼叫 ",[41,328,179],{}," 函式時，TypeScript 就會自動推斷 ",[41,331,137],{}," 的型別。",[34,334,336],{"className":36,"code":335,"language":38,"meta":39,"style":39},"const result = sayHello('Ray');\n",[41,337,338],{"__ignoreMap":39},[44,339,340,342,345,347,349,351,354],{"class":46,"line":47},[44,341,51],{"class":50},[44,343,344],{"class":54}," result",[44,346,64],{"class":50},[44,348,130],{"class":129},[44,350,133],{"class":71},[44,352,353],{"class":67},"'Ray'",[44,355,356],{"class":71},");\n",[12,358,359,360,362,363,365,366,86,368,370,371,374,375,198],{},"上方的程式碼中，我們呼叫 ",[41,361,179],{}," 函式，並傳入字串 ",[41,364,353],{},"，這樣 TypeScript 就會自動推斷 ",[41,367,137],{},[41,369,82],{},"，而 ",[41,372,373],{},"result"," 的型別也會是 ",[41,376,82],{},[91,378,379],{"title":93,"type":94},[12,380,381,383,384,387,388,387,391,387,394,397],{},[41,382,322],{}," 其實是一個型別參數並沒有特定的名稱，你可以使用任何名稱，例如：",[41,385,386],{},"\u003CType>","、",[41,389,390],{},"\u003CU>",[41,392,393],{},"\u003CV>",[41,395,396],{},"\u003CG>"," 等等。",[12,399,400,401,403],{},"有點難懂嗎？沒關係，這次我們搭配圖片來理解，首先當我們撰寫 ",[41,402,322],{}," 之後，它在呼叫時將傳入的型別往後傳遞",[12,405,406],{},[15,407],{"alt":17,"src":408},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.35.33.png",[12,410,411,412,415,416,86,418],{},"我們前面 ",[41,413,414],{},"const result = sayHello('Ray');"," 傳入的是一個字串，那麼 TypeScript 就會自動推斷 ",[41,417,282],{},[41,419,82],{},[12,421,422],{},[15,423],{"alt":17,"src":424},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.37.44.png",[12,426,427,428,430,431,433,434,436,437,439],{},"我們可以看到上方圖解 ",[41,429,322],{}," 被替換成了 ",[41,432,82],{},"，接著這個 ",[41,435,82],{}," 就會被傳遞到後面的 ",[41,438,137],{}," 與回傳值，這樣就可以讓 TypeScript 自動推斷型別",[12,441,442],{},[15,443],{"alt":17,"src":444},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.41.37.png",[12,446,447,448,450,451,453],{},"而上方這種直接呼叫 ",[41,449,179],{}," 函式並傳入字串 ",[41,452,353],{}," 的方式，稱之為「明確型別」，也就是 TypeScript 可以自動推斷型別，這樣就可以讓 TypeScript 保持型別檢查的功能。",[12,455,456,457,459],{},"但如果你想要自己手動指定型別，也是可以的，只要在呼叫 ",[41,458,179],{}," 函式時，指定型別即可",[34,461,463],{"className":36,"code":462,"language":38,"meta":39,"style":39},"const result = sayHello\u003Cnumber>('Ray');\n",[41,464,465],{"__ignoreMap":39},[44,466,467,469,471,473,475,477,480,482,484],{"class":46,"line":47},[44,468,51],{"class":50},[44,470,344],{"class":54},[44,472,64],{"class":50},[44,474,130],{"class":129},[44,476,278],{"class":71},[44,478,479],{"class":54},"number",[44,481,285],{"class":71},[44,483,353],{"class":67},[44,485,356],{"class":71},[12,487,488],{},"當然泛型不只侷限於函式，你也可以用於介面、類別",[34,490,492],{"className":36,"code":491,"language":38,"meta":39,"style":39},"interface Response\u003CT> {\n  data: T;\n}\n\nconst response: Response\u003Cstring> = {\n  data: 'Hello, World',\n};\n",[41,493,494,509,520,524,531,555,567],{"__ignoreMap":39},[44,495,496,499,502,504,506],{"class":46,"line":47},[44,497,498],{"class":50},"interface",[44,500,501],{"class":281}," Response",[44,503,278],{"class":71},[44,505,282],{"class":281},[44,507,508],{"class":71},"> {\n",[44,510,511,514,516,518],{"class":46,"line":154},[44,512,513],{"class":136},"  data",[44,515,58],{"class":50},[44,517,292],{"class":281},[44,519,72],{"class":71},[44,521,522],{"class":46,"line":170},[44,523,173],{"class":71},[44,525,527],{"class":46,"line":526},4,[44,528,530],{"emptyLinePlaceholder":529},true,"\n",[44,532,534,536,539,541,543,545,547,550,553],{"class":46,"line":533},5,[44,535,51],{"class":50},[44,537,538],{"class":54}," response",[44,540,58],{"class":50},[44,542,501],{"class":281},[44,544,278],{"class":71},[44,546,82],{"class":54},[44,548,549],{"class":71},"> ",[44,551,552],{"class":50},"=",[44,554,151],{"class":71},[44,556,558,561,564],{"class":46,"line":557},6,[44,559,560],{"class":