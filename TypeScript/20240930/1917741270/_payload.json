690,691,692,694],{},"透過泛型，我們就可以避免使用 ",[41,693,206],{}," 型別，讓 TypeScript 保持型別檢查的功能，這樣就可以讓程式碼更加安全且可讀。",[12,696,697,698,701,702,705],{},"所以最後我們簡單結論一下，其實泛型的概念是將「",[96,699,700],{},"型別參數化","」，另一種理解可以理解成「",[96,703,704],{},"型別延後指定","」的一種方式哩～",[20,707,709],{"id":708},"關於-vue-泛型","關於 Vue 泛型",[12,711,712,713,716],{},"Vue 在 3.3 之後針對 SFC(Single File Component) 的 ",[41,714,715],{},"\u003Cscript setup>"," 提供了泛型的支援，早期 Vue 其實並不容易使用 TypeScript，但是在 3.3 之後，Vue 提供了更多的 TypeScript 支援，",[12,718,719,720,727],{},"那麼 Vue3 該如何撰寫泛型呢？其實很簡單，在 ",[721,722,726],"a",{"href":723,"rel":724},"https:\u002F\u002Fvuejs.org\u002Fapi\u002Fsfc-script-setup.html#generics",[725],"nofollow","官方文件"," 其實是有提供範例的，例如：",[34,729,733],{"className":730,"code":731,"language":732,"meta":39,"style":39},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript\n  setup\n  lang=\"ts\"\n  generic=\"T extends string | number, U extends Item\"\n>\nimport type { Item } from '.\u002Ftypes';\n\ndefineProps\u003C{\n  id: T\n  list: U[]\n}>()\n\u003C\u002Fscript>\n","html",[41,734,735,743,748,758,768,773,792,796,804,814,827,832],{"__ignoreMap":39},[44,736,737,739],{"class":46,"line":47},[44,738,280],{"class":71},[44,740,742],{"class":741},"sKpQp","script\n",[44,744,745],{"class":46,"line":156},[44,746,747],{"class":54},"  setup\n",[44,749,750,753,755],{"class":46,"line":172},[44,751,752],{"class":54},"  lang",[44,754,555],{"class":71},[44,756,757],{"class":67},"\"ts\"\n",[44,759,760,763,765],{"class":46,"line":529},[44,761,762],{"class":54},"  generic",[44,764,555],{"class":71},[44,766,767],{"class":67},"\"T extends string | number, U extends Item\"\n",[44,769,770],{"class":46,"line":536},[44,771,772],{"class":71},">\n",[44,774,775,778,781,784,787,790],{"class":46,"line":560},[44,776,777],{"class":50},"import",[44,779,780],{"class":50}," type",[44,782,783],{"class":71}," { Item } ",[44,785,786],{"class":50},"from",[44,788,789],{"class":67}," '.\u002Ftypes'",[44,791,72],{"class":71},[44,793,794],{"class":46,"line":572},[44,795,533],{"emptyLinePlaceholder":532},[44,797,798,801],{"class":46,"line":654},[44,799,800],{"class":131},"defineProps",[44,802,803],{"class":71},"\u003C{\n",[44,805,806,809,811],{"class":46,"line":669},[44,807,808],{"class":138},"  id",[44,810,58],{"class":50},[44,812,813],{"class":138}," T\n",[44,815,816,819,821,824],{"class":46,"line":681},[44,817,818],{"class":138},"  list",[44,820,58],{"class":50},[44,822,823],{"class":138}," U",[44,825,826],{"class":71},"[]\n",[44,828,829],{"class":46,"line":686},[44,830,831],{"class":71},"}>()\n",[44,833,835,838,841],{"class":46,"line":834},12,[44,836,837],{"class":71},"\u003C\u002F",[44,839,840],{"class":741},"script",[44,842,772],{"class":71},[12,844,845,846,848,849,852],{},"使用方式其實就是直接在 ",[41,847,715],{}," 中加上 ",[41,850,851],{},"generic"," 屬性，並指定泛型的型別，這樣就可以讓 Vue3 支援泛型了～",[12,854,855],{},"但我們可以看到 Vue 中撰寫泛型的方式與一般 TypeScript 有些許不同，所以這邊我也簡單地講解一下上方的程式碼：",[857,858,859,873],"ol",{},[860,861,862,865,866,86,868,870,871],"li",{},[41,863,864],{},"T extends string | number","：這是指定 ",[41,867,283],{},[41,869,82],{}," 或 ",[41,872,482],{},[860,874,875,865,878,86,881,884,885,887,888,891],{},[41,876,877],{},"U extends Item",[41,879,880],{},"U",[41,882,883],{},"Item","，這邊的 ",[41,886,883],{}," 是從 ",[41,889,890],{},".\u002Ftypes"," 中引入的型別",[12,893,894],{},[15,895],{"alt":896,"src":897},"Vue3 Generics","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2014.38.35.png",[12,899,900,901,904,905,908],{},"那麼 ",[41,902,903],{},","," 是在分隔不同的泛型的，所以其實你是可以寫很多個泛型的，例如：",[41,906,907],{},"T extends string | number, U extends Item, V extends boolean","，這樣就可以寫很多個泛型了～",[12,910,911],{},"但這邊也為了讓整體更好理解，所以我稍微簡化一下圖片",[12,913,914],{},[15,915],{"alt":896,"src":916},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2014.45.55.png",[12,918,919],{},[15,920],{"alt":896,"src":921},"https:\u002F\u002Fimages.i