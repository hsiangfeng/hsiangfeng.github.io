[{"data":1,"prerenderedAt":981},["ShallowReactive",2],{"header-locale:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":3,"page:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":4,"alt:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":3,"prev-next:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":958,"related:\u002FTypeScript\u002F20240930\u002F1917741270\u002F":967},"\u002Fen\u002Ftypescript\u002F2024\u002F09\u002F30\u002Ftypescript-generics-and-vue3-generics\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":941,"date":942,"description":25,"extension":943,"lang":944,"meta":945,"navigation":532,"path":946,"readingMinutes":947,"seo":948,"standalone":949,"stem":950,"tags":951,"tldr":955,"updated":942,"url":956,"__hash__":957},"content\u002FTypeScript\u002F掌握-TypeScript-泛型（Generics）.md","掌握 TypeScript 泛型（Generics） & Vue3 泛型","1917741270",{"type":9,"value":10,"toc":936},"minimark",[11,19,23,26,30,33,73,90,116,119,176,201,208,252,258,261,267,318,334,358,378,401,407,412,423,428,443,448,457,463,489,492,576,689,695,706,710,717,728,843,853,856,892,898,909,912,917,922,932],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"TypeScript Generics","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F_0fbe4102-c5ef-4b05-8d59-c24cae6aa12c.jpg",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"泛型（Generics）是 TypeScript 中很重要的特性，它可以大幅度簡化程式碼的撰寫，並提高程式碼的可讀性，但是 TypeScript 的泛型也是初學者最難理解的部分之一，所以就來寫一篇文章來介紹 TypeScript 的泛型。",[20,27,29],{"id":28},"什麼是泛型","什麼是泛型？",[12,31,32],{},"在說明泛型之前，我們先來看一下基本常見的型別宣告：",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-ts shiki shiki-themes github-dark-high-contrast","const myName: string = 'Ray';\n","ts","",[41,42,43],"code",{"__ignoreMap":39},[44,45,48,52,56,59,62,65,69],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sWyjQ","const",[44,53,55],{"class":54},"sCcAr"," myName",[44,57,58],{"class":50},":",[44,60,61],{"class":54}," string",[44,63,64],{"class":50}," =",[44,66,68],{"class":67},"sTRMh"," 'Ray'",[44,70,72],{"class":71},"sMAXC",";\n",[12,74,75,76,79,80,83,84,86,87,89],{},"上方的例子中，我們宣告了一個常數 ",[41,77,78],{},"myName","，並指定型別為 ",[41,81,82],{},"string","，這有助於我們在開發時，可以透過編輯器的提示來知道 ",[41,85,78],{}," 的型別為 ",[41,88,82],{},"，這樣就可以避免在開發時發生型別錯誤。",[91,92,93],"blockquote",{},[12,94,95,99,100,103,104,107,108,111,112,115],{},[96,97,98],"strong",{},"Note","\n型別錯誤，在此是指 JavaScript 的隱含型別轉型導致的錯誤，例如：",[41,101,102],{},"1 + '1'"," 會得到 ",[41,105,106],{},"'11'","，這是因為 JavaScript 會將數字 ",[41,109,110],{},"1"," 轉換為字串 ",[41,113,114],{},"'1'","，再進行字串相加。",[12,117,118],{},"除此之外，我們也可以透過函式來指定型別：",[34,120,122],{"className":36,"code":121,"language":38,"meta":39,"style":39},"function sayHello(name: string): string {\n  return `Hello, ${name}`;\n}\n",[41,123,124,154,170],{"__ignoreMap":39},[44,125,126,129,133,136,140,142,144,147,149,151],{"class":46,"line":47},[44,127,128],{"class":50},"function",[44,130,132],{"class":131},"sj_SG"," sayHello",[44,134,135],{"class":71},"(",[44,137,139],{"class":138},"s_sBn","name",[44,141,58],{"class":50},[44,143,61],{"class":54},[44,145,146],{"class":71},")",[44,148,58],{"class":50},[44,150,61],{"class":54},[44,152,153],{"class":71}," {\n",[44,155,157,160,163,165,168],{"class":46,"line":156},2,[44,158,159],{"class":50},"  return",[44,161,162],{"class":67}," `Hello, ${",[44,164,139],{"class":71},[44,166,167],{"class":67},"}`",[44,169,72],{"class":71},[44,171,173],{"class":46,"line":172},3,[44,174,175],{"class":71},"}\n",[12,177,178,179,182,183,86,185,187,188,190,191,193,194,86,196,187,198,200],{},"上方的程式碼中，意思是指宣告一個函式 ",[41,180,181],{},"sayHello","，並指定參數 ",[41,184,139],{},[41,186,82],{},"，回傳值的型別也為 ",[41,189,82],{},"，這樣就可以確保在呼叫 ",[41,192,181],{}," 函式時，參數 ",[41,195,139],{},[41,197,82],{},[41,199,82],{},"。",[12,202,203,204,207],{},"但是有時候我們並不知道參數的型別，你可能會想說就用 ",[41,205,206],{},"any"," 型別",[34,209,211],{"className":36,"code":210,"language":38,"meta":39,"style":39},"function sayHello(name: any): any {\n  return `Hello, ${name}`;\n}\n",[41,212,213,236,248],{"__ignoreMap":39},[44,214,215,217,219,221,223,225,228,230,232,234],{"class":46,"line":47},[44,216,128],{"class":50},[44,218,132],{"class":131},[44,220,135],{"class":71},[44,222,139],{"class":138},[44,224,58],{"class":50},[44,226,227],{"class":54}," any",[44,229,146],{"class":71},[44,231,58],{"class":50},[44,233,227],{"class":54},[44,235,153],{"class":71},[44,237,238,240,242,244,246],{"class":46,"line":156},[44,239,159],{"class":50},[44,241,162],{"class":67},[44,243,139],{"class":71},[44,245,167],{"class":67},[44,247,72],{"class":71},[44,249,250],{"class":46,"line":172},[44,251,175],{"class":71},[12,253,254,255,257],{},"但是這樣的寫法並不安全，因為 ",[41,256,206],{}," 型別會讓 TypeScript 失去型別檢查的功能，這樣反而會增加程式碼的錯誤率以及失去使用 TypeScript 的意義。",[12,259,260],{},"那麼接下來就要來介紹泛型了，泛型是一種讓 TypeScript 可以在不指定型別的情況下，讓 TypeScript 自動推斷型別的一種特性，簡單來講泛型就是「型別參數化」。",[12,262,263,264,266],{},"什麼意思呢？就是當我們不知道參數的型別時，可以透過泛型來讓 TypeScript 自動推斷型別，這樣就可以避免使用 ",[41,265,206],{}," 型別，讓 TypeScript 保持型別檢查的功能。",[34,268,270],{"className":36,"code":269,"language":38,"meta":39,"style":39},"function sayHello\u003CT>(name: T): T {\n  return `Hello, ${name}`;\n}\n",[41,271,272,302,314],{"__ignoreMap":39},[44,273,274,276,278,281,284,287,289,291,294,296,298,300],{"class":46,"line":47},[44,275,128],{"class":50},[44,277,132],{"class":131},[44,279,280],{"class":71},"\u003C",[44,282,283],{"class":138},"T",[44,285,286],{"class":71},">(",[44,288,139],{"class":138},[44,290,58],{"class":50},[44,292,293],{"class":138}," T",[44,295,146],{"class":71},[44,297,58],{"class":50},[44,299,293],{"class":138},[44,301,153],{"class":71},[44,303,304,306,308,310,312],{"class":46,"line":156},[44,305,159],{"class":50},[44,307,162],{"class":67},[44,309,139],{"class":71},[44,311,167],{"class":67},[44,313,72],{"class":71},[44,315,316],{"class":46,"line":172},[44,317,175],{"class":71},[12,319,320,321,324,325,327,328,330,331,333],{},"使用方式非常簡單，只要在函式名稱後面加上 ",[41,322,323],{},"\u003CT>","，這樣就可以讓 TypeScript 知道這是一個泛型函式，而 ",[41,326,283],{}," 就是型別參數，當我們呼叫 ",[41,329,181],{}," 函式時，TypeScript 就會自動推斷 ",[41,332,139],{}," 的型別。",[34,335,337],{"className":36,"code":336,"language":38,"meta":39,"style":39},"const result = sayHello('Ray');\n",[41,338,339],{"__ignoreMap":39},[44,340,341,343,346,348,350,352,355],{"class":46,"line":47},[44,342,51],{"class":50},[44,344,345],{"class":54}," result",[44,347,64],{"class":50},[44,349,132],{"class":131},[44,351,135],{"class":71},[44,353,354],{"class":67},"'Ray'",[44,356,357],{"class":71},");\n",[12,359,360,361,363,364,366,367,86,369,371,372,375,376,200],{},"上方的程式碼中，我們呼叫 ",[41,362,181],{}," 函式，並傳入字串 ",[41,365,354],{},"，這樣 TypeScript 就會自動推斷 ",[41,368,139],{},[41,370,82],{},"，而 ",[41,373,374],{},"result"," 的型別也會是 ",[41,377,82],{},[91,379,380],{},[12,381,382,384,386,387,390,391,390,394,390,397,400],{},[96,383,98],{},[41,385,323],{}," 其實是一個型別參數並沒有特定的名稱，你可以使用任何名稱，例如：",[41,388,389],{},"\u003CType>","、",[41,392,393],{},"\u003CU>",[41,395,396],{},"\u003CV>",[41,398,399],{},"\u003CG>"," 等等。",[12,402,403,404,406],{},"有點難懂嗎？沒關係，這次我們搭配圖片來理解，首先當我們撰寫 ",[41,405,323],{}," 之後，它在呼叫時將傳入的型別往後傳遞",[12,408,409],{},[15,410],{"alt":17,"src":411},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.35.33.png",[12,413,414,415,418,419,86,421],{},"我們前面 ",[41,416,417],{},"const result = sayHello('Ray');"," 傳入的是一個字串，那麼 TypeScript 就會自動推斷 ",[41,420,283],{},[41,422,82],{},[12,424,425],{},[15,426],{"alt":17,"src":427},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.37.44.png",[12,429,430,431,433,434,436,437,439,440,442],{},"我們可以看到上方圖解 ",[41,432,323],{}," 被替換成了 ",[41,435,82],{},"，接著這個 ",[41,438,82],{}," 就會被傳遞到後面的 ",[41,441,139],{}," 與回傳值，這樣就可以讓 TypeScript 自動推斷型別",[12,444,445],{},[15,446],{"alt":17,"src":447},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%A