[{"data":1,"prerenderedAt":168},["ShallowReactive",2],{"header-locale:\u002FTypeScript\u002F20190622\u002F2982589304\u002F":3,"page:\u002FTypeScript\u002F20190622\u002F2982589304\u002F":4,"alt:\u002FTypeScript\u002F20190622\u002F2982589304\u002F":3,"prev-next:\u002FTypeScript\u002F20190622\u002F2982589304\u002F":144,"related:\u002FTypeScript\u002F20190622\u002F2982589304\u002F":153},"\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-union-types\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":127,"date":128,"description":18,"extension":129,"lang":130,"meta":131,"navigation":132,"path":133,"readingMinutes":134,"seo":135,"standalone":136,"stem":137,"tags":138,"tldr":141,"updated":141,"url":142,"__hash__":143},"content\u002FTypeScript 基礎入門\u002FTypeScript-基礎入門-混和型別.md","TypeScript 基礎入門-混和型別","2982589304",{"type":9,"value":10,"toc":123},"minimark",[11,15,19,22,25,65,68,109,112,119],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面講到 TypeScript 有所謂的型別推論的能力，在這邊再來講一個東西混和型別，這個東西又是什麼呢?讓我們來了解一下",[12,20,21],{"id":21},"混和型別",[16,23,24],{},"以往我們在撰寫 TypeScript 變數的時候會這樣子撰寫",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-ts shiki shiki-themes github-dark-high-contrast","let isA:string = 'Ray';\n","ts","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40,44,48,51,55,58,62],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sWyjQ","let",[36,45,47],{"class":46},"sMAXC"," isA",[36,49,50],{"class":42},":",[36,52,54],{"class":53},"sCcAr","string",[36,56,57],{"class":42}," =",[36,59,61],{"class":60},"sTRMh"," 'Ray'",[36,63,64],{"class":46},";\n",[16,66,67],{},"但是如果我們今天這個變數有可能會有兩種型別該如何撰寫?",[26,69,71],{"className":28,"code":70,"language":30,"meta":31,"style":31},"let isA:string | number = 'Ray';\nisA = 10;\n",[33,72,73,95],{"__ignoreMap":31},[36,74,75,77,79,81,83,86,89,91,93],{"class":38,"line":39},[36,76,43],{"class":42},[36,78,47],{"class":46},[36,80,50],{"class":42},[36,82,54],{"class":53},[36,84,85],{"class":42}," |",[36,87,88],{"class":53}," number",[36,90,57],{"class":42},[36,92,61],{"class":60},[36,94,64],{"class":46},[36,96,98,101,104,107],{"class":38,"line":97},2,[36,99,100],{"class":46},"isA ",[36,102,103],{"class":42},"=",[36,105,106],{"class":53}," 10",[36,108,64],{"class":46},[16,110,111],{},"可以發現並不會出現錯誤唷，那這就是所謂的混和型別，可是如果你傳入的並不是定義的型別時，那就會出現錯誤",[16,113,114],{},[115,116],"img",{"alt":117,"src":118},"型別錯誤","https:\u002F\u002Fi.imgur.com\u002Fupw4grm.png",[120,121,122],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":31,"searchDepth":97,"depth":97,"links":124},[125,126],{"id":14,"depth":97,"text":14},{"id":21,"depth":97,"text":21},"TypeScript","2019-06-22 21:56:38","md","zh-Hant",{},true,"\u002Ftypescript\u002Ftypescript","1",{"title":6,"description":18},false,"TypeScript 基礎入門\u002FTypeScript-基礎入門-混和型別",[139,140,127],"TypeScript 基礎入門","JavaScript",null,"\u002FTypeScript\u002F20190622\u002F2982589304\u002F","fCAn0VHH_uElFS6m3aCh94JCtt6IpjqeVE5GRY7FiQs",{"newer":145,"older":149},{"url":146,"title":147,"date":148},"\u002FTypeScript\u002F20190622\u002F3741788460\u002F","TypeScript 基礎入門-Function","2019-06-22 22:14:41",{"url":150,"title":151,"date":152},"\u002FTypeScript\u002F20190622\u002F2739569432\u002F","TypeScript 基礎入門-型別推論",