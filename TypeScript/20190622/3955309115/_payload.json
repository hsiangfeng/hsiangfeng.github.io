邊就直接快轉到安裝完套件以及 Gulp 環境哩~",[16,70,71],{},"※ 注意 Gulp 環境必須是 Gulp 4 唷!",[16,73,74],{},[32,75],{"alt":76,"src":77},"Image","https:\u002F\u002Fi.imgur.com\u002FsJTtXLB.png",[12,79,80],{"id":80},"變數撰寫",[16,82,83],{},"首先 TypeScript 撰寫變數的方式稍微有點不太一樣，以往我們撰寫變數頂多這樣子",[85,86,91],"pre",{"className":87,"code":88,"language":89,"meta":90,"style":90},"language-js shiki shiki-themes github-dark-high-contrast","const isA = 10;\nconst isB = '小明';\n","js","",[92,93,94,117],"code",{"__ignoreMap":90},[95,96,99,103,107,110,113],"span",{"class":97,"line":98},"line",1,[95,100,102],{"class":101},"sWyjQ","const",[95,104,106],{"class":105},"sCcAr"," isA",[95,108,109],{"class":101}," =",[95,111,112],{"class":105}," 10",[95,114,116],{"class":115},"sMAXC",";\n",[95,118,120,122,125,127,131],{"class":97,"line":119},2,[95,121,102],{"class":101},[95,123,124],{"class":105}," isB",[95,126,109],{"class":101},[95,128,130],{"class":129},"sTRMh"," '小明'",[95,132,116],{"class":115},[16,134,135],{},"但是在 TypeScript 是需要宣告型別的，所以要這樣寫才對",[85,137,141],{"className":138,"code":139,"language":140,"meta":90,"style":90},"language-ts shiki shiki-themes github-dark-high-contrast","const isA: number = 10;\nconst isB: string = '小明';\n","ts",[92,142,143,161],{"__ignoreMap":90},[95,144,145,147,149,152,155,157,159],{"class":97,"line":98},[95,146,102],{"class":101},[95,148,106],{"class":105},[95,150,151],{"class":101},":",[95,153,154],{"class":105}," number",[95,156,109],{"class":101},[95,158,112],{"class":105},[95,160,116],{"class":115},[95,162,163,165,167,169,172,174,176],{"class":97,"line":119},[95,164,102],{"class":101},[95,166,124],{"class":105},[95,168,151],{"class":101},[95,170,171],{"class":105}," string",[95,173,109],{"class":101},[95,175,130],{"class":129},[95,177,116],{"class":115},[16,179,180],{},"編譯出來就會跟原本 JS 相同",[16,182,183],{},[32,184],{"alt":185,"src":186},"TypeScript","https:\u002F\u002Fi.imgur.com\u002FZRWGumI.png",[16,188,189],{},"但是如果不宣告型別會發生什麼事情?一樣可以編譯成功，但是這樣子就會失去撰寫 TypeScript 的好處，所以如果當我們宣告變數是 number，但我們卻手誤寫入 string 那就不一樣了",[85,191,193],{"className":138,"code":192,"language":140,"meta":90,"style":90},"const isA: number = '123';\nconst isB: string = '小明';\n",[92,194,195,212],{"__ignoreMap":90},[95,196,197,199,201,203,205,207,210],{"class":97,"line":98},[95,198,102],{"class":101},[95,200,106],{"class":105},[95,202,151],{"class":101},[95,204,154],{"class":105},[95,206,109],{"class":101},[95,208,209],{"class":129}," '123'",[95,211,116],{"class":115},[95,213,214,216,218,220,222,224,226],{"class":97,"line":119},[95,215,102],{"class":101},[95,217,124],{"class":105},[95,219,151],{"class":101},[95,221,171],{"class":105},[95,223,109],{"class":101},[95,225,130],{"class":129},[95,227,116],{"class":115},[16,229,230],{},"這樣我們就會得到一個錯誤，他在跟你講，你賦予的值，不是一個正確的型別",[16,232,233],{},[32,234],{"alt":235,"src":236},"不是正確的型別","https:\u002F\u002Fi.imgur.com\u002Fp2v3goE.png",[16,238,239],{},"所以 TS 主要型別有這幾種",[85,241,243],{"className":138,"code":242,"language":140,"meta":90,"style":90},"const isA: number = '123';\n\nconst isB: string = '小明';\n\n\u002F\u002F 注意不要使用 new Boolean，因為透過建構函式創造並不是一個 boolean\nconst isC: boolean = false;\n\n\u002F\u002F 在 JavaScript 沒有值的概念可以使用 TypeScript 的 void 做表示，但是聲明 void 基本上沒什麼用處\nconst isD: void = undefined; \u002F\u002F 但是 void 只能傳入 undefined 和 null\n\n\u002F\u002F 另外還可以宣告 undefined 和 null 這兩個型別\nconst isE: undefined = undefined;\nconst isF: null = null;\n",[92,244,245,261,267,284,289,296,316,321,327,351,356,362,380],{"__ignoreMap":90},[95,246,247,249,251,253,255,257,259],{"class":97,"line":98},[95,248,102],{"class":101},[95,250,106],{"class":105},[95,252,151],{"class":101},[95,254,154],{"class":105},[95,256,109],{"class":101},[95,258,209],{"class":129},[95,260,116],{"class":115},[95,262,263],{"class":97,"line":119},[95,264,266],{"emptyLinePlaceholder":265},true,"\n",[95,268,270,272,274,276,278,280,282],{"class":97,"line":269},3,[95,271,102],{"class":101},[95,273,124],{"class":105},[95,275,151],{"class":101},[95,277,171],{"class":105},[95,279,109],{"class":101},[95,281,13