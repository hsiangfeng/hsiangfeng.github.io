[{"data":1,"prerenderedAt":1229},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250925\u002F228905455\u002F":3,"page:\u002Flearnexp\u002F20250925\u002F228905455\u002F":4,"alt:\u002Flearnexp\u002F20250925\u002F228905455\u002F":3,"prev-next:\u002Flearnexp\u002F20250925\u002F228905455\u002F":1204,"related:\u002Flearnexp\u002F20250925\u002F228905455\u002F":1213},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F25\u002Fday-25-why-am-i-suddenly-writing-html-css\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1182,"date":1183,"description":1184,"extension":1185,"lang":1186,"meta":1187,"navigation":1188,"path":1189,"readingMinutes":1190,"seo":1191,"standalone":1192,"stem":1193,"tags":1194,"tldr":1200,"updated":1201,"url":1202,"__hash__":1203},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 25】為什麼我莫名其妙變成了寫 HTML 跟 CSS 的人？.md","【Day 25】為什麼我莫名其妙變成了寫 HTML 跟 CSS 的人？","228905455",{"type":9,"value":10,"toc":1175},"minimark",[11,30,37,41,44,47,50,53,56,59,62,82,85,88,91,104,110,113,119,126,129,132,160,166,169,183,187,206,209,371,385,397,456,463,466,479,501,516,519,551,554,557,560,814,830,833,836,840,854,857,947,957,960,963,966,969,995,1012,1027,1030,1033,1065,1068,1093,1096,1103,1109,1112,1115,1118,1121,1124,1127,1171],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"為什麼我莫名其妙變成了寫 HTML 跟 CSS 的人？","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday25\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8810_01_46.png",[38,39,35],"h2",{"id":40},"為什麼我莫名其妙變成了寫-html-跟-css-的人",[15,42,43],{},"在我出社會頭 2～3 年裡，開發 Web 應用程式基本都靠 PHP，不過那時候的我，對 HTML 的理解只能說是「能顯示就好」，畫面結構、語意之類的完全沒在管。",[15,45,46],{},"雖然我算是很早就接觸 Web 開發，但那個時候 HTML5 還沒流行，主流的排版方式甚至還在用 Table，不過話說回來，也有可能只是因為我自己只會用 Table 來做佈局 XD。",[15,48,49],{},"直到後來進入了新公司才開始真正的開學習 HTML。",[15,51,52],{},"「你們有誰熟悉 Web、HTML、CSS 的？」主管一邊寫著 PHP 一邊問著團隊（只有五個人）。",[15,54,55],{},"「前端有夠難的，HTML 跟 CSS 有夠複雜。」主管問著團隊後，馬上接著抱怨講這句話。",[15,57,58],{},"「啊，那個 Ray，你來寫 HTML 跟 CSS 吧。」主管指著我。",[15,60,61],{},"說真的，當時我完全是莫名其妙就被推去負責 HTML 和 CSS。",[15,63,64,65,69,70,73,74,77,78,81],{},"原本我手上的武器是 PHP，結果臨時被丟去戰場，只能拿著 ",[66,67,68],"code",{},"\u003Cdiv>","跟",[66,71,72],{},"\u003Cspan>","硬上，連 ",[66,75,76],{},"\u003Ch1>","、",[66,79,80],{},"\u003Cp>"," 這些都還在新手村的等級。(ಥ﹏ಥ)",[15,83,84],{},"「好，我試試看。」我沒有拒絕主管的要求，倒不是因為多熱血，而是因為我手上帶著兩個新人。",[15,86,87],{},"說穿了，其實是我自己也不懂，乾脆邊學邊裝懂，再假裝很專業地帶著他們一起學，結果我們三個就像是一支新手村的隊伍 XD。",[15,89,90],{},"回想起來，當時我在找 HTML 和 CSS 的學習資源時，第一個冒出來的就是 W3Schools —— 畢竟它算是相當老牌的教學網站，不過自己看了大概三十分鐘就有點看不下去，於是開始到處翻找其他線上課程資源，像是 TibaMe、Udemy 等等。",[15,92,93,94,103],{},"最後，我決定在 Udemy 上買了一門課程，名字就叫做 ",[18,95,96,97,102],{},"「",[23,98,101],{"href":99,"rel":100},"https:\u002F\u002Fwww.udemy.com\u002Fcourse\u002Fhtml-css-learning\u002F",[27],"使用 HTML、CSS 開發一個網站","」","。",[15,105,106],{},[33,107],{"alt":108,"src":109},"使用 HTML、CSS 開發一個網站（圖源網路)","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday25\u002F20250920133337.png",[15,111,112],{},"是的，這就是我的第一個 HTML 與 CSS 課程，也就是從這個課程開始，我才真正的認識 HTML 與 CSS 的世界，在學習的過程，也讓我想到以前的「無名小站」。",[15,114,115],{},[33,116],{"alt":117,"src":118},"無名小站（圖源網路)","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday25\u002F202509201353.jpg",[15,120,121,122,125],{},"早期的",[18,123,124],{},"無名小站","是一個非常流行的部落格平台，我當時也常在上面寫文章。雖然它後來倒閉了，但對我來說仍是很重要的回憶。",[15,127,128],{},"因為那時候，為了讓自己的部落格看起來更漂亮，大家都會自己動手改版面，而改版面所需要的技術，正是 HTML 和 CSS。所以當我再次接觸 HTML 與 CSS 的時候，腦海裡立刻浮現出當年在無名小站熬夜改版面的畫面。",[15,130,131],{},"這邊也分享一下當時幾個滿流行的平台：",[133,134,135,142,148,154],"ul",{},[136,137,138,141],"li",{},[18,139,140],{},"無名小站（wretch.cc）："," 由交大學生開發，之後成立「無名小站股份有限公司」，再被 Yahoo! 收購，成為 Yahoo! 奇摩的一部分，2013 年 12 月 26 日正式關閉，當時 Yahoo! 奇摩部落格也一併收掉。",[136,143,144,147],{},[18,145,146],{},"yam 天空部落格（blog.yam.com）："," 算是無名用戶的重要避風港，不少人搬家到這裡，但最終也在 2018 年 10 月 1 日關閉並刪除所有資料。",[136,149,150,153],{},[18,151,152],{},"痞客邦（pixnet.net）："," 至今仍在運作，應該算是台灣最大的部落格平台之一（吧？）。不過我個人並沒有使用過。",[136,155,156,159],{},[18,157,158],{},"Blogger（blogger.com）："," Google 旗下的部落格平台，在台灣沒有像無名或痞客邦那樣熱門，但在國際上仍有一定用戶基礎，甚至不少 Google 工程師會用來寫技術文章。",[15,161,162],{},[33,163],{"alt":164,"src":165},"部落格平台（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday25\u002F20250920140622%20(1).png",[15,167,168],{},"以上算是當時滿流行的幾個平台，雖然現在大部分的人都改用像是 Medium、WordPress 或是自架的部落格，但這些平台在當時對於推廣網路文化和技術分享有很大的貢獻。",[12,170,171],{},[15,172,173,176,177,182],{},[18,174,175],{},"Note","\n如果有想要回顧以前的網站，你可以使用一個叫做 ",[23,178,181],{"href":179,"rel":180},"https:\u002F\u002Farchive.org\u002Fweb\u002F",[27],"Wayback Machine（網路時光機）"," 的網站，你只要輸入你想要回顧的網站網址，它就會幫你抓取過去的版本，讓你可以看到以前的樣子，但是並不是所有的網站都有被抓取到，這點要注意。",[38,184,186],{"id":185},"html-基本概念","HTML 基本概念",[15,188,189,190,193,194,197,198,201,202,205],{},"HTML 全名是 ",[18,191,192],{},"H","yper",[18,195,196],{},"T","ext ",[18,199,200],{},"M","arkup ",[18,203,204],{},"L","anguage，簡單來講就是描述一個網頁上的內容與結構的語言。",[15,207,208],{},"底下是一個基本的 HTML 範例：",[210,211,216],"pre",{"className":212,"code":213,"language":214,"meta":215,"style":215},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>Document\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html","",[66,217,218,238,258,268,287,312,327,337,347,353,362],{"__ignoreMap":215},[219,220,223,227,231,235],"span",{"class":221,"line":222},"line",1,[219,224,226],{"class":225},"sMAXC","\u003C!",[219,228,230],{"class":229},"sKpQp","DOCTYPE",[219,232,234],{"class":233},"sCcAr"," html",[219,236,237],{"class":225},">\n",[219,239,241,244,246,249,252,256],{"class":221,"line":240},2,[219,242,243],{"class":225},"\u003C",[219,245,214],{"class":229},[219,247,248],{"class":233}," lang",[219,250,251],{"class":225},"=",[219,253,255],{"class":254},"sTRMh","\"zh-Hant-TW\"",[219,257,237],{"class":225},[219,259,261,263,266],{"class":221,"line":260},3,[219,262,243],{"class":225},[219,264,265],{"class":229},"head",[219,267,237],{"class":225},[219,269,271,274,277,280,282,285],{"class":221,"line":270},4,[219,272,273],{"class":225},"  \u003C",[219,275,276],{"class":229},"meta",[219,278,279],{"class":233}," charset",[219,281,251],{"class":225},[219,283,284],{"class":254},"\"UTF-8\"",[219,286,237],{"class":225},[219,288,290,292,294,297,299,302,305,307,310],{"class":221,"line":289},5,[219,291,273],{"class":225},[219,293,276],{"class":229},[219,295,296],{"class":233}," name",[219,298,251],{"class":225},[219,300,301],{"class":254},"\"viewport\"",[219,303,304],{"class":233}," content",[219,306,251],{"class":225},[219,308,309],{"class":254},"\"width=device-width, initial-scale=1.0\"",[219,311,237],{"class":225},[219,313,315,317,320,323,325],{"class":221,"line":314},6,[219,316,273],{"class":225},[219,318,319],{"class":229},"title",[219,321,322],{"class":225},">Document\u003C\u002F",[219,324,319],{"class":229},[219,326,237],{"class":225},[219,328,330,333,335],{"class":221,"line":329},7,[219,331,332],{"class":225},"\u003C\u002F",[219,334,265],{"class":229},[219,336,237],{"class":225},[219,338,340,342,345],{"class":221,"line":339},8,[219,341,243],{"class":225},[219,343,344],{"class":229},"body",[219,346,237],{"class":225},[219,348,350],{"class":221,"line":349},9,[219,351,352],{"class":225},"  \n",[219,354,356,358,360],{"class":221,"line":355},10,[219,357,332],{"class":225},[219,359,344],{"class":229},[219,361,237],{"class":225},[219,363,365,367,369],{"class":221,"line":364},11,[219,366,332],{"class":225},[219,368,214],{"class":229},[219,370,237],{"class":225},[15,372,373,374,377,378,381,382,384],{},"檔案名稱會是以 ",[66,375,376],{},".html"," 為副檔名為主，但是你也會有機會看到 ",[66,379,380],{},".htm"," 的副檔名，這是屬於比較早期的 HTML 檔案格式，以現代開發來講，都是以 ",[66,383,376],{}," 為主。",[15,386,387,388,77,390,77,392,77,394,396],{},"而我們所知的 ",[66,389,68],{},[66,391,72],{},[66,393,76],{},[66,395,80],{}," 等等，這些都被稱為 HTML 標籤（HTML Tags），它們用來定義或描述網頁的結構與內容，在前面的範例中，我們可以看到一些基本的 HTML 結構，而這些標籤都有屬於它的作用：",[133,398,399,408,416,424,432,440,448],{},[136,400,401,407],{},[18,402,403,406],{},[66,404,405],{},"\u003C!DOCTYPE html>","："," 這一行告訴瀏覽器這是一個 HTML5 文件，這是 HTML 文件的標準宣告。",[136,409,410,415],{},[18,411,412,406],{},[66,413,414],{},"\u003Chtml lang=\"zh-Hant-TW\">"," 這一行定義了 HTML 文件的根元素，並指定語言為繁體中文。",[136,417,418,423],{},[18,419,420,406],{},[66,421,422],{},"\u003Chead>"," 這一部分包含了文檔的元數據，例如字符集、視窗設定和標題。",[136,425,426,431],{},[18,427,428,406],{},[66,429,430],{},"\u003Cmeta charset=\"UTF-8\">"," 這一行指定了文檔的字符編碼為 UTF-8，這是目前網頁開發中最常用的編碼。",[136,433,434,439],{},[18,435,436,406],{},[66,437,438],{},"\u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">"," 這一行設定了視窗的寬度和縮放比例，這對於響應式設計非常重要。",[136,441,442,447],{},[18,443,444,406],{},[66,445,446],{},"\u003Ctitle>"," 這一行定義了文檔的標題，這個標題會顯示在瀏覽器的標籤上。",[136,449,450,455],{},[18,451,452,406],{},[66,453,454],{},"\u003Cbody>"," 這一部分包含了文檔的主要內容，所有顯示在瀏覽器上的內容都應該放在這個標籤內。",[12,457,458],{},[15,459,460,462],{},[18,461,175],{},"\n響應式設計（Responsive Design）是一種設計方法，旨在使網頁能夠根據不同設備的螢幕大小和解析度自動調整佈局和內容，以提供最佳的使用者體驗。這通常通過使用 CSS 媒體查詢（Media Queries）來實現，讓網頁在桌面、平板和手機等不同設備上都能夠良好顯示。",[15,464,465],{},"你可能會問",[15,467,468,469,77,472,77,475,478],{},"「那 ",[66,470,471],{},"\u003C\u002Ftitle>",[66,473,474],{},"\u003C\u002Fhead>",[66,476,477],{},"\u003C\u002Fbody>"," 這些是什麼？」",[15,480,481,482,485,486,489,490,493,494,77,497,500],{},"在 HTML 標籤中，會有許多的 ",[18,483,484],{},"「開啟標籤」"," 與 ",[18,487,488],{},"「關閉標籤」"," ，開啟標籤是用來定義一個元素的開始，而關閉標籤則是用來定義這個元素的結束，當然你可能會看到有些標籤是沒有關閉標籤的，這些標籤被稱為 ",[18,491,492],{},"「自閉合標籤」"," ，例如 ",[66,495,496],{},"\u003Cimg>",[66,498,499],{},"\u003Cbr>"," 等等，這部分我們後面再來解釋。",[15,502,503,504,77,506,77,508,77,510,77,513,515],{},"如果你去翻閱 HTML 的相關資源，你會看到非常非常多的標籤，這些標籤有的用來定義文字、圖片、連結、表格等等，這些標籤都有各自的用途與屬性，但實際上你全部都要看懂嗎？老實講，不需要，因為你真正需要的只有常用的幾個標籤，像是 ",[66,505,68],{},[66,507,72],{},[66,509,80],{},[66,511,512],{},"\u003Ca>",[66,514,496],{}," 等等，這些標籤就足夠應付大部分的情境需求，而它底下的屬性也是相對簡單的。",[15,517,518],{},"只是我認為 HTML 的學習過程中，有兩點是比較需要注意的：",[520,521,522,538],"ol",{},[136,523,524,527,528,530,531,534,535,537],{},[18,525,526],{},"語意化："," HTML 標籤不僅僅是用來呈現內容，更重要的是要能夠表達內容的語意，例如使用 ",[66,529,76],{}," 到 ",[66,532,533],{},"\u003Ch6>"," 來定義標題的重要性，使用 ",[66,536,80],{}," 來定義段落，這些語意化不單純只是讓搜尋引擎更容易理解內容，對於開發者來說，也能夠更清楚地了解內容的結構與意圖。",[136,539,540,543,544,485,547,550],{},[18,541,542],{},"元素特性："," 每個標籤都有屬於它自己的元素特性，這邊所講的元素特性並不是指標籤可以接受的屬性，而是所謂的 ",[18,545,546],{},"區塊元素",[18,548,549],{},"行內元素"," ，區塊元素會佔據整個行的寬度，而行內元素則不會，這對於佈局與樣式的設計非常重要，尤其是響應式設計中，這個概念更是不可或缺。",[15,552,553],{},"那麼前面有提到 HTML 標籤有自閉合標籤，這是什麼意思呢？",[15,555,556],{},"自閉合標籤是指那些不需要結束標籤的 HTML 標籤，那麼為什麼會有這樣的標籤呢？這邊要額外補充一個概念，也就是 Void elements（空元素） 跟 Normal elements（普通元素）。",[15,558,559],{},"在 HTML 中除了有所謂的行內元素與區塊元素之外，還有一個分類就是空元素，這些空元素不需要結束標籤，因為它們本身是沒有內容的（甚至不允許有內容），所以這些標籤就不需要結束標籤，常見的空元素有：",[561,562,563,579],"table",{},[564,565,566],"thead",{},[567,568,569,573,576],"tr",{},[570,571,572],"th",{},"元素",[570,574,575],{},"用途",[570,577,578],{},"寫法範例",[580,581,582,600,617,632,653,670,686,702,719,736,752,776,797],"tbody",{},[567,583,584,592,595],{},[585,586,587],"td",{},[18,588,589],{},[66,590,591],{},"\u003Carea>",[585,593,594],{},"影像地圖中的可點擊區域",[585,596,597],{},[66,598,599],{},"\u003Carea shape=\"rect\" coords=\"34,44,270,350\" href=\"link.html\" alt=\"區域\">",[567,601,602,609,612],{},[585,603,604],{},[18,605,606],{},[66,607,608],{},"\u003Cbase>",[585,610,611],{},"設定頁面內所有相對 URL 的基準路徑",[585,613,614],{},[66,615,616],{},"\u003Cbase href=\"https:\u002F\u002Fexample.com\u002F\">",[567,618,619,625,628],{},[585,620,621],{},[18,622,623],{},[66,624,499],{},[585,626,627],{},"換行符（Line Break）",[585,629,630],{},[66,631,499],{},[567,633,634,641,648],{},[585,635,636],{},[18,637,638],{},[66,639,640],{},"\u003Ccol>",[585,642,643,644,647],{},"表格欄位設定（需配合 ",[66,645,646],{},"\u003Ccolgroup>","）",[585,649,650],{},[66,651,652],{},"\u003Ccol span=\"2\" style=\"background:yellow\">",[567,654,655,662,665],{},[585,656,657],{},[18,658,659],{},[66,660,661],{},"\u003Cembed>",[585,663,664],{},"嵌入外部資源（如影片、PDF）",[585,666,667],{},[66,668,669],{},"\u003Cembed src=\"file.pdf\" type=\"application\u002Fpdf\" width=\"600\" height=\"400\">",[567,671,672,679,682],{},[585,673,674],{},[18,675,676],{},[66,677,678],{},"\u003Chr>",[585,680,681],{},"水平線分隔",[585,683,684],{},[66,685,678],{},[567,687,688,694,697],{},[585,689,690],{},[18,691,692],{},[66,693,496],{},[585,695,696],{},"插入圖片",[585,698,699],{},[66,700,701],{},"\u003Cimg src=\"image.jpg\" alt=\"描述文字\">",[567,703,704,711,714],{},[585,705,706],{},[18,707,708],{},[66,709,710],{},"\u003Cinput>",[585,712,713],{},"表單輸入欄位",[585,715,716],{},[66,717,718],{},"\u003Cinput type=\"text\" name=\"username\" placeholder=\"輸入名稱\">",[567,720,721,728,731],{},[585,722,723],{},[18,724,725],{},[66,726,727],{},"\u003Clink>",[585,729,730],{},"引入外部資源（常用於 CSS）",[585,732,733],{},[66,734,735],{},"\u003Clink rel=\"stylesheet\" href=\"style.css\">",[567,737,738,745,748],{},[585,739,740],{},[18,741,742],{},[66,743,744],{},"\u003Cmeta>",[585,746,747],{},"設定頁面中繼資訊（SEO, 編碼）",[585,749,750],{},[66,751,430],{},[567,753,754,761,771],{},[585,755,756],{},[18,757,758],{},[66,759,760],{},"\u003Csource>",[585,762,763,766,767,770],{},[66,764,765],{},"\u003Caudio>"," 或 ",[66,768,769],{},"\u003Cvideo>"," 的媒體來源",[585,772,773],{},[66,774,775],{},"\u003Csource src=\"video.mp4\" type=\"video\u002Fmp4\">",[567,777,778,785,792],{},[585,779,780],{},[18,781,782],{},[66,783,784],{},"\u003Ctrack>",[585,786,787,766,789,791],{},[66,788,769],{},[66,790,765],{}," 的字幕檔",[585,793,794],{},[66,795,796],{},"\u003Ctrack src=\"subtitles.vtt\" kind=\"subtitles\" srclang=\"en\" label=\"English\">",[567,798,799,806,809],{},[585,800,801],{},[18,802,803],{},[66,804,805],{},"\u003Cwbr>",[585,807,808],{},"建議換行點（Word Break Opportunity）",[585,810,811],{},[66,812,813],{},"\u003Cwbr >",[15,815,816,817,820,821,823,824,826,827,829],{},"那麼你可能會看到有人這樣寫 ",[66,818,819],{},"\u003Cimg src=\"image.jpg\" alt=\"描述文字\" \u002F>","，這種狀況是因為 XHTML（XML 的一種）規範要求所有標籤都必須閉合，所以 ",[66,822,496],{}," 這個標籤就會寫成 ",[66,825,819],{},"，但在 HTML5 中，這個閉合斜線是可以省略的，所以你可以直接寫成 ",[66,828,701],{},"，甚至在 HTML5 中，這兩種寫法都是正確的。",[15,831,832],{},"「XHTML 是什麼？」",[15,834,835],{},"我知道你可能會提問這個問題，XHTML 其實是 HTML 的一種延伸擴充，只是通常來講我們開發還是比較常用 HTML 就是了，所以這部分就不多做解釋。",[38,837,839],{"id":838},"css-基本概念","CSS 基本概念",[15,841,842,843,846,847,850,851,853],{},"CSS 全名是 ",[18,844,845],{},"C","ascading ",[18,848,849],{},"S","tyle ",[18,852,849],{},"heets，中文翻譯是「層疊樣式表\u002F階層樣式表」，最主要是用來描述 HTML 元素的樣式與佈局。",[15,855,856],{},"底下是一個基本的 CSS 範例：",[210,858,862],{"className":859,"code":860,"language":861,"meta":215,"style":215},"language-css shiki shiki-themes github-dark-high-contrast","body {\n  background-color: #f0f0f0;\n  font-family: Arial, sans-serif;\n}\nh1 {\n  color: #333;\n  font-size: 2em;\n}\n","css",[66,863,864,871,885,903,908,915,927,943],{"__ignoreMap":215},[219,865,866,868],{"class":221,"line":222},[219,867,344],{"class":229},[219,869,870],{"class":225}," {\n",[219,872,873,876,879,882],{"class":221,"line":240},[219,874,875],{"class":233},"  background-color",[219,877,878],{"class":225},": ",[219,880,881],{"class":233},"#f0f0f0",[219,883,884],{"class":225},";\n",[219,886,887,890,892,895,898,901],{"class":221,"line":260},[219,888,889],{"class":233},"  font-family",[219,891,878],{"class":225},[219,893,894],{"class":233},"Arial",[219,896,897],{"class":225},", ",[219,899,900],{"class":233},"sans-serif",[219,902,884],{"class":225},[219,904,905],{"class":221,"line":270},[219,906,907],{"class":225},"}\n",[219,909,910,913],{"class":221,"line":289},[219,911,912],{"class":229},"h1",[219,914,870],{"class":225},[219,916,917,920,922,925],{"class":221,"line":314},[219,918,919],{"class":233},"  color",[219,921,878],{"class":225},[219,923,924],{"class":233},"#333",[219,926,884],{"class":225},[219,928,929,932,934,937,941],{"class":221,"line":329},[219,930,931],{"class":233},"  font-size",[219,933,878],{"class":225},[219,935,936],{"class":233},"2",[219,938,940],{"class":939},"sWyjQ","em",[219,942,884],{"class":225},[219,944,945],{"class":221,"line":339},[219,946,907],{"class":225},[15,948,949,950,952,953,956],{},"CSS 是無法單純運作的，它需要搭配 HTML 來使用，通常我們會在 HTML 的 ",[66,951,422],{}," 區塊中使用 ",[66,954,955],{},"\u003Cstyle>"," 標籤來寫 CSS，或者是使用外部的 CSS 檔案。",[15,958,959],{},"較早期來講，其實滿多人都不在意 CSS 的，畢竟瀏覽器的支援性並不一致，許多瀏覽器對於 CSS 的支援都不太好，但隨著人們對於畫面的要求度越來越高，瀏覽器對於 CSS 的支援度也越來越好，CSS 對於網頁開發來講也變成了一種顯學。",[15,961,962],{},"通常學習 CSS 的人，都會得到一個結論：",[15,964,965],{},"「易學難精。」",[15,967,968],{},"其實這件事情一點也沒有錯，CSS 的語法非常簡單且直覺，在前面的範例中，你應該可以很快的理解每一行程式碼的意思，直接翻譯成中文就是：",[133,970,971,977,983,989],{},[136,972,973,976],{},[66,974,975],{},"background-color","：背景顏色",[136,978,979,982],{},[66,980,981],{},"font-family","：字型",[136,984,985,988],{},[66,986,987],{},"color","：文字顏色",[136,990,991,994],{},[66,992,993],{},"font-size","：字型大小",[15,996,997,998,1000,1001,1003,1004,1000,1006,1008,1009,1011],{},"至於 ",[66,999,344],{}," 跟 ",[66,1002,912],{}," 呢？指的就是 HTML 中的 ",[66,1005,454],{},[66,1007,76],{}," 標籤，所以以 ",[66,1010,344],{}," 為例，這段 CSS 的意思就是：",[15,1013,1014,1015,1017,1018,1020,1021,1023,1024,1026],{},"「我要將 HTML 中的 ",[66,1016,454],{}," 標籤的背景顏色設為 ",[66,1019,881],{},"，字型設為 ",[66,1022,894],{}," 或者是 ",[66,1025,900],{},"。」",[15,1028,1029],{},"是不是非常淺顯易懂呢？沒錯，CSS 就是這個簡單，就是因為這麼簡單才會讓你粗心大意，讓你不願意去深入了解它。",[15,1031,1032],{},"那麼 CSS 真正易學難精的點是哪些呢？我認為主要有以下幾個點：",[133,1034,1035,1041,1047,1053,1059],{},[136,1036,1037,1040],{},[18,1038,1039],{},"選擇器："," CSS 的選擇器非常多樣化，從基本的元素選擇器到複雜的組合選擇器、偽類選擇器等，這些都需要時間去理解與掌握。",[136,1042,1043,1046],{},[18,1044,1045],{},"佈局模型："," CSS 有多種佈局模型，如盒模型、Flexbox、Grid 等等，每種模型都有其特點與使用場景，這些模型的理解與應用需要時間去練習。",[136,1048,1049,1052],{},[18,1050,1051],{},"響應式設計："," 隨著移動設備的普及，響應式設計變得越來越重要，這需要對媒體查詢、彈性佈局等有深入的理解。",[136,1054,1055,1058],{},[18,1056,1057],{},"瀏覽器兼容性："," 不同瀏覽器對於 CSS 的支援程度不同，這需要開發者去測試與調整，確保在各種瀏覽器上都能正常顯示。",[136,1060,1061,1064],{},[18,1062,1063],{},"性能優化："," CSS 的性能優化也是一個重要的課題，如何減少重繪與重排、如何使用合適的選擇器等，這些都需要深入的理解。",[15,1066,1067],{},"那麼我們該怎麼樣開始好好的學習 CSS 呢？我認為可以從幾個方面入手：",[133,1069,1070,1076,1081,1087],{},[136,1071,1072,1075],{},[18,1073,1074],{},"基礎語法："," 先掌握 CSS 的基本語法與選擇器，了解 CSS 常見的語法以及使用方式，實際開發上其實也就那幾個語法跟用法而已。",[136,1077,1078,1080],{},[18,1079,1045],{}," 在進入響應式設計之前，必須要先懂的 CSS 佈局模型，如盒模型、Flexbox、Grid 等等，這些都是非常重要的概念，否則你在還原設計稿時，會時常因為那 1px 的差異而感到困惑。",[136,1082,1083,1086],{},[18,1084,1085],{},"實際練習："," 有輸入也要有輸出，找一些範本或設計稿試著還原，有助於自己對於語法的熟悉度與掌握度，一開始速度慢沒關係，但是慢慢地再重複練習上要越來越快速，這樣才有其意義。",[136,1088,1089,1092],{},[18,1090,1091],{},"響應式版型："," 現代幾乎人手一隻手機，在早期來講響應式設計並沒有那麼重要，但現在響應式設計已經成為了網頁開發的必備技能，必須要學習並了解什麼尺寸下該如何調整樣式，這部分可以從媒體查詢開始學習。",[15,1094,1095],{},"兼容性跟性能呢？其實我認為先不用考慮到那麼深，等到你開始學習出一個心得與成就感再說，畢竟這些問題都是在你開始實際開發後才會遇到的。",[15,1097,1098,1099,1102],{},"這裡有一件事值得特別提一下，那就是 ",[18,1100,1101],{},"「兼容性」"," 。前面提過，每個瀏覽器對 CSS 的支援度不盡相同，因此畫面呈現也可能有所差異，那麼問題來了 —— 如果今天瀏覽器完全不支援某個 CSS 屬性，會發生什麼事呢？",[15,1104,1105,1106],{},"簡單來講就是...",[18,1107,1108],{},"直接忽略這個屬性，而不會出現錯誤。",[15,1110,1111],{},"一般來說，我們在寫程式碼時，如果用了不存在的語法，通常會出現錯誤提示，或者 IDE（開發環境編輯器）會提醒你這個屬性不存在，但 CSS 並沒有這種特性。",[15,1113,1114],{},"這點雖然有點令人困惑，卻也算是一種好處：\n你的網頁不會因為寫了一個不存在的 CSS 屬性就整個崩壞；相對的，你也無法立即得知這個屬性是否真的存在，只能自己去查各個瀏覽器的支援度。",[38,1116,1117],{"id":1117},"結語",[15,1119,1120],{},"回想起來，當時無名小站有滿多很好聽的歌，但隨著無名小站的消失，滿多都歌都找不到了 QQ",[38,1122,1123],{"id":1123},"同步更新",[15,1125,1126],{},"本文將同步更新至以下網站：",[133,1128,1129,1136,1143,1150,1157,1164],{},[136,1130,1131],{},[23,1132,1135],{"href":1133,"rel":1134},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[136,1137,1138],{},[23,1139,1142],{"hr