[{"data":1,"prerenderedAt":1080},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250921\u002F4248331961\u002F":3,"page:\u002Flearnexp\u002F20250921\u002F4248331961\u002F":4,"alt:\u002Flearnexp\u002F20250921\u002F4248331961\u002F":3,"prev-next:\u002Flearnexp\u002F20250921\u002F4248331961\u002F":1055,"related:\u002Flearnexp\u002F20250921\u002F4248331961\u002F":1064},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F21\u002Fday-21-my-first-c-language-experience\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1034,"date":1035,"description":1036,"extension":1037,"lang":1038,"meta":1039,"navigation":91,"path":1040,"readingMinutes":1041,"seo":1042,"standalone":1043,"stem":1044,"tags":1045,"tldr":1051,"updated":1052,"url":1053,"__hash__":1054},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 21】我的第一個 C 語言體驗之旅.md","【Day 21】我的第一個 C 語言體驗之旅","4248331961",{"type":9,"value":10,"toc":1026},"minimark",[11,30,37,41,44,52,55,62,65,68,198,201,222,225,231,234,237,240,246,249,252,255,258,265,296,299,303,306,326,329,332,335,345,414,438,441,448,455,475,478,482,485,516,526,529,548,551,554,598,604,607,636,639,642,645,655,658,689,696,699,738,753,802,805,830,836,858,861,864,867,874,891,940,943,963,966,969,972,975,978,1022],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"我的第一個 C 語言體驗之旅","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday21\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%887%E6%97%A5%20%E4%B8%8B%E5%8D%8810_46_23.png",[38,39,35],"h2",{"id":40},"我的第一個-c-語言體驗之旅",[15,42,43],{},"從小到大我接觸過不少跟電腦相關的知識，但一直沒有正式學過程式語言。\n不過因為當時太喜歡《仙境傳說 Online》，所以自己跑去研究怎麼架設私人伺服器，並在這過程中接觸到了一些簡單的腳本語言。",[12,45,46],{},[15,47,48,51],{},[18,49,50],{},"Note","\n腳本語言（Scripting Language），指的是一種設計來「快速編寫、執行」的程式語言，簡單來說就是一種「寫了就能馬上跑」的程式語言，不需要像 C 或 Java 那樣先編譯一大堆步驟。",[15,53,54],{},"這也算是我真正踏入程式世界的起點，沒想到這段經歷後來成為我學習程式的重要基礎。",[12,56,57],{},[15,58,59,61],{},[18,60,50],{},"\n私人伺服器，簡單來說就是玩家自行架設的遊戲伺服器，遊戲規則由架設者訂定，由於不是官方授權，通常會有版權爭議或法律風險。",[15,63,64],{},"當時接觸的腳本語言雖然不算正式的程式語言，但已經包含了一些程式的基本概念，例如 變數、條件判斷、迴圈 等等。",[15,66,67],{},"而我寫的語言叫做 eAthena script。\n下面提供一個簡單範例給你參考：",[69,70,75],"pre",{"className":71,"code":72,"language":73,"meta":74,"style":74},"language-plaintext shiki shiki-themes github-dark-high-contrast","prontera,150,150,4    script    Hello NPC    100,{\n\n    mes \"[Hello NPC]\";\n    mes \"請問你想選擇哪一種藥水？\";\n    next;\n\n    \u002F\u002F 顯示選單，選項依序為第一個、第二個...\n    switch(select(\"藍色藥水（恢復 SP 100）:紅色藥水（恢復 HP 100）\")) {\n        case 1:\n            mes \"[Hello NPC]\";\n            mes \"你選擇了藍色藥水！\";\n            getitem 504,1; \u002F\u002F 504 是藍色藥水的道具 ID\n            close;\n        case 2:\n            mes \"[Hello NPC]\";\n            mes \"你選擇了紅色藥水！\";\n            getitem 501,1; \u002F\u002F 501 是紅色藥水的道具 ID\n            close;\n    }\n}\n","plaintext","",[76,77,78,86,93,99,105,111,116,122,128,134,140,146,152,158,164,169,175,181,186,192],"code",{"__ignoreMap":74},[79,80,83],"span",{"class":81,"line":82},"line",1,[79,84,85],{},"prontera,150,150,4    script    Hello NPC    100,{\n",[79,87,89],{"class":81,"line":88},2,[79,90,92],{"emptyLinePlaceholder":91},true,"\n",[79,94,96],{"class":81,"line":95},3,[79,97,98],{},"    mes \"[Hello NPC]\";\n",[79,100,102],{"class":81,"line":101},4,[79,103,104],{},"    mes \"請問你想選擇哪一種藥水？\";\n",[79,106,108],{"class":81,"line":107},5,[79,109,110],{},"    next;\n",[79,112,114],{"class":81,"line":113},6,[79,115,92],{"emptyLinePlaceholder":91},[79,117,119],{"class":81,"line":118},7,[79,120,121],{},"    \u002F\u002F 顯示選單，選項依序為第一個、第二個...\n",[79,123,125],{"class":81,"line":124},8,[79,126,127],{},"    switch(select(\"藍色藥水（恢復 SP 100）:紅色藥水（恢復 HP 100）\")) {\n",[79,129,131],{"class":81,"line":130},9,[79,132,133],{},"        case 1:\n",[79,135,137],{"class":81,"line":136},10,[79,138,139],{},"            mes \"[Hello NPC]\";\n",[79,141,143],{"class":81,"line":142},11,[79,144,145],{},"            mes \"你選擇了藍色藥水！\";\n",[79,147,149],{"class":81,"line":148},12,[79,150,151],{},"            getitem 504,1; \u002F\u002F 504 是藍色藥水的道具 ID\n",[79,153,155],{"class":81,"line":154},13,[79,156,157],{},"            close;\n",[79,159,161],{"class":81,"line":160},14,[79,162,163],{},"        case 2:\n",[79,165,167],{"class":81,"line":166},15,[79,168,139],{},[79,170,172],{"class":81,"line":171},16,[79,173,174],{},"            mes \"你選擇了紅色藥水！\";\n",[79,176,178],{"class":81,"line":177},17,[79,179,180],{},"            getitem 501,1; \u002F\u002F 501 是紅色藥水的道具 ID\n",[79,182,184],{"class":81,"line":183},18,[79,185,157],{},[79,187,189],{"class":81,"line":188},19,[79,190,191],{},"    }\n",[79,193,195],{"class":81,"line":194},20,[79,196,197],{},"}\n",[15,199,200],{},"那這段程式碼要怎麼執行呢？其實很簡單：",[202,203,204,212,219],"ol",{},[205,206,207,208,211],"li",{},"把程式碼存成一個",[76,209,210],{},".txt"," 檔案。",[205,213,214,215,218],{},"放到伺服器的",[76,216,217],{},"npc","資料夾裡。",[205,220,221],{},"重新啟動伺服器，就能生效囉！",[15,223,224],{},"這邊也分享一下當時啟動伺服器的畫面給你參考：",[15,226,227],{},[33,228],{"alt":229,"src":230},"EAthena（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday21\u002F34717989-f1b34e7c-f56f-11e7-9e6c-2ab25c9ff3df.png",[15,232,233],{},"不過 eAthena script 並不是這篇的重點，所以你只要知道我因為它而第一次接觸到「程式語言」就好。",[15,235,236],{},"後來在學時期，老師宣布下一學期要教我們一門程式語言——C 語言。",[15,238,239],{},"現在回想起來，真的是標準的「從入門到放棄」，那時候我才深刻體會到，程式世界比打副本還要難。",[15,241,242],{},[33,243],{"alt":244,"src":245},"C 語言之從入門到放棄（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday21\u002F202509071417.jpeg",[15,247,248],{},"「今天我們要學習的程式語言是 C 語言！」老師一邊說著，一邊在白板上寫下大大的 C。",[15,250,251],{},"「C 語言可以說是所有程式語言的基礎，很多語言都是從 C 衍生出來的。」老師繼續補充。",[15,253,254],{},"「哦哦哦！這不就代表學會 C，以後幾乎都能通了嗎？」當下的我超級興奮，心想如果能打好正式的程式基礎，對我之後寫腳本應該會超有幫助。",[15,256,257],{},"但實際上呢……現實狠狠給了我一巴掌。",[15,259,260,261,264],{},"我的記憶只停留在 ",[76,262,263],{},"printf(\"Hello, World!\\n\");"," 這一行程式碼：",[69,266,270],{"className":267,"code":268,"language":269,"meta":74,"style":74},"language-c shiki shiki-themes github-dark-high-contrast","#include \u003Cstdio.h>\nint main() {\n    printf(\"Hello, World!\\n\");\n    return 0;\n}\n","c",[76,271,272,277,282,287,292],{"__ignoreMap":74},[79,273,274],{"class":81,"line":82},[79,275,276],{},"#include \u003Cstdio.h>\n",[79,278,279],{"class":81,"line":88},[79,280,281],{},"int main() {\n",[79,283,284],{"class":81,"line":95},[79,285,286],{},"    printf(\"Hello, World!\\n\");\n",[79,288,289],{"class":81,"line":101},[79,290,291],{},"    return 0;\n",[79,293,294],{"class":81,"line":107},[79,295,197],{},[15,297,298],{},"因為 C 語言對當時的我來說實在太難了，上到指標那一段我就徹底陣亡。掙扎了一下之後，最後還是決定回去玩遊戲比較實在。\n結果指標沒學會，倒是先在遊戲裡練成了滿級玩家。",[38,300,302],{"id":301},"萬語之祖c","萬語之祖：C",[15,304,305],{},"為什麼許多課程都會把 C 語言當作入門首選呢？其原因有幾個：",[202,307,308,314,320],{},[205,309,310,313],{},[18,311,312],{},"電腦基礎體系："," 大部分作業系統（Unix、Linux、Windows 等）、嵌入式系統，甚至許多編譯器，都是用 C 語言開發的。學 C 能幫助你更了解電腦怎麼運作。",[205,315,316,319],{},[18,317,318],{},"語言特性："," C 會逼你學會記憶體管理（指標、動態配置）和精確的資料型別，這能讓你更清楚底層的概念，例如：Stack、Heap、記憶體洩漏（Memory Leak）等。",[205,321,322,325],{},[18,323,324],{},"萬語之祖："," 很多語言像 JavaScript、Java、C#、Go 等等，都受 C 的影響，可以說是從 C 演化出來的。",[15,327,328],{},"這也是為什麼常常會有人說：",[15,330,331],{},"「你只要會 C 語言，其他語言都不在話下！」",[15,333,334],{},"因為你已經掌握了最底層的語法模式與邏輯思維，所以再去學其他語言時，就能上手得更快。",[15,336,337,338,341,342,344],{},"舉例來講，JavaScript 的 ",[76,339,340],{},"for"," 迴圈與 C 語言的 ",[76,343,340],{}," 迴圈幾乎是一模一樣的：",[69,346,350],{"className":347,"code":348,"language":349,"meta":74,"style":74},"language-javascript shiki shiki-themes github-dark-high-contrast","\u002F\u002F JavaScript 的 for 迴圈\nfor (let i = 0; i \u003C 10; i++) {\n    console.log(i);\n}\n","javascript",[76,351,352,358,398,410],{"__ignoreMap":74},[79,353,354],{"class":81,"line":82},[79,355,357],{"class":356},"sQrFR","\u002F\u002F JavaScript 的 for 迴圈\n",[79,359,360,363,367,370,373,376,380,383,386,389,392,395],{"class":81,"line":88},[79,361,340],{"class":362},"sWyjQ",[79,364,366],{"class":365},"sMAXC"," (",[79,368,369],{"class":362},"let",[79,371,372],{"class":365}," i ",[79,374,375],{"class":362},"=",[79,377,379],{"class":378},"sCcAr"," 0",[79,381,382],{"class":365},"; i ",[79,384,385],{"class":362},"\u003C",[79,387,388],{"class":378}," 10",[79,390,391],{"class":365},"; i",[79,393,394],{"class":362},"++",[79,396,397],{"class":365},") {\n",[79,399,400,403,407],{"class":81,"line":95},[79,401,402],{"class":365},"    console.",[79,404,406],{"class":405},"sj_SG","log",[79,408,409],{"class":365},"(i);\n",[79,411,412],{"class":81,"line":101},[79,413,197],{"class":365},[69,415,417],{"className":267,"code":416,"language":269,"meta":74,"style":74},"\u002F\u002F C 語言的 for 迴圈\nfor (int i = 0; i \u003C 10; i++) {\n    printf(\"%d\\n\", i);\n}\n",[76,418,419,424,429,434],{"__ignoreMap":74},[79,420,421],{"class":81,"line":82},[79,422,423],{},"\u002F\u002F C 語言的 for 迴圈\n",[79,425,426],{"class":81,"line":88},[79,427,428],{},"for (int i = 0; i \u003C 10; i++) {\n",[79,430,431],{"class":81,"line":95},[79,432,433],{},"    printf(\"%d\\n\", i);\n",[79,435,436],{"class":81,"line":101},[79,437,197],{},[15,439,440],{},"這樣的語法結構能讓你在學 JavaScript 時不會覺得陌生，因為你早就在 C 語言裡熟悉了迴圈的寫法，所以上手會快很多。",[15,442,443,444,447],{},"另外，我們前面提到過 C 語言會強迫你理解 記憶體管理。但在 JavaScript 中，你完全不用操心這部分，因為它有內建的 ",[18,445,446],{},"自動垃圾回收機制（Garbage Collection）"," ，能自動幫你釋放不再使用的記憶體，這樣一來，我們就能更專注在程式邏輯上。",[15,449,450,451,454],{},"不過這並不代表可以完全忽略記憶體問題，如果程式邏輯寫得不好，依然可能造成 ",[18,452,453],{},"記憶體洩漏"," 。因此，有了 C 語言的基礎，你會更清楚記憶體管理的重要性。",[12,456,457,461],{},[15,458,459],{},[18,460,50],{},[202,462,463,469],{},[205,464,465,468],{},[18,466,467],{},"記憶體洩漏（Memory Leak）："," 指程式在執行時，沒有釋放掉不再使用的記憶體，久而久之就會耗盡系統資源，造成效能下降甚至程式當機。",[205,470,471,474],{},[18,472,473],{},"自動垃圾回收機制（Garbage Collection）："," 指程式語言會自動管理記憶體的分配與釋放，幫助降低記憶體洩漏的風險。",[15,476,477],{},"接下來，我會簡單介紹一些 C 語言的基本語法，讓你對它有個初步的概念。\n不過要先強調，這並不代表看完這篇文章你就會 C 語言，畢竟它的知識點非常多，這裡只能算是淺嚐一下皮毛而已。",[38,479,481],{"id":480},"打聲招呼吧hello-world","打聲招呼吧！Hello, World",[15,483,484],{},"首先讓我們來看看所有程式語言的經典入門範例：",[69,486,488],{"className":267,"code":487,"language":269,"meta":74,"style":74},"#include \u003Cstdio.h>\n\nint main(void) {\n    printf(\"Hello, world!\\n\");\n    return 0;\n}\n",[76,489,490,494,498,503,508,512],{"__ignoreMap":74},[79,491,492],{"class":81,"line":82},[79,493,276],{},[79,495,496],{"class":81,"line":88},[79,497,92],{"emptyLinePlaceholder":91},[79,499,500],{"class":81,"line":95},[79,501,502],{},"int main(void) {\n",[79,504,505],{"class":81,"line":101},[79,506,507],{},"    printf(\"Hello, world!\\n\");\n",[79,509,510],{"class":81,"line":107},[79,511,291],{},[79,513,514],{"class":81,"line":113},[79,515,197],{},[12,517,518],{},[15,519,520,522,525],{},[18,521,50],{},[76,523,524],{},"Hello, World"," 是程式設計入門的經典範例，用來展示一門語言的基本語法和輸出方式。它的目的就是讓初學者快速體驗，如何在該語言中編寫並執行一個最簡單的程式。",[15,527,528],{},"不用擔心，我會逐行來說明與介紹：",[530,531,532,538],"ul",{},[205,533,534,537],{},[76,535,536],{},"#include","：告訴電腦「我要把某個工具加進來」。在 C 語言中，通常會用來引入函式庫，讓我們能使用裡面已經寫好的功能。",[205,539,540,543,544,547],{},[76,541,542],{},"\u003Cstdio.h>","：這是 C 語言的標準輸入輸出庫（Standard Input Output Library），簡單來說，它就像一個工具包，裡面放了很多常用的工具，例如 ",[76,545,546],{},"printf"," 函式就是從這裡來的。",[15,549,550],{},"所以這一行意思就是：「嘿！電腦！我要使用標準輸入輸出庫裡面的工具！」",[15,552,553],{},"接著往下看一點：",[530,555,556,569,579,590],{},[205,557,558,564,565,568],{},[18,559,560,563],{},[76,561,562],{},"int","："," C 語言中的一種資料型別，代表「整數」（Integer）。在這裡用來指定 ",[76,566,567],{},"main"," 函式的回傳值型別。至於資料型別的細節，我們會在後面章節再深入介紹。",[205,570,571,575,576,578],{},[18,572,573,563],{},[76,574,567],{}," C 語言的「主函式」（Main Function），每個 C 程式都必須有一個 ",[76,577,567],{}," 函式，這是程式執行的起點。",[205,580,581,586,587,589],{},[18,582,583,563],{},[76,584,585],{},"void"," 表示 ",[76,588,567],{}," 函式不接受任何參數",[205,591,592,597],{},[18,593,594,563],{},[76,595,596],{},"{}"," C 語言的區塊符號，用來包裹函式的內容",[15,599,600,601,603],{},"所以這一行意思就是：「嘿！電腦！這是我的主函式，當你執行程式時，請從這裡開始！接著這個函式叫做 ",[76,602,567],{},"，它不接受任何參數，並且會返回一個整數值！」",[15,605,606],{},"接著讓我們看一下程式碼的內容：",[530,608,609,621],{},[205,610,611,616,617,620],{},[18,612,613,563],{},[76,614,615],{},"printf(\"Hello, world!\\n\");"," 這行會在螢幕上顯示「Hello, world!」，",[76,618,619],{},"\\n"," 是換行符號，表示輸出後會換行。",[205,622,623,628,629,631,632,635],{},[18,624,625,563],{},[76,626,627],{},"return 0;"," 這行表示 ",[76,630,567],{}," 函式執行成功並回傳 0，代表程式正常結束。在 C 語言裡這是一種慣例，如果回傳非 0（例如",[76,633,634],{},"return 1;","），就代表程式異常結束。",[15,637,638],{},"所以這一行意思就是：「嘿！電腦！請在螢幕上輸出 'Hello, world!'，然後換行！接著告訴我程式執行成功並返回 0！」。",[15,640,641],{},"那麼以上就是最基本的 C 語言入門範例，是不是超簡單的呢？！（並沒有。）",[38,643,644],{"id":644},"資料型別",[15,646,647,648,650,651,654],{},"前面我們有提到一個特別的東西 —— ",[76,649,562],{},"，也稱之為 ",[18,652,653],{},"「資料型別（Data Type）」"," ，而這個概念在幾乎所有程式語言裡都存在。",[15,656,657],{},"那麼，為什麼需要資料型別呢？主要有幾個原因：",[202,659,660,673,683],{},[205,661,662,665,666,668,669,672],{},[18,663,664],{},"記憶體管理："," 不同型別佔的空間不同，能幫助更有效利用記憶體。例如：",[76,667,562],{}," 通常佔用 4 個位元組（bytes），而 ",[76,670,671],{},"char"," 只佔用 1 個位元組。",[205,674,675,678,679,682],{},[18,676,677],{},"類型安全："," 型別能幫忙檢查正確性，減少奇怪的錯誤或資料遺失。不過要注意，不同型別之間可能會發生 ",[18,680,681],{},"隱式轉型（implicit conversion）"," ，像是自動把浮點數變整數，可能導致資料遺失或奇怪的結果。\n因此，通常會在編譯時加上警告選項（例如 -Wall -Wextra），甚至用 -Werror 把警告當錯誤處理。",[205,684,685,688],{},[18,686,687],{},"程式可讀性："," 明確的型別讓程式碼更清楚，也方便維護。",[12,690,691],{},[15,692,693,695],{},[18,694,50],{},"\n隱式轉型（Implicit Conversion）：指的是在程式裡，當不同型別的值要做運算或指定給變數時，編譯器會自動幫你把其中一個型別轉換成另一個型別，讓程式能正常執行。這個過程是自動發生的，開發者不需要特別寫轉換指令。",[15,697,698],{},"那麼 C 語言中主要常見的資料型別區分為三大類：",[202,700,701,717,729],{},[205,702,703,706,707,709,710,709,713,716],{},[18,704,705],{},"整數（Integer）："," 用來表示整數值，例如：",[76,708,562],{},"、",[76,711,712],{},"short",[76,714,715],{},"long"," 等等。",[205,718,719,722,723,709,726,716],{},[18,720,721],{},"浮點數（Floating Point）："," 用來表示帶小數點的數值，例如：",[76,724,725],{},"float",[76,727,728],{},"double",[205,730,731,734,735,737],{},[18,732,733],{},"字元（Character）："," 用來表示單一字元，例如：",[76,736,671],{},"。",[15,739,740,741,744,745,748,749,752],{},"先不談 ",[18,742,743],{},"類型安全"," 和 ",[18,746,747],{},"程式可讀性"," ，因為這兩點比較直覺，真正難懂的是記憶體管理，那要怎麼證明它的重要性呢？其實很簡單，在 C 語言裡可以用 ",[76,750,751],{},"sizeof"," 關鍵字，來查看不同資料型別佔用的記憶體大小。",[69,754,756],{"className":267,"code":755,"language":269,"meta":74,"style":74},"#include \u003Cstdio.h>\n\nint main(void) {\n    printf(\"int 的大小：%zu\\n\", sizeof(int));\n    printf(\"char 的大小：%zu\\n\", sizeof(char));\n    printf(\"float 的大小：%zu\\n\", sizeof(float));\n    printf(\"double 的大小：%zu\\n\", sizeof(double));\n\n    return 0;\n}\n",[76,757,758,762,766,770,775,780,785,790,794,798],{"__ignoreMap":74},[79,759,760],{"class":81,"line":82},[79,761,276],{},[79,763,764],{"class":81,"line":88},[79,765,92],{"emptyLinePlaceholder":91},[79,767,768],{"class":81,"line":95},[79,769,502],{},[79,771,772],{"class":81,"line":101},[79,773,774],{},"    printf(\"int 的大小：%zu\\n\", sizeof(int));\n",[79,776,777],{"class":81,"line":107},[79,778,779],{},"    printf(\"char 的大小：%zu\\n\", sizeof(char));\n",[79,781,782],{"class":81,"line":113},[79,783,784],{},"    printf(\"float 的大小：%zu\\n\", sizeof(float));\n",[79,786,787],{"class":81,"line":118},[79,788,789],{},"    printf(\"double 的大小：%zu\\n\", sizeof(double));\n",[79,791,792],{"class":81,"line":124},[79,793,92],{"emptyLinePlaceholder":91},[79,795,796],{"class":81,"line":130},[79,797,291],{},[79,799,800],{"class":81,"line":136},[79,801,197],{},[15,803,804],{},"實際輸出之後，你可以看到以下的結果：",[69,806,808],{"className":71,"code":807,"language":73,"meta":74,"style":74},"int 的大小：4\nchar 的大小：1\nfloat 的大小：4\ndouble 的大小：8\n",[76,809,810,815,820,825],{"__ignoreMap":74},[79,811,812],{"class":81,"line":82},[79,813,814],{},"int 的大小：4\n",[79,816,817],{"class":81,"line":88},[79,818,819],{},"char 的大小：1\n",[79,821,822],{"class":81,"line":95},[79,823,824],{},"float 的大小：4\n",[79,826,827],{"class":81,"line":101},[79,828,829],{},"double 的大小：8\n",[15,831,832],{},[33,833],{"alt":834,"src":835},"C 語言資料型別大小","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday21\u002F20250907143459.png",[12,837,838],{},[15,839,840,842,843,846,847,850,851,709,854,857],{},[18,841,50],{},"\n注意：在 C 標準裡，1 byte 定義為 ",[76,844,845],{},"sizeof(char)","，不一定等於 8 bits（標準只保證 CHAR_BIT >= 8）。實務上大多是 8 bits，但不同系統與編譯器下，型別大小可能不同，例如：（Windows 64-bit 下是 4 bytes，但 Linux 64-bit 下通常是 8 bytes），因此建議跨平台程式使用 ",[76,848,849],{},"\u003Cstdint.h>"," 提供的固定大小型別，如 ",[76,852,853],{},"int32_t",[76,855,856],{},"uint64_t"," 。",[15,859,860],{},"不過這裡要特別提醒，在不同平台（像編譯器或硬體架構）上，某些型別的大小可能會不一樣，例如 Windows x64 和 Linux x64 就有所差異。",[15,862,863],{},"「ㄟ...Boolean 呢？」你可能會問。",[15,865,866],{},"如果你本身已經有其他程式語言的開發經驗，可能會疑惑：為什麼到現在還沒提到 Boolean 這個資料型別？",[15,868,869,870,873],{},"在早期的 C 語言裡，其實沒有內建 Boolean 型別，而是直接用整數來表示： ",[76,871,872],{},"0"," 代表 假（false），非零則代表 真（true）。",[15,875,876,877,880,881,709,884,744,887,890],{},"一直到 C99 才引入 ",[76,878,879],{},"\u003Cstdbool.h>"," ，裡面定義了 ",[76,882,883],{},"bool",[76,885,886],{},"true",[76,888,889],{},"false","，所以如果你想在 C 裡使用 Boolean，可以這樣寫：",[69,892,894],{"className":267,"code":893,"language":269,"meta":74,"style":74},"#include \u003Cstdio.h>\n#include \u003Cstdbool.h>\n\nint main(void) {\n    printf(\"bool 的大小：%zu\\n\", sizeof(bool));\n\n    printf(\"true 的值：%d\\n\", true);\n    printf(\"false 的值：%d\\n\", false);\n    return 0;\n}\n",[76,895,896,900,905,909,913,918,922,927,932,936],{"__ignoreMap":74},[79,897,898],{"class":81,"line":82},[79,899,276],{},[79,901,902],{"class":81,"line":88},[79,903,904],{},"#include \u003Cstdbool.h>\n",[79,906,907],{"class":81,"line":95},[79,908,92],{"emptyLinePlaceholder":91},[79,910,911],{"class":81,"line":101},[79,912,502],{},[79,914,915],{"class":81,"line":107},[79,916,917],{},"    printf(\"bool 的大小：%zu\\n\", sizeof(bool));\n",[79,919,920],{"class":81,"line":113},[79,921,92],{"emptyLinePlaceholder":91},[79,923,924],{"class":81,"line":118},[79,925,926],{},"    printf(\"true 的值：%d\\n\", true);\n",[79,928,929],{"class":81,"line":124},[79,930,931],{},"    printf(\"false 的值：%d\\n\", false);\n",[79,933,934],{"class":81,"line":130},[79,935,291],{},[79,937,938],{"class":81,"line":136},[79,939,197],{},[15,941,942],{},"這樣你就會得到以下結果：",[69,944,946],{"className":71,"code":945,"language":73,"meta":74,"style":74},"bool 的大小：1\ntrue 的值：1\nfalse 的值：0\n",[76,947,948,953,958],{"__ignoreMap":74},[79,949,950],{"class":81,"line":82},[79,951,952],{},"bool 的大小：1\n",[79,954,955],{"class":81,"line":88},[79,956,957],{},"true 的值：1\n",[79,959,960],{"class":81,"line":95},[79,961,962],{},"false 的值：0\n",[15,964,965],{},"那麼我們這一節就先介紹到這邊，讓自己也稍微緩衝一下，下一個章節就讓我們來聊聊讓我放棄 C 語言的元兇 —— 指標（Pointer）吧！",[38,967,968],{"id":968},"結語",[15,970,971],{},"回想起來，當時其實滿喜歡寫腳本的，可以把自己想像中的規則套用到遊戲裡，整個感覺就很爽。",[38,973,974],{"id":974},"同步更新",[15,976,977],{},"本文將同步更新至以下網站：",[530,979,980,987,994,1001,1008,1015],{},[205,981,982],{},[23,983,986],{"href":984,"rel":985},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[205,988,989],{},[23,990,993],{"href":991,"rel":992},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[205,995,996],{},[23,997,1000],{"href":998,"rel":999},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[205,1002,1003],{},[23,1004,1007],{"href":1005,"rel":1006},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[205,1009,1010],{},[23,1011,1014],{"href":1012,"rel":1013},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[205,1016,1017],{},[23,1018,1021],{"href":1019,"rel":1020},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",[1023,1024,1025],"style",{},"h