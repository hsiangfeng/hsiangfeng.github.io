[{"data":1,"prerenderedAt":767},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":3,"page:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":4,"alt:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":3,"prev-next:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":743,"related:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":752},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F11\u002Fday-11-virus-and-first-time-reinstalling-windows\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":721,"date":722,"description":723,"extension":724,"lang":725,"meta":726,"navigation":727,"path":728,"readingMinutes":729,"seo":730,"standalone":731,"stem":732,"tags":733,"tldr":739,"updated":740,"url":741,"__hash__":742},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 11】電腦中毒了！第一次學會重灌系統.md","【Day 11】電腦中毒了！第一次學會重灌系統","3674862620",{"type":9,"value":10,"toc":706},"minimark",[11,28,35,40,48,51,58,61,64,67,70,73,76,79,82,85,91,94,104,112,118,121,124,127,130,133,136,139,142,145,149,215,218,250,253,291,294,330,333,340,343,350,353,359,370,373,418,421,424,450,453,644,647,650,653,656,659,662],[12,13,16],"callout",{"title":14,"type":15},"Warning","warning",[17,18,19,20,27],"p",{},"嗨！這系列文章已經重新整理、改寫成書，目前在 ",[21,22,26],"a",{"href":23,"rel":24},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[25],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[17,29,30],{},[31,32],"img",{"alt":33,"src":34},"電腦中毒了！第一次學會重灌系統","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday11\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8830%E6%97%A5%20%E4%B8%8B%E5%8D%8803_19_30.png",[36,37,39],"h2",{"id":38},"oh不電腦中毒了","oh！不，電腦中毒了",[17,41,42,43,47],{},"我國中到高中那段時間，USB 幾乎是傳檔神器，但因為要一直在不同電腦之間插來插去，它同時也成了最強的 ",[44,45,46],"strong",{},"『煉蠱罐』"," 。特別是在網咖，電腦裡的病毒種類多到像是開盲盒，你永遠不知道下一次 USB 插進去會中什麼獎。雖然網咖老闆也會想辦法防堵，有的用膠帶封住 USB 插槽，有的乾脆拔掉前方插孔，但這些小伎倆對後面的 USB 插槽完全沒輒，該中毒還是照樣中毒。",[17,49,50],{},"畢竟很多裝置都是透過 USB 連接的，例如鍵盤、滑鼠，所以有些網咖乾脆把整台主機鎖進櫃子裡，然後把鍵盤、滑鼠的線拉到櫃子外。這樣一來，玩家就沒辦法隨便插 USB 了。",[17,52,53,54,57],{},"不過我常去的那間網咖可沒把主機關起來，整台就大剌剌地曝露在外面。於是我們每次都自己帶 USB 去插，然後再把這顆插過網咖的 USB 帶回家，甚至拿去插學校電腦。結果 USB 根本就變成了 ",[44,55,56],{},"『病毒快遞服務』"," ，專門幫病毒從網咖送到家裡，再順路送到學校。",[17,59,60],{},"「學校電腦不會擋嗎？」你可能會這樣問。",[17,62,63],{},"老實講呢...不會。",[17,65,66],{},"其實並不是學校電腦管制不嚴，而是因為課堂作業幾乎都要靠 USB 來繳交，所以電腦一定得開放 USB 插槽，方便學生把作業存進去再交到學校電腦。結果也因此，學校電腦常常跟網咖電腦得同樣的病症。而說到這件事，就讓我想起以前的一個小故事。",[17,68,69],{},"「ㄟㄟ！XXX 你有沒有帶魔獸啊？」電腦課上，我問了一下坐在對面的同學。",[17,71,72],{},"「有啊，在這裡，你要打哦？」同學一邊拿給我，一邊回答我。",[17,74,75],{},"「對啊，來打啦！」接過同學的 USB 後，我馬上就插到電腦上，然後 Copy 到學校電腦上開打魔獸爭霸。",[17,77,78],{},"對了，早期我們電腦教室的座位都是固定的，所以誰的電腦出事都可以知道是誰的問題。",[17,80,81],{},"我記得當天打完遊戲之後，要打開瀏覽器時，就發現不太對勁....",[17,83,84],{},"因為我的網頁變成了：",[17,86,87],{},[31,88],{"alt":89,"src":90},"hao123","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday11\u002F20250829202441.png",[17,92,93],{},"通常學校瀏覽器會有兩種首頁",[95,96,97,101],"ul",{},[98,99,100],"li",{},"學校官方網站",[98,102,103],{},"Yahoo！ 首頁",[17,105,106,107,111],{},"但我打開卻變成了「",[108,109,110],"code",{},"hao123.com","」，當時我並沒有想太多，我就把它關掉，然後重新設定首頁後繼續上課。",[17,113,114,115,117],{},"只是後來發現越來越不對勁，因為我的電腦開始變得很慢，然後瀏覽器打開又是「",[108,116,110],{},"」，這時候我才意識一件事情。",[17,119,120],{},"「Ｘ！我的電腦中毒了啦！」我跟對面同學說。",[17,122,123],{},"「你也中毒了？！」同學一臉驚訝的看著我。",[17,125,126],{},"不出意外，果然還是出了意外。我們完全沒注意到老師已經走到身邊，結果他一看到我們兩個電腦的瀏覽器首頁都是 hao123，立刻要我們換電腦，還馬上通報資訊中心來處理。",[17,128,129],{},"那為什麼會特地提到這件事呢？因為在某一天，我爸又帶了一台新電腦回家，而我偏偏又把那支中毒的 USB 插了上去。結果可想而知，這台電腦也跟著中毒了。",[17,131,132],{},"也因為電腦中毒導致越來越慢以及被綁架首頁，所以我就被迫學會了怎麼重灌電腦。",[36,134,135],{"id":135},"電腦病毒",[17,137,138],{},"簡單來講，電腦病毒就是一個惡意的程式碼\u002F軟體，它的概念跟感冒病毒一樣，都需要一個宿主來寄生，然後再透過這個宿主來傳播到其他的電腦上。",[17,140,141],{},"而電腦病毒最主要目的是破壞系統、竊取資料、或是讓電腦變得無法使用，這些都是電腦病毒的常見行為。",[17,143,144],{},"「有一段時間最嚴重的電腦病毒，大概就是勒索病毒了。它會把你的檔案整個加密，然後要求支付贖金才能解鎖。這種病毒特別可怕，因為一旦中招，你的檔案就會被鎖死，完全無法使用。」",[146,147,148],"h3",{"id":148},"感染途徑",[95,150,151,165,171,181,187,193,199,205],{},[98,152,153,156,157,160,161,164],{},[44,154,155],{},"檔案下載："," 在執行檔（",[108,158,159],{},".exe","）or 安裝檔（",[108,162,163],{},".msi","）裡，有些網站甚至會誘導你下載看似安全的檔案，其實暗藏病毒。",[98,166,167,170],{},[44,168,169],{},"Email："," 病毒常透過附件傳播，偽裝成 Word、Excel 或 PDF 文件，一旦打開就可能中毒。",[98,172,173,176,177,180],{},[44,174,175],{},"USB 隨身碟："," 在學校或網咖最常見，通常會透過「",[108,178,179],{},"autorun.inf","」自動執行，讓 USB 成為病毒的最佳媒介。",[98,182,183,186],{},[44,184,185],{},"網頁瀏覽："," 早期的 Flash 與 JavaScript 漏洞很容易被利用，病毒就能藉此進入電腦，這也是現在瀏覽器全面淘汰 Flash 的原因。",[98,188,189,192],{},[44,190,191],{},"軟體漏洞："," 系統或軟體版本過舊時，駭客會利用漏洞入侵，因此定期更新非常重要。",[98,194,195,198],{},[44,196,197],{},"社交工程："," 攻擊者假冒朋友或同事傳送檔案，引誘你打開，藉此散播病毒。",[98,200,201,204],{},[44,202,203],{},"網路分享："," P2P 軟體（如 BT、eMule）下載檔案時，常常會順便把病毒帶進電腦。",[98,206,207,210,211,214],{},[44,208,209],{},"公共 Wi-Fi："," 這個就比較特別一點了，駭客會設置假熱點進行「",[44,212,213],{},"中間人攻擊","」，竊取資料或植入病毒。",[146,216,217],{"id":217},"造成的影響",[95,219,220,226,232,238,244],{},[98,221,222,225],{},[44,223,224],{},"效能影響："," 會佔用 CPU、RAM、硬碟資源，讓電腦變慢甚至藍白畫面（BSoD）。",[98,227,228,231],{},[44,229,230],{},"資料損失："," 會刪除檔案，或像勒索病毒一樣把檔案鎖住。",[98,233,234,237],{},[44,235,236],{},"隱私洩漏："," 會竊取帳號、密碼、信用卡號等敏感資訊，用於詐騙或盜刷。",[98,239,240,243],{},[44,241,242],{},"網路安全："," 把電腦變成「肉雞」（殭屍電腦）又稱魁儡，被駭客用來發動 DDoS 或寄垃圾信。(這些行為會讓你的電腦變成駭客的工具，然後去攻擊其他的電腦或伺服器)",[98,245,246,249],{},[44,247,248],{},"硬體損壞："," 過度消耗資源造成過熱，嚴重時可能損壞主機板、顯示卡。(情況少見)",[146,251,252],{"id":252},"病毒類型",[95,254,255,261,267,273,279,285],{},[98,256,257,260],{},[44,258,259],{},"特洛伊木馬","：偽裝成正常軟體，引誘使用者執行。",[98,262,263,266],{},[44,264,265],{},"蠕蟲病毒","：可自我複製，快速在網路中傳播。",[98,268,269,272],{},[44,270,271],{},"勒索病毒","：加密檔案並索取贖金。",[98,274,275,278],{},[44,276,277],{},"廣告軟體","：強制彈出廣告。",[98,280,281,284],{},[44,282,283],{},"間諜軟體","：竊取使用者隱私資料。",[98,286,287,290],{},[44,288,289],{},"Rootkit","：隱藏自身，取得系統最高權限。",[146,292,293],{"id":293},"預防方式",[95,295,296,302,308,318,324],{},[98,297,298,301],{},[44,299,300],{},"定期更新系統與軟體："," 這是最基本的防範措施，許多病毒會利用系統漏洞入侵，定期更新能有效降低風險。",[98,303,304,307],{},[44,305,306],{},"安裝防毒軟體："," 防毒軟體能即時偵測並清除病毒，提供基本防護。",[98,309,310,313,314,317],{},[44,311,312],{},"不隨便下載檔案\u002F未授權網站："," 利用的是使用者",[44,315,316],{},"貪小便宜","的心理，下載破解檔、免費軟體常藏病毒，下載來源一定要謹慎。",[98,319,320,323],{},[44,321,322],{},"啟用防火牆："," 防火牆可監控網路流量，阻擋不明連線。",[98,325,326,329],{},[44,327,328],{},"不隨便插 USB："," 不要亂插來路不明的隨身碟，以免帶毒。",[17,331,332],{},"但不管怎麼防，肯定還是會有一些意外發生，所以請務必做好定時的備份工作，這樣才能避免資料損失的風險。",[12,334,337],{"title":335,"type":336},"Note","note",[17,338,339],{},"備份方式有分成本地備份、異地備份、雲端備份等，使用者可以根據自己的需求來選擇適合的備份方式。",[36,341,342],{"id":342},"重灌系統",[17,344,345,346,349],{},"重灌系統，說穿了就是「",[44,347,348],{},"把電腦砍掉重練","」。",[17,351,352],{},"但這邊所謂的砍掉重練並不是叫你拿刀子去砍電腦...",[17,354,355],{},[31,356],{"alt":357,"src":358},"拿刀砍電腦","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday11\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8829%E6%97%A5%20%E4%B8%8B%E5%8D%8808_45_27.png",[17,360,361,362,365,366,369],{},"而是將電腦中的所有資料與作業系統全部刪除，然後重新安裝作業系統與軟體，簡單來講就是恢復「",[44,363,364],{},"出廠設定","」的意思，如果稍微有點難懂，你也可以理解成「",[44,367,368],{},"格式化硬碟","」的概念。",[17,371,372],{},"那麼我們該怎麼重灌系統呢？在開始重灌之前需要先做以下事情：",[374,375,376,382,388,400,406,412],"ol",{},[98,377,378,381],{},[44,379,380],{},"備份重要資料："," 這是最重要的一步，因為重灌會清除電腦裡所有資料，先把重要文件、照片等存起來。",[98,383,384,387],{},[44,385,386],{},"準備安裝媒介："," 準備一個可以用來安裝作業系統的媒介，例如 USB 隨身碟或 DVD 光碟，並把作業系統的映像檔（ISO）放進去。",[98,389,390,393,394,399],{},[44,391,392],{},"取得作業系統："," 以 Windows 為例，可以到 ",[21,395,398],{"href":396,"rel":397},"https:\u002F\u002Fwww.microsoft.com\u002Fzh-tw\u002Fsoftware-download",[25],"官方網站"," 下載 ISO，然後製作成 USB 開機碟或燒錄到 DVD 光碟。",[98,401,402,405],{},[44,403,404],{},"設定 BIOS："," 不論是選擇 USB 隨身碟或 DVD 光碟作為安裝媒介，進入 BIOS，將 USB 或 DVD 設為第一開機裝置，常見的進入方式是在開機時按 F2、Del 或 Esc。",[98,407,408,411],{},[44,409,410],{},"開始安裝："," 當你完成以上步驟後，就可以開始安裝作業系統了，這邊以 Windows 為例，從安裝媒介啟動後，會進入安裝畫面，按照指示一步步完成作業系統安裝即可。",[98,413,414,417],{},[44,415,416],{},"安裝驅動程式："," 早期的作業系統會需要額外自行手動安裝驅動程式，但現代作業系統大多自帶常用驅動程式，可以正常開機使用；若有少數硬體沒驅動，則再手動下載安裝即可。",[17,419,420],{},"以上就是重灌作業系統的流程，但其實這個流程會因為作業系統的不同而有所差異，例如：Linux、macOS 等等，這邊就不一一贅述了。",[17,422,423],{},"而重灌系統的好處有很多，例如：",[95,425,426,432,438,444],{},[98,427,428,431],{},[44,429,430],{},"清除病毒："," 重灌能有效清除大多數病毒，讓系統恢復正常。但若是勒索病毒，檔案已被加密，就算重灌也救不回來。",[98,433,434,437],{},[44,435,436],{},"提升效能："," Windows 用久了會因安裝\u002F移除軟體殘留檔案而變慢，重灌能讓系統回到初始狀態，效能自然提升。",[98,439,440,443],{},[44,441,442],{},"修復系統問題："," 藍屏、無法開機等多因系統檔案損壞，重灌大多都能直接解決。",[98,445,446,449],{},[44,447,448],{},"更新系統："," 重灌通常會順便升級到最新版本，享有新功能與安全性更新。",[17,451,452],{},"最後這邊也整理一下，我個人推薦可以安裝的一些軟體。",[454,455,456,472],"table",{},[457,458,459],"thead",{},[460,461,462,466,469],"tr",{},[463,464,465],"th",{},"類型",[463,467,468],{},"軟體名稱",[463,470,471],{},"用途 \u002F 補充說明",[473,474,475,487,502,533,555,570,585,600,622],"tbody",{},[460,476,477,481,484],{},[478,479,480],"td",{},"🔐 防毒軟體",[478,482,483],{},"Windows Defender（內建）",[478,485,486],{},"Windows 10 之後已內建防護，XP\u002FWin7 建議另裝防毒軟體",[460,488,489,492,499],{},[478,490,491],{},"🧩 壓縮工具",[478,493,494],{},[21,495,498],{"href":496,"rel":497},"https:\u002F\u002Fwww.7-zip.org\u002F",[25],"7-Zip",[478,500,501],{},"解壓縮常見格式，如 ZIP、RAR、7Z",[460,503,504,507,530],{},[478,505,506],{},"🌐 瀏覽器",[478,508,509,514,515,514,518,514,523,514,525],{},[21,510,513],{"href":511,"rel":512},"https:\u002F\u002Fwww.google.com\u002Fchrome\u002F",[25],"Google Chrome"," ",[516,517],"br",{},[21,519,522],{"href":520,"rel":521},"https:\u002F\u002Fwww.mozilla.org\u002Fzh-TW\u002Ffirefox\u002Fnew\u002F",[25],"Firefox",[516,524],{},[21,526,529],{"href":527,"rel":528},"https:\u002F\u002Fbrave.com\u002F",[25],"Brave",[478,531,532],{},"就是瀏覽器",[460,534,535,538,552],{},[478,536,537],{},"📄 文書處理",[478,539,540,514,545,514,547],{},[21,541,544],{"href":542,"rel":543},"https:\u002F\u002Fdocs.google.com",[25],"Google Docs",[516,546],{},[21,548,551],{"href":549,"rel":550},"https:\u002F\u002Fzh-tw.libreoffice.org\u002F",[25],"LibreOffice",[478,553,554],{},"免費文書與試算表工具，取代 Microsoft Office",[460,556,557,560,567],{},[478,558,559],{},"🎞️ 播放器",[478,561,562],{},[21,563,566],{"href":564,"rel":565},"https:\u002F\u002Fpotplayer.daum.net\u002F",[25],"PotPlayer",[478,568,569],{},"支援多數影音格式與外掛字幕",[460,571,572,575,582],{},[478,573,574],{},"📸 截圖工具",[478,576,577],{},[21,578,581],{"href":579,"rel":580},"https:\u002F\u002Fgetsharex.com\u002F",[25],"ShareX",[478,583,584],{},"強化版截圖工具，支援全畫面、區塊截圖與錄影",[460,586,587,590,597],{},[478,588,589],{},"🔎 PDF 工具",[478,591,592],{},[21,593,596],{"href":594,"rel":595},"https:\u002F\u002Fwww.sumatrapdfreader.org\u002Ffree-pdf-reader",[25],"SumatraPDF",[478,598,599],{},"輕巧取代 Adobe Reader，僅供閱讀用途",[460,601,602,605,619],{},[478,603,604],{},"☁️ 雲端同步",[478,606,607,514,612,514,614],{},[21,608,611],{"href":609,"rel":610},"https:\u002F\u002Fwww.google.com\u002Fdrive\u002F",[25],"Google Drive",[516,613],{},[21,615,618],{"href":616,"rel":617},"https:\u002F\u002Fwww.dropbox.com\u002Fzh_TW\u002F",[25],"Dropbox",[478,620,621],{},"備份資料、跨裝置同步檔案",[460,623,624,627,641],{},[478,625,626],{},"🔧 系統工具",[478,628,629,514,634,514,636],{},[21,630,633],{"href":631,"rel":632},"https:\u002F\u002Fgeekuninstaller.com\u002F",[25],"Geek Uninstaller",[516,635],{},[21,637,640],{"href":638,"rel":639},"https:\u002F\u002Fwww.ccleaner.com\u002F",[25],"CCleaner",[478,642,643],{},"軟體移除 \u002F 清除暫存（⚠️ 註冊表清理請小心使用）",[36,645,646],{"id":646},"結語",[17,648,649],{},"不知道大家有沒有重灌電腦的經驗？",[17,651,652],{},"我大概平均兩年就會重灌一次電腦，主要原因是 Windows 用久了很容易累積各種垃圾檔，而這些檔案要清除起來特別麻煩，所以乾脆定期重灌，讓電腦保持在比較乾淨的狀態。",[17,654,655],{},"不知道有沒有人跟我一樣呢？",[36,657,658],{"id":658},"同步更新",[17,660,661],{},"本文將同步更新至以下網站：",[95,663,664,671,678,685,692,699],{},[98,665,666],{},[21,667,670],{"href":668,"rel":669},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[25],"是 Ray 不是 Array",[98,672,673],{},[21,674,677],{"href":675,"rel":676},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[25],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[98,679,680],{},[21,681,684],{"href":682,"rel":683},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[25],"Threads - 時常會聊軟實力",[98,686,687],{},[21,688,691],{"href":689,"rel":690},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[25],"Facebook - 搞怪迷因分享",[98,693,694],{},[21,695,698],{"href":696,"rel":697},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[25],"Instagram - 搞怪迷因分享 + 軟實力",[98,700,701],{},[21,702,705],{"href":703,"rel":704},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[25],"Portaly - 入口主頁",{"title":707,"searchDepth":708,"depth":708,"links":709},"",2,[710,711,718,719,720],{"id":38,"depth":708,"text":39},{"id":135,"depth":708,"text":135,"children":712},[713,715,716,717],{"id":148,"depth":714,"text":148},3,{"id":217,"depth":714,"text":217},{"id":252,"depth":714,"text":252},{"id":293,"depth":714,"text":293},{"id":342,"depth":708,"text":342},{"id":646,"depth":708,"text":646},{"id":658,"depth":708,"text":658},"學習經驗","2025-09-11 00:00:01","電腦中毒、首頁被綁到 hao123？本文以真實案例串起：感染途徑重點、備份觀念、USB 安裝媒體與 BIOS\u002FUEFI 設定、重灌流程與常用軟體清單，作為系統復原與日常維護的參考。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-11","6",{"title":6,"description":723},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 11】電腦中毒了！第一次學會重灌系統",[734,735,736,737,738],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","電腦重灌教學","電腦中毒處理","hao123 移除","防毒軟體推薦",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250911\u002F3674862620\u002F","Y1hCAb_MuZ2vEnLU_470MNoGWWNBUD7mtqbF-ulac-I",{"newer":744,"older":748},{"url":745,"title":746,"date":747},"\u002Flearnexp\u002F20250912\u002F676253939\u002F","【Day 12】第一次升級電腦：從被禁止上網咖到學會 HDD、SSD 與 RAM","2025-09-12 00:00:01",{"url":749,"title":750,"date":751},"\u002Flearnexp\u002F20250910\u002F2446482814\u002F","【Day 10】快借我 USB！我要打魔獸爭霸！","2025-09-10 00:00:01",[753,758,763],{"url":754,"title":755,"date":756,"readingMinutes":757},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":759,"title":760,"date":761,"readingMinutes":762},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":764,"title":765,"date":766,"readingMinutes":729},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",1784087359886]