[{"data":1,"prerenderedAt":769},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":3,"page:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":4,"alt:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":3,"prev-next:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":745,"related:\u002Flearnexp\u002F20250911\u002F3674862620\u002F":754},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F11\u002Fday-11-virus-and-first-time-reinstalling-windows\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":723,"date":724,"description":725,"extension":726,"lang":727,"meta":728,"navigation":729,"path":730,"readingMinutes":731,"seo":732,"standalone":733,"stem":734,"tags":735,"tldr":741,"updated":742,"url":743,"__hash__":744},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 11】電腦中毒了！第一次學會重灌系統.md","【Day 11】電腦中毒了！第一次學會重灌系統","3674862620",{"type":9,"value":10,"toc":708},"minimark",[11,30,37,42,49,52,59,62,65,68,71,74,77,80,83,86,92,95,105,113,119,122,125,128,131,134,137,140,143,146,150,216,219,251,254,292,295,331,334,342,345,352,355,361,372,375,420,423,426,452,455,646,649,652,655,658,661,664],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"電腦中毒了！第一次學會重灌系統","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday11\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8830%E6%97%A5%20%E4%B8%8B%E5%8D%8803_19_30.png",[38,39,41],"h2",{"id":40},"oh不電腦中毒了","oh！不，電腦中毒了",[15,43,44,45,48],{},"我國中到高中那段時間，USB 幾乎是傳檔神器，但因為要一直在不同電腦之間插來插去，它同時也成了最強的 ",[18,46,47],{},"『煉蠱罐』"," 。特別是在網咖，電腦裡的病毒種類多到像是開盲盒，你永遠不知道下一次 USB 插進去會中什麼獎。雖然網咖老闆也會想辦法防堵，有的用膠帶封住 USB 插槽，有的乾脆拔掉前方插孔，但這些小伎倆對後面的 USB 插槽完全沒輒，該中毒還是照樣中毒。",[15,50,51],{},"畢竟很多裝置都是透過 USB 連接的，例如鍵盤、滑鼠，所以有些網咖乾脆把整台主機鎖進櫃子裡，然後把鍵盤、滑鼠的線拉到櫃子外。這樣一來，玩家就沒辦法隨便插 USB 了。",[15,53,54,55,58],{},"不過我常去的那間網咖可沒把主機關起來，整台就大剌剌地曝露在外面。於是我們每次都自己帶 USB 去插，然後再把這顆插過網咖的 USB 帶回家，甚至拿去插學校電腦。結果 USB 根本就變成了 ",[18,56,57],{},"『病毒快遞服務』"," ，專門幫病毒從網咖送到家裡，再順路送到學校。",[15,60,61],{},"「學校電腦不會擋嗎？」你可能會這樣問。",[15,63,64],{},"老實講呢...不會。",[15,66,67],{},"其實並不是學校電腦管制不嚴，而是因為課堂作業幾乎都要靠 USB 來繳交，所以電腦一定得開放 USB 插槽，方便學生把作業存進去再交到學校電腦。結果也因此，學校電腦常常跟網咖電腦得同樣的病症。而說到這件事，就讓我想起以前的一個小故事。",[15,69,70],{},"「ㄟㄟ！XXX 你有沒有帶魔獸啊？」電腦課上，我問了一下坐在對面的同學。",[15,72,73],{},"「有啊，在這裡，你要打哦？」同學一邊拿給我，一邊回答我。",[15,75,76],{},"「對啊，來打啦！」接過同學的 USB 後，我馬上就插到電腦上，然後 Copy 到學校電腦上開打魔獸爭霸。",[15,78,79],{},"對了，早期我們電腦教室的座位都是固定的，所以誰的電腦出事都可以知道是誰的問題。",[15,81,82],{},"我記得當天打完遊戲之後，要打開瀏覽器時，就發現不太對勁....",[15,84,85],{},"因為我的網頁變成了：",[15,87,88],{},[33,89],{"alt":90,"src":91},"hao123","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday11\u002F20250829202441.png",[15,93,94],{},"通常學校瀏覽器會有兩種首頁",[96,97,98,102],"ul",{},[99,100,101],"li",{},"學校官方網站",[99,103,104],{},"Yahoo！ 首頁",[15,106,107,108,112],{},"但我打開卻變成了「",[109,110,111],"code",{},"hao123.com","」，當時我並沒有想太多，我就把它關掉，然後重新設定首頁後繼續上課。",[15,114,115,116,118],{},"只是後來發現越來越不對勁，因為我的電腦開始變得很慢，然後瀏覽器打開又是「",[109,117,111],{},"」，這時候我才意識一件事情。",[15,120,121],{},"「Ｘ！我的電腦中毒了啦！」我跟對面同學說。",[15,123,124],{},"「你也中毒了？！」同學一臉驚訝的看著我。",[15,126,127],{},"不出意外，果然還是出了意外。我們完全沒注意到老師已經走到身邊，結果他一看到我們兩個電腦的瀏覽器首頁都是 hao123，立刻要我們換電腦，還馬上通報資訊中心來處理。",[15,129,130],{},"那為什麼會特地提到這件事呢？因為在某一天，我爸又帶了一台新電腦回家，而我偏偏又把那支中毒的 USB 插了上去。結果可想而知，這台電腦也跟著中毒了。",[15,132,133],{},"也因為電腦中毒導致越來越慢以及被綁架首頁，所以我就被迫學會了怎麼重灌電腦。",[38,135,136],{"id":136},"電腦病毒",[15,138,139],{},"簡單來講，電腦病毒就是一個惡意的程式碼\u002F軟體，它的概念跟感冒病毒一樣，都需要一個宿主來寄生，然後再透過這個宿主來傳播到其他的電腦上。",[15,141,142],{},"而電腦病毒最主要目的是破壞系統、竊取資料、或是讓電腦變得無法使用，這些都是電腦病毒的常見行為。",[15,144,145],{},"「有一段時間最嚴重的電腦病毒，大概就是勒索病毒了。它會把你的檔案整個加密，然後要求支付贖金才能解鎖。這種病毒特別可怕，因為一旦中招，你的檔案就會被鎖死，完全無法使用。」",[147,148,149],"h3",{"id":149},"感染途徑",[96,151,152,166,172,182,188,194,200,206],{},[99,153,154,157,158,161,162,165],{},[18,155,156],{},"檔案下載："," 在執行檔（",[109,159,160],{},".exe","）or 安裝檔（",[109,163,164],{},".msi","）裡，有些網站甚至會誘導你下載看似安全的檔案，其實暗藏病毒。",[99,167,168,171],{},[18,169,170],{},"Email："," 病毒常透過附件傳播，偽裝成 Word、Excel 或 PDF 文件，一旦打開就可能中毒。",[99,173,174,177,178,181],{},[18,175,176],{},"USB 隨身碟："," 在學校或網咖最常見，通常會透過「",[109,179,180],{},"autorun.inf","」自動執行，讓 USB 成為病毒的最佳媒介。",[99,183,184,187],{},[18,185,186],{},"網頁瀏覽："," 早期的 Flash 與 JavaScript 漏洞很容易被利用，病毒就能藉此進入電腦，這也是現在瀏覽器全面淘汰 Flash 的原因。",[99,189,190,193],{},[18,191,192],{},"軟體漏洞："," 系統或軟體版本過舊時，駭客會利用漏洞入侵，因此定期更新非常重要。",[99,195,196,199],{},[18,197,198],{},"社交工程："," 攻擊者假冒朋友或同事傳送檔案，引誘你打開，藉此散播病毒。",[99,201,202,205],{},[18,203,204],{},"網路分享："," P2P 軟體（如 BT、eMule）下載檔案時，常常會順便把病毒帶進電腦。",[99,207,208,211,212,215],{},[18,209,210],{},"公共 Wi-Fi："," 這個就比較特別一點了，駭客會設置假熱點進行「",[18,213,214],{},"中間人攻擊","」，竊取資料或植入病毒。",[147,217,218],{"id":218},"造成的影響",[96,220,221,227,233,239,245],{},[99,222,223,226],{},[18,224,225],{},"效能影響："," 會佔用 CPU、RAM、硬碟資源，讓電腦變慢甚至藍白畫面（BSoD）。",[99,228,229,232],{},[18,230,231],{},"資料損失："," 會刪除檔案，或像勒索病毒一樣把檔案鎖住。",[99,234,235,238],{},[18,236,237],{},"隱私洩漏："," 會竊取帳號、密碼、信用卡號等敏感資訊，用於詐騙或盜刷。",[99,240,241,244],{},[18,242,243],{},"網路安全："," 把電腦變成「肉雞」（殭屍電腦）又稱魁儡，被駭客用來發動 DDoS 或寄垃圾信。(這些行為會讓你的電腦變成駭客的工具，然後去攻擊其他的電腦或伺服器)",[99,246,247,250],{},[18,248,249],{},"硬體損壞："," 過度消耗資源造成過熱，嚴重時可能損壞主機板、顯示卡。(情況少見)",[147,252,253],{"id":253},"病毒類型",[96,255,256,262,268,274,280,286],{},[99,257,258,261],{},[18,259,260],{},"特洛伊木馬","：偽裝成正常軟體，引誘使用者執行。",[99,263,264,267],{},[18,265,266],{},"蠕蟲病毒","：可自我複製，快速在網路中傳播。",[99,269,270,273],{},[18,271,272],{},"勒索病毒","：加密檔案並索取贖金。",[99,275,276,279],{},[18,277,278],{},"廣告軟體","：強制彈出廣告。",[99,281,282,285],{},[18,283,284],{},"間諜軟體","：竊取使用者隱私資料。",[99,287,288,291],{},[18,289,290],{},"Rootkit","：隱藏自身，取得系統最高權限。",[147,293,294],{"id":294},"預防方式",[96,296,297,303,309,319,325],{},[99,298,299,302],{},[18,300,301],{},"定期更新系統與軟體："," 這是最基本的防範措施，許多病毒會利用系統漏洞入侵，定期更新能有效降低風險。",[99,304,305,308],{},[18,306,307],{},"安裝防毒軟體："," 防毒軟體能即時偵測並清除病毒，提供基本防護。",[99,310,311,314,315,318],{},[18,312,313],{},"不隨便下載檔案\u002F未授權網站："," 利用的是使用者",[18,316,317],{},"貪小便宜","的心理，下載破解檔、免費軟體常藏病毒，下載來源一定要謹慎。",[99,320,321,324],{},[18,322,323],{},"啟用防火牆："," 防火牆可監控網路流量，阻擋不明連線。",[99,326,327,330],{},[18,328,329],{},"不隨便插 USB："," 不要亂插來路不明的隨身碟，以免帶毒。",[15,332,333],{},"但不管怎麼防，肯定還是會有一些意外發生，所以請務必做好定時的備份工作，這樣才能避免資料損失的風險。",[12,335,336],{},[15,337,338,341],{},[18,339,340],{},"Note","\n備份方式有分成本地備份、異地備份、雲端備份等，使用者可以根據自己的需求來選擇適合的備份方式。",[38,343,344],{"id":344},"重灌系統",[15,346,347,348,351],{},"重灌系統，說穿了就是「",[18,349,350],{},"把電腦砍掉重練","」。",[15,353,354],{},"但這邊所謂的砍掉重練並不是叫你拿刀子去砍電腦...",[15,356,357],{},[33,358],{"alt":359,"src":360},"拿刀砍電腦","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday11\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8829%E6%97%A5%20%E4%B8%8B%E5%8D%8808_45_27.png",[15,362,363,364,367,368,371],{},"而是將電腦中的所有資料與作業系統全部刪除，然後重新安裝作業系統與軟體，簡單來講就是恢復「",[18,365,366],{},"出廠設定","」的意思，如果稍微有點難懂，你也可以理解成「",[18,369,370],{},"格式化硬碟","」的概念。",[15,373,374],{},"那麼我們該怎麼重灌系統呢？在開始重灌之前需要先做以下事情：",[376,377,378,384,390,402,408,414],"ol",{},[99,379,380,383],{},[18,381,382],{},"備份重要資料："," 這是最重要的一步，因為重灌會清除電腦裡所有資料，先把重要文件、照片等存起來。",[99,385,386,389],{},[18,387,388],{},"準備安裝媒介："," 準備一個可以用來安裝作業系統的媒介，例如 USB 隨身碟或 DVD 光碟，並把作業系統的映像檔（ISO）放進去。",[99,391,392,395,396,401],{},[18,393,394],{},"取得作業系統："," 以 Windows 為例，可以到 ",[23,397,400],{"href":398,"rel":399},"https:\u002F\u002Fwww.microsoft.com\u002Fzh-tw\u002Fsoftware-download",[27],"官方網站"," 下載 ISO，然後製作成 USB 開機碟或燒錄到 DVD 光碟。",[99,403,404,407],{},[18,405,406],{},"設定 BIOS："," 不論是選擇 USB 隨身碟或 DVD 光碟作為安裝媒介，進入 BIOS，將 USB 或 DVD 設為第一開機裝置，常見的進入方式是在開機時按 F2、Del 或 Esc。",[99,409,410,413],{},[18,411,412],{},"開始安裝："," 當你完成以上步驟後，就可以開始安裝作業系統了，這邊以 Windows 為例，從安裝媒介啟動後，會進入安裝畫面，按照指示一步步完成作業系統安裝即可。",[99,415,416,419],{},[18,417,418],{},"安裝驅動程式："," 早期的作業系統會需要額外自行手動安裝驅動程式，但現代作業系統大多自帶常用驅動程式，可以正常開機使用；若有少數硬體沒驅動，則再手動下載安裝即可。",[15,421,422],{},"以上就是重灌作業系統的流程，但其實這個流程會因為作業系統的不同而有所差異，例如：Linux、macOS 等等，這邊就不一一贅述了。",[15,424,425],{},"而重灌系統的好處有很多，例如：",[96,427,428,434,440,446],{},[99,429,430,433],{},[18,431,432],{},"清除病毒："," 重灌能有效清除大多數病毒，讓系統恢復正常。但若是勒索病毒，檔案已被加密，就算重灌也救不回來。",[99,435,436,439],{},[18,437,438],{},"提升效能："," Windows 用久了會因安裝\u002F移除軟體殘留檔案而變慢，重灌能讓系統回到初始狀態，效能自然提升。",[99,441,442,445],{},[18,443,444],{},"修復系統問題："," 藍屏、無法開機等多因系統檔案損壞，重灌大多都能直接解決。",[99,447,448,451],{},[18,449,450],{},"更新系統："," 重灌通常會順便升級到最新版本，享有新功能與安全性更新。",[15,453,454],{},"最後這邊也整理一下，我個人推薦可以安裝的一些軟體。",[456,457,458,474],"table",{},[459,460,461],"thead",{},[462,463,464,468,471],"tr",{},[465,466,467],"th",{},"類型",[465,469,470],{},"軟體名稱",[465,472,473],{},"用途 \u002F 補充說明",[475,476,477,489,504,535,557,572,587,602,624],"tbody",{},[462,478,479,483,486],{},[480,481,482],"td",{},"🔐 防毒軟體",[480,484,485],{},"Windows Defender（內建）",[480,487,488],{},"Windows 10 之後已內建防護，XP\u002FWin7 建議另裝防毒軟體",[462,490,491,494,501],{},[480,492,493],{},"🧩 壓縮工具",[480,495,496],{},[23,497,500],{"href":498,"rel":499},"https:\u002F\u002Fwww.7-zip.org\u002F",[27],"7-Zip",[480,502,503],{},"解壓縮常見格式，如 ZIP、RAR、7Z",[462,505,506,509,532],{},[480,507,508],{},"🌐 瀏覽器",[480,510,511,516,517,516,520,516,525,516,527],{},[23,512,515],{"href":513,"rel":514},"https:\u002F\u002Fwww.google.com\u002Fchrome\u002F",[27],"Google Chrome"," ",[518,519],"br",{},[23,521,524],{"href":522,"rel":523},"https:\u002F\u002Fwww.mozilla.org\u002Fzh-TW\u002Ffirefox\u002Fnew\u002F",[27],"Firefox",[518,526],{},[23,528,531],{"href":529,"rel":530},"https:\u002F\u002Fbrave.com\u002F",[27],"Brave",[480,533,534],{},"就是瀏覽器",[462,536,537,540,554],{},[480,538,539],{},"📄 文書處理",[480,541,542,516,547,516,549],{},[23,543,546],{"href":544,"rel":545},"https:\u002F\u002Fdocs.google.com",[27],"Google Docs",[518,548],{},[23,550,553],{"href":551,"rel":552},"https:\u002F\u002Fzh-tw.libreoffice.org\u002F",[27],"LibreOffice",[480,555,556],{},"免費文書與試算表工具，取代 Microsoft Office",[462,558,559,562,569],{},[480,560,561],{},"🎞️ 播放器",[480,563,564],{},[23,565,568],{"href":566,"rel":567},"https:\u002F\u002Fpotplayer.daum.net\u002F",[27],"PotPlayer",[480,570,571],{},"支援多數影音格式與外掛字幕",[462,573,574,577,584],{},[480,575,576],{},"📸 截圖工具",[480,578,579],{},[23,580,583],{"href":581,"rel":582},"https:\u002F\u002Fgetsharex.com\u002F",[27],"ShareX",[480,585,586],{},"強化版截圖工具，支援全畫面、區塊截圖與錄影",[462,588,589,592,599],{},[480,590,591],{},"🔎 PDF 工具",[480,593,594],{},[23,595,598],{"href":596,"rel":597},"https:\u002F\u002Fwww.sumatrapdfreader.org\u002Ffree-pdf-reader",[27],"SumatraPDF",[480,600,601],{},"輕巧取代 Adobe Reader，僅供閱讀用途",[462,603,604,607,621],{},[480,605,606],{},"☁️ 雲端同步",[480,608,609,516,614,516,616],{},[23,610,613],{"href":611,"rel":612},"https:\u002F\u002Fwww.google.com\u002Fdrive\u002F",[27],"Google Drive",[518,615],{},[23,617,620],{"href":618,"rel":619},"https:\u002F\u002Fwww.dropbox.com\u002Fzh_TW\u002F",[27],"Dropbox",[480,622,623],{},"備份資料、跨裝置同步檔案",[462,625,626,629,643],{},[480,627,628],{},"🔧 系統工具",[480,630,631,516,636,516,638],{},[23,632,635],{"href":633,"rel":634},"https:\u002F\u002Fgeekuninstaller.com\u002F",[27],"Geek Uninstaller",[518,637],{},[23,639,642],{"href":640,"rel":641},"https:\u002F\u002Fwww.ccleaner.com\u002F",[27],"CCleaner",[480,644,645],{},"軟體移除 \u002F 清除暫存（⚠️ 註冊表清理請小心使用）",[38,647,648],{"id":648},"結語",[15,650,651],{},"不知道大家有沒有重灌電腦的經驗？",[15,653,654],{},"我大概平均兩年就會重灌一次電腦，主要原因是 Windows 用久了很容易累積各種垃圾檔，而這些檔案要清除起來特別麻煩，所以乾脆定期重灌，讓電腦保持在比較乾淨的狀態。",[15,656,657],{},"不知道有沒有人跟我一樣呢？",[38,659,660],{"id":660},"同步更新",[15,662,663],{},"本文將同步更新至以下網站：",[96,665,666,673,680,687,694,701],{},[99,667,668],{},[23,669,672],{"href":670,"rel":671},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[99,674,675],{},[23,676,679],{"href":677,"rel":678},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[99,681,682],{},[23,683,686],{"href":684,"rel":685},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[99,688,689],{},[23,690,693],{"href":691,"rel":692},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[99,695,696],{},[23,697,700],{"href":698,"rel":699},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[99,702,703],{},[23,704,707],{"href":705,"rel":706},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",{"title":709,"searchDepth":710,"depth":710,"links":711},"",2,[712,713,720,721,722],{"id":40,"depth":710,"text":41},{"id":136,"depth":710,"text":136,"children":714},[715,717,718,719],{"id":149,"depth":716,"text":149},3,{"id":218,"depth":716,"text":218},{"id":253,"depth":716,"text":253},{"id":294,"depth":716,"text":294},{"id":344,"depth":710,"text":344},{"id":648,"depth":710,"text":648},{"id":660,"depth":710,"text":660},"學習經驗","2025-09-11 00:00:01","電腦中毒、首頁被綁到 hao123？本文以真實案例串起：感染途徑重點、備份觀念、USB 安裝媒體與 BIOS\u002FUEFI 設定、重灌流程與常用軟體清單，作為系統復原與日常維護的參考。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-11","6",{"title":6,"description":725},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 11】電腦中毒了！第一次學會重灌系統",[736,737,738,739,740],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","電腦重灌教學","電腦中毒處理","hao123 移除","防毒軟體推薦",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250911\u002F3674862620\u002F","IEd1XfWXktnM1Rl2DUrzljMBIebCqeUyqX68aicZLrU",{"newer":746,"older":750},{"url":747,"title":748,"date":749},"\u002Flearnexp\u002F20250912\u002F676253939\u002F","【Day 12】第一次升級電腦：從被禁止上網咖到學會 HDD、SSD 與 RAM","2025-09-12 00:00:01",{"url":751,"title":752,"date":753},"\u002Flearnexp\u002F20250910\u002F2446482814\u002F","【Day 10】快借我 USB！我要打魔獸爭霸！","2025-09-10 00:00:01",[755,760,765],{"url":756,"title":757,"date":758,"readingMinutes":759},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":761,"title":762,"date":763,"readingMinutes":764},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":766,"title":767,"date":768,"readingMinutes":731},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",1784013088261]