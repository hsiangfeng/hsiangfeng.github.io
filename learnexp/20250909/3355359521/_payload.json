[{"data":1,"prerenderedAt":820},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250909\u002F3355359521\u002F":3,"page:\u002Flearnexp\u002F20250909\u002F3355359521\u002F":4,"alt:\u002Flearnexp\u002F20250909\u002F3355359521\u002F":3,"prev-next:\u002Flearnexp\u002F20250909\u002F3355359521\u002F":795,"related:\u002Flearnexp\u002F20250909\u002F3355359521\u002F":804},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F09\u002Fday-9-why-cant-my-file-open-its-the-extension\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":774,"date":775,"description":776,"extension":777,"lang":778,"meta":779,"navigation":711,"path":780,"readingMinutes":781,"seo":782,"standalone":783,"stem":784,"tags":785,"tldr":791,"updated":792,"url":793,"__hash__":794},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 9】為什麼我的檔案打不開？原來是副檔名在作怪！.md","【Day 9】為什麼我的檔案打不開？原來是副檔名在作怪！","3355359521",{"type":9,"value":10,"toc":766},"minimark",[11,30,37,42,45,51,54,57,60,63,66,69,72,75,78,81,84,87,90,93,96,102,105,108,111,119,122,177,184,187,222,225,232,246,249,389,392,395,398,407,410,413,416,419,431,442,455,462,465,469,472,482,489,510,513,618,625,632,656,659,666,676,679,682,685,695,698,701,712,715,718,762],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"為什麼我的檔案打不開？原來是副檔名在作怪！","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday9\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8824%E6%97%A5%20%E4%B8%8B%E5%8D%8809_02_49.png",[38,39,41],"h2",{"id":40},"為什麼我的檔案打不開原來是副檔名在作怪","為什麼我的檔案打不開？原來是副檔名在作怪",[15,43,44],{},"「不知道大家有沒有用過『即時通』呢？這裡說的可不是現在常用的 Line、WhatsApp、Messenger，而是更早期的即時通訊軟體——像 Yahoo! 即時通、MSN 這些曾經風靡一時的工具。」",[15,46,47],{},[33,48],{"alt":49,"src":50},"即時通（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday9\u002F4bee3ad74044b6fbe3f9cc16d0633c8a.jpeg",[15,52,53],{},"忘記從哪一年開始，Yahoo! 即時通跟 MSN 這類即時通訊軟體開始流行起來，基本上你只要持有一個 Yahoo 或 MSN 帳號，就可以和全世界的朋友即時聯絡。",[15,55,56],{},"某一天，我收到我同學的即時通私人訊息...",[15,58,59],{},"「叮咚～～～」即時通發出的聲音。",[15,61,62],{},"「ㄟ！Ray，你有空嗎？我想麻煩你幫我改一下作業。」那天我在網咖打遊戲，玩得正起勁時，同學的即時通小視窗突然跳了出來，結果整個遊戲畫面瞬間被切回桌面。",[15,64,65],{},"「Ｘ！」我忍不住在大喊著，因為當時正在激烈廝殺（打槍戰遊戲）。",[15,67,68],{},"你們可以想像一下，正要補最後一槍或者打 LoL 英雄聯盟團戰時，畫面突然跳到桌面上，你當下不會爆氣嗎？",[15,70,71],{},"「等等幫你看啦！我在打 CS 啦！」我超級不爽的回覆著。",[15,73,74],{},"「打屁打！先幫我改作業！」同學很神速的回覆我訊息。",[15,76,77],{},"（叮咚！叮咚！叮咚！）",[15,79,80],{},"不得不說，那時候的即時通真的很煩。只要有訊息進來就會叮咚響一聲，對話視窗還會跳出來把整個畫面遮住。想不被打擾的唯一方法，就是直接把即時通登出。",[15,82,83],{},"「好啦！改什麼啦！」要不是我剛好打完，我真的會想要直接噴髒話給他。",[15,85,86],{},"「昨天電腦課老師說要把 Word 某一段文字改間鉅，但是我電腦改不了，想請你幫我改！」同學說著。",[15,88,89],{},"「喔好~改成xx行對嗎？」其實改個行距花不了多少時間，所以我就答應了。",[15,91,92],{},"「對！」同學超神速回覆我訊息，順便把檔案傳給我。",[15,94,95],{},"接收到檔案後，我才發現這檔案根本打不開，點擊後總是出現以下畫面：",[15,97,98],{},[33,99],{"alt":100,"src":101},"選擇您想要用來開啟的程式（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday9\u002F20250824204754%202.png",[15,103,104],{},"檔案格式我已經記不得了，只記得網咖電腦限制很多，連 Microsoft Word 這類軟體都不能裝。",[38,106,107],{"id":107},"副檔名的由來",[15,109,110],{},"接下來要說明一下，為什麼前面會遇到檔案打不開的問題，這就得從『副檔名』開始講起。",[15,112,113,114,118],{},"副檔名（File Extension）是指檔案名稱後面，用來標示這個檔案類型的字串，通常會由一個英文句點（",[115,116,117],"code",{},".","）開頭，然後接著一個或多個字母組成。",[15,120,121],{},"例如...",[123,124,125,136,145,154,168],"ul",{},[126,127,128,131,132,135],"li",{},[115,129,130],{},"example.txt","：這是一個文字檔案，副檔名是 ",[115,133,134],{},".txt","。",[126,137,138,141,142,135],{},[115,139,140],{},"example.jpg","：這是一個圖片檔案，副檔名是 ",[115,143,144],{},".jpg",[126,146,147,150,151,135],{},[115,148,149],{},"example.bat","：這是一個批次檔案，副檔名是 ",[115,152,153],{},".bat",[126,155,156,159,160,163,164,167],{},[115,157,158],{},"example.docx","：這是一個 Word 檔案，副檔名是 ",[115,161,162],{},".docx","（早期是 ",[115,165,166],{},".doc","）。",[126,169,170,173,174,135],{},[115,171,172],{},"example.xlsx","：這是一個 Excel 檔案，副檔名是 ",[115,175,176],{},".xlsx",[15,178,179,180,183],{},"簡單來講，副檔名就是在告訴作業系統「",[18,181,182],{},"這是什麼類型的檔案","」，這樣作業系統才會知道要用什麼程式來打開這個檔案。",[15,185,186],{},"通常來講副檔名有以下規則：",[123,188,189,201,207,215],{},[126,190,191,192,194,195,194,197,200],{},"副檔名通常由 1 到 4 個字母不等組成，像是 ",[115,193,134],{},"、",[115,196,144],{},[115,198,199],{},".exe"," 等等。",[126,202,203,204,135],{},"副檔名通常是小寫字母，但有些作業系統會區分大小寫，所以在某些情況下，副檔名可能會是大寫字母，例如 ",[115,205,206],{},".JPG",[126,208,209,210,212,213,135],{},"副檔名通常是由一個句點（",[115,211,117],{},"）開頭，然後接著一個或多個字母組成，例如 ",[115,214,130],{},[126,216,217,218,221],{},"如果沒有副檔名，作業系統則會將此檔案視為「",[18,219,220],{},"未知類型","」，這樣的檔案通常無法直接打開，除非你知道這個檔案的格式。",[15,223,224],{},"「但我的電腦看不到副檔名啊！」你可能會這樣問。",[15,226,227,228,231],{},"這是因為大部分的作業系統都會隱藏副檔名，這樣做的原因是",[18,229,230],{},"為了避免使用者誤刪除或改變副檔名","，而導致檔案無法打開，如果你想要手動打開的話，可以參考以下的方式：",[123,233,234,240],{},[126,235,236,239],{},[18,237,238],{},"Windows","：在檔案總管中，點選「檢視」選單，然後勾選「副檔名」。",[126,241,242,245],{},[18,243,244],{},"Mac","：在 Finder 中，點選「Finder」選單，然後選擇「設定」，接著在「進階」中勾選「顯示所有檔案名稱副檔名」。",[15,247,248],{},"那麼這邊也簡單附上一張副檔名對照表，讓你可以參考一下：",[250,251,252,269],"table",{},[253,254,255],"thead",{},[256,257,258,263,266],"tr",{},[259,260,262],"th",{"align":261},"left","類型",[259,264,265],{"align":261},"副檔名範例",[259,267,268],{"align":261},"說明",[270,271,272,293,314,333,355,370],"tbody",{},[256,273,274,278,290],{},[275,276,277],"td",{"align":261},"文件檔案",[275,279,280,282,283,282,285,282,288],{"align":261},[115,281,166],{},", ",[115,284,162],{},[115,286,287],{},".pdf",[115,289,134],{},[275,291,292],{"align":261},"Word、PDF、純文字",[256,294,295,298,311],{},[275,296,297],{"align":261},"圖片檔案",[275,299,300,282,302,282,305,282,308],{"align":261},[115,301,144],{},[115,303,304],{},".png",[115,306,307],{},".gif",[115,309,310],{},".svg",[275,312,313],{"align":261},"各種圖片格式",[256,315,316,319,330],{},[275,317,318],{"align":261},"音訊檔案",[275,320,321,282,324,282,327],{"align":261},[115,322,323],{},".mp3",[115,325,326],{},".wav",[115,328,329],{},".flac",[275,331,332],{"align":261},"音樂檔案，如流行歌曲、錄音檔",[256,334,335,338,352],{},[275,336,337],{"align":261},"影片檔案",[275,339,340,282,343,282,346,282,349],{"align":261},[115,341,342],{},".mp4",[115,344,345],{},".avi",[115,347,348],{},".mov",[115,350,351],{},".mkv",[275,353,354],{"align":261},"影片檔案，如電影、短片",[256,356,357,360,367],{},[275,358,359],{"align":261},"可執行檔案",[275,361,362,282,364,366],{"align":261},[115,363,199],{},[115,365,153],{},",",[275,368,369],{"align":261},"執行程式、批次檔",[256,371,372,375,386],{},[275,373,374],{"align":261},"壓縮檔案",[275,376,377,282,380,282,383],{"align":261},[115,378,379],{},".zip",[115,381,382],{},".rar",[115,384,385],{},".7z",[275,387,388],{"align":261},"壓縮打包的檔案",[15,390,391],{},"但這邊有件事情要特別說明一下...",[15,393,394],{},"「副檔名並不等於檔案的內容」",[15,396,397],{},"也就是說，副檔名只是用來告訴作業系統這個檔案是什麼類型的檔案，而並不代表這個檔案的內容。",[15,399,400,401,403,404,406],{},"舉個例子，你可以把一個 ",[115,402,130],{}," 檔案改成 ",[115,405,140],{},"，接著再點它，作業系統就會嘗試用圖片程式開啟。雖然最後一定會發生錯誤，但這並不代表檔案內容真的變成了圖片。」",[15,408,409],{},"所以如果有人跟你說：",[15,411,412],{},"「顯示副檔名可以提升安全性」",[15,414,415],{},"其實是在跟你說...",[15,417,418],{},"「顯示副檔名可以讓你知道這個檔案的類型，讓你決定要不要打開這個檔案」",[15,420,421,422,194,424,426,427,430],{},"只是通常我們看到副檔名為 ",[115,423,199],{},[115,425,153],{}," 等這類檔案時，我們會特別小心，因為裡面可能包含「",[18,428,429],{},"惡意程式碼","」。",[12,432,433],{},[15,434,435,438,439,441],{},[18,436,437],{},"Note","\n什麼是「",[18,440,429],{},"」？簡單來講就是會對你的電腦造成傷害的程式碼，像是病毒、木馬、勒索病毒等等。",[15,443,444,445,448,449,451,452,454],{},"在早期，也常見一種惡意手法，叫做『雙副檔名攻擊』。比方說",[115,446,447],{},"example.jpg.exe","，它真正的副檔名是 ",[115,450,199],{},"，但名稱裡卻刻意放了 ",[115,453,144],{},"，讓人誤以為這是一張圖片，其實點開後跑的卻是可執行檔。」",[15,456,457,458,461],{},"這邊也分享一個小故事。在早期的 DOS 時代，檔案命名有很嚴格的限制：檔名最多 8 個字母、副檔名最多 3 個字母，這種規則被稱為 8.3 命名規則，也就是「",[18,459,460],{},"檔名 8 字元 + 副檔名 3 字元","」。不過隨著系統演進，這種限制早就成為歷史，現在的檔案名稱最長可以到 255 個字元，連副檔名也能長達 255 個字元，再也不受 8.3 規則綁住了。",[15,463,464],{},"這邊提醒大家一件事，也是很多人常有的誤解：以為只要改副檔名，就能改變檔案格式。其實這觀念是錯的，改副檔名只是改了檔案名稱而已，結果只會讓系統用錯的程式去打開，卻完全不會改變檔案的內容喔～",[466,467,468],"h3",{"id":468},"該如何找出正確的檔案格式",[15,470,471],{},"最後這邊來分享幾招如何找出正確的檔案格式吧？",[15,473,474,475,477,478,481],{},"舉例來說，你原本有個檔案叫 ",[115,476,140],{},"，結果被朋友惡作劇改成了 ",[115,479,480],{},"example","，等你過一陣子再回來看，根本不知道它原本是什麼格式，只能硬著頭皮用『猜的』來開。",[15,483,484,485,488],{},"如果你今天使用的是 Mac 的話，你可以使用 ",[115,486,487],{},"file"," 指令來查看這個檔案的格式，例如：",[490,491,496],"pre",{"className":492,"code":493,"language":494,"meta":495,"style":495},"language-bash shiki shiki-themes github-dark-high-contrast","file example\n","bash","",[115,497,498],{"__ignoreMap":495},[499,500,503,506],"span",{"class":501,"line":502},"line",1,[499,504,487],{"class":505},"s_sBn",[499,507,509],{"class":508},"sTRMh"," example\n",[15,511,512],{},"這樣就會顯示出這個檔案的格式，例如：",[490,514,516],{"className":492,"code":515,"language":494,"meta":495,"style":495},"example: JPEG image data, Exif standard: [TIFF image data, big-endian, direntries=11, manufacturer=Apple, model=iPhone 12 Pro Max, orientation=upper-left, xresolution=170, yresolution=178, resolutionunit=2, software=17.0.3, datetime=2024:01:15 17:09:51, hostcomputer=iPhone 12 Pro Max], baseline, precision 8, 4032x3024, components 3\n",[115,517,518],{"__ignoreMap":495},[499,519,520,523,526,529,532,535,538,542,545,547,550,553,556,559,563,566,569,572,575,578,581,584,587,590,593,595,597,600,603,606,609,612,615],{"class":501,"line":502},[499,521,522],{"class":505},"example:",[499,524,525],{"class":508}," JPEG",[499,527,528],{"class":508}," image",[499,530,531],{"class":508}," data,",[499,533,534],{"class":508}," Exif",[499,536,537],{"class":508}," standard:",[499,539,541],{"class":540},"sMAXC"," [TIFF ",[499,543,544],{"class":508},"image",[499,546,531],{"class":508},[499,548,549],{"class":508}," big-endian,",[499,551,552],{"class":508}," direntries=11,",[499,554,555],{"class":508}," manufacturer=Apple,",[499,557,558],{"class":508}," model=iPhone",[499,560,562],{"class":561},"sCcAr"," 12",[499,564,565],{"class":508}," Pro",[499,567,568],{"class":508}," Max,",[499,570,571],{"class":508}," orientation=upper-left,",[499,573,574],{"class":508}," xresolution=170,",[499,576,577],{"class":508}," yresolution=178,",[499,579,580],{"class":508}," resolutionunit=2,",[499,582,583],{"class":508}," software=17.0.3,",[499,585,586],{"class":508}," datetime=2024:01:15",[499,588,589],{"class":508}," 17:09:51,",[499,591,592],{"class":508}," hostcomputer=iPhone",[499,594,562],{"class":561},[499,596,565],{"class":508},[499,598,599],{"class":508}," Max],",[499,601,602],{"class":508}," baseline,",[499,604,605],{"class":508}," precision",[499,607,608],{"class":508}," 8,",[499,610,611],{"class":508}," 4032x3024,",[499,613,614],{"class":508}," components",[499,616,617],{"class":561}," 3\n",[15,619,620,621,624],{},"重點就在於 ",[115,622,623],{},"JPEG image data","，這樣就可以知道這是一個 JPEG 圖片檔案。",[15,626,627,628,631],{},"如果你使用的是 Windows 的話，你可以將它用 ",[115,629,630],{},"記事本"," 打開，然後查看檔案的內容，通常在檔案的開頭會有一些特定的字元，例如...",[490,633,637],{"className":634,"code":635,"language":636,"meta":495,"style":495},"language-txt shiki shiki-themes github-dark-high-contrast","\u003CxmpGImg:width>256\u003C\u002FxmpGImg:width>\n\u003CxmpGImg:height>248\u003C\u002FxmpGImg:height>\n\u003CxmpGImg:format>JPEG\u003C\u002FxmpGImg:format>\n","txt",[115,638,639,644,650],{"__ignoreMap":495},[499,640,641],{"class":501,"line":502},[499,642,643],{},"\u003CxmpGImg:width>256\u003C\u002FxmpGImg:width>\n",[499,645,647],{"class":501,"line":646},2,[499,648,649],{},"\u003CxmpGImg:height>248\u003C\u002FxmpGImg:height>\n",[499,651,653],{"class":501,"line":652},3,[499,654,655],{},"\u003CxmpGImg:format>JPEG\u003C\u002FxmpGImg:format>\n",[15,657,658],{},"我們就可以看到這是一個 JPEG 圖片檔案，但這招只局限於很小的檔案，如果檔案太大的話就無法使用。",[15,660,661,662,665],{},"所以這邊會建議你使用 ",[115,663,664],{},"Git Bash"," 並輸入以下指令來查看這個檔案的格式：",[490,667,668],{"className":492,"code":493,"language":494,"meta":495,"style":495},[115,669,670],{"__ignoreMap":495},[499,671,672,674],{"class":501,"line":502},[499,673,487],{"class":505},[499,675,509],{"class":508},[15,677,678],{},"那麼，什麼是 Git Bash 呢？其實只要你的電腦有安裝 Git，就會自動附帶安裝 Git Bash。它是一個類似 Linux 的指令列介面，能讓你在 Windows 上直接使用許多 Linux 指令。",[15,680,681],{},"這邊還不熟悉 Git 的話也沒關係，我們後面章節有空再來介紹 Git。",[38,683,684],{"id":684},"結語",[15,686,687,688,691,692,694],{},"老實講，我以前很常幹一件事情，把 ",[115,689,690],{},"example.rar"," 改成 ",[115,693,480],{},"，然後作業系統就無法辨識這個檔案是什麼類型的檔案",[15,696,697],{},"這樣當我爸點擊這個檔案時，就會出現「無法開啟這個檔案」的錯誤訊息，他就不會再去嘗試打開這個檔案哩～",[15,699,700],{},"最後應該滿多人沒有看過 Yahoo! 即時通的，所以這邊我也剛好翻出一個 Youtube 影片，讓大家一起走進回憶吧！",[702,703],"iframe",{"width":704,"height":705,"src":706,"title":707,"frameBorder":708,"allow":709,"referrerPolicy":710,"allowFullScreen":711},560,315,"https:\u002F\u002Fwww.youtube.com\u002Fembed\u002Fn3XFqNYwYxo?si=NDO5342PJFft6ybm","YouTube video player","0","accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share","strict-origin-when-cross-origin",true,[38,713,714],{"id":714},"同步更新",[15,716,717],{},"本文將同步更新至以下網站：",[123,719,720,727,734,741,748,755],{},[126,721,722],{},[23,723,726],{"href":724,"rel":725},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[126,728,729],{},[23,730,733],{"href":731,"rel":732},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[126,735,736],{},[23,737,740],{"href":738,"rel":739},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[126,742,743],{},[23,744,747],{"href":745,"rel":746},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[126,749,750],{},[23,751,754],{"href":752,"rel":753},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Insta