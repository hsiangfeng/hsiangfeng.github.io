[{"data":1,"prerenderedAt":761},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20190503\u002F3738458215\u002F":3,"page:\u002Flearnexp\u002F20190503\u002F3738458215\u002F":4,"alt:\u002Flearnexp\u002F20190503\u002F3738458215\u002F":3,"prev-next:\u002Flearnexp\u002F20190503\u002F3738458215\u002F":737,"related:\u002Flearnexp\u002F20190503\u002F3738458215\u002F":746},"\u002Fen\u002Flearning\u002F2019\u002F05\u002F03\u002Fhow-to-design-your-own-learning\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":721,"date":722,"description":723,"extension":724,"lang":725,"meta":726,"navigation":123,"path":727,"readingMinutes":728,"seo":729,"standalone":730,"stem":731,"tags":732,"tldr":734,"updated":722,"url":735,"__hash__":736},"content\u002F學習經驗\u002F該如何制定自己的學習.md","該如何制定自己的學習","3738458215",{"type":9,"value":10,"toc":710},"minimark",[11,15,35,38,45,48,54,57,60,63,66,76,80,83,86,137,140,143,151,154,157,160,166,169,172,175,178,212,215,224,227,238,267,272,306,313,319,325,330,337,367,370,413,419,424,436,441,444,456,459,462,467,472,477,480,483,488,491,494,497,500,505,508,513,516,519,524,527,530,535,538,543,546,551,554,557,560,563,568,573,578,583,586,591,596,601,606,609,619,622,625,632,635,638,706],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,24,25,29,30,34],"p",{},"今天又寫了一篇心得分享，主要原因出在先前所撰寫的三篇文章",[20,21,23],"a",{"href":22},"\u002Flearnexp\u002F20190416\u002F3782185665\u002F","該如何正確的學習前端技術&程式語言","、",[20,26,28],{"href":27},"\u002Flearnexp\u002F20190426\u002F43778186\u002F","學習心態調整","及",[20,31,33],{"href":32},"\u002Flearnexp\u002F20190502\u002F4023370690\u002F","你願意犧牲多少來得到你想要的事物","，很多人都來詢問該如何學習及撰寫筆記這方面的問題，所以我也寫一下我提供的建議。",[12,36,37],{"id":37},"停下來",[16,39,40],{},[41,42],"img",{"alt":43,"src":44},"stop","https:\u002F\u002Fi.imgur.com\u002FqTl7n3x.jpg",[16,46,47],{},"首先在看這篇文章之前我必須先給你一個很重要的觀念!",[49,50,51],"blockquote",{},[16,52,53],{},"別人的學習方式，並不代表適用於你。",[16,55,56],{},"為什麼會這樣子講呢? 假設今天有一位新手他的一天學習時間是 16h up，從早到晚不間斷，然後每隔一個月就做出一個大型作品，你覺得你自己受的了嗎?",[16,58,59],{},"一般人是受不了(我就受不了)，所以在看這篇文章之前一定要先有一個最基本的觀念每個人的學習方式都是獨一無二的，你問來的、看來的都只能當作參考。",[12,61,62],{"id":62},"筆記的撰寫方式",[16,64,65],{},"基本上我會在這邊將筆記歸類為兩大類。",[67,68,69,73],"ul",{},[70,71,72],"li",{},"加強記憶型筆記 (記憶點筆記)",[70,74,75],{},"回顧型筆記 (整理型筆記)",[77,78,79],"h3",{"id":79},"加強記憶型筆記",[16,81,82],{},"首先先講講何謂【加強記憶型筆記】吧。",[16,84,85],{},"通常我們在學習一個語法 or 技術的時候，都會依照課本及老師所提醒的地方做重點紀錄，以前端 CSS 其中一個語法做舉例Float的筆記大概是這樣↓",[87,88,93],"pre",{"className":89,"code":90,"language":91,"meta":92,"style":92},"language-css shiki shiki-themes github-dark-high-contrast","\u002F* float主要使用兩種屬性，可以使用這兩個屬性來並排元素 *\u002F\nfloat:left;\nfloat:right;\n\n\u002F* clear 配合float清除浮動效果 *\u002F\nclear:both;\n","css","",[94,95,96,105,112,118,125,131],"code",{"__ignoreMap":92},[97,98,101],"span",{"class":99,"line":100},"line",1,[97,102,104],{"class":103},"sQrFR","\u002F* float主要使用兩種屬性，可以使用這兩個屬性來並排元素 *\u002F\n",[97,106,108],{"class":99,"line":107},2,[97,109,111],{"class":110},"sMAXC","float:left;\n",[97,113,115],{"class":99,"line":114},3,[97,116,117],{"class":110},"float:right;\n",[97,119,121],{"class":99,"line":120},4,[97,122,124],{"emptyLinePlaceholder":123},true,"\n",[97,126,128],{"class":99,"line":127},5,[97,129,130],{"class":103},"\u002F* clear 配合float清除浮動效果 *\u002F\n",[97,132,134],{"class":99,"line":133},6,[97,135,136],{"class":110},"clear:both;\n",[16,138,139],{},"然後呢?沒有然後了，因為你常見的筆記撰寫方式就是這樣子。",[16,141,142],{},"再來筆記可以分為兩大類之外還可以分為兩大類的人。",[67,144,145,148],{},[70,146,147],{},"新手",[70,149,150],{},"程度好一點的人",[16,152,153],{},"首先新手常見的問題，很多新手在學習新的東西時會感受到【很痛苦，學不會】，常常會感覺背了一大推莫名其妙的天書單字，這些狀況並不代表你不夠努力，所以一般來講當你抄下這些東西之後，當下會有印象沒有錯，但是過一段時間之後你就會忘記這個東西的存在。",[16,155,156],{},"在來講講第二種程度好一點的人，通常程度好一點的人可以很快地吸收，然後模仿出相同的東西，但是模仿終究是模仿是無法實際應用的。",[16,158,159],{},"這些原因出在我們都是使用學校教的方式去學習。",[16,161,162],{},[41,163],{"alt":164,"src":165},"學習","https:\u002F\u002Fi.imgur.com\u002Fl1FHGqZ.jpg",[16,167,168],{},"一昧地抄筆記，一昧地依樣畫葫蘆，一昧地去依照老師所教導的方式去理解，或許你會非常有印象你記憶力非常好，但是今天我們所學的東西並不像在學校一樣還會有期中考及期末考，題目都是固定且有固定的答案，通常我們都必須依照現有的知識去組合出新的答案。",[77,170,171],{"id":171},"回顧型筆記",[16,173,174],{},"這邊我就要開始講解何謂【回顧型筆記】。",[16,176,177],{},"這邊我會舉例 float 屬性來作範例講解，在前面我有說明常見的筆記大致上像這樣子↓",[87,179,181],{"className":89,"code":180,"language":91,"meta":92,"style":92},"\u002F* float主要使用兩種屬性，可以使用這兩個屬性來並排元素 *\u002F\n\nfloat:left;\nfloat:right;\n\n\u002F* clear 配合float清除浮動效果 *\u002F\nclear:both;\n",[94,182,183,187,191,195,199,203,207],{"__ignoreMap":92},[97,184,185],{"class":99,"line":100},[97,186,104],{"class":103},[97,188,189],{"class":99,"line":107},[97,190,124],{"emptyLinePlaceholder":123},[97,192,193],{"class":99,"line":114},[97,194,111],{"class":110},[97,196,197],{"class":99,"line":120},[97,198,117],{"class":110},[97,200,201],{"class":99,"line":127},[97,202,124],{"emptyLinePlaceholder":123},[97,204,205],{"class":99,"line":133},[97,206,130],{"class":103},[97,208,210],{"class":99,"line":209},7,[97,211,136],{"class":110},[16,213,214],{},"那回顧型筆記應該要如何做?其實很簡單，觀念只有一個【試著用一般人也能理解的方式去詮釋這個東西】，就是這樣簡單，所以我在這邊舉例來講我會如何詮釋 float 屬性。",[49,216,217],{},[16,218,219,220,223],{},"首先float在中文翻譯上叫做\"浮動\"，所以一般來講使用了float屬性後這個 class 就會浮起來而導致父元素沒有高度的問題，而父元素沒有高的原因是因為父元素會依照內容來決定高度，所以這邊必須搭配一個 ",[94,221,222],{},"clear:both"," 來把浮動元素拉下來，進而讓父元素有高度。",[16,225,226],{},"單純用文字敘述就是這麼簡單，但是這還可以更好一點的詮釋，所以可以試著這樣詮釋↓",[16,228,229,230,233,234,237],{},"首先我建立一個叫 ",[94,231,232],{},".box"," 的 class，裡面放入 ",[94,235,236],{},"float:left"," 屬性",[87,239,241],{"className":89,"code":240,"language":91,"meta":92,"style":92},".box {\n  float:left\n}\n",[94,242,243,251,262],{"__ignoreMap":92},[97,244,245,248],{"class":99,"line":100},[97,246,232],{"class":247},"sCcAr",[97,249,250],{"class":110}," {\n",[97,252,253,256,259],{"class":99,"line":107},[97,254,255],{"class":247},"  float",[97,257,258],{"class":110},":",[97,260,261],{"class":247},"left\n",[97,263,264],{"class":99,"line":114},[97,265,266],{"class":110},"}\n",[16,268,269,270],{},"然後再 HTML 中插入 ",[94,271,232],{},[87,273,277],{"className":274,"code":275,"language":276,"meta":92,"style":92},"language-HTML shiki shiki-themes github-dark-high-contrast","\u003Cdiv class=\"box\">這是一個浮動元素\u003C\u002Fdiv>\n","HTML",[94,278,279],{"__ignoreMap":92},[97,280,281,284,288,291,294,298,301,303],{"class":99,"line":100},[97,282,283],{"class":110},"\u003C",[97,285,287],{"class":286},"sKpQp","div",[97,289,290],{"class":247}," class",[97,292,293],{"class":110},"=",[97,295,297],{"class":296},"sTRMh","\"box\"",[97,299,300],{"class":110},">這是一個浮動元素\u003C\u002F",[97,302,287],{"class":286},[97,304,305],{"class":110},">\n",[16,307,308,309,312],{},"這時候可以發現 ",[94,310,311],{},"\u003Cbody>"," 高度變成 0 了",[16,314,315],{},[41,316],{"alt":317,"src":318},"圖片","https:\u002F\u002Fi.imgur.com\u002FKR3MFB0.png",[16,320,321,322,324],{},"那這個原因是 ",[94,323,232],{},"，它浮起來了，用畫圖來講大概是這樣子(不太會畫畫請見諒 QQ)",[16,326,327],{},[41,328],{"alt":317,"src":329},"https:\u002F\u002Fi.imgur.com\u002FONIIyWS.png",[16,331,332,333,336],{},"所以我們就必須搭配 ",[94,334,335],{},"clearfix"," 來協助我們解決浮動元素的問題。",[87,338,340],{"className":89,"code":339,"language":91,"meta":92,"style":92},".clearfix {\n  clear: both;\n}\n",[94,341,342,349,363],{"__ignoreMap":92},[97,343,344,347],{"class":99,"line":100},[97,345,346],{"class":247},".clearfix",[97,348,250],{"class":110},[97,350,351,354,357,360],{"class":99,"line":107},[97,352,353],{"class":247},"  clear",[97,355,356],{"class":110},": ",[97,358,359],{"class":247},"both",[97,361,362],{"class":110},";\n",[97,364,365],{"class":99,"line":114},[97,366,266],{"class":110},[16,368,369],{},"然後再加入至 HTML 中",[87,371,373],{"className":274,"code":372,"language":276,"meta":92,"style":92},"\u003Cdiv class=\"box\">這是一個浮動元素\u003C\u002Fdiv>\n\u003Cdiv class=\"clearfix\">\u003C\u002Fdiv>\n",[94,374,375,393],{"__ignoreMap":92},[97,376,377,379,381,383,385,387,389,391],{"class":99,"line":100},[97,378,283],{"class":110},[97,380,287],{"class":286},[97,382,290],{"class":247},[97,384,293],{"class":110},[97,386,297],{"class":296},[97,388,300],{"class":110},[97,390,287],{"class":286},[97,392,305],{"class":110},[97,394,395,397,399,401,403,406,409,411],{"class":99,"line":107},[97,396,283],{"class":110},[97,398,287],{"class":286},[97,400,290],{"class":247},[97,402,293],{"class":110},[97,404,405],{"class":296},"\"clearfix\"",[97,407,408],{"class":110},">\u003C\u002F",[97,410,287],{"class":286},[97,412,305],{"class":110},[16,414,415,416,418],{},"這時候就可以發現 ",[94,417,311],{}," 正常有高度哩~",[16,420,421],{},[41,422],{"alt":317,"src":423},"https:\u002F\u002Fi.imgur.com\u002FNQUh19D.png",[16,425,426,427,429,430,432,433,435],{},"用圖片來形容大概就是 ",[94,428,335],{}," 類似形成了一個包覆，將 ",[94,431,232],{}," 包在 ",[94,434,311],{}," 裡面",[16,437,438],{},[41,439],{"alt":317,"src":440},"https:\u002F\u002Fi.imgur.com\u002FRF62J5y.png",[16,442,443],{},"所以你會發現回顧型筆記往往會比較花時間而且會寫得勒勒長，因為這類型筆記必須花更多的時間去思考原理及想像它的運作方式，但是這種筆記會比你第一種類型的筆記還要更有幫助，因為可以證明你是否已經了解東西，另外在撰寫這類型筆記的重點有一個，千萬不要寫得太深奧，因為這種筆記往往你會很長回顧，如果你寫得太過深奧你還必須要花時間去了解當初為什麼這樣寫，所以我會建議回顧型筆記在撰寫時要拿捏以下幾個重點。",[445,446,447,450,453],"ol",{},[70,448,449],{},"盡可能的詮釋",[70,451,452],{},"搭配圖片或繪畫來描述",[70,454,455],{},"不要寫得太深奧，要讓新手甚至一般人都可以理解",[12,457,458],{"id":458},"認識學習",[16,460,461],{},"很多人都會想找尋自己的學習計畫，學習的方式百百種，我這邊提供幾個方向。",[16,463,464],{},[41,465],{"alt":458,"src":466},"https:\u002F\u002Fi.imgur.com\u002FBHK9qah.jpg",[49,468,469],{},[16,470,471],{},"試著從問題中學習問題。",[16,473,474],{},[41,475],{"alt":458,"src":476},"https:\u002F\u002Fi.imgur.com\u002F3zQW1ay.jpg",[16,478,479],{},"什麼叫從問題中學習問題?首先你已經具備有基礎知識，但是你卻不懂如何組合，此時我就會出一個很難的題目，通常大多數人都不知道該怎麼回答，因為許多技巧都是屬於組合技能，舉例就像六角學院的最終作業一樣，其實就是在組合前面老師所教的所有技能。",[16,481,482],{},"為了做出最終作業你勢必要將老師所教的技能熟悉，所以必須回頭去將這些基礎給補齊，那你有沒有想過老師為什麼不順便教你怎麼做最終作業呢?",[49,484,485],{},[16,486,487],{},"因為老師希望讓你抱著問題去學習問題，進而培養學習。",[16,489,490],{},"如果過程中老師順便教你怎麼製作最終作業，那麼你培養出來的也只是在模仿老師而已，這樣子根本就無法培養出所謂的學習計畫。",[16,492,493],{},"反之若過程你是由自己去尋找問題的解決方式，代表著你正在活用老師所教授你的知識碎片去組合出一塊屬於你的學習計畫。",[16,495,496],{},"過程中一定會有許多困難，可是如果你若總是不願意花點時間去思考原理及理解問題，那麼你就無法活用他人所教你的知識去組合出一個新的事物，那麼你就會在名為知識的大海中溺水，然後就放棄甚至逃避這個領域的學習。",[16,498,499],{},"舉例我自己來講，在我製作 GitHub 這個小作品完畢之後我就去思考我能不能製作一個 GitLab 版本呢?",[16,501,502],{},[41,503],{"alt":458,"src":504},"https:\u002F\u002Fi.imgur.com\u002FqKCF0pe.png",[16,506,507],{},"你有沒有發現老師其實並沒有要求我做這個小作品，但我卻故意找自己麻煩，而這個過程我稱之為",[49,509,510],{},[16,511,512],{},"故意製造問題給自己去學習這個問題。",[16,514,515],{},"過程中我其實找得很辛苦，因為我找不到 GitLab 的 API 文件，但是因為我給自己製造了問題那麼就會有方向去找，只是我必須花時間去找出問題的解答，當然通常這些問題的背後有很多的問題等著我去解決。",[16,517,518],{},"以這一個小作品 GitLab 來講。",[16,520,521],{},[41,522],{"alt":317,"src":523},"https:\u002F\u002Fi.imgur.com\u002Fuk6lmpa.png",[16,525,526],{},"當時我在製作這個小作品時，我必須先找尋 API 文件，找到之後我還必須去研究看懂 API 文件，否則該怎麼知道串接方式呢?",[16,528,529],{},"當我解決串接的方式後，就又有新的問題發生，我要如何拉取我要的資料?",[16,531,532],{},[41,533],{"alt":317,"src":534},"https:\u002F\u002Fi.imgur.com\u002FR80Mw3A.jpg",[16,536,537],{},"你會發現我都是在問題中學習，然後又從這些問題中延伸很多問題，感覺像是一個很恐怖的浩瀚宇宙吧?",[16,539,540],{},[41,541],{"alt":317,"src":542},"https:\u002F\u002Fi.imgur.com\u002FZhT2cH8.jpg",[16,544,545],{},"此時你應該會跟我說：",[49,547,548],{},[16,549,550],{},"這樣子我好像都在創造問題給自己找麻煩，我到底什麼時候可以真正的學會?",[16,552,553],{},"但是你知道嗎，如果你跟我一樣的做法，那麼就代表你已經在學習的路上了，你也有了自己的學習規劃，更不用說你已經超過非常多人了。",[16,555,556],{},"學習的方式只有自己去摸索才能夠算是真正的學習，但是你也會因為從問題去學習問題而越走越遠，因為你的挑戰是未知的，而且沒有任何一個知名高手會說【我已經全部學會了！】，因為學習這條路上是無比的寬廣。",[16,558,559],{},"如果你覺得我講的很沒有說服力沒有關係，我這邊在舉例一個例子。",[16,561,562],{},"我在製作 Vuejs 最終作業時，使用了非常多老師在課程上並沒有使用的套件及作法，而我在製作最終作業時，我也是在不停製造麻煩給自己，所以你可以看到我在 V2 版的時候的樣子與 V3 版是差異幅度↓",[49,564,565],{},[16,566,567],{},"V2版",[16,569,570],{},[41,571],{"alt":317,"src":572},"https:\u002F\u002Fcamo.githubusercontent.com\u002Fd41714deadd7a43d4736c8f5bed2af4d508a326c\u002F68747470733a2f2f692e696d6775722e636f6d2f593067396f41442e706e67",[49,574,575],{},[16,576,577],{},"V3版",[16,579,580],{},[41,581],{"alt":317,"src":582},"https:\u002F\u002Fcamo.githubusercontent.com\u002Fbe530916bb62fcf219c0c7587d866ba11d1af635\u002F68747470733a2f2f692e696d6775722e636f6d2f6f6968525155482e706e67",[16,584,585],{},"我思考著我想多製作一些讓網頁看起來更接近遊戲畫面，所以給加上了地圖導覽、更多的遊戲相關話語，甚至我連後台首頁都製作了↓",[49,587,588],{},[16,589,590],{},"登入畫面",[16,592,593],{},[41,594],{"alt":317,"src":595},"https:\u002F\u002Fcamo.githubusercontent.com\u002Ff6dfc2d2f9ae6de80667f7eaa7103cb85a07fb1d\u002F68747470733a2f2f692e696d6775722e636f6d2f59697a575a6a492e706e67",[49,597,598],{},[16,599,600],{},"後臺首頁",[16,602,603],{},[41,604],{"alt":317,"src":605},"https:\u002F\u002Fcamo.githubusercontent.com\u002F0ecf95a0ef35bf72af1df8b965ad9736301f458d\u002F68747470733a2f2f692e696d6775722e636f6d2f6e724564415a6b2e706e67",[16,607,608],{},"那你說我是不是給自己找了非常非常多麻煩，其中製作後台系統首頁是最麻煩的地方，因為原始提供給我的 API 是無法讓我這樣做，而我為了實現這個功能想盡辦法查資料去作出我想要的功能，雖然過程開發很辛苦，但我得到的是我學會了活用這個 API 及套件的使用方式及原理。",[16,610,611,612,618],{},"其實在我撰寫這篇文章時，讓我想到了一篇不錯的文章叫做 ",[20,613,617],{"href":614,"rel":615},"https:\u002F\u002Fwww.facebook.com\u002FAEXERS\u002Fmedia_set?set=a.2000341100052692&type=3",[616],"nofollow","關於學習的秘密","，不妨你也能夠了解看看。",[12,620,621],{"id":621},"結尾",[16,623,624],{},"相信你看完這一篇文章，你應該對於學習的計畫及筆記的撰寫方式應該會更有方向，希望我的這一篇文章可以幫助到你的學習，讓我們互相扶持成長吧:D",[16,626,627,628],{},"圖源: ",[20,629,630],{"href":630,"rel":631},"https:\u002F\u002Funsplash.com",[616],[12,633,634],{"id":634},"補充作品部分",[16,636,637],{},"有些朋友私下來問我希望可以看看我的這幾個作品的GitHub repo，所以我這邊也提供一下囉~",[67,639,640,658,674,690],{},[70,641,642,643],{},"RagnarokShopV3",[67,644,645,652],{},[70,646,647,648],{},"Github: ",[20,649,650],{"href":650,"rel":651},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FRagnarokShopV3",[616],[70,653,654,655],{},"Demo: ",[20,656,657],{"href":657},"\u002FRagnarokShopV3\u002F",[70,659,660,661],{},"RagnarokShopV2",[67,662,663,669],{},[70,664,647,665],{},[20,666,667],{"href":667,"rel":668},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FRagnarokShop",[616],[70,670,654,671],{},[20,672,673],{"href":673},"\u002FRagnarokShop",[70,675,676,677],{},"Github Repo",[67,678,679,685],{},[70,680,647,681],{},[20,682,683],{"href":683,"rel":684},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FGitHub-LoadAllRepo",[616],[70,686,654,687],{},[20,688,689],{"href":689},"\u002FGitHub-LoadAllRepo",[70,691,692,693],{},"GitLab Repo",[67,694,695,701],{},[70,696,647,697],{},[20,698,699],{"href":699,"rel":700},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FGitlab-LoadAllRepo",[616],[70,702,654,703],{},[20,704,705],{"href":705},"\u002FGitlab-LoadAllRepo\u002F",[707,708,709],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":92,"searchDepth":107,"depth":107,"links":711},[712,713,714,718,719,720],{"id":14,"depth":107,"text":14},{"id":37,"depth":107,"text":37},{"id":62,"depth":107,"text":62,"children":715},[716,717],{"id":79,"depth":114,"text":79},{"id":171,"depth":114,"text":171},{"id":458,"depth":107,"text":458},{"id":621,"depth":107,"text":621},{"id":634,"depth":107,"text":634},"學習經驗","2019-05-03 09:53:55","今天又寫了一篇心得分享，主要原因出在先前所撰寫的三篇文章該如何正確的學習前端技術&程式語言、學習心態調整及你願意犧牲多少來得到你想要的事物，很多人都來詢問該如何學習及撰寫筆記這方面的問題，所以我也寫一下我提供的建議。","md","zh-Hant",{},"\u002F","6",{"title":6,"description":723},false,"學習經驗\u002F該如何制定自己的學習",[733,721],"其他",null,"\u002Flearnexp\u002F20190503\u002F3738458215\u002F","GIjRDhlaxjWvH-zCk2rNKPLS75aETn4Gee5ElzAAm58",{"newer":738,"older":742},{"url":739,"title":740,"date":741},"\u002Fjavascript\u002F20190505\u002F1432256317\u002F","JavaScript 製作分頁功能(使用 Fetch APIs)","2019-05-05 15:06:43",{"url":743,"title":744,"date":745},"\u002Fnodejs\u002F20190503\u002F2483499053\u002F","nodejs出現錯誤代碼500","2019-05-03 09:06:26",[747,752,757],{"url":748,"title":749,"date":750,"readingMinutes":751},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":753,"title":754,"date":755,"readingMinutes":756},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":758,"title":759,"date":760,"readingMinutes":728},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",1784013087648]