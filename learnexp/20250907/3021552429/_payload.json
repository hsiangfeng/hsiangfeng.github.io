[{"data":1,"prerenderedAt":909},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250907\u002F3021552429\u002F":3,"page:\u002Flearnexp\u002F20250907\u002F3021552429\u002F":4,"alt:\u002Flearnexp\u002F20250907\u002F3021552429\u002F":3,"prev-next:\u002Flearnexp\u002F20250907\u002F3021552429\u002F":884,"related:\u002Flearnexp\u002F20250907\u002F3021552429\u002F":893},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F07\u002Fday-7-urls-arent-magic-dns-is-just-a-lookup\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":863,"date":864,"description":865,"extension":866,"lang":867,"meta":868,"navigation":199,"path":869,"readingMinutes":870,"seo":871,"standalone":872,"stem":873,"tags":874,"tldr":880,"updated":881,"url":882,"__hash__":883},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 7】原來網址不是魔法！DNS 背後是查表的辛苦工程.md","【Day 7】原來網址不是魔法！DNS 背後是查表的辛苦工程","3021552429",{"type":9,"value":10,"toc":856},"minimark",[11,30,37,42,45,54,57,60,63,69,72,78,81,84,87,90,93,97,100,103,108,111,114,119,122,131,134,137,160,168,171,226,231,243,246,340,343,354,357,366,369,372,385,388,394,401,412,419,422,429,436,459,470,477,480,636,642,645,648,655,662,665,706,709,725,728,732,735,738,741,744,747,750,753,756,761,764,771,774,777,786,793,796,799,802,805,808,852],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"原來網址不是魔法！DNS 背後是查表的辛苦工程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday7\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8823%E6%97%A5%20%E4%B8%8B%E5%8D%8805_08_28.png",[38,39,41],"h2",{"id":40},"你今天-google-了嗎","你今天 Google 了嗎？",[15,43,44],{},"「各位同學，從今天開始要嘗試用 Google 搜尋資料唷！」老師站在電腦教室前說著。",[15,46,47,48,53],{},"其實我最早接觸電腦時，用的並不是 Google，而是 ",[23,49,52],{"href":50,"rel":51},"https:\u002F\u002Ftw.yahoo.com\u002F",[27],"Yahoo! 奇摩搜尋引擎","的，因為當時，Yahoo! 幾乎是台灣最常用的搜尋引擎之一。",[15,55,56],{},"「Google 是什麼？」我心裡想著。",[15,58,59],{},"「大家打開瀏覽器，在瀏覽器列上面輸入 G...o...o...g...l...e...，接著輸入 .c...o...m，然後按下 Enter 鍵！」老師說著。",[15,61,62],{},"還記得當時的 Google 首頁非常單調簡潔，畫面上幾乎看不出有提供哪些服務。",[15,64,65],{},[33,66],{"alt":67,"src":68},"Google 早期首頁（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday7\u002F20250430105841.png",[15,70,71],{},"相較於當時的 Yahoo! 奇摩網站，對比下，Google 感覺遜色很多。",[15,73,74],{},[33,75],{"alt":76,"src":77},"Yahoo! 奇摩（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday7\u002F20250430110155.png",[15,79,80],{},"所以當時我其實還是主要用 Yahoo 來搜尋資料。那麼，我大概是從什麼時候開始改用 Google，並逐漸取代掉 Yahoo 呢？",[15,82,83],{},"我記得大概是在國中時期開始的。那時候同學們陸續改用 Gmail 信箱，為了跟上大家的腳步，我也開始註冊 Gmail，接著就慢慢習慣改用 Google 搜尋引擎了。",[15,85,86],{},"還記得老師當時說過一句話：",[15,88,89],{},"「以後 Google 應該會成為大家主要用的搜尋引擎，所以你們一定要學會怎麼使用 Google 喔。」",[15,91,92],{},"不得不說，老師當時的眼光真的滿準的，如果那時有錢買股票的話，我現在應該發財致富了吧。（笑）。",[38,94,96],{"id":95},"domain網域是什麼","Domain（網域）是什麼？",[15,98,99],{},"為了讓你更容易理解這個抽象的網路概念，這邊用生活中的例子來舉例說明 Domain（網域名稱）。",[15,101,102],{},"想像一下，你要寄信或者要找一個地方的位置，通常會使用以下描述：",[12,104,105],{},[15,106,107],{},"「台北市信義區松山路 123 號」",[15,109,110],{},"這就是我們熟悉的地址，很容易記得，也很容易描述。",[15,112,113],{},"但實際上這個地址對地圖服務來說，會轉換成一組精準的經緯度，例如：",[12,115,116],{},[15,117,118],{},"「25.04740930776882, 121.57805454648769」",[15,120,121],{},"這串數字雖然能準確標示位置，但你記得住嗎？反正我是絕對記不住。畢竟我們人腦比較擅長記有意義的資訊，而不是一長串毫無意義的數字。",[15,123,124,125,130],{},"如果我們將這件事情放到網路世界上也是類似的狀況，以 Google 來講，我們都知道它的 Domain 是 ",[23,126,129],{"href":127,"rel":128},"https:\u002F\u002Fwww.google.com\u002F",[27],"google.com","，但你知道它的 IP 是什麼嗎？",[15,132,133],{},"大部分人可能都不知道，所以這裡要教大家一個小技巧，讓你學會如何查詢網域（Domain）的 IP 位址。",[15,135,136],{},"首先，你可以試著打開終端機（命令提示字元）並輸入以下指令來：",[138,139,144],"pre",{"className":140,"code":141,"language":142,"meta":143,"style":143},"language-bash shiki shiki-themes github-dark-high-contrast","nslookup www.google.com\n","bash","",[145,146,147],"code",{"__ignoreMap":143},[148,149,152,156],"span",{"class":150,"line":151},"line",1,[148,153,155],{"class":154},"s_sBn","nslookup",[148,157,159],{"class":158},"sTRMh"," www.google.com\n",[12,161,162],{},[15,163,164,167],{},[18,165,166],{},"Tip","\n這個指令只是用來查詢域名的 IP 地址，所以不用擔心會影響到你的電腦。",[15,169,170],{},"你會看到以下結果：",[138,172,174],{"className":140,"code":173,"language":142,"meta":143,"style":143},"Server: 192.168.50.1\nAddress: 192.168.50.1#53\n\nNon-authoritative answer:\nName: www.google.com\nAddress: 142.250.66.68\n",[145,175,176,185,194,201,210,218],{"__ignoreMap":143},[148,177,178,181],{"class":150,"line":151},[148,179,180],{"class":154},"Server:",[148,182,184],{"class":183},"sCcAr"," 192.168.50.1\n",[148,186,188,191],{"class":150,"line":187},2,[148,189,190],{"class":154},"Address:",[148,192,193],{"class":158}," 192.168.50.1#53\n",[148,195,197],{"class":150,"line":196},3,[148,198,200],{"emptyLinePlaceholder":199},true,"\n",[148,202,204,207],{"class":150,"line":203},4,[148,205,206],{"class":154},"Non-authoritative",[148,208,209],{"class":158}," answer:\n",[148,211,213,216],{"class":150,"line":212},5,[148,214,215],{"class":154},"Name:",[148,217,159],{"class":158},[148,219,221,223],{"class":150,"line":220},6,[148,222,190],{"class":154},[148,224,225],{"class":183}," 142.250.66.68\n",[15,227,228],{},[33,229],{"alt":155,"src":230},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday7\u002F20250823160857.png",[12,232,233],{},[15,234,235,238,239,242],{},[18,236,237],{},"Note","\n你這邊可能會發現 Address 不是 ",[145,240,241],{},"142.250.66.68","，而是其他的 IP，這是因為 Google 在全球有很多節點，會根據你的地理位置來回傳不同的 IP 位址，所謂的節點意思是 Google 在不同地區的伺服器。",[15,244,245],{},"那我們該如何看這些資訊呢？別擔心，這邊我幫你整理了表格：",[247,248,249,265],"table",{},[250,251,252],"thead",{},[253,254,255,259,262],"tr",{},[256,257,258],"th",{},"顯示內容",[256,260,261],{},"分類",[256,263,264],{},"說明",[266,267,268,282,298,311,324],"tbody",{},[253,269,270,276,279],{},[271,272,273],"td",{},[145,274,275],{},"Server: 192.168.50.1",[271,277,278],{},"查詢伺服器",[271,280,281],{},"你的電腦使用的 DNS 伺服器，通常是家用路由器的 IP。",[253,283,284,289,291],{},[271,285,286],{},[145,287,288],{},"Address: 192.168.50.1#53",[271,290,278],{},[271,292,293,294,297],{},"同上；",[145,295,296],{},"#53"," 表示使用的是 DNS 的預設通訊埠：Port 53。",[253,299,300,305,308],{},[271,301,302],{},[145,303,304],{},"Non-authoritative answer:",[271,306,307],{},"回應性質",[271,309,310],{},"表示這個 IP 資訊並非來自 Google 的權威 DNS，而是經由中繼或快取伺服器提供的非官方資料。",[253,312,313,318,321],{},[271,314,315],{},[145,316,317],{},"Name: www.google.com",[271,319,320],{},"查詢名稱",[271,322,323],{},"你查詢的網域名稱（domain name）。",[253,325,326,331,334],{},[271,327,328],{},[145,329,330],{},"Address: 142.250.66.68",[271,332,333],{},"查詢結果",[271,335,336,339],{},[145,337,338],{},"www.google.com"," 對應的 IP 位址；這是 Google 的一個節點（可能因地區而異）。",[15,341,342],{},"所以我們為什麼需要 Domain 呢？你可以試想，如果今天 Google 的 IP 是一串不好記憶的數字，例如：",[138,344,348],{"className":345,"code":346,"language":347,"meta":143,"style":143},"language-txt shiki shiki-themes github-dark-high-contrast","142.250.66.68\n","txt",[145,349,350],{"__ignoreMap":143},[148,351,352],{"class":150,"line":151},[148,353,346],{},[15,355,356],{},"那麼你要怎麼記住它呢？難道要把這串數字背起來嗎？又或者如果今天是 IPv6：",[138,358,360],{"className":345,"code":359,"language":347,"meta":143,"style":143},"2404:6800:4012:1::200e\n",[145,361,362],{"__ignoreMap":143},[148,363,364],{"class":150,"line":151},[148,365,359],{},[15,367,368],{},"你可以把握記住這些數字嗎？我想大部分人應該都不行，至少我是不行的，因此才需要有 Domain 來輔助我們記憶。",[15,370,371],{},"透過上面的說明，我們可以知道一個好的網域會具備以下特性：",[373,374,375,379,382],"ul",{},[376,377,378],"li",{},"容易被記憶",[376,380,381],{},"與品牌或服務相關",[376,383,384],{},"簡短且易於輸入",[15,386,387],{},"最典型的例子就是 Google、Facebook、YouTube 等等。好的網域對品牌建立和行銷非常重要，但也因為如此，優質的網域通常難以取得，價格也比較高，一年可能動輒幾千甚至上萬元。不過對品牌商來說，為了形象和行銷價值，這筆錢往往非常值得投資。",[15,389,390],{},[33,391],{"alt":392,"src":393},"斥資購買（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday7\u002F20250823162844.png",[15,395,396,397,400],{},"基於這些原因，網域名稱的取得通常採取「",[18,398,399],{},"先到先得","」的原則。如果你想要的網域名稱已經被別人註冊了，就無法再使用相同名稱，只能改用其他名稱，或是嘗試與現有持有人協商購買。",[15,402,403,404,407,408,411],{},"再者這種狀況下，就會衍生出一種特殊的商業行為，也就是人稱的「",[18,405,406],{},"網域蟑螂（Domain Squatter）","」，又或者是「",[18,409,410],{},"網域搶注者（Cybersquatting）","」（底下將泛指為網域蟑螂）。",[15,413,414,415,418],{},"網域蟑螂是指那些專門註冊大量網域名稱的人，然後再將這些網域名稱以高價轉售給有需要的人，這些人通常會註冊大量「",[18,416,417],{},"熱門或容易混淆","」的網域名稱，放著不經營，或掛上停放網頁廣告，等待有需求的人出高價購買。",[15,420,421],{},"「這些網域蟑螂不算違法嗎？」你可能會問我這個問題。",[15,423,424,425,428],{},"答案是",[18,426,427],{},"沒有違法","，因為網域名稱本身並沒有版權或商標的保護，只要你有錢就可以註冊任何你想要的網域名稱。",[15,430,431,432,435],{},"講到這邊就要再額外提一件事情，網域購買的方式基本上是透過「",[18,433,434],{},"網域註冊商（Domain Registrar）","」來購買，例如：",[373,437,438,445,452],{},[376,439,440],{},[23,441,444],{"href":442,"rel":443},"https:\u002F\u002Ftw.godaddy.com\u002F",[27],"GoDaddy",[376,446,447],{},[23,448,451],{"href":449,"rel":450},"https:\u002F\u002Fwww.namecheap.com\u002F",[27],"Namecheap",[376,453,454],{},[23,455,458],{"href":456,"rel":457},"https:\u002F\u002Fdomains.google\u002F",[27],"Google Domains（已於 2023 年結束服務轉移至 Squarespace）",[15,460,461,462,465,466,469],{},"這些註冊商會向 ICANN（Internet Corporation for Assigned Names and Numbers）申請網域名稱，再將其轉售給一般使用者。不過需要注意的是，當你購買網域時，並不是取得它的所有權，而是取得",[18,463,464],{},"使用權","。這個使用權通常是以「",[18,467,468],{},"年","」為單位來計算的。",[15,471,472,473,476],{},"一個網域一次最多可以註冊 10 年，但可以持續續約，所以理論上只要不間斷續約，就能一直持有。反之，如果沒有續約，網域就會被釋放出來，讓其他人重新註冊。這時候所謂的「",[18,474,475],{},"網域蟑螂","」就可能趁機搶注，並以高價轉售給原本的使用者。",[15,478,479],{},"看到這裡，可能有人也開始想試著購買自己的網域名稱了。那麼這裡我快速總結幾個重點，幫助你避免踩雷：",[247,481,482,491],{},[250,483,484],{},[253,485,486,489],{},[256,487,488],{},"項目",[256,490,264],{},[266,492,493,507,521,535,553,567,577,591,612,626],{},[253,494,495,500],{},[271,496,497],{},[18,498,499],{},"購買管道",[271,501,502,503,506],{},"網域必須透過 ",[18,504,505],{},"網域註冊商 (Domain Registrar)"," 購買，例如 Namecheap、GoDaddy、Google Domains 等。",[253,508,509,514],{},[271,510,511],{},[18,512,513],{},"使用權性質",[271,515,516,517,520],{},"網域並不是一次性買斷，而是 ",[18,518,519],{},"以年為單位","計算使用權。",[253,522,523,528],{},[271,524,525],{},[18,526,527],{},"最長持有期限",[271,529,530,531,534],{},"一次最多可註冊 ",[18,532,533],{},"10 年","，之後必須續約才能繼續使用。",[253,536,537,542],{},[271,538,539],{},[18,540,541],{},"續約機制",[271,543,544,545,548,549,552],{},"若未續約，網域會進入 ",[18,546,547],{},"寬限期 (Grace Period)"," → ",[18,550,551],{},"贖回期 (Redemption Period)"," → 最終釋出供他人購買。",[253,554,555,560],{},[271,556,557],{},[18,558,559],{},"續約費用",[271,561,562,563,566],{},"需注意不同註冊商的收費模式，可能 ",[18,564,565],{},"首年便宜、續約變貴","（例如首年 USD 10，續約 USD 20+）。",[253,568,569,574],{},[271,570,571],{},[18,572,573],{},"網域品質",[271,575,576],{},"好的網域應該具備：容易記憶、與品牌\u002F服務相關、簡短、易於輸入、不易拼錯。",[253,578,579,584],{},[271,580,581],{},[18,582,583],{},"購買已註冊網域",[271,585,586,587,590],{},"如果目標網域已被註冊，需與持有人協商，可能透過 ",[18,588,589],{},"域名交易平台 (Domain Marketplace)","，價格通常較高。",[253,592,593,598],{},[271,594,595],{},[18,596,597],{},"頂級網域 (TLD)",[271,599,600,601,604,605,604,608,611],{},"網域結尾稱為 TLD，例如 ",[145,602,603],{},".com","、",[145,606,607],{},".tw",[145,609,610],{},".org","。不同 TLD 的價格、續約政策與可用性差異很大。",[253,613,614,619],{},[271,615,616],{},[18,617,618],{},"隱私保護",[271,620,621,622,625],{},"購買網域時建議額外加購 ",[18,623,624],{},"WHOIS 隱私保護","，避免個人資料（如姓名、電話、Email）公開。",[253,627,628,633],{},[271,629,630],{},[18,631,632],{},"DNS 管理",[271,634,635],{},"註冊網域後，需要設定 DNS 記錄 (A、CNAME、MX、TXT...)，才能讓網站與 Email 正常運作。",[15,637,638,639,641],{},"上面表格中，有一個「",[18,640,624],{},"」我要特別拉出來講一下，因為這件事對於個人資料的保護非常重要。",[15,643,644],{},"在購買網域之前，務必要確認該網域商是否提供 WHOIS 隱私保護服務。這項服務能隱藏你的個人資訊，避免被公開在 WHOIS 資料庫中。若沒有啟用這個服務，你的姓名、電話、Email 等資訊就會完全公開，任何人都能查到，對個人隱私相當不安全。",[15,646,647],{},"「為什麼 WHOIS 會公開個人資訊？以及會公開哪些資料？」想也知道你會好奇這個問題。",[15,649,650,651,654],{},"簡單來講，這個問題是因為『",[18,652,653],{},"WHOIS 系統的設計","』導致，在 ICANN （網際網路名稱與數字位址分配機構）有明確規定，所有網域註冊商都必須提供註冊者的個人資訊。是為了讓網域管理更具透明度，並防止濫用（例如詐騙、垃圾郵件）。",[12,656,657],{},[15,658,659,661],{},[18,660,237],{},"\n部分地區因 GDPR，WHOIS 資料可能自動隱藏（例如 .eu 網域），但並非所有 TLD 都適用，.com、.tw 等依然可能公開個資。",[15,663,664],{},"如果你的資料沒有被保護的話，你可能會在 WHOIS 資料庫中看到以下資訊：",[138,666,668],{"className":345,"code":667,"language":347,"meta":143,"style":143},"Domain Name: example.com\nRegistrar: XYZ Registrar, Inc.\nRegistrant Name: Ray Chen\nRegistrant Organization: 個人\nRegistrant Street: Taipei City, Xinyi District, Songshan Rd. 123\nRegistrant Phone: +886.912345678\nRegistrant Email: ray@example.com\n",[145,669,670,675,680,685,690,695,700],{"__ignoreMap":143},[148,671,672],{"class":150,"line":151},[148,673,674],{},"Domain Name: example.com\n",[148,676,677],{"class":150,"line":187},[148,678,679],{},"Registrar: XYZ Registrar, Inc.\n",[148,681,682],{"class":150,"line":196},[148,683,684],{},"Registrant Name: Ray Chen\n",[148,686,687],{"class":150,"line":203},[148,688,689],{},"Registrant Organization: 個人\n",[148,691,692],{"class":150,"line":212},[148,693,694],{},"Registrant Street: Taipei City, Xinyi District, Songshan Rd. 123\n",[148,696,697],{"class":150,"line":220},[148,698,699],{},"Registrant Phone: +886.912345678\n",[148,701,703],{"class":150,"line":702},7,[148,704,705],{},"Registrant Email: ray@example.com\n",[15,707,708],{},"也正因為你的個人資料相當重要，所以我才會建議你購買 WHOIS 隱私保護服務，用來隱藏個資，避免被公開。下面我也附上幾篇自己寫過的文章，提供你參考：",[373,710,711,718],{},[376,712,713],{},[23,714,717],{"href":715,"rel":716},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20221206\u002F2011045213\u002F",[27],"從零開始教你買網址(Google Domain)到設定成自己部落格網址",[376,719,720],{},[23,721,724],{"href":722,"rel":723},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20250521\u002F617540884\u002F",[27],"Google Domains 停止後怎麼辦？用 Cloudflare 建立網域、部署網站完整圖文教學",[15,726,727],{},"希望以上的說明可以讓你在購買網域之前，少踩一點雷點～",[38,729,731],{"id":730},"dns-又是什麼","DNS 又是什麼？",[15,733,734],{},"最後的最後，來簡單補一個東西，前面有提到一句話：",[15,736,737],{},"「你的電腦使用的 DNS 伺服器，通常是家用路由器的 IP。」",[15,739,740],{},"這時候大家可能會有這幾個問題：",[15,742,743],{},"「DNS 是什麼？」",[15,745,746],{},"「原來我家有 DNS 啊！」",[15,748,749],{},"沒錯，其實你每天都在用它，只是你不知道而已，但這並不是真的 DNS 伺服器。",[15,751,752],{},"DNS（Domain Name System）就像網路的電話簿，負責把人類容易記住的網址（如 Google.com），轉換成電腦能理解的 IP 位址，是整個網際網路中非常重要的基礎設施。",[15,754,755],{},"沒有 DNS，你就必須用一長串數字來瀏覽網站，這就像是你必須用經緯度才能叫外送一樣痛苦。",[15,757,758],{},[18,759,760],{},"家中的路由器，並不是真的 DNS 伺服器，而是 DNS 的中繼器。",[15,762,763],{},"當你在瀏覽器輸入 Domain 並送出後，你家的路由器會將這個 Domain 送到真正的 DNS 伺服器，然後 DNS 伺服器會回傳對應的 IP 位址給路由器，最後由路由器再將這個 IP 位址回傳給你的電腦。",[15,765,766,767,770],{},"這個動作稱為「",[18,768,769],{},"DNS 轉送（forwarding）","」。透過這樣的設計，你家裡的所有設備（電腦、手機、平板）只需要向路由器查詢 DNS，不必每台裝置都單獨設定，讓上網流程更快、更順暢。",[15,772,773],{},"這樣的設計也能讓路由器啟用 DNS 快取（cache），避免每次都重新查詢 DNS 伺服器，進而加快上網速度。",[15,775,776],{},"所以整個過程大致上如下：",[138,778,780],{"className":345,"code":779,"language":347,"meta":143,"style":143},"瀏覽器 → 路由器 DNS → ISP DNS → 根 DNS → TLD DNS → 權威 DNS → 回傳 IP\n",[145,781,782],{"__ignoreMap":143},[148,783,784],{"class":150,"line":151},[148,785,779],{},[15,787,788,789,792],{},"這就是所謂的「",[18,790,791],{},"DNS 背後的查表工程","」，每當你輸入一個網址，其實都可能經歷這一連串的層層查詢。",[38,794,795],{"id":795},"結語",[15,797,798],{},"不知道大家第一個接觸的搜尋引擎是什麼呢？",[15,800,801],{},"聽說只要知道這個答案，就可以大致上區分出年齡層了 XD",[38,803,804],{"id":804},"同步更新",[15,806,807],{},"本文將同步更新至以下網站：",[373,809,810,817,824,831,838,845],{},[376,811,812],{},[23,813,816],{"href":814,"rel":815},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[376,818,819],{},[23,820,823],{"href":821,"rel":822},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[376,825,826],{},[23,827,830],{"href":828,"rel":829},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[376,832,833],{},[23,834,837],{"href":835,"rel":836},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[376,839,840],{},[23,841,844],{"href":842,"rel":843},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[376,846,847],{},[23,848,851],{"href":849,"rel":850},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",[853,854,855],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":143,"searchDepth":187,"depth":187,"links":857},[858,859,860,861,862],{"id":40,"depth":187,"text":41},{"id":95,"depth":187,"text":96},{"id":730,"depth":187,"text":731},{"id":795,"depth":187,"text":795},{"id":804,"depth":187,"text":804},"學習經驗","2025-09-07 00:00:01","網址不是魔法：以 nslookup 為切入口，梳理 Domain vs. IP、DNS 轉送\u002F快取與解析路徑，並整理 網域購買、續約、TLD、WHOIS 隱私 的重點，讓「輸入網址→取得 IP」的過程更清楚。","md","zh-Hant",{},"\u002Fcode-review\u002Fday-7dns","7",{"title":6,"description":865},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 7】原來網址不是魔法！DNS 背後是查表的辛苦工程",[875,876,877,878,879],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","DNS 解析教學","網址查表機制","網域購買指南","Google 搜尋引擎",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250907\u002F3021552429\u002F","W7xk-KNX2ERw2fUDeTuR7dirSp425rPyxkd5h_vQcbU",{"newer":885,"older":889},{"url":886,"title":887,"date":888},"\u002Flearnexp\u002F20250908\u002F3148680987\u002F","【Day 8】作業交了沒？快點燒進光碟裡啊！","2025-09-08 00:00:01",{"url":890,"title":891,"date":892},"\u002Flearnexp\u002F20250906\u002F3612035488\u002F