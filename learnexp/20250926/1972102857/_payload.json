[{"data":1,"prerenderedAt":1297},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250926\u002F1972102857\u002F":3,"page:\u002Flearnexp\u002F20250926\u002F1972102857\u002F":4,"alt:\u002Flearnexp\u002F20250926\u002F1972102857\u002F":3,"prev-next:\u002Flearnexp\u002F20250926\u002F1972102857\u002F":1272,"related:\u002Flearnexp\u002F20250926\u002F1972102857\u002F":1281},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F26\u002Fday-26-forced-to-become-a-frontend-engineer\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1251,"date":1252,"description":1253,"extension":1254,"lang":1255,"meta":1256,"navigation":330,"path":1257,"readingMinutes":1258,"seo":1259,"standalone":1260,"stem":1261,"tags":1262,"tldr":1268,"updated":1269,"url":1270,"__hash__":1271},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 26】就這樣我被迫轉職成前端工程師了.md","【Day 26】就這樣我被迫轉職成前端工程師了","1972102857",{"type":9,"value":10,"toc":1245},"minimark",[11,30,37,40,43,46,49,52,60,63,66,69,77,80,91,116,119,122,125,128,131,134,155,168,171,174,177,183,186,190,193,196,199,205,208,214,217,220,223,226,229,236,243,246,249,252,990,993,996,1004,1007,1089,1100,1103,1116,1119,1122,1138,1141,1153,1156,1162,1182,1185,1188,1191,1194,1197,1241],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"就這樣我被迫轉職成前端工程師了","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday26\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8810_08_47.png",[38,39,35],"h2",{"id":35},[15,41,42],{},"你沒看錯，因為公司需求，我從 PHP 工程師硬生生被轉職成了前端工程師。",[15,44,45],{},"理由呢？因為全公司只有我學過 HTML & CSS，於是主管腦中的邏輯是這樣的：",[15,47,48],{},"會切版 → 會前端 → 一定會 JavaScript。",[15,50,51],{},"結果我就這樣被推上了前端的不歸路 XD。",[12,53,54],{},[15,55,56,59],{},[18,57,58],{},"Note","\n瀏覽器主要是透過 HTML 來結構化網頁內容，CSS 用來美化網頁的外觀，而 JavaScript 則用來增加網頁的互動性與動態效果，這三者相輔相成，共同構成了現代網頁的基礎。",[15,61,62],{},"不要問我為什麼這麼聽話，自從接觸 HTML 和 CSS 之後，我就像打開了新世界的大門，開始對前端開發產生濃厚的興趣。",[15,64,65],{},"於是乎，主管順勢一推，我就這樣跌進了坑，成了前端工程師。",[15,67,68],{},"每天上班大家可以聽到的對話大概就是：",[15,70,71,72,76],{},"「Ray 這個 ",[73,74,75],"code",{},"position: absolute;"," 怎麼用啊？」",[15,78,79],{},"「Ray 公司首頁你可以幫我改一下嗎？」",[15,81,82,83,86,87,90],{},"「Ray 為什麼這個 ",[73,84,85],{},"Form"," 表單內的 ",[73,88,89],{},"Button"," 按鈕點了都是直接送出啊？」",[12,92,93],{},[15,94,95,97,86,99,101,102,105,106,109,110,115],{},[18,96,58],{},[73,98,85],{},[73,100,89],{}," 按鈕預設行為是提交表單，若要避免這種情況，可以在按鈕的 ",[73,103,104],{},"type"," 屬性中設定為 ",[73,107,108],{},"button","，詳情可見「",[23,111,114],{"href":112,"rel":113},"https:\u002F\u002Fisraynotarray.com\u002Fhtml\u002F20220924\u002F1348879561\u002F",[27],"關於 Button 有一個很奇妙的 Type 現象","」。",[15,117,118],{},"只要跟前端沾上邊的，就是找 Ray。",[15,120,121],{},"Ray = 前端",[15,123,124],{},"「Ray，這邊有一段 JavaScript，你可以幫我看一下嗎？」\n有一天，主管突然丟了這麼一句話過來。",[15,126,127],{},"當下我心裡的第一個反應只有：\n「蛤？我也不會啊！」 🤯",[15,129,130],{},"但表面上還是要裝專業，點頭回了一句：「好，我看看。」（然後內心狂翻使用手冊 XD）",[15,132,133],{},"還好主管給我的程式碼不算困難，主要只是一些基本的 DOM 操作和事件處理，我心裡鬆了一大口氣：「呼～幸好不是高難度，上天是眷顧我的 XD 」",[15,135,136,137,142,143,148,149,154],{},"也因為這件事情讓我接著買下了 ",[23,138,141],{"href":139,"rel":140},"https:\u002F\u002Fwww.udemy.com\u002Fcourse\u002Fhtml-css-learning\u002F",[27],"使用 HTML、CSS 開發一個網站"," 這堂課程的單位所出的另一門課程 ",[23,144,147],{"href":145,"rel":146},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjavascript.html",[27],"JavaScript 入門篇 - 學徒的試煉","，這時候我才開始真正認識 ",[23,150,153],{"href":151,"rel":152},"https:\u002F\u002Fwww.hexschool.com\u002F",[27],"六角學院"," 這個單位。",[12,156,157],{},[15,158,159,161,162,167],{},[18,160,58],{},"\n「JavaScript 入門篇 - 學徒的試煉」這門課由於後來過於老舊，應該改出了新版的課程，建議可以參考 ",[23,163,166],{"href":164,"rel":165},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-plus.html",[27],"JavaScript 必修篇 - 前端全攻略","。",[15,169,170],{},"沒過多久，主管一邊準備新專案，一邊自言自語地說：「下一份專案感覺可以試試看 Vue.js 呢。」",[15,172,173],{},"我心裡瞬間冒出一句 OS：「慘了，我要被迫升等學新技能了。」",[15,175,176],{},"於是，JavaScript 學到最後，我乾脆一口氣把六角學院的前端組合包買下來開始猛 K。",[15,178,179],{},[33,180],{"alt":181,"src":182},"前端組合包","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday25\u002F20250920144501.png",[15,184,185],{},"就這樣，我開啟了我的前端工程師之路。",[38,187,189],{"id":188},"javascript-的基礎","JavaScript 的基礎",[15,191,192],{},"相較於 C 語言，JavaScript 算是相對容易學習的語言，而且更容易帶來成就感，這裡的「成就感」指的是 —— 當它與 HTML、CSS 搭配使用時，可以立刻在畫面上看到實際成果。",[15,194,195],{},"「為什麼？」你可能會這樣想。",[15,197,198],{},"相較於 C、C++ 等語言，除了需要安裝較複雜的開發環境之外，而且比較多的互動都是在命令列介面（Command Line Interface, CLI）中進行，對於初學者來講，可能會覺得比較枯燥乏味。",[15,200,201],{},[33,202],{"alt":203,"src":204},"終端機（範例）","https:\u002F\u002Fraw.githubusercontent.com\u002Fhsiangfeng\u002Fhsiangfeng\u002Fmaster\u002Fassets\u002Fimages\u002Ftyped_8encjeq.gif",[15,206,207],{},"在早期網路發展的那些年來講，其實網頁非常的靜態，靜態到什麼程度呢？這邊讓我找一個 Youtube 的早期版本來當作範例。",[15,209,210],{},[33,211],{"alt":212,"src":213},"Youtube 2005（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday26\u002Fyoutube-2005.png",[15,215,216],{},"早期網頁在畫面上能看到的元素其實很少，主要還是以文字為主，雖然也能放圖片，但整體來說仍相當靜態。",[15,218,219],{},"當時的網頁大多是靠 HTML 來做內容結構化，再加上 CSS 美化，雖然畫面看起來更好看了，但依舊缺乏互動性。",[15,221,222],{},"「互動性？是指 CSS 的動畫效果嗎？」你可能會這樣想。",[15,224,225],{},"其實這裡說的「互動性」並不是指畫面漂亮，而是指使用者能和網頁互動。\n例如點擊按鈕、填寫表單時，能即時得到反應或回饋，像是表單驗證或動態更新內容。",[15,227,228],{},"當時的 CSS 頂多只能提供一些視覺效果，並不能實現真正的互動，而要解決這個問題，關鍵就在於 JavaScript —— 它甚至在那個年代被稱為 「膠水語言（Glue Language）」。",[15,230,231,232,235],{},"那麼，什麼是",[18,233,234],{},"膠水語言","呢？",[15,237,238,239,242],{},"簡單來說，就是能把不同技術或系統 ",[18,240,241],{},"「黏合」"," 在一起的語言。",[15,244,245],{},"以 JavaScript 為例，它能把 HTML 和 CSS 結合起來，讓網頁不再只是靜態的樣子，而是具備互動性。",[15,247,248],{},"在早期，JavaScript 的主要角色就是提供網頁互動，讓使用者能和網頁進行簡單的操作，但發展到現在，它的應用範圍早已大幅擴展，不僅能用於網頁前端，還能應用在 伺服器開發、桌面應用程式、行動應用程式 等領域，幾乎已經成為一門 全方位的程式語言。",[15,250,251],{},"前面提到過，JavaScript 是一個相對容易學習的語言，那它到底有多容易呢？我們先來看一個簡單的範例：",[253,254,259],"pre",{"className":255,"code":256,"language":257,"meta":258,"style":258},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F 宣告變數\nvar message = \"Hello, World!\";\nlet number = 42;\nconst pi = 3.14;\n\n\u002F\u002F 輸出變數\n\u002F\u002F console.log 的作用是將內容輸出到控制台\nconsole.log(message);\nconsole.log(number);\nconsole.log(pi);\n\n\u002F\u002F 條件判斷\nif (number > 0) {\n    console.log(\"這是一個正數\");\n} else {\n    console.log(\"這不是正數\");\n}\n\n\u002F\u002F 迴圈\nfor (let i = 0; i \u003C 5; i++) {\n    console.log(\"這是第 \" + i + \" 次迴圈\");\n}\n\n\u002F\u002F 陣列\nlet fruits = [\"蘋果\", \"香蕉\", \"橘子\"];\nfruits.forEach(function(fruit) {\n    console.log(\"我喜歡吃 \" + fruit);\n});\n\n\u002F\u002F 函式\nfunction greet(name) {\n    return \"你好，\" + name + \"！\";\n}\nconsole.log(greet(\"Ray\"));\n\n\u002F\u002F 物件導向\nclass Person {\n    constructor(name, age) {\n        this.name = name;\n        this.age = age;\n    }\n\n    introduce() {\n        return \"我的名字是 \" + this.name + \"，我的年齡是 \" + this.age + \" 歲。\";\n    }\n}\nlet person = new Person(\"Ray\", 30);\nconsole.log(person.introduce());\n\n\u002F\u002F 例外處理\ntry {\n    \u002F\u002F 嘗試執行可能會出錯的程式碼\n    let result = number \u002F 0; \u002F\u002F 這裡會產生 Infinity\n    console.log(result);\n} catch (error) {\n    \u002F\u002F 捕捉到錯誤後執行的程式碼\n    console.error(\"發生錯誤：\" + error.message);\n} finally {\n    \u002F\u002F 無論是否發生錯誤，這裡的程式碼都會執行\n    console.log(\"程式執行結束\");\n}\n","js","",[73,260,261,270,291,308,325,332,338,344,357,367,377,382,388,406,423,435,449,455,460,466,501,526,531,536,542,572,594,611,617,622,628,643,664,669,689,694,700,711,728,742,755,761,766,775,809,814,819,845,861,866,872,880,886,910,920,931,937,955,965,971,985],{"__ignoreMap":258},[262,263,266],"span",{"class":264,"line":265},"line",1,[262,267,269],{"class":268},"sQrFR","\u002F\u002F 宣告變數\n",[262,271,273,277,2