,957],{"class":269},"finally",[256,959,428],{"class":273},[256,961,963],{"class":258,"line":962},59,[256,964,965],{"class":262},"    \u002F\u002F 無論是否發生錯誤，這裡的程式碼都會執行\n",[256,967,969,971,973,975,978],{"class":258,"line":968},60,[256,970,405],{"class":273},[256,972,347],{"class":346},[256,974,410],{"class":273},[256,976,977],{"class":280},"\"程式執行結束\"",[256,979,416],{"class":273},[256,981,983],{"class":258,"line":982},61,[256,984,448],{"class":273},[17,986,987],{},"上面的範例其實是我把 PHP 的語法轉成 JavaScript 來寫，從中可以看出兩者的語法結構確實有些相似，這也是我能快速上手 JavaScript 的原因之一。",[17,989,990],{},"不過這裡並不打算深入教學 JavaScript，畢竟這不是本文的重點。",[17,992,993,994,110],{},"如果你有興趣，可以參考我先前的鐵人賽系列 ——「",[21,995,998],{"href":996,"rel":997},"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20190915\u002F57691927\u002F",[25],"RE：從零開始的學習 JS 生活",[17,1000,1001],{},"雖然 JavaScript 語法簡單易學，但也很容易被誤解，尤其是對於初學者來說，可能會因為語法的特殊性而產生一些困惑，例如：",[247,1003,1005],{"className":249,"code":1004,"language":251,"meta":252,"style":252},"let a; \u002F\u002F 如果沒有給 a 賦值，則 a 的值為 undefined\nconsole.log(a); \u002F\u002F undefined\n\nlet b = null; \u002F\u002F null 是一個特殊的值，表示「沒有值」\nconsole.log(b); \u002F\u002F null\n\nconsole.log(a == b); \u002F\u002F true\n",[70,1006,1007,1017,1029,1033,1050,1062,1066],{"__ignoreMap":252},[256,1008,1009,1011,1014],{"class":258,"line":259},[256,1010,290],{"class":269},[256,1012,1013],{"class":273}," a; ",[256,1015,1016],{"class":262},"\u002F\u002F 如果沒有給 a 賦值，則 a 的值為 undefined\n",[256,1018,1019,1021,1023,1026],{"class":258,"line":266},[256,1020,343],{"class":273},[256,1022,347],{"class":346},[256,1024,1025],{"class":273},"(a); ",[256,1027,1028],{"class":262},"\u002F\u002F undefined\n",[256,1030,1031],{"class":258,"line":287},[256,1032,325],{"emptyLinePlaceholder":324},[256,1034,1035,1037,1040,1042,1045,1047],{"class":258,"line":304},[256,1036,290],{"class":269},[256,1038,1039],{"class":273}," b ",[256,1041,277],{"class":269},[256,1043,1044],{"class":298}," null",[256,1046,901],{"class":273},[256,1048,1049],{"class":262},"\u002F\u002F null 是一個特殊的值，表示「沒有值」\n",[256,1051,1052,1054,1056,1059],{"class":258,"line":321},[256,1053,343],{"class":273},[256,1055,347],{"class":346},[256,1057,1058],{"class":273},"(b); ",[256,1060,1061],{"class":262},"\u002F\u002F null\n",[256,1063,1064],{"class":258,"line":328},[256,1065,325],{"emptyLinePlaceholder":324},[256,1067,1068,1070,1072,1075,1078,1081],{"class":258,"line":334},[256,1069,343],{"class":273},[256,1071,347],{"class":346},[256,1073,1074],{"class":273},"(a ",[256,1076,1077],{"class":269},"==",[256,1079,1080],{"class":273}," b); ",[256,1082,1083],{"class":262},"\u002F\u002F true\n",[17,1085,1086,1087,1090,1091,1094],{},"在正常的狀況下，這兩者的值應該是不相等的，但在 JavaScript 中，",[70,1088,1089],{},"undefined"," 和 ",[70,1092,1093],{},"null"," 可以被視為相等的，最主要關鍵原因在於 JavaScript 的型別轉換機制以及比較運算符的特性。",[17,1096,1097],{},"正因為這些特性，讓 JavaScript 這門語言冠上了各種稱號：",[1099,1100,1101,1105,1108],"ul",{},[1102,1103,1104],"li",{},"奇葩語言",[1102,1106,1107],{},"怪異語言",[1102,1109,1110],{},"世界上最容易誤解的語言",[17,1112,1113],{},"既然如此，那為什麼 JavaScript 到現在依然這麼受歡迎呢？",[17,1115,1116],{},"我認為最主要的原因，是有一群熱愛這門語言的開發者，持續推廣並不斷修正它的缺陷，讓 JavaScript 在演進中變得越來越完善。",[17,1118,1119,1120,1090,1122,1124,1125,1127,1128,1090,1130,1132],{},"像是早期 JavaScript 並沒有 ",[70,1121,290],{},[70,1123,307],{}," 這兩個關鍵字，只有 ",[70,1126,270],{},"，這會導致變數的作用域不明確，容易造成變數污染，但後來 ECMAScript 6（ES6）引入了 ",[70,1129,290],{},[70,1131,307],{},"，讓變數的作用域更加明確。",[17,1134,1135],{},"正因為這些改進，JavaScript 才能夠在前端開發中佔有一席之地，並且成為了現今最受歡迎的程式語言之一。",[12,1137,1138],{"title":52,"type":53},[17,1139,1140,1141,110],{},"如果你對於 JavaScript 有想要更深入學習它的特性的話，可以考慮閱讀我之前寫的系列「",[21,1142,1145],{"href":1143,"rel":1144},"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20200307\u002F318160061\u002F",[25],"JavaScript 核心觀念",[17,1147,1148],{},"如果真的要講 HTML 、CSS、JavaScript 三者之間的關係的話，就會像下方這張圖一樣：",[17,1150,1151],{},[31,1152],{"alt":1153,"src":1154},"HTML 、CSS、JavaScript 三者關係圖","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday26\u002F338-1733217432633.jpg",[1099,1156,1157,1163,1169],{},[1102,1158,1159,1162],{},[226,1160,1161],{},"HTML："," 就像人體骨架，提供結構與框架",[1102,1164,1165,1168],{},[226,1166,1167],{},"CSS："," 就像皮膚與衣服，提供外觀與美感",[1102,1170,1171,1174],{},[226,1172,1173],{},"JavaScript："," 就像肌肉與神經系統，提供動作與互動",[17,1176,1177],{},"以上就是前端開發的三大支柱，缺一不可。",[36,1179,1180],{"id":1180},"結語",[17,1182,1183],{},"到後來，我發現我也深深喜歡上 JavaScript 這些奇奇怪怪的特性，雖然它有很多讓人抓狂的地方，但也正因為這些特性，讓我對這門語言產生了濃厚的興趣。",[36,1185,1186],{"id":1186},"同步更新",[17,1188,1189],{},"本文將同步更新至以下網站：",[1099,1191,1192,1199,1206,1213,1220,1227],{},[1102,1193,1194],{},[21,1195,1198],{"href":1196,"rel":1197},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[25],"是 Ray 不是 Array",[1102,1200,1201],{},[21,1202,1205],{"href":1203,"rel":1204},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[25],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[1102,1207,1208],{},[21,1209,1212],{"href":1210,"rel":1211},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[25],"Threads - 時常會聊軟實力",[1102,1214,1215],{},[21,1216,1219],{"href":1217,"rel":1218},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[25],"Facebook - 搞怪迷因分享",[1102,1221,1222],{},[21,1223,1226],{"href":1224,"rel":1225},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[25],"Instagram - 搞怪迷因分享 + 軟實力",[1102,1228,1229],{},[21,1230,1233],{"href":1231,"rel":1232},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[25],"Portaly - 入口主頁",[1235,1236,1237],"style",{},"html pre.shiki code .sGBqm, html code.shiki .sGBqm{--shiki-light:#6A737D;--shiki-default:#6A737D;--shiki-dark:#BDC4CC}html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-defau