[{"data":1,"prerenderedAt":368},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":3,"page:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":4,"alt:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":3,"prev-next:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":349,"related:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":358},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F29\u002Fday-29-ten-years-as-an-engineer-and-the-future\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":327,"date":328,"description":329,"extension":330,"lang":331,"meta":332,"navigation":333,"path":334,"readingMinutes":335,"seo":336,"standalone":337,"stem":338,"tags":339,"tldr":345,"updated":346,"url":347,"__hash__":348},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 29】十年工程師之路與未來.md","【Day 29】十年工程師之路","4192339363",{"type":9,"value":10,"toc":321},"minimark",[11,30,37,40,43,46,49,52,55,72,75,78,81,84,134,140,143,146,149,152,155,172,175,178,181,184,191,194,197,200,203,206,217,220,223,252,255,258,261,264,267,270,273,276,279],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"十年工程師之路","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday29\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8811_17_10.png",[38,39,35],"h2",{"id":35},[15,41,42],{},"至今，我成為軟體工程師已經十年了。",[15,44,45],{},"這一次參加鐵人賽，最主要的目的就是想重新覆盤這十年來的知識與經歷。",[15,47,48],{},"從一個什麼都不懂的小白，只憑著對遊戲的喜愛一路走到今天，\n這段路上充滿了無數的挫折，但同時也收穫滿滿。",[15,50,51],{},"「你沒有想過放棄當工程師嗎？」",[15,53,54],{},"老實說，好幾次都有這種念頭。\n但每當想放棄時，我就會回想自己最初的動機 ——",[56,57,58,66,69],"ul",{},[59,60,61,62,65],"li",{},"第一次聽到電腦開機的 ",[18,63,64],{},"「嗶」"," 聲",[59,67,68],{},"第一次玩遊戲的興奮感",[59,70,71],{},"第一次看到畫面能與我互動的驚喜感。",[15,73,74],{},"初心不滅，就是我能走到今天的理由。",[15,76,77],{},"從 PHP 工程師一路轉職成前端工程師，這條路怎麼可能會輕鬆？",[15,79,80],{},"雖然程式底子讓我學習起來稍微快一些，但挑戰依然不少：\nJavaScript 的語言特性、前端生態圈的快速變化、各種框架的學習曲線……要說比較輕鬆嗎？我覺得一點也沒有 XD。",[15,82,83],{},"那麼，為了成為前端工程師，我究竟付出了哪些努力？不妨來簡單覆盤一下：",[56,85,86,89,92,95,104,125,128,131],{},[59,87,88],{},"觀看各種前端相關的課程（例如 Youtube、Udemy、HaHow、HiSKIO 等等）",[59,90,91],{},"主動參與並加入各種社群",[59,93,94],{},"參與開源專案",[59,96,97,98,103],{},"建立",[23,99,102],{"href":100,"rel":101},"https:\u002F\u002Fisraynotarray.com\u002F",[27],"前端部落格","，一年撰寫超過學習四百篇文章",[59,105,106,107,112,113,118,119,124],{},"建立 ",[23,108,111],{"href":109,"rel":110},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"粉絲專頁"," 、 ",[23,114,117],{"href":115,"rel":116},"https:\u002F\u002Fwww.instagram.com\u002Fisray_notarray\u002F",[27],"Instagram"," 、",[23,120,123],{"href":121,"rel":122},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads"," 等社群媒體，分享各種知識與經驗",[59,126,127],{},"參加各種前端相關的活動（例如前端技術大會、社群聚會等等）",[59,129,130],{},"舉辦小型讀書與分享會",[59,132,133],{},"到後期把自己變成一個 Mentor，透過分享與教學的方式提升自己的技術與知識",[15,135,136],{},[33,137],{"alt":138,"src":139},"Udemy 課程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday29\u002F20250907220131.png",[15,141,142],{},"那我有因此變得很厲害嗎？\n或者，成為前端領域裡有名的人物呢？",[15,144,145],{},"我覺得沒有。\n畢竟學海無涯，這十年來雖然學了很多，\n但依然還有更多知識沒碰過，還有無數領域值得去探索。",[15,147,148],{},"回顧這十年的旅程，就這樣告一段落了嗎？",[15,150,151],{},"當然不是，這僅僅只是新的開始，尤其在 AI 的快速發展下，我們的生活與工作都已經天翻地覆地改變。",[15,153,154],{},"我認為未來將會是這樣的：",[56,156,157,160,163,166,169],{},[59,158,159],{},"知識取得變得更容易、更廉價",[59,161,162],{},"人人都可以做出自己的產品",[59,164,165],{},"AI 將高度取代重複性高的工作",[59,167,168],{},"人們將更專注於創造性工作",[59,170,171],{},"人人必須學會使用 AI 工具來輔助自己的工作",[15,173,174],{},"未來，不是被 AI 取代的人類，而是會使用 AI 的人類。",[15,176,177],{},"儘管 AI 再怎麼發達，基本功仍然很重要，因為 AI 依舊可能出現幻覺（AI Hallucination）。",[15,179,180],{},"這時候，我們需要有足夠的知識去判斷輸出是否正確。",[15,182,183],{},"若缺乏判斷力，AI 的輸出就會變成一個黑盒子、甚至像黑魔法一樣，你無法確認它的正確性，最後只會在工作中犯下更大的錯誤。",[15,185,186,187,190],{},"這件事至今我也一直在傳達給學生們，\n與其只教他們怎麼使用 AI 工具，我更希望他們能學會如何判斷 AI 的輸出是否正確，以及 ",[18,188,189],{},"用正確的心態去面對"," AI 工具。",[15,192,193],{},"「嗯？正確的心態？」",[15,195,196],{},"你沒看錯，確實有不少學生在 AI 問世後失去了學習動力，很多人長期處在焦慮中，擔心自己會被 AI 取代。",[15,198,199],{},"但與其擔心，不如去了解 AI 的運作方式，並嘗試用它來完成一些事情，這時你會發現 —— AI 並不是萬能的，它有優點，也有缺點，而且仍需要人類的智慧來輔助與引導。",[15,201,202],{},"要說取代，我認為還需要一段時間。\n（雖然我也很希望 AI 趕快取代我每天的工作，這樣我就能有更多時間做自己喜歡的事 XD）",[15,204,205],{},"我自己這段時間也用 AI 做了不少工具，例如...",[56,207,208,211,214],{},[59,209,210],{},"網站監控系統",[59,212,213],{},"GitHub Star 分析工具",[59,215,216],{},"狼人殺遊戲",[15,218,219],{},"這些事情其實我早就一直想做，只是過去礙於時間不足，始終沒有實現，如今因為 AI 的發展，讓我能更快完成這些工具，也因此騰出更多時間去做其他想做的事。",[15,221,222],{},"當然，這個系列還有許多知識點沒有提到，例如：",[56,224,225,228,231,234,237,240,243,246,249],{},[59,226,227],{},"資料庫（MySQL、PostgreSQL、MongoDB、Redis 等等）",[59,229,230],{},"版本控制（Git、SVN 等等）",[59,232,233],{},"伺服器（Linux、Nginx、Apache、Docker、Kubernetes 等等）",[59,235,236],{},"軟體開發流程（Agile、Scrum、Kanban 等等）",[59,238,239],{},"軟體設計模式（MVC、MVVM、Singleton、Factory 等等）",[59,241,242],{},"測試（單元測試、整合測試、端對端測試等等）",[59,244,245],{},"CI\u002FCD（Jenkins、GitHub Actions、GitLab CI\u002FCD 等等）",[59,247,248],{},"雲端服務（AWS、GCP、Azure 等等）",[59,250,251],{},"其他程式語言（Python、Go、Rust、Java、C# 等等）",[15,253,254],{},"這些都是我在這十年裡陸續學到的知識點。",[15,256,257],{},"如果要一一介紹，恐怕連 Day30 的挑戰都不夠用，為了保護我的肝，我只挑了幾個有趣又基礎的部分來分享，希望能讓大家建立起一個概念。",[15,259,260],{},"至於其他更深入的知識，就留給你們自己去探索吧！",[15,262,263],{},"至於下一次鐵人賽我會不會再參加？老實說我也不知道，我只希望，看完這個系列的你，能有所收穫與成長。",[15,265,266],{},"畢竟，我也是花了很長的時間，才慢慢走到今天這一步。",[15,268,269],{},"只要你願意堅持下去，\n我相信你也一定能成為你想成為的人 —— 或是你夢想中的軟體工程師。 ：）",[15,271,272],{},"我是 Ray，我們未來有機會再見。",[38,274,275],{"id":275},"同步更新",[15,277,278],{},"本文將同步更新至以下網站：",[56,280,281,288,295,301,307,314],{},[59,282,283],{},[23,284,287],{"href":285,"rel":286},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[59,289,290],{},[23,291,294],{"href":292,"rel":293},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[59,296,297],{},[23,298,300],{"href":121,"rel":299},[27],"Threads - 時常會聊軟實力",[59,302,303],{},[23,304,306],{"href":109,"rel":305},[27],"Facebook - 搞怪迷因分享",[59,308,309],{},[23,310,313],{"href":311,"rel":312},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[59,315,316],{},[23,317,320],{"href":318,"rel":319},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",{"title":322,"searchDepth":323,"depth":323,"links":324},"",2,[325,326],{"id":35,"depth":323,"text":35},{"id":275,"depth":323,"text":275},"學習經驗","2025-09-29 00:00:00","從「嗶」聲到十年：被遊戲點燃、被前端折磨、靠寫文成長、最後和 AI 共舞 —— 一路跌跌撞撞的工程師成長紀錄。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-29","3",{"title":6,"description":329},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 29】十年工程師之路與未來",[340,341,342,343,344],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","工程師十年歷程","AI時代程式員","技術職涯破版","程式學習心得",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250929\u002F4192339363\u002F","TrxdcunEhY9FkA_yTyYP2TBLKWEa_wEgoDhXPjfjsSc",{"newer":350,"older":354},{"url":351,"title":352,"date":353},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00",{"url":355,"title":356,"date":357},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",[359,361,363],{"url":351,"title":352,"date":353,"readingMinutes":360},"4",{"url":355,"title":356,"date":357,"readingMinutes":362},"6",{"url":364,"title":365,"date":366,"readingMinutes":367},"\u002Flearnexp\u002F20250927\u002F1706365915\u002F","【Day 27】爽爽放連假的期間，我收到了資遣通知~","2025-09-27 00:00:00","5",1784011723754]