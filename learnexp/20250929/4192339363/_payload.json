[{"data":1,"prerenderedAt":367},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":3,"page:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":4,"alt:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":3,"prev-next:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":348,"related:\u002Flearnexp\u002F20250929\u002F4192339363\u002F":357},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F29\u002Fday-29-ten-years-as-an-engineer-and-the-future\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":326,"date":327,"description":328,"extension":329,"lang":330,"meta":331,"navigation":332,"path":333,"readingMinutes":334,"seo":335,"standalone":336,"stem":337,"tags":338,"tldr":344,"updated":345,"url":346,"__hash__":347},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 29】十年工程師之路與未來.md","【Day 29】十年工程師之路","4192339363",{"type":9,"value":10,"toc":320},"minimark",[11,28,35,38,41,44,47,50,53,71,74,77,80,83,133,139,142,145,148,151,154,171,174,177,180,183,190,193,196,199,202,205,216,219,222,251,254,257,260,263,266,269,272,275,278],[12,13,16],"callout",{"title":14,"type":15},"Warning","warning",[17,18,19,20,27],"p",{},"嗨！這系列文章已經重新整理、改寫成書，目前在 ",[21,22,26],"a",{"href":23,"rel":24},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[25],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[17,29,30],{},[31,32],"img",{"alt":33,"src":34},"十年工程師之路","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday29\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8811_17_10.png",[36,37,33],"h2",{"id":33},[17,39,40],{},"至今，我成為軟體工程師已經十年了。",[17,42,43],{},"這一次參加鐵人賽，最主要的目的就是想重新覆盤這十年來的知識與經歷。",[17,45,46],{},"從一個什麼都不懂的小白，只憑著對遊戲的喜愛一路走到今天，\n這段路上充滿了無數的挫折，但同時也收穫滿滿。",[17,48,49],{},"「你沒有想過放棄當工程師嗎？」",[17,51,52],{},"老實說，好幾次都有這種念頭。\n但每當想放棄時，我就會回想自己最初的動機 ——",[54,55,56,65,68],"ul",{},[57,58,59,60,64],"li",{},"第一次聽到電腦開機的 ",[61,62,63],"strong",{},"「嗶」"," 聲",[57,66,67],{},"第一次玩遊戲的興奮感",[57,69,70],{},"第一次看到畫面能與我互動的驚喜感。",[17,72,73],{},"初心不滅，就是我能走到今天的理由。",[17,75,76],{},"從 PHP 工程師一路轉職成前端工程師，這條路怎麼可能會輕鬆？",[17,78,79],{},"雖然程式底子讓我學習起來稍微快一些，但挑戰依然不少：\nJavaScript 的語言特性、前端生態圈的快速變化、各種框架的學習曲線……要說比較輕鬆嗎？我覺得一點也沒有 XD。",[17,81,82],{},"那麼，為了成為前端工程師，我究竟付出了哪些努力？不妨來簡單覆盤一下：",[54,84,85,88,91,94,103,124,127,130],{},[57,86,87],{},"觀看各種前端相關的課程（例如 Youtube、Udemy、HaHow、HiSKIO 等等）",[57,89,90],{},"主動參與並加入各種社群",[57,92,93],{},"參與開源專案",[57,95,96,97,102],{},"建立",[21,98,101],{"href":99,"rel":100},"https:\u002F\u002Fisraynotarray.com\u002F",[25],"前端部落格","，一年撰寫超過學習四百篇文章",[57,104,105,106,111,112,117,118,123],{},"建立 ",[21,107,110],{"href":108,"rel":109},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[25],"粉絲專頁"," 、 ",[21,113,116],{"href":114,"rel":115},"https:\u002F\u002Fwww.instagram.com\u002Fisray_notarray\u002F",[25],"Instagram"," 、",[21,119,122],{"href":120,"rel":121},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[25],"Threads"," 等社群媒體，分享各種知識與經驗",[57,125,126],{},"參加各種前端相關的活動（例如前端技術大會、社群聚會等等）",[57,128,129],{},"舉辦小型讀書與分享會",[57,131,132],{},"到後期把自己變成一個 Mentor，透過分享與教學的方式提升自己的技術與知識",[17,134,135],{},[31,136],{"alt":137,"src":138},"Udemy 課程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday29\u002F20250907220131.png",[17,140,141],{},"那我有因此變得很厲害嗎？\n或者，成為前端領域裡有名的人物呢？",[17,143,144],{},"我覺得沒有。\n畢竟學海無涯，這十年來雖然學了很多，\n但依然還有更多知識沒碰過，還有無數領域值得去探索。",[17,146,147],{},"回顧這十年的旅程，就這樣告一段落了嗎？",[17,149,150],{},"當然不是，這僅僅只是新的開始，尤其在 AI 的快速發展下，我們的生活與工作都已經天翻地覆地改變。",[17,152,153],{},"我認為未來將會是這樣的：",[54,155,156,159,162,165,168],{},[57,157,158],{},"知識取得變得更容易、更廉價",[57,160,161],{},"人人都可以做出自己的產品",[57,163,164],{},"AI 將高度取代重複性高的工作",[57,166,167],{},"人們將更專注於創造性工作",[57,169,170],{},"人人必須學會使用 AI 工具來輔助自己的工作",[17,172,173],{},"未來，不是被 AI 取代的人類，而是會使用 AI 的人類。",[17,175,176],{},"儘管 AI 再怎麼發達，基本功仍然很重要，因為 AI 依舊可能出現幻覺（AI Hallucination）。",[17,178,179],{},"這時候，我們需要有足夠的知識去判斷輸出是否正確。",[17,181,182],{},"若缺乏判斷力，AI 的輸出就會變成一個黑盒子、甚至像黑魔法一樣，你無法確認它的正確性，最後只會在工作中犯下更大的錯誤。",[17,184,185,186,189],{},"這件事至今我也一直在傳達給學生們，\n與其只教他們怎麼使用 AI 工具，我更希望他們能學會如何判斷 AI 的輸出是否正確，以及 ",[61,187,188],{},"用正確的心態去面對"," AI 工具。",[17,191,192],{},"「嗯？正確的心態？」",[17,194,195],{},"你沒看錯，確實有不少學生在 AI 問世後失去了學習動力，很多人長期處在焦慮中，擔心自己會被 AI 取代。",[17,197,198],{},"但與其擔心，不如去了解 AI 的運作方式，並嘗試用它來完成一些事情，這時你會發現 —— AI 並不是萬能的，它有優點，也有缺點，而且仍需要人類的智慧來輔助與引導。",[17,200,201],{},"要說取代，我認為還需要一段時間。\n（雖然我也很希望 AI 趕快取代我每天的工作，這樣我就能有更多時間做自己喜歡的事 XD）",[17,203,204],{},"我自己這段時間也用 AI 做了不少工具，例如...",[54,206,207,210,213],{},[57,208,209],{},"網站監控系統",[57,211,212],{},"GitHub Star 分析工具",[57,214,215],{},"狼人殺遊戲",[17,217,218],{},"這些事情其實我早就一直想做，只是過去礙於時間不足，始終沒有實現，如今因為 AI 的發展，讓我能更快完成這些工具，也因此騰出更多時間去做其他想做的事。",[17,220,221],{},"當然，這個系列還有許多知識點沒有提到，例如：",[54,223,224,227,230,233,236,239,242,245,248],{},[57,225,226],{},"資料庫（MySQL、PostgreSQL、MongoDB、Redis 等等）",[57,228,229],{},"版本控制（Git、SVN 等等）",[57,231,232],{},"伺服器（Linux、Nginx、Apache、Docker、Kubernetes 等等）",[57,234,235],{},"軟體開發流程（Agile、Scrum、Kanban 等等）",[57,237,238],{},"軟體設計模式（MVC、MVVM、Singleton、Factory 等等）",[57,240,241],{},"測試（單元測試、整合測試、端對端測試等等）",[57,243,244],{},"CI\u002FCD（Jenkins、GitHub Actions、GitLab CI\u002FCD 等等）",[57,246,247],{},"雲端服務（AWS、GCP、Azure 等等）",[57,249,250],{},"其他程式語言（Python、Go、Rust、Java、C# 等等）",[17,252,253],{},"這些都是我在這十年裡陸續學到的知識點。",[17,255,256],{},"如果要一一介紹，恐怕連 Day30 的挑戰都不夠用，為了保護我的肝，我只挑了幾個有趣又基礎的部分來分享，希望能讓大家建立起一個概念。",[17,258,259],{},"至於其他更深入的知識，就留給你們自己去探索吧！",[17,261,262],{},"至於下一次鐵人賽我會不會再參加？老實說我也不知道，我只希望，看完這個系列的你，能有所收穫與成長。",[17,264,265],{},"畢竟，我也是花了很長的時間，才慢慢走到今天這一步。",[17,267,268],{},"只要你願意堅持下去，\n我相信你也一定能成為你想成為的人 —— 或是你夢想中的軟體工程師。 ：）",[17,270,271],{},"我是 Ray，我們未來有機會再見。",[36,273,274],{"id":274},"同步更新",[17,276,277],{},"本文將同步更新至以下網站：",[54,279,280,287,294,300,306,313],{},[57,281,282],{},[21,283,286],{"href":284,"rel":285},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[25],"是 Ray 不是 Array",[57,288,289],{},[21,290,293],{"href":291,"rel":292},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[25],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[57,295,296],{},[21,297,299],{"href":120,"rel":298},[25],"Threads - 時常會聊軟實力",[57,301,302],{},[21,303,305],{"href":108,"rel":304},[25],"Facebook - 搞怪迷因分享",[57,307,308],{},[21,309,312],{"href":310,"rel":311},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[25],"Instagram - 搞怪迷因分享 + 軟實力",[57,314,315],{},[21,316,319],{"href":317,"rel":318},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[25],"Portaly - 入口主頁",{"title":321,"searchDepth":322,"depth":322,"links":323},"",2,[324,325],{"id":33,"depth":322,"text":33},{"id":274,"depth":322,"text":274},"學習經驗","2025-09-29 00:00:00","從「嗶」聲到十年：被遊戲點燃、被前端折磨、靠寫文成長、最後和 AI 共舞 —— 一路跌跌撞撞的工程師成長紀錄。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-29","3",{"title":6,"description":328},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 29】十年工程師之路與未來",[339,340,341,342,343],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","工程師十年歷程","AI時代程式員","技術職涯破版","程式學習心得",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250929\u002F4192339363\u002F","hJ1RtIGhB5PjIzfQuZcmlFRR1kfcr8QwNOnKnI1ytKU",{"newer":349,"older":353},{"url":350,"title":351,"date":352},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00",{"url":354,"title":355,"date":356},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",[358,360,362],{"url":350,"title":351,"date":352,"readingMinutes":359},"4",{"url":354,"title":355,"date":356,"readingMinutes":361},"6",{"url":363,"title":364,"date":365,"readingMinutes":366},"\u002Flearnexp\u002F20250927\u002F1706365915\u002F","【Day 27】爽爽放連假的期間，我收到了資遣通知~","2025-09-27 00:00:00","5",1784087360272]