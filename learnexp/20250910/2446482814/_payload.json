[{"data":1,"prerenderedAt":526},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":3,"page:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":4,"alt:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":3,"prev-next:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":501,"related:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":510},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F10\u002Fday-10-lend-me-your-usb-i-need-to-play-warcraft\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":479,"date":480,"description":481,"extension":482,"lang":483,"meta":484,"navigation":485,"path":486,"readingMinutes":487,"seo":488,"standalone":489,"stem":490,"tags":491,"tldr":497,"updated":498,"url":499,"__hash__":500},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 10】快借我 USB！我要打魔獸爭霸！.md","【Day 10】快借我 USB！我要打魔獸爭霸！","2446482814",{"type":9,"value":10,"toc":470},"minimark",[11,28,35,39,42,45,48,51,54,57,60,66,69,72,75,78,81,84,88,91,94,97,103,106,109,112,118,121,124,127,130,138,145,148,229,236,239,245,248,258,261,264,267,270,273,276,284,287,290,320,323,327,330,333,336,339,342,345,348,408,411,414,417,420,423,426],[12,13,16],"callout",{"title":14,"type":15},"Warning","warning",[17,18,19,20,27],"p",{},"嗨！這系列文章已經重新整理、改寫成書，目前在 ",[21,22,26],"a",{"href":23,"rel":24},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[25],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[17,29,30],{},[31,32],"img",{"alt":33,"src":34},"快借我 USB！我要打魔獸爭霸","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8824%E6%97%A5%20%E4%B8%8B%E5%8D%8809_47_16.png",[36,37,33],"h2",{"id":38},"快借我-usb我要打魔獸爭霸",[17,40,41],{},"雖然有一段時間都是用光碟來交作業，後來也有人改用 Email ，但後來忘記是在我國高中時， USB 開始慢慢取代光碟成為主要的儲存工具。在我的記憶中，那時候市面上的 USB 容量多半落在 4GB～16GB 之間，價格大概 300～500 元左右吧？",[17,43,44],{},"後來學校下了一個新規定，要求之後一律要用 USB 繳交作業。沒辦法，我只好跑去家裡附近的書局，買了一支 8GB 的 USB 來用。",[17,46,47],{},"「Ray 你有帶 USB 嗎？」同學在電腦課上問我。",[17,49,50],{},"「有啊，怎麼了？」反正當同學問我有沒有什麼時，八成肯定沒有好事。",[17,52,53],{},"「我有一個檔案容量有點大，你 USB 借我抓一下檔案，等一下我們一起玩。」同學用手指著螢幕，我在他畫面上看到一個叫「GAME」的壓縮檔資料夾，我就知道他想要揪人一起玩遊戲了。",[17,55,56],{},"「好啊。」我就把 USB 插上去，準備把檔案複製到我的 USB 上。",[17,58,59],{},"當時抓的那款遊戲叫做「魔獸爭霸」，每次開房（建立遊戲）都會開一個叫做「信長之野望」的地圖，沒記錯的話，地圖編號應該是 12.1c 吧？",[17,61,62],{},[31,63],{"alt":64,"src":65},"魔獸爭霸之信長之野望（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002F202508242107.jpg",[17,67,68],{},"從那之後，我們的電腦課從 CS（槍戰遊戲）進階成了魔獸爭霸了。",[17,70,71],{},"在複製的過程中，電腦跳出了一個警告視窗：",[17,73,74],{},"「檔案太大無法放置在目的地檔案系統。」",[17,76,77],{},"「後來問了同學才知道，原來如果要在 USB 裡存放超過 4GB 以上的單一檔案，就必須先把 USB 格式化成特定的檔案格式才行。」",[17,79,80],{},"不過當時我也搞不懂，為什麼那個 Game 資料夾會這麼大，更不清楚它到底是哪裡來的。後來才打聽到，原來那其實是以前學長留下來的『遺產（？）』，裡面塞滿了各種遊戲的安裝檔、破解檔，甚至還夾帶一些盜版軟體。難怪我在複製的時候，電腦一直跳出警告視窗。",[17,82,83],{},"好不容易解決了檔案太大的問題，但某次使用 USB 的時候，我卻發現整台電腦竟然被病毒入侵——那又是另一個故事了。",[36,85,87],{"id":86},"格式化format","格式化（Format）",[17,89,90],{},"基本上我們記憶卡跟 USB 剛到手時，都會需要先做一件事情，也就是「格式化」。",[17,92,93],{},"我們大多數人對格式化的印象可能是：",[17,95,96],{},"「右鍵點 USB，選擇格式化，然後跳出一個選單，選擇檔案系統，按下確定就搞定。」",[17,98,99],{},[31,100],{"alt":101,"src":102},"格式化","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002F202508242117.png",[17,104,105],{},"但其實你知道嗎？",[17,107,108],{},"格式化大致可以分為兩種層次：低階格式化（Low-Level Formatting，LLF）和高階格式化（High-Level Formatting，HLF）。",[17,110,111],{},"低階格式化又稱物理格式化，這個說法並不是真的叫你拿著一把錘子往硬碟猛敲，把它敲爛的意思",[17,113,114],{},[31,115],{"alt":116,"src":117},"敲爛硬碟","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8824%E6%97%A5%20%E4%B8%8B%E5%8D%8809_21_02.png",[17,119,120],{},"早期的硬碟雖然已經製造好磁碟片和機械結構，但裡面的磁軌、磁區劃分（邏輯結構）還是空白的，需要使用者透過低階格式化手動建立。",[17,122,123],{},"如果要做這件事情，你自己要拿 BIOS 裡面的工具或 DOS 下的專用工具，手動把磁碟劃成一格一格，設定好每個磁軌和磁區的位置。",[17,125,126],{},"對於現在來說，其實廠商都預設出場就幫你做好了這些磁碟的劃分，所以你不需要再去做這件事情了。",[17,128,129],{},"這也是為什麼你買了一顆硬碟回來，只要插上去就能直接使用。只有少數還是會遇到一些小狀況，比如 BIOS 不支援，或者主機板的 SATA 版本不相容之類的啦。不過這些細節就先不在這裡多聊了～",[17,131,132,133,137],{},"隨著時代進步，『低階格式化』這個名詞也產生了變化。早期的低階格式化，是指將磁碟劃分成一格一格的結構，並設定好每個磁軌與磁區的位置；而現在所說的低階格式化，則多是指把磁碟上的資料全部清除，並將所有內容寫成 0——這個過程也被稱為「",[134,135,136],"strong",{},"寫零","」。",[12,139,142],{"title":140,"type":141},"Note","note",[17,143,144],{},"磁碟的每個儲存單位都被清成 0，也就是把原本的資料覆蓋成空白狀態。實務上，這樣的操作更常被稱為『磁碟抹除』或『安全清除』，而不是真正意義上的低階格式化。",[17,146,147],{},"為了讓你更清楚的理解，我在下面整理了一張對照表。",[149,150,151,174],"table",{},[152,153,154],"thead",{},[155,156,157,162,165,168,171],"tr",{},[158,159,161],"th",{"align":160},"left","時代",[158,163,164],{"align":160},"低階格式化的工作內容",[158,166,167],{"align":160},"誰來做？",[158,169,170],{"align":160},"目的是什麼？",[158,172,173],{"align":160},"補充說明",[175,176,177,195,212],"tbody",{},[155,178,179,183,186,189,192],{},[180,181,182],"td",{"align":160},"🕰️ 早期",[180,184,185],{"align":160},"✏️ 手動劃分柱面、磁軌、磁區",[180,187,188],{"align":160},"👨‍💻 使用者自己（BIOS操作）",[180,190,191],{"align":160},"🛠️ 讓硬碟能正常存資料",[180,193,194],{"align":160},"⚡ 沒劃格子就不能用",[155,196,197,200,203,206,209],{},[180,198,199],{"align":160},"🚀 現代",[180,201,202],{"align":160},"🏭 出廠前自動劃分完成",[180,204,205],{"align":160},"🏢 工廠處理好",[180,207,208],{"align":160},"🔌 到手就能直接使用",[180,210,211],{"align":160},"📂 使用者只需要高階格式化",[155,213,214,217,220,223,226],{},[180,215,216],{"align":160},"❓ 現代常見的「低階格式化」",[180,218,219],{"align":160},"🧹 把資料清成0（寫零）",[180,221,222],{"align":160},"👨‍🔧 使用者或工具軟體",[180,224,225],{"align":160},"🧼 資料消除但格局不變",[180,227,228],{"align":160},"✅ 磁區不動，只清除內容",[17,230,231,232,235],{},"講完了低階格式化，接下來就要來講一下第二種格式化，也就是",[134,233,234],{},"進階格式化","。",[17,237,238],{},"進階格式化也被稱為邏輯格式化。每一個磁碟都有對應的檔案系統，而當你執行格式化時，其實就是在選擇要使用哪一種檔案系統，例如 FAT32、NTFS、exFAT 等。",[17,240,241],{},[31,242],{"alt":243,"src":244},"檔案系統","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002F20250824213902.png",[17,246,247],{},"選定檔案系統之後，系統會在磁碟上建立對應的檔案管理結構，比如：",[249,250,251,255],"ul",{},[252,253,254],"li",{},"如果是 FAT32 或 exFAT，就建立檔案配置表（File Allocation Table，FAT）。",[252,256,257],{},"如果是 NTFS，就建立主檔案表（Master File Table，MFT）。",[17,259,260],{},"這些檔案管理表會記錄每個檔案的名稱、大小與所在位置，讓系統能正確存取和管理資料。",[17,262,263],{},"你可能會想說：",[17,265,266],{},"「欸？我從來沒看過這些表格啊？」",[17,268,269],{},"沒錯，這些東西是直接寫在磁碟裡的，是系統在背後幫你偷偷管理著，所以你根本不會發現到它的存在。",[17,271,272],{},"另外，在格式化整顆磁碟時，系統通常也會更新或重建磁碟開頭的主開機紀錄（MBR，Master Boot Record），這個 MBR 負責記錄整顆磁碟的分割區結構與開機資訊。",[17,274,275],{},"所以進階格式化會有兩個重點東西：",[249,277,278,281],{},[252,279,280],{},"FAT（檔案配置表）",[252,282,283],{},"MBR（主開機紀錄）",[17,285,286],{},"這兩個東西是格式化的時候會自動建立的，當你格式化完之後，你就可以在這個磁碟上存放檔案了。",[17,288,289],{},"最後來整理一下：",[149,291,292,302],{},[152,293,294],{},[155,295,296,299],{},[158,297,298],{"align":160},"名稱",[158,300,301],{"align":160},"作用",[175,303,304,312],{},[155,305,306,309],{},[180,307,308],{"align":160},"FAT 或 MFT",[180,310,311],{"align":160},"管理檔案的名稱、大小、位置等資訊",[155,313,314,317],{},[180,315,316],{"align":160},"MBR（或 GPT）",[180,318,319],{"align":160},"記錄整顆磁碟的分割區資訊與開機設定",[17,321,322],{},"講完了格式化，接下來當然要來講講檔案系統了。",[36,324,326],{"id":325},"常見的檔案系統fat32ntfsexfat","常見的檔案系統：FAT32、NTFS、exFAT",[17,328,329],{},"講到檔案系統，最常見的不外乎就是 FAT32、NTFS、exFAT 這三種。",[17,331,332],{},"但往下講之前，我想先簡單介紹一下 FAT32 的部分，畢竟這是一個非常有歷史淵源的檔案格式。",[17,334,335],{},"早期常見的檔案系統包括 FAT12、FAT16 和 FAT32，其中數字代表的是位元數，而這些位元數會決定檔案系統能支援的最大容量。以 FAT32 為例，單一檔案最大只能支援到 4GB，而整顆磁碟則最多可支援 2TB。",[17,337,338],{},"所以 FAT 的結構可以說是相容性最好的檔案系統，如果你是老相機、老電腦要讀取使用的話，那麼選擇 FAT32 是最好的選擇。",[17,340,341],{},"至於 NTFS 和 exFAT 則是較新的檔案系統。雖然它們都能在 Windows 和 Mac 上使用，但 NTFS 在 Mac 上僅支援讀取，無法直接寫入。這是因為 NTFS 是微軟自行開發的檔案系統，主要是為了 Windows 作業系統而設計的。",[17,343,344],{},"exFAT 則是一種同時支援 Windows 與 Mac 的檔案系統，不僅能讀取也能寫入，非常適合用來存放大型檔案，例如 4K 影片或遊戲等，可以說是目前最常見的主流標準。",[17,346,347],{},"最後這邊也來做個總結表格，未來你在選擇檔案系統的時候，可以參考一下：",[149,349,350,365],{},[152,351,352],{},[155,353,354,356,359,362],{},[158,355,243],{"align":160},[158,357,358],{"align":160},"最大單一檔案大小",[158,360,361],{"align":160},"相容性",[158,363,364],{"align":160},"使用情境",[175,366,367,381,395],{},[155,368,369,372,375,378],{},[180,370,371],{"align":160},"FAT32",[180,373,374],{"align":160},"4GB",[180,376,377],{"align":160},"Windows、Mac",[180,379,380],{"align":160},"相容性最好，適合舊設備使用",[155,382,383,386,389,392],{},[180,384,385],{"align":160},"NTFS",[180,387,388],{"align":160},"16TB",[180,390,391],{"align":160},"Windows",[180,393,394],{"align":160},"適合大型檔案，Windows 專用",[155,396,397,400,403,405],{},[180,398,399],{"align":160},"exFAT",[180,401,402],{"align":160},"64ZB",[180,404,377],{"align":160},[180,406,407],{"align":160},"適合大型檔案，支援 Windows 和 Mac 使用",[17,409,410],{},"相信下次你要格式化 USB 的時候就知道該怎麼選擇檔案系統了～",[36,412,413],{"id":413},"結語",[17,415,416],{},"基本上我幾乎每天都在搞丟 USB，就跟鑰匙一樣神奇，每次都會不見，然後又會在某個地方找到。",[17,418,419],{},"不知道大家有沒有跟我一樣的經驗呢 QQ...",[36,421,422],{"id":422},"同步更新",[17,424,425],{},"本文將同步更新至以下網站：",[249,427,428,435,442,449,456,463],{},[252,429,430],{},[21,431,434],{"href":432,"rel":433},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[25],"是 Ray 不是 Array",[252,436,437],{},[21,438,441],{"href":439,"rel":440},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[25],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[252,443,444],{},[21,445,448],{"href":446,"rel":447},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[25],"Threads - 時常會聊軟實力",[252,450,451],{},[21,452,455],{"href":453,"rel":454},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[25],"Facebook - 搞怪迷因分享",[252,457,458],{},[21,459,462],{"href":460,"rel":461},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[25],"Instagram - 搞怪迷因分享 + 軟實力",[252,464,465],{},[21,466,469],{"href":467,"rel":468},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[25],"Portaly - 入口主頁",{"title":471,"searchDepth":472,"depth":472,"links":473},"",2,[474,475,476,477,478],{"id":38,"depth":472,"text":33},{"id":86,"depth":472,"text":87},{"id":325,"depth":472,"text":326},{"id":413,"depth":472,"text":413},{"id":422,"depth":472,"text":422},"學習經驗","2025-09-10 00:00:01","USB 複製檔案卻遇到 4GB 限制？這篇從魔獸爭霸的課堂回憶出發，分享 格式化層次、FAT32 限制 以及 NTFS、exFAT 的差異，以故事帶出檔案系統的基礎概念。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-10-usb","5",{"title":6,"description":481},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 10】快借我 USB！我要打魔獸爭霸！",[492,493,494,495,496],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","USB。格式化教學","檔案系統比較","魔獸爭霸回憶","4GB 檔案限制",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250910\u002F2446482814\u002F","yJmnOJrX99pF4aDh8F4hBvRy6FutelhgEjw51RmrDxM",{"newer":502,"older":506},{"url":503,"title":504,"date":505},"\u002Flearnexp\u002F20250911\u002F3674862620\u002F","【Day 11】電腦中毒了！第一次學會重灌系統","2025-09-11 00:00:01",{"url":507,"title":508,"date":509},"\u002Flearnexp\u002F20250909\u002F3355359521\u002F","【Day 9】為什麼我的檔案打不開？原來是副檔名在作怪！","2025-09-09 00:00:01",[511,516,521],{"url":512,"title":513,"date":514,"readingMinutes":515},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":517,"title":518,"date":519,"readingMinutes":520},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":522,"title":523,"date":524,"readingMinutes":525},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00","6",1784087359864]