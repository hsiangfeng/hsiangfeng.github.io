[{"data":1,"prerenderedAt":528},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":3,"page:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":4,"alt:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":3,"prev-next:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":503,"related:\u002Flearnexp\u002F20250910\u002F2446482814\u002F":512},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F10\u002Fday-10-lend-me-your-usb-i-need-to-play-warcraft\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":481,"date":482,"description":483,"extension":484,"lang":485,"meta":486,"navigation":487,"path":488,"readingMinutes":489,"seo":490,"standalone":491,"stem":492,"tags":493,"tldr":499,"updated":500,"url":501,"__hash__":502},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 10】快借我 USB！我要打魔獸爭霸！.md","【Day 10】快借我 USB！我要打魔獸爭霸！","2446482814",{"type":9,"value":10,"toc":472},"minimark",[11,30,37,41,44,47,50,53,56,59,62,68,71,74,77,80,83,86,90,93,96,99,105,108,111,114,120,123,126,129,132,139,147,150,231,238,241,247,250,260,263,266,269,272,275,278,286,289,292,322,325,329,332,335,338,341,344,347,350,410,413,416,419,422,425,428],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"快借我 USB！我要打魔獸爭霸","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8824%E6%97%A5%20%E4%B8%8B%E5%8D%8809_47_16.png",[38,39,35],"h2",{"id":40},"快借我-usb我要打魔獸爭霸",[15,42,43],{},"雖然有一段時間都是用光碟來交作業，後來也有人改用 Email ，但後來忘記是在我國高中時， USB 開始慢慢取代光碟成為主要的儲存工具。在我的記憶中，那時候市面上的 USB 容量多半落在 4GB～16GB 之間，價格大概 300～500 元左右吧？",[15,45,46],{},"後來學校下了一個新規定，要求之後一律要用 USB 繳交作業。沒辦法，我只好跑去家裡附近的書局，買了一支 8GB 的 USB 來用。",[15,48,49],{},"「Ray 你有帶 USB 嗎？」同學在電腦課上問我。",[15,51,52],{},"「有啊，怎麼了？」反正當同學問我有沒有什麼時，八成肯定沒有好事。",[15,54,55],{},"「我有一個檔案容量有點大，你 USB 借我抓一下檔案，等一下我們一起玩。」同學用手指著螢幕，我在他畫面上看到一個叫「GAME」的壓縮檔資料夾，我就知道他想要揪人一起玩遊戲了。",[15,57,58],{},"「好啊。」我就把 USB 插上去，準備把檔案複製到我的 USB 上。",[15,60,61],{},"當時抓的那款遊戲叫做「魔獸爭霸」，每次開房（建立遊戲）都會開一個叫做「信長之野望」的地圖，沒記錯的話，地圖編號應該是 12.1c 吧？",[15,63,64],{},[33,65],{"alt":66,"src":67},"魔獸爭霸之信長之野望（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002F202508242107.jpg",[15,69,70],{},"從那之後，我們的電腦課從 CS（槍戰遊戲）進階成了魔獸爭霸了。",[15,72,73],{},"在複製的過程中，電腦跳出了一個警告視窗：",[15,75,76],{},"「檔案太大無法放置在目的地檔案系統。」",[15,78,79],{},"「後來問了同學才知道，原來如果要在 USB 裡存放超過 4GB 以上的單一檔案，就必須先把 USB 格式化成特定的檔案格式才行。」",[15,81,82],{},"不過當時我也搞不懂，為什麼那個 Game 資料夾會這麼大，更不清楚它到底是哪裡來的。後來才打聽到，原來那其實是以前學長留下來的『遺產（？）』，裡面塞滿了各種遊戲的安裝檔、破解檔，甚至還夾帶一些盜版軟體。難怪我在複製的時候，電腦一直跳出警告視窗。",[15,84,85],{},"好不容易解決了檔案太大的問題，但某次使用 USB 的時候，我卻發現整台電腦竟然被病毒入侵——那又是另一個故事了。",[38,87,89],{"id":88},"格式化format","格式化（Format）",[15,91,92],{},"基本上我們記憶卡跟 USB 剛到手時，都會需要先做一件事情，也就是「格式化」。",[15,94,95],{},"我們大多數人對格式化的印象可能是：",[15,97,98],{},"「右鍵點 USB，選擇格式化，然後跳出一個選單，選擇檔案系統，按下確定就搞定。」",[15,100,101],{},[33,102],{"alt":103,"src":104},"格式化","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002F202508242117.png",[15,106,107],{},"但其實你知道嗎？",[15,109,110],{},"格式化大致可以分為兩種層次：低階格式化（Low-Level Formatting，LLF）和高階格式化（High-Level Formatting，HLF）。",[15,112,113],{},"低階格式化又稱物理格式化，這個說法並不是真的叫你拿著一把錘子往硬碟猛敲，把它敲爛的意思",[15,115,116],{},[33,117],{"alt":118,"src":119},"敲爛硬碟","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8824%E6%97%A5%20%E4%B8%8B%E5%8D%8809_21_02.png",[15,121,122],{},"早期的硬碟雖然已經製造好磁碟片和機械結構，但裡面的磁軌、磁區劃分（邏輯結構）還是空白的，需要使用者透過低階格式化手動建立。",[15,124,125],{},"如果要做這件事情，你自己要拿 BIOS 裡面的工具或 DOS 下的專用工具，手動把磁碟劃成一格一格，設定好每個磁軌和磁區的位置。",[15,127,128],{},"對於現在來說，其實廠商都預設出場就幫你做好了這些磁碟的劃分，所以你不需要再去做這件事情了。",[15,130,131],{},"這也是為什麼你買了一顆硬碟回來，只要插上去就能直接使用。只有少數還是會遇到一些小狀況，比如 BIOS 不支援，或者主機板的 SATA 版本不相容之類的啦。不過這些細節就先不在這裡多聊了～",[15,133,134,135,138],{},"隨著時代進步，『低階格式化』這個名詞也產生了變化。早期的低階格式化，是指將磁碟劃分成一格一格的結構，並設定好每個磁軌與磁區的位置；而現在所說的低階格式化，則多是指把磁碟上的資料全部清除，並將所有內容寫成 0——這個過程也被稱為「",[18,136,137],{},"寫零","」。",[12,140,141],{},[15,142,143,146],{},[18,144,145],{},"Note","\n磁碟的每個儲存單位都被清成 0，也就是把原本的資料覆蓋成空白狀態。實務上，這樣的操作更常被稱為『磁碟抹除』或『安全清除』，而不是真正意義上的低階格式化。",[15,148,149],{},"為了讓你更清楚的理解，我在下面整理了一張對照表。",[151,152,153,176],"table",{},[154,155,156],"thead",{},[157,158,159,164,167,170,173],"tr",{},[160,161,163],"th",{"align":162},"left","時代",[160,165,166],{"align":162},"低階格式化的工作內容",[160,168,169],{"align":162},"誰來做？",[160,171,172],{"align":162},"目的是什麼？",[160,174,175],{"align":162},"補充說明",[177,178,179,197,214],"tbody",{},[157,180,181,185,188,191,194],{},[182,183,184],"td",{"align":162},"🕰️ 早期",[182,186,187],{"align":162},"✏️ 手動劃分柱面、磁軌、磁區",[182,189,190],{"align":162},"👨‍💻 使用者自己（BIOS操作）",[182,192,193],{"align":162},"🛠️ 讓硬碟能正常存資料",[182,195,196],{"align":162},"⚡ 沒劃格子就不能用",[157,198,199,202,205,208,211],{},[182,200,201],{"align":162},"🚀 現代",[182,203,204],{"align":162},"🏭 出廠前自動劃分完成",[182,206,207],{"align":162},"🏢 工廠處理好",[182,209,210],{"align":162},"🔌 到手就能直接使用",[182,212,213],{"align":162},"📂 使用者只需要高階格式化",[157,215,216,219,222,225,228],{},[182,217,218],{"align":162},"❓ 現代常見的「低階格式化」",[182,220,221],{"align":162},"🧹 把資料清成0（寫零）",[182,223,224],{"align":162},"👨‍🔧 使用者或工具軟體",[182,226,227],{"align":162},"🧼 資料消除但格局不變",[182,229,230],{"align":162},"✅ 磁區不動，只清除內容",[15,232,233,234,237],{},"講完了低階格式化，接下來就要來講一下第二種格式化，也就是",[18,235,236],{},"進階格式化","。",[15,239,240],{},"進階格式化也被稱為邏輯格式化。每一個磁碟都有對應的檔案系統，而當你執行格式化時，其實就是在選擇要使用哪一種檔案系統，例如 FAT32、NTFS、exFAT 等。",[15,242,243],{},[33,244],{"alt":245,"src":246},"檔案系統","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday10\u002F20250824213902.png",[15,248,249],{},"選定檔案系統之後，系統會在磁碟上建立對應的檔案管理結構，比如：",[251,252,253,257],"ul",{},[254,255,256],"li",{},"如果是 FAT32 或 exFAT，就建立檔案配置表（File Allocation Table，FAT）。",[254,258,259],{},"如果是 NTFS，就建立主檔案表（Master File Table，MFT）。",[15,261,262],{},"這些檔案管理表會記錄每個檔案的名稱、大小與所在位置，讓系統能正確存取和管理資料。",[15,264,265],{},"你可能會想說：",[15,267,268],{},"「欸？我從來沒看過這些表格啊？」",[15,270,271],{},"沒錯，這些東西是直接寫在磁碟裡的，是系統在背後幫你偷偷管理著，所以你根本不會發現到它的存在。",[15,273,274],{},"另外，在格式化整顆磁碟時，系統通常也會更新或重建磁碟開頭的主開機紀錄（MBR，Master Boot Record），這個 MBR 負責記錄整顆磁碟的分割區結構與開機資訊。",[15,276,277],{},"所以進階格式化會有兩個重點東西：",[251,279,280,283],{},[254,281,282],{},"FAT（檔案配置表）",[254,284,285],{},"MBR（主開機紀錄）",[15,287,288],{},"這兩個東西是格式化的時候會自動建立的，當你格式化完之後，你就可以在這個磁碟上存放檔案了。",[15,290,291],{},"最後來整理一下：",[151,293,294,304],{},[154,295,296],{},[157,297,298,301],{},[160,299,300],{"align":162},"名稱",[160,302,303],{"align":162},"作用",[177,305,306,314],{},[157,307,308,311],{},[182,309,310],{"align":162},"FAT 或 MFT",[182,312,313],{"align":162},"管理檔案的名稱、大小、位置等資訊",[157,315,316,319],{},[182,317,318],{"align":162},"MBR（或 GPT）",[182,320,321],{"align":162},"記錄整顆磁碟的分割區資訊與開機設定",[15,323,324],{},"講完了格式化，接下來當然要來講講檔案系統了。",[38,326,328],{"id":327},"常見的檔案系統fat32ntfsexfat","常見的檔案系統：FAT32、NTFS、exFAT",[15,330,331],{},"講到檔案系統，最常見的不外乎就是 FAT32、NTFS、exFAT 這三種。",[15,333,334],{},"但往下講之前，我想先簡單介紹一下 FAT32 的部分，畢竟這是一個非常有歷史淵源的檔案格式。",[15,336,337],{},"早期常見的檔案系統包括 FAT12、FAT16 和 FAT32，其中數字代表的是位元數，而這些位元數會決定檔案系統能支援的最大容量。以 FAT32 為例，單一檔案最大只能支援到 4GB，而整顆磁碟則最多可支援 2TB。",[15,339,340],{},"所以 FAT 的結構可以說是相容性最好的檔案系統，如果你是老相機、老電腦要讀取使用的話，那麼選擇 FAT32 是最好的選擇。",[15,342,343],{},"至於 NTFS 和 exFAT 則是較新的檔案系統。雖然它們都能在 Windows 和 Mac 上使用，但 NTFS 在 Mac 上僅支援讀取，無法直接寫入。這是因為 NTFS 是微軟自行開發的檔案系統，主要是為了 Windows 作業系統而設計的。",[15,345,346],{},"exFAT 則是一種同時支援 Windows 與 Mac 的檔案系統，不僅能讀取也能寫入，非常適合用來存放大型檔案，例如 4K 影片或遊戲等，可以說是目前最常見的主流標準。",[15,348,349],{},"最後這邊也來做個總結表格，未來你在選擇檔案系統的時候，可以參考一下：",[151,351,352,367],{},[154,353,354],{},[157,355,356,358,361,364],{},[160,357,245],{"align":162},[160,359,360],{"align":162},"最大單一檔案大小",[160,362,363],{"align":162},"相容性",[160,365,366],{"align":162},"使用情境",[177,368,369,383,397],{},[157,370,371,374,377,380],{},[182,372,373],{"align":162},"FAT32",[182,375,376],{"align":162},"4GB",[182,378,379],{"align":162},"Windows、Mac",[182,381,382],{"align":162},"相容性最好，適合舊設備使用",[157,384,385,388,391,394],{},[182,386,387],{"align":162},"NTFS",[182,389,390],{"align":162},"16TB",[182,392,393],{"align":162},"Windows",[182,395,396],{"align":162},"適合大型檔案，Windows 專用",[157,398,399,402,405,407],{},[182,400,401],{"align":162},"exFAT",[182,403,404],{"align":162},"64ZB",[182,406,379],{"align":162},[182,408,409],{"align":162},"適合大型檔案，支援 Windows 和 Mac 使用",[15,411,412],{},"相信下次你要格式化 USB 的時候就知道該怎麼選擇檔案系統了～",[38,414,415],{"id":415},"結語",[15,417,418],{},"基本上我幾乎每天都在搞丟 USB，就跟鑰匙一樣神奇，每次都會不見，然後又會在某個地方找到。",[15,420,421],{},"不知道大家有沒有跟我一樣的經驗呢 QQ...",[38,423,424],{"id":424},"同步更新",[15,426,427],{},"本文將同步更新至以下網站：",[251,429,430,437,444,451,458,465],{},[254,431,432],{},[23,433,436],{"href":434,"rel":435},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[254,438,439],{},[23,440,443],{"href":441,"rel":442},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[254,445,446],{},[23,447,450],{"href":448,"rel":449},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[254,452,453],{},[23,454,457],{"href":455,"rel":456},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[254,459,460],{},[23,461,464],{"href":462,"rel":463},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[254,466,467],{},[23,468,471],{"href":469,"rel":470},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",{"title":473,"searchDepth":474,"depth":474,"links":475},"",2,[476,477,478,479,480],{"id":40,"depth":474,"text":35},{"id":88,"depth":474,"text":89},{"id":327,"depth":474,"text":328},{"id":415,"depth":474,"text":415},{"id":424,"depth":474,"text":424},"學習經驗","2025-09-10 00:00:01","USB 複製檔案卻遇到 4GB 限制？這篇從魔獸爭霸的課堂回憶出發，分享 格式化層次、FAT32 限制 以及 NTFS、exFAT 的差異，以故事帶出檔案系統的基礎概念。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-10-usb","5",{"title":6,"description":483},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 10】快借我 USB！我要打魔獸爭霸！",[494,495,496,497,498],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","USB。格式化教學","檔案系統比較","魔獸爭霸回憶","4GB 檔案限制",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250910\u002F2446482814\u002F","5gsAzkCSHgy8xmbI9mAZbrDgK1N3ss3qUIkEGVFhOQs",{"newer":504,"older":508},{"url":505,"title":506,"date":507},"\u002Flearnexp\u002F20250911\u002F3674862620\u002F","【Day 11】電腦中毒了！第一次學會重灌系統","2025-09-11 00:00:01",{"url":509,"title":510,"date":511},"\u002Flearnexp\u002F20250909\u002F3355359521\u002F","【Day 9】為什麼我的檔案打不開？原來是副檔名在作怪！","2025-09-09 00:00:01",[513,518,523],{"url":514,"title":515,"date":516,"readingMinutes":517},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":519,"title":520,"date":521,"readingMinutes":522},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":524,"title":525,"date":526,"readingMinutes":527},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00","6",1784013088251]