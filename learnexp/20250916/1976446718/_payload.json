[{"data":1,"prerenderedAt":539},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250916\u002F1976446718\u002F":3,"page:\u002Flearnexp\u002F20250916\u002F1976446718\u002F":4,"alt:\u002Flearnexp\u002F20250916\u002F1976446718\u002F":3,"prev-next:\u002Flearnexp\u002F20250916\u002F1976446718\u002F":517,"related:\u002Flearnexp\u002F20250916\u002F1976446718\u002F":526},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F16\u002Fday-16-gaming-in-class-missed-osi-7-layer-model\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":497,"date":498,"description":499,"extension":500,"lang":501,"meta":502,"navigation":503,"path":504,"readingMinutes":346,"seo":505,"standalone":506,"stem":507,"tags":508,"tldr":513,"updated":514,"url":515,"__hash__":516},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 16】因為上課打遊戲，害我沒聽到老師講什麼是 OSI 七層模型.md","【Day 16】因為上課打遊戲，害我沒聽到老師講什麼是 OSI 七層模型","1976446718",{"type":9,"value":10,"toc":489},"minimark",[11,30,37,41,44,47,54,60,63,66,69,72,75,78,81,88,95,101,108,111,115,122,125,131,137,140,147,150,156,159,165,168,174,177,180,183,186,190,193,200,203,253,256,259,265,268,273,276,279,427,430,433,436,439,442,445],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"因為上課打遊戲，害我沒聽到老師講什麼是 OSI 七層模型","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8831%E6%97%A5%20%E4%B8%8B%E5%8D%8809_53_08.png",[38,39,35],"h2",{"id":40},"因為上課打遊戲害我沒聽到老師講什麼是-osi-七層模型",[15,42,43],{},"雖然從小學就開始接觸電腦課，但那時候的我根本把教室電腦當成遊戲機，上課時間幾乎都在玩，真正認真聽課的次數少之又少。一直到國高中，因為要準備升學考試，才不得不乖乖開始聽老師講課。",[15,45,46],{},"「各位同學，今天我們要學一個東西，叫做網路七層架構。」老師在黑板上寫下這幾個字，然後開始講解。",[15,48,49,50,53],{},"通常老師在正式上課之前，會先把全班的電腦「",[18,51,52],{},"控制","」住，把大家的螢幕都同步成一樣的畫面，這樣就沒有人能在上課時偷偷玩遊戲。當時用的軟體就叫做「網路教室」。",[15,55,56],{},[33,57],{"alt":58,"src":59},"網路教室","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F4-70416136-253-pic1.jpg",[15,61,62],{},"講解的過程中，我還記得老師說過一句話：",[15,64,65],{},"「網路七層架構是一個分層式模型，主要用來幫助我們理解網路通訊的過程。」老師邊操控著電腦畫面，邊切換投影片，一邊講解著。",[15,67,68],{},"老師講網路七層架構？抱歉，我只懂「遊戲一層」。",[15,70,71],{},"「ㄟㄟ，XXX 要不要來打信長？」我問著坐在我旁邊的同學。",[15,73,74],{},"「好啊！」同學回答。",[15,76,77],{},"嗯？你是不是很好奇一件事情呢？",[15,79,80],{},"「老師不是已經控制住你們電腦了？怎麼還可以打遊戲？」",[15,82,83,84,87],{},"沒錯，雖然當下確實不能打遊戲，但我後來發現了一個小技巧能擺脫老師的控制──只要直接「",[18,85,86],{},"關機","」，就能把控制權解除，接著就能隨心所欲地做任何事了。",[15,89,90,91,94],{},"小技巧其實很簡單：只要先打開一些會在關機時跳出「",[18,92,93],{},"是否要強制關閉","」視窗的程式，像是 Word、Excel、PowerPoint 都行。",[15,96,97,98,100],{},"當 Windows 執行關機時，系統會嘗試把能關閉的程式都關掉，其中也包含了「",[18,99,58],{},"」。",[15,102,103,104,107],{},"這時候，如果有程式跳出「是否要關閉」的視窗，你只要選「否」，就能成功讓「網路教室」被關掉，同時電腦也不會真的關機。這樣一來，老師的控制就解除了──不過，",[18,105,106],{},"好孩子千萬別學這招唷","！",[15,109,110],{},"那這招真的沒有壞處嗎？當然有。記得有一次老師在課後布置作業，但因為我早就把網路教室關掉，結果完全不知道老師出了什麼作業。畢竟要讓網路教室恢復正常，只能重新啟動電腦才行。",[38,112,114],{"id":113},"osi-七層模型","OSI 七層模型",[15,116,117,118,121],{},"前面我們章節介紹了不少東西，其中包含 Email、即時通以及遊戲等，這些都脫離不了一個核心概念，也就是「",[18,119,120],{},"網路","」，但你有想過一個問題嗎？",[15,123,124],{},"「網路是怎麼運作的呢？」",[15,126,127,128,130],{},"為了幫助大家理解網路的運作與架構，接下來要介紹的是「",[18,129,114],{},"」。別搞錯了，這可不是七龍珠，裡面沒有悟空，只有滿滿的網路協定。",[15,132,133],{},[33,134],{"alt":135,"src":136},"七龍珠（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F161580251493.jpg",[15,138,139],{},"簡單來說，OSI 模型（Open Systems Interconnection Model）就是一個網路通訊的參考架構，它把資料傳輸的過程拆成七層，讓我們更容易理解網路是怎麼運作的，同時也方便不同系統之間能互通、維護。",[15,141,142,143,146],{},"不過要注意，OSI 模型其實是一個 ",[18,144,145],{},"理論模型","，現實中的網路協定（像是 TCP\u002FIP）並不完全依照七層來劃分。但 OSI 模型依然是理解網路運作的重要參考框架，特別是在排查與分析網路問題時，常會用它來當作依據。",[15,148,149],{},"那麼，簡單來講 OSI 模型就是將網路的硬體跟軟體定義成了七層標準：",[15,151,152],{},[33,153],{"alt":154,"src":155},"OSI 七層架構圖","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F202508312022.png",[15,157,158],{},"但我們網路實際使用的是 TCP\u002FIP 則是四層模型，並且是將 OSI 的七層模型進行了合併：",[15,160,161],{},[33,162],{"alt":163,"src":164},"TCP\u002FIP 四層模型","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F202508312040.png",[15,166,167],{},"可是後來又發現，切割成五層架構才比較合理實際狀況：",[15,169,170],{},[33,171],{"alt":172,"src":173},"TCP\u002FIP 五層模型","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F202508312048.png",[15,175,176],{},"「ㄟ...不是，這麼多種模型，所以我們到底要學什麼？」",[15,178,179],{},"你可能會想問：「為什麼不直接講 TCP\u002FIP？」",[15,181,182],{},"其實很簡單，OSI 是理論模型，TCP\u002FIP 則是實際應用。差別在於 OSI 把網路通訊切得更細，所以在分析或排查問題時更好用。也因此，接下來我們會著重介紹 OSI 七層模型。",[15,184,185],{},"首先，OSI 七層模型由 下到上分為 1 到 7 層（實體層 → 應用層），不過我們常常會從第七層（應用層）開始往下解釋，因為它最貼近使用者：",[15,187,188],{},[33,189],{"alt":154,"src":155},[15,191,192],{},"在 OSI 模型中，從第七層往下算到第一層，層級越高就越接近使用者，層級越低則越貼近硬體設備。而每一層都有其特定的功能與責任。為了更好理解，這裡舉一個情境來說明：",[15,194,195,196,199],{},"「小明今天打開 Chrome 瀏覽器，輸入了 ",[23,197,198],{"href":198},"www.google.com","，然後按下 Enter 鍵，接著瀏覽器就會顯示 Google 的首頁。」",[15,201,202],{},"那麼把這個情境套用到 OSI 七層模型中，會是這樣的：",[204,205,206,213,219,229,235,241,247],"ul",{},[207,208,209,212],"li",{},[18,210,211],{},"第七層（應用層）","：小明用 Chrome 瀏覽器，透過 HTTP 協定向 Google 伺服器發出「我要打開 google.com」的請求，這個請求其實就是你輸入的網址。",[207,214,215,218],{},[18,216,217],{},"第六層（表示層）","：瀏覽器把請求資料轉換成電腦能理解的格式，並進行編碼、壓縮或加密處理（例如透過 TLS\u002FSSL 建立 HTTPS 安全連線）。",[207,220,221,224,225,228],{},[18,222,223],{},"第五層（會議層）","：瀏覽器先與 Google 伺服器建立並維持「",[18,226,227],{},"會話連線","」，確保雙方能持續對話。就像先打招呼：「嗨，我是小明，要開始和你溝通了！」",[207,230,231,234],{},[18,232,233],{},"第四層（傳輸層）","：瀏覽器把資料切割成多個小段，交給 TCP 協定處理。TCP 會加上序號並檢查錯誤，確保資料完整送達。即使只是個請求訊息，也要被可靠地傳遞。",[207,236,237,240],{},[18,238,239],{},"第三層（網路層）","：每個資料段會加上 IP 標頭，標明來源 IP（小明的電腦）和目的 IP（Google 伺服器）。網路層會透過路由器決定最佳路徑，把封包送到正確的位置。",[207,242,243,246],{},[18,244,245],{},"第二層（資料鏈路層）","：封包被封裝成 Frame（幀），並加入來源與目的 MAC 位址。這一層負責點對點的傳輸，例如：「小明的電腦 → 家裡 Wi-Fi AP → 路由器」。",[207,248,249,252],{},[18,250,251],{},"第一層（實體層）","：最底層，資料最終轉換成電訊號（電線）、光訊號（光纖）、或無線電波（Wi-Fi），把 0 和 1 真正送出去。",[15,254,255],{},"接著，Google 的伺服器在收到請求後，也會依照相同的七層流程進行處理，最後再把 Google 首頁的資料回傳給小明的瀏覽器，而瀏覽器則會把這些資料組合並呈現在螢幕上。",[15,257,258],{},"接下來說明一下 OSI 在傳輸時的流程：一開始，使用者這邊會從第七層往下處理，一路到第一層，再透過網路把資料傳送到對方伺服器。對方伺服器接收到資料後，則會從第一層往上處理，直到第七層完成。",[15,260,261],{},[33,262],{"alt":263,"src":264},"OSI 流程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F202508312134.png",[15,266,267],{},"那 Google 又是怎麼把資料回傳給小明呢？其實流程完全相同，只是這次是從 Google 伺服器開始，先從第七層往下處理到第一層，再透過網路傳送到小明的電腦。小明的電腦接收到資料後，會從第一層一路往上處理到第七層，最後在瀏覽器中呈現出來。",[15,269,270],{},[33,271],{"alt":263,"src":272},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday16\u002F202508312137.png",[15,274,275],{},"以上就是 OSI 七層模型的完整運作流程。",[15,277,278],{},"最後，我再幫大家整理一下七層模型的層級名稱、功能說明，以及對應的常見協定或應用程式：",[280,281,282,304],"table",{},[283,284,285],"thead",{},[286,287,288,292,295,298,301],"tr",{},[289,290,291],"th",{},"層級",[289,293,294],{},"中文名稱",[289,296,297],{},"英文名稱",[289,299,300],{},"功能說明",[289,302,303],{},"常見協定／應用程式",[305,306,307,325,342,359,376,393,410],"tbody",{},[286,308,309,313,316,319,322],{},[310,311,312],"td",{},"7",[310,314,315],{},"應用層",[310,317,318],{},"Application Layer",[310,320,321],{},"使用者與網路互動的介面，提供應用服務",[310,323,324],{},"HTTP、FTP、SMTP、DNS、Telnet、Web、Email",[286,326,327,330,333,336,339],{},[310,328,329],{},"6",[310,331,332],{},"表示層",[310,334,335],{},"Presentation Layer",[310,337,338],{},"資料格式轉換、編碼解碼、壓縮加密處理",[310,340,341],{},"TLS\u002FSSL、JPEG、MP4、UTF-8、Base64",[286,343,344,347,350,353,356],{},[310,345,346],{},"5",[310,348,349],{},"會議層",[310,351,352],{},"Session Layer",[310,354,355],{},"管理會話連線、控制對話、建立／維持／終止連線",[310,357,358],{},"NetBIOS、RPC、SQL session、WebSocket",[286,360,361,364,367,370,373],{},[310,362,363],{},"4",[310,365,366],{},"傳輸層",[310,368,369],{},"Transport Layer",[310,371,372],{},"分段傳輸、錯誤控制、流量控制、重傳機制",[310,374,375],{},"TCP、UDP、QUIC",[286,377,378,381,384,387,390],{},[310,379,380],{},"3",[310,382,383],{},"網路層",[310,385,386],{},"Network Layer",[310,388,389],{},"路由選擇、IP 位址處理、封包傳輸、跨網段通訊",[310,391,392],{},"IP、ICMP、IGMP、BGP、IPSec",[286,394,395,398,401,404,407],{},[310,396,397],{},"2",[310,399,400],{},"資料連結層層",[310,402,403],{},"Data Link Layer",[310,405,406],{},"封裝資料幀、錯誤偵測、MAC 管理、在同一網段傳輸",[310,408,409],{},"Ethernet、ARP、PPP、Switch、Wi-Fi MAC 層",[286,411,412,415,418,421,424],{},[310,413,414],{},"1",[310,416,417],{},"實體層",[310,419,420],{},"Physical Layer",[310,422,423],{},"實際媒介的傳輸，如電壓、電磁波、光訊號轉換成 0 和 1",[310,425,426],{},"RJ45、光纖、同軸電纜、無線電波、Hub、Repeater",[38,428,429],{"id":429},"結語",[15,431,432],{},"記得我剛出社會去面試時，真的被問到過 OSI 模型，當下我的表情大概就是這樣：",[15,434,435],{},"？＿？",[15,437,438],{},"畢竟這東西已經離我好幾年了，為了面試我還特地翻出以前的筆記，才把 OSI 七層模型重新複習了一遍 XD",[38,440,441],{"id":441},"同步更新",[15,443,444],{},"本文將同步更新至以下網站：",[204,446,447,454,461,468,475,482],{},[207,448,449],{},[23,450,453],{"href":451,"rel":452},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[207,455,456],{},[23,457,460],{"href":458,"rel":459},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[207,462,463],{},[23,464,467],{"href":465,"rel":466},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[207,469,470],{},[23,471,474],{"href":472,"rel":473},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[207,476,477],{},[23,478,481],{"href":479,"rel":480},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[207,483,484],{},[23,485,488],{"href":486,"rel":487},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",{"title":490,"searchDepth":491,"depth":491,"links":492},"",2,[493,494,495,496],{"id":40,"depth":491,"text":35},{"id":113,"depth":491,"text":114},{"id":429,"depth":491,"text":429},{"id":441,"depth":491,"text":441},"學習經驗","2025-09-16 00:00:01","以瀏覽器按下 Enter 為起點，跟著資料從應用層一路往下再回到畫面；過程中把各層功能與常見協定、TCP\u002FIP 對應收進一張清單。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-16-osi",{"title":6,"description":499},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 16】因為上課打遊戲，害我沒聽到老師講什麼是 OSI 七層模型",[509,114,510,511,512],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","網路協定教學","網路原理入門","面試技術題",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250916\u002F1976446718\u002F","p8c2H5N6wP-XJfyqH8eRaAF5sIS3-N-T950OtEuBPnE",{"newer":518,"older":522},{"url":519,"title":520,"date":521},"\u002Flearnexp\u002F20250917\u002F709893047\u002F","【Day 17】比我還單純的語言？電腦的世界只有 0 和 1！","2025-09-17 00:00:01",{"url":523,"title":524,"date":525},"\u002Flearnexp\u002F20250915\u002F525914564\u002F","【Day 15】電腦有夠慢，我不想再重灌了！","2025-09-15 00:00:01",[527,531,535],{"url":528,"title":529,"date":530,"readingMinutes":363},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00",{"url":532,"title":533,"date":534,"readingMinutes":380},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00",{"url":536,"title":537,"date":538,"readingMinutes":329},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",1784012800451]