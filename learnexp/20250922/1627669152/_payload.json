[{"data":1,"prerenderedAt":806},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250922\u002F1627669152\u002F":3,"page:\u002Flearnexp\u002F20250922\u002F1627669152\u002F":4,"alt:\u002Flearnexp\u002F20250922\u002F1627669152\u002F":3,"prev-next:\u002Flearnexp\u002F20250922\u002F1627669152\u002F":781,"related:\u002Flearnexp\u002F20250922\u002F1627669152\u002F":790},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F22\u002Fday-22-pointers-made-me-quit-c\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":760,"date":761,"description":762,"extension":763,"lang":764,"meta":765,"navigation":155,"path":766,"readingMinutes":767,"seo":768,"standalone":769,"stem":770,"tags":771,"tldr":777,"updated":778,"url":779,"__hash__":780},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 22】C 語言直接讓我放棄的記憶體指標.md","【Day 22】C 語言直接讓我放棄的記憶體指標","1627669152",{"type":9,"value":10,"toc":754},"minimark",[11,30,37,41,56,59,62,65,68,74,77,80,83,86,89,92,95,98,101,104,107,110,113,116,119,130,133,198,224,227,244,254,264,267,276,340,342,366,375,434,437,452,457,460,463,470,473,482,485,541,544,558,576,588,638,641,666,680,683,686,689,692,695,698,701,704,750],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"C 語言直接讓我放棄的記憶體指標","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday21\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8809_32_23.png",[38,39,40],"h2",{"id":40},"讓我放棄的記憶體指標",[15,42,43,44,48,49,48,52,55],{},"在學習 C 語言的過程中， ",[45,46,47],"code",{},"if","、",[45,50,51],{},"for",[45,53,54],{},"while"," 這些流程控制語法對我來說不算難，因為曾經寫過遊戲腳本，邏輯其實很接近。原以為自己算是挺聰明的，沒想到一個指標就讓我瞬間從天堂墜落，還沒真正起飛就直接殞落。",[15,57,58],{},"「前面的各種流程判斷，大家應該都沒問題吧？」老師環顧教室，語氣平淡地問。",[15,60,61],{},"教室裡一片寂靜，只有鍵盤敲擊聲零星響起。這種場景在電腦課上很常見，因為大多數人其實都在偷偷打自己的遊戲。",[15,63,64],{},"「期中考的時候，會有幾題是關於指標的題目喔！」老師接著補了一句。",[15,66,67],{},"「蛤？？？」我心裡只冒出這一個字，毫無懸念。",[15,69,70],{},[33,71],{"alt":72,"src":73},"蛤（圖源 tenor）","https:\u002F\u002Fmedia.tenor.com\u002FyMQCwh-hwwkAAAAM\u002F%E8%9B%A4.gif",[15,75,76],{},"「說明指標之前，我們先來複習一下上週的變數內容，因為變數和指標有一定的關聯……」老師站在講台上開始解說。",[15,78,79],{},"聽到「期中考會考指標」這句話，我整個人瞬間慌了，心裡只冒出一句：",[15,81,82],{},"「糟了，這下電腦課會不會被當啊？」",[15,84,85],{},"我完全搞不懂指標到底是什麼，只好偷偷戳一下旁邊那個跟我一起打《魔獸爭霸》的同學。",[15,87,88],{},"他頭也不抬，還在操作英雄放技能，淡淡回一句：「怕屁，不會啦，繼續打《信長》啦！」",[15,90,91],{},"我愣了三秒，覺得這傢伙比城牆還穩。",[15,93,94],{},"結果……我就真的放下焦慮，繼續操滑鼠跟著衝鋒陷陣，彷彿期中考根本不存在。",[15,96,97],{},"但你各位知道嗎？",[15,99,100],{},"讀書時期總有一種人特別討厭 —— 每次都嘴上說不會讀、不會看，結果一到考試就穩穩拿下班上前三名。",[15,102,103],{},"同學（攤手）：「啊～這次我都沒看啦，一定會考爛。」\n我（心想）：「呵，這次總算有機會贏他了！」",[15,105,106],{},"考卷發下來 ——\n同學：✨滿分✨\n我：……",[15,108,109],{},"老師（盯著我）：「你，下課後記得來補考。」\n我：Σ(°△°|||)",[15,111,112],{},"同學：😎「早就說不會啊。」\n我：Orz",[38,114,115],{"id":115},"記憶體指標與位址",[15,117,118],{},"在電腦世界中，不管你宣告的是函式、變數，還是陣列，它們最後都會被存放在記憶體裡，而每一個存放的位置都有一個唯一的「位址」，C 語言中的指標，正是用來存取和操作這些位址的工具。",[15,120,121,122,125,126,129],{},"那麼，該怎麼查看變數的位址呢？其實非常簡單 —— 只要在變數前加上 ",[45,123,124],{},"&"," 符號即可，這個稱之為",[18,127,128],{},"取址運算子（Address-of Operator）","，透過它，我們就能直接取得變數在記憶體中的位址。",[15,131,132],{},"底下就讓我們看一個非常簡單的範例，來認識一下指標的基本概念：",[134,135,140],"pre",{"className":136,"code":137,"language":138,"meta":139,"style":139},"language-c shiki shiki-themes github-dark-high-contrast","#include \u003Cstdio.h>\n\nint main(void) {\n    int a = 10; \u002F\u002F 宣告一個整數變數 a 並賦值為 10\n\n    printf(\"a 的值是: %d\\n\", a); \u002F\u002F 輸出 a 的值\n    printf(\"a 的位址是: %p\\n\", &a); \u002F\u002F 輸出 a 的位址\n    return 0;\n}\n","c","",[45,141,142,150,157,163,169,174,180,186,192],{"__ignoreMap":139},[143,144,147],"span",{"class":145,"line":146},"line",1,[143,148,149],{},"#include \u003Cstdio.h>\n",[143,151,153],{"class":145,"line":152},2,[143,154,156],{"emptyLinePlaceholder":155},true,"\n",[143,158,160],{"class":145,"line":159},3,[143,161,162],{},"int main(void) {\n",[143,164,166],{"class":145,"line":165},4,[143,167,168],{},"    int a = 10; \u002F\u002F 宣告一個整數變數 a 並賦值為 10\n",[143,170,172],{"class":145,"line":171},5,[143,173,156],{"emptyLinePlaceholder":155},[143,175,177],{"class":145,"line":176},6,[143,178,179],{},"    printf(\"a 的值是: %d\\n\", a); \u002F\u002F 輸出 a 的值\n",[143,181,183],{"class":145,"line":182},7,[143,184,185],{},"    printf(\"a 的位址是: %p\\n\", &a); \u002F\u002F 輸出 a 的位址\n",[143,187,189],{"class":145,"line":188},8,[143,190,191],{},"    return 0;\n",[143,193,195],{"class":145,"line":194},9,[143,196,197],{},"}\n",[12,199,200],{},[15,201,202,205,208,209,212,213,216,219,220,223],{},[18,203,204],{},"Note",[45,206,207],{},"%p"," 用來印出記憶體位址，通常會顯示成十六進位數字。",[210,211],"br",{},"\n最嚴謹的寫法是 ",[45,214,215],{},"(void*)&a",[45,217,218],{},"printf(\"a 的位址是: %p\\n\", (void*)&a);","\n不過大部分情況下 ",[45,221,222],{},"&a"," 也能正常印出。",[15,225,226],{},"執行之後，你可能會看到以下訊息：",[134,228,232],{"className":229,"code":230,"language":231,"meta":139,"style":139},"language-plaintext shiki shiki-themes github-dark-high-contrast","a 的值是: 10\na 的位址是: 0x16dd6eac8\n","plaintext",[45,233,234,239],{"__ignoreMap":139},[143,235,236],{"class":145,"line":146},[143,237,238],{},"a 的值是: 10\n",[143,240,241],{"class":145,"line":152},[143,242,243],{},"a 的位址是: 0x16dd6eac8\n",[15,245,246,247,250,251,253],{},"這裡的 ",[45,248,249],{},"0x16dd6eac8"," 就是變數 ",[45,252,23],{}," 在記憶體中的位址，順帶一提，你看到的位址不一定跟我一樣，因為每次程式跑的時候，記憶體分配都可能不一樣喔！",[15,255,256,257,259,260,263],{},"對前面讀過二進位或十六進位的朋友來說， ",[45,258,249],{}," 應該不陌生，需要注意的是，這並不是說記憶體真的用十六進位存，而是因為",[18,261,262],{},"位址本質上是一個數字","，只是用十六進位表示會比較精簡，因此通常會以十六進位來顯示。",[15,265,266],{},"那麼為什麼要理解指標呢？",[15,268,269,270,272,273,275],{},"因為指標可以讓我們直接操作記憶體中的位址，舉例來講，我們可以將 ",[45,271,23],{}," 的位址存放到一個指標變數中，這樣我們就可以透過這個指標來存取 ",[45,274,23],{}," 的值。",[134,277,279],{"className":136,"code":278,"language":138,"meta":139,"style":139},"#include \u003Cstdio.h>\n\nint main(void) {\n    int a = 10; \u002F\u002F 宣告一個整數變數 a 並賦值為 10\n    int *p = &a; \u002F\u002F 宣告一個指標變數 p，並將 a 的位址存放到 p 中\n\n    printf(\"a 的值是: %d\\n\", a); \u002F\u002F 輸出 a 的值\n    printf(\"a 的位址是: %p\\n\", &a); \u002F\u002F 輸出 a 的位址\n    printf(\"p 指向的位址是: %p\\n\", p); \u002F\u002F 輸出 p 指向的位址\n    printf(\"p 指向的值是: %d\\n\", *p); \u002F\u002F 使用解引用運算子 (*) 取得 p 指向的值\n\n    return 0;\n}\n",[45,280,281,285,289,293,297,302,306,310,314,319,325,330,335],{"__ignoreMap":139},[143,282,283],{"class":145,"line":146},[143,284,149],{},[143,286,287],{"class":145,"line":152},[143,288,156],{"emptyLinePlaceholder":155},[143,290,291],{"class":145,"line":159},[143,292,162],{},[143,294,295],{"class":145,"line":165},[143,296,168],{},[143,298,299],{"class":145,"line":171},[143,300,301],{},"    int *p = &a; \u002F\u002F 宣告一個指標變數 p，並將 a 的位址存放到 p 中\n",[143,303,304],{"class":145,"line":176},[143,305,156],{"emptyLinePlaceholder":155},[143,307,308],{"class":145,"line":182},[143,309,179],{},[143,311,312],{"class":145,"line":188},[143,313,185],{},[143,315,316],{"class":145,"line":194},[143,317,318],{},"    printf(\"p 指向的位址是: %p\\n\", p); \u002F\u002F 輸出 p 指向的位址\n",[143,320,322],{"class":145,"line":321},10,[143,323,324],{},"    printf(\"p 指向的值是: %d\\n\", *p); \u002F\u002F 使用解引用運算子 (*) 取得 p 指向的值\n",[143,326,328],{"class":145,"line":327},11,[143,329,156],{"emptyLinePlaceholder":155},[143,331,333],{"class":145,"line":332},12,[143,334,191],{},[143,336,338],{"class":145,"line":337},13,[143,339,197],{},[15,341,226],{},[134,343,345],{"className":229,"code":344,"language":231,"meta":139,"style":139},"a 的值是: 10\na 的位址是: 0x16f0c6ac8\np 指向的位址是: 0x16f0c6ac8\np 指向的值是: 10\n",[45,346,347,351,356,361],{"__ignoreMap":139},[143,348,349],{"class":145,"line":146},[143,350,238],{},[143,352,353],{"class":145,"line":152},[143,354,355],{},"a 的位址是: 0x16f0c6ac8\n",[143,357,358],{"class":145,"line":159},[143,359,360],{},"p 指向的位址是: 0x16f0c6ac8\n",[143,362,363],{"class":145,"line":165},[143,364,365],{},"p 指向的值是: 10\n",[15,367,368,369,371,372,374],{},"這代表什麼意思呢？我們可以直接修改 ",[45,370,15],{}," 指向的值，這樣就可以間接地修改 ",[45,373,23],{}," 的值：",[134,376,378],{"className":136,"code":377,"language":138,"meta":139,"style":139},"#include \u003Cstdio.h>\n\nint main(void) {\n    int a = 10; \u002F\u002F 宣告一個整數變數 a 並賦值為 10\n    int *p = &a; \u002F\u002F 宣告一個指標變數 p，並將 a 的位址存放到 p 中\n\n    printf(\"修改前 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改前 a 的值\n    *p = 20; \u002F\u002F 使用解引用運算子修改 p 指向的值\n    printf(\"修改後 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改後 a 的值\n\n    return 0;\n}\n",[45,379,380,384,388,392,396,400,404,409,417,422,426,430],{"__ignoreMap":139},[143,381,382],{"class":145,"line":146},[143,383,149],{},[143,385,386],{"class":145,"line":152},[143,387,156],{"emptyLinePlaceholder":155},[143,389,390],{"class":145,"line":159},[143,391,162],{},[143,393,394],{"class":145,"line":165},[143,395,168],{},[143,397,398],{"class":145,"line":171},[143,399,301],{},[143,401,402],{"class":145,"line":176},[143,403,156],{"emptyLinePlaceholder":155},[143,405,406],{"class":145,"line":182},[143,407,408],{},"    printf(\"修改前 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改前 a 的值\n",[143,410,411,414],{"class":145,"line":188},[143,412,413],{},"    *p = 20;",[143,415,416],{}," \u002F\u002F 使用解引用運算子修改 p 指向的值\n",[143,418,419],{"class":145,"line":194},[143,420,421],{},"    printf(\"修改後 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改後 a 的值\n",[143,423,424],{"class":145,"line":321},[143,425,156],{"emptyLinePlaceholder":155},[143,427,428],{"class":145,"line":327},[143,429,191],{},[143,431,432],{"class":145,"line":332},[143,433,197],{},[15,435,436],{},"接著執行之後，你就會看到以下訊息：",[134,438,440],{"className":229,"code":439,"language":231,"meta":139,"style":139},"修改前 a 的值是: 10\n修改後 a 的值是: 20\n",[45,441,442,447],{"__ignoreMap":139},[143,443,444],{"class":145,"line":146},[143,445,446],{},"修改前 a 的值是: 10\n",[143,448,449],{"class":145,"line":152},[143,450,451],{},"修改後 a 的值是: 20\n",[15,453,454,455,275],{},"這樣我們就成功地透過指標修改了 ",[45,456,23],{},[15,458,459],{},"如果你是 JavaScript 開發者，應該會覺得「欸，這不就跟物件、陣列的參考差不多嗎？」沒錯，概念上有點像。",[15,461,462],{},"差別在於 —— JS 的參考就像小朋友用安全剪刀，最多剪不直；但 C 的指標是直接給你一把武士刀，你一不小心就可能把程式砍爆，所以阿，指標很強大，但用起來真的要非常小心。",[15,464,465,466,469],{},"這裡要特別注意一點，在 C 語言中，如果要作為指標使用，必須要先宣告一個指標變數，並且使用 ",[45,467,468],{},"*"," 符號來表示這是一個指標類型的變數，這也是前面尚未提到的重要部分。",[15,471,472],{},"接著你可能會好奇：",[15,474,475,476,478,479,481],{},"「如果我沒有使用 ",[45,477,468],{}," 與 ",[45,480,124],{}," 符號，會發生什麼事情呢？」",[15,483,484],{},"很好的問題，我們不如來實驗看看比較快：",[134,486,488],{"className":136,"code":487,"language":138,"meta":139,"style":139},"#include \u003Cstdio.h>\n\nint main(void) {\n    int a = 10; \u002F\u002F 宣告一個整數變數 a 並賦值為 10\n    int p = a; \u002F\u002F 宣告一個整數變數 p，並將 a 的值賦給 p\n\n     printf(\"修改前 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改前 a 的值\n    p = 20; \u002F\u002F 嘗試修改 p 的值\n    printf(\"修改後 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改後 a 的值\n\n    return 0;\n}\n",[45,489,490,494,498,502,506,511,515,520,525,529,533,537],{"__ignoreMap":139},[143,491,492],{"class":145,"line":146},[143,493,149],{},[143,495,496],{"class":145,"line":152},[143,497,156],{"emptyLinePlaceholder":155},[143,499,500],{"class":145,"line":159},[143,501,162],{},[143,503,504],{"class":145,"line":165},[143,505,168],{},[143,507,508],{"class":145,"line":171},[143,509,510],{},"    int p = a; \u002F\u002F 宣告一個整數變數 p，並將 a 的值賦給 p\n",[143,512,513],{"class":145,"line":176},[143,514,156],{"emptyLinePlaceholder":155},[143,516,517],{"class":145,"line":182},[143,518,519],{},"     printf(\"修改前 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改前 a 的值\n",[143,521,522],{"class":145,"line":188},[143,523,524],{},"    p = 20; \u002F\u002F 嘗試修改 p 的值\n",[143,526,527],{"class":145,"line":194},[143,528,421],{},[143,530,531],{"class":145,"line":321},[143,532,156],{"emptyLinePlaceholder":155},[143,534,535],{"class":145,"line":327},[143,536,191],{},[143,538,539],{"class":145,"line":332},[143,540,197],{},[15,542,543],{},"基本上你會看到以下訊息：",[134,545,547],{"className":229,"code":546,"language":231,"meta":139,"style":139},"修改前 a 的值是: 10\n修改後 a 的值是: 10\n",[45,548,549,553],{"__ignoreMap":139},[143,550,551],{"class":145,"line":146},[143,552,446],{},[143,554,555],{"class":145,"line":152},[143,556,557],{},"修改後 a 的值是: 10\n",[15,559,560,561,563,564,567,568,570,571,573,574,275],{},"因為我們是將 ",[45,562,23],{}," 的值也就是 ",[45,565,566],{},"10"," 賦值給 ",[45,569,15],{},"，所以當我們修改 ",[45,572,15],{}," 的值時，並不會影響到 ",[45,575,23],{},[15,577,578,579,581,582,584,585,587],{},"那如果將 ",[45,580,23],{}," 的位址賦值給 ",[45,583,15],{},"，然後再修改 ",[45,586,15],{}," 的值，會發生什麼事情呢？我們來試試看：",[134,589,591],{"className":136,"code":590,"language":138,"meta":139,"style":139},"#include \u003Cstdio.h>\n\nint main(void) {\n    int a = 10; \u002F\u002F 宣告一個整數變數 a 並賦值為 10\n    int p = &a; \u002F\u002F 宣告一個整數變數 p，並將 a 的位址賦給 p\n\n    printf(\"修改前 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改前 a 的值\n    p = 20; \u002F\u002F 嘗試修改 p 的值\n    printf(\"修改後 a 的值是: %d\\n\", a); \u002F\u002F 輸出修改後 a 的值\n    return 0;\n}\n",[45,592,593,597,601,605,609,614,618,622,626,630,634],{"__ignoreMap":139},[143,594,595],{"class":145,"line":146},[143,596,149],{},[143,598,599],{"class":145,"line":152},[143,600,156],{"emptyLinePlaceholder":155},[143,602,603],{"class":145,"line":159},[143,604,162],{},[143,606,607],{"class":145,"line":165},[143,608,168],{},[143,610,611],{"class":145,"line":171},[143,612,613],{},"    int p = &a; \u002F\u002F 宣告一個整數變數 p，並將 a 的位址賦給 p\n",[143,615,616],{"class":145,"line":176},[143,617,156],{"emptyLinePlaceholder":155},[143,619,620],{"class":145,"line":182},[143,621,408],{},[143,623,624],{"class":145,"line":188},[143,625,524],{},[143,627,628],{"class":145,"line":194},[143,629,421],{},[143,631,632],{"class":145,"line":321},[143,633,191],{},[143,635,636],{"class":145,"line":327},[143,637,197],{},[15,639,640],{},"不出意外的話，現在就會看到錯誤訊息了：",[134,642,644],{"className":229,"code":643,"language":231,"meta":139,"style":139},"main.c:4:9: error: incompatible pointer to integer conversion initializing 'int' with an expression of type 'int *'; remove & [-Wint-conversion]\n    4 |     int p = &a; \u002F\u002F 宣告一個整數變數 p，並將 a 的位址賦給 p\n      |         ^   ~~\n1 error generated.\n",[45,645,646,651,656,661],{"__ignoreMap":139},[143,647,648],{"class":145,"line":146},[143,649,650],{},"main.c:4:9: error: incompatible pointer to integer conversion initializing 'int' with an expression of type 'int *'; remove & [-Wint-conversion]\n",[143,652,653],{"class":145,"line":152},[143,654,655],{},"    4 |     int p = &a; \u002F\u002F 宣告一個整數變數 p，並將 a 的位址賦給 p\n",[143,657,658],{"class":145,"line":159},[143,659,660],{},"      |         ^   ~~\n",[143,662,663],{"class":145,"line":165},[143,664,665],{},"1 error generated.\n",[15,667,668,669,672,673,675,676,679],{},"這是因為位址必須要使用指標類型的變數來存放，而我們在這裡使用了 ",[45,670,671],{},"int"," 類型的變數 ",[45,674,15],{},"，因為指標是一種特殊的型別，不同於整數，所以必須用 ",[45,677,678],{},"int *p"," 來宣告。",[15,681,682],{},"是不是感覺滿有趣的（並沒有）？",[15,684,685],{},"指標對我來說，就像 C 語言裡的 Final Boss。\n問題是……我還沒練滿等級，連裝備都沒齊，就直接衝進去挑戰，結果當然是被一招秒殺。\n那一刻我只能心裡默念：「Game Over… QQ」",[15,687,688],{},"由此可知，沒天分沒關係，上課還是要認真聽課，打不贏魔王沒差，至少別被路邊的史萊姆打爆。",[38,690,691],{"id":691},"結語",[15,693,694],{},"不知道大家以前在學時期有沒有那種不讀書也能考高分的同學？",[15,696,697],{},"還是說你就是那個同學呢？",[38,699,700],{"id":700},"同步更新",[15,702,703],{},"本文將同步更新至以下網站：",[705,706,707,715,722,729,736,743],"ul",{},[708,709,710],"li",{},[23,711,714],{"href":712,"rel":713},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[708,716,717],{},[23,718,721],{"href":719,"rel":720},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[708,723,724],{},[23,725,728],{"href":726,"rel":727},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[708,730,731],{},[23,732,735],{