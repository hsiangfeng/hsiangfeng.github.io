[{"data":1,"prerenderedAt":764},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250924\u002F2137873228\u002F":3,"page:\u002Flearnexp\u002F20250924\u002F2137873228\u002F":4,"alt:\u002Flearnexp\u002F20250924\u002F2137873228\u002F":3,"prev-next:\u002Flearnexp\u002F20250924\u002F2137873228\u002F":739,"related:\u002Flearnexp\u002F20250924\u002F2137873228\u002F":748},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F24\u002Fday-24-security-offense-and-defense\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":718,"date":719,"description":720,"extension":721,"lang":722,"meta":723,"navigation":387,"path":724,"readingMinutes":725,"seo":726,"standalone":727,"stem":728,"tags":729,"tldr":735,"updated":736,"url":737,"__hash__":738},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 24】資安攻防戰.md","【Day 24】資安攻防戰","2137873228",{"type":9,"value":10,"toc":712},"minimark",[11,30,37,40,43,46,49,52,55,58,61,64,67,70,73,76,79,82,104,107,114,117,120,130,137,150,153,156,159,162,176,179,182,189,192,195,495,498,561,574,581,628,631,634,637,640,643,646,649,652,655,658,661,664,708],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"資安攻防戰","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday24\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8809_57_09.png",[38,39,35],"h2",{"id":35},[15,41,42],{},"因為大學專題的關係，我選擇了 PHP 作為開發語言。不過那時候環境還不成熟，PHP 從 4.x 正要升級到 5.x，沒有 Framework 可用，整個開發過程幾乎是土法煉鋼，非常辛苦。",[15,44,45],{},"「Ray，你的 PHP 有做資安防禦嗎？」老師在我製作專題的過程中，問了我這個問題。",[15,47,48],{},"老實說，那時候我完全沒想到這件事。可老師既然特別強調，顯然代表這點非常重要。於是我開始在心裡猜測：到底是哪裡需要特別注意？",[15,50,51],{},"就在我還在思索的瞬間，老師的下一句話，直接打斷了我的思考——",[15,53,54],{},"「到時候發表時，你們會先把作品交給系主任和其他老師試用，但記得不要提供後台，發表時由你們自己操作就好，這樣才能避免被其他老師亂搞。」老師叮嚀著說。",[15,56,57],{},"ㄟ…原來老師這樣提醒不是沒道理的。\n說穿了，專題不只學生在拚，老師之間其實也在暗暗較勁，畢竟誰不想自己的學生做出最亮眼的成果？所以偶爾就會出現一些小心機、小競爭。",[15,59,60],{},"我心裡只能默默想：\n「哇，原來專題戰場不只在學生之間，老師們背後也有小劇場啊 XD」",[15,62,63],{},"一路從跌跌撞撞到最後的專題發表，過程雖然辛苦，但也因為老師對細節的嚴格把關，從簡報內容到報告方式都幫我們拉了一把，結果發表會當天一切都非常順利，不只拿到系上老師們的讚賞，最後作品甚至被選為招生範例。",[15,65,66],{},"對我們這組來說，這完全是一場漂亮的逆轉勝。",[15,68,69],{},"專題發表的時候看起來風光順利，但等我後來仔細研究資安防禦，回頭檢視我們的系統時才發現 ——那根本不是作品，是一塊蜂巢，滿滿都是洞啊 XD",[15,71,72],{},"至於後來我們的專題系統嘛……直接被我玩到壞掉，結局比發表會還要精彩。XD",[38,74,75],{"id":75},"資安防禦的基本概念",[15,77,78],{},"那麼資安防禦到底在講什麼呢？簡單來講就是不被駭客入侵，或者是防止駭客入侵後造成的損害。",[15,80,81],{},"有些人可能不太懂什麼是駭客以及駭客其實有區分為三大類：",[83,84,85,92,98],"ul",{},[86,87,88,91],"li",{},[18,89,90],{},"白帽駭客："," 這類駭客是為了保護系統而存在的，他們會找出系統的漏洞並且通知系統管理員修補漏洞，又稱道德駭客。",[86,93,94,97],{},[18,95,96],{},"黑帽駭客："," 主要是以自己利益為優先，利用系統的漏洞來獲取非法利益。",[86,99,100,103],{},[18,101,102],{},"灰帽駭客："," 這類駭客介於白帽與黑帽之間。",[15,105,106],{},"其中我們最不希望遇到的就是黑帽駭客。",[15,108,109,110,113],{},"早些年有一場非常知名的黑帽駭客事件 —— ",[18,111,112],{},"「WannaCry（中文：想哭、想解密）」"," 那次攻擊讓許多企業與個人都蒙受巨大損失。",[15,115,116],{},"前面章節中我們提到過，中毒本身就是件麻煩的事，更何況有些病毒並不是單純重新安裝作業系統就能解決。因為它們可能早已潛伏在你的檔案或備份裡，所以即使重灌系統，依然會再次被感染。",[15,118,119],{},"這邊也簡單講一下當年的令人聞風喪膽的 WannaCry 病毒。",[15,121,122,125,126,129],{},[18,123,124],{},"WannaCry"," 是一種利用 ",[18,127,128],{},"Microsoft Windows"," 系統漏洞的勒索病毒，當電腦遭到感染時，它會立即加密你的檔案，接著要求你支付比特幣才能解鎖。",[15,131,132,133,136],{},"它採用了 ",[18,134,135],{},"非對稱加密"," 的方式，這種加密的特點是使用一組金鑰：公開金鑰與私密金鑰。公開金鑰負責加密資料，而只有私密金鑰才能解密，也就是說，如果你不按照駭客的指示支付贖金，就無法拿到解密所需的私密金鑰，你的檔案也就等於被永久鎖死。",[12,138,139],{},[15,140,141,144,145],{},[18,142,143],{},"Note","\n如果想多了解加密的議題，可以參考我之前寫的文章：",[23,146,149],{"href":147,"rel":148},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20231022\u002F2787463355\u002F",[27],"加密是什麼呢？為什麼要加密？關於加密的基本觀念",[15,151,152],{},"你可能會想：「那我只要定期備份就好了吧？」\n沒錯，定期備份是一個手段，但問題在於 —— 如果連備份也被感染了，那麼當你還原時，病毒也會一併回來。",[15,154,155],{},"老實說，我早期也曾中過一次毒，當時用雲端硬碟備份檔案，但因為沒有回溯功能，連備份也被感染，幸好資料不重要，我只好直接放棄，畢竟照當時的 Bitcoin 價格來算，贖金得要好幾萬台幣。",[15,157,158],{},"這也是為什麼大家都強調：只要出現重大資安漏洞，就一定要立刻更新系統。因為如果不更新，就等於把大門敞開，讓駭客隨時能進來。",[15,160,161],{},"通常來講備份方式會有兩種：",[83,163,164,170],{},[86,165,166,169],{},[18,167,168],{},"本地備份","：簡單來講就是將自己電腦的重要資料拷貝一份到其他儲存裝置上，例如：外接硬碟、USB 隨身碟等。",[86,171,172,175],{},[18,173,174],{},"異地備份","：將資料備份到其他地方，例如：雲端儲存服務、遠端伺服器等。",[15,177,178],{},"這兩種備份方式各有優缺點，本地備份的優點是速度快、成本低，但是如果你的電腦被入侵了，那麼本地備份也會被感染；異地備份的優點是可以避免本地備份被感染，但是速度較慢、成本較高。",[15,180,181],{},"上面我們所講的比較偏向個人電腦的資安防禦，但如果今天我們是寫程式呢？那麼要考慮的方向就不同了。",[15,183,184,185,188],{},"這邊要來提一個很常見的攻擊手法，也就是 ",[18,186,187],{},"SQL Injection（SQL 注入攻擊）","，這種攻擊是利用程式在處理 SQL 語句時，沒有對使用者輸入進行適當過濾或轉義，讓攻擊者有機會注入惡意的 SQL 指令，進而操控資料庫。",[15,190,191],{},"在當時 ORM（俗稱：物件關聯對映）還不流行，大家幾乎都是直接用 SQL 語句操作資料庫，所以 SQL 注入攻擊 變得特別常見。",[15,193,194],{},"這邊舉例一下前一篇章節所介紹的 PHP 程式碼：",[196,197,202],"pre",{"className":198,"code":199,"language":200,"meta":201,"style":201},"language-php shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>第一個 PHP 程式\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003C?php\n      $username = \"admin\";\n      $password = \"password123\";\n\n      $connection = mysqli_connect(\"localhost\", $username, $password);\n      if ($connection) {\n          echo \"\u003Cdiv>成功連接到 MySQL 資料庫！\u003C\u002Fdiv>\";\n      } else {\n          echo \"\u003Cdiv>無法連接到 MySQL 資料庫！\u003C\u002Fdiv>\";\n      }\n\n      mysqli_close($connection);\n  ?>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","php","",[203,204,205,224,245,255,274,299,326,335,345,354,369,382,389,409,418,429,441,451,457,462,471,477,486],"code",{"__ignoreMap":201},[206,207,210,214,218,221],"span",{"class":208,"line":209},"line",1,[206,211,213],{"class":212},"sWyjQ","\u003C!",[206,215,217],{"class":216},"sCcAr","DOCTYPE",[206,219,220],{"class":216}," html",[206,222,223],{"class":212},">\n",[206,225,227,230,233,236,239,243],{"class":208,"line":226},2,[206,228,229],{"class":212},"\u003C",[206,231,232],{"class":216},"html",[206,234,235],{"class":216}," lang",[206,237,238],{"class":212},"=",[206,240,242],{"class":241},"sTRMh","\"zh-Hant-TW\"",[206,244,223],{"class":212},[206,246,248,250,253],{"class":208,"line":247},3,[206,249,229],{"class":212},[206,251,252],{"class":216},"head",[206,254,223],{"class":212},[206,256,258,261,264,267,269,272],{"class":208,"line":257},4,[206,259,260],{"class":212},"  \u003C",[206,262,263],{"class":216},"meta",[206,265,266],{"class":216}," charset",[206,268,238],{"class":212},[206,270,271],{"class":241},"\"UTF-8\"",[206,273,223],{"class":212},[206,275,277,279,281,284,286,289,292,294,297],{"class":208,"line":276},5,[206,278,260],{"class":212},[206,280,263],{"class":216},[206,282,283],{"class":216}," name",[206,285,238],{"class":212},[206,287,288],{"class":241},"\"viewport\"",[206,290,291],{"class":216}," content",[206,293,238],{"class":212},[206,295,296],{"class":241},"\"width=device-width, initial-scale=1.0\"",[206,298,223],{"class":212},[206,300,302,304,307,310,313,316,319,322,324],{"class":208,"line":301},6,[206,303,260],{"class":212},[206,305,306],{"class":216},"title",[206,308,309],{"class":212},">",[206,311,312],{"class":216},"第一個",[206,314,315],{"class":216}," PHP",[206,317,318],{"class":216}," 程式",[206,320,321],{"class":212},"\u003C\u002F",[206,323,306],{"class":216},[206,325,223],{"class":212},[206,327,329,331,333],{"class":208,"line":328},7,[206,330,321],{"class":212},[206,332,252],{"class":216},[206,334,223],{"class":212},[206,336,338,340,343],{"class":208,"line":337},8,[206,339,229],{"class":212},[206,341,342],{"class":216},"body",[206,344,223],{"class":212},[206,346,348,351],{"class":208,"line":347},9,[206,349,350],{"class":212},"  \u003C?",[206,352,353],{"class":216},"php\n",[206,355,357,361,363,366],{"class":208,"line":356},10,[206,358,360],{"class":359},"sMAXC","      $username ",[206,362,238],{"class":212},[206,364,365],{"class":241}," \"admin\"",[206,367,368],{"class":359},";\n",[206,370,372,375,377,380],{"class":208,"line":371},11,[206,373,374],{"class":359},"      $password ",[206,376,238],{"class":212},[206,378,379],{"class":241}," \"password123\"",[206,381,368],{"class":359},[206,383,385],{"class":208,"line":384},12,[206,386,388],{"emptyLinePlaceholder":387},true,"\n",[206,390,392,395,397,400,403,406],{"class":208,"line":391},13,[206,393,394],{"class":359},"      $connection ",[206,396,238],{"class":212},[206,398,399],{"class":216}," mysqli_connect",[206,401,402],{"class":359},"(",[206,404,405],{"class":241},"\"localhost\"",[206,407,408],{"class":359},", $username, $password);\n",[206,410,412,415],{"class":208,"line":411},14,[206,413,414],{"class":212},"      if",[206,416,417],{"class":359}," ($connection) {\n",[206,419,421,424,427],{"class":208,"line":420},15,[206,422,423],{"class":216},"          echo",[206,425,426],{"class":241}," \"\u003Cdiv>成功連接到 MySQL 資料庫！\u003C\u002Fdiv>\"",[206,428,368],{"class":359},[206,430,432,435,438],{"class":208,"line":431},16,[206,433,434],{"class":359},"      } ",[206,436,437],{"class":212},"else",[206,439,440],{"class":359}," {\n",[206,442,444,446,449],{"class":208,"line":443},17,[206,445,423],{"class":216},[206,447,448],{"class":241}," \"\u003Cdiv>無法連接到 MySQL 資料庫！\u003C\u002Fdiv>\"",[206,450,368],{"class":359},[206,452,454],{"class":208,"line":453},18,[206,455,456],{"class":359},"      }\n",[206,458,460],{"class":208,"line":459},19,[206,461,388],{"emptyLinePlaceholder":387},[206,463,465,468],{"class":208,"line":464},20,[206,466,467],{"class":216},"      mysqli_close",[206,469,470],{"class":359},"($connection);\n",[206,472,474],{"class":208,"line":473},21,[206,475,476],{"class":212},"  ?>\n",[206,478,480,482,484],{"class":208,"line":479},22,[206,481,321],{"class":212},[206,483,342],{"class":216},[206,485,223],{"class":212},[206,487,489,491,493],{"class":208,"line":488},23,[206,490,321],{"class":212},[206,492,232],{"class":216},[206,494,223],{"class":212},[15,496,497],{},"一般情況下，使用者會在畫面上輸入帳號和密碼，程式再把這些資料傳送到資料庫做驗證，這時候就會用到 SQL 語句來進行資料庫操作，例如：",[196,499,501],{"className":198,"code":500,"language":200,"meta":201,"style":201},"$sql = \"SELECT * FROM users WHERE username = '$username' AND password = '$password'\";\n",[203,502,503],{"__ignoreMap":201},[206,504,505,508,510,513,516,519,522,525,528,531,533,536,539,542,545,548,551,553,556,559],{"class":208,"line":209},[206,506,507],{"class":359},"$sql ",[206,509,238],{"class":212},[206,511,512],{"class":241}," \"",[206,514,515],{"class":212},"SELECT",[206,517,518],{"class":212}," *",[206,520,521],{"class":212}," FROM",[206,523,524],{"class":241}," users ",[206,526,527],{"class":212},"WHERE",[206,529,530],{"class":241}," username ",[206,532,238],{"class":212},[206,534,535],{"class":241}," '",[206,537,538],{"class":359},"$username",[206,540,541],{"class":241},"' ",[206,543,544],{"class":212},"AND",[206,546,547],{"class":212}," password",[206,549,550],{"class":212}," =",[206,552,535],{"class":241},[206,554,555],{"class":359},"$password",[206,557,558],{"class":241},"'\"",[206,560,368],{"class":359},[15,562,563,564,567,568,570,571,573],{},"這段程式碼的意思是：從 ",[203,565,566],{},"users"," 資料表中，找出使用者名稱等於 ",[203,569,538],{}," 、密碼等於 ",[203,572,555],{}," 的資料，如果找到符合條件的紀錄，就代表使用者輸入的帳號與密碼正確。",[15,575,576,577,580],{},"但如果今天使用者輸入的是 ",[203,578,579],{},"$username = \"admin' OR '1'='1\""," 呢？那就會變成以下的 SQL 語句：",[196,582,586],{"className":583,"code":584,"language":585,"meta":201,"style":201},"language-sql shiki shiki-themes github-dark-high-contrast","SELECT * FROM users WHERE username = 'admin' OR '1'='1' AND password = '$password'\n","sql",[203,587,588],{"__ignoreMap":201},[206,589,590,592,594,596,598,600,602,604,607,610,613,615,618,621,623,625],{"class":208,"line":209},[206,591,515],{"class":212},[206,593,518],{"class":212},[206,595,521],{"class":212},[206,597,524],{"class":359},[206,599,527],{"class":212},[206,601,530],{"class":359},[206,603,238],{"class":212},[206,605,606],{"class":241}," 'admin'",[206,608,609],{"class":212}," OR",[206,611,612],{"class":241}," '1'",[206,614,238],{"class":212},[206,616,617],{"class":241},"'1'",[206,619,620],{"class":212}," AND",[206,622,547],{"class":212},[206,624,550],{"class":212},[206,626,627],{"class":241}," '$password'\n",[15,629,630],{},"這句 SQL 意思是「選取使用者名稱為 'admin' 或者 '1' 等於 '1' 的使用者資料」，由於 '1' 等於 '1' 永遠成立，所以這個 SQL 語句會返回所有使用者的資料，這樣就可以繞過驗證，直接登入系統。",[15,632,633],{},"你可能會疑惑一件事情：",[15,635,636],{},"「後面不是有 AND password = '$password' 嗎？那麼這樣不就還是會被驗證嗎？」",[15,638,639],{},"其實這個問題很好，因為在 SQL 語句中，OR 的優先級是高於 AND 的，所以這個 SQL 語句會先執行 OR 的部分，然後再執行 AND 的部分，所以最後的結果就是會返回所有使用者的資料。",[15,641,642],{},"最後再提一個常見的攻擊手法，在建立資料庫時，我們通常會對欄位設定型別限制，例如使用者名稱只能存放字串，密碼欄位也只能存放字串。",[15,644,645],{},"但如果沒有對欄位設定長度限制，攻擊者就可能利用這個漏洞發動攻擊。",[15,647,648],{},"那這種攻擊手法是什麼呢？其實它屬於 DoS（Denial of Service，阻斷服務攻擊） 的一種，做法就是在欄位裡存入一筆超長的字串，導致資料庫在處理時因為字串過長而消耗大量系統資源，最終把系統拖到當機。",[38,650,651],{"id":651},"結語",[15,653,654],{},"WannaCry 爆發的時候，我身邊的朋友都陸續中毒，就連我也沒能倖免，幸好當時資料不重要，所以我也就直接放棄。",[15,656,657],{},"不知道有沒有人中過 WannaCry 的經驗呢？",[38,659,660],{"id":660},"同步更新",[15,662,663],{},"本文將同步更新至以下網站：",[83,665,666,673,680,687,694,701],{},[86,667,668],{},[23,669,672],{"href":670,"rel":671},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[86,674,675],{},[23,676,679],{"href":677,"rel":678},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[86,681,682],{},[23,683,686],{"href":684,"rel":685},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[86,688,689],{},[23,690,693],{"href":691,"rel":692},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook 