[{"data":1,"prerenderedAt":466},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250917\u002F709893047\u002F":3,"page:\u002Flearnexp\u002F20250917\u002F709893047\u002F":4,"alt:\u002Flearnexp\u002F20250917\u002F709893047\u002F":3,"prev-next:\u002Flearnexp\u002F20250917\u002F709893047\u002F":442,"related:\u002Flearnexp\u002F20250917\u002F709893047\u002F":451},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F17\u002Fday-17-language-simpler-than-me-only-0-and-1\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":420,"date":421,"description":422,"extension":423,"lang":424,"meta":425,"navigation":426,"path":427,"readingMinutes":428,"seo":429,"standalone":430,"stem":431,"tags":432,"tldr":438,"updated":439,"url":440,"__hash__":441},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 17】比我還單純的語言？電腦的世界只有 0 和 1！.md","【Day 17】比我還單純的語言？電腦的世界只有 0 和 1！","709893047",{"type":9,"value":10,"toc":413},"minimark",[11,28,35,40,43,46,49,52,55,58,61,64,67,70,76,83,86,89,93,96,99,102,105,115,127,133,136,143,150,153,156,159,162,168,175,178,181,184,187,194,208,213,216,223,228,231,234,249,252,263,266,316,322,328,331,345,351,357,360,363,366,369],[12,13,16],"callout",{"title":14,"type":15},"Warning","warning",[17,18,19,20,27],"p",{},"嗨！這系列文章已經重新整理、改寫成書，目前在 ",[21,22,26],"a",{"href":23,"rel":24},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[25],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[17,29,30],{},[31,32],"img",{"alt":33,"src":34},"比我還單純的語言？電腦的世界只有 0 和 1！","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday17\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8813%E6%97%A5%20%E4%B8%8B%E5%8D%8802_40_46.png",[36,37,39],"h2",{"id":38},"比我還單純的語言電腦的世界只有-0-和-1","比我還單純的語言？電腦的世界只有 0 和 1",[17,41,42],{},"基本上只要上電腦課，我幾乎都會用「強制關閉」這招來擺脫老師的控制。但有一次，不知道為什麼，突然心血來潮（對，就是這麼突然），想要好好聽聽老師到底在講什麼。",[17,44,45],{},"「在電腦的世界裡，你們所看到的一切都是由 0 和 1 組成的。」老師在白板上寫著。",[17,47,48],{},"「蛤？什麼？電腦的世界只有 0 和 1？那顏色怎麼來的？」我心裡冒出疑問。",[17,50,51],{},"「是不是很好奇顏色怎麼產生的？其實顏色也是由 0 和 1 組成的。」老師彷彿讀心術般地接著說。",[17,53,54],{},"「大家應該還記得 RGB 三元素吧？R 代表 Red（紅）、G 代表 Green（綠）、B 代表 Blue（藍），這三個顏色組合起來就能產生各種色彩。」老師一邊說著一邊在白板上畫了三個圓圈，分別標上 R、G、B。",[17,56,57],{},"「就連畫面上的 A、B、C 這些字母，也是由 0 和 1 組成的。要靠一個東西，叫做 ASCII。」老師寫下大大的「ASCII」。",[17,59,60],{},"「WOW！原來電腦沒辦法直接看懂 A、B、C 啊！」我心裡覺得挺酷炫的。\n……不過沒多久我就棄聽課，照慣例跑去打遊戲了。",[17,62,63],{},"「ㄟ，XXX，你們魔獸爭霸打完沒？」我邊用「強制關閉」技巧解除老師的控制，邊轉頭問同學。",[17,65,66],{},"「快打完了，你下一場要打嗎？」同學一邊專注操控角色，一邊回我。",[17,68,69],{},"「好啊，要不要用 GGC 跟路人對打？」我問。",[17,71,72],{},[31,73],{"alt":74,"src":75},"GGC（圖源網路）","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday17\u002F20250914104929.png",[12,77,80],{"title":78,"type":79},"Note","note",[17,81,82],{},"GGC 是一個社群遊戲平台，由於魔獸爭霸僅能在區域網路（LAN）對戰，所以玩家會透過 GGC 來模擬區域網路，進而與其他玩家進行對戰。",[17,84,85],{},"「好啊！」同學回答。",[17,87,88],{},"相信你各位應該都知道沒聽課的下場是什麼了，電腦課的考試和課後作業，我根本一題都寫不出來。",[36,90,92],{"id":91},"二進位-binary","二進位 Binary",[17,94,95],{},"什麼是二進位呢？二進位又稱 Binary，它是一套數字系統，僅用兩個符號來做代表，也就是數字的 0 和 1。",[17,97,98],{},"「二進位只有電腦有嗎？」你可能會有這樣的疑問。",[17,100,101],{},"不對，只要跟電子電路有關的東西都是使用二進位，那為什麼會採用二進位呢？難道不能用其他進位嗎？像是八進位、十進位、十六進位等等的？",[17,103,104],{},"其實原因有兩個：",[106,107,108,112],"ul",{},[109,110,111],"li",{},"二進位的電路設計相對簡單，因為它只需要兩種狀態：開（1）和關（0），這使得電路更容易被設計與實現。",[109,113,114],{},"二進位對於電子訊號的容錯率相對較高。",[17,116,117,118,122,123,126],{},"這邊有些名詞可能對於讀者稍微比較陌生，所以我在這邊也同時解釋一下「",[119,120,121],"strong",{},"容錯率","」與「",[119,124,125],{},"電子訊號","」的意思。",[17,128,129,130,126],{},"首先容錯率（Fault Tolerance）是指系統在遇到錯誤或故障時的忍受範圍，也就是系統能夠在某些部分失效的情況下仍然能夠繼續運作，你也可以理解為「",[119,131,132],{},"明明出錯了，但系統還是能夠繼續運作",[17,134,135],{},"那麼電子訊號呢？",[17,137,138,139,142],{},"電子訊號（Electrical Signal）是在指電路中傳遞的電壓變化，這些變化可以用於表示數字，例如：0V ~ 0.8V 代表 0，而 2V ~ 5V 代表 1，而 0.8V ~ 2V 則是代表不確定的狀態，又稱為「",[119,140,141],{},"雜訊","」。",[17,144,145,146,149],{},"在電子訊號裡，有一個很容易被誤解的觀念：「",[119,147,148],{},"電子訊號 ≠ 資料","」。\n電子訊號指的是電壓的變化，而資料則是這些變化所承載的意義。換句話說，電子訊號只是資料的「載體」，但它本身不等於資料。",[17,151,152],{},"舉個例子，假設我們要傳遞數字 5，它的二進位表示是 101。轉換成電子訊號後，可能會變成「5V、0V、5V」，這組電壓變化就代表數字 5，接著電腦會再把它解讀回 101。",[17,154,155],{},"那麼這邊要來說明一個關鍵問題：",[17,157,158],{},"「5 是怎麼變成 101 的呢？」",[17,160,161],{},"這邊就會牽扯到二進位的表示方式了。",[17,163,164,165,142],{},"首先，要介紹二進位之前，我們先認識一下我們平常最常使用的「",[119,166,167],{},"十進位",[17,169,170,171,174],{},"十進位（Decimal）就是我們日常使用的數字系統，使用 0 到 9 這十個符號來表示數字。當從 0 數到 9 之後，下一個數字「10」的產生方式是：個位歸零，前一位進一，這就是「",[119,172,173],{},"進位","」的概念。",[17,176,177],{},"那麼二進位呢？它只使用 0 和 1 兩個符號。當數到「2」時，因為已經超出範圍，個位數會歸零，前一位進一，所以就從「1」變成「10」。",[17,179,180],{},"接下來我們來試一道小小的練習題，示範如何把十進位轉換成二進位。",[17,182,183],{},"「請試著將十進位的數字 13 轉換成二進位。」",[17,185,186],{},"別擔心，接下來我會手把手帶你一步步完成。",[17,188,189,190,193],{},"做法是「",[119,191,192],{},"不斷除以 2，並記下餘數","」，直到商數為 0 為止：",[106,195,196,199,202,205],{},[109,197,198],{},"13 ÷ 2 = 6，餘數 1",[109,200,201],{},"6 ÷ 2 = 3，餘數 0",[109,203,204],{},"3 ÷ 2 = 1，餘數 1",[109,206,207],{},"1 ÷ 2 = 0，餘數 1",[12,209,210],{"title":78,"type":79},[17,211,212],{},"所謂的「商數」指的是除法的結果，而「餘數」則是除法後剩下的部分。",[17,214,215],{},"接著我們將餘數從下往上排列（最後一個 → 最前一個）：",[17,217,218,219],{},"→ ",[220,221,222],"code",{},"1101",[17,224,225,226],{},"所以十進位的數字 13，換成二進位就是：",[119,227,222],{},[17,229,230],{},"看到這邊應該會有人冒出一個疑問：",[17,232,233],{},"「13 ÷ 2 不是應該是 6.5 嗎？為什麼會是 6 呢？」",[17,235,236,237,240,241,244,245,248],{},"這是因為在數學裡，像 ",[220,238,239],{},"6.5"," 這種帶小數的結果屬於「",[119,242,243],{},"實數除法","」，但在做二進位轉換時，我們用的是「",[119,246,247],{},"整數除法","」，也就是只取整數部分，把小數點後的部分直接捨去，至於被捨去的小數部分，就會變成我們所說的「餘數」。",[17,250,251],{},"那餘數為什麼是 1 呢？ 以最直接的方式來看：",[106,253,254,257,260],{},[109,255,256],{},"13 ÷ 2 = 6 …… 餘 1",[109,258,259],{},"因為2 × 6 = 12，剛好小於 13。",[109,261,262],{},"13 − 12 = 1，這就是餘數。",[17,264,265],{},"以表格來表示的話，會是這樣：",[267,268,269,280],"table",{},[270,271,272],"thead",{},[273,274,275,278],"tr",{},[276,277,243],"th",{},[276,279,247],{},[281,282,283,292,300,308],"tbody",{},[273,284,285,289],{},[286,287,288],"td",{},"13 ÷ 2 = 6.5",[286,290,291],{},"13 ÷ 2 = 6 餘數 1",[273,293,294,297],{},[286,295,296],{},"6 ÷ 2 = 3",[286,298,299],{},"6 ÷ 2 = 3 餘數 0",[273,301,302,305],{},[286,303,304],{},"3 ÷ 2 = 1.5",[286,306,307],{},"3 ÷ 2 = 1 餘數 1",[273,309,310,313],{},[286,311,312],{},"1 ÷ 2 = 0.5",[286,314,315],{},"1 ÷ 2 = 0 餘數 1",[17,317,318],{},[31,319],{"alt":320,"src":321},"進位轉換過程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday17\u002F202509141042.png",[17,323,324,325,327],{},"那有辦法驗證我們的答案嗎？當然可以，將二進位的 ",[220,326,222],{}," 轉換回十進位：",[17,329,330],{},"1101（二進位）從右到左分別代表：",[106,332,333,336,339,342],{},[109,334,335],{},"1 × 2⁰ = 1",[109,337,338],{},"0 × 2¹ = 0",[109,340,341],{},"1 × 2² = 4",[109,343,344],{},"1 × 2³ = 8",[17,346,347,348],{},"將這些數字加總起來：1 + 0 + 4 + 8 = ",[119,349,350],{},"13",[17,352,353],{},[31,354],{"alt":355,"src":356},"轉換成十進位的過程​","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday17\u002F202509141043.png",[17,358,359],{},"這樣就證明了我們的轉換是正確的。",[17,361,362],{},"那麼這時候可能會冒出一個疑問：電腦到底是怎麼儲存這些二進位數字？又是如何把它們轉換成我們能理解的文字呢？\n這些內容，我會在下一篇文章中再跟大家分享！",[36,364,365],{"id":365},"同步更新",[17,367,368],{},"本文將同步更新至以下網站：",[106,370,371,378,385,392,399,406],{},[109,372,373],{},[21,374,377],{"href":375,"rel":376},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[25],"是 Ray 不是 Array",[109,379,380],{},[21,381,384],{"href":382,"rel":383},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[25],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[109,386,387],{},[21,388,391],{"href":389,"rel":390},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[25],"Threads - 時常會聊軟實力",[109,393,394],{},[21,395,398],{"href":396,"rel":397},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[25],"Facebook - 搞怪迷因分享",[109,400,401],{},[21,402,405],{"href":403,"rel":404},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[25],"Instagram - 搞怪迷因分享 + 軟實力",[109,407,408],{},[21,409,412],{"href":410,"rel":411},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[25],"Portaly - 入口主頁",{"title":414,"searchDepth":415,"depth":415,"links":416},"",2,[417,418,419],{"id":38,"depth":415,"text":39},{"id":91,"depth":415,"text":92},{"id":365,"depth":415,"text":365},"學習經驗","2025-09-17 00:00:01","你以為顏色、文字都很複雜？其實電腦眼中只有 0 和 1。本文用遊戲回憶和小練習，帶你看懂二進位的魔法！","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-17-0-1","4",{"title":6,"description":422},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 17】比我還單純的語言？電腦的世界只有 0 和 1！",[433,434,435,436,437],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","二進位轉換教學","電腦原理入門","魔獸爭霸回憶","RGB 顏色原理",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250917\u002F709893047\u002F","4fWUTPGLSx6DFiEWMix8ESvd71jkXmdpezAviYKH-gE",{"newer":443,"older":447},{"url":444,"title":445,"date":446},"\u002Flearnexp\u002F20250918\u002F2508084667\u002F","【Day 18】A 原來是 65？我終於搞懂 ASCII 跟 bit 是什麼了！","2025-09-18 00:00:01",{"url":448,"title":449,"date":450},"\u002Flearnexp\u002F20250916\u002F1976446718\u002F","【Day 16】因為上課打遊戲，害我沒聽到老師講什麼是 OSI 七層模型","2025-09-16 00:00:01",[452,456,461],{"url":453,"title":454,"date":455,"readingMinutes":428},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00",{"url":457,"title":458,"date":459,"readingMinutes":460},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":462,"title":463,"date":464,"readingMinutes":465},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00","6",1784087360011]