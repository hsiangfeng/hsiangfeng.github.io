[{"data":1,"prerenderedAt":1452},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250225\u002F3903283315\u002F":3,"page:\u002Flearnexp\u002F20250225\u002F3903283315\u002F":4,"alt:\u002Flearnexp\u002F20250225\u002F3903283315\u002F":3,"prev-next:\u002Flearnexp\u002F20250225\u002F3903283315\u002F":1427,"related:\u002Flearnexp\u002F20250225\u002F3903283315\u002F":1436},"\u002Fen\u002Flearning\u002F2025\u002F02\u002F25\u002Funderstanding-api-through-lottery\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1411,"date":1412,"description":24,"extension":1413,"lang":1414,"meta":1415,"navigation":943,"path":1416,"readingMinutes":1417,"seo":1418,"standalone":1419,"stem":1420,"tags":1421,"tldr":1424,"updated":1412,"url":1425,"__hash__":1426},"content\u002F學習經驗\u002F買彩券也能理解-API！從生活案例帶你一次搞懂-RESTful-API.md","買彩券也能理解 API！從生活案例帶你一次搞懂 RESTful API","3903283315",{"type":9,"value":10,"toc":1399},"minimark",[11,18,22,25,29,32,35,38,41,44,47,50,53,58,61,64,74,77,80,99,102,122,125,128,131,134,137,148,162,166,169,180,187,190,193,196,207,210,214,217,220,223,226,230,245,248,251,256,259,316,319,326,330,333,336,374,377,381,388,392,395,398,409,412,415,418,438,452,456,459,462,465,559,562,566,569,573,576,579,605,608,670,673,724,727,748,755,758,807,813,816,819,822,854,857,887,890,894,897,1103,1106,1139,1153,1156,1190,1193,1380,1383,1386,1389,1392,1395],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Frest-restful-api\u002F202502271045.jpg",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"接下來，就讓我們從一個簡單的彩券案例開始，一步步揭開 API、REST、以及 RESTful API 的神祕面紗。",[19,26,28],{"id":27},"apis","APIs",[12,30,31],{},"很多時候我們會常常聽到人家說：",[12,33,34],{},"「這個有 APIs 可以用嗎？」",[12,36,37],{},"「這個有提供 APIs 嗎？」",[12,39,40],{},"「你會接 APIs 嗎？」。",[12,42,43],{},"身為一名工程師，相信你一定聽過不少次 APIs 這個單字，那麼究竟什麼是 APIs 呢？",[12,45,46],{},"APIs 全名是 Application Programming Interface 中文翻譯為應用程式介面，大多文獻、參考來源都會說它是一個應用程式與應用程式之間的橋樑、接口，我認為這樣的定義與說明對於一個新手來講是相對難懂的，所以我想請你把這些介紹與說明拋到腦後。",[12,48,49],{},"「拋到腦後的話，那你該怎麼解釋？」",[12,51,52],{},"我知道你會這樣講，所以別擔心，我將會用現實生活中的例子來解釋 APIs，讓你更容易理解。",[54,55,57],"h3",{"id":56},"其實-apis-是一種交易行為","其實 APIs 是一種「交易」行為",[12,59,60],{},"請你試著在腦海中模擬出一個畫面...",[12,62,63],{},"你今天要去彩券行買彩券，當你走進去後，你會跟彩券行老闆說：「老闆，我要 100 塊大樂透！」，接著你就會把 100 塊給老闆，老闆確定有收到 100 塊後，就會在彩券機上輸入你的 100 塊訂單，接著彩券機就會印出一張大樂透，裡面有兩組號碼，然後老闆就會把這張大樂透給你。",[65,66,67],"blockquote",{},[12,68,69,73],{},[70,71,72],"strong",{},"Note","\n通常彩卷一組號碼（6 個號碼）是 50 元，而這邊舉例買了兩組號碼，所以是 100 元。",[12,75,76],{},"這個過程中，我們就已經解釋了整個 APIs 的概念跟行為，什麼意思呢？讓我們將 APIs 與買彩券的行為做一個對應，這樣你就會更容易理解了。",[12,78,79],{},"首先我們先了解一下這個對應表：",[81,82,83,87,90,93,96],"ul",{},[84,85,86],"li",{},"你：使用者（User）",[84,88,89],{},"老闆：伺服器（Server）",[84,91,92],{},"100 塊：請求（Request），通常會附帶驗證資料",[84,94,95],{},"彩券機：銀行將寫好的 APIs 封裝在裡面，讓伺服器可以直接呼叫對應的功能，當然也會包含一些驗證資料、參數等",[84,97,98],{},"大樂透：回傳（Response）的資料（Data）",[12,100,101],{},"接著我們將這個對應表套用到我們的例子中：",[81,103,104,107,110,113,116,119],{},[84,105,106],{},"你今天要去彩券行買彩券，當你走進去：使用者打開瀏覽器，輸入網址進入到特定網站",[84,108,109],{},"跟彩券行老闆說：「老闆，我要 100 塊大樂透！」，把 100 塊給老闆：向網站發請一個請求，並附帶驗證資料",[84,111,112],{},"老闆確定有收到 100 塊：伺服器驗證你的請求是否合法以及是否有權限",[84,114,115],{},"就會在彩券機上輸入你的 100 塊訂單：伺服器去呼叫 APIs，APIs 是一個已經封裝好的函式或程式，通常會有多個 APIs 可以使用",[84,117,118],{},"彩券機就會印出一張大樂透：APIs 回傳資料給伺服器",[84,120,121],{},"老闆就會把這張大樂透給你：伺服器將資料回傳給使用者",[12,123,124],{},"當然這個舉例可能沒有很標準，但至少我認為你已經有一定的概念了。",[12,126,127],{},"而這邊 APIs 真正的重點在於「就會在彩券機上輸入你的 100 塊訂單」這件事情上，我們都知道販售彩卷的單位是銀行，但我們不可能買一張彩卷都跑去銀行買，所以我們會去彩券行買，而彩卷機就是幫助我們跟銀行溝通的橋樑，這就是 APIs 的概念。",[12,129,130],{},"所以這邊簡單結論一下...",[12,132,133],{},"「APIs 其實是 A 應用程式（老闆）與 B 應用程式（銀行）之間的橋樑（彩券機），讓 A 應用程式可以透過 APIs 來跟 B 應用程式溝通，這樣就可以達到資料交換的目的。」",[12,135,136],{},"那...如果套用到 Web 前後端開發呢？",[81,138,139,142,145],{},[84,140,141],{},"使用者可見的網頁介面（前端）：A 應用程式",[84,143,144],{},"伺服器：作為執行與處理的中心，負責處理後端程式的邏輯",[84,146,147],{},"APIs：由後端程式提供的接口，讓前端程式可以透過 APIs 來跟後端程式溝通",[12,149,150,151,155,156,158,159,161],{},"所以使用者在操作畫面時，其實會跟伺服器說：「嘿！我現在正在請求 ",[152,153,154],"code",{},"\u002Fapi\u002Fv1\u002Fuser"," 的資料，你可以幫我把資料回傳給我嗎？」，而伺服器就會去呼叫 ",[152,157,154],{}," 這個 APIs，然後將資料回傳給使用者，而這個 ",[152,160,154],{}," 則是會去呼叫一個封裝好的函式或程式，這就是 APIs 的概念。",[54,163,165],{"id":164},"apis-的種類","APIs 的種類",[12,167,168],{},"APIs 的種類基本上不外乎是以下這幾種最常見：",[81,170,171,174,177],{},[84,172,173],{},"開放式 APIs（Open APIs）：提供給開發者使用，讓開發者可以串接這些 APIs 來開發自己的應用程式",[84,175,176],{},"內部 APIs（Internal APIs）：公司內部使用的 APIs，不對外開放",[84,178,179],{},"第三方 APIs（Third-party APIs）：由第三方提供的 APIs，讓開發者可以串接這些 APIs 來開發自己的應用程式",[65,181,182],{},[12,183,184,186],{},[70,185,72],{},"\n第三方意旨非官方提供的 APIs，通常是由第三方公司或者個人提供的 APIs。",[12,188,189],{},"以 OpenAI 來講，大多人都是使用 ChatGPT 的 WebUI 來跟 AI 對話，但是如果你想要串接 ChatGPT 的 APIs 來開發自己的應用程式，那你就可以使用 OpenAI 提供的 APIs 來串接，而這個 APIs 就隸屬於開放式 APIs。",[12,191,192],{},"那麼開放式 APIs 與第三方 APIs 有什麼差別呢？其實差別不大，只是開放式 APIs 比較著重於開放性，舉例來講開放式 APIs 的資料來源可能是由政府開放資料平台提供，但是你如果直接去串接 APIs，可能會有一些資料邏輯上的問題要處理，這時候你就可以使用第三方 APIs 來解決這個問題，因為第三方 APIs 已經幫你處理好了這些問題。",[12,194,195],{},"所以這邊簡單結論一下：",[81,197,198,201,204],{},[84,199,200],{},"開放式 APIs：強調的是公開性與生態系建立，通常由原始服務提供。",[84,202,203],{},"第三方 APIs：指由非官方或其他公司基於原始 APIs 再做封裝或增強處理，目的是讓資料整合更便利。",[84,205,206],{},"內部 APIs：Just for company.，僅著重於公司內部使用，不對外開放",[12,208,209],{},"這邊也額外補充說明一下，如果可以直接使用開放式 APIs，那是最好的，因為第三方 APIs 是由第三方提供，其穩定度以及資料安全性都是一個問題，所以如果可以直接使用開放式 APIs，那是最好的。",[19,211,213],{"id":212},"restful","RESTful",[12,215,216],{},"首先，這邊我要直接先講結論...",[12,218,219],{},"「RESTful APIs 是一種設計 APIs 的風格，而不是一種技術或標準，僅僅只是一個約定俗成的方式。」",[12,221,222],{},"前面我們已經知道什麼是 APIs，但 RESTful...又是什麼鬼東西呢？如果你去 Google 應該會得到一個「表現層狀態轉換」的翻譯文字，但這樣的翻譯對於一個新手來講是非常難懂的，就算是我也是。",[12,224,225],{},"所以在解釋 RESTful 之前，我們要先知道什麼是 REST。",[54,227,229],{"id":228},"rest-是什麼","REST 是什麼？",[12,231,232,233,236,237,240,241,244],{},"REST 是 ",[70,234,235],{},"RE","presentational ",[70,238,239],{},"S","tate ",[70,242,243],{},"T","ransfer 的縮寫，中文翻譯確實是「表現層狀態轉換」，目的是為了方便管理分散的資源所提出來的一套設計模式，而這套設計模式是由 Roy Fielding 在 2000 年博士論文中提出來的。",[12,246,247],{},"只要你設計出來的 APIs 符合 REST 的設計風格，那這個 APIs 就可以稱為 RESTful APIs。",[12,249,250],{},"那麼想要符合 REST 的設計風格，你需要遵守以下這幾個原則：",[252,253,255],"h4",{"id":254},"uniform-interface統一介面","Uniform Interface（統一介面）",[12,257,258],{},"要達成統一介面這件事情，其實是有一些事情要注意，通常必須要達成四項約束：",[81,260,261,271,278,293],{},[84,262,263,264,266,267,270],{},"資源識別：每一個資料請求都要有一個獨特的 Url 來識別資源（如：",[152,265,154],{},"），就跟前端在取得特定元素時會使用 ",[152,268,269],{},"document.getElementById('id')"," 一樣。",[84,272,273,274,277],{},"資源操作：伺服器再回傳資料時，一率都是統一一種格式，例如：JSON 格式，這樣串接的開發者就不用再重新學習新格式的問題，現今開發也都大多採用 ",[152,275,276],{},"Content-Type: application\u002Fjson"," 這種格式",[84,279,280,281,284,285,288,289,292],{},"自我描述：伺服器回傳的資料中，必須要有足夠的資訊讓開發者可以理解，不需要再去查閱文件，例如：HTTP 狀態碼、錯誤訊息等，例如：",[152,282,283],{},"HTTP Code: 200"," 代表成功，",[152,286,287],{},"HTTP Code: 400"," 代表錯誤，接著再回傳一些錯誤訊息，像是 ",[152,290,291],{},"{\"message\": \"錯誤訊息\"}"," 這樣",[84,294,295,296,299,300,303,304,307,308,311,312,315],{},"超媒體應用狀態：簡單來講就是，當你在取得資料時，伺服器會回傳一些超連結，好處在於前端不用再去處理 Url，而是透過伺服器回傳的超連結來取得資料，只需要後端去維護這些超連結即可，這樣可以讓前端更專注在畫面的呈現上，通常裡面會包含 ",[152,297,298],{},"self","（當前） 、",[152,301,302],{},"next","（下一筆） 、",[152,305,306],{},"prev","（上一筆） 、",[152,309,310],{},"first","（第一筆） 、",[152,313,314],{},"last","（最後一筆） 等等連結。",[12,317,318],{},"基本上只要符合上述這四項約束，就可以稱為符合 Uniform Interface 這個原則。",[65,320,321],{},[12,322,323,325],{},[70,324,72],{},"\n以我目前自己開發經驗來講，超媒體應用狀態這件事情比較常見在管理側邊欄的欄位連結，例如...當你登入後，後台並不會直接呈現所有前端的頁面連結，而是透過後端驗證之後，回傳給你前端的頁面連結。",[252,327,329],{"id":328},"stateless無狀態","Stateless（無狀態）",[12,331,332],{},"RESTful APIs 必須是無狀態的，這邊所謂的無狀態是指，每一次的請求都是獨立的，不會受到前一次請求的影響，這樣的好處在於伺服器不需要去維護使用者的狀態，只需要處理請求即可。",[12,334,335],{},"不好懂的話，這邊舉例使用者登入的情境，當使用者登入後，伺服器會回傳一個 Token 給使用者",[337,338,343],"pre",{"className":339,"code":340,"language":341,"meta":342,"style":342},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30\"\n}\n","json","",[152,344,345,354,368],{"__ignoreMap":342},[346,347,350],"span",{"class":348,"line":349},"line",1,[346,351,353],{"class":352},"sMAXC","{\n",[346,355,357,361,364],{"class":348,"line":356},2,[346,358,360],{"class":359},"sKpQp","  \"token\"",[346,362,363],{"class":352},": ",[346,365,367],{"class":366},"sTRMh","\"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30\"\n",[346,369,371],{"class":348,"line":370},3,[346,372,373],{"class":352},"}\n",[12,375,376],{},"此時這個 Token 將會記憶在使用者的瀏覽器中，當使用者再次發送請求時，只需要帶上這個 Token，伺服器就可以知道這個使用者是誰，而不需要再去維護使用者的狀態（意旨早期 Session 的概念）。",[252,378,380],{"id":379},"client-server客戶端-伺服器","Client-Server（客戶端-伺服器）",[12,382,383,384,387],{},"Client-Server 是在講分離客戶端與伺服器，使得用客戶端與伺服器之間可以獨立演進，而不會互相影響，在早期的網頁開發中，我們會將 HTML、CSS、JavaScript、後端程式碼全部混在一起，這樣的開發方式是不符合 Client-Server 這個原則的，如果這樣還不好懂的話，更白話文一點就是指「",[70,385,386],{},"前後端分離","」這件事。",[252,389,391],{"id":390},"layered-system分層系統","Layered System（分層系統）",[12,393,394],{},"Layered System 意思是指將整個應用程式切成多的獨立的層級，每一層只做好自己的事情，不會去干涉到其他層級的事情。",[12,396,397],{},"最好懂的例子大多都是舉例 MVC 模式：",[81,399,400,403,406],{},[84,401,402],{},"Model：負責處理資料的邏輯",[84,404,405],{},"View：負責處理畫面的邏輯",[84,407,408],{},"Controller：負責處理邏輯的控制器",[12,410,411],{},"MVC 的經典設計模式中，就可以知道 View 不會直接跟 Model 溝通，而是透過 Controller 來處理，這樣就符合 Layered System 這個原則。",[12,413,414],{},"所以 Layered System 概念就像是一個團隊，每個人各司其職，只和隔壁的同事協作，這樣整個工作流程會更順暢。",[12,416,417],{},"在應用程式開發中，我們也會把檢查 Token 與處理使用者邏輯分在不同的 Service\u002FModule，這也是一種分層的概念，如果套用到我們 APIs 設計上也就是指 APIs 會分成多層，例如一個使用者登入的行為，就會被拆成以下幾個層級：",[81,419,420,426,432],{},[84,421,422,425],{},[152,423,424],{},"POST \u002Fapi\u002Fv1\u002Fauth\u002F","：負責處理驗證的邏輯，但不會去處理使用者的邏輯",[84,427,428,431],{},[152,429,430],{},"POST \u002Fapi\u002Fv1\u002Fuser\u002F","：負責處理使用者的邏輯，但不會去處理 Token 的邏輯",[84,433,434,437],{},[152,435,436],{},"POST \u002Fapi\u002Fv1\u002Ftoken\u002F","：負責處理 Token 的邏輯，但不會去處理使用者的邏輯",[12,439,440,441,444,445,444,448,451],{},"接著底下還會區分成更細的層級，例如：",[152,442,443],{},"POST \u002Fapi\u002Fv1\u002Fauth\u002Fsignin","、",[152,446,447],{},"POST \u002Fapi\u002Fv1\u002Fauth\u002Fsignup",[152,449,450],{},"POST \u002Fapi\u002Fv1\u002Fauth\u002Fsignout","，這樣就可以達到 Layered System 這個原則。",[252,453,455],{"id":454},"cacheable可快取","Cacheable（可快取）",[12,457,458],{},"Cacheable 意思是指伺服器回傳的資料可以被快取，這樣可以提升效能，減少伺服器的負擔。",[12,460,461],{},"這邊以串接 APIs 來講，我們可以針對一些不常變動的資料進行快取（設定 Cache-Control），這樣當使用者再次發送請求時，就可以直接從快取中取得資料，而不用再次向伺服器發送請求，這樣可以提升效能。",[12,463,464],{},"但這部分比較偏向由後端工程師來處理，例如：",[337,466,470],{"className":467,"code":468,"language":469,"meta":342,"style":342},"language-js shiki shiki-themes github-dark-high-contrast","app.get('\u002Fapi\u002Fv1\u002Fuser', (req, res) => {\n  \u002F\u002F 設定快取時間為 1 小時\n  res.setHeader('Cache-Control', 'max-age=3600')\n  res.json({ message: 'Hello World' })\n})\n","js",[152,471,472,510,516,537,553],{"__ignoreMap":342},[346,473,474,477,481,484,487,490,494,497,500,503,507],{"class":348,"line":349},[346,475,476],{"class":352},"app.",[346,478,480],{"class":479},"sj_SG","get",[346,482,483],{"class":352},"(",[346,485,486],{"class":366},"'\u002Fapi\u002Fv1\u002Fuser'",[346,488,489],{"class":352},", (",[346,491,493],{"class":492},"s_sBn","req",[346,495,496],{"class":352},", ",[346,498,499],{"class":492},"res",[346,501,502],{"class":352},") ",[346,504,506],{"class":505},"sWyjQ","=>",[346,508,509],{"class":352}," {\n",[346,511,512],{"class":348,"line":356},[346,513,515],{"class":514},"sQrFR","  \u002F\u002F 設定快取時間為 1 小時\n",[346,517,518,521,524,526,529,531,534],{"class":348,"line":370},[346,519,520],{"class":352},"  res.",[346,522,523],{"class":479},"setHeader",[346,525,483],{"class":352},[346,527,528],{"class":366},"'Cache-Control'",[346,530,496],{"class":352},[346,532,533],{"class":366},"'max-age=3600'",[346,535,536],{"class":352},")\n",[346,538,540,542,544,547,550],{"class":348,"line":539},4,[346,541,520],{"class":352},[346,543,341],{"class":479},[346,545,546],{"class":352},"({ message: ",[346,548,549],{"class":366},"'Hello World'",[346,551,552],{"class":352}," })\n",[346,554,556],{"class":348,"line":555},5,[346,557,558],{"class":352},"})\n",[12,560,561],{},"接下來當使用者再次發送請求時，就可以直接從快取中取得資料，而不用再次向伺服器發送請求，這樣可以提升效能。",[252,563,565],{"id":564},"code-on-demand可程式碼化","Code on Demand（可程式碼化）",[12,567,568],{},"這個並不是非必要的，但以 Code on Demand 這個原則來講，就是指伺服器可以回傳一些程式碼給客戶端執行，這樣可以提升客戶端的功能性，只是這個 Code on Demand 通常不會是必要的，就算是我也還沒遇過這種需求。",[19,570,572],{"id":571},"restful-apis-restful-apis","RESTful + APIs = RESTful APIs",[12,574,575],{},"前面我們認識了什麼是 APIs，也了解了什麼是 REST，那麼當這兩個東西組合在一起時，只要符合 REST 的設計風格，那這個 APIs 就可以稱為 RESTful APIs，所以這一篇我將會以 Web 開發領域的角度去說明該如何設計 RESTful APIs。",[12,577,578],{},"首先我們先假設一個情景，也就是今天有一個電商系統，目前線稿圖上有以下功能：",[81,580,581,584,587,590,593,596,599,602],{},[84,582,583],{},"使用者登入",[84,585,586],{},"使用者註冊",[84,588,589],{},"使用者登出",[84,591,592],{},"取得商品列表",[84,594,595],{},"取得商品詳細資訊",[84,597,598],{},"加入購物車",[84,600,601],{},"刪除購物車商品",[84,603,604],{},"結帳",[12,606,607],{},"你可以試著暫停一下，你會如何設計這些 APIs 路徑（溝通橋樑）呢？這邊就舉例我真人真事遇過的例子，當時我在 A 公司，那間公司的後端工程師就是這樣設計的：",[81,609,610,616,622,628,634,640,646,652,658,664],{},[84,611,612,613],{},"使用者登入：",[152,614,615],{},"POST \u002Flogin",[84,617,618,619],{},"使用者註冊：",[152,620,621],{},"POST \u002Fregister",[84,623,624,625],{},"使用者登出：",[152,626,627],{},"POST \u002Flogout",[84,629,630,631],{},"取得商品列表：",[152,632,633],{},"GET \u002Fproducts",[84,635,636,637],{},"取得商品詳細資訊：",[152,638,639],{},"GET \u002Fproducts\u002F:id",[84,641,642,643],{},"加入購物車：",[152,644,645],{},"POST \u002Fcart",[84,647,648,649],{},"刪除購物車商品：",[152,650,651],{},"POST \u002Fcart\u002F:id",[84,653,654,655],{},"結帳：",[152,656,657],{},"POST \u002Fcheckout",[84,659,660,661],{},"建立商品（後台）：",[152,662,663],{},"POST \u002Fadmin\u002Fproducts",[84,665,666,667],{},"刪除商品（後台）：",[152,668,669],{},"POST \u002Fadmin\u002Fproducts\u002F:id",[12,671,672],{},"感覺好像沒有什麼，接著我離職後到另一間公司，那間公司的後端工程師就是這樣設計的：",[81,674,675,680,685,690,695,700,705,710,714,719],{},[84,676,612,677],{},[152,678,679],{},"POST \u002FuserSignIn",[84,681,618,682],{},[152,683,684],{},"POST \u002FuserSignUp",[84,686,624,687],{},[152,688,689],{},"POST \u002FuserSignOut",[84,691,630,692],{},[152,693,694],{},"GET \u002FproductList",[84,696,636,697],{},[152,698,699],{},"GET \u002FproductDetail",[84,701,642,702],{},[152,703,704],{},"POST \u002FaddCart",[84,706,648,707],{},[152,708,709],{},"POST \u002FdeleteCart",[84,711,654,712],{},[152,713,657],{},[84,715,660,716],{},[152,717,718],{},"POST \u002FadminCreateProduct",[84,720,666,721],{},[152,722,723],{},"POST \u002FadminDeleteProduct",[12,725,726],{},"雖然看起來好像還算 ok，沒有什麼問題，但是這個問題就會變成每一間公司都有屬於自己的特色命名方式，那麼這樣的命名就會有以下問題：",[728,729,730,733,736,739,742,745],"ol",{},[84,731,732],{},"不容易使用現代化工具（標準化工具）來產生文件，如：Swagger、Postman 這些都是基於 RESTful APIs 來設計的",[84,734,735],{},"以「動作」為主的命名方式，容易導致發生所謂的 RPC（Remote Procedure Call）風格，導致資源不明確，路徑也會因此複雜化",[84,737,738],{},"不符合 HTTP Method 的規範，例如：POST（新增）、GET（取得）、PUT（更新）、DELETE（刪除），開發者難以透過 HTTP Method 來判斷這個 APIs 是做什麼的",[84,740,741],{},"難以直觀的瞭解到這個 APIs 是做什麼的，容易有各自解釋的問題，動詞與名詞上會有不同的命名方式與解釋",[84,743,744],{},"對於版本與路徑的管理不易，後續若要新增功能或者修改功能，會導致路徑的變動，這樣會對前端開發者造成困擾",[84,746,747],{},"每進一間公司就要重新學習他們的 APIs or 閱讀文件才能知道這個 APIs 是做什麼的",[65,749,750],{},[12,751,752,754],{},[70,753,72],{},"\nRPC 是另一種設計方式，通常是以「動作」為主的命名方式，也需要知道相關參數才能夠使用。",[12,756,757],{},"因此這邊如果將這些 APIs 路徑重新設計一下，那應該要怎麼設計呢？這邊我將會以 RESTful APIs 的設計風格來重新設計這些 APIs 路徑：",[81,759,760,764,768,772,777,782,787,792,797,802],{},[84,761,612,762],{},[152,763,443],{},[84,765,618,766],{},[152,767,447],{},[84,769,624,770],{},[152,771,450],{},[84,773,630,774],{},[152,775,776],{},"GET \u002Fapi\u002Fv1\u002Fproducts",[84,778,636,779],{},[152,780,781],{},"GET \u002Fapi\u002Fv1\u002Fproducts\u002F:id",[84,783,642,784],{},[152,785,786],{},"POST \u002Fapi\u002Fv1\u002Fcart",[84,788,648,789],{},[152,790,791],{},"DELETE \u002Fapi\u002Fv1\u002Fcart\u002F:id",[84,793,654,794],{},[152,795,796],{},"POST \u002Fapi\u002Fv1\u002Fcheckout",[84,798,660,799],{},[152,800,801],{},"POST \u002Fapi\u002Fv1\u002Fadmin\u002Fproducts",[84,803,666,804],{},[152,805,806],{},"DELETE \u002Fapi\u002Fv1\u002Fadmin\u002Fproducts\u002F:id",[12,808,809,810,812],{},"接著這些格式請求（Request）與回應（Response）的格式，一率都是統一使用 JSON 格式（",[152,811,276],{},"） 進行傳輸，你可能會問：",[12,814,815],{},"「為什麼要使用 JSON 格式呢？」",[12,817,818],{},"最主要原因是，JSON 格式是一種輕量級的資料交換格式，由於 JSON 是輕量且易讀的資料交換格式，多數程式語言都有支援，因此前後端開發者能以最低成本解析與調整。",[12,820,821],{},"由於我們是採用 Web 開發來講，所以就會搭配 HTTP Method 來設計這些 APIs 路徑：",[81,823,824,830,836,842,848],{},[84,825,826,829],{},[152,827,828],{},"POST","：新增資料（or 資料狀態的改變）",[84,831,832,835],{},[152,833,834],{},"GET","：取得資料",[84,837,838,841],{},[152,839,840],{},"PUT","：更新資料",[84,843,844,847],{},[152,845,846],{},"PATCH","：部分更新資料",[84,849,850,853],{},[152,851,852],{},"DELETE","：刪除資料",[12,855,856],{},"接著會搭配 HTTP Code 來回傳資料，例如：",[81,858,859,864,869,875,881],{},[84,860,861,863],{},[152,862,283],{},"：成功",[84,865,866,868],{},[152,867,287],{},"：錯誤",[84,870,871,874],{},[152,872,873],{},"HTTP Code: 401","：未授權",[84,876,877,880],{},[152,878,879],{},"HTTP Code: 404","：找不到資源",[84,882,883,886],{},[152,884,885],{},"HTTP Code: 500","：伺服器錯誤",[12,888,889],{},"因此，一個符合 RESTful APIs 風格的 APIs 會像以下這樣：",[12,891,612,892],{},[152,893,443],{},[12,895,896],{},"Request（請求）：",[337,898,900],{"className":467,"code":899,"language":469,"meta":342,"style":342},"const data = {\n  email: 'example@example.com',\n  password: '123456'\n}\n\nconst options = {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application\u002Fjson'\n  },\n  body: JSON.stringify(data)\n}\n\nfetch('\u002Fapi\u002Fv1\u002Fauth\u002Fsignin', options)\n  .then(response => response.json())\n  .then(data => console.log(data))\n  .catch(error => console.error(error))\n",[152,901,902,916,927,935,939,945,957,968,974,985,991,1009,1014,1019,1033,1058,1081],{"__ignoreMap":342},[346,903,904,907,911,914],{"class":348,"line":349},[346,905,906],{"class":505},"const",[346,908,910],{"class":909},"sCcAr"," data",[346,912,913],{"class":505}," =",[346,915,509],{"class":352},[346,917,918,921,924],{"class":348,"line":356},[346,919,920],{"class":352},"  email: ",[346,922,923],{"class":366},"'example@example.com'",[346,925,926],{"class":352},",\n",[346,928,929,932],{"class":348,"line":370},[346,930,931],{"class":352},"  password: ",[346,933,934],{"class":366},"'123456'\n",[346,936,937],{"class":348,"line":539},[346,938,373],{"class":352},[346,940,941],{"class":348,"line":555},[346,942,944],{"emptyLinePlaceholder":943},true,"\n",[346,946,948,950,953,955],{"class":348,"line":947},6,[346,949,906],{"class":505},[346,951,952],{"class":909}," options",[346,954,913],{"class":505},[346,956,509],{"class":352},[346,958,960,963,966],{"class":348,"line":959},7,[346,961,962],{"class":352},"  method: ",[346,964,965],{"class":366},"'POST'",[346,967,926],{"class":352},[346,969,971],{"class":348,"line":970},8,[346,972,973],{"class":352},"  headers: {\n",[346,975,977,980,982],{"class":348,"line":976},9,[346,978,979],{"class":366},"    'Content-Type'",[346,981,363],{"class":352},[346,983,984],{"class":366},"'application\u002Fjson'\n",[346,986,988],{"class":348,"line":987},10,[346,989,990],{"class":352},"  },\n",[346,992,994,997,1000,1003,1006],{"class":348,"line":993},11,[346,995,996],{"class":352},"  body: ",[346,998,999],{"class":909},"JSON",[346,1001,1002],{"class":352},".",[346,1004,1005],{"class":479},"stringify",[346,1007,1008],{"class":352},"(data)\n",[346,1010,1012],{"class":348,"line":1011},12,[346,1013,373],{"class":352},[346,1015,1017],{"class":348,"line":1016},13,[346,1018,944],{"emptyLinePlaceholder":943},[346,1020,1022,1025,1027,1030],{"class":348,"line":1021},14,[346,1023,1024],{"class":479},"fetch",[346,1026,483],{"class":352},[346,1028,1029],{"class":366},"'\u002Fapi\u002Fv1\u002Fauth\u002Fsignin'",[346,1031,1032],{"class":352},", options)\n",[346,1034,1036,1039,1042,1044,1047,1050,1053,1055],{"class":348,"line":1035},15,[346,1037,1038],{"class":352},"  .",[346,1040,1041],{"class":479},"then",[346,1043,483],{"class":352},[346,1045,1046],{"class":492},"response",[346,1048,1049],{"class":505}," =>",[346,1051,1052],{"class":352}," response.",[346,1054,341],{"class":479},[346,1056,1057],{"class":352},"())\n",[346,1059,1061,1063,1065,1067,1070,1072,1075,1078],{"class":348,"line":1060},16,[346,1062,1038],{"class":352},[346,1064,1041],{"class":479},[346,1066,483],{"class":352},[346,1068,1069],{"class":492},"data",[346,1071,1049],{"class":505},[346,1073,1074],{"class":352}," console.",[346,1076,1077],{"class":479},"log",[346,1079,1080],{"class":352},"(data))\n",[346,1082,1084,1086,1089,1091,1094,1096,1098,1100],{"class":348,"line":1083},17,[346,1085,1038],{"class":352},[346,1087,1088],{"class":479},"catch",[346,1090,483],{"class":352},[346,1092,1093],{"class":492},"error",[346,1095,1049],{"class":505},[346,1097,1074],{"class":352},[346,1099,1093],{"class":479},[346,1101,1102],{"class":352},"(error))\n",[12,1104,1105],{},"Response（回應, HTTP Code: 200）：",[337,1107,1109],{"className":339,"code":1108,"language":341,"meta":342,"style":342},"{\n  \"message\": \"登入成功\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTUxNjIzOTAyMn0.KMUFsIDTnFmyG3nMiGM6H9FNFUROf3wh7SmqJp-QV30\"\n}\n",[152,1110,1111,1115,1127,1135],{"__ignoreMap":342},[346,1112,1113],{"class":348,"line":349},[346,1114,353],{"class":352},[346,1116,1117,1120,1122,1125],{"class":348,"line":356},[346,1118,1119],{"class":359},"  \"message\"",[346,1121,363],{"class":352},[346,1123,1124],{"class":366},"\"登入成功\"",[346,1126,926],{"class":352},[346,1128,1129,1131,1133],{"class":348,"line":370},[346,1130,360],{"class":359},[346,1132,363],{"class":352},[346,1134,367],{"class":366},[346,1136,1137],{"class":348,"line":539},[346,1138,373],{"class":352},[65,1140,1141],{},[12,1142,1143,1145,1146],{},[70,1144,72],{},"\n上方 Token 稱之為 JWT Token，如果你對於 JWT Token 不熟悉，可以參考這篇文章：",[1147,1148,1152],"a",{"href":1149,"rel":1150},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20231013\u002F3280561145\u002F",[1151],"nofollow","關於 JWT 驗證",[12,1154,1155],{},"Response（回應, HTTP Code: 400）：",[337,1157,1159],{"className":339,"code":1158,"language":341,"meta":342,"style":342},"{\n  \"message\": \"登入失敗\",\n  \"error\": \"帳號或密碼錯誤\"\n}\n",[152,1160,1161,1165,1176,1186],{"__ignoreMap":342},[346,1162,1163],{"class":348,"line":349},[346,1164,353],{"class":352},[346,1166,1167,1169,1171,1174],{"class":348,"line":356},[346,1168,1119],{"class":359},[346,1170,363],{"class":352},[346,1172,1173],{"class":366},"\"登入失敗\"",[346,1175,926],{"class":352},[346,1177,1178,1181,1183],{"class":348,"line":370},[346,1179,1180],{"class":359},"  \"error\"",[346,1182,363],{"class":352},[346,1184,1185],{"class":366},"\"帳號或密碼錯誤\"\n",[346,1187,1188],{"class":348,"line":539},[346,1189,373],{"class":352},[12,1191,1192],{},"這邊也提供一下 RESTful APIs 與原本的三者比較表格給你參考：",[1194,1195,1196,1214],"table",{},[1197,1198,1199],"thead",{},[1200,1201,1202,1205,1208,1211],"tr",{},[1203,1204],"th",{},[1203,1206,1207],{},"RESTful APIs",[1203,1209,1210],{},"A 公司",[1203,1212,1213],{},"B 公司",[1215,1216,1217,1234,1250,1266,1282,1298,1314,1330,1346,1363],"tbody",{},[1200,1218,1219,1222,1226,1230],{},[1220,1221,583],"td",{},[1220,1223,1224],{},[152,1225,443],{},[1220,1227,1228],{},[152,1229,615],{},[1220,1231,1232],{},[152,1233,679],{},[1200,1235,1236,1238,1242,1246],{},[1220,1237,586],{},[1220,1239,1240],{},[152,1241,447],{},[1220,1243,1244],{},[152,1245,621],{},[1220,1247,1248],{},[152,1249,684],{},[1200,1251,1252,1254,1258,1262],{},[1220,1253,589],{},[1220,1255,1256],{},[152,1257,450],{},[1220,1259,1260],{},[152,1261,627],{},[1220,1263,1264],{},[152,1265,689],{},[1200,1267,1268,1270,1274,1278],{},[1220,1269,592],{},[1220,1271,1272],{},[152,1273,776],{},[1220,1275,1276],{},[152,1277,633],{},[1220,1279,1280],{},[152,1281,694],{},[1200,1283,1284,1286,1290,1294],{},[1220,1285,595],{},[1220,1287,1288],{},[152,1289,781],{},[1220,1291,1292],{},[152,1293,639],{},[1220,1295,1296],{},[152,1297,699],{},[1200,1299,1300,1302,1306,1310],{},[1220,1301,598],{},[1220,1303,1304],{},[152,1305,786],{},[1220,1307,1308],{},[152,1309,645],{},[1220,1311,1312],{},[152,1313,704],{},[1200,1315,1316,1318,1322,1326],{},[1220,1317,601],{},[1220,1319,1320],{},[152,1321,791],{},[1220,1323,1324],{},[152,1325,651],{},[1220,1327,1328],{},[152,1329,709],{},[1200,1331,1332,1334,1338,1342],{},[1220,1333,604],{},[1220,1335,1336],{},[152,1337,796],{},[1220,1339,1340],{},[152,1341,657],{},[1220,1343,1344],{},[152,1345,657],{},[1200,1347,1348,1351,1355,1359],{},[1220,1349,1350],{},"建立商品（後台）",[1220,1352,1353],{},[152,1354,801],{},[1220,1356,1357],{},[152,1358,663],{},[1220,1360,1361],{},[152,1362,718],{},[1200,1364,1365,1368,1372,1376],{},[1220,1366,1367],{},"刪除商品（後台）",[1220,1369,1370],{},[152,1371,806],{},[1220,1373,1374],{},[152,1375,669],{},[1220,1377,1378],{},[152,1379,723],{},[12,1381,1382],{},"透過上述講解與範例，相信你對於為什麼我們會推薦你開 APIs 時，使用 RESTful APIs 的設計風格，應該有一定的概念囉～",[19,1384,1385],{"id":1385},"結語",[12,1387,1388],{},"但這邊最後要特別提醒一件事情，我們這邊所使用的 HTTP Method 並不等於 REST，也不等於 REST 是絕對的規範，這僅僅只是一種約定俗成的方式，只要符合 REST 的設計風格，那這個 APIs 就可以稱為 RESTful APIs。",[12,1390,1391],{},"RESTful 雖然主流，但也不代表唯一解；如果需要複雜查詢或縮減資料傳輸，GraphQL 可能更適合，在某些企業內部會用 SOAP \u002F RPC 等傳統方案哩。",[12,1393,1394],{},"另外，通常來講不會在意 API 的路徑長度，因為 RESTful API 的設計核心理念在於資源的表現，而不是在意路徑的長度，所以不要因為路徑長度而去犧牲資源的表現，導致資源不明確、開發者難以理解哩。",[1396,1397,1398],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":342,"searchDepth":356,"depth":356,"links":1400},[1401,1402,1406,1409,1410],{"id":21,"depth":356,"text":21},{"id":27,"depth":356,"text":28,"children":1403},[1404,1405],{"id":56,"depth":370,"text":57},{"id":164,"depth":370,"text":165},{"id":212,"depth":356,"text":213,"children":1407},[1408],{"id":228,"depth":370,"text":229},{"id":571,"depth":356,"text":572},{"id":1385,"depth":356,"text":1385},"學習經驗","2025-02-25 11:15:47","md","zh-Hant",{},"\u002Fapi-restful-api","10",{"title":6,"description":24},false,"學習經驗\u002F買彩券也能理解-API！從生活案例帶你一次搞懂-RESTful-API",[1422,213,1423],"API","REST",null,"\u002Flearnexp\u002F20250225\u002F3903283315\u002F","UkWKxhSyd6Ail7EDSpDqenX--P2EhcSeiOiqh9kXH3c",{"newer":1428,"older":1432},{"url":1429,"title":1430,"date":1431},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26",{"url":1433,"title":1434,"date":1435},"\u002Fvue\u002F20250216\u002F532019259\u002F","不同於 ref 的 shallowRef 宣告","2025-02-16 19:32:58",[1437,1442,1447],{"url":1438,"title":1439,"date":1440,"readingMinutes":1441},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":1443,"title":1444,"date":1445,"readingMinutes":1446},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":1448,"title":1449,"date":1450,"readingMinutes":1451},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00","6",1784012800210]