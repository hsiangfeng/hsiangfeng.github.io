,[103,1432,180],{"class":113},[103,1434,183],{"class":113},[103,1436,186],{"class":109},[103,1438,189],{"class":123},[103,1440,172],{"class":109},[103,1442,1443,1445,1447],{"class":105,"line":131},[103,1444,177],{"class":109},[103,1446,198],{"class":113},[103,1448,172],{"class":109},[103,1450,1451,1453,1455,1457,1459,1461],{"class":105,"line":203},[103,1452,206],{"class":109},[103,1454,209],{"class":113},[103,1456,212],{"class":113},[103,1458,186],{"class":109},[103,1460,217],{"class":123},[103,1462,172],{"class":109},[103,1464,1465,1467,1469,1471,1473,1475,1477,1479,1481],{"class":105,"line":222},[103,1466,206],{"class":109},[103,1468,209],{"class":113},[103,1470,229],{"class":113},[103,1472,186],{"class":109},[103,1474,234],{"class":123},[103,1476,237],{"class":113},[103,1478,186],{"class":109},[103,1480,242],{"class":123},[103,1482,172],{"class":109},[103,1484,1485,1487,1489,1491,1494,1496,1499,1501,1503],{"class":105,"line":247},[103,1486,206],{"class":109},[103,1488,252],{"class":113},[103,1490,255],{"class":109},[103,1492,1493],{"class":113},"我的第一個",[103,1495,261],{"class":113},[103,1497,1498],{"class":113}," 網頁",[103,1500,267],{"class":109},[103,1502,252],{"class":113},[103,1504,172],{"class":109},[103,1506,1507,1509,1511],{"class":105,"line":274},[103,1508,267],{"class":109},[103,1510,198],{"class":113},[103,1512,172],{"class":109},[103,1514,1515,1517,1519],{"class":105,"line":283},[103,1516,177],{"class":109},[103,1518,288],{"class":113},[103,1520,172],{"class":109},[103,1522,1523,1525,1528,1530,1533,1535,1538,1540,1542],{"class":105,"line":293},[103,1524,206],{"class":109},[103,1526,1527],{"class":113},"h1",[103,1529,255],{"class":109},[103,1531,1532],{"class":113},"歡迎來到我的",[103,1534,261],{"class":113},[103,1536,1537],{"class":113}," 網頁！",[103,1539,267],{"class":109},[103,1541,1527],{"class":113},[103,1543,172],{"class":109},[103,1545,1546,1548,1550,1552,1555,1557,1560,1562,1564],{"class":105,"line":301},[103,1547,206],{"class":109},[103,1549,15],{"class":113},[103,1551,255],{"class":109},[103,1553,1554],{"class":113},"這是一個簡單的",[103,1556,261],{"class":113},[103,1558,1559],{"class":113}," 範例。",[103,1561,267],{"class":109},[103,1563,15],{"class":113},[103,1565,172],{"class":109},[103,1567,1568,1570],{"class":105,"line":314},[103,1569,296],{"class":109},[103,1571,114],{"class":113},[103,1573,1574,1577,1580,1582,1585,1587,1590,1593,1595,1598],{"class":105,"line":327},[103,1575,1576],{"class":113},"      echo",[103,1578,1579],{"class":123}," \"\u003Cp>今天的日期是 \"",[103,1581,1205],{"class":109},[103,1583,1584],{"class":113}," date",[103,1586,345],{"class":127},[103,1588,1589],{"class":123},"\"Y-m-d\"",[103,1591,1592],{"class":127},") ",[103,1594,1340],{"class":109},[103,1596,1597],{"class":123}," \"。\u003C\u002Fp>\"",[103,1599,128],{"class":127},[103,1601,1602],{"class":105,"line":334},[103,1603,419],{"class":109},[103,1605,1606,1608,1610],{"class":105,"line":354},[103,1607,267],{"class":109},[103,1609,288],{"class":113},[103,1611,172],{"class":109},[103,1613,1614,1616,1618],{"class":105,"line":363},[103,1615,267],{"class":109},[103,1617,180],{"class":113},[103,1619,172],{"class":109},[15,1621,1622,1623,1626,1627,1630],{},"這段程式碼展示了如何在 HTML 中嵌入 PHP 程式碼，並輸出當前日期，這讓我們可以在網頁上動態地顯示內容，但這邊要強調一件事情，PHP 的副檔案名稱是 ",[100,1624,1625],{},".php","，而不是 ",[100,1628,1629],{},".html","，這是因為 PHP 程式碼需要在伺服器端執行編譯後，再將結果（HTML）傳送到瀏覽器。",[15,1632,1633,1634,1636],{},"所以早期的網頁開發在切換頁面時，都會有一段「空白」的瞬間閃爍畫面，這是因為當你送出了請求時，PHP 會需要將 ",[100,1635,1625],{}," 檔案中的 PHP 程式碼執行完畢，然後再將結果轉換成 HTML 傳送到瀏覽器，這個過程會有一點延遲。",[15,1638,1639],{},"這也是為什麼後來出現了 AJAX 技術，可以讓我們在不重新載入整個頁面的情況下，動態地更新網頁內容。",[15,1641,1642],{},"那麼大家可能都會好奇，為什麼 PHP 會如此流行與受歡迎，其中有幾個原因：",[1644,1645,1646,1653,1659,1665],"ol",{},[1647,1648,1649,1652],"li",{},[18,1650,1651],{},"簡單易學："," PHP 的語法相對簡單，容易上手，特別是對於初學者來說。",[1647,1654,1655,1658],{},[18,1656,1657],{},"開源免費："," PHP 是一個開源的語言，對於某些企業來講，他們不需要付費昂貴的授權費用就可以使用 PHP 來開發網頁應用程式。",[1647,1660,1661,1664],{},[18,1662,1663],{},"強大的社群支持："," PHP 擁有一個龐大的社群（至少以我認知中，這個社群是非常活躍的）。",[1647,1666,1667,1670],{},[18,1668,1669],{},"本身就是為了網頁開發而設計："," PHP 的設計初衷就是為了網頁開發，所以它有很多內建的功能可以直接使用，例如與資料庫的連接、處理表單等。",[15,1672,1673],{},"每個程式語言都有它的優缺點，PHP 也不意外，只是我認為...",[15,1675,1676],{},"「並不是 PHP 本身不好，而是太過於『容易被用的不好』。」",[15,1678,1679],{},"這是我對 PHP 的一個總結。",[38,1681,1682],{"id":1682},"結語",[15,1684,1685],{},"前陣子回頭看了一下自己當初寫的專題，整個就是黑歷史，程式碼寫得亂七八糟，完全沒有結構可言，甚至還有一堆 SQL Injection 的漏洞，真的是慘不忍睹啊～～～",[38,1687,1688],{"id":1688},"同步更新",[15,1690,1691],{},"本文將同步更新至以下網站：",[1693,1694,1695,1702,1709,1716,1723,1730],"ul",{},[1647,1696,1697],{},[23,1698,1701],{"href":1699,"rel":1700},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[1647,1703,1704],{},[23,1705,1708],{"href":1706,"rel":1707},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[1647,1710,1711],{},[23,1712,1715],{"href":1713,"rel":1714},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[1647,1717,1718],{},[23,1719,1722],{"href":1720,"rel":1721},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[1647,1724,1725],{},[23,1726,1729],{"href":1727,"rel":1728},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[1647,1731,1732],{},[23,1733,1736],{"href":1734,"rel":1735},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",[1738,1739,1740],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);ba