,1345,1346],{"class":121},"\"name\"",[101,1348,1333],{"class":125},[101,1350,1336],{"class":107},[101,1352,1353],{"class":121}," \"\u003Cbr>\"",[101,1355,126],{"class":125},[101,1357,1358],{"class":103,"line":429},[101,1359,882],{"class":125},[101,1361,1362,1364,1366],{"class":103,"line":714},[101,1363,584],{"class":125},[101,1365,378],{"class":107},[101,1367,381],{"class":125},[101,1369,1370,1372,1375],{"class":103,"line":730},[101,1371,574],{"class":111},[101,1373,1374],{"class":121}," \"0 結果\"",[101,1376,126],{"class":125},[101,1378,1379],{"class":103,"line":735},[101,1380,602],{"class":125},[101,1382,1383],{"class":103,"line":740},[101,1384,1385],{"class":491},"\u002F\u002F 關閉連接\n",[101,1387,1388,1391,1393,1396],{"class":103,"line":746},[101,1389,1390],{"class":125},"$conn",[101,1392,854],{"class":107},[101,1394,1395],{"class":752},"close",[101,1397,973],{"class":125},[101,1399,1400],{"class":103,"line":759},[101,1401,132],{"class":107},[17,1403,1404],{},"這段程式碼展示了如何連接到 MySQL 資料庫，並執行一個簡單的 SQL 查詢，然後輸出查詢結果。",[17,1406,1407],{},"前面也有示範過 PHP 也可以嵌入到 HTML 中，這讓 PHP 成為一個非常適合用來開發網頁應用程式的語言。",[91,1409,1411],{"className":93,"code":1410,"language":95,"meta":96,"style":96},"\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>我的第一個 PHP 網頁\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>歡迎來到我的 PHP 網頁！\u003C\u002Fh1>\n  \u003Cp>這是一個簡單的 PHP 範例。\u003C\u002Fp>\n  \u003C?php\n      echo \"\u003Cp>今天的日期是 \" . date(\"Y-m-d\") . \"。\u003C\u002Fp>\";\n  ?>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n",[98,1412,1413,1423,1437,1445,1459,1479,1501,1509,1517,1540,1562,1568,1596,1600,1608],{"__ignoreMap":96},[101,1414,1415,1417,1419,1421],{"class":103,"line":104},[101,1416,161],{"class":107},[101,1418,164],{"class":111},[101,1420,167],{"class":111},[101,1422,170],{"class":107},[101,1424,1425,1427,1429,1431,1433,1435],{"class":103,"line":115},[101,1426,175],{"class":107},[101,1428,178],{"class":111},[101,1430,181],{"class":111},[101,1432,184],{"class":107},[101,1434,187],{"class":121},[101,1436,170],{"class":107},[101,1438,1439,1441,1443],{"class":103,"line":129},[101,1440,175],{"class":107},[101,1442,196],{"class":111},[101,1444,170],{"class":107},[101,1446,1447,1449,1451,1453,1455,1457],{"class":103,"line":201},[101,1448,204],{"class":107},[101,1450,207],{"class":111},[101,1452,210],{"class":111},[101,1454,184],{"class":107},[101,1456,215],{"class":121},[101,1458,170],{"class":107},[101,1460,1461,1463,1465,1467,1469,1471,1473,1475,1477],{"class":103,"line":220},[101,1462,204],{"class":107},[101,1464,207],{"class":111},[101,1466,227],{"class":111},[101,1468,184],{"class":107},[101,1470,232],{"class":121},[101,1472,235],{"class":111},[101,1474,184],{"class":107},[101,1476,240],{"class":121},[101,1478,170],{"class":107},[101,1480,1481,1483,1485,1487,1490,1492,1495,1497,1499],{"class":103,"line":245},[101,1482,204],{"class":107},[101,1484,250],{"class":111},[101,1486,253],{"class":107},[101,1488,1489],{"class":111},"我的第一個",[101,1491,259],{"class":111},[101,1493,1494],{"class":111}," 網頁",[101,1496,265],{"class":107},[101,1498,250],{"class":111},[101,1500,170],{"class":107},[101,1502,1503,1505,1507],{"class":103,"line":272},[101,1504,265],{"class":107},[101,1506,196],{"class":111},[101,1508,170],{"class":107},[101,1510,1511,1513,1515],{"class":103,"line":281},[101,1512,175],{"class":107},[101,1514,286],{"class":111},[101,1516,170],{"class":107},[101,1518,1519,1521,1524,1526,1529,1531,1534,1536,1538],{"class":103,"line":291},[101,1520,204],{"class":107},[101,1522,1523],{"class":111},"h1",[101,1525,253],{"class":107},[101,1527,1528],{"class":111},"歡迎來到我的",[101,1530,259],{"class":111},[101,1532,1533],{"class":111}," 網頁！",[101,1535,265],{"class":107},[101,1537,1523],{"class":111},[101,1539,170],{"class":107},[101,1541,1542,1544,1546,1548,1551,1553,1556,1558,1560],{"class":103,"line":299},[101,1543,204],{"class":107},[101,1545,17],{"class":111},[101,1547,253],{"class":107},[101,1549,1550],{"class":111},"這是一個簡單的",[101,1552,259],{"class":111},[101,1554,1555],{"class":111}," 範例。",[101,1557,265],{"class":107},[101,1559,17],{"class":111},[101,1561,170],{"class":107},[101,1563,1564,1566],{"class":103,"line":312},[101,1565,294],{"class":107},[101,1567,112],{"class":111},[101,1569,1570,1573,1576,1578,1581,1583,1586,1589,1591,1594],{"class":103,"line":325},[101,1571,1572],{"class":111},"      echo",[101,1574,1575],{"class":121}," \"\u003Cp>今天的日期是 \"",[101,1577,1201],{"class":107},[101,1579,1580],{"class":111}," date",[101,1582,343],{"class":125},[101,1584,1585],{"class":121},"\"Y-m-d\"",[101,1587,1588],{"class":125},") ",[101,1590,1336],{"class":107},[101,1592,1593],{"class":121}," \"。\u003C\u002Fp>\"",[101,1595,126],{"class":125},[101,1597,1598],{"class":103,"line":332},[101,1599,417],{"class":107},[101,1601,1602,1604,1606],{"class":103,"line":352},[101,1603,265],{"class":107},[101,1605,286],{"class":111},[101,1607,170],{"class":107},[101,1609,1610,1612,1614],{"class":103,"line":361},[101,1611,265],{"class":107},[101,1613,178],{"class":111},[101,1615,170],{"class":107},[17,1617,1618,1619,1622,1623,1626],{},"這段程式碼展示了如何在 HTML 中嵌入 PHP 程式碼，並輸出當前日期，這讓我們可以在網頁上動態地顯示內容，但這邊要強調一件事情，PHP 的副檔案名稱是 ",[98,1620,1621],{},".php","，而不是 ",[98,1624,1625],{},".html","，這是因為 PHP 程式碼需要在伺服器端執行編譯後，再將結果（HTML）傳送到瀏覽器。",[17,1628,1629,1630,1632],{},"所以早期的網頁開發在切換頁面時，都會有一段「空白」的瞬間閃爍畫面，這是因為當你送出了請求時，PHP 會需要將 ",[98,1631,1621],{}," 檔案中的 PHP 程式碼執行完畢，然後再將結果轉換成 HTML 傳送到瀏覽器，這個過程會有一點延遲。",[17,1634,1635],{},"這也是為什麼後來出現了 AJAX 技術，可以讓我們在不重新載入整個頁面的情況下，動態地更新網頁內容。",[17,1637,1638],{},"那麼大家可能都會好奇，為什麼 PHP 會如此流行與受歡迎，其中有幾個原因：",[1640,1641,1642,1649,1655,1661],"ol",{},[1643,1644,1645,1648],"li",{},[52,1646,1647],{},"簡單易學："," PHP 的語法相對簡單，容易上手，特別是對於初學者來說。",[1643,1650,1651,1654],{},[52,1652,1653],{},"開源免費："," PHP 是一個開源的語言，對於某些企業來講，他們不需要付費昂貴的授權費用就可以使用 PHP 來開發網頁應用程式。",[1643,1656,1657,1660],{},[52,1658,1659],{},"強大的社群支持："," PHP 擁有一個龐大的社群（至少以我認知中，這個社群是非常活躍的）。",[1643,1662,1663,1666],{},[52,1664,1665],{},"本身就是為了網頁開發而設計："," PHP 的設計初衷就是為了網頁開發，所以它有很多內建的功能可以直接使用，例如與資料庫的連接、處理表單等。",[17,1668,1669],{},"每個程式語言都有它的優缺點，PHP 也不意外，只是我認為...",[17,1671,1672],{},"「並不是 PHP 本身不好，而是太過於『容易被用的不好』。」",[17,1674,1675],{},"這是我對 PHP 的一個總結。",[36,1677,1678],{"id":1678},"結語",[17,1680,1681],{},"前陣子回頭看了一下自己當初寫的專題，整個就是黑歷史，程式碼寫得亂七八糟，完全沒有結構可言，甚至還有一堆 SQL Injection 的漏洞，真的是慘不忍睹啊～～～",[36,1683,1684],{"id":1684},"同步更新",[17,1686,1687],{},"本文將同步更新至以下網站：",[1689,1690,1691,1698,1705,1712,1719,1726],"ul",{},[1643,1692,1693],{},[21,1694,1697],{"href":1695,"rel":1696},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[25],"是 Ray 不是 Array",[1643,1699,1700],{},[21,1701,1704],{"href":1702,"rel":1703},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[25],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[1643,1706,1707],{},[21,1708,1711],{"href":1709,"rel":1710},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[25],"Threads - 時常會聊軟實力",[1643,1713,1714],{},[21,1715,1718],{"href":1716,"rel":1717},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[25],"Facebook - 搞怪迷因分享",[1643,1720,1721],{},[21,1722,1725],{"href":1723,"rel":1724},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[25],"Instagram - 搞怪迷因分享 + 軟實力",[1643,1727,1728],{},[21,1729,1732],{"href":1730,"rel":1731},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[25],"Portaly - 入口主頁",[1734,1735,1736],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F6