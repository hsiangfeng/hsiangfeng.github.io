[{"data":1,"prerenderedAt":1792},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":3,"page:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":4,"alt:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":3,"prev-next:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":1768,"related:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":1777},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F23\u002Fday-23-php-huh-an-elephant\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1747,"date":1748,"description":1749,"extension":1750,"lang":1751,"meta":1752,"navigation":330,"path":1753,"readingMinutes":1754,"seo":1755,"standalone":1756,"stem":1757,"tags":1758,"tldr":1764,"updated":1765,"url":1766,"__hash__":1767},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 23】PHP？蛤？一隻大象？.md","【Day 23】PHP？蛤？一隻大象？","2062222122",{"type":9,"value":10,"toc":1741},"minimark",[11,30,37,41,44,47,50,57,60,63,66,69,77,80,83,86,89,92,135,148,151,154,438,441,444,447,450,453,456,459,462,468,472,475,478,1074,1083,1086,1089,1406,1409,1412,1620,1631,1637,1640,1643,1671,1674,1677,1680,1683,1686,1689,1692,1737],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"PHP？蛤？一隻大象？","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday23\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8809_47_18.png",[38,39,35],"h2",{"id":40},"php蛤一隻大象",[15,42,43],{},"在 C 語言的戰場上，我曾經被指標這個最終 Boss 打得落花流水，只能無奈退場。那段日子裡，我幾乎放下程式，只偶爾靠寫些遊戲腳本來刷一點存在感。",[15,45,46],{},"直到大學時期，我重新踏上程式這條路，而這次迎接我的，不再是讓我頭痛的指標，來了一位新的夥伴 —— PHP: Hypertext Preprocessor（PHP：超文本預處理器）。",[15,48,49],{},"為什麼會突然又接觸程式語言呢？",[15,51,52,53,56],{},"因為當初選擇了資訊管理系，而此系畢業條件之一就是 ",[18,54,55],{},"「專題製作」"," ，說實話，剛聽到的時候，心理壓力很大，畢竟要獨立做出一個完整作品，聽起來就不是件簡單的事。",[15,58,59],{},"但在接觸到 PHP 課程時，我發現做 Web Application（網頁應用程式） 不僅有趣，還能立即看到畫面變化，對當時的我來說特別新鮮。",[15,61,62],{},"當時有一門叫做「程式語言設計」的大一必修課。授課老師相當嚴格，但不得不說，他的教學非常扎實，也正是他，成為了把我正式帶入程式設計世界的啟蒙老師。",[15,64,65],{},"「來！今天我們要上的課叫做『網頁程式設計』，在這門課裡，大家要用一個程式語言來完成一個簡單的網頁應用程式。」老師一邊說一邊在白板上寫下那幾個字母：PHP，以及它的全名。",[15,67,68],{},"你可能會想：「大學電腦課的你，應該還是在打遊戲吧？」抱歉，這次你猜錯了。因為大學開始後我很快就發現 —— 在電腦課偷打遊戲，輸的可不只是分數，還可能是未來。\n所以我乖乖收起遊戲，開始認真聽課，不然就等著被當掉 QQ。",[12,70,71],{},[15,72,73,76],{},[18,74,75],{},"Note","\n大學的必修課程如果被當掉的話，就必須要花時間、金錢重修，而且也會延後畢業時間。",[15,78,79],{},"「大家先安裝 XAMPP，因為我們接下來要用 Apache 伺服器來執行 PHP 程式碼。」老師邊操作邊解說。",[15,81,82],{},"「XAMPP 是一個跨平台的網頁伺服器套件，裡面包含了 Apache、MySQL、PHP 和 Perl 等組件。」",[15,84,85],{},"接著他又說：「再打開 phpDesigner 8，這是一個專門用來編輯 PHP 程式碼的開發工具。」",[15,87,88],{},"對我來說，這是第一次接觸專門的 IDE，畢竟以前寫程式時都還在用 Notepad++ 或純文字編輯器（有點年代感）。",[15,90,91],{},"最後老師示範：「現在我們來寫一個簡單的 PHP 程式，讓它在瀏覽器輸出 Hello, World!。」",[93,94,99],"pre",{"className":95,"code":96,"language":97,"meta":98,"style":98},"language-php shiki shiki-themes github-dark-high-contrast","\u003C?php\necho \"Hello, World!\";\n?>\n","php","",[100,101,102,115,129],"code",{"__ignoreMap":98},[103,104,107,111],"span",{"class":105,"line":106},"line",1,[103,108,110],{"class":109},"sWyjQ","\u003C?",[103,112,114],{"class":113},"sCcAr","php\n",[103,116,118,121,125],{"class":105,"line":117},2,[103,119,120],{"class":113},"echo",[103,122,124],{"class":123},"sTRMh"," \"Hello, World!\"",[103,126,128],{"class":127},"sMAXC",";\n",[103,130,132],{"class":105,"line":131},3,[103,133,134],{"class":109},"?>\n",[15,136,137,138,141,142,144,145,147],{},"不得不說，當時我真的覺得這沒什麼特別的，畢竟之前寫過 C 語言的 ",[100,139,140],{},"printf"," ，所以覺得 PHP 的 ",[100,143,120],{}," 其實跟 ",[100,146,140],{}," 沒啥差別，但真正讓我眼睛一亮的，是老師接下來的介紹。",[15,149,150],{},"「PHP 是一種伺服器端的腳本語言，可以嵌入到 HTML 中，還能和資料庫互動。」老師一邊解說語法，一邊現場敲範例程式碼。",[15,152,153],{},"而我坐在台下心裡默默想著：\n「咦？程式還能跟資料庫對話？這也太酷了吧！」",[93,155,157],{"className":95,"code":156,"language":97,"meta":98,"style":98},"\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>第一個 PHP 程式\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003C?php\n      $username = \"admin\";\n      $password = \"password123\";\n\n      $connection = mysqli_connect(\"localhost\", $username, $password);\n      if ($connection) {\n          echo \"\u003Cdiv>成功連接到 MySQL 資料庫！\u003C\u002Fdiv>\";\n      } else {\n          echo \"\u003Cdiv>無法連接到 MySQL 資料庫！\u003C\u002Fdiv>\";\n      }\n\n      mysqli_close($connection);\n  ?>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n",[100,158,159,173,192,201,220,245,272,281,291,299,312,325,332,352,361,372,384,394,400,405,414,420,429],{"__ignoreMap":98},[103,160,161,164,167,170],{"class":105,"line":106},[103,162,163],{"class":109},"\u003C!",[103,165,166],{"class":113},"DOCTYPE",[103,168,169],{"class":113}," html",[103,171,172],{"class":109},">\n",[103,174,175,178,181,184,187,190],{"class":105,"line":117},[103,176,177],{"class":109},"\u003C",[103,179,180],{"class":113},"html",[103,182,183],{"class":113}," lang",[103,185,186],{"class":109},"=",[103,188,189],{"class":123},"\"zh-Hant-TW\"",[103,191,172],{"class":109},[103,193,194,196,199],{"class":105,"line":131},[103,195,177],{"class":109},[103,197,198],{"class":113},"head",[103,200,172],{"class":109},[103,202,204,207,210,213,215,218],{"class":105,"line":203},4,[103,205,206],{"class":109},"  \u003C",[103,208,209],{"class":113},"meta",[103,211,212],{"class":113}," charset",[103,214,186],{"class":109},[103,216,217],{"class":123},"\"UTF-8\"",[103,219,172],{"class":109},[103,221,223,225,227,230,232,235,238,240,243],{"class":105,"line":222},5,[103,224,206],{"class":109},[103,226,209],{"class":113},[103,228,229],{"class":113}," name",[103,231,186],{"class":109},[103,233,234],{"class":123},"\"viewport\"",[103,236,237],{"class":113}," content",[103,239,186],{"class":109},[103,241,242],{"class":123},"\"width=device-width, initial-scale=1.0\"",[103,244,172],{"class":109},[103,246,248,250,253,256,259,262,265,268,270],{"class":105,"line":247},6,[103,249,206],{"class":109},[103,251,252],{"class":113},"title",[103,254,255],{"class":109},">",[103,257,258],{"class":113},"第一個",[103,260,261],{"class":113}," PHP",[103,263,264],{"class":113}," 程式",[103,266,267],{"class":109},"\u003C\u002F",[103,269,252],{"class":113},[103,271,172],{"class":109},[103,273,275,277,279],{"class":105,"line":274},7,[103,276,267],{"class":109},[103,278,198],{"class":113},[103,280,172],{"class":109},[103,282,284,286,289],{"class":105,"line":283},8,[103,285,177],{"class":109},[103,287,288],{"class":113},"body",[103,290,172],{"class":109},[103,292,294,297],{"class":105,"line":293},9,[103,295,296],{"class":109},"  \u003C?",[103,298,114],{"class":113},[103,300,302,305,307,310],{"class":105,"line":301},10,[103,303,304],{"class":127},"      $username ",[103,306,186],{"class":109},[103,308,309],{"class":123}," \"admin\"",[103,311,128],{"class":127},[103,313,315,318,320,323],{"class":105,"line":314},11,[103,316,317],{"class":127},"      $password ",[103,319,186],{"class":109},[103,321,322],{"class":123}," \"password123\"",[103,324,128],{"class":127},[103,326,328],{"class":105,"line":327},12,[103,329,331],{"emptyLinePlaceholder":330},true,"\n",[103,333,335,338,340,343,346,349],{"class":105,"line":334},13,[103,336,337],{"class":127},"      $connection ",[103,339,186],{"class":109},[103,341,342],{"class":113}," mysqli_connect",[103,344,345],{"class":127},"(",[103,347,348],{"class":123},"\"localhost\"",[103,350,351],{"class":127},", $username, $password);\n",[103,353,355,358],{"class":105,"line":354},14,[103,356,357],{"class":109},"      if",[103,359,360],{"class":127}," ($connection) {\n",[103,362,364,367,370],{"class":105,"line":363},15,[103,365,366],{"class":113},"          echo",[103,368,369],{"class":123}," \"\u003Cdiv>成功連接到 MySQL 資料庫！\u003C\u002Fdiv>\"",[103,371,128],{"class":127},[103,373,375,378,381],{"class":105,"line":374},16,[103,376,377],{"class":127},"      } ",[103,379,380],{"class":109},"else",[103,382,383],{"class":127}," {\n",[103,385,387,389,392],{"class":105,"line":386},17,[103,388,366],{"class":113},[103,390,391],{"class":123}," \"\u003Cdiv>無法連接到 MySQL 資料庫！\u003C\u002Fdiv>\"",[103,393,128],{"class":127},[103,395,397],{"class":105,"line":396},18,[103,398,399],{"class":127},"      }\n",[103,401,403],{"class":105,"line":402},19,[103,404,331],{"emptyLinePlaceholder":330},[103,406,408,411],{"class":105,"line":407},20,[103,409,410],{"class":113},"      mysqli_close",[103,412,413],{"class":127},"($connection);\n",[103,415,417],{"class":105,"line":416},21,[103,418,419],{"class":109},"  ?>\n",[103,421,423,425,427],{"class":105,"line":422},22,[103,424,267],{"class":109},[103,426,288],{"class":113},[103,428,172],{"class":109},[103,430,432,434,436],{"class":105,"line":431},23,[103,433,267],{"class":109},[103,435,180],{"class":113},[103,437,172],{"class":109},[15,439,440],{},"「這段程式碼會連接到 MySQL 資料庫，並且輸出連接成功或失敗的訊息。」老師解釋道。",[15,442,443],{},"沒錯，這就是我第一次接觸 PHP 的契機，沒想到吧？\n當時我覺得 PHP 超厲害，不只可以直接跟資料庫互動，還能嵌入到 HTML 中，重點是能即時把結果呈現在畫面上，甚至還能跟使用者互動。",[15,445,446],{},"相比之下，C 語言就顯得有些單調，頂多就是在黑底白字的視窗裡輸出幾行文字，完全沒有什麼成就感。",[15,448,449],{},"也因為這個契機，我決定請這位老師擔任我的專題指導老師，從那一刻起，我正式踏上了專題製作之路。",[15,451,452],{},"專題成品算是順利出爐，也拿到很好成績，甚至被系上點名想拿去當招生教材範本，但過程真的是滿滿血淚。",[15,454,455],{},"程式過程慘，但團隊合作更慘，我的組員們，擺爛、不合群、狀況外一堆，組員 5 人，但真正在做的只有 2 人（說真的，Debug 比吵架容易多了 XD）。",[15,457,458],{},"更別提那位嚴格到爆的指導老師，雖然把我磨得更強，可是壓力也大到快得心理陰影。",[15,460,461],{},"只能說 —— 專題結束時交出去的不只是作品，還有我的半條命 XD。",[15,463,464],{},[33,465],{"alt":466,"src":467},"半條命","https:\u002F\u002Fmedia1.tenor.com\u002Fm\u002F7IKGRY1nLM0AAAAC\u002Face-attorney-penalty.gif",[38,469,471],{"id":470},"php-專為網頁設計而生的語言","PHP 專為網頁設計而生的語言",[15,473,474],{},"PHP 本身就是為了網頁程式開發而設計的語言，對一般程式設計師來說，相對來講是很容易快速上手的，為什麼這麼說呢？",[15,476,477],{},"讓我們來看一下幾個基本的 PHP 語法：",[93,479,481],{"className":95,"code":480,"language":97,"meta":98,"style":98},"\u003C?php\n\u002F\u002F 宣告變數\n$name = \"Ray\";\n$age = 30;\n\n\u002F\u002F 輸出變數\necho \"我的名字是 $name，我的年齡是 $age 歲。\";\n\n\u002F\u002F 條件判斷\nif ($age >= 18) {\n    echo \"我已經成年了。\";\n} else {\n    echo \"我還未成年。\";\n}\n\n\u002F\u002F 迴圈\nfor ($i = 0; $i \u003C 5; $i++) {\n    echo \"這是第 $i 次迴圈。\";\n}\n\n\u002F\u002F 陣列\n$fruits = array(\"蘋果\", \"香蕉\", \"橘子\");\nforeach ($fruits as $fruit) {\n    echo \"我喜歡吃 $fruit。\";\n}\n\n\u002F\u002F 函式\nfunction greet($name) {\n    return \"你好，$name！\";\n}\necho greet(\"Ray\");\n\n\u002F\u002F 物件導向\nclass Person {\n    public $name;\n    public $age; \n    public function __construct($name, $age) {\n        $this->name = $name;\n        $this->age = $age;\n    }\n    public function introduce() {\n        return \"我的名字是 $this->name，我的年齡是 $this->age 歲。\";\n    }\n}\n$person = new Person(\"Ray\", 30);\necho $person->introduce();\n\n\u002F\u002F 例外處理\ntry {\n    $result = 10 \u002F 0; \u002F\u002F 這會引發除以零\n} catch (DivisionByZeroError $e) {\n    echo \"錯誤：除以零！\";\n} finally {\n    echo \"這是 finally 區塊，無論如何都會執行。\";\n}\n?>\n",[100,482,483,489,495,507,519,523,528,546,550,555,572,582,591,600,605,609,614,643,658,662,666,671,700,714,730,735,740,746,759,775,780,794,799,805,817,826,834,848,864,879,885,898,926,931,936,960,976,981,987,995,1017,1034,1044,1054,1064,1069],{"__ignoreMap":98},[103,484,485,487],{"class":105,"line":106},[103,486,110],{"class":109},[103,488,114],{"class":113},[103,490,491],{"class":105,"line":117},[103,492,494],{"class":493},"sQrFR","\u002F\u002F 宣告變數\n",[103,496,497,500,502,505],{"class":105,"line":131},[103,498,499],{"class":127},"$name ",[103,501,186],{"class":109},[103,503,504],{"class":123}," \"Ray\"",[103,506,128],{"class":127},[103,508,509,512,514,517],{"class":105,"line":203},[103,510,511],{"class":127},"$age ",[103,513,186],{"class":109},[103,515,516],{"class":113}," 30",[103,518,