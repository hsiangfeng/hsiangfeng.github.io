[{"data":1,"prerenderedAt":1788},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":3,"page:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":4,"alt:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":3,"prev-next:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":1764,"related:\u002Flearnexp\u002F20250923\u002F2062222122\u002F":1773},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F23\u002Fday-23-php-huh-an-elephant\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1743,"date":1744,"description":1745,"extension":1746,"lang":1747,"meta":1748,"navigation":328,"path":1749,"readingMinutes":1750,"seo":1751,"standalone":1752,"stem":1753,"tags":1754,"tldr":1760,"updated":1761,"url":1762,"__hash__":1763},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 23】PHP？蛤？一隻大象？.md","【Day 23】PHP？蛤？一隻大象？","2062222122",{"type":9,"value":10,"toc":1737},"minimark",[11,28,35,39,42,45,48,56,59,62,65,68,75,78,81,84,87,90,133,146,149,152,436,439,442,445,448,451,454,457,460,466,470,473,476,1072,1079,1082,1085,1402,1405,1408,1616,1627,1633,1636,1639,1667,1670,1673,1676,1679,1682,1685,1688,1733],[12,13,16],"callout",{"title":14,"type":15},"Warning","warning",[17,18,19,20,27],"p",{},"嗨！這系列文章已經重新整理、改寫成書，目前在 ",[21,22,26],"a",{"href":23,"rel":24},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[25],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[17,29,30],{},[31,32],"img",{"alt":33,"src":34},"PHP？蛤？一隻大象？","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday23\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8809_47_18.png",[36,37,33],"h2",{"id":38},"php蛤一隻大象",[17,40,41],{},"在 C 語言的戰場上，我曾經被指標這個最終 Boss 打得落花流水，只能無奈退場。那段日子裡，我幾乎放下程式，只偶爾靠寫些遊戲腳本來刷一點存在感。",[17,43,44],{},"直到大學時期，我重新踏上程式這條路，而這次迎接我的，不再是讓我頭痛的指標，來了一位新的夥伴 —— PHP: Hypertext Preprocessor（PHP：超文本預處理器）。",[17,46,47],{},"為什麼會突然又接觸程式語言呢？",[17,49,50,51,55],{},"因為當初選擇了資訊管理系，而此系畢業條件之一就是 ",[52,53,54],"strong",{},"「專題製作」"," ，說實話，剛聽到的時候，心理壓力很大，畢竟要獨立做出一個完整作品，聽起來就不是件簡單的事。",[17,57,58],{},"但在接觸到 PHP 課程時，我發現做 Web Application（網頁應用程式） 不僅有趣，還能立即看到畫面變化，對當時的我來說特別新鮮。",[17,60,61],{},"當時有一門叫做「程式語言設計」的大一必修課。授課老師相當嚴格，但不得不說，他的教學非常扎實，也正是他，成為了把我正式帶入程式設計世界的啟蒙老師。",[17,63,64],{},"「來！今天我們要上的課叫做『網頁程式設計』，在這門課裡，大家要用一個程式語言來完成一個簡單的網頁應用程式。」老師一邊說一邊在白板上寫下那幾個字母：PHP，以及它的全名。",[17,66,67],{},"你可能會想：「大學電腦課的你，應該還是在打遊戲吧？」抱歉，這次你猜錯了。因為大學開始後我很快就發現 —— 在電腦課偷打遊戲，輸的可不只是分數，還可能是未來。\n所以我乖乖收起遊戲，開始認真聽課，不然就等著被當掉 QQ。",[12,69,72],{"title":70,"type":71},"Note","note",[17,73,74],{},"大學的必修課程如果被當掉的話，就必須要花時間、金錢重修，而且也會延後畢業時間。",[17,76,77],{},"「大家先安裝 XAMPP，因為我們接下來要用 Apache 伺服器來執行 PHP 程式碼。」老師邊操作邊解說。",[17,79,80],{},"「XAMPP 是一個跨平台的網頁伺服器套件，裡面包含了 Apache、MySQL、PHP 和 Perl 等組件。」",[17,82,83],{},"接著他又說：「再打開 phpDesigner 8，這是一個專門用來編輯 PHP 程式碼的開發工具。」",[17,85,86],{},"對我來說，這是第一次接觸專門的 IDE，畢竟以前寫程式時都還在用 Notepad++ 或純文字編輯器（有點年代感）。",[17,88,89],{},"最後老師示範：「現在我們來寫一個簡單的 PHP 程式，讓它在瀏覽器輸出 Hello, World!。」",[91,92,97],"pre",{"className":93,"code":94,"language":95,"meta":96,"style":96},"language-php shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C?php\necho \"Hello, World!\";\n?>\n","php","",[98,99,100,113,127],"code",{"__ignoreMap":96},[101,102,105,109],"span",{"class":103,"line":104},"line",1,[101,106,108],{"class":107},"sOudu","\u003C?",[101,110,112],{"class":111},"stw71","php\n",[101,114,116,119,123],{"class":103,"line":115},2,[101,117,118],{"class":111},"echo",[101,120,122],{"class":121},"sWayO"," \"Hello, World!\"",[101,124,126],{"class":125},"s8XSl",";\n",[101,128,130],{"class":103,"line":129},3,[101,131,132],{"class":107},"?>\n",[17,134,135,136,139,140,142,143,145],{},"不得不說，當時我真的覺得這沒什麼特別的，畢竟之前寫過 C 語言的 ",[98,137,138],{},"printf"," ，所以覺得 PHP 的 ",[98,141,118],{}," 其實跟 ",[98,144,138],{}," 沒啥差別，但真正讓我眼睛一亮的，是老師接下來的介紹。",[17,147,148],{},"「PHP 是一種伺服器端的腳本語言，可以嵌入到 HTML 中，還能和資料庫互動。」老師一邊解說語法，一邊現場敲範例程式碼。",[17,150,151],{},"而我坐在台下心裡默默想著：\n「咦？程式還能跟資料庫對話？這也太酷了吧！」",[91,153,155],{"className":93,"code":154,"language":95,"meta":96,"style":96},"\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>第一個 PHP 程式\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003C?php\n      $username = \"admin\";\n      $password = \"password123\";\n\n      $connection = mysqli_connect(\"localhost\", $username, $password);\n      if ($connection) {\n          echo \"\u003Cdiv>成功連接到 MySQL 資料庫！\u003C\u002Fdiv>\";\n      } else {\n          echo \"\u003Cdiv>無法連接到 MySQL 資料庫！\u003C\u002Fdiv>\";\n      }\n\n      mysqli_close($connection);\n  ?>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n",[98,156,157,171,190,199,218,243,270,279,289,297,310,323,330,350,359,370,382,392,398,403,412,418,427],{"__ignoreMap":96},[101,158,159,162,165,168],{"class":103,"line":104},[101,160,161],{"class":107},"\u003C!",[101,163,164],{"class":111},"DOCTYPE",[101,166,167],{"class":111}," html",[101,169,170],{"class":107},">\n",[101,172,173,176,179,182,185,188],{"class":103,"line":115},[101,174,175],{"class":107},"\u003C",[101,177,178],{"class":111},"html",[101,180,181],{"class":111}," lang",[101,183,184],{"class":107},"=",[101,186,187],{"class":121},"\"zh-Hant-TW\"",[101,189,170],{"class":107},[101,191,192,194,197],{"class":103,"line":129},[101,193,175],{"class":107},[101,195,196],{"class":111},"head",[101,198,170],{"class":107},[101,200,202,205,208,211,213,216],{"class":103,"line":201},4,[101,203,204],{"class":107},"  \u003C",[101,206,207],{"class":111},"meta",[101,209,210],{"class":111}," charset",[101,212,184],{"class":107},[101,214,215],{"class":121},"\"UTF-8\"",[101,217,170],{"class":107},[101,219,221,223,225,228,230,233,236,238,241],{"class":103,"line":220},5,[101,222,204],{"class":107},[101,224,207],{"class":111},[101,226,227],{"class":111}," name",[101,229,184],{"class":107},[101,231,232],{"class":121},"\"viewport\"",[101,234,235],{"class":111}," content",[101,237,184],{"class":107},[101,239,240],{"class":121},"\"width=device-width, initial-scale=1.0\"",[101,242,170],{"class":107},[101,244,246,248,251,254,257,260,263,266,268],{"class":103,"line":245},6,[101,247,204],{"class":107},[101,249,250],{"class":111},"title",[101,252,253],{"class":107},">",[101,255,256],{"class":111},"第一個",[101,258,259],{"class":111}," PHP",[101,261,262],{"class":111}," 程式",[101,264,265],{"class":107},"\u003C\u002F",[101,267,250],{"class":111},[101,269,170],{"class":107},[101,271,273,275,277],{"class":103,"line":272},7,[101,274,265],{"class":107},[101,276,196],{"class":111},[101,278,170],{"class":107},[101,280,282,284,287],{"class":103,"line":281},8,[101,283,175],{"class":107},[101,285,286],{"class":111},"body",[101,288,170],{"class":107},[101,290,292,295],{"class":103,"line":291},9,[101,293,294],{"class":107},"  \u003C?",[101,296,112],{"class":111},[101,298,300,303,305,308],{"class":103,"line":299},10,[101,301,302],{"class":125},"      $username ",[101,304,184],{"class":107},[101,306,307],{"class":121}," \"admin\"",[101,309,126],{"class":125},[101,311,313,316,318,321],{"class":103,"line":312},11,[101,314,315],{"class":125},"      $password ",[101,317,184],{"class":107},[101,319,320],{"class":121}," \"password123\"",[101,322,126],{"class":125},[101,324,326],{"class":103,"line":325},12,[101,327,329],{"emptyLinePlaceholder":328},true,"\n",[101,331,333,336,338,341,344,347],{"class":103,"line":332},13,[101,334,335],{"class":125},"      $connection ",[101,337,184],{"class":107},[101,339,340],{"class":111}," mysqli_connect",[101,342,343],{"class":125},"(",[101,345,346],{"class":121},"\"localhost\"",[101,348,349],{"class":125},", $username, $password);\n",[101,351,353,356],{"class":103,"line":352},14,[101,354,355],{"class":107},"      if",[101,357,358],{"class":125}," ($connection) {\n",[101,360,362,365,368],{"class":103,"line":361},15,[101,363,364],{"class":111},"          echo",[101,366,367],{"class":121}," \"\u003Cdiv>成功連接到 MySQL 資料庫！\u003C\u002Fdiv>\"",[101,369,126],{"class":125},[101,371,373,376,379],{"class":103,"line":372},16,[101,374,375],{"class":125},"      } ",[101,377,378],{"class":107},"else",[101,380,381],{"class":125}," {\n",[101,383,385,387,390],{"class":103,"line":384},17,[101,386,364],{"class":111},[101,388,389],{"class":121}," \"\u003Cdiv>無法連接到 MySQL 資料庫！\u003C\u002Fdiv>\"",[101,391,126],{"class":125},[101,393,395],{"class":103,"line":394},18,[101,396,397],{"class":125},"      }\n",[101,399,401],{"class":103,"line":400},19,[101,402,329],{"emptyLinePlaceholder":328},[101,404,406,409],{"class":103,"line":405},20,[101,407,408],{"class":111},"      mysqli_close",[101,410,411],{"class":125},"($connection);\n",[101,413,415],{"class":103,"line":414},21,[101,416,417],{"class":107},"  ?>\n",[101,419,421,423,425],{"class":103,"line":420},22,[101,422,265],{"class":107},[101,424,286],{"class":111},[101,426,170],{"class":107},[101,428,430,432,434],{"class":103,"line":429},23,[101,431,265],{"class":107},[101,433,178],{"class":111},[101,435,170],{"class":107},[17,437,438],{},"「這段程式碼會連接到 MySQL 資料庫，並且輸出連接成功或失敗的訊息。」老師解釋道。",[17,440,441],{},"沒錯，這就是我第一次接觸 PHP 的契機，沒想到吧？\n當時我覺得 PHP 超厲害，不只可以直接跟資料庫互動，還能嵌入到 HTML 中，重點是能即時把結果呈現在畫面上，甚至還能跟使用者互動。",[17,443,444],{},"相比之下，C 語言就顯得有些單調，頂多就是在黑底白字的視窗裡輸出幾行文字，完全沒有什麼成就感。",[17,446,447],{},"也因為這個契機，我決定請這位老師擔任我的專題指導老師，從那一刻起，我正式踏上了專題製作之路。",[17,449,450],{},"專題成品算是順利出爐，也拿到很好成績，甚至被系上點名想拿去當招生教材範本，但過程真的是滿滿血淚。",[17,452,453],{},"程式過程慘，但團隊合作更慘，我的組員們，擺爛、不合群、狀況外一堆，組員 5 人，但真正在做的只有 2 人（說真的，Debug 比吵架容易多了 XD）。",[17,455,456],{},"更別提那位嚴格到爆的指導老師，雖然把我磨得更強，可是壓力也大到快得心理陰影。",[17,458,459],{},"只能說 —— 專題結束時交出去的不只是作品，還有我的半條命 XD。",[17,461,462],{},[31,463],{"alt":464,"src":465},"半條命","https:\u002F\u002Fmedia1.tenor.com\u002Fm\u002F7IKGRY1nLM0AAAAC\u002Face-attorney-penalty.gif",[36,467,469],{"id":468},"php-專為網頁設計而生的語言","PHP 專為網頁設計而生的語言",[17,471,472],{},"PHP 本身就是為了網頁程式開發而設計的語言，對一般程式設計師來說，相對來講是很容易快速上手的，為什麼這麼說呢？",[17,474,475],{},"讓我們來看一下幾個基本的 PHP 語法：",[91,477,479],{"className":93,"code":478,"language":95,"meta":96,"style":96},"\u003C?php\n\u002F\u002F 宣告變數\n$name = \"Ray\";\n$age = 30;\n\n\u002F\u002F 輸出變數\necho \"我的名字是 $name，我的年齡是 $age 歲。\";\n\n\u002F\u002F 條件判斷\nif ($age >= 18) {\n    echo \"我已經成年了。\";\n} else {\n    echo \"我還未成年。\";\n}\n\n\u002F\u002F 迴圈\nfor ($i = 0; $i \u003C 5; $i++) {\n    echo \"這是第 $i 次迴圈。\";\n}\n\n\u002F\u002F 陣列\n$fruits = array(\"蘋果\", \"香蕉\", \"橘子\");\nforeach ($fruits as $fruit) {\n    echo \"我喜歡吃 $fruit。\";\n}\n\n\u002F\u002F 函式\nfunction greet($name) {\n    return \"你好，$name！\";\n}\necho greet(\"Ray\");\n\n\u002F\u002F 物件導向\nclass Person {\n    public $name;\n    public $age; \n    public function __construct($name, $age) {\n        $this->name = $name;\n        $this->age = $age;\n    }\n    public function introduce() {\n        return \"我的名字是 $this->name，我的年齡是 $this->age 歲。\";\n    }\n}\n$person = new Person(\"Ray\", 30);\necho $person->introduce();\n\n\u002F\u002F 例外處理\ntry {\n    $result = 10 \u002F 0; \u002F\u002F 這會引發除以零\n} catch (DivisionByZeroError $e) {\n    echo \"錯誤：除以零！\";\n} finally {\n    echo \"這是 finally 區塊，無論如何都會執行。\";\n}\n?>\n",[98,480,481,487,493,505,517,521,526,544,548,553,570,580,589,598,603,607,612,641,656,660,664,669,698,712,728,733,738,744,757,773,778,792,797,803,815,824,832,846,862,877,883,896,924,929,934,958,974,979,985,993,1015,1032,1042,1052,1062,1067],{"__ignoreMap":96},[101,482,483,485],{"class":103,"line":104},[101,484,108],{"class":107},[101,486,112],{"class":111},[101,488,489],{"class":103,"line":115},[101,490,492],{"class":491},"sGBqm","\u002F\u002F 宣告變數\n",[101,494,495,498,500,503],{"class":103,"line":129},[101,496,497],{"class":125},"$name ",[101,499,184],{"class":107},[101,501,502],{"class":121}," \"Ray\"",[101,504,126],{"class":125},[101,506,507,510,512,515],{"class":103,"line":201},[101,508,509],{"class":125},"$age ",[101,511,184],{"class":107},[101,513