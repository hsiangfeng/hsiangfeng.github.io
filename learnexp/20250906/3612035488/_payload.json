[{"data":1,"prerenderedAt":662},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250906\u002F3612035488\u002F":3,"page:\u002Flearnexp\u002F20250906\u002F3612035488\u002F":4,"alt:\u002Flearnexp\u002F20250906\u002F3612035488\u002F":3,"prev-next:\u002Flearnexp\u002F20250906\u002F3612035488\u002F":637,"related:\u002Flearnexp\u002F20250906\u002F3612035488\u002F":646},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F06\u002Fday-6-first-email-and-the-at-symbol\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":615,"date":616,"description":617,"extension":618,"lang":619,"meta":620,"navigation":621,"path":622,"readingMinutes":623,"seo":624,"standalone":625,"stem":626,"tags":627,"tldr":633,"updated":634,"url":635,"__hash__":636},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 6】第一次註冊 Email 被「小老鼠」搞瘋！＠符號與 Ray Tomlinson 的故事.md","【Day 6】第一次註冊 Email 被「小老鼠」搞瘋！＠符號與 Ray Tomlinson 的故事","3612035488",{"type":9,"value":10,"toc":607},"minimark",[11,30,37,42,45,48,57,60,63,66,69,72,75,82,85,93,96,99,102,105,108,111,114,117,124,127,134,137,140,143,151,154,157,167,178,181,197,200,287,293,299,305,312,327,333,337,343,357,366,369,391,394,397,406,415,432,435,461,464,467,490,493,496,533,536,539,550,553,556,559,603],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"第一次註冊 Email 被「小老鼠」搞瘋！＠符號與 Ray Tomlinson 的故事","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday6\u002FChatGPT%20Image%202025%E5%B9%B48%E6%9C%8831%E6%97%A5%20%E4%B8%8B%E5%8D%8801_19_10.png",[38,39,41],"h2",{"id":40},"我也想擁有自己的-email-信箱","我也想擁有自己的 Email 信箱",[15,43,44],{},"國小時有一堂電腦課讓我印象非常深刻，到現在都還記得清清楚楚。當時老師要我們每個人註冊一個自己的 Email 信箱，然後寄信給他。",[15,46,47],{},"「今天的回家作業是到 Yahoo！去註冊一個自己的 Email 信箱，然後寄一封信給我，內容隨便都行。老師的信箱在這裡……」老師在下課前這麼交代著。",[15,49,50,51,56],{},"老實說，當下聽到這個回家作業我整個緊張到不行，因為我上電腦課根本沒在專心，都在玩「",[23,52,55],{"href":53,"rel":54},"http:\u002F\u002Fgame.slime.com.tw\u002F",[27],"史萊姆好玩遊戲區","」，只依稀記得老師好像有教過怎麼註冊 Email 信箱，但我完全沒在聽就是了。",[15,58,59],{},"回到家後，我第一個反應就是立刻打電話給班上有認真聽課的同學，請他教我怎麼註冊 Email 信箱。",[15,61,62],{},"「嘟嘟...」電話響了幾聲後，對方接起來了。",[15,64,65],{},"「喂～是 XXX 嗎？我是 Ray」我說著。",[15,67,68],{},"「喔！Ray，怎麼了嗎？」同學問我。",[15,70,71],{},"「我想問你，要怎麼註冊 Yahoo！的 Email 信箱，就是今天的回家作業啦。」我記得那天還特地跑去同學家用電腦，因為我自己的電腦早就壞掉了。",[15,73,74],{},"「喔！這個很簡單啦！你打開 Yahoo！，然後點註冊，填寫你的資料就註冊好一個 Email 帳號了～」同學說著。",[15,76,77,78,81],{},"聽起來是不是滿簡單的，但對我超難，因為我只會搜尋 ",[23,79,55],{"href":53,"rel":80},[27]," 而已，其他東西完全不會查也不會用。(上課都在混)",[15,83,84],{},"「哎！XXX，其他欄位我都填好了，但是有一個欄位叫『備用信箱』，我不知道要填什麼？」我問著。",[15,86,87,88,92],{},"「備用信箱就是你要填一個信箱，你填我姐的信箱好了，a0....」這時候同學講到『",[89,90,91],"code",{},"＠","』的時候，我聽不懂，於是我就問他說：",[15,94,95],{},"「你剛剛說的那個符號是什麼？我該怎麼打？」我問著。",[15,97,98],{},"「就是小老鼠啊！你打小老鼠就可以了！」同學說著。",[15,100,101],{},"「不行啊！出錯了，他說我這個信箱不正確！」我看著同學給我的信箱，然後再次確認一次。",[15,103,104],{},"「出現什麼錯誤啊？」同學問我。",[15,106,107],{},"「它說我這個信箱不正確，請檢查一下！我唸一次給你聽：a0...小老鼠...」我說著。",[15,109,110],{},"大概這樣來回幾次之後，我同學似乎意識到什麼",[15,112,113],{},"「你該不會打中文『小老鼠』吧？」同學問我。",[15,115,116],{},"「對阿！不是嗎？」我充滿疑惑著。",[15,118,119,120,123],{},"「不是打『小老鼠』啦！你要按 Shift + 2 才對！這個符號叫做 ",[89,121,122],{},"at","（小老鼠）！」同學說著。",[15,125,126],{},"搞了老半天我才發現是自己打錯字，結果光是註冊一個 Yahoo 信箱就花了將近一個小時才搞定。好不容易註冊成功後，剩下的就靠自己亂摸索，最後總算把信寄給老師，完成了這次的回家作業。(再不認真上課阿~~~~)",[38,128,130,131,133],{"id":129},"與-email-之間的關聯","「",[89,132,91],{},"」與 Email 之間的關聯",[15,135,136],{},"前面我們提到過區域網路的概念，如果要在同一個網路範圍內傳遞資料或訊息，彼此之間才能互相溝通。",[15,138,139],{},"但如果想要跨出這個區域網路範圍，和其他區域網路的電腦交換資料或訊息，那該怎麼辦呢？",[15,141,142],{},"這時候 Email 就派上用場了。它可以讓我們在不同的區域網路之間傳遞資料。舉例來說，我可以在台灣的電腦寄一封信給美國的電腦，而對方就能收到這封信件。",[12,144,145],{},[15,146,147,150],{},[18,148,149],{},"Note","\n早期並沒有 Line、即時通這種通訊軟體，當時大家都是透過 Email 來傳遞訊息與資料的。",[15,152,153],{},"但...你有想過 Email 是怎麼來的嗎？",[15,155,156],{},"Email 是由一位叫做 Ray Tomlinson（雷·湯姆林森）的人所發明的，他在 1971 年的時候設計了這套系統，讓人們可以在不同電腦之間傳送信件，並寄給不同的使用者，開啟了現代電子郵件的時代。",[15,158,159,160,162,163,166],{},"當初 Ray Tomlinson 發明 Email 這套系統時，為了能區分「使用者名稱」與「主機名稱」，所以他選擇使用「",[89,161,91],{},"」這個符號來區分。以當時來講 ",[89,164,165],{},"@"," 幾乎沒有特別用途跟意義，所以很適合拿來作為分隔符號。但隨著網際網路與 DNS 發展，原本的主機名稱部分也逐漸演變成以 網域名稱 (domain name) 來識別郵件服務商。",[12,168,169],{},[15,170,171,173,174,177],{},[18,172,149],{},"\n所謂的 DNS（Domain Name System）是一套把網域名稱轉換成 IP 位址的系統。也就是說，當我們在瀏覽器輸入 ",[89,175,176],{},"www.google.com","時，背後實際上對應的就是某個 IP 位址。",[15,179,180],{},"所以現代的 Email 的格式才會長成這樣：",[182,183,188],"pre",{"className":184,"code":185,"language":186,"meta":187,"style":187},"language-txt shiki shiki-themes github-dark-high-contrast","使用者名稱＠網域名稱\n","txt","",[89,189,190],{"__ignoreMap":187},[191,192,195],"span",{"class":193,"line":194},"line",1,[191,196,185],{},[15,198,199],{},"這樣的格式能清楚區分「使用者名稱」和「網域名稱」，下面來看幾個範例：",[201,202,203,222],"table",{},[204,205,206],"thead",{},[207,208,209,213,216,219],"tr",{},[210,211,212],"th",{},"使用者名稱",[210,214,215],{},"網域名稱",[210,217,218],{},"服務商",[210,220,221],{},"完整信箱",[223,224,225,242,257,272],"tbody",{},[207,226,227,231,234,237],{},[228,229,230],"td",{},"israynotarray",[228,232,233],{},"gmail.com",[228,235,236],{},"Google",[228,238,239],{},[89,240,241],{},"israynotarray@gmail.com",[207,243,244,246,249,252],{},[228,245,230],{},[228,247,248],{},"yahoo.com.tw",[228,250,251],{},"Yahoo",[228,253,254],{},[89,255,256],{},"israynotarray@yahoo.com.tw",[207,258,259,261,264,267],{},[228,260,230],{},[228,262,263],{},"hotmail.com",[228,265,266],{},"Microsoft",[228,268,269],{},[89,270,271],{},"israynotarray@hotmail.com",[207,273,274,276,279,282],{},[228,275,230],{},[228,277,278],{},"icloud.com",[228,280,281],{},"Apple",[228,283,284],{},[89,285,286],{},"israynotarray@icloud.com",[15,288,289,290,292],{},"我們可以看到透過這個格式，使用者名稱與網域名稱是用「",[89,291,91],{},"」來區分的，這樣一來就能清楚知道信是寄給誰，以及透過哪個服務商傳送。所以 Email 格式並不是隨便訂的，而是有其背後的意義與歷史。",[15,294,295,296,298],{},"當然，這個「",[89,297,91],{},"」的符號也不只限於 Email 上使用，像是我們在社群網站上標記使用者時，也會用到這個符號，例如：",[15,300,301],{},[33,302],{"alt":303,"src":304},"社群網站標記","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday6\u002F20250823143820.png",[15,306,307,308,311],{},"這個標記其實有它的意義，代表著「我在這個社群\u002F服務上，標記一位叫做 ",[89,309,310],{},"isray_notarray"," 的使用者」，而這個概念都是從 Email 的用法上延伸而來的。",[15,313,314,315,317,318,320,321,323,324,326],{},"所以當我們要從 ",[89,316,241],{}," 寄信到 ",[89,319,271],{},"，這句白話文的意思就是「我在 gmail.com 網域上寄信給一位叫做 ",[89,322,230],{}," 的使用者，而這個使用者的網域名稱是 Hotmail（網域名稱為 ",[89,325,263],{},"）」。",[15,328,329,330,332],{},"透過以上的說明，相信你應該已經了解為什麼 Email 的格式會是這樣設計的，同時也能理解為什麼在社群網站上會用「",[89,331,91],{},"」這個符號來標記使用者啦～",[38,334,336],{"id":335},"主機網域名稱","主機\u002F網域名稱",[15,338,339,340,342],{},"前面提到「",[89,341,91],{},"」的符號在早期是用來區分使用者名稱與主機名稱的，但在現代，則演變成用來區分使用者名稱與網域名稱。",[15,344,345,346,348,349,352,353,356],{},"那當時所說的主機名稱（hostname）是什麼呢？簡單來說，就是電腦的名稱。比如我的使用者名稱是 ",[89,347,230],{},"，主機名稱是 ",[89,350,351],{},"bbs-work","，所以組合起來就會是 ",[89,354,355],{},"israynotarray@bbs-work","，這就是早期用來識別使用者與主機的方式。",[182,358,360],{"className":184,"code":359,"language":186,"meta":187,"style":187},"username@hostname\n",[89,361,362],{"__ignoreMap":187},[191,363,364],{"class":193,"line":194},[191,365,359],{},[15,367,368],{},"這樣的區分方式有助於我們辨別使用者與主機，因為同一台主機上可能會存在多個使用者，就像在 Windows 或 macOS 裡可以建立不同的使用者帳號一樣。每個帳號都有自己的設定和資料，但大家共用同一台電腦，所以就會像下面這樣：",[182,370,372],{"className":184,"code":371,"language":186,"meta":187,"style":187},"israynotarray@bbs-work\nadministrator@bbs-work\nguest@bbs-work\n",[89,373,374,379,385],{"__ignoreMap":187},[191,375,376],{"class":193,"line":194},[191,377,378],{},"israynotarray@bbs-work\n",[191,380,382],{"class":193,"line":381},2,[191,383,384],{},"administrator@bbs-work\n",[191,386,388],{"class":193,"line":387},3,[191,389,390],{},"guest@bbs-work\n",[15,392,393],{},"當我們在區域網路上傳遞資料時，就可以透過這樣的方式來辨別使用者與主機。",[15,395,396],{},"隨著網際網路擴展，我們不再只靠單一主機名稱來辨別，而是引入「網域名稱 (domain name)」，網域名稱能清楚標示郵件服務商，讓 Email 可以跨越不同網路來傳遞。",[182,398,400],{"className":184,"code":399,"language":186,"meta":187,"style":187},"username@domain\n",[89,401,402],{"__ignoreMap":187},[191,403,404],{"class":193,"line":194},[191,405,399],{},[15,407,408,409,411,412,414],{},"所以假設我有一個 Gmail 帳號，然後我的使用者名稱是 ",[89,410,230],{},"，那麼我的 Email 就會是 ",[89,413,241],{},"。",[12,416,417],{},[15,418,419,421,422,425,426,428,429,414],{},[18,420,149],{},"\n這邊你應該會疑惑為什麼不是 ",[89,423,424],{},"israynotarray@google.com"," 呢？其原因是因為 Gmail 是 Google 所提供的 Email 服務，Gmail 的網域名稱是 ",[89,427,233],{},"，而不是 ",[89,430,431],{},"google.com",[15,433,434],{},"透過網域名稱的概念，我們能更清楚地分辨這封信是寄到哪一個服務商。這些服務商的名稱通常會以「網域名稱」來表示，用來區分彼此，例如：",[182,436,438],{"className":184,"code":437,"language":186,"meta":187,"style":187},"gmail.com\nyahoo.com.tw\nhotmail.com\nicloud.com\n",[89,439,440,445,450,455],{"__ignoreMap":187},[191,441,442],{"class":193,"line":194},[191,443,444],{},"gmail.com\n",[191,446,447],{"class":193,"line":381},[191,448,449],{},"yahoo.com.tw\n",[191,451,452],{"class":193,"line":387},[191,453,454],{},"hotmail.com\n",[191,456,458],{"class":193,"line":457},4,[191,459,460],{},"icloud.com\n",[15,462,463],{},"這些都是網域名稱，而透過網域名稱，我們就能清楚知道這封信是寄往哪一個服務商。",[15,465,466],{},"這邊也稍微簡單總結一下時代背景差異：",[468,469,470,481],"ul",{},[471,472,473,476,477,480],"li",{},[18,474,475],{},"早期"," ： ",[89,478,479],{},"username@hostname","，用來辨別哪個使用者在哪台電腦。",[471,482,483,476,486,489],{},[18,484,485],{},"現代",[89,487,488],{},"username@domain","，用來辨別哪個使用者在哪個郵件服務商。",[15,491,492],{},"關於網域其實可以展開很多內容，不過這裡就先不深入探討。你只要先理解 網域名稱是用來區分不同服務商的 就可以了。在後面的章節，我會再詳細介紹網域名稱的相關知識。",[15,494,495],{},"為了讓你更釐清一點，我也做一個表格：",[201,497,498,507],{},[204,499,500],{},[207,501,502,505],{},[210,503,504],{},"服務商名稱",[210,506,215],{},[223,508,509,515,521,527],{},[207,510,511,513],{},[228,512,236],{},[228,514,233],{},[207,516,517,519],{},[228,518,251],{},[228,520,248],{},[207,522,523,525],{},[228,524,266],{},[228,526,263],{},[207,528,529,531],{},[228,530,281],{},[228,532,278],{},[38,534,535],{"id":535},"結語",[15,537,538],{},"在寫這一篇的時候，我才發現小老鼠還有其他唸法，例如...",[468,540,541,544,547],{},[471,542,543],{},"圈 a",[471,545,546],{},"花 a",[471,548,549],{},"艾特符號",[15,551,552],{},"不知道大家比較常念哪一種呢？以我自己來講，我還是比較習慣唸「小老鼠」就是了。",[38,554,555],{"id":555},"同步更新",[15,557,558],{},"本文將同步更新至以下網站：",[468,560,561,568,575,582,589,596],{},[471,562,563],{},[23,564,567],{"href":565,"rel":566},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[471,569,570],{},[23,571,574],{"href":572,"rel":573},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[471,576,577],{},[23,578,581],{"href":579,"rel":580},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[471,583,584],{},[23,585,588],{"href":586,"rel":587},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[471,590,591],{},[23,592,595],{"href":593,"rel":594},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[471,597,598],{},[23,599,602],{"href":600,"rel":601},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",[604,605,606],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":187,"searchDepth":381,"depth":381,"links":608},[609,610,612,613,614],{"id":40,"depth":381,"text":41},{"id":129,"depth":381,"text":611},"「＠」與 Email 之間的關聯",{"id":335,"depth":381,"text":336},{"id":535,"depth":381,"text":535},{"id":555,"depth":381,"text":555},"學習經驗","2025-09-06 00:00:01","被「小老鼠」卡住的註冊記：從 @ 的歷史與用途，到 username@domain 的格式、DNS 與社群 @ 標記的延伸，理清 Email 為什麼長這樣。","md","zh-Hant",{},true,"\u002Fcode-review\u002Fday-6-email-ray-tomlinson","5",{"title":6,"description":617},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 6】第一次註冊 Email 被「小老鼠」搞瘋！＠符號與 Ray Tomlinson 的故事",[628,629,630,631,632],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","Email 註冊教學","＠ 符號歷史","Ray Tomlinson","網域名稱入門",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250906\u002F3612035488\u002F","g48lYCyp0fkBgWgczH44NKo3oJchj0-daKefqYnBZsI",{"newer":638,"older":642},{"url":639,"title":640,"date":641},"\u002Flearnexp\u002F20250907\u002F3021552429\u002F","【Day 7】原來網址不是魔法！DNS 背後是查表的辛苦工程","2025-09-07 00:00:01",{"url":643,"title":644,"date":645},"\u002Flearnexp\u002F20250905\u002F289503212\u002F","【Day 5】第一次玩 CS 被打爆！從網咖連線到 IP 的啟蒙旅程","2025-09-05 00:00:01",[647,652,657],{"url":648,"title":649,"date":650,"readingMinutes":651},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":653,"title":654,"date":655,"readingMinutes":656},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":658,"title":659,"date":660,"readingMinutes":661},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00","6",1784012800300]