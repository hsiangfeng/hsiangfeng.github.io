[{"data":1,"prerenderedAt":735},["ShallowReactive",2],{"header-locale:\u002Flearnexp\u002F20250927\u002F1706365915\u002F":3,"page:\u002Flearnexp\u002F20250927\u002F1706365915\u002F":4,"alt:\u002Flearnexp\u002F20250927\u002F1706365915\u002F":3,"prev-next:\u002Flearnexp\u002F20250927\u002F1706365915\u002F":713,"related:\u002Flearnexp\u002F20250927\u002F1706365915\u002F":722},"\u002Fen\u002Flearning\u002F2025\u002F09\u002F27\u002Fday-27-got-laid-off-during-long-weekend\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":692,"date":693,"description":694,"extension":695,"lang":696,"meta":697,"navigation":173,"path":698,"readingMinutes":699,"seo":700,"standalone":701,"stem":702,"tags":703,"tldr":709,"updated":710,"url":711,"__hash__":712},"content\u002FCode Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 27】爽爽放連假的期間，我收到了資遣通知~.md","【Day 27】爽爽放連假的期間，我收到了資遣通知~","1706365915",{"type":9,"value":10,"toc":685},"minimark",[11,30,37,42,45,48,51,54,57,60,63,66,69,305,308,317,323,326,332,335,338,341,344,347,350,353,356,359,362,365,368,384,387,390,401,407,410,419,425,428,455,458,461,464,467,470,484,487,490,494,505,508,511,514,517,529,532,535,538,589,592,595,598,601,613,616,619,622,625,628,631,634,637,681],[12,13,14],"blockquote",{},[15,16,17,21,22,29],"p",{},[18,19,20],"strong",{},"Warning","\n嗨！這系列文章已經重新整理、改寫成書，目前在 ",[23,24,28],"a",{"href":25,"rel":26},"https:\u002F\u002Fwww.tenlong.com.tw\u002Fproducts\u002F9786267889251?list_name=i-r-zh_tw",[27],"nofollow","天瓏網路書店"," 販售中。(2026\u002F05\u002F07 更新)\n書本版我幾乎是從頭重寫了一遍，把當時 IT 邦幫忙連載時來不及好好說的故事補完，也修掉了不少當時寫得不夠精準的段落，是我自己更滿意的版本。\n如果你看完這篇覺得還想多看一些、或想直接收藏完整版，歡迎到天瓏支持一下，會是對我很大的鼓勵，謝謝！\n部落格與 IT 邦幫忙就會保留當時的寫作版本，因此建議以書本內容為主，這邊的文章請讀者自行斟酌參考哩～",[15,31,32],{},[33,34],"img",{"alt":35,"src":36},"爽爽放連假的期間，我收到了資遣通知","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday27\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8820%E6%97%A5%20%E4%B8%8B%E5%8D%8810_59_06.png",[38,39,41],"h2",{"id":40},"爽爽放連假的期間我收到了資遣通知","爽爽放連假的期間，我收到了資遣通知~",[15,43,44],{},"出社會後，一切都很順利嗎？\n不，其實並沒有。",[15,46,47],{},"那一年 228 連假，正當我放假放得正爽，電話突然響起。",[15,49,50],{},"「Ray，下個月我們團隊被裁員了，有空來公司整理一下吧。」\n主管的語氣冷靜到不可思議，像是在告知一件例行公事。",[15,52,53],{},"電話掛斷後，我忍不住苦笑 ——\n原來所謂的「資遣通知」，其實就是一種免費的職涯轉職提醒。",[15,55,56],{},"同事們陸續收到通知，在群組裡瘋狂咒罵，而我只淡淡回了一句：\n「對啊，真麻煩，現在要開始準備履歷跟面試了 QQ」",[15,58,59],{},"在被資遣後，我就把心思全放在前端技術上，先把 JavaScript 課程上完，還反覆練習了三、四次，才硬著頭皮去碰 Vue.js。",[15,61,62],{},"結果第一感想只有一個：\n「哇靠，怎麼到處都是新名詞！」\n什麼元件化、單向資料流、生命週期 ……\n每一個聽起來都像是 RPG 技能樹，結果我又回到新手村了。",[15,64,65],{},"要說它像魔法嗎？\n當時我真的這麼覺得 —— 只要寫上短短幾行程式碼，就能產生出炫酷的效果。",[15,67,68],{},"就像下面這個簡單的 Vue 元件：",[70,71,76],"pre",{"className":72,"code":73,"language":74,"meta":75,"style":75},"language-html shiki shiki-themes github-dark-high-contrast","\u003Ctemplate>\n  \u003Cdiv>\n    \u003Ch1>{{ message }}\u003C\u002Fh1>\n    \u003Cbutton @click=\"updateMessage\">點我改變訊息\u003C\u002Fbutton>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\u003Cscript>\nexport default {\n  data() {\n    return {\n      message: 'Hello, Vue!'\n    };\n  },\n  methods: {\n    updateMessage() {\n      this.message = '你點了我！';\n    }\n  }\n};\n\u003C\u002Fscript>\n","html","",[77,78,79,95,106,122,148,158,168,175,185,199,212,220,229,235,244,250,259,276,282,288,296],"code",{"__ignoreMap":75},[80,81,84,88,92],"span",{"class":82,"line":83},"line",1,[80,85,87],{"class":86},"sMAXC","\u003C",[80,89,91],{"class":90},"sKpQp","template",[80,93,94],{"class":86},">\n",[80,96,98,101,104],{"class":82,"line":97},2,[80,99,100],{"class":86},"  \u003C",[80,102,103],{"class":90},"div",[80,105,94],{"class":86},[80,107,109,112,115,118,120],{"class":82,"line":108},3,[80,110,111],{"class":86},"    \u003C",[80,113,114],{"class":90},"h1",[80,116,117],{"class":86},">{{ message }}\u003C\u002F",[80,119,114],{"class":90},[80,121,94],{"class":86},[80,123,125,127,130,134,137,141,144,146],{"class":82,"line":124},4,[80,126,111],{"class":86},[80,128,129],{"class":90},"button",[80,131,133],{"class":132},"sCcAr"," @click",[80,135,136],{"class":86},"=",[80,138,140],{"class":139},"sTRMh","\"updateMessage\"",[80,142,143],{"class":86},">點我改變訊息\u003C\u002F",[80,145,129],{"class":90},[80,147,94],{"class":86},[80,149,151,154,156],{"class":82,"line":150},5,[80,152,153],{"class":86},"  \u003C\u002F",[80,155,103],{"class":90},[80,157,94],{"class":86},[80,159,161,164,166],{"class":82,"line":160},6,[80,162,163],{"class":86},"\u003C\u002F",[80,165,91],{"class":90},[80,167,94],{"class":86},[80,169,171],{"class":82,"line":170},7,[80,172,174],{"emptyLinePlaceholder":173},true,"\n",[80,176,178,180,183],{"class":82,"line":177},8,[80,179,87],{"class":86},[80,181,182],{"class":90},"script",[80,184,94],{"class":86},[80,186,188,192,195],{"class":82,"line":187},9,[80,189,191],{"class":190},"sWyjQ","export",[80,193,194],{"class":190}," default",[80,196,198],{"class":197},"s_sBn"," {\n",[80,200,202,206,209],{"class":82,"line":201},10,[80,203,205],{"class":204},"sj_SG","  data",[80,207,208],{"class":197},"() ",[80,210,211],{"class":86},"{\n",[80,213,215,218],{"class":82,"line":214},11,[80,216,217],{"class":190},"    return",[80,219,198],{"class":86},[80,221,223,226],{"class":82,"line":222},12,[80,224,225],{"class":86},"      message: ",[80,227,228],{"class":139},"'Hello, Vue!'\n",[80,230,232],{"class":82,"line":231},13,[80,233,234],{"class":86},"    };\n",[80,236,238,241],{"class":82,"line":237},14,[80,239,240],{"class":86},"  }",[80,242,243],{"class":197},",\n",[80,245,247],{"class":82,"line":246},15,[80,248,249],{"class":86},"  methods: {\n",[80,251,253,256],{"class":82,"line":252},16,[80,254,255],{"class":204},"    updateMessage",[80,257,258],{"class":86},"() {\n",[80,260,262,265,268,270,273],{"class":82,"line":261},17,[80,263,264],{"class":132},"      this",[80,266,267],{"class":86},".message ",[80,269,136],{"class":190},[80,271,272],{"class":139}," '你點了我！'",[80,274,275],{"class":86},";\n",[80,277,279],{"class":82,"line":278},18,[80,280,281],{"class":86},"    }\n",[80,283,285],{"class":82,"line":284},19,[80,286,287],{"class":86},"  }\n",[80,289,291,294],{"class":82,"line":290},20,[80,292,293],{"class":197},"}",[80,295,275],{"class":86},[80,297,299,301,303],{"class":82,"line":298},21,[80,300,163],{"class":86},[80,302,182],{"class":90},[80,304,94],{"class":86},[15,306,307],{},"如果是用純 JavaScript 來實現這個功能，可能需要寫上好幾十行程式碼，還要處理事件綁定、DOM 操作等，但使用 Vue.js 就可以輕鬆地達成這個效果。",[15,309,310,311,316],{},"前後我大概準備了半年左右，最終用 Vue.js 製作出了一個「",[23,312,315],{"href":313,"rel":314},"https:\u002F\u002Fisraynotarray.com\u002FRagnarokShopV3\u002F",[27],"RagnarokShop","」的電商練習網站",[15,318,319],{},[33,320],{"alt":321,"src":322},"RagnarokShop（圖源網路）","https:\u002F\u002Fcamo.githubusercontent.com\u002F49549cb32e699e3ce6028cebb96d0250c7b73c6687af80483267d8c04b5f407a\u002F68747470733a2f2f692e696d6775722e636f6d2f6f6968525155482e706e67",[15,324,325],{},"通過了當時課程老師給予的 Code Review 後，我才開始準備投遞前端工程師的工作。",[15,327,328],{},[33,329],{"alt":330,"src":331},"課程 Code Review","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday27\u002F20250920151557.gif",[15,333,334],{},"那時候我投遞的職位是 「Junior Frontend Engineer」 ，畢竟沒有實際的前端工作經驗，只能比較認命地先從 Junior 開始。",[15,336,337],{},"在面試過程中，有幾個題目讓我印象非常深刻：",[15,339,340],{},"面試官問了我幾個問題：\n「JavaScript 是直譯語言還是編譯語言？」還有「什麼是 Framework？什麼是 Library？」",[15,342,343],{},"老實說，這些問題我當時並不清楚，與其硬掰答案，不如直接誠實回應：",[15,345,346],{},"「ㄜ…這個我不太確定，因為我沒有特別去了解過。」",[15,348,349],{},"「難道 PHP 沒有用 Framework 嗎？」你可能會這樣問我",[15,351,352],{},"的確，我在寫 PHP 時，大部分時間也都是用 Framework。\n但那時候的我，根本沒想過什麼 Framework 跟 Library 的差別，反正照著官方文件抄一抄就能跑就好。",[15,354,355],{},"至於差異？呵呵，當時的我只想著：\n「能跑就好啦，管它叫什麼！」",[15,357,358],{},"在整個面試過程中，其實被問了不少問題，但唯獨這幾題我沒能答出來，不過面試官在最後還特地幫我解釋了一遍，這也讓我留下了非常深刻的印象。",[38,360,361],{"id":361},"直譯語言與編譯語言",[15,363,364],{},"在程式語言的世界中，有區分為兩種主要類型，分別是直譯語言（Interpreted Language）與編譯語言（Compiled Language）。",[15,366,367],{},"那麼這兩個分類有什麼差呢？這邊讓我們來認識一下彼此的差異：",[369,370,371,378],"ul",{},[372,373,374,377],"li",{},[18,375,376],{},"直譯語言(Interpreted Language)："," 程式碼不需要經過編譯，而是透過一個直譯器（Interpreter）針對每一行程式碼進行解釋並執行，以前面章節所介紹的 JavaScript 就是屬於直譯語言的範疇。",[372,379,380,383],{},[18,381,382],{},"編譯語言(Compiled Language)："," 程式碼一率都是需要經過編譯，先轉換成機器碼（Machine Code），再去執行。所謂的機器碼就是電腦能夠直接理解的二進位碼，像是 C 語言就是屬於編譯語言的範疇。",[15,385,386],{},"這之間，我們也可以比較一下兩者之間的執行過程",[15,388,389],{},"直譯語言流程：",[70,391,395],{"className":392,"code":393,"language":394,"meta":75,"style":75},"language-txt shiki shiki-themes github-dark-high-contrast","你撰寫的程式碼（Source Code） -> 直譯器（Interpreter） -> 即時執行（Runtime）\n","txt",[77,396,397],{"__ignoreMap":75},[80,398,399],{"class":82,"line":83},[80,400,393],{},[15,402,403],{},[33,404],{"alt":405,"src":406},"直譯語言","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday27\u002F20250920153234.png",[15,408,409],{},"編譯語言流程：",[70,411,413],{"className":392,"code":412,"language":394,"meta":75,"style":75},"你撰寫的程式碼（Source Code） -> 編譯器（Compiler） -> 機器碼（Machine Code） -> 執行（Execution）\n",[77,414,415],{"__ignoreMap":75},[80,416,417],{"class":82,"line":83},[80,418,412],{},[15,420,421],{},[33,422],{"alt":423,"src":424},"編譯語言","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday27\u002F202509201539.png",[15,426,427],{},"從這執行流程我們可以看彼此之間的優缺點：",[369,429,430,443],{},[372,431,432,434,435],{},[18,433,405],{},"：\n",[369,436,437,440],{},[372,438,439],{},"優點：開發速度快，因為不需要編譯過程，可以即時執行程式碼。",[372,441,442],{},"缺點：執行速度較慢，因為每次執行都需要解釋程式碼。",[372,444,445,434,447],{},[18,446,423],{},[369,448,449,452],{},[372,450,451],{},"優點：執行速度較快，因為程式碼已經被轉換成機器碼。",[372,453,454],{},"缺點：開發速度較慢，因為需要經過編譯過程才能執行程式碼。",[15,456,457],{},"所以前面章節所介紹到的 JavaScript、PHP 都是屬於直譯語言的範疇，而 C 語言則是屬於編譯語言的範疇。",[15,459,460],{},"為了解決這些問題，現在有些程式語言已經不再是單純的直譯語言或編譯語言，而是結合了兩者的優點。",[15,462,463],{},"以 JavaScript 為例，V8 引擎會先將程式碼編譯成 中間碼（Bytecode），再透過 JIT（Just-In-Time）編譯器把中間碼轉換成機器碼，讓程式在執行時能大幅提升速度。",[15,465,466],{},"這種模式被稱為 「混合語言（Hybrid Language）」。",[15,468,469],{},"這些編譯方式又可以細分為：",[369,471,472,478],{},[372,473,474,477],{},[18,475,476],{},"AOT（Ahead-Of-Time）編譯","：預先將直譯語言編譯成機器碼。",[372,479,480,483],{},[18,481,482],{},"JIT（Just-In-Time）編譯","：主要將直譯語言以及編譯語言兩者的優勢結合再一起，這樣就可以在執行時提高速度。",[15,485,486],{},"所以，不管你選擇哪一種程式語言，最重要的是先了解它的特性與優缺點，\n只有這樣，才能在開發過程中做出更好的判斷與選擇。",[15,488,489],{},"每種語言都有它的適用場景與優勢，而選擇合適的語言，往往能讓開發過程更加順利哩～",[38,491,493],{"id":492},"什麼是-framework-與-library","什麼是 Framework 與 Library？",[15,495,496,497,500,501,504],{},"在軟體開發的世界裡，",[18,498,499],{},"Framework（框架）"," 和 ",[18,502,503],{},"Library（函式庫）"," 是兩個經常被提到的概念。",[15,506,507],{},"記得在我早期的一份工作中，就有前輩跟我說過一句話：",[15,509,510],{},"「如果你程式碼要學得好，我會建議你少用 Framework，多用 Library。」",[15,512,513],{},"當下的我其實並不太能理解這句話的意思，直到後來在工作與學習的過程中，才慢慢體會出 Framework 和 Library 之間的差異。",[15,515,516],{},"那麼，什麼是 Framework 與 Library 呢？我們來一一解釋：",[369,518,519,524],{},[372,520,521,523],{},[18,522,503],{},"：是一組預先寫好的程式碼集合，提供特定功能或服務，讓開發者可以直接調用這些功能，而不需要從頭開始撰寫。",[372,525,526,528],{},[18,527,499],{},"：是一個更為全面的解決方案，提供了一個結構化的開發環境，並規範了應用程式的整體架構與流程。",[15,530,531],{},"你可以把 Library 想像成一個工具箱，裡面有各種工具（函式）幫助你完成特定任務，它就像是提供了釘子、錘子這些工具，讓你自己決定怎麼用，但不會干涉你的工作流程。",[15,533,534],{},"相反地，Framework 比較像是一個完整的工作坊，裡面有一套固定的流程和規範，你必須按照它的規則來做事，Framework 不只提供工具，還會告訴你該怎麼做，並且替你建立好整體結構。",[15,536,537],{},"這兩個有它的好壞處：",[369,539,540,553,563,576],{},[372,541,542,434,545],{},[18,543,544],{},"Library 的優點",[369,546,547,550],{},[372,548,549],{},"靈活性高，可以自由選擇使用哪些函式（工具）。",[372,551,552],{},"不會干涉你的工作流程，可以按照自己的方式來開發。",[372,554,555,434,558],{},[18,556,557],{},"Library 的缺點",[369,559,560],{},[372,561,562],{},"需要自行管理程式碼的結構與流程，可能會增加開發的複雜度。",[372,564,565,434,568],{},[18,566,567],{},"Framework 的優點",[369,569,570,573],{},[372,571,572],{},"提供了一個清晰的結構與規範，可以提高開發效率。",[372,574,575],{},"內建許多功能，減少重複造輪子的機會。",[372,577,578,434,581],{},[18,579,580],{},"Framework 的缺點",[369,582,583,586],{},[372,584,585],{},"學習曲線較陡，需要花時間熟悉框架的規範與用法。",[372,587,588],{},"可能會限制開發者的自由度，必須遵循框架的設計理念。",[15,590,591],{},"「那麼我該選擇 Framework 還是 Library 呢？」這是許多初學者常常會問的問題。",[15,593,594],{},"其實兩者都行，重點還是看 專案需求跟個人習慣。",[15,596,597],{},"如果你今天要做的是一個 MVP 專案，或只是想快速驗證一個想法，那麼使用 Framework 會比較適合，因為它能幫你更快完成原型。",[15,599,600],{},"但如果你要建立的是一個大型系統，並且需要高度的可維護性與擴展性，那麼選擇 Library 可能更合適，因為它能提供你更大的靈活性來設計架構。",[12,602,603],{},[15,604,605,608,609,612],{},[18,606,607],{},"Note","\nMVP 是 Minimum Viable Product 的縮寫，意思是 ",[18,610,611],{},"「最小可行產品」"," ，指的是一個具有最基本功能的產品，可以用來驗證市場需求與用戶反饋。",[15,614,615],{},"當然，這並不是說用 Framework 就學不好程式碼，或是用 Library 就一定比較好，最重要的還是先搞懂它們的 特性與優缺點。",[15,617,618],{},"像現在前端圈的 React、Vue、Angular，本質上都還是建立在 JavaScript 上的，所以與其糾結到底該選哪一個，不如先把 JavaScript 基礎練好。",[15,620,621],{},"畢竟 —— JS 沒學好，換幾個框架都只是換湯不換藥 。",[38,623,624],{"id":624},"結語",[15,626,627],{},"這是我第一次被資遣的經驗，雖然當下感到挫折，但也讓我有機會重新審視自己的職涯方向。",[15,629,630],{},"所以，其實反而要感謝公司裁員吧？！",[38,632,633],{"id":633},"同步更新",[15,635,636],{},"本文將同步更新至以下網站：",[369,638,639,646,653,660,667,674],{},[372,640,641],{},[23,642,645],{"href":643,"rel":644},"https:\u002F\u002Fisraynotarray.com\u002Ftags\u002FCode-Review-%E6%88%91%E7%9A%84%E9%9D%92%E6%98%A5%EF%BC%9A%E5%BE%9E%E3%80%8E%E5%97%B6%E3%80%8F%E8%81%B2%E9%96%8B%E5%95%9F%E6%88%91%E7%9A%84%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB%E4%B9%8B%E8%B7%AF\u002F",[27],"是 Ray 不是 Array",[372,647,648],{},[23,649,652],{"href":650,"rel":651},"https:\u002F\u002Fithelp.ithome.com.tw\u002Fusers\u002F20119486\u002Fironman\u002F8232",[27],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路（佛心分享-IT 人自學之術）",[372,654,655],{},[23,656,659],{"href":657,"rel":658},"https:\u002F\u002Fwww.threads.com\u002F@isray_notarray",[27],"Threads - 時常會聊軟實力",[372,661,662],{},[23,663,666],{"href":664,"rel":665},"https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray",[27],"Facebook - 搞怪迷因分享",[372,668,669],{},[23,670,673],{"href":671,"rel":672},"https:\u002F\u002Fwww.instagram.com\u002Fisraynotarray\u002F",[27],"Instagram - 搞怪迷因分享 + 軟實力",[372,675,676],{},[23,677,680],{"href":678,"rel":679},"https:\u002F\u002Fportaly.cc\u002Fisraynotarray",[27],"Portaly - 入口主頁",[682,683,684],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":75,"searchDepth":97,"depth":97,"links":686},[687,688,689,690,691],{"id":40,"depth":97,"text":41},{"id":361,"depth":97,"text":361},{"id":492,"depth":97,"text":493},{"id":624,"depth":97,"text":624},{"id":633,"depth":97,"text":633},"學習經驗","2025-09-27 00:00:00","被裁之後我把技能樹點滿：Vue 寫電商、面試被問爆直譯\u002F編譯與框架\u002F函式庫，最後懂了——JS 基礎才是萬用被動技。","md","zh-Hant",{},"\u002Fcode-review\u002Fday-27~","5",{"title":6,"description":694},false,"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路\u002F【Day 27】爽爽放連假的期間，我收到了資遣通知~",[704,705,706,707,708],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","工程師裁員經驗","Vue.js 學習歷程","面試技巧分享","技術框架比較",null,"2026-05-07 21:00:00","\u002Flearnexp\u002F20250927\u002F1706365915\u002F","D2Jm1ecAFA-cuoRFlq0omLvviEru-x5RG-6rxcPggYw",{"newer":714,"older":718},{"url":715,"title":716,"date":717},"\u002Flearnexp\u002F20250928\u002F1706365915\u002F","【Day 28】每一個學生的問題，都是我成長的修羅場","2025-09-28 00:00:00",{"url":719,"title":720,"date":721},"\u002Flearnexp\u002F20250926\u002F1972102857\u002F","【Day 26】就這樣我被迫轉職成前端工程師了","2025-09-26 00:00:01",[723,728,733],{"url":724,"title":725,"date":726,"readingMinutes":727},"\u002Flearnexp\u002F20250930\u002F2883140524\u002F","【Day 30】目錄","2025-09-30 00:00:00","4",{"url":729,"title":730,"date":731,"readingMinutes":732},"\u002Flearnexp\u002F20250929\u002F4192339363\u002F","【Day 29】十年工程師之路","2025-09-29 00:00:00","3",{"url":715,"title":716,"date":717,"readingMinutes":734},"6",1784020392275]