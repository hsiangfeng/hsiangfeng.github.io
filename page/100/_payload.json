[{"data":1,"prerenderedAt":83},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F100\u002F":3,"post-page:zh-Hant:100":4,"author-stats:zh-Hant:full":81},null,{"posts":5,"total":79,"totalPages":80},[6,16,23,31,38,44,50,56,63,70],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190515\u002F1176852332\u002F","[JS奇怪的世界]No.6 執行環境:程式執行","2019-05-15 21:57:35","克服JS奇怪的部分系列",[12,13],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分","前面程式在執行的時候會有兩個階段...","1",{"url":17,"title":18,"date":19,"updated":3,"category":10,"tags":20,"description":21,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190515\u002F1399834060\u002F","[JS奇怪的世界]No.5 觀念小提醒:JavaScript 與 Undefined","2019-05-15 21:00:35",[12,13],"在前面已經稍微有講過一些 Undefined，接下來將會更深入的了解 JavaScript 與 Undefined 之間的關係。","2",{"url":24,"title":25,"date":26,"updated":3,"category":27,"tags":28,"description":30,"readingMinutes":22},"\u002Fhexo\u002F20190515\u002F3137769270\u002F","替Hexo加入像APP一樣的通知(推播)功能","2019-05-15 13:58:15","Hexo",[27,29],"iZooto","由於我們部落格都會希望加入一個通知可以提醒使用者我的部落格文章更新囉~一般來講都是使用 RSS 方式，但是現階段手機很流行的情況下這邊就要用不同於 RSS 的作法來達到通知的效果。",{"url":32,"title":33,"date":34,"updated":3,"category":10,"tags":35,"description":36,"readingMinutes":37},"\u002Fjsweirdworld\u002F20190515\u002F3344152504\u002F","[JS奇怪的世界]No.4 執行環境:創造與提升","2019-05-15 12:00:35",[12,13],"這章節將會講解到 JavaScript 中一個非常詭異的地方，就是「創造與提升」而這部分也是許多人常搞不清楚的地方。","3",{"url":39,"title":40,"date":41,"updated":3,"category":10,"tags":42,"description":43,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190515\u002F1050733096\u002F","[JS奇怪的世界]No.3 全域環境與全域物件","2019-05-15 11:30:35",[12,13],"「全域環境」的觀念與「執行環境」也有一定的關係，一般來講當程式一開始執行時，都是在「全域環境」下，而這環境也是別人所寫好的一個程式，一個 「Global」",{"url":45,"title":46,"date":47,"updated":3,"category":10,"tags":48,"description":49,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F","[JS奇怪的世界]No.2 觀念小提醒:名稱 and 值配對與物件","2019-05-15 10:54:35",[12,13],"簡單來講一個名稱只會配對一個唯一的值，觀念就像一個變數只會配一個值，而名稱可以被定義及變換值很多次，但是一般狀況下名稱只會對上一個值。",{"url":51,"title":52,"date":53,"updated":3,"category":10,"tags":54,"description":55,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190515\u002F2002773604\u002F","[JS奇怪的世界]No.1 觀念小提醒:語法解析器、執行環境、詞彙環境","2019-05-15 09:54:35",[12,13],"接下來將會開始一系列的 JS 奇怪的部分，主要是為了深入了解人稱世界上誤會最大的程式語言 JavaScript，也希望藉由這次的筆記能夠讓自己成長。",{"url":57,"title":58,"date":59,"updated":3,"category":27,"tags":60,"description":62,"readingMinutes":37},"\u002Fhexo\u002F20190514\u002F1899427194\u002F","NexT 實用的設定與功能","2019-05-14 16:20:41",[27,61],"NexT","這邊紀錄一下我的 NexT 修改了那些地方及一些不錯的插件安裝。",{"url":64,"title":65,"date":66,"updated":3,"category":27,"tags":67,"description":69,"readingMinutes":37},"\u002Fhexo\u002F20190514\u002F2072033203\u002F","Hexo搜尋引擎優化","2019-05-14 08:38:25",[27,68,61],"SEO","由於自己架設計部落格之後凡事都要自己來，所以這邊紀錄一下該如何加強 Hexo 的 SEO 部分。",{"url":71,"title":72,"date":73,"updated":3,"category":74,"tags":75,"description":78,"readingMinutes":37},"\u002Fvue\u002F20190513\u002F948497494\u002F","Vuejs部屬GitHub Pages","2019-05-13 19:34:56","Vue",[12,74,76,77],"Git","GitHub","開發 Vue.js 結束後接下來就是部屬上 GitHub，這邊紀錄一下指令該如何部屬到 GitHub Pages 吧~",1036,104,{"postCount":79,"tagCount":82},1011,1784087367898]