[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F87\u002F":3,"post-page:zh-Hant:87":4,"author-stats:zh-Hant:full":77},null,{"posts":5,"total":75,"totalPages":76},[6,14,21,29,35,41,47,53,60,68],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":12,"readingMinutes":13},"\u002Fjavascript\u002F20190625\u002F981473819\u002F","let、const 提升的雷點","2019-06-25 19:52:32","JavaScript",[10],"今天看到一個題目，一開始我以為 undefined & undefined，結果竟然不是，所以這邊紀錄一下題目及答案。","1",{"url":15,"title":16,"date":17,"updated":3,"category":10,"tags":18,"description":19,"readingMinutes":20},"\u002Fjavascript\u002F20190624\u002F604717444\u002F","嘗試了解 JavaScript 的原型鏈","2019-06-24 12:28:48",[10],"這一篇其實我一直猶豫該不該寫，因為我深怕一個地方紀錄錯了會導致其他看的人也跟著錯，但是想一想我當初撰寫 Hexo 部落格的初衷是做自己的筆記後就又好點了，這一篇來記錄一下 JavaScript 的原型鏈這個主題","3",{"url":22,"title":23,"date":24,"updated":3,"category":25,"tags":26,"description":28,"readingMinutes":20},"\u002FTypeScript\u002F20190623\u002F3262185960\u002F","TypeScript 基礎入門-Class","2019-06-23 11:43:56","TypeScript",[27,10,25],"TypeScript 基礎入門","類別(class)這個是在 ES6 引入的，而這個功能又有何用處呢?讓我們來研究一下",{"url":30,"title":31,"date":32,"updated":3,"category":25,"tags":33,"description":34,"readingMinutes":13},"\u002FTypeScript\u002F20190622\u002F2385966784\u002F","TypeScript 基礎入門-Array","2019-06-22 22:27:26",[27,10,25],"接下來講到陣列的撰寫方式，其實與撰寫變數是太大的差異，這邊就來了解一下 TypeScript 中應該怎麼寫陣列吧",{"url":36,"title":37,"date":38,"updated":3,"category":25,"tags":39,"description":40,"readingMinutes":13},"\u002FTypeScript\u002F20190622\u002F3741788460\u002F","TypeScript 基礎入門-Function","2019-06-22 22:14:41",[27,10,25],"寫 JavaScript 的時候會非常撰寫 function，但 TypeScript 也有它的撰寫方式，讓我們來了解一下",{"url":42,"title":43,"date":44,"updated":3,"category":25,"tags":45,"description":46,"readingMinutes":13},"\u002FTypeScript\u002F20190622\u002F2982589304\u002F","TypeScript 基礎入門-混和型別","2019-06-22 21:56:38",[27,10,25],"前面講到 TypeScript 有所謂的型別推論的能力，在這邊再來講一個東西混和型別，這個東西又是什麼呢?讓我們來了解一下",{"url":48,"title":49,"date":50,"updated":3,"category":25,"tags":51,"description":52,"readingMinutes":13},"\u002FTypeScript\u002F20190622\u002F2739569432\u002F","TypeScript 基礎入門-型別推論","2019-06-22 15:49:05",[27,10,25],"前面已經了解該如何設置變數型別的方式，但是尾段其實也有講到如果不設置型別也是會編譯成功，但是實際上真的是這樣子嗎?這邊就來講講 TypeScript 裡面有一個很特別的東西，叫做型別推論，就算你不宣告型別 TypeScript 也會自己判定，來了解看看吧~",{"url":54,"title":55,"date":56,"updated":3,"category":25,"tags":57,"description":58,"readingMinutes":59},"\u002FTypeScript\u002F20190622\u002F3955309115\u002F","TypeScript 基礎入門-變數篇","2019-06-22 15:06:22",[27,10,25],"身邊滿多前端工程師都會接觸到 TypeScript，所以這邊紀錄一下 TypeScript 基礎入門","2",{"url":61,"title":62,"date":63,"updated":3,"category":64,"tags":65,"description":67,"readingMinutes":59},"\u002Fgit\u002F20190621\u002F4239571950\u002F","GitHub 發生衝突該如何解決","2019-06-21 16:35:09","Git",[66,64],"GitHub","當參加團隊專案開發的時候，其實很容易發生程式碼衝突問題，那這邊就來講一下該如何解除衝突吧~",{"url":69,"title":70,"date":71,"updated":3,"category":10,"tags":72,"description":74,"readingMinutes":13},"\u002Fjavascript\u002F20190621\u002F538821393\u002F","CoffeeScript 三元運算子","2019-06-21 11:49:07",[10,73],"CoffeeScript","這邊紀錄一下 CoffeeScript 的三元運算子該如何撰寫",1036,104,{"postCount":75,"tagCount":78},1011,1784087370385]