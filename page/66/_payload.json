[{"data":1,"prerenderedAt":88},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F66\u002F":3,"post-page:zh-Hant:66":4,"author-stats:zh-Hant:full":86},null,{"posts":5,"total":84,"totalPages":85},[6,15,27,36,44,51,57,63,69,78],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":13,"readingMinutes":14},"\u002Fvscode\u002F20200312\u002F457161302\u002F","Visual Studio Code(VSCode) 1.43 高亮問題","2020-03-12 10:20:20","VSCode",[10,12],"障礙排除","這幾天 Visual Studio Code(VSCode) 更新成了 1.43，但卻發生高亮不太正常?!不知道是刻意改的還是不正常的關係，所以這一篇紀錄一下該如何解決。","1",{"url":16,"title":17,"date":18,"updated":3,"category":19,"tags":20,"description":25,"readingMinutes":26},"\u002Fjavascript\u002F20200309\u002F2684951958\u002F","PixiJS V5 教學 (5) - Texture","2020-03-09 08:15:00","JavaScript",[21,22,19,23,24],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","有引入文字那麼就會有引入圖片啦~而 PIXI 會使用 GPU 以及 WebGL 來渲染圖片，而圖片需要經過處理才能夠使用的，而通常處理好的圖片都會稱為 Texture。","2",{"url":28,"title":29,"date":30,"updated":3,"category":19,"tags":31,"description":34,"readingMinutes":35},"\u002Fjavascript\u002F20200308\u002F3384986223\u002F","Fetch API 到底是 ESMAScript6 還是 Web APIs?","2020-03-08 12:07:26",[19,32,33],"ESMAScript6","Fetch API","Fetch API 是一個很多人會誤解的一個語法，最大誤解大概就是無法區分這一個語法到底是屬於 ECMAScript6 還是 Web APIs，所以這一篇來詳解一下吧。","3",{"url":37,"title":38,"date":39,"updated":3,"category":19,"tags":40,"description":43,"readingMinutes":35},"\u002Fjavascript\u002F20200307\u002F1405700237\u002F","JavaScript 核心觀念(1)-執行環境與作用域-JavaScript 運作方式","2020-03-07 21:37:04",[19,41,42],"JavaScript 核心篇","執行環境與作用域","第一篇將會來了解 JavaScript 的運作模式，",{"url":45,"title":46,"date":47,"updated":3,"category":19,"tags":48,"description":49,"readingMinutes":50},"\u002Fjavascript\u002F20200307\u002F318160061\u002F","JavaScript 核心觀念(0)-目錄及前言","2020-03-07 21:27:49",[19,41],"JavaScript 核心篇是基於六角學院的線上影音課程而撰寫的系列文章，雖然自己本身已經有上過 JavaScript 奇怪的部份，但每一位講者都有屬於他的講解方式，所以這一篇也來開始做一次紀錄以及學習囉。","4",{"url":52,"title":53,"date":54,"updated":3,"category":19,"tags":55,"description":56,"readingMinutes":26},"\u002Fjavascript\u002F20200302\u002F3104976087\u002F","PixiJS V5 教學 (4) - Text","2020-03-02 09:00:10",[21,22,19,23,24],"前一篇介紹了 Container，接下來要來看介紹前一篇所使用到的語法，也就是 new PIXI.Text()。",{"url":58,"title":59,"date":60,"updated":3,"category":19,"tags":61,"description":62,"readingMinutes":26},"\u002Fjavascript\u002F20200224\u002F4132682256\u002F","PixiJS V5 教學 (3) - Container","2020-02-24 08:17:13",[21,22,19,23,24],"前面基本知識也算是講得差不多，接下來將會介紹 PIXI 中的一個重要的東西，也就是 Container。",{"url":64,"title":65,"date":66,"updated":3,"category":19,"tags":67,"description":68,"readingMinutes":26},"\u002Fjavascript\u002F20200217\u002F4014508881\u002F","PixiJS V5 教學 (2) - WebGL 以及 Renderer","2020-02-17 00:05:28",[21,22,19,23,24],"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",{"url":70,"title":71,"date":72,"updated":3,"category":73,"tags":74,"description":77,"readingMinutes":50},"\u002Fvue\u002F20200214\u002F1055437216\u002F","一個指令快速部署 Vue Cli 到 GitHub Pages","2020-02-14 08:47:16","Vue",[19,73,75,76],"GitHub","Git","一般來說我們使用 Vue Cli 開發一個作品完畢之後都會需要部署到特定空間來展示作品，舉例來講 GitHub Pages 就是一個，那麼這一篇就來介紹該如何一個指令快速部署吧。",{"url":79,"title":80,"date":81,"updated":3,"category":73,"tags":82,"description":83,"readingMinutes":14},"\u002Fvue\u002F20200212\u002F3763656674\u002F","TypeError: this.getResolve is not a function","2020-02-12 08:53:36",[19,73],"最近剛好一些專案需求，所以會使用 Vue Cli2，但是在環境架設上突然發生一個錯誤，所以這一篇就來紀錄一下解決原因",1035,104,{"postCount":84,"tagCount":87},1009,1784020398446]