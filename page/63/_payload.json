[{"data":1,"prerenderedAt":95},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F63\u002F":3,"post-page:zh-Hant:63":4,"author-stats:zh-Hant:full":93},null,{"posts":5,"total":91,"totalPages":92},[6,18,27,36,45,51,58,66,74,80],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20200525\u002F1127214799\u002F","PixiJS V5 教學 (16) - Game HP","2020-05-25 09:00:08","JavaScript",[12,13,10,14,15],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","前一篇開始我們開始有那麼一點像是在製作遊戲，所以接下來會來介紹一下遊戲中的血條該如何製作。","1",{"url":19,"title":20,"date":21,"updated":3,"category":10,"tags":22,"description":25,"readingMinutes":26},"\u002Fjavascript\u002F20200524\u002F995184384\u002F","JavaScript 核心觀念(8)-執行環境與作用域-記憶體存放與釋放","2020-05-24 10:56:06",[10,23,24],"JavaScript 核心篇","執行環境與作用域","接下來講一下記憶體的回收機制。","2",{"url":28,"title":29,"date":30,"updated":3,"category":31,"tags":32,"description":35,"readingMinutes":26},"\u002Fcss\u002F20200523\u002F116058774\u002F","淺談 CSS 設計模式系列-Sass 7-1 Pattern 篇","2020-05-23 21:00:52","CSS",[33,34,31],"CSS 設計模式","7+1 設計模式","7+1 的設計模式主要是在講目錄結構的區分，早期開發 CSS 時只能將所有檔案放在同一個地方，那麼這樣就會導致維護上的困擾，因此在開發 Sass 時就可以搭配 @import 然後使用資料夾區分相關檔案，也就是所謂的 Sass 7-1 Pattern。",{"url":37,"title":38,"date":39,"updated":3,"category":40,"tags":41,"description":44,"readingMinutes":26},"\u002Fvue\u002F20200522\u002F1986801509\u002F","如何替 Vue Cli 加入 ESLint","2020-05-22 23:48:14","Vue",[10,40,42,43],"Vue Cli","ESLint","實際開發專案時我們為了確保程式碼的品質，通常都會加入程式碼風格管理器，也就是 ESLint，但在 Vue Cli 中該如何正確加入呢？",{"url":46,"title":47,"date":48,"updated":3,"category":10,"tags":49,"description":50,"readingMinutes":26},"\u002Fjavascript\u002F20200518\u002F1745009932\u002F","PixiJS V5 教學 (15) - Bump","2020-05-18 08:20:50",[12,13,10,14,15],"前一篇我們學習如何使用 PIXI 建立幾何圖形，那麼接下來要學習 PIXI 中一個我認為滿特別的東西，也就是碰撞檢測。",{"url":52,"title":53,"date":54,"updated":3,"category":31,"tags":55,"description":57,"readingMinutes":26},"\u002Fcss\u002F20200517\u002F4250484451\u002F","淺談 CSS 設計模式系列-BEM 篇","2020-05-17 15:33:48",[33,56,31],"BEM","BEM 是一個為了讓 class 有更好地維護架構 CSS 設計模式，但最主要的致命缺點就是命名長度過長，可是在實際開發上非常多人都會使用到 BEM。",{"url":59,"title":60,"date":61,"updated":3,"category":31,"tags":62,"description":64,"readingMinutes":65},"\u002Fcss\u002F20200517\u002F168089779\u002F","淺談 CSS 設計模式系列-OOCSS 篇","2020-05-17 12:53:41",[33,63,31],"OOCSS","OOCSS 是 CSS 設計模式的另一種，其中最主要代表的框架就是 Bootstrap。","3",{"url":67,"title":68,"date":69,"updated":3,"category":31,"tags":70,"description":72,"readingMinutes":73},"\u002Fcss\u002F20200516\u002F2341336904\u002F","淺談 CSS 設計模式-SMACSS 篇","2020-05-16 19:59:52",[33,71,31],"SMACSS","CSS 設計模式是一個觀念、規範以及心法，最主要就是要替我們提高開發與維護的效率。","5",{"url":75,"title":76,"date":77,"updated":3,"category":10,"tags":78,"description":79,"readingMinutes":26},"\u002Fjavascript\u002F20200511\u002F1897499725\u002F","PixiJS V5 教學 (14) - Graphics(2)","2020-05-11 07:30:15",[12,13,10,14,15],"前一篇介紹了基本的幾何圖形的繪畫，但是只介紹矩形，其實 PIXI 還有其他幾何圖形的繪畫，所以接下來就來講其他的幾何圖形囉",{"url":81,"title":82,"date":83,"updated":3,"category":84,"tags":85,"description":89,"readingMinutes":90},"\u002Fother\u002F20200510\u002F1067127387\u002F","解決 Windows 上輸入指令出現「因為這個系統上已停用指令碼執行，所以無法載入...」的問題","2020-05-10 22:52:10","雜談",[86,87,88],"Windows","障礙排除","Terminal","Windows PowerShell 跳「因為這個系統上已停用指令碼執行...」？這一篇講 Set-ExecutionPolicy 預設 Restricted 的原因， 整理 AllSigned、Bypass、Unrestricted 各選項差別與最安全的調整指令。","4",1035,104,{"postCount":91,"tagCount":94},1009,1784011728880]