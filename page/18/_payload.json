[{"data":1,"prerenderedAt":82},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F18\u002F":3,"post-page:zh-Hant:18":4,"author-stats:zh-Hant:full":80},null,{"posts":5,"total":78,"totalPages":79},[6,16,23,29,35,41,52,58,65,71],{"url":7,"title":8,"date":9,"updated":9,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20230926\u002F1829302614\u002F","Day12 - 關於 CORS 與 Env","2023-09-26 00:00:01","Nodejs",[12,13],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","前一篇我們完成了 Express + Mongoose 的整合，接下來我們要來處理一些環境變數的問題，以及 CORS 的問題。","6",{"url":17,"title":18,"date":19,"updated":19,"category":10,"tags":20,"description":21,"readingMinutes":22},"\u002Fnodejs\u002F20230925\u002F3347882734\u002F","Day11 - Express 與 Mongoose","2023-09-25 00:00:01",[12,13],"在上一篇文章中，我們初步建立了 MongoDB Atlas 的帳號，並且快速認識了 Mongoose，接下來當然就是要來整合再一起啦～","5",{"url":24,"title":25,"date":26,"updated":26,"category":10,"tags":27,"description":28,"readingMinutes":22},"\u002Fnodejs\u002F20230924\u002F3283299199\u002F","Day10 - MongoDB 與 Mongoose","2023-09-24 00:00:01",[12,13],"前一篇我們初步對於資料庫有了一點概念後，接下來當然要進入資料庫章節啦～",{"url":30,"title":31,"date":32,"updated":32,"category":10,"tags":33,"description":34,"readingMinutes":22},"\u002Fnodejs\u002F20230923\u002F264010765\u002F","Day9 - What is a database？","2023-09-23 00:00:01",[12,13],"對於一個網站或者服務來講，資料庫是不可或缺的一個元素，那麼什麼是資料庫呢？接下來我們就來聊聊什麼是資料庫。",{"url":36,"title":37,"date":38,"updated":38,"category":10,"tags":39,"description":40,"readingMinutes":15},"\u002Fnodejs\u002F20230922\u002F299784561\u002F","Day8 - 再續 Express.js","2023-09-22 00:00:01",[12,13],"前面我們介紹了 Express 以及 Middleware 的概念，這一篇我們將會繼續介紹 Express.js。",{"url":42,"title":43,"date":44,"updated":44,"category":45,"tags":46,"description":50,"readingMinutes":51},"\u002Fvscode\u002F20230921\u002F1985180173\u002F","Visual Studio Code 自訂折疊區塊","2023-09-21 09:43:55","VSCode",[45,47,48,49],"實用設定","Setting","開發","VSCode 預設可以折疊函式但不能自訂區塊？其實只要用 #region 跟 #endregion 包住程式碼就能自訂折疊範圍，這一篇示範這個少人知道但相當實用的小技巧。","2",{"url":53,"title":54,"date":55,"updated":55,"category":10,"tags":56,"description":57,"readingMinutes":15},"\u002Fnodejs\u002F20230921\u002F766511846\u002F","Day7 - Web Framework to Express.js","2023-09-21 00:00:01",[12,13],"前一篇我們嘗試用 Node.js 建立了 HTTP API，我相信你應該學到相當的多，但是實戰上來講，我們並不會直接使用 Node.js 來建立 HTTP API，因為這樣會太麻煩了，因此我們會使用一些框架來幫助我們建立 HTTP API，而這邊我們就來介紹一個非常熱門的框架，也就是 Express.js。",{"url":59,"title":60,"date":61,"updated":61,"category":10,"tags":62,"description":63,"readingMinutes":64},"\u002Fnodejs\u002F20230920\u002F2057349059\u002F","Day6 - 建立 HTTP API","2023-09-20 00:00:01",[12,13],"接下來這一篇我們將會來嘗試用純 Node.js 建立 HTTP API，基本上會使用到前面的知識點，所以前面的許多知識點都非常的重要唷～","8",{"url":66,"title":67,"date":68,"updated":68,"category":10,"tags":69,"description":70,"readingMinutes":15},"\u002Fnodejs\u002F20230919\u002F1426601281\u002F","Day5 - Node.js Modules","2023-09-19 00:00:01",[12,13],"前一篇我們認識了一些內置模組，接下來這一篇我們要來認識一個有點特別但又好像不怎麼特別的 Modules",{"url":72,"title":73,"date":74,"updated":74,"category":10,"tags":75,"description":76,"readingMinutes":77},"\u002Fnodejs\u002F20230918\u002F3279535859\u002F","Day4 - Node.js 內置模組","2023-09-18 00:00:01",[12,13],"上一篇我們講了一大推東西，終於撰寫了第一個簡單的 Node.js 專案（雖然範例是透過 Node.js 官方提供的），接下來我們會針對 Node.js 的內置模組來做一些介紹。","10",1036,104,{"postCount":78,"tagCount":81},1011,1784087368230]