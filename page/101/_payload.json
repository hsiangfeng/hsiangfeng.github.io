[{"data":1,"prerenderedAt":83},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F101\u002F":3,"post-page:zh-Hant:101":4,"author-stats:zh-Hant:full":81},null,{"posts":5,"total":79,"totalPages":80},[6,15,22,30,38,44,51,58,65,72],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":13,"readingMinutes":14},"\u002Fvue\u002F20190510\u002F1766915506\u002F","props與emit的傳遞方式","2019-05-10 19:04:33","Vue",[12,10],"JavaScript","這幾天自己突然又開始使用 Vue 來製作一個小東西，因為我都是用 components 來製作，所以勢必要了解 props 與 emit 之間是如何傳遞的。","2",{"url":16,"title":17,"date":18,"updated":19,"category":10,"tags":20,"description":21,"readingMinutes":14},"\u002Fvue\u002F20190510\u002F86469050\u002F","Vue 的 @（小老鼠）符號是什麼？src 路徑別名與 .. 的差異","2019-05-10 10:30:35","2026-06-11 09:00:00",[12,10],"在 Vue 專案的 import 路徑常看到 @ 這個小老鼠符號，它其實是 Vue CLI 幫你設定好的 src 路徑別名（alias）。這篇講清楚 @ 跟相對路徑 .. 的差異，以及 Vue CLI 2 與 3 的設定位置在哪。",{"url":23,"title":24,"date":25,"updated":25,"category":26,"tags":27,"description":29,"readingMinutes":14},"\u002Flearnexp\u002F20190509\u002F3880255625\u002F","適當的休息也是學習的一種方式","2019-05-09 22:18:55","學習經驗",[28,26],"其他","這陣子準備一個小作品同時也不停地幫忙一些私下找我聊聊的朋友們，發現有很多朋友都有一種不太好的習慣，這邊分享一下經驗:D",{"url":31,"title":32,"date":33,"updated":3,"category":34,"tags":35,"description":36,"readingMinutes":37},"\u002Fcss\u002F20190509\u002F1681665762\u002F","用CSS來判別跑版","2019-05-09 10:23:41","CSS",[34],"有時候我們在做 CSS 切版的時候常常會發生跑版的狀況，但是一般瀏覽器並沒有辦法提供給我們格線系統，所以這邊紀錄一下使用 CSS 來開啟格線。","1",{"url":39,"title":40,"date":41,"updated":3,"category":10,"tags":42,"description":43,"readingMinutes":37},"\u002Fvue\u002F20190508\u002F40080850\u002F","vuejs(cli)中使用wowjs","2019-05-08 22:10:45",[12,10],"最近正在製作一個小作品，因為是使用 Vue Cli 開發，這邊紀錄一下該如何在 Vue Cli 中使用 WOWJS",{"url":45,"title":46,"date":47,"updated":3,"category":12,"tags":48,"description":49,"readingMinutes":50},"\u002Fjavascript\u002F20190507\u002F3500556123\u002F","JavaScript全域變數與區域變數的差別","2019-05-07 15:33:37",[12],"JavaScript 中真的滿多坑可以撲倒新手的，一個不小心就踩到地雷，所以這一篇來講講全域變數及區域變數的差異吧~","4",{"url":52,"title":53,"date":54,"updated":3,"category":55,"tags":56,"description":57,"readingMinutes":37},"\u002Fhexo\u002F20190506\u002F2831397096\u002F","Hexo使用特殊符號sitemap會出現錯誤","2019-05-06 20:42:07","Hexo",[55],"最近在調整 Hexo 的 SEO 時發現 sitemap 竟然出現錯誤?!",{"url":59,"title":60,"date":61,"updated":3,"category":62,"tags":63,"description":64,"readingMinutes":14},"\u002Fanalytics\u002F20190506\u002F1879363764\u002F","如何使用GA來替自己網站作分析","2019-05-06 15:42:13","Analytics",[62,55],"這一篇主要是被朋友推坑下來做撰寫得，所以這邊會介紹該如何埋入 Analytics，就是俗稱得 GA 分析，只要你有自己的網站、部落格，我推薦要使用 GA 分析，這可以讓自己了解到自己那些文章是屬於熱門文章。",{"url":66,"title":67,"date":68,"updated":3,"category":12,"tags":69,"description":70,"readingMinutes":71},"\u002Fjavascript\u002F20190505\u002F1432256317\u002F","JavaScript 製作分頁功能(使用 Fetch APIs)","2019-05-05 15:06:43",[12],"開網站會很長需要使用到分頁的功能，有些是在後端處理之後往前端丟，這種通常比較不擔心那麼多，只需要在資料庫做好相關設置就好了，可是如果今天後端將所有資料一次往前端丟那麼就要自己來刻分頁邏輯，所以寫一篇文章加強自己的分頁邏輯撰寫。","7",{"url":73,"title":74,"date":75,"updated":75,"category":26,"tags":76,"description":77,"readingMinutes":78},"\u002Flearnexp\u002F20190503\u002F3738458215\u002F","該如何制定自己的學習","2019-05-03 09:53:55",[28,26],"今天又寫了一篇心得分享，主要原因出在先前所撰寫的三篇文章該如何正確的學習前端技術&程式語言、學習心態調整及你願意犧牲多少來得到你想要的事物，很多人都來詢問該如何學習及撰寫筆記這方面的問題，所以我也寫一下我提供的建議。","6",1035,104,{"postCount":79,"tagCount":82},1009,1784010305643]