[{"data":1,"prerenderedAt":92},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F69\u002F":3,"post-page:zh-Hant:69":4,"author-stats:zh-Hant:full":90},null,{"posts":5,"total":88,"totalPages":89},[6,14,20,35,41,53,59,69,75,82],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":12,"readingMinutes":13},"\u002Fpwa\u002F20191203\u002F2841782636\u002F","Day6-PWA 初體驗 - 小試身手","2019-12-03 09:53:48","PWA",[10],"前面真的講滿多廢話的，接下來這邊就準備拿一個小專案來小試身手囉~","2",{"url":15,"title":16,"date":17,"updated":3,"category":10,"tags":18,"description":19,"readingMinutes":13},"\u002Fpwa\u002F20191126\u002F3955439291\u002F","Day5-PWA 初體驗 - 開發環境","2019-11-26 09:24:48",[10],"前面講那麼多東西，也認識了基本的 PWA 架構，接下來就要來準備一下開發環境了。",{"url":21,"title":22,"date":23,"updated":3,"category":24,"tags":25,"description":33,"readingMinutes":34},"\u002Fjavascript\u002F20191119\u002F2727084611\u002F","有點長的淺談 JavaScript function 函式","2019-11-19 21:11:19","JavaScript",[24,26,27,28,29,30,31,32],"Function","Named Function","Anonymous Function","Arrow Function","IIFE","Vue","ES6","昨天在六角學院做了線上直播的介紹，過程真的是緊張到爆炸，我知道自己其實滿容易健忘的，所以不寫文章筆記心裡有點過意不去，因此這一篇 「有點長的淺談 JavaScript function 函式」就誕生了。","7",{"url":36,"title":37,"date":38,"updated":3,"category":10,"tags":39,"description":40,"readingMinutes":13},"\u002Fpwa\u002F20191114\u002F405525681\u002F","Day4-PWA 初體驗 - PWA 架構(二)","2019-11-14 22:56:48",[10],"這一篇將會介紹 PWA 的核心，也就是 Service Workers。",{"url":42,"title":43,"date":44,"updated":45,"category":46,"tags":47,"description":51,"readingMinutes":52},"\u002Fother\u002F20191111\u002F1875438261\u002F","Markdown 入門教學：常見語法與範例完整整理","2019-11-11 09:48:27","2026-03-18 13:20:00","雜談",[48,49,50],"Markdown","Markdown 教學","Markdown 語法","一篇涵蓋所有常見 Markdown 語法的入門教學，從標題、粗體、清單到表格與程式碼區塊，每個語法皆附範例與對應的 HTML 標籤說明，幫助你快速上手 Markdown 寫作。","4",{"url":54,"title":55,"date":56,"updated":3,"category":10,"tags":57,"description":58,"readingMinutes":13},"\u002Fpwa\u002F20191104\u002F3071954899\u002F","Day3-PWA 初體驗 - PWA 架構(一)","2019-11-04 17:24:48",[10],"接下來這一篇將會來了解 PWA 的架構，但是這邊將會拆成兩個章節介紹。",{"url":60,"title":61,"date":62,"updated":3,"category":46,"tags":63,"description":67,"readingMinutes":68},"\u002Fother\u002F20191028\u002F864994619\u002F","軟體工程師必學的文字對話藝術","2019-10-28 21:28:54",[64,65,66],"其他","軟體工程師","文字對話藝術","文字交流上其實有許多非常需要注意的事情，看似單純幾個中文字，但真正傳遞的感受是不同的，尤其是身為軟體工程師這個行業更不用說最常使用文字與他人溝通，所以這一篇將會來集中討論關於文字對話上的藝術。","5",{"url":70,"title":71,"date":72,"updated":3,"category":10,"tags":73,"description":74,"readingMinutes":13},"\u002Fpwa\u002F20191024\u002F1480429268\u002F","Day2-PWA 初體驗 - PWA 特色","2019-10-24 19:24:48",[10],"這一篇將會來介紹如何開啟 PWA 的特色。",{"url":76,"title":77,"date":78,"updated":78,"category":79,"tags":80,"description":81,"readingMinutes":52},"\u002Flearnexp\u002F20191020\u002F1606493563\u002F","2019 MOPCON 一日遊記","2019-10-20 18:02:46","學習經驗",[64,79],"由於 MOPCON 第一天有點事情所以只去第二天，這一篇就來記錄一下 MOPCON 第二天的一日遊吧。",{"url":83,"title":84,"date":85,"updated":3,"category":10,"tags":86,"description":87,"readingMinutes":13},"\u002Fpwa\u002F20191017\u002F2186080947\u002F","Day1-PWA 初體驗 - 前言","2019-10-17 09:14:48",[10],"PWA 是一個逐漸成熟的網頁技術，那 PWA 到底是什麼?它又有用處?又為什麼要了解?所以接下來的文章就讓我們來了解 PWA 吧 :D",1035,104,{"postCount":88,"tagCount":91},1009,1784020398478]