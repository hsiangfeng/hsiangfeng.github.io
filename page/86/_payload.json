[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Fpage\u002F86\u002F":3,"post-page:zh-Hant:86":4,"author-stats:zh-Hant:full":77},null,{"posts":5,"total":75,"totalPages":76},[6,16,22,28,35,41,47,53,59,68],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20190627\u002F3580804465\u002F","全端勇士之路 Node.js 基礎學習-nodemon","2019-06-27 08:51:20","Nodejs",[12,13],"Node.js","全端勇士之路 Node.js","以往我們修改 js 檔案後，往往都要重新停下來再執行 node all.js，但是常常這樣子其實很麻煩，所以這邊介紹一個很好用的工具 nodemon","1",{"url":17,"title":18,"date":19,"updated":3,"category":10,"tags":20,"description":21,"readingMinutes":15},"\u002Fnodejs\u002F20190626\u002F1317979814\u002F","npm 安裝指令差異","2019-06-26 22:03:53",[12],"基本上這一篇算是做一下筆記整理，避免自己哪天金魚腦忘記，雖然很常打就是了",{"url":23,"title":24,"date":25,"updated":3,"category":10,"tags":26,"description":27,"readingMinutes":15},"\u002Fnodejs\u002F20190626\u002F2459037265\u002F","npm 版本號辨別","2019-06-26 21:19:03",[12],"這邊紀錄一下如何辨別 npm 版本號，避免自己忘記怎麼看板本號...",{"url":29,"title":30,"date":31,"updated":3,"category":10,"tags":32,"description":33,"readingMinutes":34},"\u002Fnodejs\u002F20190626\u002F477012262\u002F","全端勇士之路 Node.js 基礎學習-開啟 Web Server","2019-06-26 19:33:04",[12,13],"接下來我們就準備來學習開啟 Web Server，而 Node.js 本身就提供了 Web Server 的功能，所以就來看看怎麼建立一個 Web Server","2",{"url":36,"title":37,"date":38,"updated":3,"category":10,"tags":39,"description":40,"readingMinutes":34},"\u002Fnodejs\u002F20190626\u002F269653331\u002F","全端勇士之路 Node.js 基礎學習-模組化開發","2019-06-26 16:14:21",[12,13],"接下來這邊將會來記錄一下 Node.js 的模組化開發，首先我們必須先認識到幾個語法。",{"url":42,"title":43,"date":44,"updated":3,"category":10,"tags":45,"description":46,"readingMinutes":15},"\u002Fnodejs\u002F20190626\u002F1683312860\u002F","全端勇士之路 Node.js 基礎學習-全域物件","2019-06-26 14:09:37",[12,13],"一般來講我們再撰寫 JavaScript 時都知道在瀏覽器上有一個全域物件叫做 Window，但是在 Node.js 上也有一個全域物件",{"url":48,"title":49,"date":50,"updated":3,"category":10,"tags":51,"description":52,"readingMinutes":15},"\u002Fnodejs\u002F20190626\u002F658065960\u002F","全端勇士之路 Node.js 基礎學習-node 模式","2019-06-26 13:55:08",[12,13],"這個篇幅可能會比較短，主要只是記錄可以使用 node 模式直接來撰寫 JavaScript。",{"url":54,"title":55,"date":56,"updated":3,"category":10,"tags":57,"description":58,"readingMinutes":34},"\u002Fnodejs\u002F20190626\u002F1885201810\u002F","全端勇士之路 Node.js 基礎學習-基礎篇","2019-06-26 12:02:21",[12,13],"又是一篇基礎學習系列的開啟，這是為了讓自己對 Node.js 觀念及開發更清楚所撰寫的系列文章，廢話不多說就開始吧~",{"url":60,"title":61,"date":62,"updated":3,"category":63,"tags":64,"description":67,"readingMinutes":15},"\u002Fpython\u002F20190626\u002F2933081730\u002F","拖曳影片檔案到 CMD 圖示內透過 Python 生成影片字幕","2019-06-26 10:13:30","Python",[63,65,66],"AI","字幕","由於先前撰寫了[使用 Python 替影片自動上字幕]的文章，後來自己在使用的時候每一次都要打開指令視窗輸入指令，對於金魚腦的我來講實在很不方便，所以這邊稍微製作 .bat 檔案，直接拖曳進去自動生成字幕。",{"url":69,"title":70,"date":71,"updated":3,"category":72,"tags":73,"description":74,"readingMinutes":15},"\u002Fjavascript\u002F20190625\u002F981473819\u002F","let、const 提升的雷點","2019-06-25 19:52:32","JavaScript",[72],"今天看到一個題目，一開始我以為 undefined & undefined，結果竟然不是，所以這邊紀錄一下題目及答案。",1035,104,{"postCount":75,"tagCount":78},1009,1784020398890]