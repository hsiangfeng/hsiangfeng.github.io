",[47,834,835,840,848],{"__ignoreMap":45},[27,836,837],{"class":51,"line":52},[27,838,839],{"class":434},"\u002F\u002F abstracts\u002F_index.scss\n",[27,841,842,844,846],{"class":51,"line":67},[27,843,157],{"class":268},[27,845,483],{"class":59},[27,847,121],{"class":63},[27,849,850,852,855],{"class":51,"line":74},[27,851,157],{"class":268},[27,853,854],{"class":59}," 'mixins'",[27,856,121],{"class":63},[12,858,859,860,863],{},"這樣我們可以一次性匯入所以可以使用的東西，這樣我們就可以在 ",[47,861,862],{},"style.scss"," 中這樣使用：",[40,865,867],{"className":232,"code":866,"language":234,"meta":45,"style":45},"@import 'abstracts\u002Findex';\nbody {\n  background-color: $primary-color;\n  @include center-block;\n}\n",[47,868,869,878,884,894,905],{"__ignoreMap":45},[27,870,871,873,876],{"class":51,"line":52},[27,872,157],{"class":268},[27,874,875],{"class":59}," 'abstracts\u002Findex'",[27,877,121],{"class":63},[27,879,880,882],{"class":51,"line":67},[27,881,278],{"class":277},[27,883,281],{"class":63},[27,885,886,888,890,892],{"class":51,"line":74},[27,887,286],{"class":249},[27,889,246],{"class":63},[27,891,242],{"class":241},[27,893,121],{"class":63},[27,895,896,899,903],{"class":51,"line":95},[27,897,898],{"class":268},"  @include",[27,900,902],{"class":901},"scAaK"," center-block",[27,904,121],{"class":63},[27,906,907],{"class":51,"line":100},[27,908,297],{"class":63},[12,910,911],{},"所以你可能第一直覺就是這樣改：",[40,913,915],{"className":232,"code":914,"language":234,"meta":45,"style":45},"\u002F\u002F abstracts\u002F_index.scss\n@use 'variables';\n",[47,916,917,921],{"__ignoreMap":45},[27,918,919],{"class":51,"line":52},[27,920,839],{"class":434},[27,922,923,925,927],{"class":51,"line":67},[27,924,161],{"class":268},[27,926,483],{"class":59},[27,928,121],{"class":63},[12,930,931,932,934,935,937,938,940,941,169],{},"但其實不太對，這樣做是會導致 ",[47,933,354],{}," 的錯誤訊息，畢竟前面有講過 ",[47,936,161],{}," 會在這個檔案中建立一個命名空間，所以你無法在 ",[47,939,862],{}," 中直接使用 ",[47,942,372],{},[12,944,945,946,948],{},"那該怎麼做呢？這邊要改用的方式就是 ",[47,947,165],{