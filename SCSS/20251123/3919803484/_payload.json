" 或 ",[47,164,165],{},"@forward"," 來取代 ",[47,168,157],{},"。",[12,171,172],{},"接下來我們將會嘗試了解一下這個變化會有什麼樣的問題。",[12,174,175],{},"如果你是使用 VSCode 的 Watch Sass 套件，那有很高機會看不到這個錯誤，因為 Watch Sass 套件的版本比較舊，但我們實際正式開發環境會是使用 Vite、Webpack 或其他工具來編譯 SCSS，所以還是會遇到這個問題。",[12,177,178],{},"如果你不想使用 Vite、Webpack 等工具來編譯 SCSS，你也可以考慮使用 Parcel 來編譯取代。",[20,180,182],{"id":181},"sass-use-與-forward-有什麼改變","Sass @use 與 @forward 有什麼改變？",[12,184,185,186,188,189,162,191,169],{},"基本上新版就都是一律建議你不要再使用 ",[47,187,157],{},"，而是改用 ",[47,190,161],{},[47,192,165],{},[12,194,195],{},"假設今天有一個架構是這樣：",[40,197,201],{"className":198,"code":199,"language":200,"meta":45,"style":45},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","styles\u002F\n  abstracts\u002F\n    _variables.scss\n  style.scss\n","txt",[47,202,203,208,213,218],{"__ignoreMap":45},[27,204,205],{"class":51,"line":52},[27,206,207],{},"styles\u002F\n",[27,209,210],{"class":51,"line":67},[27,211,212],{},"  abstracts\u002F\n",[27,214,215],{"class":51,"line":74},[27,216,217],{},"    _variables.scss\n",[27,219,220],{"class":51,"line":95},[27,221,222],{},"  style.scss\n",[12,224,225,226,229],{},"然後 ",[47,227,228],{},"style\u002Fabstracts\u002F_variables.scss"," 內容是：",[40,231,235],{"className":232,"code":233,"language":234,"meta":45,"style":45},"language-scss shiki shiki-themes github-light github-light github-dark-high-contrast","$primary-color: #3498db;\n","scss",[47,236,237],{"__ignoreMap":45},[27,238,239,243,247,251],{"class":51,"line":52},[27,240,242],{"class":241},"syBk-","$primary-color",[27,244,246],{"class":245},"sTzn1",": ",[27,248,250],{"class":249},"stw71","#3498db",[27,252,121],{"class":63},[12,254,255,256,229],{},"接著 ",[47,257,258],{},"style\u002Fstyle.scss",[40,260,262],{"className":232,"code":261,"language":234,"meta":45,"style":45},"@import 'abstracts\u002Fvariables';\nbody {\n  background-color: $primary-color;\n}\n",[47,263,264,273,282,293],{"__ignoreMap":45},[27,265,266,269,271],{"class":51,"line":52},[27,267,157],{"class":268},"sOudu",[27,270,118],{"class":59},[27,272,121],{"class":63},[27,274,275,279],{"class":51,"line":67},[27,276,278],{"class":277},"syv7_","body",[27,280,281],{"class":63}," {\n",[27,283,284,287,289,291],{"class":51,"line":74},[27,285,286],{"class":249},"  background-color",[27,288,246],{"class":63},[27,290,242],{"class":241},[27,292,121],{"class":63},[27,294,295],{"class":51,"line":95},[27,296,297],{"class":63},"}\n",[12,299,300],{},"相信這是大家所熟悉的寫法。",[302,303,305],"h3",{"id":304},"使用-use-的改變","使用 @use 的改變",[12,307,308,309,311],{},"但是新版之後，你必須改使用 ",[47,310,161],{},"，你可能會很直覺的想改成這樣：",[40,313,315],{"className":232,"code":314,"language":234,"meta":45,"style":45},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: $primary-color;\n}\n",[47,316,317,325,329,335,345],{"__ignoreMap":45},[27,318,319,321,323],{"class":51,"line":52},[27,320,161],{"class":268},[27,322,118],{"class":59},[27,324,121],{"class":63},[27,326,327],{"class":51,"line":67},[27,328,71],{"emptyLinePlaceholder":70},[27,330,331,333],{"class":51,"line":74},[27,332,278],{"class":277},[27,334,281],{"class":63},[27,336,337,339,341,343],{"class":51,"line":95},[27,338,286],{"class":249},[27,340,246],{"class":63},[27,342,242],{"class":241},[27,344,121],{"class":63},[27,346,347],{"class":51,"line":100},[27,348,297],{"class":63},[12,350,351,352,355],{},"接著你就會得到一串 ",[47,353,354],{},"Undefined variable: \"$primary-color\"."," 的錯誤訊息。",[12,357,358,359,361,362,365,366,369,370,373],{},"這個原因是因為使用 ",[47,360,161],{}," 之後，Sass 會將變數、函式和混入（mixins）封裝在模組命名空間中，什麼意思呢？當我們使用 ",[47,363,364],{},"@use 'abstracts\u002Fvariables';"," 時，Sass 會將 ",[47,367,368],{},"variables"," 這個檔案名稱作為一個命名空間，所以你必須使用 ",[47,371,372],{},"variables.$primary-color"," 來存取這個變數。",[12,375,376],{},"所以正確的使用方式是這樣：",[40,378,380],{"className":232,"code":379,"language":234,"meta":45,"style":45},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: variables.$primary-color;\n}\n",[47,381,382,390,394,400,415],{"__ignoreMap":45},[27,383,384,386,388],{"class":51,"line":52},[27,385,161],{"class":268},[27,387,118],{"class":59},[27,389,121],{"class":63},[27,391,392],{"class":51,"line":67},[27,393,71],{"emptyLinePlaceholder":70},[27,395,396,398],{"class":51,"line":74},[27,397,278],{"class":277},[27,399,281],{"class":63},[27,401,402,404,406,408,411,413],{"class":51,"line":95},[27,403,286],{"class":249},[27,405,246],{"class":63},[27,407,368],{"class":241},[27,409,410],{"class":63},".",[27,412,242],{"class":241},[27,414,121],{"class":63},[27,416,417],{"class":51,"line":100},[27,418,297],{"class":63},[12,420,421,422,424],{},"那麼這樣做有什麼好處呢？你可以避免命名衝突，當你 ",[47,423,157],{}," 一大推檔案時，很容易會有變數名稱重複的問題，就像...",[40,426,428],{"className":232,"code":427,"language":234,"meta":45,"style":45},"\u002F\u002F variables.scss\n$primary-color: #3498db;\n\n\u002F\u002F another-variables.scss\n$primary-color: #e74c3c;\n",[47,429,430,436,446,450,455],{"__ignoreMap":45},[27,431,432],{"class":51,"line":52},[27,433,435],{"class":434},"sGBqm","\u002F\u002F variables.scss\n",[27,437,438,440,442,444],{"class":51,"line":67},[27,439,242],{"class":241},[27,441,246],{"class":245},[27,443,250],{"class":249},[27,445,121],{"class":63},[27,447,448],{"class":51,"line":74},[27,449,71],{"emptyLinePlaceholder":70},[27,451,452],{"class":51,"line":95},[27,453,454],{"class":434},"\u002F\u002F another-variables.scss\n",[27,456,457,459,461,464],{"class":51,"line":100},[27,458,242],{"class":241},[27,460,246],{"class":245},[27,462,463],{"class":249},"#e74c3c",[27,465,121],{"class":63},[12,467,468,469,471],{},"如果是使用 ",[47,470,157],{},"，那麼這兩個變數就會衝突：",[40,473,475],{"className":232,"code":474,"language":234,"meta":45,"style":45},"@import 'variables';\n@import 'another-variables';\n\nbody {\n  background-color: $primary-color; \u002F\u002F 這邊就會發生衝突\n}\n",[47,476,477,486,495,499,505,519],{"__ignoreMap":45},[27,478,479,481,484],{"class":51,"line":52},[27,480,157],{"class":268},[27,482,483],{"class":59}," 'variables'",[27,485,121],{"class":63},[27,487,488,490,493],{"class":51,"line":67},[27,489,157],{"class":268},[27,491,492],{"class":59}," 'another-variables'",[27,494,121],{"class":63},[27,496,497],{"class":51,"line":74},[27,498,71],{"emptyLinePlaceholder":70},[27,500,501,503],{"class":51,"line":95},[27,502,278],{"class":277},[27,504,281],{"class":63},[27,506,507,509,511,513,516],{"class":51,"line":100},[27,508,286],{"class":249},[27,510,246],{"class":63},[27,512,242],{"class":241},[27,514,515],{"class":63},"; ",[27,517,518],{"class":434},"\u002F\u002F 這邊就會發生衝突\n",[27,520,521],{"class":51,"line":106},[27,522,297],{"class":63},[12,524,525,526,528,529,531],{},"所以到底是 ",[47,527,250],{}," 還是 ",[47,530,463],{},"？",[533,534,535,539],"details",{},[536,537,538],"summary",{},"點我看解答(請認真思考後再看解答)","\n答案是：#e74c3c，因為後面的會覆蓋前面的。\n",[12,541,542,543,545],{},"因此，使用 ",[47,544,161],{}," 可以避免這種命名衝突的問題：",[40,547,549],{"className":232,"code":548,"language":234,"meta":45,"style":45},"@use 'variables';\n@use 'another-variables';\n\nbody {\n  background-color: another-variables.$primary-color; \u002F\u002F 明確指定使用哪個命名空間的變數\n}\n",[47,550,551,559,567,571,577,595],{"__ignoreMap":45},[27,552,553,555,557],{"class":51,"line":52},[27,554,161],{"class":268},[27,556,483],{"class":59},[27,558,121],{"class":63},[27,560,561,563,565],{"class":51,"line":67},[27,562,161],{"class":268},[27,564,492],{"class":59},[27,566,121],{"class":63},[27,568,569],{"class":51,"line":74},[27,570,71],{"emptyLinePlaceholder":70},[27,572,573,575],{"class":51,"line":95},[27,574,278],{"class":277},[27,576,281],{"class":63},[27,578,579,581,583,586,588,590,592],{"class":51,"line":100},[27,580,286],{"class":249},[27,582,246],{"class":63},[27,584,585],{"class":241},"another-variables",[27,587,410],{"class":63},[27,589,242],{"class":241},[27,591,515],{"class":63},[27,593,594],{"class":434},"\u002F\u002F 明確指定使用哪個命名空間的變數\n",[27,596,597],{"class":51,"line":106},[27,598,297],{"class":63},[12,600,601],{},"這是一個非常重大的更新與調整，對於較大型專案來講，我認為是非常值得更新的。",[12,603,604,605,608,609,611,612,615,616,618,619,621,622,624,62