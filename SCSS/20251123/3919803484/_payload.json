rward"," 來取代 ",[47,168,157],{},"。",[12,171,172],{},"接下來我們將會嘗試了解一下這個變化會有什麼樣的問題。",[12,174,175],{},"如果你是使用 VSCode 的 Watch Sass 套件，那有很高機會看不到這個錯誤，因為 Watch Sass 套件的版本比較舊，但我們實際正式開發環境會是使用 Vite、Webpack 或其他工具來編譯 SCSS，所以還是會遇到這個問題。",[12,177,178],{},"如果你不想使用 Vite、Webpack 等工具來編譯 SCSS，你也可以考慮使用 Parcel 來編譯取代。",[20,180,182],{"id":181},"sass-use-與-forward-有什麼改變","Sass @use 與 @forward 有什麼改變？",[12,184,185,186,188,189,162,191,169],{},"基本上新版就都是一律建議你不要再使用 ",[47,187,157],{},"，而是改用 ",[47,190,161],{},[47,192,165],{},[12,194,195],{},"假設今天有一個架構是這樣：",[40,197,201],{"className":198,"code":199,"language":200,"meta":45,"style":45},"language-txt shiki shiki-themes github-dark-high-contrast","styles\u002F\n  abstracts\u002F\n    _variables.scss\n  style.scss\n","txt",[47,202,203,208,213,218],{"__ignoreMap":45},[27,204,205],{"class":51,"line":52},[27,206,207],{},"styles\u002F\n",[27,209,210],{"class":51,"line":67},[27,211,212],{},"  abstracts\u002F\n",[27,214,215],{"class":51,"line":74},[27,216,217],{},"    _variables.scss\n",[27,219,220],{"class":51,"line":95},[27,221,222],{},"  style.scss\n",[12,224,225,226,229],{},"然後 ",[47,227,228],{},"style\u002Fabstracts\u002F_variables.scss"," 內容是：",[40,231,235],{"className":232,"code":233,"language":234,"meta":45,"style":45},"language-scss shiki shiki-themes github-dark-high-contrast","$primary-color: #3498db;\n","scss",[47,236,237],{"__ignoreMap":45},[27,238,239,242,246],{"class":51,"line":52},[27,240,241],{"class":55},"$primary-color: ",[27,243,245],{"class":244},"sCcAr","#3498db",[27,247,121],{"class":63},[12,249,250,251,229],{},"接著 ",[47,252,253],{},"style\u002Fstyle.scss",[40,255,257],{"className":232,"code":256,"language":234,"meta":45,"style":45},"@import 'abstracts\u002Fvariables';\nbody {\n  background-color: $primary-color;\n}\n",[47,258,259,268,277,290],{"__ignoreMap":45},[27,260,261,264,266],{"class":51,"line":52},[27,262,157],{"class":263},"sWyjQ",[27,265,118],{"class":59},[27,267,121],{"class":63},[27,269,270,274],{"class":51,"line":67},[27,271,273],{"class":272},"sKpQp","body",[27,275,276],{"class":63}," {\n",[27,278,279,282,285,288],{"class":51,"line":74},[27,280,281],{"class":244},"  background-color",[27,283,284],{"class":63},": ",[27,286,287],{"class":55},"$primary-color",[27,289,121],{"class":63},[27,291,292],{"class":51,"line":95},[27,293,294],{"class":63},"}\n",[12,296,297],{},"相信這是大家所熟悉的寫法。",[299,300,302],"h3",{"id":301},"使用-use-的改變","使用 @use 的改變",[12,304,305,306,308],{},"但是新版之後，你必須改使用 ",[47,307,161],{},"，你可能會很直覺的想改成這樣：",[40,310,312],{"className":232,"code":311,"language":234,"meta":45,"style":45},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: $primary-color;\n}\n",[47,313,314,322,326,332,342],{"__ignoreMap":45},[27,315,316,318,320],{"class":51,"line":52},[27,317,161],{"class":263},[27,319,118],{"class":59},[27,321,121],{"class":63},[27,323,324],{"class":51,"line":67},[27,325,71],{"emptyLinePlaceholder":70},[27,327,328,330],{"class":51,"line":74},[27,329,273],{"class":272},[27,331,276],{"class":63},[27,333,334,336,338,340],{"class":51,"line":95},[27,335,281],{"class":244},[27,337,284],{"class":63},[27,339,287],{"class":55},[27,341,121],{"class":63},[27,343,344],{"class":51,"line":100},[27,345,294],{"class":63},[12,347,348,349,352],{},"接著你就會得到一串 ",[47,350,351],{},"Undefined variable: \"$primary-color\"."," 的錯誤訊息。",[12,354,355,356,358,359,362,363,366,367,370],{},"這個原因是因為使用 ",[47,357,161],{}," 之後，Sass 會將變數、函式和混入（mixins）封裝在模組命名空間中，什麼意思呢？當我們使用 ",[47,360,361],{},"@use 'abstracts\u002Fvariables';"," 時，Sass 會將 ",[47,364,365],{},"variables"," 這個檔案名稱作為一個命名空間，所以你必須使用 ",[47,368,369],{},"variables.$primary-color"," 來存取這個變數。",[12,372,373],{},"所以正確的使用方式是這樣：",[40,375,377],{"className":232,"code":376,"language":234,"meta":45,"style":45},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: variables.$primary-color;\n}\n",[47,378,379,387,391,397,412],{"__ignoreMap":45},[27,380,381,383,385],{"class":51,"line":52},[27,382,161],{"class":263},[27,384,118],{"class":59},[27,386,121],{"class":63},[27,388,389],{"class":51,"line":67},[27,390,71],{"emptyLinePlaceholder":70},[27,392,393,395],{"class":51,"line":74},[27,394,273],{"class":272},[27,396,276],{"class":63},[27,398,399,401,403,405,408,410],{"class":51,"line":95},[27,400,281],{"class":244},[27,402,284],{"class":63},[27,404,365],{"class":55},[27,406,407],{"class":63},".",[27,409,287],{"class":55},[27,411,121],{"class":63},[27,413,414],{"class":51,"line":100},[27,415,294],{"class":63},[12,417,418,419,421],{},"那麼這樣做有什麼好處呢？你可以避免命名衝突，當你 ",[47,420,157],{}," 一大推檔案時，很容易會有變數名稱重複的問題，就像...",[40,423,425],{"className":232,"code":424,"language":234,"meta":45,"style":45},"\u002F\u002F variables.scss\n$primary-color: #3498db;\n\n\u002F\u002F another-variables.scss\n$primary-color: #e74c3c;\n",[47,426,427,433,441,445,450],{"__ignoreMap":45},[27,428,429],{"class":51,"line":52},[27,430,432],{"class":431},"sQrFR","\u002F\u002F variables.scss\n",[27,434,435,437,439],{"class":51,"line":67},[27,436,241],{"class":55},[27,438,245],{"class":244},[27,440,121],{"class":63},[27,442,443],{"class":51,"line":74},[27,444,71],{"emptyLinePlaceholder":70},[27,446,447],{"class":51,"line":95},[27,448,449],{"class":431},"\u002F\u002F another-variables.scss\n",[27,451,452,454,457],{"class":51,"line":100},[27,453,241],{"class":55},[27,455,456],{"class":244},"#e74c3c",[27,458,121],{"class":63},[12,460,461,462,464],{},"如果是使用 ",[47,463,157],{},"，那麼這兩個變數就會衝突：",[40,466,468],{"className":232,"code":467,"language":234,"meta":45,"style":45},"@import 'variables';\n@import 'another-variables';\n\nbody {\n  background-color: $primary-color; \u002F\u002F 這邊就會發生衝突\n}\n",[47,469,470,479,488,492,498,512],{"__ignoreMap":45},[27,471,472,474,477],{"class":51,"line":52},[27,473,157],{"class":263},[27,475,476],{"class":59}," 'variables'",[27,478,121],{"class":63},[27,480,481,483,486],{"class":51,"line":67},[27,482,157],{"class":263},[27,484,485],{"class":59}," 'another-variables'",[27,487,121],{"class":63},[27,489,490],{"class":51,"line":74},[27,491,71],{"emptyLinePlaceholder":70},[27,493,494,496],{"class":51,"line":95},[27,495,273],{"class":272},[27,497,276],{"class":63},[27,499,500,502,504,506,509],{"class":51,"line":100},[27,501,281],{"class":244},[27,503,284],{"class":63},[27,505,287],{"class":55},[27,507,508],{"class":63},"; ",[27,510,511],{"class":431},"\u002F\u002F 這邊就會發生衝突\n",[27,513,514],{"class":51,"line":106},[27,515,294],{"class":63},[12,517,518,519,521,522,524],{},"所以到底是 ",[47,520,245],{}," 還是 ",[47,523,456],{},"？",[526,527,528,532],"details",{},[529,530,531],"summary",{},"點我看解答(請認真思考後再看解答)","\n答案是：#e74c3c，因為後面的會覆蓋前面的。\n",[12,534,535,536,538],{},"因此，使用 ",[47,537,161],{}," 可以避免這種命名衝突的問題：",[40,540,542],{"className":232,"code":541,"language":234,"meta":45,"style":45},"@use 'variables';\n@use 'another-variables';\n\nbody {\n  background-color: another-variables.$primary-color; \u002F\u002F 明確指定使用哪個命名空間的變數\n}\n",[47,543,544,552,560,564,570,588],{"__ignoreMap":45},[27,545,546,548,550],{"class":51,"line":52},[27,547,161],{"class":263},[27,549,476],{"class":59},[27,551,121],{"class":63},[27,553,554,556,558],{"class":51,"line":67},[27,555,161],{"class":263},[27,557,485],{"class":59},[27,559,121],{"class":63},[27,561,562],{"class":51,"line":74},[27,563,71],{"emptyLinePlaceholder":70},[27,565,566,568],{"class":51,"line":95},[27,567,273],{"class":272},[27,569,276],{"class":63},[27,571,572,574,576,579,581,583,585],{"class":51,"line":100},[27,573,281],{"class":244},[27,575,284],{"class":63},[27,577,578],{"class":55},"another-variables",[27,580,407],{"class":63},[27,582,287],{"class":55},[27,584,508],{"class":63},[27,586,587],{"class":431},"\u002F\u002F 明確指定使用哪個命名空間的變數\n",[27,589,590],{"class":51,"line":106},[27,591,294],{"class":63},[12,593,594],{},"這是一個非常重大的更新與調整，對於較大型專案來講，我認為是非常值得更新的。",[12,596,597,598,601,602,604,605,608,609,611,612,614,615,617,618,169],{},"但這邊要注意一件事情，通常我們會將各種變數放在 ",[47,599,600],{},"_variables.scss","，但使用 ",[47,603,161],{}," 後，你原本再另一個 ",[47,606,607],{},"_card.scss"," 想要使用 ",[47,610,287],{}," 變數的話，你必須在 ",[