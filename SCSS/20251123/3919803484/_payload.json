3},[27,715,287],{"class":55},[27,717,121],{"class":63},[27,719,720],{"class":51,"line":106},[27,721,294],{"class":63},[12,723,724,725,727,728,730,731,733],{},"不然你會得到一個 ",[47,726,351],{}," 的錯誤訊息，畢竟我們早期使用 ",[47,729,157],{}," 時，是可以直接共用變數的，",[47,732,157],{}," 類似建立一個全域的變數空間，所以就很容易發生命名衝突的問題。",[12,735,736,737,739],{},"所以當你使用 ",[47,738,161],{}," 時，每個檔案的引入都是獨立運作的。",[12,741,742,743,745,746,748,749,752,753,748,756,759,760,763],{},"當然這種 ",[47,744,161],{}," 的方式也很麻煩，因為你可能就不希望它叫做 ",[47,747,365],{}," or ",[47,750,751],{},"card","，你可能希望它叫做 ",[47,754,755],{},"v",[47,757,758],{},"c","，這時候你可以使用 ",[47,761,762],{},"as"," 來重新命名命名空間：",[40,765,767],{"className":232,"code":766,"language":234,"meta":45,"style":45},"@use 'abstracts\u002Fvariables' as v;\n\n.card {\n  background-color: v.$primary-color;\n}\n",[47,768,769,783,787,793,807],{"__ignoreMap":45},[27,770,771,773,775,778,781],{"class":51,"line":52},[27,772,161],{"class":263},[27,774,118],{"class":59},[27,776,777],{"class":263}," as",[27,779,780],{"class":55}," v",[27,782,121],{"class":63},[27,784,785],{"class":51,"line":67},[27,786,71],{"emptyLinePlaceholder":70},[27,788,789,791],{"class":51,"line":74},[27,790,655],{"class":244},[27,792,276],{"class":63},[27,794,795,797,799,801,803,805],{"class":51,"line":95},[27,796,281],{"class":244},[27,798,284],{"class":63},[27,800,755],{"class":55},[27,802,407],{"class":63},[27,804,287],{"class":55},[27,806,121],{"class":63},[27,808,809],{"class":51,"line":100},[27,810,294],{"class":63},[299,812,814],{"id":813},"使用-forward-的改變","使用 @forward 的改變",[12,816,817,818,821],{},"通常我們在實戰開發上，很長建立一個 ",[47,819,820],{},"index.scss"," 來統一匯出所有的變數、混入、函式等，原本我們會是這樣寫：",[40,823,825],{"className":232,"code":824,"language":234,"meta":45,"style":45},"\u002F\u002F abstracts\u002F_index.scss\n@import 'variables';\n@import 'mixins';\n",[47,826,827,832,840],{"__ignoreMap":45},[27,828,829],{"class":51,"line":52},[27,830,831],{"class":431},"\u002F\u002F abstracts\u002F_index.scss\n",[27,833,834,836,838],{"class":51,"line":67},[27,835,157],{"class":263},[27,837,476],{"class":59},[27,839,121],{"class":63},[27,841,842,844,847],{"class":51,"line":74},[27,843,157],{"class":263},[27,845,846],{"class":59}," 'mixins'",[27,848,121],{"class":63},[12,850,851,852,855],{},"這樣我們可以一次性匯入所以可以使用的東西，這樣我們就可以在 ",[47,853,854],{},"style.scss"," 中這樣使用：",[40,857,859],{"className":232,"code":858,"language":234,"meta":45,"style":45},"@import 'abstracts\u002Findex';\nbody {\n  background-color: $primary-color;\n  @include center-block;\n}\n",[47,860,861,870,876,886,897],{"__ignoreMap":45},[27,862,863,865,868],{"class":51,"line":52},[27,864,157],{"class":263},[27,866,867],{"class":59}," 'abstracts\u002Findex'",[27,869,121],{"class":63},[27,871,872,874],{"class":51,"line":67},[27,873,273],{"class":272},[27,875,276],{"class":63},[27,877,878,880,882,884],{"class":51,"line":74},[27,879,281],{"class":244},[27,881,284],{"class":63},[27,883,287],{"class":55},[27,885,121],{"class":63},[27,887,888,891,895],{"class":51,"line":95},[27,889,890],{"class":263},"  @include",[27,892,894],{"class":893},"sj_SG"," center-block",[27,896,121],{"class":63},[27,898,899],{"class":51,"line":100},[27,900,294],{"class":63},[12,902,903],{},"所以你可能第一直覺就是這樣改：",[40,905,907],{"className":232,"code":906,"language":234,"meta":45,"style":45},"\u002F\u002F abstracts\u002F_index.scss\n@use 'variables';\n",[47,908,909,913],{"__ignoreMap":45},[27,910,911],{"class":51,"line":52},[27,912,831],{"class":431},[27,914,915,917,919],{"class":51,"line":67},[27,916,161],{"class":263},[27,918,476],{"class":59},[27,920,121],{"class":63},[12,922,923,924,926,927,929,930,932,933,169],{},"但其實不太對，這樣做是會導致 ",[47,925,351],{}," 的錯誤訊息，畢竟前面有講過 ",[47,928,161],{}," 會在這個檔案中建立一個命名空間，所以你無法在 ",[47,931,854],{}," 中直接使用 ",[47,934,369],{},[12,936,937,938,940],{},"那該怎麼做呢？這邊要改用的方式就是 ",[47,939,165],{},"，所以正確的寫法是這樣：",[40,942,944],{"className":232,"code":943,"language":234,"meta":45,"style":45},"\u002F\u002F abstracts\u002F_index.scss\n@forward 'variables';\n",[47,945,946,950],{"__ignoreMap":45},[27,947,948],{"class":51,"line":52},[27,949,831],{"class":431},[27,951,952,954,956],{"class":51,"line":67},[27,953,165],{"class":263},[27,955,476],{"class":59},[27,957,121],{"class":63},[12,959,960,962],{},[47,961,165],{}," 概念類似把這些變數、混入、函式等「轉發」出去，讓其他檔案可以直接使用。",[12,964,965,966,968],{},"因此我們回到 ",[47,967,854],{},"，我們就可以這樣寫：",[40,970,972],{"className":232,"code":971,"language":234,"meta":45,"style":45},"@use 'abstracts\u002Findex' as abs;\nbody {\n  background-color: abs.$primary-color;\n}\n",[47,973,974,987,993,1008],{"__ignoreMap":45},[27,975,976,978,980,982,985],{"class":51,"line":52},[27,977,161],{"class":263},[27,979,867],{"class":59},[27,981,777],{"class":263},[27,983,984],{"class":55}," abs",[27,986,121],{"class":63},[27,988,989,991],{"class":51,"line":67},[27,990,273],{"class":272},[27,992,276],{"class":63},[27,994,995,997,999,1002,1004,1006],{"class":51,"line":74},[27,996,281],{"class":244},[27,998,284],{"class":63},[27,1000,1001],{"class":55},"abs",[27,1003,407],{"class":63},[27,1005,287],{"class":55},[27,1007,121],{"class":63},[27,1009,1010],{"class":51,"line":95},[27,1011,294],{"class":63},[12,1013,1014,1015,1017],{},"這樣就可以正確使用 ",[47,1016,165],{}," 轉發出去的變數與混入了。",[20,1019,1020],{"id":1020},"結論",[12,1022,1023],{},"太久沒有寫 SCSS，真是沒想到已經有這樣的變化惹 QQ",[1025,1026,1027],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.