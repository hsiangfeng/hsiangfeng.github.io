[{"data":1,"prerenderedAt":314},["ShallowReactive",2],{"header-locale:\u002FSCSS\u002F20190417\u002F2961076508\u002F":3,"page:\u002FSCSS\u002F20190417\u002F2961076508\u002F":4,"alt:\u002FSCSS\u002F20190417\u002F2961076508\u002F":3,"prev-next:\u002FSCSS\u002F20190417\u002F2961076508\u002F":291,"related:\u002FSCSS\u002F20190417\u002F2961076508\u002F":300},"\u002Fen\u002Fscss\u002F2019\u002F04\u002F17\u002Fscss-handbook-2-variables\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":275,"date":276,"description":18,"extension":277,"lang":278,"meta":279,"navigation":280,"path":281,"readingMinutes":282,"seo":283,"standalone":284,"stem":285,"tags":286,"tldr":288,"updated":288,"url":289,"__hash__":290},"content\u002FSCSS 學習手冊\u002FSCSS學習-變數($)(二).md","SCSS學習-變數($)(二)","2961076508",{"type":9,"value":10,"toc":267},"minimark",[11,15,19,23,38,41,48,51,56,65,68,71,74,79,90,95,98,104,107,112,115,121,137,142,145,150,153,159,162,165,170,176,183,186,189],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"從這篇開始就不會講到 SASS，讓我們來專心地了解一下如何基礎學會 SCSS。",[12,20,22],{"id":21},"變數是什麼可以吃嗎","變數是什麼?可以吃嗎?",[16,24,25,26,30,31,34,37],{},"撰寫 SCSS 的時候，最方便的東西就是變數，首先 SCSS 設置變數的方式是使用了 【$】 字號，撰寫方式是這樣子\n",[27,28,29],"code",{},"$變數名稱: 色碼、數字及字串等","。\n舉例來講→",[27,32,33],{},"$black: #ec0f0f",[27,35,36],{},"#ec0f0f","是紅色",[16,39,40],{},"讓我們照慣例速寫一個 box 出來瞭解。",[16,42,43],{},[44,45],"img",{"alt":46,"src":47},"圖片","https:\u002F\u002Fi.imgur.com\u002Fxc6Engl.png",[16,49,50],{},"圖片中可以看到我將一個色碼儲存至變數 ($red) 中，透過變數名稱直接呼叫於 background-color 並使用於此。",[16,52,53],{},[44,54],{"alt":46,"src":55},"https:\u002F\u002Fi.imgur.com\u002FTSP5cXS.png",[16,57,58],{},[59,60,64],"a",{"href":61,"rel":62},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FqggPNr",[63],"nofollow","Codepen",[12,66,67],{"id":67},"好處是什麼",[16,69,70],{},"相信有些人一定會問，這樣子有什麼好處?\n因為以往我們在寫 CSS 的時候都是上千上百行，有些時候顏色是不停重複使用的，當我們要變更顏色的時候就會顯得特別麻煩 而且一方面也可以不需要用人腦來記憶色票。",[16,72,73],{},"所以就讓我們來實際實驗看看吧!\n首先新增 5 個 box。",[16,75,76],{},[44,77],{"alt":46,"src":78},"https:\u002F\u002Fi.imgur.com\u002F8NY3pRW.png",[16,80,81,82,85,86,89],{},"接下來針對 SCSS 也寫入 5 個相對應的 box。\n並將",[27,83,84],{},"background-color","也加入",[27,87,88],{},"$red","的變數名稱。",[16,91,92],{},[44,93],{"alt":46,"src":94},"https:\u002F\u002Fi.imgur.com\u002F15Vdbuz.png",[16,96,97],{},"此時我們可以看到 5 個紅色的 box。",[16,99,100],{},[59,101,64],{"href":102,"rel":103},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FzeeEKq",[63],[16,105,106],{},"以往我們若要修改這五個 .box 的顏色時，我們必須一個一個去做修改，但使用 SCSS 變數之後，僅需針對上方$red 的變數修改成所需要的色碼即可。",[16,108,109],{},[44,110],{"alt":46,"src":111},"https:\u002F\u002Fi.imgur.com\u002FMzG5JCU.png",[16,113,114],{},"修改結果就可以看到，只要有使用 $red 變數的 class，就會通通變成你所指定的顏色囉!",[16,116,117],{},[59,118,64],{"href":119,"rel":120},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FpGGWEM",[63],[16,122,123,124,127,128,127,131,127,134],{},"我們也可以故意將所有 box 中的數值通通以變數載入來加快我們生產 box 的速度。\n這邊另外新增一些變數，分別為",[27,125,126],{},"$box-width","、",[27,129,130],{},"$box-height",[27,132,133],{},"$mb-1: 5px",[27,135,136],{},"$mb-2: 10px;",[16,138,139],{},[44,140],{"alt":46,"src":141},"https:\u002F\u002Fi.imgur.com\u002F2B55ffH.png",[16,143,144],{},"然後個別載入 CSS 屬性中。",[16,146,147],{},[44,148],{"alt":46,"src":149},"https:\u002F\u002Fi.imgur.com\u002Fusfhqfn.png",[16,151,152],{},"結果如何呢?讓我們來看看。",[16,154,155],{},[59,156,64],{"href":157,"rel":158},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FJxxrEW",[63],[16,160,161],{},"相信各位應該已經感受到 SCSS 變數的威力，以往我們開發網站都會針對網頁字型做調整，所以我自己就會將字型加入至變數中使用。",[16,163,164],{},"還沒使用更換字型之前。",[16,166,167],{},[44,168],{"alt":46,"src":169},"https:\u002F\u002Fi.imgur.com\u002FlvqBdLB.png",[16,171,172,173],{},"使用SCSS變數，來加載字型，這邊我使用的將系統預設字型載入。\n",[44,174],{"alt":46,"src":175},"https:\u002F\u002Fi.imgur.com\u002FYVBU4w3.png",[16,177,178,179],{},"圖片中可能看不出差異，所以可以自己嘗試看看唷!\n",[59,180,64],{"href":181,"rel":182},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FgqqGWd",[63],[12,184,185],{"id":185},"系統預設字型",[16,187,188],{},"這邊也提供系統預設的字型表給各位，其中建議不要打【微軟正黑體】有可能會出現無法預期之錯誤。",[190,191,192,212],"table",{},[193,194,195],"thead",{},[196,197,198,203,206,209],"tr",{},[199,200,202],"th",{"align":201},"center","系統",[199,204,205],{"align":201},"系統預設",[199,207,208],{"align":201},"英文字體",[199,210,211],{"align":201},"中文字體",[213,214,215,229,243,254],"tbody",{},[196,216,217,221,224,226],{},[218,219,220],"td",{"align":201},"Windwos",[218,222,223],{"align":201},"-",[218,225],{"align":201},[218,227,228],{"align":201},"Microsoft JhengHei\u002F 微軟正黑體",[196,230,231,234,237,240],{},[218,232,233],{"align":201},"Mac OS",[218,235,236],{"align":201},"-apple-system",[218,238,239],{"align":201},"San Francisco",[218,241,242],{"align":201},"蘋方體",[196,244,245,248,250,252],{},[218,246,247],{"align":201},"iOS",[218,249,236],{"align":201},[218,251,239],{"align":201},[218,253,242],{"align":201},[196,255,256,259,261,264],{},[218,257,258],{"align":201},"Android",[218,260,223],{"align":201},[218,262,263],{"align":201},"Roboto",[218,265,266],{"align":201},"Droidsansfallback",{"title":268,"searchDepth":269,"depth":269,"links":270},"",2,[271,272,273,274],{"id":14,"depth":269,"text":14},{"id":21,"depth":269,"text":22},{"id":67,"depth":269,"text":67},{"id":185,"depth":269,"text":185},"SCSS","2019-04-17 12:45:50","md","zh-Hant",{},true,"\u002Fscss\u002Fscss-(dollar)()","2",{"title":6,"description":18},false,"SCSS 學習手冊\u002FSCSS學習-變數($)(二)",[275,287],"SCSS 學習手冊",null,"\u002FSCSS\u002F20190417\u002F2961076508\u002F","ZbvOgIWLjLkI_2e-m-AmbwIRLSfaD3hJ90EYZa4R6iQ",{"newer":292,"older":296},{"url":293,"title":294,"date":295},"\u002Fjavascript\u002F20190418\u002F3212024334\u002F","JavaScript陣列物件屬性合併","2019-04-18 16:00:00",{"url":297,"title":298,"date":299},"\u002Flearnexp\u002F20190416\u002F3782185665\u002F","該如何正確的學習前端技術或程式語言","2019-04-16 22:36:38",[301,306,310],{"url":302,"title":303,"date":304,"readingMinutes":305},"\u002FSCSS\u002F20251123\u002F3919803484\u002F","SCSS 棄用 @import？！","2025-11-23 15:32:01","3",{"url":307,"title":308,"date":309,"readingMinutes":282},"\u002FSCSS\u002F20190421\u002F968240674\u002F","SCSS學習-mixin(五)","2019-04-21 07:24:30",{"url":311,"title":312,"date":313,"readingMinutes":282},"\u002FSCSS\u002F20190419\u002F947541843\u002F","SCSS學習-import(四)","2019-04-19 17:24:30",1784011683724]