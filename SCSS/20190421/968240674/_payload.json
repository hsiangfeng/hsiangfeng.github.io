[{"data":1,"prerenderedAt":169},["ShallowReactive",2],{"header-locale:\u002FSCSS\u002F20190421\u002F968240674\u002F":3,"page:\u002FSCSS\u002F20190421\u002F968240674\u002F":4,"alt:\u002FSCSS\u002F20190421\u002F968240674\u002F":3,"prev-next:\u002FSCSS\u002F20190421\u002F968240674\u002F":145,"related:\u002FSCSS\u002F20190421\u002F968240674\u002F":154},"\u002Fen\u002Fscss\u002F2019\u002F04\u002F21\u002Fscss-handbook-5-mixin\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":128,"date":129,"description":130,"extension":131,"lang":132,"meta":133,"navigation":134,"path":135,"readingMinutes":136,"seo":137,"standalone":138,"stem":139,"tags":140,"tldr":142,"updated":142,"url":143,"__hash__":144},"content\u002FSCSS 學習手冊\u002FSCSS學習-mixin(五).md","SCSS學習-mixin(五)","968240674",{"type":9,"value":10,"toc":122},"minimark",[11,15,24,28,31,38,41,44,47,52,55,60,63,68,71,74,79,82,87,90,95,98,103,106,111,114,117],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,23],"p",{},"前一篇主要講解 ",[20,21,22],"code",{},"@import"," 使用方式，這篇會慢慢結合前面所寫的教學來統整製作，接下來將會講解 mixin，mixin 又是什麼呢?\n我會把它當作一個 SCSS 資料庫，因為這裡面會放很多自己常用的 SCSS",[12,25,27],{"id":26},"mixin","Mixin",[16,29,30],{},"為什麼會講自己常用的 SCSS 呢?如果現在突然要你寫隱藏文字的 CSS 會記得怎麼寫嗎?",[16,32,33],{},[34,35],"img",{"alt":36,"src":37},"圖片","https:\u002F\u002Fi.imgur.com\u002FnbCv2i5.png",[16,39,40],{},"或許會記得，但人的腦袋記憶是有限的，尤其是這種不常用的東西，每一次都必須去靠人腦去記憶是非常不好，這樣是在降低人腦使用效率，mixin 就發揮了一個很強大的功能，就是包裝 CSS。",[16,42,43],{},"試著去想像 mixin 就是將你常用的東西包裝起來用變成一個 class，就跟平常在撰寫 CSS class 一樣，所以就試著去撰寫 mixin 的隱藏文字吧。",[16,45,46],{},"首先先新增一個檔案 _mixin.scss 吧",[16,48,49],{},[34,50],{"alt":36,"src":51},"https:\u002F\u002Fi.imgur.com\u002F9425213.png",[16,53,54],{},"使用 mixin 的方式非常簡單僅需要這樣寫即可",[16,56,57],{},[34,58],{"alt":36,"src":59},"https:\u002F\u002Fi.imgur.com\u002FPaKZUr5.png",[16,61,62],{},"接下來將隱藏文字的 CSS 寫進去",[16,64,65],{},[34,66],{"alt":36,"src":67},"https:\u002F\u002Fi.imgur.com\u002FcJD4U7f.png",[16,69,70],{},"名稱一定要盡可能的語意化，不要取一些很奇怪的名子讓自己記不得，這樣反而降低效率。",[16,72,73],{},"那該如何將自己撰寫的 mixin 引入至自己撰寫的 SCSS 中?這邊就必須使用到前篇所教的 @import，在 layout 中 import 就可以使用剛剛寫的 mixin 了",[16,75,76],{},[34,77],{"alt":36,"src":78},"https:\u002F\u002Fi.imgur.com\u002F8gTpXnk.png",[16,80,81],{},"在這邊要注意一點重點，引入 mixin 的方式是寫 @include + 名稱，所以如果要引入剛剛撰寫的 text-hide 就要這樣子寫",[16,83,84],{},[34,85],{"alt":36,"src":86},"https:\u002F\u002Fi.imgur.com\u002FGG8aD2H.png",[16,88,89],{},"接下來編譯之後就可以看到寫在 mixin 中的隱藏文字 CSS 就會被編譯進去到 .logo 中了",[16,91,92],{},[34,93],{"alt":36,"src":94},"https:\u002F\u002Fi.imgur.com\u002FXv0yJk6.png",[16,96,97],{},"當然也可以寫一些比較簡寫的 mixin 幫助自己快速撰寫\n舉例有些時候其實我們很常用使用 background-size: cover;\n那就可以透過 mixin 來包裝減化我們編寫",[16,99,100],{},[34,101],{"alt":36,"src":102},"https:\u002F\u002Fi.imgur.com\u002FmmA1lMP.png",[16,104,105],{},"或者是圖片響應式 CSS",[16,107,108],{},[34,109],{"alt":36,"src":110},"https:\u002F\u002Fi.imgur.com\u002FxccFKIM.png",[16,112,113],{},"這些都是幫助我們盡可能簡化腦袋所需要記憶的東西，進而提升開發效率。",[16,115,116],{},"@mixin 其實也可以加入變數，撰寫方式如下",[16,118,119],{},[34,120],{"alt":36,"src":121},"https:\u002F\u002Fi.imgur.com\u002FrUwC2sY.png",{"title":123,"searchDepth":124,"depth":124,"links":125},"",2,[126,127],{"id":14,"depth":124,"text":14},{"id":26,"depth":124,"text":27},"SCSS","2019-04-21 07:24:30","前一篇主要講解 @import 使用方式，這篇會慢慢結合前面所寫的教學來統整製作，接下來將會講解 mixin，mixin 又是什麼呢?我會把它當作一個 SCSS 資料庫，因為這裡面會放很多自己常用的 SCSS","md","zh-Hant",{},true,"\u002Fscss\u002Fscss-mixin()","2",{"title":6,"description":130},false,"SCSS 學習手冊\u002FSCSS學習-mixin(五)",[128,141],"SCSS 學習手冊",null,"\u002FSCSS\u002F20190421\u002F968240674\u002F","7eCknNjf2diMRgv211jxUbC4_C3Gyg1K7vBBqh9ULgo",{"newer":146,"older":150},{"url":147,"title":148,"date":149},"\u002Fjavascript\u002F20190421\u002F1216566123\u002F","關於 JavaScript 陣列 20 種操作的方法","2019-04-21 11:56:53",{"url":151,"title":152,"date":153},"\u002Fjavascript\u002F20190419\u002F3635730318\u002F","Javascript中的hoisting","2019-04-19 20:33:08",[155,160,164],{"url":156,"title":157,"date":158,"readingMinutes":159},"\u002FSCSS\u002F20251123\u002F3919803484\u002F","SCSS 棄用 @import？！","2025-11-23 15:32:01","3",{"url":161,"title":162,"date":163,"readingMinutes":136},"\u002FSCSS\u002F20190419\u002F947541843\u002F","SCSS學習-import(四)","2019-04-19 17:24:30",{"url":165,"title":166,"date":167,"readingMinutes":168},"\u002FSCSS\u002F20190418\u002F2434021097\u002F","SCSS學習-運算子(三)","2019-04-18 17:24:30","1",1784013040837]