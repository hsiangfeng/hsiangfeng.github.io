[{"data":1,"prerenderedAt":1089},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":3,"page:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":4,"alt:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":3,"prev-next:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":1065,"related:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":1074},"\u002FSCSS\u002F20251123\u002F3919803484\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":8,"body":9,"category":1049,"date":1050,"description":1051,"extension":1052,"lang":1053,"meta":1054,"navigation":82,"path":1055,"readingMinutes":121,"seo":1056,"standalone":1057,"stem":1058,"tags":1059,"tldr":1062,"updated":1050,"url":1063,"__hash__":1064},"content\u002Fen\u002FSCSS\u002Fsass-deprecated-import-use-forward-migration.md","SCSS Is Deprecating @import?!","9314038819","\u002Fscss\u002F20251123\u002F3919803484\u002F",{"type":10,"value":11,"toc":1040},"minimark",[12,20,25,28,39,42,46,51,164,179,182,185,188,192,203,206,233,240,258,265,306,309,314,320,357,364,387,390,431,437,474,480,531,539,547,553,606,609,634,690,736,747,752,775,822,826,833,860,866,911,914,931,946,952,969,974,980,1023,1029,1033,1036],[13,14,15],"p",{},[16,17],"img",{"alt":18,"src":19},"Sass @import deprecation warning","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fscss\u002Fdeprecation-import\u002FChatGPT%20Image%202025%E5%B9%B411%E6%9C%8823%E6%97%A5%20%E4%B8%8B%E5%8D%8804_25_06.png",[21,22,24],"h2",{"id":23},"intro","Intro",[13,26,27],{},"I've been maintaining some legacy projects lately and decided to upgrade them along the way, but ran into this error:",[29,30,31],"blockquote",{},[13,32,33,34,38],{},"Deprecation Warning ",[35,36,37],"span",{},"import",": Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.",[13,40,41],{},"So this post is a quick note on what changed and how to migrate.",[21,43,45],{"id":44},"the-import-deprecation-warning","The @import deprecation warning",[13,47,48],{},[16,49],{"alt":18,"src":50},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fscss\u002Fdeprecation-import\u002F20251123153624.png",[52,53,58],"pre",{"className":54,"code":55,"language":56,"meta":57,"style":57},"language-bash shiki shiki-themes github-dark-high-contrast","Deprecation Warning [import]: Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.\n\nMore info and automated migrator: https:\u002F\u002Fsass-lang.com\u002Fd\u002Fimport\n\n  ╷\n4 │ @import 'abstracts\u002Fvariables';\n  │         ^^^^^^^^^^^^^^^^^^^^^\n  ╵\n    src\u002Fcss\u002Fstyle.scss 4:9  root stylesheet\n","bash","",[59,60,61,77,84,105,110,116,134,143,149],"code",{"__ignoreMap":57},[35,62,65,69,73],{"class":63,"line":64},"line",1,[35,66,68],{"class":67},"s_sBn","Deprecation",[35,70,72],{"class":71},"sTRMh"," Warning",[35,74,76],{"class":75},"sMAXC"," [import]: Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.\n",[35,78,80],{"class":63,"line":79},2,[35,81,83],{"emptyLinePlaceholder":82},true,"\n",[35,85,87,90,93,96,99,102],{"class":63,"line":86},3,[35,88,89],{"class":67},"More",[35,91,92],{"class":71}," info",[35,94,95],{"class":71}," and",[35,97,98],{"class":71}," automated",[35,100,101],{"class":71}," migrator:",[35,103,104],{"class":71}," https:\u002F\u002Fsass-lang.com\u002Fd\u002Fimport\n",[35,106,108],{"class":63,"line":107},4,[35,109,83],{"emptyLinePlaceholder":82},[35,111,113],{"class":63,"line":112},5,[35,114,115],{"class":67},"  ╷\n",[35,117,119,122,125,128,131],{"class":63,"line":118},6,[35,120,121],{"class":67},"4",[35,123,124],{"class":71}," │",[35,126,127],{"class":71}," @import",[35,129,130],{"class":71}," 'abstracts\u002Fvariables'",[35,132,133],{"class":75},";\n",[35,135,137,140],{"class":63,"line":136},7,[35,138,139],{"class":67},"  │",[35,141,142],{"class":71},"         ^^^^^^^^^^^^^^^^^^^^^\n",[35,144,146],{"class":63,"line":145},8,[35,147,148],{"class":67},"  ╵\n",[35,150,152,155,158,161],{"class":63,"line":151},9,[35,153,154],{"class":67},"    src\u002Fcss\u002Fstyle.scss",[35,156,157],{"class":71}," 4:9",[35,159,160],{"class":71},"  root",[35,162,163],{"class":71}," stylesheet\n",[13,165,166,167,170,171,174,175,178],{},"In short: Sass has officially announced that ",[59,168,169],{},"@import"," will be removed in Dart Sass 3.0.0, and they recommend using ",[59,172,173],{},"@use"," or ",[59,176,177],{},"@forward"," instead.",[13,180,181],{},"Let's walk through what's changing.",[13,183,184],{},"If you're using the VSCode Watch Sass extension, you probably won't see this error — the extension is on an older version. But in real-world dev, you'll be using Vite, Webpack, or some other tool to compile SCSS, so you'll hit it eventually.",[13,186,187],{},"If you don't want to use Vite or Webpack to compile SCSS, you could also consider Parcel instead.",[21,189,191],{"id":190},"what-changed-with-use-and-forward","What changed with @use and @forward?",[13,193,194,195,197,198,174,200,202],{},"Basically, the new recommendation is to stop using ",[59,196,169],{}," and switch to ",[59,199,173],{},[59,201,177],{},".",[13,204,205],{},"Say you have a structure like this:",[52,207,211],{"className":208,"code":209,"language":210,"meta":57,"style":57},"language-txt shiki shiki-themes github-dark-high-contrast","styles\u002F\n  abstracts\u002F\n    _variables.scss\n  style.scss\n","txt",[59,212,213,218,223,228],{"__ignoreMap":57},[35,214,215],{"class":63,"line":64},[35,216,217],{},"styles\u002F\n",[35,219,220],{"class":63,"line":79},[35,221,222],{},"  abstracts\u002F\n",[35,224,225],{"class":63,"line":86},[35,226,227],{},"    _variables.scss\n",[35,229,230],{"class":63,"line":107},[35,231,232],{},"  style.scss\n",[13,234,235,236,239],{},"And ",[59,237,238],{},"style\u002Fabstracts\u002F_variables.scss"," looks like:",[52,241,245],{"className":242,"code":243,"language":244,"meta":57,"style":57},"language-scss shiki shiki-themes github-dark-high-contrast","$primary-color: #3498db;\n","scss",[59,246,247],{"__ignoreMap":57},[35,248,249,252,256],{"class":63,"line":64},[35,250,251],{"class":67},"$primary-color: ",[35,253,255],{"class":254},"sCcAr","#3498db",[35,257,133],{"class":75},[13,259,260,261,264],{},"Then ",[59,262,263],{},"style\u002Fstyle.scss",":",[52,266,268],{"className":242,"code":267,"language":244,"meta":57,"style":57},"@import 'abstracts\u002Fvariables';\nbody {\n  background-color: $primary-color;\n}\n",[59,269,270,279,288,301],{"__ignoreMap":57},[35,271,272,275,277],{"class":63,"line":64},[35,273,169],{"class":274},"sWyjQ",[35,276,130],{"class":71},[35,278,133],{"class":75},[35,280,281,285],{"class":63,"line":79},[35,282,284],{"class":283},"sKpQp","body",[35,286,287],{"class":75}," {\n",[35,289,290,293,296,299],{"class":63,"line":86},[35,291,292],{"class":254},"  background-color",[35,294,295],{"class":75},": ",[35,297,298],{"class":67},"$primary-color",[35,300,133],{"class":75},[35,302,303],{"class":63,"line":107},[35,304,305],{"class":75},"}\n",[13,307,308],{},"This is what most of us are used to.",[310,311,313],"h3",{"id":312},"what-changes-with-use","What changes with @use",[13,315,316,317,319],{},"In the new version you have to use ",[59,318,173],{},". Your first instinct might be to write it like this:",[52,321,323],{"className":242,"code":322,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: $primary-color;\n}\n",[59,324,325,333,337,343,353],{"__ignoreMap":57},[35,326,327,329,331],{"class":63,"line":64},[35,328,173],{"class":274},[35,330,130],{"class":71},[35,332,133],{"class":75},[35,334,335],{"class":63,"line":79},[35,336,83],{"emptyLinePlaceholder":82},[35,338,339,341],{"class":63,"line":86},[35,340,284],{"class":283},[35,342,287],{"class":75},[35,344,345,347,349,351],{"class":63,"line":107},[35,346,292],{"class":254},[35,348,295],{"class":75},[35,350,298],{"class":67},[35,352,133],{"class":75},[35,354,355],{"class":63,"line":112},[35,356,305],{"class":75},[13,358,359,360,363],{},"And you'll get a string of ",[59,361,362],{},"Undefined variable: \"$primary-color\"."," errors.",[13,365,366,367,369,370,374,375,378,379,382,383,386],{},"The reason is that ",[59,368,173],{}," wraps variables, functions, and mixins into a ",[371,372,373],"strong",{},"module namespace",". What does that mean? When you write ",[59,376,377],{},"@use 'abstracts\u002Fvariables';",", Sass treats the filename ",[59,380,381],{},"variables"," as a namespace, so you have to use ",[59,384,385],{},"variables.$primary-color"," to access the variable.",[13,388,389],{},"So the correct usage is:",[52,391,393],{"className":242,"code":392,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: variables.$primary-color;\n}\n",[59,394,395,403,407,413,427],{"__ignoreMap":57},[35,396,397,399,401],{"class":63,"line":64},[35,398,173],{"class":274},[35,400,130],{"class":71},[35,402,133],{"class":75},[35,404,405],{"class":63,"line":79},[35,406,83],{"emptyLinePlaceholder":82},[35,408,409,411],{"class":63,"line":86},[35,410,284],{"class":283},[35,412,287],{"class":75},[35,414,415,417,419,421,423,425],{"class":63,"line":107},[35,416,292],{"class":254},[35,418,295],{"class":75},[35,420,381],{"class":67},[35,422,202],{"class":75},[35,424,298],{"class":67},[35,426,133],{"class":75},[35,428,429],{"class":63,"line":112},[35,430,305],{"class":75},[13,432,433,434,436],{},"What's the benefit? You avoid name collisions. When you ",[59,435,169],{}," a bunch of files, it's pretty easy to end up with duplicate variable names, like:",[52,438,440],{"className":242,"code":439,"language":244,"meta":57,"style":57},"\u002F\u002F variables.scss\n$primary-color: #3498db;\n\n\u002F\u002F another-variables.scss\n$primary-color: #e74c3c;\n",[59,441,442,448,456,460,465],{"__ignoreMap":57},[35,443,444],{"class":63,"line":64},[35,445,447],{"class":446},"sQrFR","\u002F\u002F variables.scss\n",[35,449,450,452,454],{"class":63,"line":79},[35,451,251],{"class":67},[35,453,255],{"class":254},[35,455,133],{"class":75},[35,457,458],{"class":63,"line":86},[35,459,83],{"emptyLinePlaceholder":82},[35,461,462],{"class":63,"line":107},[35,463,464],{"class":446},"\u002F\u002F another-variables.scss\n",[35,466,467,469,472],{"class":63,"line":112},[35,468,251],{"class":67},[35,470,471],{"class":254},"#e74c3c",[35,473,133],{"class":75},[13,475,476,477,479],{},"If you're using ",[59,478,169],{},", those two variables collide:",[52,481,483],{"className":242,"code":482,"language":244,"meta":57,"style":57},"@import 'variables';\n@import 'another-variables';\n\nbody {\n  background-color: $primary-color; \u002F\u002F collision here\n}\n",[59,484,485,494,503,507,513,527],{"__ignoreMap":57},[35,486,487,489,492],{"class":63,"line":64},[35,488,169],{"class":274},[35,490,491],{"class":71}," 'variables'",[35,493,133],{"class":75},[35,495,496,498,501],{"class":63,"line":79},[35,497,169],{"class":274},[35,499,500],{"class":71}," 'another-variables'",[35,502,133],{"class":75},[35,504,505],{"class":63,"line":86},[35,506,83],{"emptyLinePlaceholder":82},[35,508,509,511],{"class":63,"line":107},[35,510,284],{"class":283},[35,512,287],{"class":75},[35,514,515,517,519,521,524],{"class":63,"line":112},[35,516,292],{"class":254},[35,518,295],{"class":75},[35,520,298],{"class":67},[35,522,523],{"class":75},"; ",[35,525,526],{"class":446},"\u002F\u002F collision here\n",[35,528,529],{"class":63,"line":118},[35,530,305],{"class":75},[13,532,533,534,174,536,538],{},"So which one wins — ",[59,535,255],{},[59,537,471],{},"?",[540,541,542,546],"details",{},[543,544,545],"summary",{},"Click for the answer (think first!)","\nThe answer is #e74c3c — the later one overrides the earlier one.\n",[13,548,549,550,552],{},"With ",[59,551,173],{},", you can avoid this kind of collision:",[52,554,556],{"className":242,"code":555,"language":244,"meta":57,"style":57},"@use 'variables';\n@use 'another-variables';\n\nbody {\n  background-color: another-variables.$primary-color; \u002F\u002F explicitly pick which namespace\n}\n",[59,557,558,566,574,578,584,602],{"__ignoreMap":57},[35,559,560,562,564],{"class":63,"line":64},[35,561,173],{"class":274},[35,563,491],{"class":71},[35,565,133],{"class":75},[35,567,568,570,572],{"class":63,"line":79},[35,569,173],{"class":274},[35,571,500],{"class":71},[35,573,133],{"class":75},[35,575,576],{"class":63,"line":86},[35,577,83],{"emptyLinePlaceholder":82},[35,579,580,582],{"class":63,"line":107},[35,581,284],{"class":283},[35,583,287],{"class":75},[35,585,586,588,590,593,595,597,599],{"class":63,"line":112},[35,587,292],{"class":254},[35,589,295],{"class":75},[35,591,592],{"class":67},"another-variables",[35,594,202],{"class":75},[35,596,298],{"class":67},[35,598,523],{"class":75},[35,600,601],{"class":446},"\u002F\u002F explicitly pick which namespace\n",[35,603,604],{"class":63,"line":118},[35,605,305],{"class":75},[13,607,608],{},"This is a pretty significant change. For larger projects, I'd say it's worth migrating.",[13,610,611,612,615,616,618,619,621,622,625,626,628,629,631,632,202],{},"But there's a catch. Usually we put all variables in ",[59,613,614],{},"_variables.scss",". With ",[59,617,173],{},", if you want to use ",[59,620,298],{}," from a different file like ",[59,623,624],{},"_card.scss",", you have to ",[59,627,377],{}," inside ",[59,630,624],{}," too so you can access ",[59,633,385],{},[52,635,637],{"className":242,"code":636,"language":244,"meta":57,"style":57},"\u002F\u002F styles.css\n@use 'abstracts\u002Fvariables';\n@use 'components\u002Fcard';\n\n.card {\n  background-color: variables.$primary-color;\n}\n",[59,638,639,644,652,661,665,672,686],{"__ignoreMap":57},[35,640,641],{"class":63,"line":64},[35,642,643],{"class":446},"\u002F\u002F styles.css\n",[35,645,646,648,650],{"class":63,"line":79},[35,647,173],{"class":274},[35,649,130],{"class":71},[35,651,133],{"class":75},[35,653,654,656,659],{"class":63,"line":86},[35,655,173],{"class":274},[35,657,658],{"class":71}," 'components\u002Fcard'",[35,660,133],{"class":75},[35,662,663],{"class":63,"line":107},[35,664,83],{"emptyLinePlaceholder":82},[35,666,667,670],{"class":63,"line":112},[35,668,669],{"class":254},".card",[35,671,287],{"class":75},[35,673,674,676,678,680,682,684],{"class":63,"line":118},[35,675,292],{"class":254},[35,677,295],{"class":75},[35,679,381],{"class":67},[35,681,202],{"class":75},[35,683,298],{"class":67},[35,685,133],{"class":75},[35,687,688],{"class":63,"line":136},[35,689,305],{"class":75},[52,691,693],{"className":242,"code":692,"language":244,"meta":57,"style":57},"\u002F\u002F components\u002F_card.scss\n@use 'abstracts\u002Fvariables';\n\n.card {\n  background-color: variables.$primary-color;\n}\n",[59,694,695,700,708,712,718,732],{"__ignoreMap":57},[35,696,697],{"class":63,"line":64},[35,698,699],{"class":446},"\u002F\u002F components\u002F_card.scss\n",[35,701,702,704,706],{"class":63,"line":79},[35,703,173],{"class":274},[35,705,130],{"class":71},[35,707,133],{"class":75},[35,709,710],{"class":63,"line":86},[35,711,83],{"emptyLinePlaceholder":82},[35,713,714,716],{"class":63,"line":107},[35,715,669],{"class":254},[35,717,287],{"class":75},[35,719,720,722,724,726,728,730],{"class":63,"line":112},[35,721,292],{"class":254},[35,723,295],{"class":75},[35,725,381],{"class":67},[35,727,202],{"class":75},[35,729,298],{"class":67},[35,731,133],{"class":75},[35,733,734],{"class":63,"line":118},[35,735,305],{"class":75},[13,737,738,739,615,741,743,744,746],{},"Otherwise you'll hit ",[59,740,362],{},[59,742,169],{},", variables were globally shared — ",[59,745,169],{}," basically created a global variable space, which is why name collisions happened so easily.",[13,748,549,749,751],{},[59,750,173],{},", every file's imports work independently.",[13,753,754,755,757,758,174,760,763,764,174,767,770,771,774],{},"Of course, ",[59,756,173],{}," can also be annoying if you don't want the namespace named ",[59,759,381],{},[59,761,762],{},"card"," — you might prefer ",[59,765,766],{},"v",[59,768,769],{},"c",". You can use ",[59,772,773],{},"as"," to rename the namespace:",[52,776,778],{"className":242,"code":777,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Fvariables' as v;\n\n.card {\n  background-color: v.$primary-color;\n}\n",[59,779,780,794,798,804,818],{"__ignoreMap":57},[35,781,782,784,786,789,792],{"class":63,"line":64},[35,783,173],{"class":274},[35,785,130],{"class":71},[35,787,788],{"class":274}," as",[35,790,791],{"class":67}," v",[35,793,133],{"class":75},[35,795,796],{"class":63,"line":79},[35,797,83],{"emptyLinePlaceholder":82},[35,799,800,802],{"class":63,"line":86},[35,801,669],{"class":254},[35,803,287],{"class":75},[35,805,806,808,810,812,814,816],{"class":63,"line":107},[35,807,292],{"class":254},[35,809,295],{"class":75},[35,811,766],{"class":67},[35,813,202],{"class":75},[35,815,298],{"class":67},[35,817,133],{"class":75},[35,819,820],{"class":63,"line":112},[35,821,305],{"class":75},[310,823,825],{"id":824},"what-changes-with-forward","What changes with @forward",[13,827,828,829,832],{},"In real-world projects, you often create an ",[59,830,831],{},"index.scss"," to re-export all variables, mixins, and functions. The old way looked like this:",[52,834,836],{"className":242,"code":835,"language":244,"meta":57,"style":57},"\u002F\u002F abstracts\u002F_index.scss\n@import 'variables';\n@import 'mixins';\n",[59,837,838,843,851],{"__ignoreMap":57},[35,839,840],{"class":63,"line":64},[35,841,842],{"class":446},"\u002F\u002F abstracts\u002F_index.scss\n",[35,844,845,847,849],{"class":63,"line":79},[35,846,169],{"class":274},[35,848,491],{"class":71},[35,850,133],{"class":75},[35,852,853,855,858],{"class":63,"line":86},[35,854,169],{"class":274},[35,856,857],{"class":71}," 'mixins'",[35,859,133],{"class":75},[13,861,862,863,264],{},"Now you import everything in one go and use it in ",[59,864,865],{},"style.scss",[52,867,869],{"className":242,"code":868,"language":244,"meta":57,"style":57},"@import 'abstracts\u002Findex';\nbody {\n  background-color: $primary-color;\n  @include center-block;\n}\n",[59,870,871,880,886,896,907],{"__ignoreMap":57},[35,872,873,875,878],{"class":63,"line":64},[35,874,169],{"class":274},[35,876,877],{"class":71}," 'abstracts\u002Findex'",[35,879,133],{"class":75},[35,881,882,884],{"class":63,"line":79},[35,883,284],{"class":283},[35,885,287],{"class":75},[35,887,888,890,892,894],{"class":63,"line":86},[35,889,292],{"class":254},[35,891,295],{"class":75},[35,893,298],{"class":67},[35,895,133],{"class":75},[35,897,898,901,905],{"class":63,"line":107},[35,899,900],{"class":274},"  @include",[35,902,904],{"class":903},"sj_SG"," center-block",[35,906,133],{"class":75},[35,908,909],{"class":63,"line":112},[35,910,305],{"class":75},[13,912,913],{},"So your first instinct might be to change it like this:",[52,915,917],{"className":242,"code":916,"language":244,"meta":57,"style":57},"\u002F\u002F abstracts\u002F_index.scss\n@use 'variables';\n",[59,918,919,923],{"__ignoreMap":57},[35,920,921],{"class":63,"line":64},[35,922,842],{"class":446},[35,924,925,927,929],{"class":63,"line":79},[35,926,173],{"class":274},[35,928,491],{"class":71},[35,930,133],{"class":75},[13,932,933,934,936,937,939,940,942,943,945],{},"But this is wrong — you'll get ",[59,935,362],{},". As mentioned earlier, ",[59,938,173],{}," creates a namespace local to that file, so ",[59,941,865],{}," can't directly access ",[59,944,385],{}," through the index.",[13,947,948,949,951],{},"So what do you do? You use ",[59,950,177],{},". The correct syntax is:",[52,953,955],{"className":242,"code":954,"language":244,"meta":57,"style":57},"\u002F\u002F abstracts\u002F_index.scss\n@forward 'variables';\n",[59,956,957,961],{"__ignoreMap":57},[35,958,959],{"class":63,"line":64},[35,960,842],{"class":446},[35,962,963,965,967],{"class":63,"line":79},[35,964,177],{"class":274},[35,966,491],{"class":71},[35,968,133],{"class":75},[13,970,971,973],{},[59,972,177],{}," basically \"re-exports\" those variables, mixins, and functions so other files can use them directly.",[13,975,976,977,979],{},"Back in ",[59,978,865],{},", you can write:",[52,981,983],{"className":242,"code":982,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Findex' as abs;\nbody {\n  background-color: abs.$primary-color;\n}\n",[59,984,985,998,1004,1019],{"__ignoreMap":57},[35,986,987,989,991,993,996],{"class":63,"line":64},[35,988,173],{"class":274},[35,990,877],{"class":71},[35,992,788],{"class":274},[35,994,995],{"class":67}," abs",[35,997,133],{"class":75},[35,999,1000,1002],{"class":63,"line":79},[35,1001,284],{"class":283},[35,1003,287],{"class":75},[35,1005,1006,1008,1010,1013,1015,1017],{"class":63,"line":86},[35,1007,292],{"class":254},[35,1009,295],{"class":75},[35,1011,1012],{"class":67},"abs",[35,1014,202],{"class":75},[35,1016,298],{"class":67},[35,1018,133],{"class":75},[35,1020,1021],{"class":63,"line":107},[35,1022,305],{"class":75},[13,1024,1025,1026,1028],{},"And now you can correctly use variables and mixins that ",[59,1027,177],{}," re-exports.",[21,1030,1032],{"id":1031},"closing-thoughts","Closing thoughts",[13,1034,1035],{},"I haven't written much SCSS for a while — didn't expect this big a change QQ",[1037,1038,1039],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--sh