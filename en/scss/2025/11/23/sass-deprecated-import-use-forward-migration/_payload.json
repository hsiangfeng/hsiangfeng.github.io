[{"data":1,"prerenderedAt":1097},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":3,"page:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":4,"alt:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":3,"prev-next:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":1073,"related:\u002Fen\u002Fscss\u002F2025\u002F11\u002F23\u002Fsass-deprecated-import-use-forward-migration\u002F":1082},"\u002FSCSS\u002F20251123\u002F3919803484\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":8,"body":9,"category":1057,"date":1058,"description":1059,"extension":1060,"lang":1061,"meta":1062,"navigation":82,"path":1063,"readingMinutes":121,"seo":1064,"standalone":1065,"stem":1066,"tags":1067,"tldr":1070,"updated":1058,"url":1071,"__hash__":1072},"content\u002Fen\u002FSCSS\u002Fsass-deprecated-import-use-forward-migration.md","SCSS Is Deprecating @import?!","9314038819","\u002Fscss\u002F20251123\u002F3919803484\u002F",{"type":10,"value":11,"toc":1048},"minimark",[12,20,25,28,39,42,46,51,164,179,182,185,188,192,203,206,233,240,263,270,309,312,317,323,360,367,390,393,434,440,481,487,538,546,554,560,613,616,641,698,744,755,760,783,830,834,841,868,874,919,922,939,954,960,977,982,988,1031,1037,1041,1044],[13,14,15],"p",{},[16,17],"img",{"alt":18,"src":19},"Sass @import deprecation warning","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fscss\u002Fdeprecation-import\u002FChatGPT%20Image%202025%E5%B9%B411%E6%9C%8823%E6%97%A5%20%E4%B8%8B%E5%8D%8804_25_06.png",[21,22,24],"h2",{"id":23},"intro","Intro",[13,26,27],{},"I've been maintaining some legacy projects lately and decided to upgrade them along the way, but ran into this error:",[29,30,31],"blockquote",{},[13,32,33,34,38],{},"Deprecation Warning ",[35,36,37],"span",{},"import",": Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.",[13,40,41],{},"So this post is a quick note on what changed and how to migrate.",[21,43,45],{"id":44},"the-import-deprecation-warning","The @import deprecation warning",[13,47,48],{},[16,49],{"alt":18,"src":50},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fscss\u002Fdeprecation-import\u002F20251123153624.png",[52,53,58],"pre",{"className":54,"code":55,"language":56,"meta":57,"style":57},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","Deprecation Warning [import]: Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.\n\nMore info and automated migrator: https:\u002F\u002Fsass-lang.com\u002Fd\u002Fimport\n\n  ╷\n4 │ @import 'abstracts\u002Fvariables';\n  │         ^^^^^^^^^^^^^^^^^^^^^\n  ╵\n    src\u002Fcss\u002Fstyle.scss 4:9  root stylesheet\n","bash","",[59,60,61,77,84,105,110,116,134,143,149],"code",{"__ignoreMap":57},[35,62,65,69,73],{"class":63,"line":64},"line",1,[35,66,68],{"class":67},"smYoP","Deprecation",[35,70,72],{"class":71},"sWayO"," Warning",[35,74,76],{"class":75},"s8XSl"," [import]: Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.\n",[35,78,80],{"class":63,"line":79},2,[35,81,83],{"emptyLinePlaceholder":82},true,"\n",[35,85,87,90,93,96,99,102],{"class":63,"line":86},3,[35,88,89],{"class":67},"More",[35,91,92],{"class":71}," info",[35,94,95],{"class":71}," and",[35,97,98],{"class":71}," automated",[35,100,101],{"class":71}," migrator:",[35,103,104],{"class":71}," https:\u002F\u002Fsass-lang.com\u002Fd\u002Fimport\n",[35,106,108],{"class":63,"line":107},4,[35,109,83],{"emptyLinePlaceholder":82},[35,111,113],{"class":63,"line":112},5,[35,114,115],{"class":67},"  ╷\n",[35,117,119,122,125,128,131],{"class":63,"line":118},6,[35,120,121],{"class":67},"4",[35,123,124],{"class":71}," │",[35,126,127],{"class":71}," @import",[35,129,130],{"class":71}," 'abstracts\u002Fvariables'",[35,132,133],{"class":75},";\n",[35,135,137,140],{"class":63,"line":136},7,[35,138,139],{"class":67},"  │",[35,141,142],{"class":71},"         ^^^^^^^^^^^^^^^^^^^^^\n",[35,144,146],{"class":63,"line":145},8,[35,147,148],{"class":67},"  ╵\n",[35,150,152,155,158,161],{"class":63,"line":151},9,[35,153,154],{"class":67},"    src\u002Fcss\u002Fstyle.scss",[35,156,157],{"class":71}," 4:9",[35,159,160],{"class":71},"  root",[35,162,163],{"class":71}," stylesheet\n",[13,165,166,167,170,171,174,175,178],{},"In short: Sass has officially announced that ",[59,168,169],{},"@import"," will be removed in Dart Sass 3.0.0, and they recommend using ",[59,172,173],{},"@use"," or ",[59,176,177],{},"@forward"," instead.",[13,180,181],{},"Let's walk through what's changing.",[13,183,184],{},"If you're using the VSCode Watch Sass extension, you probably won't see this error — the extension is on an older version. But in real-world dev, you'll be using Vite, Webpack, or some other tool to compile SCSS, so you'll hit it eventually.",[13,186,187],{},"If you don't want to use Vite or Webpack to compile SCSS, you could also consider Parcel instead.",[21,189,191],{"id":190},"what-changed-with-use-and-forward","What changed with @use and @forward?",[13,193,194,195,197,198,174,200,202],{},"Basically, the new recommendation is to stop using ",[59,196,169],{}," and switch to ",[59,199,173],{},[59,201,177],{},".",[13,204,205],{},"Say you have a structure like this:",[52,207,211],{"className":208,"code":209,"language":210,"meta":57,"style":57},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","styles\u002F\n  abstracts\u002F\n    _variables.scss\n  style.scss\n","txt",[59,212,213,218,223,228],{"__ignoreMap":57},[35,214,215],{"class":63,"line":64},[35,216,217],{},"styles\u002F\n",[35,219,220],{"class":63,"line":79},[35,221,222],{},"  abstracts\u002F\n",[35,224,225],{"class":63,"line":86},[35,226,227],{},"    _variables.scss\n",[35,229,230],{"class":63,"line":107},[35,231,232],{},"  style.scss\n",[13,234,235,236,239],{},"And ",[59,237,238],{},"style\u002Fabstracts\u002F_variables.scss"," looks like:",[52,241,245],{"className":242,"code":243,"language":244,"meta":57,"style":57},"language-scss shiki shiki-themes github-light github-light github-dark-high-contrast","$primary-color: #3498db;\n","scss",[59,246,247],{"__ignoreMap":57},[35,248,249,253,257,261],{"class":63,"line":64},[35,250,252],{"class":251},"syBk-","$primary-color",[35,254,256],{"class":255},"sTzn1",": ",[35,258,260],{"class":259},"stw71","#3498db",[35,262,133],{"class":75},[13,264,265,266,269],{},"Then ",[59,267,268],{},"style\u002Fstyle.scss",":",[52,271,273],{"className":242,"code":272,"language":244,"meta":57,"style":57},"@import 'abstracts\u002Fvariables';\nbody {\n  background-color: $primary-color;\n}\n",[59,274,275,284,293,304],{"__ignoreMap":57},[35,276,277,280,282],{"class":63,"line":64},[35,278,169],{"class":279},"sOudu",[35,281,130],{"class":71},[35,283,133],{"class":75},[35,285,286,290],{"class":63,"line":79},[35,287,289],{"class":288},"syv7_","body",[35,291,292],{"class":75}," {\n",[35,294,295,298,300,302],{"class":63,"line":86},[35,296,297],{"class":259},"  background-color",[35,299,256],{"class":75},[35,301,252],{"class":251},[35,303,133],{"class":75},[35,305,306],{"class":63,"line":107},[35,307,308],{"class":75},"}\n",[13,310,311],{},"This is what most of us are used to.",[313,314,316],"h3",{"id":315},"what-changes-with-use","What changes with @use",[13,318,319,320,322],{},"In the new version you have to use ",[59,321,173],{},". Your first instinct might be to write it like this:",[52,324,326],{"className":242,"code":325,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: $primary-color;\n}\n",[59,327,328,336,340,346,356],{"__ignoreMap":57},[35,329,330,332,334],{"class":63,"line":64},[35,331,173],{"class":279},[35,333,130],{"class":71},[35,335,133],{"class":75},[35,337,338],{"class":63,"line":79},[35,339,83],{"emptyLinePlaceholder":82},[35,341,342,344],{"class":63,"line":86},[35,343,289],{"class":288},[35,345,292],{"class":75},[35,347,348,350,352,354],{"class":63,"line":107},[35,349,297],{"class":259},[35,351,256],{"class":75},[35,353,252],{"class":251},[35,355,133],{"class":75},[35,357,358],{"class":63,"line":112},[35,359,308],{"class":75},[13,361,362,363,366],{},"And you'll get a string of ",[59,364,365],{},"Undefined variable: \"$primary-color\"."," errors.",[13,368,369,370,372,373,377,378,381,382,385,386,389],{},"The reason is that ",[59,371,173],{}," wraps variables, functions, and mixins into a ",[374,375,376],"strong",{},"module namespace",". What does that mean? When you write ",[59,379,380],{},"@use 'abstracts\u002Fvariables';",", Sass treats the filename ",[59,383,384],{},"variables"," as a namespace, so you have to use ",[59,387,388],{},"variables.$primary-color"," to access the variable.",[13,391,392],{},"So the correct usage is:",[52,394,396],{"className":242,"code":395,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Fvariables';\n\nbody {\n  background-color: variables.$primary-color;\n}\n",[59,397,398,406,410,416,430],{"__ignoreMap":57},[35,399,400,402,404],{"class":63,"line":64},[35,401,173],{"class":279},[35,403,130],{"class":71},[35,405,133],{"class":75},[35,407,408],{"class":63,"line":79},[35,409,83],{"emptyLinePlaceholder":82},[35,411,412,414],{"class":63,"line":86},[35,413,289],{"class":288},[35,415,292],{"class":75},[35,417,418,420,422,424,426,428],{"class":63,"line":107},[35,419,297],{"class":259},[35,421,256],{"class":75},[35,423,384],{"class":251},[35,425,202],{"class":75},[35,427,252],{"class":251},[35,429,133],{"class":75},[35,431,432],{"class":63,"line":112},[35,433,308],{"class":75},[13,435,436,437,439],{},"What's the benefit? You avoid name collisions. When you ",[59,438,169],{}," a bunch of files, it's pretty easy to end up with duplicate variable names, like:",[52,441,443],{"className":242,"code":442,"language":244,"meta":57,"style":57},"\u002F\u002F variables.scss\n$primary-color: #3498db;\n\n\u002F\u002F another-variables.scss\n$primary-color: #e74c3c;\n",[59,444,445,451,461,465,470],{"__ignoreMap":57},[35,446,447],{"class":63,"line":64},[35,448,450],{"class":449},"sGBqm","\u002F\u002F variables.scss\n",[35,452,453,455,457,459],{"class":63,"line":79},[35,454,252],{"class":251},[35,456,256],{"class":255},[35,458,260],{"class":259},[35,460,133],{"class":75},[35,462,463],{"class":63,"line":86},[35,464,83],{"emptyLinePlaceholder":82},[35,466,467],{"class":63,"line":107},[35,468,469],{"class":449},"\u002F\u002F another-variables.scss\n",[35,471,472,474,476,479],{"class":63,"line":112},[35,473,252],{"class":251},[35,475,256],{"class":255},[35,477,478],{"class":259},"#e74c3c",[35,480,133],{"class":75},[13,482,483,484,486],{},"If you're using ",[59,485,169],{},", those two variables collide:",[52,488,490],{"className":242,"code":489,"language":244,"meta":57,"style":57},"@import 'variables';\n@import 'another-variables';\n\nbody {\n  background-color: $primary-color; \u002F\u002F collision here\n}\n",[59,491,492,501,510,514,520,534],{"__ignoreMap":57},[35,493,494,496,499],{"class":63,"line":64},[35,495,169],{"class":279},[35,497,498],{"class":71}," 'variables'",[35,500,133],{"class":75},[35,502,503,505,508],{"class":63,"line":79},[35,504,169],{"class":279},[35,506,507],{"class":71}," 'another-variables'",[35,509,133],{"class":75},[35,511,512],{"class":63,"line":86},[35,513,83],{"emptyLinePlaceholder":82},[35,515,516,518],{"class":63,"line":107},[35,517,289],{"class":288},[35,519,292],{"class":75},[35,521,522,524,526,528,531],{"class":63,"line":112},[35,523,297],{"class":259},[35,525,256],{"class":75},[35,527,252],{"class":251},[35,529,530],{"class":75},"; ",[35,532,533],{"class":449},"\u002F\u002F collision here\n",[35,535,536],{"class":63,"line":118},[35,537,308],{"class":75},[13,539,540,541,174,543,545],{},"So which one wins — ",[59,542,260],{},[59,544,478],{},"?",[547,548,549,553],"details",{},[550,551,552],"summary",{},"Click for the answer (think first!)","\nThe answer is #e74c3c — the later one overrides the earlier one.\n",[13,555,556,557,559],{},"With ",[59,558,173],{},", you can avoid this kind of collision:",[52,561,563],{"className":242,"code":562,"language":244,"meta":57,"style":57},"@use 'variables';\n@use 'another-variables';\n\nbody {\n  background-color: another-variables.$primary-color; \u002F\u002F explicitly pick which namespace\n}\n",[59,564,565,573,581,585,591,609],{"__ignoreMap":57},[35,566,567,569,571],{"class":63,"line":64},[35,568,173],{"class":279},[35,570,498],{"class":71},[35,572,133],{"class":75},[35,574,575,577,579],{"class":63,"line":79},[35,576,173],{"class":279},[35,578,507],{"class":71},[35,580,133],{"class":75},[35,582,583],{"class":63,"line":86},[35,584,83],{"emptyLinePlaceholder":82},[35,586,587,589],{"class":63,"line":107},[35,588,289],{"class":288},[35,590,292],{"class":75},[35,592,593,595,597,600,602,604,606],{"class":63,"line":112},[35,594,297],{"class":259},[35,596,256],{"class":75},[35,598,599],{"class":251},"another-variables",[35,601,202],{"class":75},[35,603,252],{"class":251},[35,605,530],{"class":75},[35,607,608],{"class":449},"\u002F\u002F explicitly pick which namespace\n",[35,610,611],{"class":63,"line":118},[35,612,308],{"class":75},[13,614,615],{},"This is a pretty significant change. For larger projects, I'd say it's worth migrating.",[13,617,618,619,622,623,625,626,628,629,632,633,635,636,638,639,202],{},"But there's a catch. Usually we put all variables in ",[59,620,621],{},"_variables.scss",". With ",[59,624,173],{},", if you want to use ",[59,627,252],{}," from a different file like ",[59,630,631],{},"_card.scss",", you have to ",[59,634,380],{}," inside ",[59,637,631],{}," too so you can access ",[59,640,388],{},[52,642,644],{"className":242,"code":643,"language":244,"meta":57,"style":57},"\u002F\u002F styles.css\n@use 'abstracts\u002Fvariables';\n@use 'components\u002Fcard';\n\n.card {\n  background-color: variables.$primary-color;\n}\n",[59,645,646,651,659,668,672,680,694],{"__ignoreMap":57},[35,647,648],{"class":63,"line":64},[35,649,650],{"class":449},"\u002F\u002F styles.css\n",[35,652,653,655,657],{"class":63,"line":79},[35,654,173],{"class":279},[35,656,130],{"class":71},[35,658,133],{"class":75},[35,660,661,663,666],{"class":63,"line":86},[35,662,173],{"class":279},[35,664,665],{"class":71}," 'components\u002Fcard'",[35,667,133],{"class":75},[35,669,670],{"class":63,"line":107},[35,671,83],{"emptyLinePlaceholder":82},[35,673,674,678],{"class":63,"line":112},[35,675,677],{"class":676},"sK3KL",".card",[35,679,292],{"class":75},[35,681,682,684,686,688,690,692],{"class":63,"line":118},[35,683,297],{"class":259},[35,685,256],{"class":75},[35,687,384],{"class":251},[35,689,202],{"class":75},[35,691,252],{"class":251},[35,693,133],{"class":75},[35,695,696],{"class":63,"line":136},[35,697,308],{"class":75},[52,699,701],{"className":242,"code":700,"language":244,"meta":57,"style":57},"\u002F\u002F components\u002F_card.scss\n@use 'abstracts\u002Fvariables';\n\n.card {\n  background-color: variables.$primary-color;\n}\n",[59,702,703,708,716,720,726,740],{"__ignoreMap":57},[35,704,705],{"class":63,"line":64},[35,706,707],{"class":449},"\u002F\u002F components\u002F_card.scss\n",[35,709,710,712,714],{"class":63,"line":79},[35,711,173],{"class":279},[35,713,130],{"class":71},[35,715,133],{"class":75},[35,717,718],{"class":63,"line":86},[35,719,83],{"emptyLinePlaceholder":82},[35,721,722,724],{"class":63,"line":107},[35,723,677],{"class":676},[35,725,292],{"class":75},[35,727,728,730,732,734,736,738],{"class":63,"line":112},[35,729,297],{"class":259},[35,731,256],{"class":75},[35,733,384],{"class":251},[35,735,202],{"class":75},[35,737,252],{"class":251},[35,739,133],{"class":75},[35,741,742],{"class":63,"line":118},[35,743,308],{"class":75},[13,745,746,747,622,749,751,752,754],{},"Otherwise you'll hit ",[59,748,365],{},[59,750,169],{},", variables were globally shared — ",[59,753,169],{}," basically created a global variable space, which is why name collisions happened so easily.",[13,756,556,757,759],{},[59,758,173],{},", every file's imports work independently.",[13,761,762,763,765,766,174,768,771,772,174,775,778,779,782],{},"Of course, ",[59,764,173],{}," can also be annoying if you don't want the namespace named ",[59,767,384],{},[59,769,770],{},"card"," — you might prefer ",[59,773,774],{},"v",[59,776,777],{},"c",". You can use ",[59,780,781],{},"as"," to rename the namespace:",[52,784,786],{"className":242,"code":785,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Fvariables' as v;\n\n.card {\n  background-color: v.$primary-color;\n}\n",[59,787,788,802,806,812,826],{"__ignoreMap":57},[35,789,790,792,794,797,800],{"class":63,"line":64},[35,791,173],{"class":279},[35,793,130],{"class":71},[35,795,796],{"class":279}," as",[35,798,799],{"class":251}," v",[35,801,133],{"class":75},[35,803,804],{"class":63,"line":79},[35,805,83],{"emptyLinePlaceholder":82},[35,807,808,810],{"class":63,"line":86},[35,809,677],{"class":676},[35,811,292],{"class":75},[35,813,814,816,818,820,822,824],{"class":63,"line":107},[35,815,297],{"class":259},[35,817,256],{"class":75},[35,819,774],{"class":251},[35,821,202],{"class":75},[35,823,252],{"class":251},[35,825,133],{"class":75},[35,827,828],{"class":63,"line":112},[35,829,308],{"class":75},[313,831,833],{"id":832},"what-changes-with-forward","What changes with @forward",[13,835,836,837,840],{},"In real-world projects, you often create an ",[59,838,839],{},"index.scss"," to re-export all variables, mixins, and functions. The old way looked like this:",[52,842,844],{"className":242,"code":843,"language":244,"meta":57,"style":57},"\u002F\u002F abstracts\u002F_index.scss\n@import 'variables';\n@import 'mixins';\n",[59,845,846,851,859],{"__ignoreMap":57},[35,847,848],{"class":63,"line":64},[35,849,850],{"class":449},"\u002F\u002F abstracts\u002F_index.scss\n",[35,852,853,855,857],{"class":63,"line":79},[35,854,169],{"class":279},[35,856,498],{"class":71},[35,858,133],{"class":75},[35,860,861,863,866],{"class":63,"line":86},[35,862,169],{"class":279},[35,864,865],{"class":71}," 'mixins'",[35,867,133],{"class":75},[13,869,870,871,269],{},"Now you import everything in one go and use it in ",[59,872,873],{},"style.scss",[52,875,877],{"className":242,"code":876,"language":244,"meta":57,"style":57},"@import 'abstracts\u002Findex';\nbody {\n  background-color: $primary-color;\n  @include center-block;\n}\n",[59,878,879,888,894,904,915],{"__ignoreMap":57},[35,880,881,883,886],{"class":63,"line":64},[35,882,169],{"class":279},[35,884,885],{"class":71}," 'abstracts\u002Findex'",[35,887,133],{"class":75},[35,889,890,892],{"class":63,"line":79},[35,891,289],{"class":288},[35,893,292],{"class":75},[35,895,896,898,900,902],{"class":63,"line":86},[35,897,297],{"class":259},[35,899,256],{"class":75},[35,901,252],{"class":251},[35,903,133],{"class":75},[35,905,906,909,913],{"class":63,"line":107},[35,907,908],{"class":279},"  @include",[35,910,912],{"class":911},"scAaK"," center-block",[35,914,133],{"class":75},[35,916,917],{"class":63,"line":112},[35,918,308],{"class":75},[13,920,921],{},"So your first instinct might be to change it like this:",[52,923,925],{"className":242,"code":924,"language":244,"meta":57,"style":57},"\u002F\u002F abstracts\u002F_index.scss\n@use 'variables';\n",[59,926,927,931],{"__ignoreMap":57},[35,928,929],{"class":63,"line":64},[35,930,850],{"class":449},[35,932,933,935,937],{"class":63,"line":79},[35,934,173],{"class":279},[35,936,498],{"class":71},[35,938,133],{"class":75},[13,940,941,942,944,945,947,948,950,951,953],{},"But this is wrong — you'll get ",[59,943,365],{},". As mentioned earlier, ",[59,946,173],{}," creates a namespace local to that file, so ",[59,949,873],{}," can't directly access ",[59,952,388],{}," through the index.",[13,955,956,957,959],{},"So what do you do? You use ",[59,958,177],{},". The correct syntax is:",[52,961,963],{"className":242,"code":962,"language":244,"meta":57,"style":57},"\u002F\u002F abstracts\u002F_index.scss\n@forward 'variables';\n",[59,964,965,969],{"__ignoreMap":57},[35,966,967],{"class":63,"line":64},[35,968,850],{"class":449},[35,970,971,973,975],{"class":63,"line":79},[35,972,177],{"class":279},[35,974,498],{"class":71},[35,976,133],{"class":75},[13,978,979,981],{},[59,980,177],{}," basically \"re-exports\" those variables, mixins, and functions so other files can use them directly.",[13,983,984,985,987],{},"Back in ",[59,986,873],{},", you can write:",[52,989,991],{"className":242,"code":990,"language":244,"meta":57,"style":57},"@use 'abstracts\u002Findex' as abs;\nbody {\n  background-color: abs.$primary-color;\n}\n",[59,992,993,1006,1012,1027],{"__ignoreMap":57},[35,994,995,997,999,1001,1004],{"class":63,"line":64},[35,996,173],{"class":279},[35,998,885],{"class":71},[35,1000,796],{"class":279},[35,1002,1003],{"class":251}," abs",[35,1005,133],{"class":75},[35,1007,1008,1010],{"class":63,"line":79},[35,1009,289],{"class":288},[35,1011,292],{"class":75},[35,1013,1014,1016,1018,1021,1023,1025],{"class":63,"line":86},[35,1015,297],{"class":259},[35,1017,256],{"class":75},[35,1019,1020],{"class":251},"abs",[35,1022,202],{"class":75},[35,1024,252],{"class":251},[35,1026,133],{"class":75},[35,1028,1029],{"class":63,"line":107},[35,1030,308],{"class":75},[13,1032,1033,1034,1036],{},"And now you can correctly use variables and mixins that ",[59,1035,177],{}," re-exports.",[21,1038,1040],{"id":1039},"closing-thoughts","Closing thoughts",[13,1042,1043],{},"I haven't written much SCSS for a while — didn't expect this big a change QQ",[1045,1046,1047],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-defau