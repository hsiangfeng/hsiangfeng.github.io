result);\n",[257,904,906,908,911],{"class":259,"line":905},54,[257,907,423],{"class":274},[257,909,910],{"class":270},"catch",[257,912,913],{"class":274}," (error) {\n",[257,915,917,919,922,924,927,929],{"class":259,"line":916},55,[257,918,406],{"class":274},[257,920,921],{"class":347},"error",[257,923,411],{"class":274},[257,925,926],{"class":281},"\"Error: \"",[257,928,510],{"class":270},[257,930,931],{"class":274}," error.message);\n",[257,933,935,937,940],{"class":259,"line":934},56,[257,936,423],{"class":274},[257,938,939],{"class":270},"finally",[257,941,429],{"class":274},[257,943,945,947,949,951,954],{"class":259,"line":944},57,[257,946,406],{"class":274},[257,948,348],{"class":347},[257,950,411],{"class":274},[257,952,953],{"class":281},"\"Program execution finished\"",[257,955,417],{"class":274},[257,957,959],{"class":259,"line":958},58,[257,960,449],{"class":274},[15,962,963],{},"The example above is actually PHP syntax translated to JavaScript. You can see the syntax structures are similar — that's part of why I ramped up on JavaScript quickly.",[15,965,966],{},"This post doesn't dive deep into JavaScript — not its focus.",[15,968,969,970,975],{},"If you're interested, see my earlier Ironman series: \"",[23,971,974],{"href":972,"rel":973},"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20190915\u002F57691927\u002F",[27],"RE: Zero Starting Learning JS Life","\" (article in Mandarin).",[15,977,978],{},"JavaScript syntax is simple, but easily misunderstood — especially for beginners, due to syntax quirks. E.g.:",[248,980,982],{"className":250,"code":981,"language":252,"meta":253,"style":253},"let a; \u002F\u002F If a isn't assigned, its value is undefined\nconsole.log(a); \u002F\u002F undefined\n\nlet b = null; \u002F\u002F null is a special value meaning \"no value\"\nconsole.log(b); \u002F\u002F null\n\nconsole.log(a == b); \u002F\u002F true\n",[74,983,984,994,1006,1010,1027,1039,1043],{"__ignoreMap":253},[257,985,986,988,991],{"class":259,"line":260},[257,987,291],{"class":270},[257,989,990],{"class":274}," a; ",[257,992,993],{"class":263},"\u002F\u002F If a isn't assigned, its value is undefined\n",[257,995,996,998,1000,1003],{"class":259,"line":267},[257,997,344],{"class":274},[257,999,348],{"class":347},[257,1001,1002],{"class":274},"(a); ",[257,1004,1005],{"class":263},"\u002F\u002F undefined\n",[257,1007,1008],{"class":259,"line":288},[257,1009,326],{"emptyLinePlaceholder":325},[257,1011,1012,1014,1017,1019,1022,1024],{"class":259,"line":305},[257,1013,291],{"class":270},[257,1015,1016],{"class":274}," b ",[257,1018,278],{"class":270},[257,1020,1021],{"class":299}," null",[257,1023,889],{"class":274},[257,1025,1026],{"class":263},"\u002F\u002F null is a special value meaning \"no value\"\n",[257,1028,1029,1031,1033,1036],{"class":259,"line":322},[257,1030,344],{"class":274},[257,1032,348],{"class":347},[257,1034,1035],{"class":274},"(b); ",[257,1037,1038],{"class":263},"\u002F\u002F null\n",[257,1040,1041],{"class":259,"line":329},[257,1042,326],{"emptyLinePlaceholder":325},[257,1044,1045,1047,1049,1052,1055,1058],{"class":259,"line":335},[257,1046,344],{"class":274},[257,1048,348],{"class":347},[257,1050,1051],{"class":274},"(a ",[257,1053,1054],{"class":270},"==",[257,1056,1057],{"class":274}," b); ",[257,1059,1060],{"class":263},"\u002F\u002F true\n",[15,1062,1063,1064,1067,1068,1071],{},"Normally these two shouldn't be equal, but in JavaScript, ",[74,1065,1066],{},"undefined"," and ",[74,1069,1070],{},"null"," are treated as equal. The reason: JavaScript's type coercion and comparison operator behavior.",[15,1073,1074],{},"These quirks have earned JavaScript various titles:",[1076,1077,1078,1082,1085],"ul",{},[1079,1080,1081],"li",{},"The weird language",[1079,1083,1084],{},"The quirky language",[1079,1086,1087],{},"The most misunderstood language in the world",[15,1089,1090],{},"So why is JavaScript still so popular?",[15,1092,1093],{},"I think mainly because there's a group of devs who love this language, continuously promoting it and fixing its flaws — making JavaScript better over time.",[15,1095,1096,1097,1067,1099,1101,1102,1104,1105,1067,1107,1109],{},"E.g., early JavaScript didn't have ",[74,1098,291],{},[74,1100,308],{}," — only ",[74,1103,271],{},", leading to unclear variable scope and pollution. Later ECMAScript 6 (ES6) introduced ",[74,1106,291],{},[74,1108,308],{},", making scope clearer.",[15,1111,1112],{},"These improvements are why JavaScript holds its place in frontend dev and is now one of the most popular languages.",[12,1114,1115],{},[15,1116,1117,1119,1120,975],{},[18,1118,59],{},"\nFor deeper learning on JavaScript's features, consider my earlier series \"",[23,1121,1124],{"href":1122,"rel":1123},"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20200307\u002F318160061\u002F",[27],"JavaScript Core Concepts",[15,1126,1127],{},"To really capture HTML \u002F CSS \u002F JavaScript's relationship:",[15,1129,1130],{},[33,1131],{"alt":1132,"src":1133},"HTML \u002F CSS \u002F JavaScript relationship diagram","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Flearnexp\u002Fithelp-2025\u002Fday26\u002F338-1733217432633.jpg",[1076,1135,1136,1142,1148],{},[1079,1137,1138,1141],{},[18,1139,1140],{},"HTML:"," the skeleton — provides structure and frame",[1079,1143,1144,1147],{},[18,1145,1146],{},"CSS:"," the skin and clothing — provides appearance and aesthetic",[1079,1149,1150,1153],{},[18,1151,1152],{},"JavaScript:"," the muscles and nervous system — provides movement and interaction",[15,1155,1156],{},"These are frontend dev's three pillars — none can be missing.",[38,1158,1160],{"id":1159},"closing-thoughts","Closing thoughts",[15,1162,1163],{},"Eventually I genuinely fell in love with JavaScript's weird quirks. Lots of frustrating moments, but those very quirks are what made me get into the language.",[38,1165,1167],{"id":1166},"also-published","Also published",[15,1169,1170],{},"This article is also published on:",[1076,1172,1