04,372,373],{"class":124}," \"\u003Cdiv>Successfully connected to MySQL!\u003C\u002Fdiv>\"",[104,375,129],{"class":128},[104,377,379,382,385],{"class":106,"line":378},16,[104,380,381],{"class":128},"      } ",[104,383,384],{"class":110},"else",[104,386,387],{"class":128}," {\n",[104,389,391,393,396],{"class":106,"line":390},17,[104,392,370],{"class":114},[104,394,395],{"class":124}," \"\u003Cdiv>Failed to connect to MySQL!\u003C\u002Fdiv>\"",[104,397,129],{"class":128},[104,399,401],{"class":106,"line":400},18,[104,402,403],{"class":128},"      }\n",[104,405,407],{"class":106,"line":406},19,[104,408,335],{"emptyLinePlaceholder":334},[104,410,412,415],{"class":106,"line":411},20,[104,413,414],{"class":114},"      mysqli_close",[104,416,417],{"class":128},"($connection);\n",[104,419,421],{"class":106,"line":420},21,[104,422,423],{"class":110},"  ?>\n",[104,425,427,429,431],{"class":106,"line":426},22,[104,428,271],{"class":110},[104,430,292],{"class":114},[104,432,173],{"class":110},[104,434,436,438,440],{"class":106,"line":435},23,[104,437,271],{"class":110},[104,439,181],{"class":114},[104,441,173],{"class":110},[17,443,444],{},"\"This code connects to MySQL and outputs success or failure.\" He explained.",[17,446,447],{},"That was my first PHP moment. Didn't see it coming?",[17,449,450],{},"At the time, PHP felt amazing — direct DB interaction, HTML embedding, real-time results on screen, even user interaction.",[17,452,453],{},"By comparison, C felt boring — at best, a few lines of text on black background, no satisfaction.",[17,455,456],{},"Because of this, I asked this teacher to be my capstone advisor. From that moment, I was officially on the capstone path.",[17,458,459],{},"The project came together fine, scored well — even got nominated by the department to be used as recruiting promotional material. But the process was misery and tears.",[17,461,462],{},"Code was rough, but team collaboration was rougher. My teammates slacked off, didn't collaborate, were clueless. 5-person group, but only 2 of us actually working (debugging is way easier than arguing, XD).",[17,464,465],{},"Don't forget the super-strict advisor — yes he made me stronger, but the pressure nearly gave me trauma.",[17,467,468],{},"What I handed in at the end wasn't just a project — it was half my life XD.",[17,470,471],{},[31,472],{"alt":473,"src":474},"Half-life","https:\u002F\u002Fmedia1.tenor.com\u002Fm\u002F7IKGRY1nLM0AAAAC\u002Face-attorney-penalty.gif",[36,476,478],{"id":477},"php-a-language-built-for-web-programming","PHP — a language built for web programming",[17,480,481],{},"PHP was designed from the start for web development, making it relatively easy for general programmers to pick up. Why?",[17,483,484],{},"Basic PHP syntax:",[94,486,488],{"className":96,"code":487,"language":98,"meta":99,"style":99},"\u003C?php\n\u002F\u002F Declare variables\n$name = \"Ray\";\n$age = 30;\n\n\u002F\u002F Output\necho \"My name is $name, I'm $age years old.\";\n\n\u002F\u002F Conditional\nif ($age >= 18) {\n    echo \"I'm an adult.\";\n} else {\n    echo \"I'm not an adult yet.\";\n}\n\n\u002F\u002F Loop\nfor ($i = 0; $i \u003C 5; $i++) {\n    echo \"This is iteration $i.\";\n}\n\n\u002F\u002F Array\n$fruits = array(\"Apple\", \"Banana\", \"Orange\");\nforeach ($fruits as $fruit) {\n    echo \"I like eating $fruit.\";\n}\n\n\u002F\u002F Function\nfunction greet($name) {\n    return \"Hi, $name!\";\n}\necho greet(\"Ray\");\n\n\u002F\u002F OOP\nclass Person {\n    public $name;\n    public $age; \n    public function __construct($name, $age) {\n        $this->name = $name;\n        $this->age = $age;\n    }\n    public function introduce() {\n        return \"My name is $this->name, I'm $this->age years old.\";\n    }\n}\n$person = new Person(\"Ray\", 30);\necho $person->introduce();\n\n\u002F\u002F Exception handling\ntry {\n    $result = 10 \u002F 0; \u002F\u002F Triggers division by zero\n} catch (DivisionByZeroError $e) {\n    echo \"Error: division by zero!\";\n} finally {\n    echo \"This is the finally block — always runs.\";\n}\n?>\n",[101,489,490,496,502,514,526,530,535,556,560,565,582,592,601,610,615,619,624,653,668,672,676,681,710,724,739,744,749,755,768,784,789,803,808,814,826,835,843,857,873,888,894,907,936,941,946,970,986,991,997,1005,1027,1044,1054,1064,1074,1079],{"__ignoreMap":99},[104,491,492,494],{"class":106,"line":107},[104,493,111],{"class":110},[104,495,115],{"class":114},[104,497,498],{"class":106,"line":118},[104,499,501],{"class":500},"sGBqm","\u002F\u002F Declare variables\n",[104,503,504,507,509,512],{"class":106,"line":132},[104,505,506],{"class":128},"$name ",[104,508,187],{"class":110},[104,510,511],{"class":124}," \"Ray\"",[104,513,129],{"class":128},[104,515,516,519,521,524],{"class":106,"line":204},[104,517,518],{"class":128},"$age ",[104,520,187],{"class":110},[104,522,523],{"class":114}," 30",[104,525,129],{"class":128},[104,527,528],{"class":106,"line":223},[104,529,335],{"emptyLinePlaceholder":334},[104,531,532],{"class":106,"line":248},[104,533,534],{"class":500},"\u002F\u002F Output\n",[104,536,537,539,542,545,548,551,554],{"class":106,"line":278},[104,538,121],{"class":114},[104,540,541],{"class":124}," \"My name is ",[104,543,544],{"class":128},"$name",[104,546,547],{"class":124},", I'm ",[104,549,550],{"class":128},"$age",[104,552,553],{"class":124}," years old.\"",[104,555,129],{"class":128},[104,557,558],{"class":106,"line":287},[104,559,335],{"emptyLinePlaceholder":334},[104,561,562],{"class":106,"line":297},[104,563,564],{"class":500},"\u002F\u002F Conditional\n",[104,566,567,570,573,576,579],{"class":106,"line":305},[104,568,569],{"class":110},"if",[104,571,572],{"class":128}," ($age ",[104,574,575],{"class":110},">=",[104,577,578],{"class":114}," 18",[104,580,581],{"class":128},") {\n",[104,583,584,587,590],{"class":106,"line":318},[104,585,586],{"class":114},"    echo",[104,588,589],{"class":124}," \"I'm an adult.\"",[104,591,129],{"class":128},[104,593,594,597,599],{"cl