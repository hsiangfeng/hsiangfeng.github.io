[{"data":1,"prerenderedAt":481},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F":3,"page:\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F":4,"alt:\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F":3,"prev-next:\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F":457,"related:\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F":466},"\u002Fgulp\u002F20190610\u002F1454585646\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":439,"date":440,"description":19,"extension":441,"lang":442,"meta":443,"navigation":444,"path":445,"readingMinutes":446,"seo":447,"standalone":448,"stem":449,"tags":450,"tldr":454,"updated":454,"url":455,"__hash__":456},"content\u002Fen\u002FGulp\u002Fgulp-series-02-install.md","Gulp Series: Installing Gulp","5646145458",{"type":9,"value":10,"toc":431},"minimark",[11,16,20,24,27,30,39,42,49,52,60,63,69,73,76,86,99,104,114,124,149,152,167,172,178,182,193,198,201,207,210,219,222,248,251,266,272,279,285,293,302,308,314,320,329,343,348,358,361,367,377,381,384,407,427],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last post got us familiar with what Gulp is. This one walks through installing Gulp from scratch. Keep your terminal open — we'll be using it a lot.",[12,21,23],{"id":22},"install-nodejs","Install Node.js",[17,25,26],{},"Like I mentioned earlier, install Node.js first. If you haven't, go do that.",[17,28,29],{},"LTS: Long-Term Support, stable\nCurrent: Latest",[17,31,32],{},[33,34,38],"a",{"href":35,"rel":36},"https:\u002F\u002Fnodejs.org\u002Fen\u002F",[37],"nofollow","Node.js (English)",[17,40,41],{},"I recommend LTS.",[17,43,44],{},[45,46],"img",{"alt":47,"src":48},"LTS","https:\u002F\u002Fi.imgur.com\u002FTCkPeqn.png",[17,50,51],{},"(Install is just clicking Next — skipping screenshots.)",[17,53,54,55,59],{},"Verify with ",[56,57,58],"code",{},"node -v",":",[17,61,62],{},"(I had v11.7.0 from another project — ignore that.)",[17,64,65],{},[45,66],{"alt":67,"src":68},"node version","https:\u002F\u002Fi.imgur.com\u002F4g8jejV.png",[12,70,72],{"id":71},"gulp-install-environment","Gulp install environment",[17,74,75],{},"Gulp install has two environments:",[77,78,79,83],"ul",{},[80,81,82],"li",{},"Windows (your machine — global)",[80,84,85],{},"Local (your project — scoped to that project)",[17,87,88,89,92,93,98],{},"Before installing, verify npm with ",[56,90,91],{},"npm -v"," — Gulp lives on ",[33,94,97],{"href":95,"rel":96},"https:\u002F\u002Fwww.npmjs.com\u002F",[37],"npm"," so we need it.",[17,100,101],{},[45,102],{"alt":97,"src":103},"https:\u002F\u002Fi.imgur.com\u002FiW8MmgX.png",[17,105,106,107,110,111,113],{},"With npm confirmed, install Gulp globally with ",[56,108,109],{},"-g",". Without ",[56,112,109],{}," it only installs in the project.",[17,115,116,117,119,120,123],{},"(",[56,118,109],{}," and ",[56,121,122],{},"--global"," are the same.)",[125,126,131],"pre",{"className":127,"code":128,"language":129,"meta":130,"style":130},"language-js shiki shiki-themes github-dark-high-contrast","npm install -g gulp\n","js","",[56,132,133],{"__ignoreMap":130},[134,135,138,142,146],"span",{"class":136,"line":137},"line",1,[134,139,141],{"class":140},"sMAXC","npm install ",[134,143,145],{"class":144},"sWyjQ","-",[134,147,148],{"class":140},"g gulp\n",[17,150,151],{},"or",[125,153,155],{"className":127,"code":154,"language":129,"meta":130,"style":130},"npm install --global gulp\n",[56,156,157],{"__ignoreMap":130},[134,158,159,161,164],{"class":136,"line":137},[134,160,141],{"class":140},[134,162,163],{"class":144},"--",[134,165,166],{"class":140},"global gulp\n",[17,168,54,169,59],{},[56,170,171],{},"gulp -v",[17,173,174],{},[45,175],{"alt":176,"src":177},"gulp version","https:\u002F\u002Fi.imgur.com\u002FdLSelyN.png",[12,179,181],{"id":180},"initialize-the-project","Initialize the project",[17,183,184,185,188,189,192],{},"Now create a project folder called ",[56,186,187],{},"Project",", then ",[56,190,191],{},"cd"," into it in your terminal:",[17,194,195],{},[45,196],{"alt":191,"src":197},"https:\u002F\u002Fi.imgur.com\u002FD4lM7qv.png",[17,199,200],{},"Make sure you're inside the project folder — otherwise you'll install in weird places.",[17,202,203],{},[45,204],{"alt":205,"src":206},"Project folder","https:\u002F\u002Fi.imgur.com\u002FsPBLGha.png",[17,208,209],{},"Initialize the project (so we can manage installed packages):",[125,211,213],{"className":127,"code":212,"language":129,"meta":130,"style":130},"npm init\n",[56,214,215],{"__ignoreMap":130},[134,216,217],{"class":136,"line":137},[134,218,212],{"class":140},[17,220,221],{},"You'll get a bunch of prompts. You can hit Enter through all of them to accept defaults (which is what I usually do):",[77,223,224,227,230,233,236,239,242,245],{},[80,225,226],{},"name: project name (defaults to folder name)",[80,228,229],{},"description: project description",[80,231,232],{},"entry point: entry file",[80,234,235],{},"test command: test command",[80,237,238],{},"git repository: Git URL",[80,240,241],{},"keyword: keywords",[80,243,244],{},"author: author",[80,246,247],{},"license: license",[17,249,250],{},"Lazy version that accepts all defaults:",[125,252,254],{"className":127,"code":253,"language":129,"meta":130,"style":130},"npm init -y\n",[56,255,256],{"__ignoreMap":130},[134,257,258,261,263],{"class":136,"line":137},[134,259,260],{"class":140},"npm init ",[134,262,145],{"class":144},[134,264,265],{"class":140},"y\n",[17,267,268],{},[45,269],{"alt":270,"src":271},"-y","https:\u002F\u002Fi.imgur.com\u002FzT5i3tB.png",[17,273,274,275,278],{},"Back in your folder you'll see a new ",[56,276,277],{},"package.json",".",[17,280,281],{},[45,282],{"alt":283,"src":284},"package","https:\u002F\u002Fi.imgur.com\u002FJvNt4ge.png",[17,286,287,288,290,291,59],{},"What's ",[56,289,277],{},"? It tracks installed packages. For example, install gulp without ",[56,292,109],{},[125,294,296],{"className":127,"code":295,"language":129,"meta":130,"style":130},"npm install gulp\n",[56,297,298],{"__ignoreMap":130},[134,299,300],{"class":136,"line":137},[134,301,295],{"class":140},[17,303,304],{},[45,305],{"alt":306,"src":307},"local","https:\u002F\u002Fi.imgur.com\u002FWRX0Emk.png",[17,309,310],{},[45,311],{"alt":312,"src":313},"No gulp before","https:\u002F\u002Fi.imgur.com\u002FjeSlL8g.png",[17,315,316],{},[45,317],{"alt":318,"src":319},"gulp after local install","https:\u002F\u002Fi.imgur.com\u002FqAvDQjR.png",[17,321,322,323,326,327,59],{},"But typically for project installs, use ",[56,324,325],{},"--save"," so the dependency is recorded in ",[56,328,277],{},[125,330,332],{"className":127,"code":331,"language":129,"meta":130,"style":130},"npm install --save gulp\n",[56,333,334],{"__ignoreMap":130},[134,335,336,338,340],{"class":136,"line":137},[134,337,141],{"class":140},[134,339,163],{"class":144},[134,341,342],{"class":140},"save gulp\n",[17,344,345,346,278],{},"This saves the package into ",[56,347,277],{},[17,349,350,351,353,354,357],{},"Why? If you don't save to ",[56,352,277],{},", when someone else clones your project they can't restore it — they'd just run ",[56,355,356],{},"npm install"," and get nothing.",[17,359,360],{},"You might think \"but the whole project folder gets zipped up, doesn't it?\"",[17,362,363],{},[45,364],{"alt":365,"src":366},"Image","https:\u002F\u002Fi.imgur.com\u002F2cJ0mjT.png",[17,368,369,370,373,374,376],{},"Sure, but some folders are ignored — like ",[56,371,372],{},"node_modules",", which is huge. So ",[56,375,277],{}," is the record of dependencies instead.",[12,378,380],{"id":379},"note","Note",[17,382,383],{},"This post is based on Gulp 4.2.0. If you want Gulp 3.9.1, swap the install commands:",[125,385,387],{"className":127,"code":386,"language":129,"meta":130,"style":130},"npm install -g gulp@3.9.1\n",[56,388,389],{"__ignoreMap":130},[134,390,391,393,395,398,402,404],{"class":136,"line":137},[134,392,141],{"class":140},[134,394,145],{"class":144},[134,396,397],{"class":140},"g gulp@",[134,399,401],{"class":400},"sCcAr","3.9",[134,403,278],{"class":140},[134,405,406],{"class":400},"1\n",[125,408,410],{"className":127,"code":409,"language":129,"meta":130,"style":130},"npm install --save gulp@3.9.1\n",[56,411,412],{"__ignoreMap":130},[134,413,414,416,418,421,423,425],{"class":136,"line":137},[134,415,141],{"class":140},[134,417,163],{"class":144},[134,419,420],{"class":140},"save gulp@",[134,422,401],{"class":400},[134,424,278],{"class":140},[134,426,406],{"class":400},[428,429,430],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":130,"searchDepth":432,"depth":432,"links":433},2,[434,435,436,437,438],{"id":14,"depth":432,"text":15},{"id":22,"depth":432,"text":23},{"id":71,"depth":432,"text":72},{"id":180,"depth":432,"text":181},{"id":379,"depth":432,"text":380},"Gulp","2019-06-10 10:09:08","md","en",{},true,"\u002Fen\u002Fgulp\u002Fgulp-series-02-install","2",{"title":6,"description":19},false,"en\u002FGulp\u002Fgulp-series-02-install",[439,451,452,453],"Node.js","Gulp 4","Gulp Series",null,"\u002Fen\u002Fgulp\u002F2019\u002F06\u002F10\u002Fgulp-series-02-install\u002F","JoDbJUboGCyIOsE_DfdsRdxP0tEg-r2glb2j2U5ap3E",{"newer":458,"older":462},{"url":459,"title":4