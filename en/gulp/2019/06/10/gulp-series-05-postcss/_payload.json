u can tune which browser versions need prefixes too.",[17,57,58,59,62,63,65],{},"The prefixes specifically come from the ",[36,60,61],{},"autoprefixer"," plugin. So what is PostCSS for? PostCSS is a CSS optimization layer, and ",[36,64,61],{}," is the plugin that handles the prefixing.",[12,67,69],{"id":68},"install-gulp-postcss-autoprefixer","Install gulp-postcss + autoprefixer",[17,71,72],{},"Install:",[74,75,80],"pre",{"className":76,"code":77,"language":78,"meta":79,"style":79},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save gulp-postcss autoprefixer\n","js","",[36,81,82],{"__ignoreMap":79},[83,84,87,91,95,98,101],"span",{"class":85,"line":86},"line",1,[83,88,90],{"class":89},"sMAXC","npm install ",[83,92,94],{"class":93},"sWyjQ","--",[83,96,97],{"class":89},"save gulp",[83,99,100],{"class":93},"-",[83,102,103],{"class":89},"postcss autoprefixer\n",[12,105,107],{"id":106},"how-to-set-it-up","How to set it up",[17,109,110,111,114,115,117],{},"Import ",[36,112,113],{},"gulp-postcss"," and ",[36,116,61],{},":",[74,119,121],{"className":76,"code":120,"language":78,"meta":79,"style":79},"const autoprefixer = require('autoprefixer');\nconst postcss = require('gulp-postcss');\n",[36,122,123,149],{"__ignoreMap":79},[83,124,125,128,132,135,139,142,146],{"class":85,"line":86},[83,126,127],{"class":93},"const",[83,129,131],{"class":130},"sCcAr"," autoprefixer",[83,133,134],{"class":93}," =",[83,136,138],{"class":137},"sj_SG"," require",[83,140,141],{"class":89},"(",[83,143,145],{"class":144},"sTRMh","'autoprefixer'",[83,147,148],{"class":89},");\n",[83,150,152,154,157,159,161,163,166],{"class":85,"line":151},2,[83,153,127],{"class":93},[83,155,156],{"class":130}," postcss",[83,158,134],{"class":93},[83,160,138],{"class":137},[83,162,141],{"class":89},[83,164,165],{"class":144},"'gulp-postcss'",[83,167,148],{"class":89},[17,169,170,171,117],{},"We need to update the SCSS task. SCSS is already compiled after ",[36,172,173],{},".pipe(sass().on('