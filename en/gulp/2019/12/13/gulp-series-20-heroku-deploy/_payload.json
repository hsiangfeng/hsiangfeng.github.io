[{"data":1,"prerenderedAt":486},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F":3,"page:\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F":4,"alt:\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F":3,"prev-next:\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F":462,"related:\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F":471},"\u002Fgulp\u002F20191213\u002F3886861343\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":445,"date":446,"description":19,"extension":447,"lang":448,"meta":449,"navigation":145,"path":450,"readingMinutes":451,"seo":452,"standalone":453,"stem":454,"tags":455,"tldr":459,"updated":459,"url":460,"__hash__":461},"content\u002Fen\u002FGulp\u002Fgulp-series-20-heroku-deploy.md","Gulp Series Bonus: Deploying Gulp to Heroku","1343388686",{"type":9,"value":10,"toc":439},"minimark",[11,16,20,24,27,36,44,51,55,58,83,90,298,301,312,330,336,339,345,360,369,372,375,383,386,392,399,428,435],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Haven't updated this series in a while. I recently needed to deploy my Gulp setup to Heroku, so let me write it up as a bonus chapter.",[12,21,23],{"id":22},"environment","Environment",[17,25,26],{},"Using the Gulp sample repo I built earlier:",[17,28,29],{},[30,31,35],"a",{"href":32,"rel":33},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FgulpSample",[34],"nofollow","gulpSample",[17,37,38,39,43],{},"I also updated the gulpfile to the Gulp 4 recommended style, in the ",[40,41,42],"code",{},"newGulpfile"," branch. It's not much different from Gulp 3.9.1, so check the code directly.",[17,45,46],{},[30,47,50],{"href":48,"rel":49},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FgulpSample\u002Fblob\u002Fcf0836a38eeedfd9fbe204ac170e6e524f577daf\u002Fgulpfile.js\u002Findex.js#L12",[34],"Code snippet",[12,52,54],{"id":53},"server","Server",[17,56,57],{},"Heroku just provides an environment — no built-in server. So we need to install Express:",[59,60,65],"pre",{"className":61,"code":62,"language":63,"meta":64,"style":64},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save express morgan\n","js","",[40,66,67],{"__ignoreMap":64},[68,69,72,76,80],"span",{"class":70,"line":71},"line",1,[68,73,75],{"class":74},"sMAXC","npm install ",[68,77,79],{"class":78},"sWyjQ","--",[68,81,82],{"class":74},"save express morgan\n",[17,84,85,86,89],{},"Create ",[40,87,88],{},"serve.js"," in the root:",[59,91,93],{"className":61,"code":92,"language":63,"meta":64,"style":64},"const express = require('express');\nconst logger = require('morgan');\n\nconst app = express();\n\napp.use(logger('dev'));\napp.use(express.static('public')); \u002F\u002F serve the static folder\napp.get('\u002F', (req, res) => {\n  res.sendfile('.\u002Fpublic\u002F');\n});\n\napp.listen(process.env.PORT || 3000);\n",[40,94,95,121,140,147,162,167,189,214,249,265,271,276],{"__ignoreMap":64},[68,96,97,100,104,107,111,114,118],{"class":70,"line":71},[68,98,99],{"class":78},"const",[68,101,103],{"class":102},"sCcAr"," express",[68,105,106],{"class":78}," =",[68,108,110],{"class":109},"sj_SG"," require",[68,112,113],{"class":74},"(",[68,115,117],{"class":116},"sTRMh","'express'",[68,119,120],{"class":74},");\n",[68,122,124,126,129,131,133,135,138],{"class":70,"line":123},2,[68,125,99],{"class":78},[68,127,128],{"class":102}," logger",[68,130,106],{"class":78},[68,132,110],{"class":109},[68,134,113],{"class":74},[68,136,137],{"class":116},"'morgan'",[68,139,120],{"class":74},[68,141,143],{"class":70,"line":142},3,[68,144,146],{"emptyLinePlaceholder":145},true,"\n",[68,148,150,152,155,157,159],{"class":70,"line":149},4,[68,151,99],{"class":78},[68,153,154],{"class":102}," app",[68,156,106],{"class":78},[68,158,103],{"class":109},[68,160,161],{"class":74},"();\n",[68,163,165],{"class":70,"line":164},5,[68,166,146],{"emptyLinePlaceholder":145},[68,168,170,173,176,178,181,183,186],{"class":70,"line":169},6,[68,171,172],{"class":74},"app.",[68,174,175],{"class":109},"use",[68,177,113],{"class":74},[68,179,180],{"class":109},"logger",[68,182,113],{"class":74},[68,184,185],{"class":116},"'dev'",[68,187,188],{"class":74},"));\n",[68,190,192,194,196,199,202,204,207,210],{"class":70,"line":191},7,[68,193,172],{"class":74},[68,195,175],{"class":109},[68,197,198],{"class":74},"(express.",[68,200,201],{"class":109},"static",[68,203,113],{"class":74},[68,205,206],{"class":116},"'public'",[68,208,209],{"class":74},")); ",[68,211,213],{"class":212},"sQrFR","\u002F\u002F serve the static folder\n",[68,215,217,219,222,224,227,230,234,237,240,243,246],{"class":70,"line":216},8,[68,218,172],{"class":74},[68,220,221],{"class":109},"get",[68,223,113],{"class":74},[68,225,226],{"class":116},"'\u002F'",[68,228,229],{"class":74},", (",[68,231,233],{"class":232},"s_sBn","req",[68,235,236],{"class":74},", ",[68,238,239],{"class":232},"res",[68,241,242],{"class":74},") ",[68,244,245],{"class":78},"=>",[68,247,248],{"class":74}," {\n",[68,250,252,255,258,260,263],{"class":70,"line":251},9,[68,253,254],{"class":74},"  res.",[68,256,257],{"class":109},"sendfile",[68,259,113],{"class":74},[68,261,262],{"class":116},"'.\u002Fpublic\u002F'",[68,264,120],{"class":74},[68,266,268],{"class":70,"line":267},10,[68,269,270],{"class":74},"});\n",[68,272,274],{"class":70,"line":273},11,[68,275,146],{"emptyLinePlaceholder":145},[68,277,279,281,284,287,290,293,296],{"class":70,"line":278},12,[68,280,172],{"class":74},[68,282,283],{"class":109},"listen",[68,285,286],{"class":74},"(process.env.",[68,288,289],{"class":102},"PORT",[68,291,292],{"class":78}," ||",[68,294,295],{"class":102}," 3000",[68,297,120],{"class":74},[12,299,300],{"id":300},"package",[17,302,303,304,307,308,311],{},"Heroku looks for ",[40,305,306],{},"npm start"," by default, so add a ",[40,309,310],{},"start"," script:",[59,313,317],{"className":314,"code":315,"language":316,"meta":64,"style":64},"language-json shiki shiki-themes github-dark-high-contrast","\"start\": \"node serve.js\"\n","json",[40,318,319],{"__ignoreMap":64},[68,320,321,324,327],{"class":70,"line":71},[68,322,323],{"class":116},"\"start\"",[68,325,326],{"class":74},": ",[68,328,329],{"class":116},"\"node serve.js\"\n",[17,331,332,333,335],{},"We're running ",[40,334,88],{}," with Node.",[17,337,338],{},"If you've worked with Node.js, you might be thinking: \"OK but that's just starting the server — where's Gulp?\" Right, that's the key:",[17,340,341,342,311],{},"To run a Gulp build before serving, add a ",[40,343,344],{},"build",[59,346,348],{"className":314,"code":347,"language":316,"meta":64,"style":64},"\"build\": \"gulp build --env prod\"\n",[40,349,350],{"__ignoreMap":64},[68,351,352,355,357],{"class":70,"line":71},[68,353,354],{"class":116},"\"build\"",[68,356,326],{"class":74},[68,358,359],{"class":116},"\"gulp build --env prod\"\n",[17,361,362,363,368],{},"You can customize other behaviors too — see ",[30,364,367],{"href":365,"rel":366},"https:\u002F\u002Fdevcenter.heroku.com\u002Farticles\u002Fnodejs-support#customizing-the-build-process",[34],"Heroku's customizing-build docs",".",[17,370,371],{},"Now deploy to Heroku and it'll run. I won't walk through Heroku setup — that's a separate topic.",[17,373,374],{},"One important gotcha — you might hit this error:",[59,376,381],{"className":377,"code":379,"language":380,"meta":64},[378],"language-text","npm ERR! Failed at the project@1.0.0 build script.\n\nnpm ERR! This is probably not a problem with npm. There is likely additional logging output above.\n\nnpm ERR! A complete log of this run can be found\n","text",[40,382,379],{"__ignoreMap":64},[17,384,385],{},"And:",[59,387,390],{"className":388,"code":389,"language":380,"meta":64},[378],"We're sorry this build is failing! You can troubleshoot common issues here:\nhttps:\u002F\u002Fdevcenter.heroku.com\u002Farticles\u002Ftroubleshooting-node-deploys\n\nSome possible problems:\n- Node version not specified in package.json\n  https:\u002F\u002Fdevcenter.heroku.com\u002Farticles\u002Fnodejs-support#specifying-a-node-js-version\n",[40,391,389],{"__ignoreMap":64},[17,393,394,395,398],{},"Fix: add this to ",[40,396,397],{},"package.json",":",[59,400,402],{"className":314,"code":401,"language":316,"meta":64,"style":64},"\"engines\": {\n    \"node\": \"11.7.0\"\n  }\n",[40,403,404,412,423],{"__ignoreMap":64},[68,405,406,409],{"class":70,"line":71},[68,407,408],{"class":116},"\"engines\"",[68,410,411],{"class":74},": {\n",[68,413,414,418,420],{"class":70,"line":123},[68,415,417],{"class":416},"sKpQp","    \"node\"",[68,419,326],{"class":74},[68,421,422],{"class":116},"\"11.7.0\"\n",[68,424,425],{"class":70,"line":142},[68,426,427],{"class":74},"  }\n",[17,429,430],{},[30,431,434],{"href":432,"rel":433},"https:\u002F\u002Fgulpdeployheroku.herokuapp.com\u002F",[34],"Live demo",[436,437,438],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default: