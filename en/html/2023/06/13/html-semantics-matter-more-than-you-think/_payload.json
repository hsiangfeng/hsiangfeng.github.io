1523,173],{"class":64},[54,1525,1526],{"class":517}," type",[54,1528,521],{"class":60},[54,1530,1531],{"class":524},"\"text\"",[54,1533,1534],{"class":60}," \u002F>\n",[54,1536,1537,1539,1541,1544,1546],{"class":56,"line":83},[54,1538,431],{"class":60},[54,1540,176],{"class":64},[54,1542,1543],{"class":60},">Submit\u003C\u002F",[54,1545,176],{"class":64},[54,1547,73],{"class":60},[54,1549,1550,1552,1554],{"class":56,"line":322},[54,1551,446],{"class":60},[54,1553,170],{"class":64},[54,1555,73],{"class":60},[363,1557,1559],{"height":365,"style":366,"scrolling":367,"title":170,"src":1558,"frameBorder":367,"loading":370,"allowTransparency":371,"allowFullScreen":371},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FbGQVrRa?default-tab=result","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FbGQVrRa\">\n  form\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[12,1561,1562,1563,1565,1566,1569,1570,883],{},"Quick note on ",[51,1564,176],{}," — in real-world dev, always set ",[51,1567,1568],{},"type"," explicitly. I won't repeat the why here, see my earlier post ",[136,1571,1573,1574,1576],{"href":1572},"\u002Fen\u002Fhtml\u002F2022\u002F09\u002F24\u002Fthe-curious-button-type-attribute\u002F","The Curious Case of Button's ",[51,1575,1568],{}," Attribute",[12,1578,1579,1580,1582,1583,845],{},"One more thing — we often pair ",[51,1581,1494],{}," with ",[51,1584,173],{},[44,1586,1588],{"className":46,"code":1587,"language":48,"meta":49,"style":49},"\u003Clabel for=\"name\">Name\u003C\u002Flabel>\n\u003Cinput type=\"text\" id=\"name\" \u002F>\n",[51,1589,1590,1610],{"__ignoreMap":49},[54,1591,1592,1594,1596,1599,1601,1604,1606,1608],{"class":56,"line":57},[54,1593,61],{"class":60},[54,1595,1494],{"class":64},[54,1597,1598],{"class":517}," for",[54,1600,521],{"class":60},[54,1602,1603],