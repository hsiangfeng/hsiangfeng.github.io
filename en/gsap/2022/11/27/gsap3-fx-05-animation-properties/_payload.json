[{"data":1,"prerenderedAt":382},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgsap\u002F2022\u002F11\u002F27\u002Fgsap3-fx-05-animation-properties\u002F":3,"page:\u002Fen\u002Fgsap\u002F2022\u002F11\u002F27\u002Fgsap3-fx-05-animation-properties\u002F":4,"alt:\u002Fen\u002Fgsap\u002F2022\u002F11\u002F27\u002Fgsap3-fx-05-animation-properties\u002F":3,"prev-next:\u002Fen\u002Fgsap\u002F2022\u002F11\u002F27\u002Fgsap3-fx-05-animation-properties\u002F":359,"related:\u002Fen\u002Fgsap\u002F2022\u002F11\u002F27\u002Fgsap3-fx-05-animation-properties\u002F":368},"\u002Fgsap\u002F20221127\u002F1252086867\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":341,"date":342,"description":19,"extension":343,"lang":344,"meta":345,"navigation":346,"path":347,"readingMinutes":210,"seo":348,"standalone":349,"stem":350,"tags":351,"tldr":356,"updated":342,"url":357,"__hash__":358},"content\u002Fen\u002FGSAP\u002Fgsap3-fx-05-animation-properties.md","(5) Fun Frontend Effects With GSAP3 - Animation Properties","8686712520",{"type":9,"value":10,"toc":336},"minimark",[11,16,20,24,27,37,40,86,97,100,127,138,144,147,178,183,186,217,222,225,232,263,268,279,290,321,326,329,332],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Let's take a look at the animation properties GSAP supports.",[12,21,23],{"id":22},"animation-properties","Animation properties",[17,25,26],{},"GSAP supports a ton of animation properties. There isn't really a definitive list because most of them are based on CSS properties. So GSAP's properties split into two groups:",[28,29,30,34],"ul",{},[31,32,33],"li",{},"CSS properties",[31,35,36],{},"Custom properties",[17,38,39],{},"Take the earlier example:",[41,42,47],"pre",{"className":43,"code":44,"language":45,"meta":46,"style":46},"language-js shiki shiki-themes github-dark-high-contrast","gsap.to('.box', { x: 100, duration: 3 })\n","js","",[48,49,50],"code",{"__ignoreMap":46},[51,52,55,59,63,66,70,73,77,80,83],"span",{"class":53,"line":54},"line",1,[51,56,58],{"class":57},"sMAXC","gsap.",[51,60,62],{"class":61},"sj_SG","to",[51,64,65],{"class":57},"(",[51,67,69],{"class":68},"sTRMh","'.box'",[51,71,72],{"class":57},", { x: ",[51,74,76],{"class":75},"sCcAr","100",[51,78,79],{"class":57},", duration: ",[51,81,82],{"class":75},"3",[51,84,85],{"class":57}," })\n",[17,87,88,89,92,93,96],{},"That ",[48,90,91],{},"x"," is a CSS-based GSAP shortcut for ",[48,94,95],{},"transform: translateX(100px)",".",[17,98,99],{},"You could write the long form instead:",[41,101,103],{"className":43,"code":102,"language":45,"meta":46,"style":46},"gsap.to('.box', { transform: 'translateX(100px)', duration: 3 })\n",[48,104,105],{"__ignoreMap":46},[51,106,107,109,111,113,115,118,121,123,125],{"class":53,"line":54},[51,108,58],{"class":57},[51,110,62],{"class":61},[51,112,65],{"class":57},[51,114,69],{"class":68},[51,116,117],{"class":57},", { transform: ",[51,119,120],{"class":68},"'translateX(100px)'",[51,122,79],{"class":57},[51,124,82],{"class":75},[51,126,85],{"class":57},[128,129,137],"iframe",{"height":130,"style":131,"scrolling":132,"title":133,"src":134,"frameBorder":132,"loading":135,"allowTransparency":136,"allowFullScreen":136},300,"width: 100%;","no","GSAP basics - 7","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FabKmVMx?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FabKmVMx\">\n  GSAP basics - 7\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,139,140,141,143],{},"Honestly though, that's painful to write — in practice we use ",[48,142,91],{}," because it's just shorter.",[17,145,146],{},"So which CSS properties does GSAP support? If you're a frontend dev, basically every CSS property you know is fair game. For example, move while rotating 360°:",[41,148,150],{"className":43,"code":149,"language":45,"meta":46,"style":46},"gsap.to('.box', { x: 100, rotate: 360, duration: 3 })\n",[48,151,152],{"__ignoreMap":46},[51,153,154,156,158,160,162,164,166,169,172,174,176],{"class":53,"line":54},[51,155,58],{"class":57},[51,157,62],{"class":61},[51,159,65],{"class":57},[51,161,69],{"class":68},[51,163,72],{"class":57},[51,165,76],{"class":75},[51,167,168],{"class":57},", rotate: ",[51,170,171],{"class":75},"360",[51,173,79],{"class":57},[51,175,82],{"class":75},[51,177,85],{"class":57},[128,179,182],{"height":130,"style":131,"scrolling":132,"title":180,"src":181,"frameBorder":132,"loading":135,"allowTransparency":136,"allowFullScreen":136},"GSAP - 8","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FpoKEpbO?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FpoKEpbO\">\n  GSAP - 8\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,184,185],{},"Or move while scaling:",[41,187,189],{"className":43,"code":188,"language":45,"meta":46,"style":46},"gsap.to('.box', { x: 100, scale: 2, duration: 3 })\n",[48,190,191],{"__ignoreMap":46},[51,192,193,195,197,199,201,203,205,208,211,213,215],{"class":53,"line":54},[51,194,58],{"class":57},[51,196,62],{"class":61},[51,198,65],{"class":57},[51,200,69],{"class":68},[51,202,72],{"class":57},[51,204,76],{"class":75},[51,206,207],{"class":57},", scale: ",[51,209,210],{"class":75},"2",[51,212,79],{"class":57},[51,214,82],{"class":75},[51,216,85],{"class":57},[128,218,221],{"height":130,"style":131,"scrolling":132,"title":219,"src":220,"frameBorder":132,"loading":135,"allowTransparency":136,"allowFullScreen":136},"GSAP - 9","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FLYrReRp?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpe