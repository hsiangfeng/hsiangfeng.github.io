'.box', { css: { x: 100, backgroundColor: 'red' }, duration: 3 })\n",[48,294,295],{"__ignoreMap":46},[51,296,297,299,301,303,305,308,310,312,314,317,319],{"class":53,"line":54},[51,298,58],{"class":57},[51,300,62],{"class":61},[51,302,65],{"class":57},[51,304,69],{"class":68},[51,306,307],{"class":57},", { css: { x: ",[51,309,76],{"class":75},[51,311,253],{"class":57},[51,313,256],{"class":68},[51,315,316],{"class":57}," }, duration: ",[51,318,82],{"class":75},[51,320,85],{"class":57},[128,322,325],{"height":130,"style":131,"scrolling":132,"title":323,"src":324,"frameBorder":132,"loading":135,"allowTransparency":136,"allowFullScreen":136},"GSAP - 11","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FBaVLJRJ?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FBaVLJRJ\">\n  GSAP - 11\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,327,328],{},"This is more typing for no real benefit — in practice we use the original flat form.",[17,330,331],{},"Next post: custom properties.",[333,334,335],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}