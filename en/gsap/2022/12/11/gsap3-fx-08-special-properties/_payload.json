[38,54,56],{"class":55},"sTRMh","'#box'",[38,58,59],{"class":44},", {\n",[38,61,63,66,70],{"class":40,"line":62},2,[38,64,65],{"class":44},"  x: ",[38,67,69],{"class":68},"sCcAr","100",[38,71,72],{"class":44},",\n",[38,74,76,79,82],{"class":40,"line":75},3,[38,77,78],{"class":44},"  duration: ",[38,80,81],{"class":68},"1",[38,83,72],{"class":44},[38,85,87,90,94,96],{"class":40,"line":86},4,[38,88,89],{"class":44},"  repeat: ",[38,91,93],{"class":92},"sWyjQ","-",[38,95,81],{"class":68},[38,97,72],{"class":44},[38,99,101,104],{"class":40,"line":100},5,[38,102,103],{"class":44},"  yoyo: ",[38,105,106],{"class":68},"true\n",[38,108,110],{"class":40,"line":109},6,[38,111,112],{"class":44},"})\n",[114,115,123],"iframe",{"height":116,"style":117,"scrolling":118,"title":119,"src":120,"frameBorder":118,"loading":121,"allowTransparency":122,"allowFullScreen":122},300,"width: 100%;","no","GSAP - 19","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FYzvQzGQ?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FYzvQzGQ\">\n  GSAP - 19\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,125,126],{},"So which ones above are special? Anything you wouldn't recognize as a CSS property is a GSAP \"special\" property:",[128,129,130,136,141,146],"ul",{},[131,132,133],"li",{},[35,134,135],{},"x",[131,137,138],{},[35,139,140],{},"duration",[131,142,143],{},[35,144,145],{},"repeat",[131,147,148],{},[35,149,150],{},"yoyo",[17,152,153,154,161],{},"There are a lot of special properties — I can't cover them all in one post. So let me cover some common ones. For the rest, see ",[155,156,160],"a",{"href":157,"rel":158},"https:\u002F\u002Fgreensock.com\u002Fdocs\u002Fv3\u002FGSAP\u002Fgsap.to()",[159],"nofollow","GSAP's official docs",".",[17,163,164,165,167,168,171,172,175,176,179,180,175,183,186],{},"Heads up — ",[35,166,135],{}," isn't strictly a special property; it's a shortcut for ",[35,169,170],{},"transform: translateX()",". Same goes for ",[35,173,174],{},"y"," and ",[35,177,178],{},"z"," (shortcuts for ",[35,181,182],{},"translateY()",[35,184,185],{},"translateZ()","). So I'll skip those.",[17,188,189,190,192,193,195,196,161],{},"Let's cover ",[35,191,140],{},", ",[35,194,145],{},", and ",[35,197,150],{},[12,199,140],{"id":140},[17,201,202,204],{},[35,203,140],{}," is how long the animation runs, in seconds. Set it to 1 and the animation finishes in 1 second. 0.x for sub-second.",[17,206,207],{},"Note: if you don't set this, the default is 0.5 seconds.",[28,209,211],{"className":30,"code":210,"language":32,"meta":33,"style":33},"gsap.to('#box', {\n  x: 100,\n  repeat: -1,\n  yoyo: true\n})\n",[35,212,213,225,233,243,249],{"__ignoreMap":33},[38,214,215,217,219,221,223],{"class":40,"line":41},[38,216,45],{"class":44},[38,218,49],{"class":48},[38,220,52],{"class":44},[38,222,56],{"class":55},[38,224,59],{"class":44},[38,226,227,229,231],{"class":40,"line":62},[38,228,65],{"class":44},[38,230,69],{"class":68},[38,232,72],{"class":44},[38,234,235,237,239,241],{"class":40,"line":75},[38,236,89],{"class":44},[38,238,93],{"class":92},[38,240,81],{"class":68},[38,242,72],{"class":44},[38,244,245,247],{"class":40,"line":86},[38,246,103],{"class":44},[38,248,106],{"class":68},[38,250,251],{"class":40,"line":100},[38,252,112],{"class":44},[114,254,257],{"height":116,"style":117,"scrolling":118,"title":255,"src":256,"frameBorder":118,"loading":121,"allowTransparency":122,"allowFullScreen":122},"GSAP - 20","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FyLEXLKL?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FyLEXLKL\">\n  GSAP - 20\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[12,259,145],{"id":145},[17,261,262,264,265,268,269,272,273,276],{},[35,263,145],{}," is how many times the animation repeats. Set it to ",[35,266,267],{},"-1"," for infinite repeat. ",[35,270,271],{},"0"," means no repeat. ",[35,274,275],{},"5"," means the animation runs 6 times total.",[28,278,280],{"className":30,"code":279,"language":32,"meta":33,"style":33},"gsap.to('#box', {\n  x: 100,\n  duration: 1,\n  repeat: 5,\n})\n",[35,281,282,294,302,310,318],{"__ignoreMap":33},[38,283,284,286,288,290,292],{"class":40,"line":41},[38,285,45],{"class":44},[38,287,49],{"class":48},[38,289,52],{"class":44},[38,291,56],{"class":55},[38,293,59],{"class":44},[38,295,296,298,300],{"class":40,"line":62},[38,297,65],{"class":44},[38,299,69],{"class":68},[38,301,72],{"class":44},[38,303,304,306,308],{"class":40,"line":75},[38,305,78],{"class":44},[38,307,81],{"class":68},[38,309,72],{"class":44},[38,311,312,314,316],{"class":40,"line":86},[38,313,89],{"class":44},[38,315,275],{"class":68},[38,317,72],{"class":44},[38,319,320],{"class":40,"line":100},[38,321,112],{"class":44},[114,323,326],{"height":116,"style":117,"scrolling":118,"title":324,"src":325,"frameBorder":118,"loading":121,"allowTransparency":122,"allowFullScreen":122},"GSAP - 22","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FYzvQPqJ?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FYzvQPqJ\">\n  GSAP - 22\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,328,329],{},"You might wonder: why is it 6 times when I said 5?",[17,331,332],{},"Because the initial run also counts — first time + 5 repeats = 6 total.",[12,334,150],{"id":150},[17,336,337,339,340,342,343,346],{},[35,338,150],{}," is fun. It controls whether the animation rewind