[{"data":1,"prerenderedAt":504},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgsap\u002F2023\u002F02\u002F08\u002Fgsap3-fx-17-scrolltrigger\u002F":3,"page:\u002Fen\u002Fgsap\u002F2023\u002F02\u002F08\u002Fgsap3-fx-17-scrolltrigger\u002F":4,"alt:\u002Fen\u002Fgsap\u002F2023\u002F02\u002F08\u002Fgsap3-fx-17-scrolltrigger\u002F":3,"prev-next:\u002Fen\u002Fgsap\u002F2023\u002F02\u002F08\u002Fgsap3-fx-17-scrolltrigger\u002F":482,"related:\u002Fen\u002Fgsap\u002F2023\u002F02\u002F08\u002Fgsap3-fx-17-scrolltrigger\u002F":491},"\u002Fgsap\u002F20230208\u002F3652684018\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":463,"date":464,"description":465,"extension":466,"lang":467,"meta":468,"navigation":108,"path":469,"readingMinutes":470,"seo":471,"standalone":472,"stem":473,"tags":474,"tldr":479,"updated":464,"url":480,"__hash__":481},"content\u002Fen\u002FGSAP\u002Fgsap3-fx-17-scrolltrigger.md","(17) Fun Frontend Effects With GSAP3 - ScrollTrigger","6840183652",{"type":9,"value":10,"toc":456},"minimark",[11,16,20,24,27,30,34,45,56,59,63,66,78,190,193,233,236,240,259,332,349,444,449,452],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"After covering plugin registration, let's look at ScrollTrigger specifically — it's one of the most useful GSAP plugins, so it deserves its own post.",[12,21,23],{"id":22},"what-is-scrolltrigger","What is ScrollTrigger?",[17,25,26],{},"ScrollTrigger is one of GSAP's official plugins, mainly used for scroll-driven animations.",[17,28,29],{},"A lot of scroll effects on real-world sites use ScrollTrigger. Let's get into it.",[12,31,33],{"id":32},"scrolltrigger-setup","ScrollTrigger setup",[17,35,36,37,44],{},"Last chapter covered the two install methods. Here I'll use CDN. Here's a ",[38,39,43],"a",{"href":40,"rel":41},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FJjZZOdR",[42],"nofollow","CodePen"," you can use:",[46,47,55],"iframe",{"height":48,"style":49,"scrolling":50,"title":51,"src":52,"frameBorder":50,"loading":53,"allowTransparency":54,"allowFullScreen":54},300,"width: 100%;","no","GSAP - 42","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FJjZZOdR?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FJjZZOdR\">\n  GSAP - 42\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,57,58],{},"I've prepared some basic HTML so you can practice.",[12,60,62],{"id":61},"basic-scrolltrigger-usage","Basic ScrollTrigger usage",[17,64,65],{},"Let's look at how to use ScrollTrigger to build a simple scroll animation.",[17,67,68,69,73,74,77],{},"It's straightforward — add a ",[70,71,72],"code",{},"scrollTrigger"," property to your ",[70,75,76],{},"gsap.to"," config and pass an options object that defines the trigger conditions.",[79,80,85],"pre",{"className":81,"code":82,"language":83,"meta":84,"style":84},"language-js shiki shiki-themes github-dark-high-contrast","gsap.registerPlugin(ScrollTrigger);\n\ngsap.to(\"#target\", {\n  scrollTrigger: {\n    trigger: \"#target\",\n    start: \"top\",\n    end: \"bottom\",\n    scrub: true,\n  },\n});\n","js","",[70,86,87,103,110,128,134,145,156,167,178,184],{"__ignoreMap":84},[88,89,92,96,100],"span",{"class":90,"line":91},"line",1,[88,93,95],{"class":94},"sMAXC","gsap.",[88,97,99],{"class":98},"sj_SG","registerPlugin",[88,101,102],{"class":94},"(ScrollTrigger);\n",[88,104,106],{"class":90,"line":105},2,[88,107,109],{"emptyLinePlaceholder":108},true,"\n",[88,111,113,115,118,121,125],{"class":90,"line":112},3,[88,114,95],{"class":94},[88,116,117],{"class":98},"to",[88,119,120],{"class":94},"(",[88,122,124],{"class":123},"sTRMh","\"#target\"",[88,126,127],{"class":94},", {\n",[88,129,131],{"class":90,"line":130},4,[88,132,133],{"class":94},"  scrollTrigger: {\n",[88,135,137,140,142],{"class":90,"line":136},5,[88,138,139],{"class":94},"    trigger: ",[88,141,124],{"class":123},[88,143,144],{"class":94},",\n",[88,146,148,151,154],{"class":90,"line":147},6,[88,149,150],{"class":94},"    start: ",[88,152,153],{"class":123},"\"top\"",[88,155,144],{"class":94},[88,157,159,162,165],{"class":90,"line":158},7,[88,160,161],{"class":94},"    end: ",[88,163,164],{"class":123},"\"bottom\"",[88,166,144],{"class":94},[88,168,170,173,176],{"class":90,"line":169},8,[88,171,172],{"class":94},"    scrub: ",[88,174,54],{"class":175},"sCcAr",[88,177,144],{"class":94},[88,179,181],{"class":90,"line":180},9,[88,182,183],{"class":94},"  },\n",[88,185,187],{"class":90,"line":186},10,[88,188,189],{"class":94},"});\n",[17,191,192],{},"What do the options mean?",[194,195,196,203,212,218],"ul",{},[197,198,199,202],"li",{},[70,200,201],{},"trigger",": the element that triggers the animation — when scrolling reaches it, the animation fires",[197,204,205,208,209,211],{},[70,206,207],{},"start",": where the animation starts — when scrolling reaches this point on the ",[70,210,201],{}," element",[197,213,214,217],{},[70,215,216],{},"end",": where the animation ends",[197,219,220,223,224,226,227,230,231],{},[70,221,222],{},"scrub",": whether the animation is driven by scroll. ",[70,225,54],{}," syncs animation with scroll. ",[70,228,229],{},"false"," triggers the animation when you hit ",[70,232,216],{},[17,234,235],{},"There are more options, but this is enough to start.",[12,237,239],{"id":238},"scrolltrigger-basic-example","ScrollTrigger basic example",[17,241,242,243,246,247,250,251,254,255,258],{},"Quick demo: when you scroll to ",[70,244,245],{},"#box2",", fade in ",[70,248,249],{},"#text2"," from ",[70,252,253],{},"opacity: 0"," to ",[70,256,257],{},"opacity: 1",":",[79,260,262],{"className":81,"code":261,"language":83,"meta":84,"style":84},"gsap.to(\"#text2\", {\n  scrollTrigger: {\n    trigger: \"#box2\",\n    start: \"top\",\n    end: \"bottom\",\n    scrub: true,\n  },\n  opacity: 1,\n});\n",[70,263,264,277,281,290,298,306,314,318,328],{"__ignoreMap":84},[88,265,266,268,270,272,275],{"class":90,"line":91},[88,267,95],{"class":94},[88,269,117],{"class":98},[88,271,120],{"class":94},[88,273,274],{"class":123},"\"#text2\"",[88,276,127],{"class":94},[88,278,279],{"class":90,"line":105},[88,280,133],{"class":94},[88,282,283,285,288],{"class":90,"line":112},[88,284,139],{"class":94},[88,286,287],{"class":123},"\"#box2\"",[88,289,144],{"class":94},[88,291,292,294,296],{"class":90,"line":130},[88,293,150],{"class":94},[88,295,153],{"class":123},[88,297,144],{"class":94},[88,299,300,302,304],{"class":90,"line":136},[88,301,161],{"class":94},[88,303,164],{"class":123},[88,305,144],{"class":94},[88,307,308,310,312],{"class":90,"line":147},[88,309,172],{"class":94},[88,311,54],{"class":175},[88,313,144],{"class":94},[88,315,316],{"class":90,"line":158},[88,317,183],{"class":94},[88,319,320,323,326],{"class":90,"line":169},[88,321,322],{"class":94},"  opacity: ",[88,324,325],{"class":175},"1",[88,327,144],{"class":94},[88,329,330],{"class":90,"line":180},[88,331,189],{"class":94},[17,333,334,335,337,338,341,342,344,345,348],{},"You might wonder why nothing happens. The issue is ",[70,336,249],{},"'s ",[70,339,340],{},"opacity"," starts at ",[70,343,325],{},", so there's no visible change. Two ways to fix this — either add an ",[70,346,347],{},"opacity-0"," class to the HTML to start it transparent, or use GSAP to set the initial state. Let me use option two:",[79,350,352],{"className":81,"code":351,"language":83,"meta":84,"style":84},"gsap.set('#text2', { opacity: 0 })\n\ngsap.to(\"#text2\", {\n  scrollTrigger: {\n    trigger: \"#box2\",\n    start: \"top\",\n    end: \"bottom\",\n    scrub: false,\n  },\n  opacity: 1,\n});\n",[70,353,354,375,379,391,395,403,411,419,427,431,439],{"__ignoreMap":84},[88,355,356,358,361,363,366,369,372],{"class":90,"line":91},[88,357,95],{"class":94},[88,359,360],{"class":98},"set",[88,362,120],{"class":94},[88,364,365],{"clas