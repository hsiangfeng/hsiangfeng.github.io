\u002Fdiv>\n",[57,208,210],{"class":59,"line":209},26,[57,211,212],{},"  );\n",[57,214,216],{"class":59,"line":215},27,[57,217,117],{},[57,219,221],{"class":59,"line":220},28,[57,222,124],{"emptyLinePlaceholder":123},[57,224,226],{"class":59,"line":225},29,[57,227,228],{},"const app = document.querySelector('#app');\n",[57,230,232],{"class":59,"line":231},30,[57,233,234],{},"const root = ReactDOM.createRoot(app);\n",[57,236,238],{"class":59,"line":237},31,[57,239,240],{},"root.render(\u003CApp \u002F>);\n",[242,243,251],"iframe",{"height":244,"style":245,"scrolling":246,"title":247,"src":248,"frameBorder":246,"loading":249,"allowTransparency":250,"allowFullScreen":250},300,"width: 100%;","no","(118) React useReducer","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FMWGprPj?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FMWGprPj\">\n  (118) React useReducer\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,253,254,255,257,258,260,261,263,264,266],{},"So what's the relationship between ",[43,256,45],{}," and Redux? At its core, ",[43,259,45],{}," is a Hook that the React team built after looking at Redux. But in practice the two still have some real differences. For example, Redux lets us share state across different pages or different components, whereas ",[43,262,45],{}," can only share state within the same component. Unless you bring in the Context API, under normal circumstances ",[43,265,45],{}," can't share state between different components.",[12,268,270],{"id":269},"the-relationship-between-react-redux-and-redux","The relationship between React Redux and Redux",[17,272,273],{},"So like I mentioned, Redux can be used on its own. But if it can run standalone, then what's the relationship between React Redux and Redux? It's basically because React uses Redux for state management so often that the React side put together a React Redux package. That package integrates Redux with React so we can use Redux more conveniently.",[12,275,277],{"id":276},"installing-react-redux-and-redux-toolkit","Installing React Redux and Redux Toolkit",[17,279,280],{},"Next up we're going to install React Redux and Redux Toolkit. Both of these are Redux-related packages, and Redux Toolkit is an official package from the Redux team that makes using Redux a lot easier.",[17,282,283,284,291],{},"So why use Redux Toolkit? If you head over to the ",[285,286,290],"a",{"href":287,"rel":288},"https:\u002F\u002Fredux-toolkit.js.org\u002Fintroduction\u002Fgetting-started",[289],"nofollow","Redux Toolkit"," docs, you'll see three pain points listed:",[293,294,295,304,312],"ul",{},[296,297,298,299],"li",{},"\"Configuring a Redux store is too complicated\"\n",[293,300,301],{},[296,302,303],{},"Configuring Redux is too complicated",[296,305,306,307],{},"\"I have to add a lot of packages to get Redux to do anything useful\"\n",[293,308,309],{},[296,310,311],{},"You have to install a bunch of packages just to get Redux doing anything useful",[296,313,314,315],{},"\"Redux requires too much boilerplate code\"\n",[293,316,317],{},[296,318,319],{},"Redux requires too much boilerplate code",[17,321,322],{},"Because of those three things, we're going to use Redux Toolkit to set up Redux here. So first we install Redux Toolkit and React Redux:",[48,324,328],{"className":325,"code":326,"language":327,"meta":53,"style":53},"language-bash shiki shiki-themes github-dark-high-contrast","npm install react-redux @reduxjs\u002Ftoolkit\n","bash",[43,329,330],{"__ignoreMap":53},[57,331,332,336,340,343],{"class":59,"line":60},[57,333,335],{"class":334},"s_sBn","npm",[57,337,339],{"class":338},"sTRMh"," install",[57,341,342],{"class":338}," react-redux",[57,344,345],{"class":338}," @reduxjs\u002Ftoolkit\n",[17,347,348],{},"One thing to watch out for when installing: React Redux 8.x needs at least React 16.8.3 to use React Hooks.",[12,350,352],{"id":351},"creating-a-redux-store-with-redux-toolkit","Creating a Redux Store with Redux Toolkit",[17,354,355,356,361],{},"For this part we'll use ",[285,357,360],{"href":358,"rel":359},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-vite-react",[289],"this"," sample code as our starting point. I'd suggest downloading it first so it's easier to follow along.",[17,363,364,365,368,369,372,373,376,377,379,380,382],{},"If there are no issues, start by creating a ",[43,366,367],{},"store"," folder under ",[43,370,371],{},"src",", then create an ",[43,374,375],{},"index.js"," file inside the ",[43,378,367],{}," folder, and add the following code to ",[43,381,375],{},":",[48,384,386],{"className":50,"code":385,"language":52,"meta":53,"style":53},"import { configureStore } from \"@reduxjs\u002Ftoolkit\";\n\nconst store = configureStore({\n  reducer: {},\n});\n\nexport default store;\n",[43,387,388,393,397,402,407,412,416],{"__ignoreMap":53},[57,389,390],{"class":59,"line":60},[57,391,392],{},"import { configureStore } from \"@reduxjs\u002Ftoolkit\";\n",[57,394,395],{"class":59,"line":66},[57,396,124],{"emptyLinePlaceholder":123},[57,398,399],{"class":59,"line":72},[57,400,401],{},"const store = configureStore({\n",[57,403,404],{"class":59,"line":78},[57,405,406],{},"  reducer: {},\n",[57,408,409],{"class":59,"line":84},[57,410,411],{},"});\n",[57,413,414],{"class":59,"line":90},[57,415,124],{"emptyLinePlaceholder":123},[57,417,418],{"class":59,"line":96},[57,419,420],{},"export default store;\n",[17,422,423,424,427,428,431,432,435,436,439,440,382],{},"Next, open ",[43,425,426],{},"src\u002Fmain.jsx",", import ",[43,429,430],{},"import store from '.\u002Fstore'"," and ",[43,433,434],{},"import { Provider } from 'react-redux'",", and wrap ",[43,437,438],{},"\u003CApp \u002F>"," with ",[43,441,442],{},"\u003CProvider store={store}>",[48,444,446],{"className":50,"code":445,"language":52,"meta":53,"style":53},"import React from 'react'\nimport ReactDOM from 'react-dom\u002Fclient'\nimport App from '.\u002FApp'\nimport '.\u002Findex.css'\nimport store from '.\u002Fstore'\nimport { Provider } from 'react-redux'\n\nReactDOM.createRoot(document.getElementById('root')).render(\n  \u003CReact.StrictMode>\n    \u003CProvider store={ store }>\n      \u003CApp \u002F>\n    \u003C\u002FProvider>\n  \u003C\u002FReact.StrictMode>\n)\n",[43,447,448,453,458,463,468,473,478,482,487,492,497,502,507,512],{"__ignoreMap":53},[57,449,450],{"class":59,"line":60},[57,451,452],{},"import React from 'react'\n",[57,454,455],{"class":59,"line":66},[57,456,457],{},"import ReactDOM from 'react-dom\u002Fclient'\n",[57,459,460],{"class":59,"line":72},[57,461,462],{},"import App from '.\u002FApp'\n",[57,464,465],{"class":59,"line":78},[57,466,467],{},"import '.\u002Findex.css'\n",[57,469,470],{"class":59,"line":84},[57,471,472],{},"import store from '.\u002Fstore'\n",[57,474,475],{"class":59,"line":90},[57,476,477],{},"import { Provider } from 'react-redux'\n",[57,479,480],{"class":59,"line":96},[57,481,124],{"emptyLinePlaceholder":123},[57,483,484],{"class":59,"line":102},[57,485,486],{},"ReactDOM.createRoot(document.getElementById('root')).render(\n",[57,488,489],{"class":59,"line":108},[57,490,491],{},"  \u003CReact.StrictMode>\n",[57,493,494],{"class":59,"line":114},[57,495,496],{},"    \u003CProvider store={ store }>\n",[57,498,499],{"class":59,"line":120},[57,500,501],{},"      \u003CApp \u002F>\n",[57,503,504],{"class":59,"line":127},[57,505,506],{},"    \u003C\u002FProvider>\n",[57,508,509],{"class":59,"line":133},[57,510,511],{},"  \u003C\u002FReact.StrictMode>\n",[57,513,514],{"class":59,"line":139},[57,515,516],{},")\n",[17,518,519],{},"So far we've finished setting up React Redux. Next we're going to tweak our original ToDoList code so it uses Redux for state management.",[12,521,523],{"id":522},"creating-a-redux-slice-with-redux-toolkit","Creating a Redux Slice with Redux Toolkit",[17,525,526,527,376,530,532,533,536,537,382],{},"Now we'll create a React Slice, so create a ",[43,528,529],{},"todoSlice.js",[43,531,367],{}," folder, and import ",[43,534,535],{},"createSlice"," in ",[43,538,529],{},[48,540,542],{"className":50,"code":541,"language":52,"meta":53,"style":53},"import { createSlice } from \"@reduxjs\u002Ftoolkit\";\n",[43,543,544],{"__ignoreMap":53},[57,545,546],{"class":59,"line":60},[57,547,541],{},[17,549,550,552,553,555,556,431,559,562],{},[43,551,535],{}," is a method provided by Redux Toolkit that makes creating a Redux Slice much easier. ",[43,554,535],{}," returns an object containing a ",[43,557,558],{},"reducer",[43,560,561],{},"actions",", so we can use it like this:",[48,564,566],{"className":50,"code":565,"language":52,"meta":53,"style":53},"const todoSlice = createSlice({\n  name: \"todo\"\n});\n",[43,567,568,573,578],{"__ignoreMap":53},[57,569,570],{"class":59,"line":60},[57,571,572],{},"const todoSlice = createSlice({\n",[57,574,575],{"class":59,"line":66},[57,576,577],{},"  name: \"todo\"\n",[57,579,580],{"class":59,"line":72},[57,581,411],{},[17,583,584,585,587,588,431,591,594,595,597,598,600,601,604,605,607,608,431,611,613],{},"There are two important things inside ",[43,586,535],{},": ",[43,589,590],{},"initialState",[43,592,593],{},"reducers",". ",[43,596,590],{}," is the initial state, and ",[43,599,593],{}," is an object containing all the ",[43,602,603],{},"action","s. You can think of an ",[43,606,603],{}," as a function, and each of these functions takes in two parameters, ",[43,609,610],{},"state",[43,612,603],{},".",[17,615,616,617,619,620,623,624,382],{},"Next let's convert the ToDoList code into Redux code. First we set up ",[43,618,590],{},", so the original ",[43,621,622],{},"const [ todoList, setTodoList ] = useState(JSON.parse(localStorage.getItem('todoList')) || []);"," that lived in App.jsx becomes the value of ",[43,625,590],{},[48,627,629],{"className":50,"code