"line":178},19,[66,180,163],{},[66,182,184],{"class":68,"line":183},20,[66,185,186],{},"        \u003C\u002Ful>\n",[66,188,190],{"class":68,"line":189},21,[66,191,192],{},"      \u003C\u002Fnav>\n",[66,194,196],{"class":68,"line":195},22,[66,197,198],{},"      \u003CRoutes>\n",[66,200,202],{"class":68,"line":201},23,[66,203,204],{},"        \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } \u002F>\n",[66,206,208],{"class":68,"line":207},24,[66,209,210],{},"        \u003CRoute path=\"\u002Ftodolist\" element={ \u003CToDoList \u002F> } \u002F>\n",[66,212,214],{"class":68,"line":213},25,[66,215,216],{},"      \u003C\u002FRoutes>\n",[66,218,220],{"class":68,"line":219},26,[66,221,222],{},"    \u003C\u002FHashRouter>\n",[66,224,226],{"class":68,"line":225},27,[66,227,228],{},"  \u003C\u002FReact.StrictMode>\n",[66,230,232],{"class":68,"line":231},28,[66,233,234],{},")\n",[17,236,237,238,240,241,244],{},"One thing to watch out for: ",[28,239,30],{}," has to live inside ",[28,242,243],{},"HashRouter",", otherwise you'll get this error:",[246,247,248],"blockquote",{},[17,249,250],{},"Uncaught Error: useHref() may be used only in the context of a Router component.",[17,252,253,254,256,257,260],{},"OK, back to where we left off. Above, we added two ",[28,255,30],{},"s — one for the home page and one for the ",[28,258,259],{},"ToDoList"," page. Now when you click either link up top, you'll see the view below switch along with it.",[17,262,263],{},[264,265],"img",{"alt":23,"src":266},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E4%BE%86%E8%87%AA%20Vue%20%E7%9A%84%20React%20Hook%20%E9%96%8B%E7%99%BC%E8%80%85\u002FJul-16-2022%2014-51-08.gif",[17,268,269,270,272,273,276,277,280,281,284],{},"So you can see ",[28,271,30],{}," is really easy to use — you just give it a ",[28,274,275],{},"to"," prop set to the same value as the ",[28,278,279],{},"Path"," attribute on your ",[28,282,283],{},"Route",", and it'll take you to that page.",[17,286,287,288,291],{},"Doesn't it feel a lot like Vue Router's ",[28,289,290],{},"router-link","? Here's a quick reminder of how navigation switching looks in Vue Router.",[57,293,297],{"className":294,"code":295,"language":296,"meta":62,"style":62},"language-html shiki shiki-themes github-dark-high-contrast","\u003Crouter-link to=\"\u002Ftodolist\">ToDoList\u003C\u002Frouter-link>\n","html",[28,298,299],{"__ignoreMap":62},[66,300,301,305,308,312,315,319,322,324],{"class":68,"line":69},[66,302,304],{"class":303},"sMAXC","\u003C",[66,306,290],{"class":307},"sKpQp",[66,309,311],{"class":310},"sCcAr"," to",[66,313,314],{"class":303},"=",[66,316,318],{"class":317},"sTRMh","\"\u002Ftodolist\"",[66,320,321],{"class":303},">ToDoList\u003C\u002F",[66,323,290],{"class":307},[66,325,326],{"class":303},">\n",[12,328,330],{"id":329},"nested-routes","Nested routes",[17,332,333,334,337,338,340,341,344,345,348],{},"Back to nested routes. There's a problem here if you look closely: all of our pages live under ",[28,335,336],{},"\u002F",". But in real development you can't have everything sitting under ",[28,339,336],{}," — you'll almost always have routes like ",[28,342,343],{},"admin",", ",[28,346,347],{},"dashboard",", and so on, with other routes hanging off of them. For example, say we expect the URL to change like this:",[57,350,354],{"className":351,"code":352,"language":353,"meta":62,"style":62},"language-sh shiki shiki-themes github-dark-high-contrast","https:\u002F\u002Fwww.example.com\u002F#\u002Fadmin\nhttps:\u002F\u002Fwww.example.com\u002F#\u002Fadmin\u002Fproducts\n","sh",[28,355,356,362],{"__ignoreMap":62},[66,357,358],{"class":68,"line":69},[66,359,361],{"class":360},"s_sBn","https:\u002F\u002Fwww.example.com\u002F#\u002Fadmin\n",[66,363,364],{"class":68,"line":75},[66,365,366],{"class":360},"https:\u002F\u002Fwww.example.com\u002F#\u002Fadmin\u002Fproducts\n",[17,368,369,370,372],{},"At this point you might be thinking... \"So I just write the ",[28,371,283],{}," like this, right? What's the problem?\"",[57,374,376],{"className":59,"code":375,"language":61,"meta":62,"style":62},"\u003CRoutes>\n  \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } \u002F>\n  \u003CRoute path=\"\u002Ftodolist\" element={ \u003CToDoList \u002F> } \u002F>\n  \u003CRoute path=\"\u002Fadmin\" element={ \u003CToDoList \u002F> } \u002F>\n  \u003CRoute path=\"\u002Fadmin\u002Fproducts\" element={ \u003CToDoList \u002F> } \u002F>\n\u003C\u002FRoutes>\n",[28,377,378,383,388,393,398,403],{"__ignoreMap":62},[66,379,380],{"class":68,"line":69},[66,381,382],{},"\u003CRoutes>\n",[66,384,385],{"class":68,"line":75},[66,386,387],{},"  \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } \u002F>\n",[66,389,390],{"class":68,"line":81},[66,391,392],{},"  \u003CRoute path=\"\u002Ftodolist\" element={ \u003CToDoList \u002F> } \u002F>\n",[66,394,395],{"class":68,"line":87},[66,396,397],{},"  \u003CRoute path=\"\u002Fadmin\" element={ \u003CToDoList \u002F> } \u002F>\n",[66,399,400],{"class":68,"line":93},[66,401,402],{},"  \u003CRoute path=\"\u002Fadmin\u002Fproducts\" element={ \u003CToDoList \u002F> } \u002F>\n",[66,404,405],{"class":68,"line":99},[66,406,407],{},"\u003C\u002FRoutes>\n",[17,409,410,411,413,414,417,418,420,421,423,424,426,427,429],{},"And yeah, writing it like this does get you the effect I described above. But the ",[28,412,343],{}," pages and the ",[28,415,416],{},"user"," pages are bound to differ in some ways — for instance, ",[28,419,343],{}," has its own navbar that's definitely not the same as the ",[28,422,416],{}," one. You can't have ",[28,425,416],{}," seeing the ",[28,428,343],{}," features and controls, right? If you really did it this way, every page would end up sharing the exact same navbar. So this is where we need nested routes to pull off the idea of a Layout.",[17,431,432,433,435,436,438],{},"So how do we write nested routes? It's actually simple — you just wrap a ",[28,434,283],{}," inside another ",[28,437,283],{},", like this:",[57,440,442],{"className":59,"code":441,"language":61,"meta":62,"style":62},"\u003CRoutes>\n  \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } >\n    \u003CRoute path=\"todolist\" element={ \u003CToDoList \u002F> } \u002F>\n  \u003C\u002FRoute>\n  \u003CRoute path=\"\u002Fadmin\" element={ \u003CAdmin \u002F> } >\n    \u003CRoute path=\"products\" element={ \u003CAdminProducts \u002F> } \u002F>\n  \u003C\u002FRoute>\n\u003C\u002FRoutes>\n",[28,443,444,448,453,458,463,468,473,477],{"__ignoreMap":62},[66,445,446],{"class":68,"line":69},[66,447,382],{},[66,449,450],{"class":68,"line":75},[66,451,452],{},"  \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } >\n",[66,454,455],{"class":68,"line":81},[66,456,457],{},"    \u003CRoute path=\"todolist\" element={ \u003CToDoList \u002F> } \u002F>\n",[66,459,460],{"class":68,"line":87},[66,461,462],{},"  \u003C\u002FRoute>\n",[66,464,465],{"class":68,"line":93},[66,466,467],{},"  \u003CRoute path=\"\u002Fadmin\" element={ \u003CAdmin \u002F> } >\n",[66,469,470],{"class":68,"line":99},[66,471,472],{},"    \u003CRoute path=\"products\" element={ \u003CAdminProducts \u002F> } \u002F>\n",[66,474,475],{"class":68,"line":105},[66,476,462],{},[66,478,479],{"class":68,"line":112},[66,480,407],{},[17,482,483],{},"Next, to make the difference more obvious, I want you to take the navbar we just wrote in main.jsx:",[57,485,487],{"className":59,"code":486,"language":61,"meta":62,"style":62},"\u003Cnav className=\"px-5 flex items-center h-[60px] bg-indigo-500 text-white\">\n  \u003Ch1 className=\"mr-auto text-2xl\">React TodoList\u003C\u002Fh1>\n  \u003Cul className=\"flex\">\n    \u003Cli className=\"mr-3\">\n      \u003CLink to=\"\u002F\" className=\"border p-3 hover:bg-indigo-600 duration-500\">Home\u003C\u002FLink>\n    \u003C\u002Fli>\n    \u003Cli>\n      \u003CLink to=\"\u002Ftodolist\" className=\"border p-3 hover:bg-indigo-600 duration-500\">ToDoList\u003C\u002FLink>\n    \u003C\u002Fli>\n    \u003Cli>\n      