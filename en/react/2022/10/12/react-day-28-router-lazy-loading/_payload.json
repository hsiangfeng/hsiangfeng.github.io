39],{"class":89},[53,340,142],{"class":89},[53,342,145],{"class":89},[53,344,345],{"class":108}," 51.47",[53,347,127],{"class":89},[17,349,350],{},"You can see things got split up into much smaller pieces. With Lazy Loading, we split our code into separate chunks and only load the matching file when we need or request it. So let's look at how to actually use it.",[17,352,353,354,357],{},"First, open ",[39,355,356],{},"index.js"," inside the routes folder. You'll see code like this:",[44,359,363],{"className":360,"code":361,"language":362,"meta":49,"style":49},"language-jsx shiki shiki-themes github-dark-high-contrast","import { useRoutes } from 'react-router-dom';\n\nimport App from '..\u002FApp';\nimport ToDoList from '..\u002FToDoList';\nimport Products from '..\u002FProducts';\nimport Admin from '..\u002FAdmin';\n\nconst routes = [\n  {\n    path: '\u002F',\n    element: \u003CApp \u002F>,\n  },\n  {\n    path: '\u002Ftodolist',\n    element: \u003CToDoList \u002F>,\n  },\n  {\n    path: '\u002Fproducts',\n    element: \u003CProducts \u002F>,\n  },\n  {\n    path: '\u002Fadmin',\n    element: \u003CAdmin \u002F>,\n  }\n];\n\nexport default () => useRoutes(routes);\n","jsx",[39,364,365,370,374,379,384,389,394,398,403,408,413,418,423,428,434,440,445,450,456,462,467,472,478,484,490,496,501],{"__ignoreMap":49},[53,366,367],{"class":55,"line":56},[53,368,369],{},"import { useRoutes } from 'react-router-dom';\n",[53,371,372],{"class":55,"line":67},[53,373,79],{"emptyLinePlaceholder":78},[53,375,376],{"class":55,"line":75},[53,377,378],{},"import App from '..\u002FApp';\n",[53,380,381],{"class":55,"line":82},[53,382,383],{},"import ToDoList from '..\u002FToDoList';\n",[53,385,386],{"class":55,"line":102},[53,387,388],{},"import Products from '..\u002FProducts';\n",[53,390,391],{"class":55,"line":118},[53,392,393],{},"import Admin from '..\u002FAdmin';\n",[53,395,396],{"class":55,"line":130},[53,397,79],{"emptyLinePlaceholder":78},[53,399,400],{"class":55,"line":153},[53,401,402],{},"const routes = [\n",[53,404,405],{"class":55,"line":273},[53,406,407],{},"  {\n",[53,409,410],{"class":55,"line":293},[53,411,412],{},"    path: '\u002F',\n",[53,414,415],{"class":55,"line":312},[53,416,417],{},"    element: \u003CApp \u002F>,\n",[53,419,420],{"class":55,"line":330},[53,421,422],{},"  },\n",[53,424,426],{"class":55,"line":425},13,[53,427,407],{},[53,429,431],{"class":55,"line":430},14,[53,432,433],{},"    path: '\u002Ftodolist',\n",[53,435,437],{"class":55,"line":436},15,[53,438,439],{},"    element: \u003CToDoList \u002F>,\n",[53,441,443],{"class":55,"line":442},16,[53,444,422],{},[53,446,448],{"class":55,"line":447},17,[53,449,407],{},[53,451,453],{"class":55,"line":452},18,[53,454,455],{},"    path: '\u002Fproducts',\n",[53,457,459],{"class":55,"line":458},19,[53,460,461],{},"    element: \u003CProducts \u002F>,\n",[53,463,465],{"class":55,"line":464},20,[53,466,422],{},[53,468,470],{"class":55,"line":469},21,[53,471,407],{},[53,473,475],{"class":55,"line":474},22,[53,476,477],{},"    path: '\u002Fadmin',\n",[53,479,481],{"class":55,"line":480},23,[53,482,483],{},"    element: \u003CAdmin \u002F>,\n",[53,485,487],{"class":55,"line":486},24,[53,488,489],{},"  }\n",[53,491,493],{"class":55,"line":492},25,[53,494,495],{},"];\n",[53,497,499],{"class":55,"line":498},26,[53,500,79],{"emptyLinePlaceholder":78},[53,502,504],{"class":55,"line":503},27,[53,505,506],{},"export default () => useRoutes(routes);\n",[17,508,509,510,513],{},"Next, import the ",[39,511,512],{},"lazy"," function at the top:",[44,515,517],{"className":360,"code":516,"language":362,"meta":49,"style":49},"import { lazy } from 'react';\n",[39,518,519],{"__ignoreMap":49},[53,520,521],{"class":55,"line":56},[53,522,516],{},[17,524,525,526,528,529,532,533,532,536,539,540,543,544,546],{},"So what is ",[39,527,512],{},"? In short, it's a function that lets us load the matching code only when we need it, instead of loading everything up front. So we can switch all four components — ",[39,530,531],{},"App",", ",[39,534,535],{},"ToDoList",[39,537,538],{},"Products",", and ",[39,541,542],{},"Admin"," — over to loading via ",[39,545,512],{},":",[44,548,550],{"className":360,"code":549,"language":362,"meta":49,"style":49},"import { lazy } from 'react';\n\nconst App = lazy(() => import('..\u002FApp'));\nconst ToDoList = lazy(() => import('..\u002FToDoList'));\nconst Products = lazy(() => import('..\u002FProducts'));\nconst Admin = lazy(() => import('..\u002FAdmin'));\n",[39,551,552,556,560,565,570,575],{"__ignoreMap":49},[53,553,554],{"class":55,"line":56},[53,555,516],{},[53,557,558],{"class":55,"line":67},[53,559,79],{"emptyLinePlaceholder":78},[53,561,562],{"class":55,"line":75},[53,563,564],{},"const App = lazy(() => import('..\u002FApp'));\n",[53,566,567],{"class":55,"line":82},[53,568,569],{},"const ToDoList = lazy(() => import('..\u002FToDoList'));\n",[53,571,572],{"class":55,"line":102},[53,573,574],{},"const Products = lazy(() => import('..\u002FProducts'));\n",[53,576,577],{"class":55,"line":118},[53,578,579],{},"const Admin = lazy(() => import('..\u002FAdmin'));\n",[17,581,582,583,586,587,590],{},"Next, we need to import the ",[39,584,585],{},"Suspense"," component in ",[39,588,589],{},"App.js",". This component lets us show some kind of loading screen while a component is loading. The basic usage is pretty simple:",[44,592,594],{"className":360,"code":593,"language":362,"meta":49,"style":49},"\u003CSuspense fallback={ Loading component }>component about to load\u003CSuspense>\n",[39,595,596],{"__ignoreMap":49},[53,597,598],{"class":55,"line":56},[53,599,593],{},[17,601,602,603,605,606,608,609,611,612,614,615,617],{},"So why use ",[39,604,585],{},"? Mainly because the components are loaded with ",[39,607,512],{},", which means there's a bit of delay while they load. With ",[39,610,585],{},", we can show a loading screen so the user knows something's happening instead of just staring at a blank page. So let's add ",[39,613,585],{}," in ",[39,616,589],{}," to display that loading screen:",[44,619,621],{"className":360,"code":620,"language":362,"meta":49,"style":49},"import { StrictMode, Suspense } from 'react'\nimport { HashRouter, NavLink } from \"react-router-dom\";\nimport ReactDOM from 'react-dom\u002Fclient'\nimport Router from '.\u002Froutes'\nimport '.\u002Findex.css';\n\nReactDOM.createRoot(document.getElementById('root')).render(\n  \u003CStrictMode>\n    \u003CHashRouter>\n      \u003Cnav className=\"px-5 flex items-center h-[60px] bg-indigo-500 text-white\">\n        {\u002F* ...trimmed *\u002F}\n      \u003C\u002Fnav>\n      \u003CSuspense fallback={\u003Cdiv>Loading...\u003C\u002Fdiv>}>\n        \u003CRouter \u002F>\n      \u003C\u002FSuspense>\n    \u003C\u002FHashRouter>\n  \u003C\u002FStrictMode>\n)\n",[39,622,623,628,633,638,643,648,652,657,662,667,672,677,682,687,692,697,702,707],{"__ignoreMap":49},[53,624,625],{"class":55,"line":56},[53,626,627],{},"import { StrictMode, Suspense } from 'react'\n",[53,629,630],{"class":55,"line":67},[53,631,632],{},"import { HashRouter, NavLink } from \"react-router-dom\";\n",[53,634,635],{"class":55,"line":75},[53,636,637],{},"import ReactDOM from 'react-dom\u002Fclient'\n",[53,639,640],{"class":55,"line":82},[53,641,642],{},"import Router from '.\u002Froutes'\n",[53,644,645],{"class":55,"line":102},[53,646,647],{},"import '.\u002Findex.css';\n",[53,649,650],{"class":55,"line":118},[53,651,79],{"emptyLinePlaceholder":78},[53,653,654],{"class":55,"line":130},[53,655,656],{},"ReactDOM.createRoot(document.getElementById('root')).render(\n",[53,658,659],{"class":55,"line":153},[53,660,661],{},"  \u003CStrictMode>\n",[53,663,664],{"class":55,"line":273},[53,665,666],{},"    \u003CHashRouter>\n",[53,668,669],{"class":55,"line":293},[53,670,671],{},"      \u003Cnav className=\"px-5 flex items-center h-[60px] bg-indigo-500 text-white\">\n",[53,673,674],{"class":55,"line":312},[53,675,676],{},"        {\u002F* ...trimmed *\u002F}\n",[53,678,679],{"class":55,"line":330},[53,680,681],{},"      \u003C\u002Fnav>\n",[53,683,684],{"class":55,"line":425},[53,685,686],{},"      \u003CSuspense fallback={\u003Cdiv>Loading...\u003C\u002Fdiv>}>\n",[53,688,689],{"class":55,"line":430},[53,690,691],{},"        \u003CRouter \u002F>\n",[53,693,694],{"class":55,"line":436},[53,695,696],{},"      \u003C\u002FSuspense>\n",[53,698,699],{"class":55,"line":442},[53,700,701],{},"    \u003C\u002FHashRouter>\n",[53,703,704],{"class":55,"line":447},[53,705,706],{},"  \u003C\u002FStrictMode>\n",[53,708,709],{"class":55,"line":452},[53,710,711],{},")\n",[17,713,714,715,718,719,721,722,725,726,729,730,732],{},"The ",[39,716,717],{},"fallback"," prop on ",[39,720,585],{}," can take a component, so above I just dropped in a ",[39,723,724],{},"div"," with the text ",[39,727,728],{},"Loading...",". That way, while a component is loading, you'll see ",[39,731,728],{}," instead of waiting on a blank screen.",[17,734,735,736,738],{},"One thing to watch out for: if you don't use ",[39,737,585],{},", you'll get this error message:",[44,740,742],{"className":46,"code":741,"language":48,"meta":49,"style":49},"Uncaught Error: A component suspended while responding to synchronous input. This will cause the UI to be replaced with a loading indicator. To fix, updates that suspend should be wrapped with startTransition.\n",[39,743,744],{"__ignoreMap":49},[53,745,746,749,752,755,758,761,764,767,770,773,776,779,782,785,788,791,793,796,799,802,805,808,811,814,817,820,823,826,829,831,834,836],{"class":55,"line":56},[53,747,748],{"class":85},"Uncaught",[53,750,751],{"class":89}," Error:",[53,753,754],{"class":89}," A",[53,756,757],{"class":89}," component",[53,759,760],{"class":89}," suspended",[53,762,763],{"class":89}," while",[53,765,766],{"class":89}," responding",[53,768,769],{"class":89}," to",[53,771,772],{"class":89}," synchronous",[53,774,775],{"class":89}," input.",[53,777,778],{"class":89}," This",[53,780,781],{"class":89}," will",[53,783,784],{"class":89}," cause",[53,786,787],{"class":89}," the",[53,789,790],{"class":89}," UI",[53,792,769],{"class":89},[53,794,795],{"class":89}," be",[53,797,798],{"class":89}," replaced",[53,800,801],{"class":89}," with",[53,803,804],{"class":89}," a",[53,806,807],{"class":89}," loading",[53,809,810],{"class":89}," indicator.",[53,812,813],{"class":89}," To",[53,815,816],{"class":89}," fix,",[53,818,819],{"class":89}," updates",[53,821,822],{"class":89}," that",[53,824,825],{"class":89}," suspend",[53,827,828],{"class":89}," should",[53,830,795],{"class":89},[53,832,833],{"class":89}," wrapped",[53,835,801],{"class":89},[53,837,838],{"class":89}," startTransition.\n",[17,840,841,842,844],{},"So we have to use ",[39,843,585],{}," to show the loading screen, otherwise the error pops up.",[17,846,847,848,850,851,854],{},"Now, I mentioned ",[39,849,717],{}," can take a component too, so let me show a quick example. First, create ",[39,852,853],{},"components\u002FLoading.js"," to hold a Loading component:",[44,856,858],{"className":360,"code":857,"language":362,"meta":49,"style":49},"\u002F\u002F components\u002FLoading.jsx\nconst Loading = () => {\n  return (\n    \u003Cdiv className=\"flex justify-center items-center h-screen bg-indigo-500\">\n      \u003Cimg src=\"https:\u002F\u002Fi.imgur.com\u002F0HSGxif.gif\" alt=\"\" className=\"w-[150px] h-[150px] \"\u002F>\n    \u003C\u002Fdiv>\n  )\n}\n\nexport default Loading;\n",[39,859,860,865,870,875,880,885,890,895,900,904],{"__ignoreMap":49},[53,861,862],{"class":55,"line":56},[53,863,864],{},"\u002F\u002F components\u002FLoading.jsx\n",[53,866,867],{"class":55,"line":67},[53,868,869],{},"const Loading = () => {\n",[53,871,872],{"class":55,"line":75},[53,873,874],{},"  return (\n",[53,876,877],{"class":55,"line":82},[53,878,879],{},"    \u003Cdiv className=\"flex justify-center items-center h-screen bg-indigo-500\">\n",[53,881,882],{"class":55,"line":102},[53,883,884],{},"      \u003Cimg src=\"https:\u002F\u002Fi.imgur.com\u002F0HS