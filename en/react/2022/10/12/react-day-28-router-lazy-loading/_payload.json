2,164,166,169],{"class":55,"line":153},8,[53,155,156],{"class":85},"dist\u002Fassets\u002Findex.50715e86.js",[53,158,159],{"class":108},"    157.74",[53,161,139],{"class":89},[53,163,142],{"class":89},[53,165,145],{"class":89},[53,167,168],{"class":108}," 51.15",[53,170,127],{"class":89},[17,172,173,174,176],{},"See that ",[39,175,156],{},"? That file is your whole project compiled and bundled into one piece, and it weighs 157.74 KiB. That doesn't look huge right now, but as your project grows, this file grows right along with it. And that causes problems — the most obvious one being that users bounce when a page takes too long to load. That's exactly where Lazy Loading comes to the rescue.",[17,178,179],{},"Once you've applied Lazy Loading, the bundle output ends up looking more like this:",[44,181,183],{"className":46,"code":182,"language":48,"meta":49,"style":49},"> vite-project@0.0.0 build\n> vite build\n\nvite v3.1.4 building for production...\n✓ 40 modules transformed.\ndist\u002Findex.html                    0.44 KiB\ndist\u002Fassets\u002FProducts.6a1dfb49.js   0.14 KiB \u002F gzip: 0.14 KiB\ndist\u002Fassets\u002FApp.2df53b30.js        0.11 KiB \u002F gzip: 0.12 KiB\ndist\u002Fassets\u002FToDoList.1f52c4c4.js   0.13 KiB \u002F gzip: 0.13 KiB\ndist\u002Fassets\u002FAdmin.868445da.js      0.13 KiB \u002F gzip: 0.13 KiB\ndist\u002Fassets\u002Findex.f9c6795a.css     4.70 KiB \u002F gzip: 1.53 KiB\ndist\u002Fassets\u002Findex.df8ef9bc.js      158.30 KiB \u002F gzip: 51.47 KiB\n",[39,184,185,191,197,201,213,224,233,252,271,291,310,328],{"__ignoreMap":49},[53,186,187,189],{"class":55,"line":56},[53,188,60],{"class":59},[53,190,64],{"class":63},[53,192,193,195],{"class":55,"line":67},[53,194,60],{"class":59},[53,196,72],{"class":63},[53,198,199],{"class":55,"line":75},[53,200,79],{"emptyLinePlaceholder":78},[53,202,203,205,207,209,211],{"class":55,"line":82},[53,204,86],{"class":85},[53,206,90],{"class":89},[53,208,93],{"class":89},[53,210,96],{"class":89},[53,212,