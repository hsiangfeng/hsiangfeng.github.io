],{"class":55,"line":273},[53,963,661],{},[53,965,966],{"class":55,"line":293},[53,967,666],{},[53,969,970],{"class":55,"line":312},[53,971,671],{},[53,973,974],{"class":55,"line":330},[53,975,676],{},[53,977,978],{"class":55,"line":425},[53,979,681],{},[53,981,982],{"class":55,"line":430},[53,983,984],{},"      \u003CSuspense fallback={ \u003CLoading\u002F> }>\n",[53,986,987],{"class":55,"line":436},[53,988,691],{},[53,990,991],{"class":55,"line":442},[53,992,696],{},[53,994,995],{"class":55,"line":447},[53,996,701],{},[53,998,999],{"class":55,"line":452},[53,1000,706],{},[53,1002,1003],{"class":55,"line":458},[53,1004,711],{},[17,1006,1007],{},"From now on, any component that's loading for the first time will show the Loading screen, and the second time you load it, the Loading screen won't appear again.",[17,1009,1010],{},"That's it for this post.",[17,1012,1013,1014,1019],{},"The example code is uploaded ",[28,1015,1018],{"href":1016,"rel":1017},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-react-router-link\u002Ftree\u002Ffeature\u002Flazy",[32],"here"," as usual.",[12,1021,1023],{"id":1022},"postscript","Postscript",[17,1025,1026],{},"This article is also published on my blog:",[1028,1029,1030],"ul",{},[1031,1032,1033],"li",{},[28,1034,1037],{"href":1035,"rel":1036},"https:\u002F\u002Fisraynotarray.com\u002F",[32],"Is Ray not Array",[1039,1040,1041],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text