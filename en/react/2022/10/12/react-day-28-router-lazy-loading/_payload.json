[{"data":1,"prerenderedAt":1086},["ShallowReactive",2],{"header-locale:\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F":3,"page:\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F":4,"alt:\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F":3,"prev-next:\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F":1066,"related:\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F":1075},"\u002Freact\u002F20221012\u002F622986263\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1047,"date":1048,"description":1049,"extension":1050,"lang":1051,"meta":1052,"navigation":78,"path":1053,"readingMinutes":1054,"seo":1055,"standalone":1056,"stem":1057,"tags":1058,"tldr":1063,"updated":1048,"url":1064,"__hash__":1065},"content\u002Fen\u002FReact\u002Freact-day-28-router-lazy-loading.md","Why Learn React Eventually? Learn It Now! - React Router Lazy Loading (28)","1003040899",{"type":9,"value":10,"toc":1042},"minimark",[11,16,20,24,35,43,171,177,180,348,351,358,507,514,523,547,580,591,600,618,712,733,739,839,845,855,909,922,1005,1008,1011,1020,1024,1027,1038],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This post is about one of the most important optimizations in React Router: Lazy Loading. Honestly, it's a big deal once you're building real projects. Lazy Loading lets you split your code into separate chunks and only load the matching file when you actually need or request it. So in this post, I'll walk through how Lazy Loading works.",[12,21,23],{"id":22},"lazy-loading","Lazy Loading",[17,25,26,27,34],{},"We'll use this ",[28,29,33],"a",{"href":30,"rel":31},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-react-router-link\u002Ftree\u002Ffeature\u002Froutes",[32],"nofollow","example code"," as our starting point.",[17,36,37,38,42],{},"Once you've dow