1,1433],{"class":40,"line":127},[38,1428,1283],{"class":212},[38,1430,1260],{"class":88},[38,1432,1288],{"class":160},[38,1434,1266],{"class":88},[38,1436,1437,1439,1441,1443],{"class":40,"line":142},[38,1438,1295],{"class":212},[38,1440,1260],{"class":88},[38,1442,1300],{"class":95},[38,1444,1266],{"class":88},[38,1446,1447,1449],{"class":40,"line":149},[38,1448,1307],{"class":212},[38,1450,1310],{"class":88},[38,1452,1453],{"class":40,"line":154},[38,1454,1315],{"class":312},[38,1456,1457],{"class":40,"line":189},[38,1458,364],{"class":88},[38,1460,1461,1463],{"class":40,"line":194},[38,1462,1324],{"class":212},[38,1464,1310],{"class":88},[38,1466,1467,1470,1472,1475],{"class":40,"line":206},[38,1468,1469],{"class":212},"    \"predeploy\"",[38,1471,1260],{"class":88},[38,1473,1474],{"class":95},"\"npm run build\"",[38,1476,1266],{"class":88},[38,1478,1479,1482,1484,1487],{"class":40,"line":219},[38,1480,1481],{"class":212},"    \"deploy\"",[38,1483,1260],{"class":88},[38,1485,1486],{"class":95},"\"gh-pages -d build\"",[38,1488,1266],{"class":88},[38,1490,1491],{"class":40,"line":231},[38,1492,1315],{"class":312},[38,1494,1495],{"class":40,"line":241},[38,1496,364],{"class":88},[38,1498,1499],{"class":40,"line":556},[38,1500,1339],{"class":312},[38,1502,1503],{"class":40,"line":562},[38,1504,374],{"class":88},[17,1506,377,1507,1509,1510,1512,1513,1516],{},[35,1508,1392],{}," script runs automatically before ",[35,1511,1395],{}," when you run the deploy command, so you can put whatever you want to run beforehand in there. In our case we want to run ",[35,1514,1515],{},"npm run build",", so that's what we added.",[17,1518,1519],{},"At this point you're ready to deploy to GitHub Pages.",[17,1521,1522],{},"Run this in the terminal:",[28,1524,1526],{"className":999,"code":1525,"language":1001,"meta":33,"style":33},"npm run deploy\n",[35,1527,1528],{"__ignoreMap":33},[38,1529,1530,1532,1535],{"class":40,"line":41},[38,1531,1366],{"class":319},[38,1533,1534],{"class":95}," run",[38,1536,1537],{"class":95}," deploy\n",[17,1539,1540],{},"And just like that, you've deployed to the repo you set up earlier.",[1223,1542,1544],{"id":1543},"step-four-check-the-deploy-result","Step four: check the deploy result",[17,1546,1547,1548,286,1551,290],{},"So how do you know the deploy succeeded? The first place to look is the branch section. If the deploy worked, you'll see your branches go from one to two: ",[35,1549,1550],{},"main",[35,1552,1553],{},"gh-pages",[17,1555,1556],{},[294,1557],{"alt":1558,"src":1559},"Two branches: main and gh-pages","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Fithelp2022-react\u002F%E6%88%AA%E5%9C%96%202022-09-23%2023.28.09.png",[17,1561,1562],{},"The second place is the Settings tab. Scroll down and you'll find the GitHub Pages section. If the deploy worked, you'll see your GitHub Pages URL there.",[17,1564,1565],{},[294,1566],{"alt":1567,"src":1568},"The GitHub Pages URL shown in repository settings","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Fithelp2022-react\u002F%E6%88%AA%E5%9C%96%202022-09-23%2023.30.20.png",[17,1570,1571,1572,1578],{},"And there you go, your project is deployed to gh-pages. Here's ",[428,1573,1577],{"href":1574,"rel":1575},"https:\u002F\u002Fhsiangfeng.github.io\u002Fexample-react-todolist\u002F",[1576],"nofollow","my example"," if you want to take a look.",[17,1580,1581,1582,1587,1588],{},"Example code repo: ",[428,1583,1586],{"href":1584,"rel":1585},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-react-todolist",[1576],"GitHub","\nExample GitHub Pages: ",[428,1589,1591],{"href":1574,"rel":1590},[1576],"GitHub Pages",[17,1593,1594,1595,1599],{},"Lastly, a quick resource: if you're not super comfortable with Git commands, you can check out my ",[428,1596,1598],{"href":1597},"\u002Fen\u002Fgit\u002F2019\u002F06\u002F15\u002Fbasic-git-commands\u002F","Basic Git Commands"," post, where I've listed out the common ones.",