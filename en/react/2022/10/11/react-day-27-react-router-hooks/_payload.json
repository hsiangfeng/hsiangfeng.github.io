[{"data":1,"prerenderedAt":1044},["ShallowReactive",2],{"header-locale:\u002Fen\u002Freact\u002F2022\u002F10\u002F11\u002Freact-day-27-react-router-hooks\u002F":3,"page:\u002Fen\u002Freact\u002F2022\u002F10\u002F11\u002Freact-day-27-react-router-hooks\u002F":4,"alt:\u002Fen\u002Freact\u002F2022\u002F10\u002F11\u002Freact-day-27-react-router-hooks\u002F":3,"prev-next:\u002Fen\u002Freact\u002F2022\u002F10\u002F11\u002Freact-day-27-react-router-hooks\u002F":1021,"related:\u002Fen\u002Freact\u002F2022\u002F10\u002F11\u002Freact-day-27-react-router-hooks\u002F":1030},"\u002Freact\u002F20221011\u002F3592716318\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1002,"date":1003,"description":1004,"extension":1005,"lang":1006,"meta":1007,"navigation":193,"path":1008,"readingMinutes":1009,"seo":1010,"standalone":1011,"stem":1012,"tags":1013,"tldr":1018,"updated":1003,"url":1019,"__hash__":1020},"content\u002Fen\u002FReact\u002Freact-day-27-react-router-hooks.md","React, Why Not Learn It Now? - The React Router Hooks You'll Actually Use - (27)","1003032980",{"type":9,"value":10,"toc":993},"minimark",[11,16,20,24,27,52,55,58,64,81,170,179,240,256,259,279,299,309,318,354,360,363,374,483,489,638,648,651,654,708,714,722,889,892,965,968,971,975,978,989],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Since we've been building everything around React Hooks throughout this series, it makes sense that React Router hands us a few of its own Hooks too. So in this post let's get familiar with the React Router Hooks you'll run into most often.",[12,21,23],{"id":22},"the-hooks-youll-use-most","The Hooks you'll use most",[17,25,26],{},"Here's a quick list of the React Router Hooks that come up a lot:",[28,29,30,37,42,47],"ul",{},[31,32,33],"li",{},[34,35,36],"code",{},"useLocation",[31,38,39],{},[34,40,41],{},"useParams",[31,43,44],{},[34,45,46],{},"useNavigate",[31,48,49],{},[34,50,51],{},"useRoutes",[17,53,54],{},"I'll write a few small examples below so we can get a feel for each one.",[12,56,36],{"id":57},"uselocation",[17,59,60,61,63],{},"We've actually already used ",[34,62,36],{}," for a couple of things in earlier chapters — but what does it actually do?",[17,65,66,67,70,71,73,74,77,78,80],{},"Here's a ",[34,68,69],{},"\u003CLink>"," example we used before. Notice that ",[34,72,69],{}," has a ",[34,75,76],{},"to"," prop, and that ",[34,79,76],{}," is basically the path and the params we want to navigate to:",[82,83,88],"pre",{"className":84,"code":85,"language":86,"meta":87,"style":87},"language-jsx shiki shiki-themes github-dark-high-contrast","\u003CLink to={{\n    pathname: '\u002Fproducts',\n    search: 'q=ray',\n    hash: '#products',\n  }}\n  state={{\n    products: {\n      id: '1',\n      name: 'QQ 產品'\n    }\n  }}>\n  產品詳細\n\u003C\u002FLink>\n","jsx","",[34,89,90,98,104,110,116,122,128,134,140,146,152,158,164],{"__ignoreMap":87},[91,92,95],"span",{"class":93,"line":94},"line",1,[91,96,97],{},"\u003CLink to={{\n",[91,99,101],{"class":93,"line":100},2,[91,102,103],{},"    pathname: '\u002Fproducts',\n",[91,105,107],{"class":93,"line":106},3,[91,108,109],{},"    search: 'q=ray',\n",[91,111,113],{"class":93,"line":112},4,[91,114,115],{},"    hash: '#products',\n",[91,117,119],{"class":93,"line":118},5,[91,120,121],{},"  }}\n",[91,123,125],{"class":93,"line":124},6,[91,126,127],{},"  state={{\n",[91,129,131],{"class":93,"line":130},7,[91,132,133],{},"    products: {\n",[91,135,137],{"class":93,"line":136},8,[91,138,139],{},"      id: '1',\n",[91,141,143],{"class":93,"line":142},9,[91,144,145],{},"      name: 'QQ 產品'\n",[91,147,149],{"class":93,"line":148},10,[91,150,151],{},"    }\n",[91,153,155],{"class":93,"line":154},11,[91,156,157],{},"  }}>\n",[91,159,161],{"class":93,"line":160},12,[91,162,163],{},"  產品詳細\n",[91,165,167],{"class":93,"line":166},13,[91,168,169],{},"\u003C\u002FLink>\n",[17,171,172,173,175,176,178],{},"When we want to read the params inside that ",[34,174,69],{},", ",[34,177,36],{}," is how we grab that info. Here's a simple example:",[82,180,182],{"className":84,"code":181,"language":86,"meta":87,"style":87},"import { useLocation } from \"react-router\";\n\nconst { hash, key, pathname, search, state } = useLocation();\n  \nuseEffect(() => {\n  console.log('hash:', hash); \u002F\u002F hash: #products\n  console.log('key:', key); \u002F\u002F key: ry5x4mjc\n  console.log('pathname:', pathname); \u002F\u002F pathname: \u002Fproducts\n  console.log('search:', search); \u002F\u002F search: ?q=ray\n  console.log('state:', state); \u002F\u002F state: { products: { id: '1', name: 'QQ 產品' } }\n},[]);\n",[34,183,184,189,195,200,205,210,215,220,225,230,235],{"__ignoreMap":87},[91,185,186],{"class":93,"line":94},[91,187,188],{},"import { useLocation } from \"react-router\";\n",[91,190,191],{"class":93,"line":100},[91,192,194],{"emptyLinePlaceholder":193},true,"\n",[91,196,197],{"class":93,"line":106},[91,198,199],{},"const { hash, key, pathname, search, state } = useLocation();\n",[91,201,202],{"class":93,"line":112},[91,203,204],{},"  \n",[91,206,207],{"class":93,"line":118},[91,208,209],{},"useEffect(() => {\n",[91,211,212],{"class":93,"line":124},[91,213,214],{},"  console.log('hash:', hash); \u002F\u002F hash: #products\n",[91,216,217],{"class":93,"line":130},[91,218,219],{},"  console.log('key:', key); \u002F\u002F key: ry5x4mjc\n",[91,221,222],{"class":93,"line":136},[91,223,224],{},"  console.log('pathname:', pathname); \u002F\u002F pathname: \u002Fproducts\n",[91,226,227],{"class":93,"line":142},[91,228,229],{},"  console.log('search:', search); \u002F\u002F search: ?q=ray\n",[91,231,232],{"class":93,"line":148},[91,233,234],{},"  console.log('state:', state); \u002F\u002F state: { products: { id: '1', name: 'QQ 產品' } }\n",[91,236,237],{"class":93,"line":154},[91,238,239],{},"},[]);\n",[17,241,242,243,245,246,249,250,252,253,255],{},"And if you swap ",[34,244,69],{}," out for ",[34,247,248],{},"\u003CNavLink>",", this still works fine — because ",[34,251,248],{}," also uses ",[34,254,36],{}," under the hood to get the same info.",[12,257,41],{"id":258},"useparams",[17,260,261,263,264,267,268,271,272,274,275,278],{},[34,262,41],{}," is hands down the React Router Hook you'll use the most in real projects. So where does it come in? Picture a common scenario: you've got a page that shows the details of a product, and its path looks like ",[34,265,266],{},"\u002Fproducts\u002F:id",", where ",[34,269,270],{},":id"," is the param we want to read. That's exactly what ",[34,273,41],{}," is for. The ",[34,276,277],{},"Route"," would look like this:",[82,280,282],{"className":84,"code":281,"language":86,"meta":87,"style":87},"\u003CRoute path=\"\u002Fproducts\" element={ \u003CProducts \u002F> } >\n  \u003CRoute path=\":id\" element={ \u003CProduct \u002F> } \u002F>\n\u003C\u002FRoute>\n",[34,283,284,289,294],{"__ignoreMap":87},[91,285,286],{"class":93,"line":94},[91,287,288],{},"\u003CRoute path=\"\u002Fproducts\" element={ \u003CProducts \u002F> } >\n",[91,290,291],{"class":93,"line":100},[91,292,293],{},"  \u003CRoute path=\":id\" element={ \u003CProduct \u002F> } \u002F>\n",[91,295,296],{"class":93,"line":106},[91,297,298],{},"\u003C\u002FRoute>\n",[17,300,301,302,305,306,308],{},"So why use a dynamic route here? Because there's no way you're writing a separate path for every single product. A dynamic route lets us read the product's ",[34,303,304],{},"id"," instead. There's another nice perk too: when you want to share a product with someone, you can just drop the product's ",[34,307,304],{}," straight into the URL and they'll land right on that product's detail page.",[17,310,311,312,314,315,317],{},"And to read the ",[34,313,270],{}," from that dynamic route, you absolutely need ",[34,316,41],{},":",[82,319,321],{"className":84,"code":320,"language":86,"meta":87,"style":87},"import { useParams } from \"react-router\";\n\nconst { id } = useParams();\n  \nuseEffect(() => {\n  console.log('params id:', id); \u002F\u002F params id: 123\n},[]);\n",[34,322,323,328,332,337,341,345,350],{"__ignoreMap":87},[91,324,325],{"class":93,"line":94},[91,326,327],{},"import { useParams } from \"react-router\";\n",[91,329,330],{"class":93,"line":100},[91,331,194],{"emptyLinePlaceholder":193},[91,333,334],{"class":93,"line":106},[91,335,336],{},"const { id } = useParams();\n",[91,338,339],{"class":93,"line":112},[91,340,204],{},[91,342,343],{"class":93,"line":118},[91,344,209],{},[91,346,347],{"class":93,"line":124},[91,348,349],{},"  console.log('params id:', id); \u002F\u002F params id: 123\n",[91,351,352],{"class":93,"line":130},[91,353,239],{},[17,355,356,357,359],{},"With ",[34,358,41],{}," we can grab the dynamic route's ID without any hassle.",[12,361,46],{"id":362},"usenavigate",[17,364,365,367,368,370,371,317],{},[34,366,46],{}," is mainly for redirecting. For example, when you click a button you can use ",[34,369,46],{}," to send the user off to another page. The example below redirects to ",[34,372,373],{},"\u002Fproducts\u002F123",[82,375,377],{"className":84,"code":376,"language":86,"meta":87,"style":87},"import { useNavigate } from \"react-router\";\n\nconst Products = () => {\n  const navigate = useNavigate();\n\n  return (\n    \u003C>\n      \u003Ch1>Products\u003C\u002Fh1>\n      \u003Cbutton\n        className=\"border-1 bg-indigo-500 p-3 text-white\"\n        onClick={ () => navigate('\u002Fproducts\u002F123')}\n      >\n        點我跳轉\n      \u003C\u002Fbutton>\n      \u003COutlet \u002F>\n    \u003C\u002F>\n  )\n}\n\nexport default Products;\n",[34,378,379,384,388,393,398,402,407,412,417,422,427,432,437,442,448,454,460,466,472,477],{"__ignoreMap":87},[91,380,381],{"class":93,"line":94},[91,382,383],{},"import { useNavigate } from \"react-router\";\n",[91,385,386],{"class":93,"line":100},[91,387,194],{"emptyLinePlaceholder":193},[91,389,390],{"class":93,"line":106},[91,391,392],{},"const Products = () => {\n",[91,394,395],{"class":93,"line":112},[91,396,397],{},"  const navigate = useNavigate();\n",[91,399,400],{"class":93,"line":118},[91,401,194],{"emptyLinePlaceholder":193},[91,403,404],{"class":93,"line":124},[91,405,406],{},"  return (\n",[91,408,409],{"class":93,"line":130},[91,410,411],{},"    \u003C>\n",[91,413,414],{"class":93,"line":136},[91,415,416],{},"      \u003Ch1>Products\u003C\u002Fh1>\n",[91,418,419],{"class":93,"line":142},[91,420,421],{},"      \u003Cbutton\n",[91,423,424],{"class":93,"line":148},[91,425,426],{},"        className=\"border-1 bg-indigo-500 p-3 text-white\"\n",[91,428,429],{"class":93,"line":154},[91,430,431],{},"        onClick={ () => navigate('\u002Fproducts\u002F123')}\n",[91,433,434],{"class":93,"line":160},[91,435,436],{},"      >\n",[91,438,439],{"class":93,"line":166},[91,440,441],{},"        點我跳轉\n",[91,443,445],{"class":93,"line":444},14,[91,446,447],{},"      \u003C\u002Fbutton>\n",[91,449,451],{"class":93,"line":450},15,[91,452,453],{},"      \u003COutlet \u002F>\n",[91,455,457],{"class":93,"line":456},16,[91,458,459],{},"    \u003C\u002F>\n",[91,461,463],{"class":93,"line":462},17,[91,464,465],{},"  )\n",[91,467,469],{"class":93,"line":468},18,[91,470,471],{},"}\n",[91,473,475],{"class":93,"line":474},19,[91,476,194],{"emptyLinePlaceholder":193},[91,478,480],{"class":93,"line":479},20,[91,481,482],{},"export default Products;\n",[17,484,485,486,488],{},"You can also use ",[34,487,46],{}," to go back and forward, like a browser's back\u002Fforward buttons:",[82,490,492],{"className":84,"code":491,"language":86,"meta":87,"style":87},"import { useNavigate } from \"react-router\";\n\nconst Products = () => {\n  const navigate = useNavigate();\n\n  return (\n    \u003C>\n      \u003Ch1>Products\u003C\u002Fh1>\n      \u003Cbutton\n        className=\"border-1 bg-indigo-500 p-3 text-white\"\n        onClick={ () => navigate('\u002Fproducts\u002F123')}\n      >\n        點我跳轉\n      \u003C\u002Fbutton>\n      \u003Cbutton\n        className=\"border-1 bg-indigo-500 p-3 text-white\"\n        onClick={ () => navigate(-1) }\n      >\n        前一頁\n      \u003C\u002Fbutton>\n      \u003Cbutton\n        className=\"border-1 bg-indigo-500 p-3 text-white\"\n        onClick={ () => navigate(1) }\n      >\n        後一頁\n      \u003C\u002Fbutton>\n      \u003COutlet \u002F>\n    \u003C\u002F>\n  )\n}\n\nexport default Products;\n",[34,493,494,498,502,506,510,514,518,522,526,530,534,538,542,546,550,554,558,563,567,572,576,581,586,592,597,603,608,613,618,623,628,633],{"__ignoreMap":87},[91,495,496],{"class":93,"line":94},[91,497,383],{},[91,499,500],{"class":93,"line":100},[91,501,194],{"emptyLinePlaceholder":193},[91,503,504],{"class":93,"line":106},[91,505,392],{},[91,507,508],{"class":93,"line":112},[91,509,397],{},[91,511,512],{"class":93,"line":118},[91,513,194],{"emptyLinePlaceholder":193},[91,515,516],{"class":93,"line":124},[91,517,406],{},[91,519,520],{"class":93,"line":130},[91,521,411],{},[91,523,524],{"class":93,"line":136},[91,525,416],{},[91,527,528],{"class":93,"line":142},[91,529,421],{},[91,531,532],{"class":93,"line":148},[91,533,426],{},[91,535,536],{"class":93,"line":154},[91,537,431],{},[91,539,540],{"class":93,"line":160},[91,541,436],{},[91,543,544],{"class":93,"line":166},[91,545,441],{},[91,547,548],{"class":93,"line":444},[91,549,447],{},[91,551,552],{"class":93,"line":450},[91,553,421],{},[91,555,556],{"class":93,"line":456},[91,557,426],{},[91,559,560],{"class":93,"line":462},[91,561,562],{},"        onClick={ () => navigate(-1) }\n",[91,564,565],{"class":93,"line":468},[91,566,436],{},[91,568,569],{"class":93,"line":474},[91,570,571],{},"        前一頁\n",[91,573,574],{"class":93,"line":479},[91,575,447],{},[91,577,579],{"class":93,"line":578},21,[91,580,421],{},[91,582,584],{"class":93,"line":583},22,[91,585,426],{},[91,587,589],{"class":93,"line":588},23,[91,590,591],{},"        onClick={ () => navigate(1) }\n",[91,593,595],{"class":93,"line":594},24,[91,596,436],{},[91,598,600],{"class":93,"line":599},25,[91,601,602],{},"        後一頁\n",[91,604,606],{"class":93,"line":605},26,[91,607,447],{},[91,609,611],{"class":93,"line":610},27,[91,612,453],{},[91,614,616],{"class":93,"line":615},28,[91,617,459],{},[91,619,621],{"class":93,"line":620},29,[91,622,465],{},[91,624,626],{"class":93,"line":625},30,[91,627,471],{},[91,629,631],{"class":93,"line":630},31,[91,632,194],{"emptyLinePlaceholder":193},[91,634,636],{"class":93,"line":635},32,[91,637,482],{},[17,639,640,641,175,644,647],{},"And it works just fine if you pass strings too: ",[34,642,643],{},"() => navigate('1')",[34,645,646],{},"() => navigate('-1')",".",[12,649,51],{"id":650},"useroutes",[17,652,653],{},"Remember how we set up React Router earlier? No worries if not — here's the example again:",[82,655,657],{"className":84,"code":656,"language":86,"meta":87,"style":87},"\u003CHashRouter>\n  \u003CRoutes>\n    \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } >\n      \u003CRoute path=\"todolist\" element={ \u003CToDoList \u002F> } \u002F>\n    \u003C\u002FRoute>\n    \u003CRoute path=\"\u002Fadmin\" element={ \u003CAdmin \u002F> } >\n      \u003CRoute path=\"products\" element={ \u003CAdminProducts \u002F> } \u002F>\n    \u003C\u002FRoute>\n  \u003C\u002FRoutes>\n\u003C\u002FHashRouter>\n",[34,658,659,664,669,674,679,684,689,694,698,703],{"__ignoreMap":87},[91,660,661],{"class":93,"line":94},[91,662,663],{},"\u003CHashRouter>\n",[91,665,666],{"class":93,"line":100},[91,667,668],{},"  \u003CRoutes>\n",[91,670,671],{"class":93,"line":106},[91,672,673],{},"    \u003CRoute path=\"\u002F\" element={ \u003CApp \u002F> } >\n",[91,675,676],{"class":93,"line":112},[91,677,678],{},"      \u003CRoute path=\"todolist\" element={ \u003CToDoList \u002F> } \u002F>\n",[91,680,681],{"class":93,"line":118},[91,682,683],{},"    \u003C\u002FRoute>\n",[91,685,686],{"class":93,"line":124},[91,687,688],{},"    \u003CRoute path=\"\u002Fadmin\" element={ \u003CAdmin \u002F> } >\n",[91,690,691],{"class":93,"line":130},[91,692,693],{},"      \u003CRoute path=\"products\" element={ \u003CAdminProducts \u002F> } \u002F>\n",[91,695,696],{"class":93,"line":136},[91,697,683],{},[91,699,700],{"class":93,"line":142},[91,701,702],{},"  \u003C\u002FRoutes>\n",[91,704,705],{"class":93,"line":148},[91,706,707],{},"\u003C\u002FHashRouter>\n",[17,709,710,711,713],{},"I get that some people aren't crazy about this style, since it has a bit of nesting going on. And in real projects you'll have plenty of nesting — once it gets too deep, it turns into a maintenance headache. So if this style isn't your thing, you can wrap it all up with ",[34,712,51],{}," instead.",[17,715,716,717,719,720,317],{},"So how do you use ",[34,718,51],{},"? First, create a dedicated file to manage your router. The overall structure is going to feel about 87% identical to using Vue Router, so let me rewrite the example above with ",[34,721,51],{},[82,723,725],{"className":84,"code":724,"language":86,"meta":87,"style":87},"\u002F\u002F router\u002Findex.js\nimport { useRoutes } from 'react-router-dom';\n\nimport App from '..\u002FApp';\nimport ToDoList from \"..\u002FTodoList\";\n\nimport Admin from \"..\u002Fadmin\u002FIndex\";\nimport AdminProducts from \"..\u002Fadmin\u002FProducts\";\n\n\nconst routes = [\n  {\n    path: '\u002F',\n    element: \u003CApp \u002F>,\n    children: [\n      {\n        path: '\u002FtodoList',\n        element: \u003CToDoList \u002F>,\n      },\n    ],\n  },\n  {\n    path: '\u002Fadmin',\n    element: \u003CAdmin \u002F>,\n    children: [\n      {\n        path: 'products',\n        element: \u003CAdminProducts \u002F>,\n      },\n    ],\n  }\n];\n\nexport default () => useRoutes(routes);\n",[34,726,727,732,737,741,746,751,755,760,765,769,773,778,783,788,793,798,803,808,813,818,823,828,832,837,842,846,850,855,860,864,868,873,878,883],{"__ignoreMap":87},[91,728,729],{"class":93,"line":94},[91,730,731],{},"\u002F\u002F router\u002Findex.js\n",[91,733,734],{"class":93,"line":100},[91,735,736],{},"import { useRoutes } from 'react-router-dom';\n",[91,738,739],{"class":93,"line":106},[91,740,194],{"emptyLinePlaceholder":193},[91,742,743],{"class":93,"line":112},[91,744,745],{},"import App from '..\u002FApp';\n",[91,747,748],{"class":93,"line":118},[91,749,750],{},"import ToDoList from \"..\u002FTodoList\";\n",[91,752,753],{"class":93,"line":124},[91,754,194],{"emptyLinePlaceholder":193},[91,756,757],{"class":93,"line":130},[91,758,759],{},"import Admin from \"..\u002Fadmin\u002FIndex\";\n",[91,761,762],{"class":93,"line":136},[91,763,764],{},"import AdminProducts from \"..\u002Fadmin\u002FProducts\";\n",[91,766,767],{"class":93,"line":142},[91,768,194],{"emptyLinePlaceholder":193},[91,770,771],{"class":93,"line":148},[91,772,194],{"emptyLinePlaceholder":193},[91,774,775],{"class":93,"line":154},[91,776,777],{},"const routes = [\n",[91,779,780],{"class":93,"line":160},[91,781,782],{},"  {\n",[91,784,785],{"class":93,"line":166},[91,786,787],{},"    path: '\u002F',\n",[91,789,790],{"class":93,"line":444},[91,791,792],{},"    element: \u003CApp \u002F>,\n",[91,794,795],{"class":93,"line":450},[91,796,797],{},"    children: [\n",[91,799,800],{"class":93,"line":456},[91,801,802],{},"      {\n",[91,804,805],{"class":93,"line":462},[91,806,807],{},"        path: '\u002FtodoList',\n",[91,809,810],{"class":93,"line":468},[91,811,812],{},"        element: \u003CToDoList \u002F>,\n",[91,814,815],{"class":93,"line":474},[91,816,817],{},"      },\n",[91,819,820],{"class":93,"line":479},[91,821,822],{},"    ],\n",[91,824,825],{"class":93,"line":578},[91,826,827],{},"  },\n",[91,829,830],{"class":93,"line":583},[91,831,782],{},[91,833,834],{"class":93,"line":588},[91,835,836],{},"    path: '\u002Fadmin',\n",[91,838,839],{"class":93,"line":594},[91,840,841],{},"    element: \u003CAdmin \u002F>,\n",[91,843,844],{"class":93,"line":599},[91,845,797],{},[91,847,848],{"class":93,"line":605},[91,849,802],{},[91,851,852],{"class":93,"line":610},[91,853,854],{},"        path: 'products',\n",[91,856,857],{"class":93,"line":615},[91,858,859],{},"        element: \u003CAdminProducts \u002F>,\n",[91,861,862],{"class":93,"line":620},[91,863,817],{},[91,865,866],{"class":93,"line":625},[91,867,822],{},[91,869,870],{"class":93,"line":630},[91,871,872],{},"  }\n",[91,874,875],{"class":93,"line":635},[91,876,877],{},"];\n",[91,879,881],{"class":93,"line":880},33,[91,882,194],{"emptyLinePlaceholder":193},[91,884,886],{"class":93,"line":885},34,[91,887,888],{},"export default () => useRoutes(routes);\n",[17,890,891],{},"Then head back to main.jsx and change it to this:",[82,893,895],{"className":84,"code":894,"language":86,"meta":87,"style":87},"import React from 'react'\nimport { HashRouter, Route, Routes, Link } from \"react-router-dom\";\nimport ReactDOM from 'react-dom\u002Fclient'\nimport '.\u002Findex.css'\n\nimport Router from '.\u002Frouter';\n\nReactDOM.createRoot(document.getElementById('root')).render(\n  \u003CReact.StrictMode>\n    \u003CHashRouter>\n      \u003CRouter \u002F>\n    \u003C\u002FHashRouter>\n  \u003C\u002FReact.StrictMode>\n)\n",[34,896,897,902,907,912,917,921,926,930,935,940,945,950,955,960],{"__ignoreMap":87},[91,898,899],{"class":93,"line":94},[91,900,901],{},"import React from 'react'\n",[91,903,904],{"class":93,"line":100},[91,905,906],{},"import { HashRouter, Route, Routes, Link } from \"react-router-dom\";\n",[91,908,909],{"class":93,"line":106},[91,910,911],{},"import ReactDOM from 'react-dom\u002Fclient'\n",[91,913,914],{"class":93,"line":112},[91,915,916],{},"import '.\u002Findex.css'\n",[91,918,919],{"class":93,"line":118},[91,920,194],{"emptyLinePlaceholder":193},[91,922,923],{"class":93,"line":124},[91,924,925],{},"import Router from '.\u002Frouter';\n",[91,927,928],{"class":93,"line":130},[91,929,194],{"emptyLinePlaceholder":193},[91,931,932],{"class":93,"line":136},[91,933,934],{},"ReactDOM.createRoot(document.getElementById('root')).render(\n",[91,936,937],{"class":93,"line":142},[91,938,939],{},"  \u003CReact.StrictMode>\n",[91,941,942],{"class":93,"line":148},[91,943,944],{},"    \u003CHashRouter>\n",[91,946,947],{"class":93,"line":154},[91,948,949],{},"      \u003CRouter \u002F>\n",[91,951,952],{"class":93,"line":160},[91,953,954],{},"    \u003C\u002FHashRouter>\n",[91,956,957],{"class":93,"line":166},[91,958,959],{},"  \u003C\u002FReact.StrictMode>\n",[91,961,962],{"class":93,"line":444},[91,963,964],{},")\n",[17,966,967],{},"The screen ends up exactly the same as before, but the code is cleaner — and it looks a whole lot like how you'd write Vue Router.",[17,969,970],{},"That's about it for this post. I'm not going to ship a full example this time, so try implementing it yourself and see how it goes.",[12,972,974],{"id":973},"afterword","Afterword",[17,976,977],{},"This post is also published on my blog:",[28,979,980],{},[31,981,982],{},[983,984,988],"a",{"href":985,"rel":986},"https:\u002F\u002Fisraynotarray.com\u002F",[987],"nofollow","Is Ray Not Array",[990,991,992],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":87,"searchDepth":100,"depth":100,"links":994},[995,996,997,998,999,1000,1001],{"id":14,"depth":100,"text":15},{"id":22,"depth":100,"text":23},{"id":57,"depth":100,"text":36},{"id":258,"depth":100,"text":41},{"id":362,"depth":100,"text":46},{"id":650,"depth":100,"text":51},{"id":973,"depth":100,"text":974},"React","2022-10-11 00:00:01","Since we've been doing everything the Hook way in this series, it makes sense that React Router ships its own set of Hooks too. In this post I'll walk through the ones you'll bump into most often — useLocation, useParams, useNavigate, and useRoutes — with small examples for each so you know what they do and when to reach for them.","md","en",{},"\u002Fen\u002Freact\u002Freact-day-27-react-router-hooks","4",{"title":6,"description":1004},false,"en\u002FReact\u002Freact-day-27-react-router-hooks",[1014,1015,1016,1017,51,46,36,41],"React, Why Not Learn It Now?","React Basics","React Router","React Router Hook",null,"\u002Fen\u002Freact\u002F2022\u002F10\u002F11\u002Freact-day-27-react-router-hooks\u002F","hTMFirUTnjwCHkCOBufa3voGXBsmKX6Y_F1o-QUk95M",{"newer":1022,"older":1026},{"url":1023,"title":1024,"date":1025},"\u002Fen\u002Fmisc\u002F2022\u002F10\u002F11\u002Fwrite-clean-code-without-reading-clean-code\u002F","You Don't Have to Read Clean Code to Write Decent Code","2022-10-11 10:26:32",{"url":1027,"title":1028,"date":1029},"\u002Fen\u002Freact\u002F2022\u002F10\u002F10\u002Flearn-react-now-26-react-router-link-navlink\u002F","You'll Learn React Eventually, So Why Not Now? - React Router - Link and NavLink - (26)","2022-10-10 00:00:01",[1031,1035,1040],{"url":1032,"title":1033,"date":1034,"readingMinutes":1009},"\u002Fen\u002Freact\u002F2022\u002F10\u002F14\u002Flearn-react-now-30-wrap-up-and-toc\u002F","Learn React Now — Wrap-up Notes & Full Table of Contents (30)","2022-10-14 00:00:01",{"url":1036,"title":1037,"date":1038,"readingMinutes":1039},"\u002Fen\u002Freact\u002F2022\u002F10\u002F13\u002Flearn-react-29-react-redux-quick-start\u002F","Learn React Eventually, So Why Not Now? - React Redux: Redux and a Quick Start - (29)","2022-10-13 00:00:01","6",{"url":1041,"title":1042,"date":1043,"readingMinutes":1009},"\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F","Why Learn React Eventually? Learn It Now! - React Router Lazy Loading (28)","2022-10-12 00:00:01",1784020375473]