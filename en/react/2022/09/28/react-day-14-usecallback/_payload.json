[{"data":1,"prerenderedAt":888},["ShallowReactive",2],{"header-locale:\u002Fen\u002Freact\u002F2022\u002F09\u002F28\u002Freact-day-14-usecallback\u002F":3,"page:\u002Fen\u002Freact\u002F2022\u002F09\u002F28\u002Freact-day-14-usecallback\u002F":4,"alt:\u002Fen\u002Freact\u002F2022\u002F09\u002F28\u002Freact-day-14-usecallback\u002F":3,"prev-next:\u002Fen\u002Freact\u002F2022\u002F09\u002F28\u002Freact-day-14-usecallback\u002F":865,"related:\u002Fen\u002Freact\u002F2022\u002F09\u002F28\u002Freact-day-14-usecallback\u002F":874},"\u002Freact\u002F20220928\u002F3362055744\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":848,"date":849,"description":850,"extension":851,"lang":852,"meta":853,"navigation":189,"path":854,"readingMinutes":855,"seo":856,"standalone":857,"stem":858,"tags":859,"tldr":862,"updated":849,"url":863,"__hash__":864},"content\u002Fen\u002FReact\u002Freact-day-14-usecallback.md","React Day 14 — useCallback, or How I Stopped an Infinite setTimeout Loop","1002922114",{"type":9,"value":10,"toc":843},"minimark",[11,16,28,31,49,52,80,83,106,114,117,125,243,254,270,276,382,387,402,405,542,547,553,556,609,620,658,661,667,790,810,815,821,825,828,839],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24,25,27],"p",{},"This one's a short and easy chapter. We're just going to quickly get to know ",[21,22,23],"code",{},"useCallback",". So what is ",[21,26,23],{},"? Let's keep reading and find out.",[12,29,23],{"id":30},"usecallback",[17,32,33,35,36,39,40,42,43,45,46,48],{},[21,34,23],{}," is actually really similar to ",[21,37,38],{},"useMemo"," from the previous post. Honestly, you could call it a variation of ",[21,41,38],{}," and you wouldn't be wrong. But... that's pretty vague, right? So what's the actual difference between ",[21,44,38],{}," and ",[21,47,23],{},"?",[17,50,51],{},"In short, both of these Hooks exist to optimize React rendering performance. They just focus on different things:",[53,54,55,69],"ul",{},[56,57,58,60],"li",{},[21,59,38],{},[53,61,62],{},[56,63,64,65],{},"returns a memoized ",[66,67,68],"strong",{},"value",[56,70,71,73],{},[21,72,23],{},[53,74,75],{},[56,76,64,77],{},[66,78,79],{},"function",[17,81,82],{},"What does \"memoized\" even mean here? The word \"memoize\" kind of sounds scary, so you can also think of it as \"caching\" or \"stashing\" something away. With that in mind, let's tweak the list above a bit:",[53,84,85,96],{},[56,86,87,89],{},[21,88,38],{},[53,90,91],{},[56,92,93,94],{},"returns a memoized \u002F cached \u002F stashed ",[66,95,68],{},[56,97,98,100],{},[21,99,23],{},[53,101,102],{},[56,103,93,104],{},[66,105,79],{},[17,107,108,109,45,111,113],{},"So how do ",[21,110,38],{},[21,112,23],{}," actually differ? Let's look at an example.",[17,115,116],{},"One quick heads-up: the code below is purely for demonstration. You wouldn't actually write it this way in real projects.",[17,118,119,120,45,122,124],{},"Both ",[21,121,38],{},[21,123,23],{}," take a function and an array, and both are expressions:",[126,127,132],"pre",{"className":128,"code":129,"language":130,"meta":131,"style":131},"language-jsx shiki shiki-themes github-dark-high-contrast","const App = () => {\n  const exampleMemo = React.useMemo(() => 1 + 1, []);\n  const exampleCallback = React.useCallback(() => 1 + 1, []);\n  \n  React.useEffect(() => {\n    console.log('useMemo', exampleMemo);\n    console.log('useCallback', exampleCallback);\n  })\n\n\n  return (\n    \u003Cdiv>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n","jsx","",[21,133,134,142,148,154,160,166,172,178,184,191,196,202,208,214,220,226,231,237],{"__ignoreMap":131},[135,136,139],"span",{"class":137,"line":138},"line",1,[135,140,141],{},"const App = () => {\n",[135,143,145],{"class":137,"line":144},2,[135,146,147],{},"  const exampleMemo = React.useMemo(() => 1 + 1, []);\n",[135,149,151],{"class":137,"line":150},3,[135,152,153],{},"  const exampleCallback = React.useCallback(() => 1 + 1, []);\n",[135,155,157],{"class":137,"line":156},4,[135,158,159],{},"  \n",[135,161,163],{"class":137,"line":162},5,[135,164,165],{},"  React.useEffect(() => {\n",[135,167,169],{"class":137,"line":168},6,[135,170,171],{},"    console.log('useMemo', exampleMemo);\n",[135,173,175],{"class":137,"line":174},7,[135,176,177],{},"    console.log('useCallback', exampleCallback);\n",[135,179,181],{"class":137,"line":180},8,[135,182,183],{},"  })\n",[135,185,187],{"class":137,"line":186},9,[135,188,190],{"emptyLinePlaceholder":189},true,"\n",[135,192,194],{"class":137,"line":193},10,[135,195,190],{"emptyLinePlaceholder":189},[135,197,199],{"class":137,"line":198},11,[135,200,201],{},"  return (\n",[135,203,205],{"class":137,"line":204},12,[135,206,207],{},"    \u003Cdiv>\n",[135,209,211],{"class":137,"line":210},13,[135,212,213],{},"    \u003C\u002Fdiv>\n",[135,215,217],{"class":137,"line":216},14,[135,218,219],{},"  )\n",[135,221,223],{"class":137,"line":222},15,[135,224,225],{},"}\n",[135,227,229],{"class":137,"line":228},16,[135,230,190],{"emptyLinePlaceholder":189},[135,232,234],{"class":137,"line":233},17,[135,235,236],{},"const root = ReactDOM.createRoot(document.querySelector('#root'));\n",[135,238,240],{"class":137,"line":239},18,[135,241,242],{},"root.render(\u003CApp \u002F>);\n",[244,245,253],"iframe",{"height":246,"style":247,"scrolling":248,"title":249,"src":250,"frameBorder":248,"loading":251,"allowTransparency":252,"allowFullScreen":252},300,"width: 100%;","no","(111) React useMemo Sort","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FVwxKqRZ?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FVwxKqRZ\">\n  (111) React useMemo Sort\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,255,256,257,45,260,263,264,266,267,269],{},"But in terms of the result, the two output different things — ",[21,258,259],{},"2",[21,261,262],{},"() => 1 + 1"," respectively. Just like I said earlier: ",[21,265,38],{}," returns a memoized value, while ",[21,268,23],{}," returns a memoized function.",[17,271,272,273,275],{},"So now the question becomes: where does ",[21,274,23],{}," actually show up most often? Let's start with a simple example.",[126,277,279],{"className":128,"code":278,"language":130,"meta":131,"style":131},"const App = () => {\n  const [count, setCount] = React.useState(0);\n  \n  const getData = () => {\n    setTimeout(() => {\n       setCount((pre) => pre + 1)\n    }, 2000);\n  }\n\n  React.useEffect(() => {\n    getData()\n  }, []);\n\n  return (\n    \u003Cdiv>\n      { count }\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,280,281,285,290,294,299,304,309,314,319,323,327,332,337,341,345,349,354,358,362,367,372,377],{"__ignoreMap":131},[135,282,283],{"class":137,"line":138},[135,284,141],{},[135,286,287],{"class":137,"line":144},[135,288,289],{},"  const [count, setCount] = React.useState(0);\n",[135,291,292],{"class":137,"line":150},[135,293,159],{},[135,295,296],{"class":137,"line":156},[135,297,298],{},"  const getData = () => {\n",[135,300,301],{"class":137,"line":162},[135,302,303],{},"    setTimeout(() => {\n",[135,305,306],{"class":137,"line":168},[135,307,308],{},"       setCount((pre) => pre + 1)\n",[135,310,311],{"class":137,"line":174},[135,312,313],{},"    }, 2000);\n",[135,315,316],{"class":137,"line":180},[135,317,318],{},"  }\n",[135,320,321],{"class":137,"line":186},[135,322,190],{"emptyLinePlaceholder":189},[135,324,325],{"class":137,"line":193},[135,326,165],{},[135,328,329],{"class":137,"line":198},[135,330,331],{},"    getData()\n",[135,333,334],{"class":137,"line":204},[135,335,336],{},"  }, []);\n",[135,338,339],{"class":137,"line":210},[135,340,190],{"emptyLinePlaceholder":189},[135,342,343],{"class":137,"line":216},[135,344,201],{},[135,346,347],{"class":137,"line":222},[135,348,207],{},[135,350,351],{"class":137,"line":228},[135,352,353],{},"      { count }\n",[135,355,356],{"class":137,"line":233},[135,357,213],{},[135,359,360],{"class":137,"line":239},[135,361,219],{},[135,363,365],{"class":137,"line":364},19,[135,366,225],{},[135,368,370],{"class":137,"line":369},20,[135,371,190],{"emptyLinePlaceholder":189},[135,373,375],{"class":137,"line":374},21,[135,376,236],{},[135,378,380],{"class":137,"line":379},22,[135,381,242],{},[244,383,386],{"height":246,"style":247,"scrolling":248,"title":384,"src":385,"frameBorder":248,"loading":251,"allowTransparency":252,"allowFullScreen":252},"(112) React useMemo useCallback","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FbGMwZaJ?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FbGMwZaJ\">\n  (112) React useMemo useCallback\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,388,389,390,393,394,397,398,401],{},"In the example above, we use ",[21,391,392],{},"setTimeout"," to fake an AJAX call. After about two seconds it bumps ",[21,395,396],{},"count"," up by ",[21,399,400],{},"1",", and the screen updates accordingly. There's basically nothing wrong here, and it only runs once.",[17,403,404],{},"But now let's tweak things a little and pull part of it out into its own component:",[126,406,408],{"className":128,"code":407,"language":130,"meta":131,"style":131},"const Child = ({ count, getData }) => {\n  React.useEffect(() => {\n    getData()\n  }, [ getData ]);\n\n  return (\n    \u003Cdiv>\n      {count}\n    \u003C\u002Fdiv>\n  )\n}\n\nconst App = () => {\n  const [count, setCount] = React.useState(0);\n  \n  const getData = () => {\n    setTimeout(() => {\n       setCount((pre) => pre + 1)\n    }, 2000);\n  }\n\n  return (\n    \u003Cdiv>\n      \u003CChild count={count} getData={getData} \u002F>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,409,410,415,419,423,428,432,436,440,445,449,453,457,461,465,469,473,477,481,485,489,493,497,501,506,512,517,522,527,532,537],{"__ignoreMap":131},[135,411,412],{"class":137,"line":138},[135,413,414],{},"const Child = ({ count, getData }) => {\n",[135,416,417],{"class":137,"line":144},[135,418,165],{},[135,420,421],{"class":137,"line":150},[135,422,331],{},[135,424,425],{"class":137,"line":156},[135,426,427],{},"  }, [ getData ]);\n",[135,429,430],{"class":137,"line":162},[135,431,190],{"emptyLinePlaceholder":189},[135,433,434],{"class":137,"line":168},[135,435,201],{},[135,437,438],{"class":137,"line":174},[135,439,207],{},[135,441,442],{"class":137,"line":180},[135,443,444],{},"      {count}\n",[135,446,447],{"class":137,"line":186},[135,448,213],{},[135,450,451],{"class":137,"line":193},[135,452,219],{},[135,454,455],{"class":137,"line":198},[135,456,225],{},[135,458,459],{"class":137,"line":204},[135,460,190],{"emptyLinePlaceholder":189},[135,462,463],{"class":137,"line":210},[135,464,141],{},[135,466,467],{"class":137,"line":216},[135,468,289],{},[135,470,471],{"class":137,"line":222},[135,472,159],{},[135,474,475],{"class":137,"line":228},[135,476,298],{},[135,478,479],{"class":137,"line":233},[135,480,303],{},[135,482,483],{"class":137,"line":239},[135,484,308],{},[135,486,487],{"class":137,"line":364},[135,488,313],{},[135,490,491],{"class":137,"line":369},[135,492,318],{},[135,494,495],{"class":137,"line":374},[135,496,190],{"emptyLinePlaceholder":189},[135,498,499],{"class":137,"line":379},[135,500,201],{},[135,502,504],{"class":137,"line":503},23,[135,505,207],{},[135,507,509],{"class":137,"line":508},24,[135,510,511],{},"      \u003CChild count={count} getData={getData} \u002F>\n",[135,513,515],{"class":137,"line":514},25,[135,516,213],{},[135,518,520],{"class":137,"line":519},26,[135,521,219],{},[135,523,525],{"class":137,"line":524},27,[135,526,225],{},[135,528,530],{"class":137,"line":529},28,[135,531,190],{"emptyLinePlaceholder":189},[135,533,535],{"class":137,"line":534},29,[135,536,236],{},[135,538,540],{"class":137,"line":539},30,[135,541,242],{},[244,543,546],{"height":246,"style":247,"scrolling":248,"title":544,"src":545,"frameBorder":248,"loading":251,"allowTransparency":252,"allowFullScreen":252},"(113) React useCallback","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FdyepLQB?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FdyepLQB\">\n  (113) React useCallback\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,548,549,550,552],{},"Once we change the example to this, something interesting happens: ",[21,551,392],{}," keeps firing over and over again. Why is that?",[17,554,555],{},"Let's break down how the code above actually runs:",[557,558,559,576,594],"ol",{},[56,560,561,562,565,566,45,569,571,572,575],{},"The ",[21,563,564],{},"App"," component renders, and ",[21,567,568],{},"getData",[21,570,396],{}," get passed down to the ",[21,573,574],{},"Child"," component.",[56,577,561,578,580,581,584,585,587,588,590,591,593],{},[21,579,574],{}," component renders and sets up a ",[21,582,583],{},"useEffect"," that listens for ",[21,586,568],{}," — when ",[21,589,568],{}," changes, it runs the ",[21,592,568],{}," function.",[56,595,596,598,599,601,602,605,606,608],{},[21,597,568],{}," runs and kicks off the ",[21,600,392],{},". After about two seconds it calls ",[21,603,604],{},"setCount"," to update ",[21,607,396],{},".",[17,610,611,612,619],{},"So far so good — nothing wrong yet. But the key part is this bit: \"",[66,613,614,615,605,617],{},"after about two seconds it calls ",[21,616,604],{},[21,618,396],{},".\"",[557,621,622,630,644],{},[56,623,624,625,627,628,575],{},"Because ",[21,626,396],{}," got updated, it triggers a re-render of the ",[21,629,564],{},[56,631,632,633,635,636,45,638,640,641,643],{},"Since ",[21,634,564],{}," re-renders, ",[21,637,568],{},[21,639,396],{}," get re-created and passed down to the ",[21,642,574],{}," component again.",[56,645,646,648,649,651,652,654,655,657],{},[21,647,574],{},"'s ",[21,650,583],{}," notices that ",[21,653,568],{}," was re-created, so it runs the ",[21,656,568],{}," function once more.",[17,659,660],{},"And just like that, we've got an infinite loop.",[17,662,663,664,666],{},"So how do we fix it? This is exactly where ",[21,665,23],{}," gets its moment to shine. Let's adjust the code like this:",[126,668,670],{"className":128,"code":669,"language":130,"meta":131,"style":131},"const Child = ({ count, getData }) => {\n  React.useEffect(() => {\n    getData()\n  }, [ getData ]);\n\n  return (\n    \u003Cdiv>\n      {count}\n    \u003C\u002Fdiv>\n  )\n}\nconst App = () => {\n  const [count, setCount] = React.useState(0);\n  \n  const getData = React.useCallback(() => {\n    setTimeout(() => {\n       setCount((pre) => pre + 1)\n    }, 2000);\n  }, [])\n\n  return (\n    \u003Cdiv>\n      \u003CChild count={count} getData={getData} \u002F>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,671,672,676,680,684,688,692,696,700,704,708,712,716,720,724,728,733,737,741,745,750,754,758,762,766,770,774,778,782,786],{"__ignoreMap":131},[135,673,674],{"class":137,"line":138},[135,675,414],{},[135,677,678],{"class":137,"line":144},[135,679,165],{},[135,681,682],{"class":137,"line":150},[135,683,331],{},[135,685,686],{"class":137,"line":156},[135,687,427],{},[135,689,690],{"class":137,"line":162},[135,691,190],{"emptyLinePlaceholder":189},[135,693,694],{"class":137,"line":168},[135,695,201],{},[135,697,698],{"class":137,"line":174},[135,699,207],{},[135,701,702],{"class":137,"line":180},[135,703,444],{},[135,705,706],{"class":137,"line":186},[135,707,213],{},[135,709,710],{"class":137,"line":193},[135,711,219],{},[135,713,714],{"class":137,"line":198},[135,715,225],{},[135,717,718],{"class":137,"line":204},[135,719,141],{},[135,721,722],{"class":137,"line":210},[135,723,289],{},[135,725,726],{"class":137,"line":216},[135,727,159],{},[135,729,730],{"class":137,"line":222},[135,731,732],{},"  const getData = React.useCallback(() => {\n",[135,734,735],{"class":137,"line":228},[135,736,303],{},[135,738,739],{"class":137,"line":233},[135,740,308],{},[135,742,743],{"class":137,"line":239},[135,744,313],{},[135,746,747],{"class":137,"line":364},[135,748,749],{},"  }, [])\n",[135,751,752],{"class":137,"line":369},[135,753,190],{"emptyLinePlaceholder":189},[135,755,756],{"class":137,"line":374},[135,757,201],{},[135,759,760],{"class":137,"line":379},[135,761,207],{},[135,763,764],{"class":137,"line":503},[135,765,511],{},[135,767,768],{"class":137,"line":508},[135,769,213],{},[135,771,772],{"class":137,"line":514},[135,773,219],{},[135,775,776],{"class":137,"line":519},[135,777,225],{},[135,779,780],{"class":137,"line":524},[135,781,190],{"emptyLinePlaceholder":189},[135,783,784],{"class":137,"line":529},[135,785,236],{},[135,787,788],{"class":137,"line":534},[135,789,242],{},[17,791,792,793,795,796,798,799,801,802,804,805,807,808,593],{},"And now you'll see that ",[21,794,392],{}," doesn't keep firing anymore. That's because once ",[21,797,568],{}," is wrapped in ",[21,800,23],{},", its memory reference doesn't get re-created on every render. So ",[21,803,583],{}," no longer thinks ",[21,806,568],{}," changed, and it stops re-running the ",[21,809,568],{},[244,811,814],{"height":246,"style":247,"scrolling":248,"title":812,"src":813,"frameBorder":248,"loading":251,"allowTransparency":252,"allowFullScreen":252},"(115) React useCallback","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FeYrdaYL?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FeYrdaYL\">\n  (115) React useCallback\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,816,817,818,820],{},"And that's a quick rundown of ",[21,819,23],{}," with a simple example.",[12,822,824],{"id":823},"afterword","Afterword",[17,826,827],{},"This post is also published on my blog:",[53,829,830],{},[56,831,832],{},[833,834,838],"a",{"href":835,"rel":836},"https:\u002F\u002Fisraynotarray.com\u002F",[837],"nofollow","Is Ray Not Array",[840,841,842],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":131,"searchDepth":144,"depth":144,"links":844},[845,846,847],{"id":14,"depth":144,"text":15},{"id":30,"depth":144,"text":23},{"id":823,"depth":144,"text":824},"React","2022-09-28 00:00:01","This one's a short and easy chapter. We're just going to quickly get to know useCallback. So what is useCallback? It's pretty much a variation of useMemo — but instead of memoizing a value, it memoizes a function. We'll look at a fun little example where a component falls into an infinite re-render loop, and how useCallback gets us out of it.","md","en",{},"\u002Fen\u002Freact\u002Freact-day-14-usecallback","4",{"title":6,"description":850},false,"en\u002FReact\u002Freact-day-14-usecallback",[