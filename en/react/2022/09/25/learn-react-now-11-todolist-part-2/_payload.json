ponent and render the screen by passing data in through Props.",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"language-jsx shiki shiki-themes github-dark-high-contrast","\u003Cul>\n  {\n    todoList.map((todo) => (\n      \u003Cli className=\"py-4\" key={ todo.id } data-id={ todo.id } >\n        \u003Clabel className={ todo.status ? 'line-through' : ''}>\n          \u003Cinput onChange={ updateTodo } type=\"checkbox\" className=\"mr-2\"  data-id={ todo.id } checked={ todo.status }\u002F>\n          { todo.name }\n        \u003C\u002Flabel>\n      \u003C\u002Fli>\n    ))\n  }\n\u003C\u002Ful>\n","jsx","",[28,52,53,61,67,73,79,85,91,97,103,109,115,121],{"__ignoreMap":50},[54,55,58],"span",{"class":56,"line":57},"line",1,[54,59,60],{},"\u003Cul>\n",[54,62,64],{"class":56,"line":63},2,[54,65,66],{},"  {\n",[54,68,70],{"class":56,"line":69},3,[54,71,72],{},"    todoList.map((todo) => (\n",[54,74,76],{"class":56,"line":75},4,[54,77,78],{},"      \u003Cli className=\"py-4\" key={ todo.id } data-id={ todo.id } >\n",[54,80,82],{"class":56,"line":81},5,[54,83,84],{},"        \u003Clabel className={ todo.status ? 'line-through' : ''}>\n",[54,86,88],{"class":56,"line":87},6,[54,89,90],{},"          \u003Cinput onChange={ updateTodo } type=\"checkbox\" className=\"mr-2\"  data-id={ todo.id } checked={ todo.status }\u002F>\n",[54,92,94],{"class":56,"line":93},7,[54,95,96],{},"          { todo.name }\n",[54,98,100],{"class":56,"line":99},8,[54,101,102],{},"        \u003C\u002Flabel>\n",[54,104,106],{"class":56,"line":105},9,[54,107,108],{},"      \u003C\u002Fli>\n",[54,110,112],{"class":56,"line":111},10,[54,113,114],{},"    ))\n",[54,116,118],{"class":56,"line":117},11,[54,119,120],{},"  }\n",[54,122,124],{"class":56,"line":123},12,[54,125,126],{},"\u003C\u002Ful>\n",[17,128,129,130,133,134,136,137,140,141,144],{},"First step is to create a component called ",[28,131,132],{},"List"," and move the ",[28,135,42],{}," code into it. Don't forget to pass in ",[28,138,139],{},"todoList"," and ",[28,142,143],{},"updateTodo"," as Props.",[45,146,148],{"className":47,"code":147,"language":49,"meta":50,"style":50},"const List = ({ todoList, updateTodo }) => {\n  return (\n    \u003Cul>\n      {\n        todoList.map((todo) => (\n          \u003Cli className=\"py-4\" key={ todo.id } data-id={ todo.id } >\n            \u003Clabel className={ todo.status ? 'line-through' : ''}>\n              \u003Cinput onChange={ updateTodo } type=\"checkbox\" className=\"mr-2\"  data-id={ todo.id } checked={ todo.status }\u002F>\n              { todo.name }\n            \u003C\u002Flabel>\n          \u003C\u002Fli>\n        ))\n      }\n    \u003C\u002Ful>\n  )\n}\n",[28,149,150,155,160,165,170,175,180,185,190,195,200,205,210,216,222,228],{"__ignoreMap":50},[54,151,152],{"class":56,"line":57},[54,153,154],{},"const List = ({ todoList, updateTodo }) => {\n",[54,156,157],{"class":56,"line":63},[54,158,159],{},"  return (\n",[54,161,162],{"class":56,"line":69},[54,163,164],{},"    \u003Cul>\n",[54,166,167],{"class":56,"line":75},[54,168,169],{},"      {\n",[54,171,172],{"class":56,"line":81},[54,173,174],{},"        todoList.map((todo) => (\n",[54,176,177],{"class":56,"line":87},[54,178,179],{},"          \u003Cli className=\"py-4\" key={ todo.id } data-id={ todo.id } >\n",[54,181,182],{"class":56,"line":93},[54,183,184],{},"            \u003Clabel className={ todo.status ? 'line-through' : ''}>\n",[54,186,187],{"class":56,"line":99},[54,188,189],{},"              \u003Cinput onChange={ updateTodo } type=\"checkbox\" className=\"mr-2\"  data-id={ todo.id } checked={ todo.status }\u002F>\n",[54,191,192],{"class":56,"line":105},[54,193,194],{},"              { todo.name }\n",[54,196,197],{"class":56,"line":111},[54,198,199],{},"            \u003C\u002Flabel>\n",[54,201,202],{"class":56,"line":117},[54,203,204],{},"          \u003C\u002Fli>\n",[54,206,207],{"class":56,"line":123},[54,208,209],{},"        ))\n",[54,211,213],{"class":56,"line":212},13,[54,214,215],{},"      }\n",[54,217,219],{"class":56,"line":218},14,[54,220,221],{},"    \u003C\u002Ful>\n",[54,223,225],{"class":56,"line":224},15,[54,226,227],{},"  )\n",[54,229,231],{"class":56,"line":230},16,[54,232,233],{},"}\n",[17,235,236,237,239,240,242,243,140,245,247],{},"Now drop the ",[28,238,132],{}," component into ",[28,241,30],{}," and pass ",[28,244,139],{},[28,246,143],{}," through to it.",[45,249,251],{"className":47,"code":250,"language":49,"meta":50,"style":50},"\u003CList  todoList={ todoList } updateTodo={ updateTodo }\u002F>\n",[28,252,253],{"__ignoreMap":50},[54,254,255],{"class":56,"line":57},[54,256,250],{},[258,259,267],"iframe",{"height":260,"style":261,"scrolling":262,"title":263,"src":264,"frameBorder":262,"loading":265,"allowTransparency":266,"allowFullScreen":266},300,"width: 100%;","no","(89) React ToDoList (上) - Finish","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FExLaVeV?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FExLaVeV\">\n  (89) React ToDoList (上) - Finish\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,269,270],{},"Now try typing in a todo, and you'll see it renders to the screen just fine.",[33,272,274],{"id":273},"saving-todo-data-to-localstorage","Saving todo data to LocalStorage",[17,276,277],{},"Right now, the moment you close the page, every todo you wrote gets wiped. So to keep them around, we need a bit of LocalStorage magic.",[17,279,280,281,284,285,140,288,290],{},"Your first instinct is probably to write the ",[28,282,283],{},"localStorage"," calls inside ",[28,286,287],{},"addTodo",[28,289,143],{},":",[45,292,294],{"className":47,"code":293,"language":49,"meta":50,"style":50},"\u002F\u002F ...snipped\n\nconst addTodo = (event) => {\n  const input = document.querySelector('#todoInput');\n  setTodoList([\n    ...todoList,\n    {\n      id: Date.now(),\n      name: input.value,\n      status: false,\n    }\n  ]);\n  input.value = '';\n  window.localStorage.setItem('todoList', JSON.stringify(todoList));\n};\n\nconst updateTodo = (event) => {\n  const { id } = event.target.dataset;\n  console.log(id)\n\n  const newTodoList = todoList.map((todo) => {\n    if(todo.id === Number(id)) {\n      todo.status = !todo.status;\n    }\n    return todo;\n  });\n\n  setTodoList([ ...newTodoList ]);\n  window.localStorage.setItem('todoList', JSON.stringify(todoList));\n}\n\n\u002F\u002F ...snipped\n",[28,295,296,301,307,312,317,322,327,332,337,342,347,352,357,362,367,372,376,382,388,394,399,405,411,417,422,428,434,439,445,450,455,460],{"__ignoreMap":50},[54,297,298],{"class":56,"line":57},[54,299,300],{},"\u002F\u002F ...snipped\n",[54,302,303],{"class":56,"line":63},[54,304,306],{"emptyLinePlaceholder":305},true,"\n",[54,308,309],{"class":56,"line":69},[54,310,311],{},"const addTodo = (event) => {\n",[54,313,314],{"class":56,"line":75},[54,315,316],{},"  const input = document.querySelector('#todoInput');\n",[54,318,319],{"class":56,"line":81},[54,320,321],{},"  setTodoList([\n",[54,323,324],{"class":56,"line":87},[54,325,326],{},"    ...todoList,\n",[54,328,329],{"class":56,"line":93},[54,330,331],{},"    {\n",[54,333,334],{"class":56,"line":99},[54,335,336],{},"      id: Date.now(),\n",[54,338,339],{"class":56,"line":105},[54,340,341],{},"      name: input.value,\n",[54,343,344],{"class":56,"line":111},[54,345,346],{},"      status: false,\n",[54,348,349],{"class":56,"line":117},[54,350,351],{},"    }\n",[54,353,354],{"class":56,"line":123},[54,355,356],{},"  ]);\n",[54,358,359],{"class":56,"line":212},[54,360,361],{},"  input.value = '';\n",[54,363,364],{"class":56,"line":218},[54,365,366],{},"  window.localStorage.setItem('todoList', JSON.stringify(todoList));\n",[54,368,369],{"class":56,"line":224},[54,370,371],{},"};\n",[54,373,374],{"class":56,"line":230},[54,375,306],{"emptyLinePlaceholder":305},[54,377,379],{"class":56,"line":378},17,[54,380,381],{},"const updateTodo = (event) => {\n",[54,383,385],{"class":56,"line":384},18,[54,386,387],{},"  const { id } = event.target.dataset;\n",[54,389,391],{"class":56,"line":390},19,[54,392,393],{},"  console.log(id)\n",[54,395,397],{"class":56,"line":396},20,[54,398,306],{"emptyLinePlaceholder":305},[54,400,402],{"class":56,"line":401},21,[54,403,404],{},"  const newTodoList = todoList.map((todo) => {\n",[54,406,408],{"class":56,"line":407},22,[54,409,410],{},"    if(todo.id === Number(id)) {\n",[54,412,414],{"class":56,"line":413},23,[54,415,416],{},"      todo.status = !todo.status;\n",[54,418,420],{"class":56,"line":419},24,[54,421,351],{},[54,423,425],{"class":56,"line":424},25,[54,426,427],{},"    return todo;\n",[54,429,431],{"class":56,"line":430},26,[54,432,433],{},"  });\n",[54,435,437],{"class":56,"line":436},27,[54,438,306],{"emptyLinePlaceholder":305},[54,440,442],{"class":56,"line":441},28,[54,443,444],{},"  setTodoList([ ...newTodoList ]);\n",[54,446,448],{"class":56,"line":447},29,[54,449,366],{},[54,451,453],{"class":56,"line":452},30,[54,454,233],{},[54,456,458],{"class":56,"line":457},31,[54,459,306],{"emptyLinePlaceholder":305},[54,461,463],{"class":56,"line":462},32,[54,464,300],{},[17,466,467,468,470,471,474],{},"But here's the thing — you'll notice the data only seems to get written to ",[28,469,283],{}," on the second or third entry, always one step behind. The reason is that ",[28,472,473],{},"useState"," is asynchronous.",[17,476,477,478,480,481,484,485,487],{},"So the correct approach is to pull ",[28,479,283],{}," out on its own and use ",[28,482,483],{},"useEffect"," to watch for changes to ",[28,486,139],{},". Only when it actually changes do we write the data out.",[45,489,491],{"className":47,"code":490,"language":49,"meta":50,"style":50},"React.useEffect(() => {\n  window.localStorage.setItem('todoList', JSON.stringify(todoList));\n}, [todoList]);\n",[28,492,493,498,502],{"__ignoreMap":50},[54,494,495],{"class":56,"line":57},[54,496,497],{},"React.useEffect(() => {\n",[54,499,500],{"class":56,"line":63},[54,501,366],{},[54,503,504],{"class":56,"line":69},[54,505,506],{},"}, [todoList]);\n",[17,508,509,510,512],{},"Finally, every time we reopen the page we'd want it to automatically grab whatever's saved in LocalStorage. So let's tweak our original ",[28,511,473],{}," a little.",[45,514,516],{"className":47,"code":515,"language":49,"meta":50,"style":50},"const [ todoList, setTodoList ] = React.useState(JSON.parse(localStorage.getItem('todoList')) || []);\n",[28,517,518],{"__ignoreMap":50},[54,519,520],{"class":56,"line":57},[54,521,515],{},[17,523,524,525,527,528,530,531,533],{},"At this point you might be wondering: why not write a ",[28,526,483],{}," to read the ",[28,529,283],{}," data, instead of stuffing it straight into ",[28,532,473],{},"? Two reasons:",[535,536,537,554],"ol",{},[538,539,540,542,543,545,546,550,551,553],"li",{},[28,541,473],{}," runs on the component's first render, whereas ",[28,544,483],{}," only runs ",[547,548,549],"em",{},"after"," the component renders. So we just put it directly in ",[28,552,473],{},".",[538,555,556,557,527,559,561,562,565,566,568,569,571,572,574],{},"If we used ",[28,558,483],{},[28,560,283],{}," data, then when we run ",[28,563,564],{},"setTodoList(JSON.parse(localStorage.getItem('todoList')) || []);",", ",[28,567,139],{}," changes — which triggers ",[28,570,483],{}," again, and now we're in an infinite loop. So for this situation, ",[28,573,483],{}," isn't a good fit.",[258,576,579],{"height":260,"style":261,"scrolling":262,"title":577,"src":578,"frameBorder":262,"loading":265,"allowTransparency":266,"allowFullScreen":266},"(92) React ToDoList (下) - ","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FWNJbxjy?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNJbxjy\">\n  (92) React ToDoList (下) - \u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,581,582,583,585],{},"Now whether we refresh, add, or update data, all of it gets written to ",[28,584,283],{}," — and we put a bunch of the techniques from earlier to good use too.",[17,587,588,589,553],{},"As always, here's the link to the full version: ",[590,591,595],"a",{"href":592,"rel":593},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNJbxjy",[594],"nofollow","React - TodoList CodePen",[17,597,598,599,604],{},"And since it wouldn't feel right to skip it, here's the Vue version too — ",[590,600,603],{"href":601,"rel":602},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FeYrmzVw",[594],"Vue - TodoList CodePen"," — so you can compare the two.",[12,606,608],{"id":607},"afterword","Afterword",[17,610,611],{},"This post is also published on my blog:",[613,614,615],"ul",{},[538,616,617],{},[590,618,621],{"href":619,"rel":620},"https:\u002F\u002Fisraynotarray.com\u002F",[594],"It's Ray, not Array",[623,624,625],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":50,"searchDepth":63,"depth":63,"links":627},[628,629,633],{"id":14,"depth":63,"text":15},{"id":22,"depth":63,"text":23,"children":630},[631,632],{"id":35,"depth":69,"text":36},{"id":273,"depth":69,"text":274},{"id":607,"depth":63,"text":608},"React","2022-09-25 00:00:02","Last time we built a bare-bones React TodoList. In this one we're going to polish it up — pull a chunk of the markup out into its own component, and wire up LocalStorage so your todos actually survive a page refresh. Along the way we'll run into a fun gotcha with useState being asynchronous, and figure out why useEffect is the right tool for the job (and where it isn't).","md","en",{},"\u002Fen\u002Freact\u002Flearn-react-now-11-todolist-part-2","3",{"title":6,"description":636},false,"en\u002FReact\u002Flearn-react-now-11-todolist-part-2",[646,647,648,649,650],"You'll Learn React Eventually, So Why Not Now?","React Basics","React TodoList","Vue TodoList","TodoList Part 2",null,"\u002Fen\u002Freact\u002F2022\u002F09\u002F25\u002Flearn-react-now-11-todolist-part-2\u002F","-cMoCZRVHMplTyENBe18eLnCDZxonuVr0ZqUKJlyvEE",{"newer":655,"older":659},{"url":656,"title":657,"date":658},"\u002Fen\u002Freact\u002F2022\u002F09\u002F26\u002Flearn-react-now-12-jsx-deep-dive\u002F","You'll Learn React Eventually, So Why Not Now? - Going Deeper Into JSX - (12)","2022-09-26 00:00:01",{"url":660,"title":661,"date":662},"\u002Fen\u002Fhtml\u002F2022\u002F09\u002F24\u002Fthe-curious-button-type-attribute\u002F","The Curious Case of Button's `type` Attribute","2022-09-24 22:12:46",[664,669,674],{"url":665,"title":666,"date":667,"readingMinutes":668},"\u002Fen\u002Freact\u002F2022\u002F10\u002F14\u002Flearn-react-now-30-wrap-up-and-toc\u002F","Learn React Now — Wrap-up Notes & Full Table of Contents (30)","2022-10-14 00:00:01","4",{"url":670,"title":671,"date":672,"readingMinutes":673},"\u002Fen\u002Freact\u002F2022\u002F10\u002F13\u002Flearn-react-29-react-redux-quick-start\u002F","Learn React Eventually, So Why Not Now? - React Redux: Redux and a Quick Start - (29)","2022-10-13 00:00:01","6",{"url":675,"title":676,"date":677,"readingMinutes":668},"\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F","Why Learn React Eventually? Learn It Now! - React Router Lazy Loading (28)","2022-10-12 00:00:01",17