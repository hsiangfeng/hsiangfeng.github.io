line":186},[159,837,838],{},"        \u003Clabel>\n",[159,840,841],{"class":161,"line":192},[159,842,843],{},"          \u003Cinput type=\"checkbox\" class=\"mr-2\" checked={ todo.status }\u002F>\n",[159,845,846],{"class":161,"line":198},[159,847,848],{},"          { todo.name }\n",[159,850,851],{"class":161,"line":204},[159,852,853],{},"        \u003C\u002Flabel>\n",[159,855,856],{"class":161,"line":210},[159,857,858],{},"      \u003C\u002Fli>\n",[159,860,861],{"class":161,"line":216},[159,862,863],{},"    ))\n",[159,865,866],{"class":161,"line":222},[159,867,868],{},"  }\n",[159,870,871],{"class":161,"line":228},[159,872,796],{},[17,874,875,876,878,879,881],{},"You might be wondering why ",[89,877,747],{}," renders the data correctly. Like we covered in an earlier chapter, JSX spreads arrays out automatically, and ",[89,880,747],{}," returns an array — so the data renders just fine.",[17,883,884],{},"While you're at it, you can also tweak this bit:",[150,886,888],{"className":152,"code":887,"language":154,"meta":155,"style":155},"\u003Cp>\n  You have \u003Cspan className=\"font-medium\">1\u003C\u002Fspan> item left to do\n\u003C\u002Fp>\n",[89,889,890,895,900],{"__ignoreMap":155},[159,891,892],{"class":161,"line":162},[159,893,894],{},"\u003Cp>\n",[159,896,897],{"class":161,"line":168},[159,898,899],{},"  You have \u003Cspan className=\"font-medium\">1\u003C\u002Fspan> item left to do\n",[159,901,902],{"class":161,"line":174},[159,903,904],{},"\u003C\u002Fp>\n",[17,906,907],{},"into this:",[150,909,911],{"className":152,"code":910,"language":154,"meta":155,"style":155},"\u003Cp>\n  You have \u003Cspan className=\"font-medium\">{ todoList.length }\u003C\u002Fspan> item(s) left to do\n\u003C\u002Fp>\n",[89,912,913,917,922],{"__ignoreMap":155},[159,914,915],{"class":161,"line":162},[159,916,894],{},[159,918,919],{"class":161,"line":168},[159,920,921],{},"  You have \u003Cspan className=\"font-medium\">{ todoList.length }\u003C\u002Fspan> item(s) left to do\n",[159,92