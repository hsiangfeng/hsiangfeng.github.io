>\n",[89,982,983,987,991,995,999,1004,1009,1013,1017,1021,1025,1029],{"__ignoreMap":155},[159,984,985],{"class":161,"line":162},[159,986,761],{},[159,988,989],{"class":161,"line":168},[159,990,823],{},[159,992,993],{"class":161,"line":174},[159,994,828],{},[159,996,997],{"class":161,"line":180},[159,998,833],{},[159,1000,1001],{"class":161,"line":186},[159,1002,1003],{},"        \u003Clabel className={ todo.status ? 'line-through' : ''}>\n",[159,1005,1006],{"class":161,"line":192},[159,1007,1008],{},"          \u003Cinput type=\"checkbox\" data-id={ todo.id } className=\"mr-2\" checked={ todo.status }\u002F>\n",[159,1010,1011],{"class":161,"line":198},[159,1012,848],{},[159,1014,1015],{"class":161,"line":204},[159,1016,853],{},[159,1018,1019],{"class":161,"line":210},[159,1020,858],{},[159,1022,1023],{"class":161,"line":216},[159,1024,863],{},[159,1026,1027],{"class":161,"line":222},[159,1028,868],{},[159,1030,1031],{"class":161,"line":228},[159,1032,796],{},[17,1034,1035,1036,1039,1040,133],{},"Now every item you add will have a ",[89,1037,1038],{},"data-id"," attribute on its ",[89,1041,1042],{},"Li",[17,1044,1045,1046,1048,1049,1052,1053,1056],{},"Next we need to bind an event to the ",[89,1047,969],{}," — an ",[89,1050,1051],{},"onClick"," event mapping to the ",[89,1054,1055],{},"updateTodo"," method.",[150,1058,1060],{"className":152,"code":1059,"language":154,"meta":155,"style":155},"\u003Cul>\n  {\n    todoList.map((todo) => (\n      \u003Cli className=\"py-4\" key={ todo.id } data-id={ todo.id } >\n        \u003Clabel className={ todo.status ? 'line-through' : ''} >\n          \u003Cinput onClick={ updateTodo } type=\"checkbox\" className=\"mr-2\" data-id={ todo.id } checked={ todo.status }\u002F>\n          { todo.name }\n        \u003C\u002Flabel>\n      \u003C\u002Fli>\n    ))\n  }\n\u003C\u002Ful>\n",[89,1061,1062,1066,1070,1074,1079,1084,1089,1093,1097,1101,1105,1109],{"__ignoreMap":155},[159,1063,1064],{"class":161,"line":162},[159,1065,761],{},[159,1