ue);\n",[159,519,520],{"class":161,"line":180},[159,521,522],{},"};\n",[65,524,527],{"height":67,"style":68,"scrolling":69,"title":525,"src":526,"frameBorder":69,"loading":72,"allowTransparency":73,"allowFullScreen":73},"(83) React ToDoList ","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FJjvjgjW?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FJjvjgjW\">\n  (83) React ToDoList \u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,529,530,531,533,534,536,537,539],{},"Now type anything into the ",[89,532,143],{}," and hit \"",[89,535,394],{},"\", and you'll see we're correctly grabbing the ",[89,538,143],{},"'s value.",[103,541,543],{"id":542},"saving-the-input-value","Saving the input value",[17,545,546,547,550],{},"Once we've got the value, we need to push it into ",[89,548,549],{},"setTodoList",". First we spread the original data object, then we write in another object.",[150,552,554],{"className":152,"code":553,"language":154,"meta":155,"style":155},"const addTodo = () => {\n  const input = document.querySelector('#todoInput');\n  setTodoList([\n    ...todoList,\n    {\n      name: input.value\n    }\n  ])\n};\n",[89,555,556,560,565,570,575,580,585,590,595],{"__ignoreMap":155},[159,557,558],{"class":161,"line":162},[159,559,417],{},[159,561,562],{"class":161,"line":168},[159,563,564],{},"  const input = document.querySelector('#todoInput');\n",[159,566,567],{"class":161,"line":174},[159,568,569],{},"  setTodoList([\n",[159,571,572],{"class":161,"line":180},[159,573,574],{},"    ...todoList,\n",[159,576,577],{"class":161,"line":186},[159,578,579],{},"    {\n",[159,581,582],{"class":161,"line":192},[159,583,584],{},"      name: input.value\n",[159,586,587],{"class":161,"line":198},[159,588,589],{},"    }\n",[159,591,592],{"class":161,"line":204},[159,593,594],{},"  ])\n",[159,596,597],{"class":161,"line":210},[159,598,522],{},[17,600,601],{},"The reason we spread the original data first is that we don't want to overwrite what's already there — we want to push the new item in instead, so we don't lose any data. That's why we spread the existing data first and then add the new item.",[17,603,604,605,608,609,611,612,615],{},"Next we also want to record when the todo was added. The easiest way to do that is ",[89,606,607],{},"Date.now()",", and it just so happens ",[89,610,607],{}," works great as a ",[89,613,614],{},"key",", so we'll use it for both. Finally we'll tack on the todo's status (done or not done).",[150,617,619],{"className":152,"code":618,"language":154,"meta":155,"style":155},"const addTodo = (event) => {\n  const input = document.querySelector('#todoInput');\n  setTodoList([\n    ...todoList,\n    {\n      id: Date.now(),\n      name: input.value,\n      status: false,\n    }\n  ])\n};\n",[89,620,621,625,629,633,637,641,646,651,656,660,664],{"__ignoreMap":155},[159,622,623],{"class":161,"line":162},[159,624,507],{},[159,626,627],{"class":161,"line":168},[159,628,564],{},[159,630,631],{"class":161,"line":174},[159,632,569],{},[159,634,635],{"class":161,"line":180},[159,636,574],{},[159,638,639],{"class":161,"line":186},[159,640,579],{},[159,642,643],{"class":161,"line":192},[159,644,645],{},"      id: Date.now(),\n",[159,647,648],{"class":161,"line":198},[159,649,650],{},"      name: input.value,\n",[159,652,653],{"class":161,"line":204},[159,654,655],{},"      status: false,\n",[159,657,658],{"class":161,"line":210},[159,659,589],{},[159,661,662],{"class":161,"line":216},[159,663,594],{},[159,665,666],{"class":161,"line":222},[159,667,522],{},[17,669,670],{},"And don't forget to clear the input field at the end — once it's added successfully, we want it cleared.",[150,672,674],{"className":152,"code":673,"language":154,"meta":155,"style":155},"const addTodo = (event) => {\n  const input = docu