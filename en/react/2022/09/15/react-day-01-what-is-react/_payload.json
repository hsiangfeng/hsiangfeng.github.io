3},[176,406,366],{"class":186},[176,408,409,411,414],{"class":178,"line":237},[176,410,371],{"class":186},[176,412,413],{"class":353},"hr",[176,415,416],{"class":186},"\u002F> \n",[176,418,419,421,423,425,427,429,431,433,436,439,441],{"class":178,"line":246},[176,420,371],{"class":186},[176,422,374],{"class":353},[176,424,377],{"class":357},[176,426,197],{"class":186},[176,428,382],{"class":296},[176,430,385],{"class":357},[176,432,197],{"class":186},[176,434,435],{"class":296},"\"sayHi\"",[176,437,438],{"class":186},">Say hi\u003C\u002F",[176,440,374],{"class":353},[176,442,366],{"class":186},[176,444,445,448,450],{"class":178,"line":258},[176,446,447],{"class":186},"\u003C\u002F",[176,449,354],{"class":353},[176,451,366],{"class":186},[453,454,462],"iframe",{"height":455,"style":456,"scrolling":457,"title":458,"src":459,"frameBorder":457,"loading":460,"allowTransparency":461,"allowFullScreen":461},300,"width: 100%;","no","Untitled","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FMWVXzRE?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FMWVXzRE\">\n  Untitled\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,464,465],{},"That's the structure and the opening move that we Vue developers know inside out.",[17,467,468],{},"Now let's convert that Vue structure into React. What does the code look like then?",[17,470,471],{},"(Using a React Component for this one)",[167,473,477],{"className":474,"code":475,"language":476,"meta":172,"style":172},"language-jsx shiki shiki-themes github-light github-light github-dark-high-contrast","class App extends React.Component {\n  constructor(props) {\n    super(props);\n    this.state = {\n      count: 0,\n    };\n\n    this.handleClick = this.handleClick.bind(this);\n  }\n\n  sayHi() {\n    window.alert('Hello Ray.');\n  }\n  \n  handleClick() {\n    this.setState((prevState) => ({\n      count: prevState.count += 1,\n    }));\n  }\n  \n  render() {\n    return (\n      \u003Cdiv>\n        \u003Cbutton onClick={this.handleClick}>\n          Count is: { this.state.count }\n        \u003C\u002Fbutton>\n        \u003Chr \u002F>\n        \u003Cbutton type=\"button\" onClick={ this.sayHi }>Say hi\u003C\u002Fbutton>\n      \u003C\u002Fdiv>\n    );\n  }\n}\n\nconst app = ReactDOM.createRoot(document.getElementById('app'));\napp.render(\u003CApp \u002F>);\n","jsx",[113,478,479,484,489,494,499,504,508,512,517,522,526,531,536,540,545,550,555,561,567,572,577,583,589,595,601,607,613,619,625,631,637,642,648,653,659],{"__ignoreMap":172},[176,480,481],{"class":178,"line":179},[176,482,483],{},"class App extends React.Component {\n",[176,485,486],{"class":178,"line":203},[176,487,488],{},"  constructor(props) {\n",[176,490,491],{"class":178,"line":210},[176,492,493],{},"    super(props);\n",[176,495,496],{"class":178,"line":228},[176,497,498],{},"    this.state = {\n",[176,500,501],{"class":178,"line":237},[176,502,503],{},"      count: 0,\n",[176,505,506],{"class":178,"line":246},[176,507,261],{},[176,509,510],{"class":178,"line":258},[176,511,207],{"emptyLinePlaceholder":206},[176,513,514],{"class":178,"line":264},[176,515,516],{},"    this.handleClick = this.handleClick.bind(this);\n",[176,518,519],{"class":178,"line":270},[176,520,521],{},"  }\n",[176,523,524],{"class":178,"line":276},[176,525,207],{"emptyLinePlaceholder":206},[176,527,528],{"class":178,"line":284},[176,529,530],{},"  sayHi() {\n",[176,532,533],{"class":178,"line":303},[176,534,535],{},"    window.alert('Hello Ray.');\n",[176,537,538],{"class":178,"line":309},[176,539,521],{},[176,541,542],{"class":178,"line":314},[176,543,544],{},"  \n",[176,546,547],{"class":178,"line":320},[176,548,549],{},"  handleClick() {\n",[176,551,552],{"class":178,"line":325},[176,553,554],{},"    this.setState((prevState) => (