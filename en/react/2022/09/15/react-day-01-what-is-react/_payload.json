,363],{"class":296},[176,683,684],{"class":186},">\u003C\u002F",[176,686,354],{"class":353},[176,688,366],{"class":186},[453,690,693],{"height":455,"style":456,"scrolling":457,"title":691,"src":692,"frameBorder":457,"loading":460,"allowTransparency":461,"allowFullScreen":461},"(2)React Component init","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FmdxKaLr?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FmdxKaLr\">\n  (2)React Component init\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,695,696],{},"If you've been learning Vue, I bet your first reaction is...",[17,698,699],{},"\"The overall structure is wildly different! And why does React look like it's just writing plain JavaScript?!\"",[17,701,702],{},"Comparing React and Vue's initial setup and syntax, yeah, you really do get the feeling that React is just writing plain JavaScript.",[17,704,705],{},[46,706],{"alt":707,"src":708},"It's literally just JavaScript!","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E4%BE%86%E8%87%AA%20Vue%20%E7%9A%84%20React%20Hook%20%E9%96%8B%E7%99%BC%E8%80%85\u002F1653197441448.png",[17,710,711],{},"But someone might point out that I used a React Class Component as the example, so let me also show the newer syntax for both Vue and React side by side.",[17,713,714],{},"First, Vue's Composition API style:",[167,716,718],{"className":169,"code":717,"language":171,"meta":172,"style":172},"const { createApp, ref } = Vue;\n\nconst app = createApp({\n  setup() {\n    const count = ref(0);\n    \n    const sayHi = () => {\n      window.alert('Hello Ray.');\n    };\n    \n    return {\n      count,\n      sayHi\n    }\n  },\n});\n\napp.mount('#app');\n",[113,719,720,739,743,755,762,781,786,803,815,819,823,829,834,839,844,848,852,856],{