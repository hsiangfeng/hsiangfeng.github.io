0,183],{"class":55},[45,392,393,395,397,399,402],{"class":47,"line":204},[45,394,343],{"class":55},[45,396,346],{"class":101},[45,398,131],{"class":55},[45,400,401],{"class":226},"'methods'",[45,403,137],{"class":55},[45,405,406,408,410,412],{"class":47,"line":210},[45,407,358],{"class":51},[45,409,159],{"class":55},[45,411,162],{"class":51},[45,413,365],{"class":59},[45,415,416],{"class":47,"line":215},[45,417,195],{"class":55},[45,419,421],{"class":47,"line":420},15,[45,422,174],{"class":55},[45,424,426,428],{"class":47,"line":425},16,[45,427,180],{"class":51},[45,429,183],{"class":55},[45,431,433],{"class":47,"line":432},17,[45,434,435],{"class":55},"      total,\n",[45,437,439],{"class":47,"line":438},18,[45,440,441],{"class":55},"      add\n",[45,443,445],{"class":47,"line":444},19,[45,446,195],{"class":55},[45,448,450],{"class":47,"line":449},20,[45,451,201],{"class":55},[45,453,455],{"class":47,"line":454},21,[45,456,207],{"class":55},[45,458,460],{"class":47,"line":459},22,[45,461,87],{"emptyLinePlaceholder":86},[45,463,465,467,469,471,473],{"class":47,"line":464},23,[45,466,218],{"class":55},[45,468,221],{"class":101},[45,470,131],{"class":55},[45,472,227],{"class":226},[45,474,137],{"class":55},[231,476,479],{"height":233,"style":234,"scrolling":235,"title":477,"src":478,"frameBorder":235,"loading":238,"allowTransparency":239,"allowFullScreen":239},"(106)Vue Computed","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FoNdLWyW?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FoNdLWyW\">\n  (106)Vue Computed\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,481,482,483,486,487,490,491,493,494,497,498,500],{},"When you open the Console, you'll notice the ",[21,484,485],{},"add"," function gets called five times in total, so ",[21,488,489],{},"console.log('methods')"," shows up five times too — that's because we called it five times on screen. But ",[21,492,256],{}," was technically also \"called\" five times, yet ",[21,495,496],{},"console.log('computed')"," only appears once. That's because ",[21,499,256],{}," only recalculates and re-runs when its underlying data changes. When the data doesn't change at all, it won't run again. That's the classic Computed behavior we all know.",[17,502,503,504,506],{},"So what about React's ",[21,505,23],{},"? Let's keep going and find out.",[12,508,23],{"id":509},"usememo",[17,511,512,513,515],{},"After the example above, we know Vue's Computed only recalculates when its data changes — and that exact behavior is what we get from React's ",[21,514,23],{}," Hook.",[17,517,518,519,521],{},"Let me take that earlier Vue example and roughly port it into a React Hook version, just to check whether ",[21,520,23],{}," really is similar to Vue Computed:",[36,523,527],{"className":524,"code":525,"language":526,"meta":41,"style":41},"language-jsx shiki shiki-themes github-light github-light github-dark-high-contrast","const App = () => {\n  const num = 1;\n  \n  \n  const total = React.useMemo(() => {\n    console.log('useMemo')\n    return num * 2\n  });\n  \n  const add = () => {\n    console.log('methods');\n    return num * 2;\n  }\n  \n  return (\n    \u003Cdiv>\n      \u003Cp>useMemo：{ total }\u003C\u002Fp>\n      \u003Cp>useMemo：{ total }\u003C\u002Fp>\n      \u003Cp>useMemo：{ total }\u003C\u002Fp>\n      \u003Cp>useMemo：{ total }\u003C\u002Fp>\n      \u003Cp>useMemo：{ total }\u003C\u002Fp>\n      \n      \u003Cp>methods：{ add() }\u003C\u002Fp>\n      \u003Cp>methods：{ add() }\u003C\u002Fp>\n      \u003Cp>methods：{ add() }\u003C\u002Fp>\n      \u003Cp>methods：{ add() }\u003C\u002Fp>\n      \u003Cp>methods：{ add() }\u003C\u002Fp>\n    \u003C\u002Fdiv>\n  )\n}\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n","jsx",[21,