     users.map((user) => (\n            \u003Cli key={user.email}>\n              { user.name.first + user.name.last }\n            \u003C\u002Fli>\n          ))\n        }\n      \u003C\u002Ful>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,718,719,723,728,732,737,742,747,752,756,760,765,770,775,779,783,787,792,797,802,807,812,817,822,827,832,836,840,844,848,852],{"__ignoreMap":41},[45,720,721],{"class":47,"line":48},[45,722,533],{},[45,724,725],{"class":47,"line":83},[45,726,727],{},"  const [ users, setUsers ] = React.useState([]);\n",[45,729,730],{"class":47,"line":90},[45,731,543],{},[45,733,734],{"class":47,"line":108},[45,735,736],{},"  const getData = async () => {\n",[45,738,739],{"class":47,"line":117},[45,740,741],{},"    \u002F\u002F CORS can pop up sometimes — just refresh and you're good\n",[45,743,744],{"class":47,"line":140},[45,745,746],{},"    const { data } = await axios.get('https:\u002F\u002Frandomuser.me\u002Fapi\u002F?results=10');\n",[45,748,749],{"class":47,"line":171},[45,750,751],{},"    setUsers(data.results);\n",[45,753,754],{"class":47,"line":177},[45,755,201],{},[45,757,758],{"class":47,"line":186},[45,759,543],{},[45,761,762],{"class":47,"line":192},[45,763,764],{},"  React.useEffect(() => {\n",[45,766,767],{"class":47,"line":198},[45,768,769],{},"    getData()\n",[45,771,772],{"class":47,"line":204},[45,773,774],{},"  }, []);\n",[45,776,777],{"class":47,"line":210},[45,778,543],{},[45,780,781],{"class":47,"line":215},[45,782,599],{},[45,784,785],{"class":47,"line":420},[45,786,604],{},[45,788,789],{"class":47,"line":425},[45,790,791],{},"      \u003Cul>\n",[45,793,794],{"class":47,"line":432},[45,795,796],{},"        {\n",[45,798,799],{"class":47,"line":438},[45,800,801],{},"          users.map((user) => (\n",[45,803,804],{"class":47,"line":444},[45,805,806],{},"            \u003Cli key={user.email}>\n",[45,808,809],{"class":47,"line":449},[45,810,811],{},"              { user.name.first + user.name.last }\n",[45,813,814],{"class":47,"line":454},[45,815,816],{},"            \u003C\u002Fli>\n",[45,818,819],{"class":47,"line":459},[45,820,821],{},"          ))\n",[45,823,824],{"class":47,"line":464},[45,825,826],{},"        }\n",[45,828,829],{"class":47,"line":638},[45,830,831],{},"      \u003C\u002Ful>\n",[45,833,834],{"class":47,"line":643},[45,835,661],{},[45,837,838],{"class":47,"line":648},[45,839,667],{},[45,841,842],{"class":47,"line":653},[45,843,673],{},[45,845,846],{"class":47,"line":658},[45,847,87],{"emptyLinePlaceholder":86},[45,849,850],{"class":47,"line":664},[45,851,679],{},[45,853,854],{"class":47,"line":670},[45,855,685],{},[231,857,860],{"height":233,"style":234,"scrolling":235,"title":858,"src":859,"frameBorder":235,"loading":238,"allowTransparency":239,"allowFullScreen":239},"(109) React useMemo","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FRwyRgNB?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FRwyRgNB\">\n  (109) React useMemo\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,862,863,864,871],{},"This example uses a service called ",[865,866,870],"a",{"href":867,"rel":868},"https:\u002F\u002Frandomuser.me\u002F",[869],"nofollow","RandomUser",". It's super handy when you're practicing and need some fake user data, and you don't have to worry about any real personal info being in there.",[17,873,874,875,877,878,880,881,883,884,886,887,890],{},"So apart from ",[21,876,23],{}," being a dead ringer for Vue's ",[21,879,256],{},", what else does it do? Well, ",[21,882,23],{}," actually takes two arguments: a Callback and an Array. ",[21,885,23],{}," memoizes the result of the Callback — that's the ",[21,888,889],{},"memoized"," concept — and you can pass the variables you want to watch into that second array. When a watched variable changes, it triggers a re-render.",[36,892,894],{"className":524,"code":893,"language":526,"meta":41,"style":41},"const [ users, setUsers ] = React.useState([]);\nconst newUsers = React.useMemo(() => {}, [ users ])\n",[21,895,896,901],{"__ignoreMap":41},[45,897,898],{"class":47,"line":48},[45,899,900],{},"const [ users, setUsers ] = React.useState([]);\n",[45,902,903],{"class":47,"line":83},[45,904,905],{},"const newUsers = React.useMemo(() => {}, [ users ])\n",[17,907,908,909,911],{},"But if you don't pass in the second array, ",[21,910,23],{}," will run on every single render — just like the earlier example.",[17,913,914,915,918,919,922],{},"Let's actually write some code so it sticks. Remember the ",[865,916,870],{"href":867,"rel":917},[869]," service I mentioned? After we fetch the data via AJAX, we'll want to re-sort it with ",[21,920,921],{},"sort",". So you might write it like this:",[36,924,926],{"className":524,"code":925,"language":526,"meta":41,"style":41},"const App = () => {\n  const [ users, setUsers ] = React.useState([]);;\n  const [ state, setState ] = React.useState(false);\n\n  const getUsers = async() => {\n    const { data } = await axios.get('https:\u002F\u002Frandomuser.me\u002Fapi\u002F?results=10');\n    setUsers(data.results);\n  }\n\n  React.useEffect(() => {\n    getUsers();\n  }, []);\n\n  const filterUsers = (state) => {\n    const newUser = users.sort((a, b) =>  {\n      if(state) {\n        return a.dob.age \u003C b.dob.age ? 1 : -1\n      }\n      return a.dob.age > b.dob.age ? 1 : -1\n    });\n    \n    setUsers([...newUser]);\n  }\n\n  return (\n    \u003Cdiv>\n      \u003Cbutton onClick={ () => filterUsers(true) } className=\"border-4 border-indigo-500\">Age high to low\u003C\u002Fbutton>\n      \u003Cbutton onClick={ () => filterUsers(false) }className=\"border-4 border-indigo-500 ml-4\">Age low to high\u003C\u002Fbutton>\n      \u003Chr className=\"my-4\"\u002F>\n      \u003Cul>\n        {\n          users.map((user) =>(\n            \u003Cli key={ user.email }>\n              { `Name：${user.name.title}.${user.name.first } ${user.name.last}, Age：${user.dob.age}` }\n            \u003C\u002Fli>\n          ))\n        }\n      \u003C\u002Ful>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,927,928,932,937,942,946,951,955,959,963,967,971,976,980,984,989,994,999,1004,1009,1014,1019,1023,1028,1032,1036,1040,1044,1049,1054,1059,1063,1067,1072,1078,1084,1089,1094,1099,1104,1109,1114,1119,1124,1129],{"__ignoreMap":41},[45,929,930],{"class":47,"line":48},[45,931,533],{},[45,933,934],{"class":47,"line":83},[45,935,936],{},"  const [ users, setUsers ] = React.useState([]);;\n",[45,938,939],{"class":47,"line":90},[45,940,941],{},"  const [ state, setState ] = React.useState(false);\n",[45,943,944],{"class":47,"line":108},[45,945,87],{"emptyLinePlaceholder":86},[45,947,948],{"class":47,"line":117},[45,949,950],{},"  const getUsers = async() => {\n",[45,952,953],{"class":47,"line":140},[45,954,746],{},[45,956,957],{"class":47,"line":171},[45,958,751],{},[45,960,961],{"class":47,"line":177},[45,962,201],{},[45,964,965],{"class":47,"line":186},[45,966,87],{"emptyLinePlaceholder":86},[45,968,969],{"class":47,"line":192},[45,970,764],{},[45,972,973],{"class":47,"line":198},[45,974,975],{},"    getUsers();\n",[45,977,978],{"class":47,"line":204},[45,979,774],{},[45,981,982],{"class":47,"line":210},[45,983,87],{"emptyLinePlaceholder":86},[45,985,986],{"class":47,"line":215},[45,987,988],{},"  const filterUsers = (state) => {\n",[45,990,991],{"class":47,"line":420},[45,992,993],{},"    const newUser = users.sort((a, b) =>  {\n",[45,995,996],{"class":47,"line":425},[45,997,998],{},"      if(state) {\n",[45,1000,1001],{"class":47,"line":432},[45,1002,1003],{},"        return a.dob.age \u003C b.dob.age ? 1 : -1\n",[45,1005,1006],{"class":47,"line":438},[45,1007,1008],{},"      }\n",[45,1010,1011],{"class":47,"line":444},[45,1012,1013],{},"      return a.dob.age > b.dob.age ? 1 : -1\n",[45,1015,1016],{"class":47,"line":449},[45,1017,1018],{},"    });\n",[45,1020,1021],{"class":47,"line":454},[45,1022,174],{},[45,1024,1025],{"class":47,"line":459},[45,1026,1027],{},"    setUsers([...newUser]);\n",[45,1029,1030],{"class":47,"line":464},[45,1031,201],{},[45,1033,1034],{"class":47,"line":638},[45,1035,87],{"emptyLinePlaceholder":86},[45,1037,1038],{"class":47,"line":643},[45,1039,599],{},[45,1041,1042],{"class":47,"line":648},[45,1043,604],{},[45,1045,1046],{"class":47,"line":653},[45,1047,1048],{},"      \u003Cbutton onClick={ () => filterUsers(true) } className=\"border-4 border-indigo-500\">Age high to low\u003C\u002Fbutton>\n",[45,1050,1051],{"class":47,"line":658},[45,1052,1053],{},"      \u003Cbutton onClick={ () => filterUsers(false) }className=\"border-4 border-indigo-500 ml-4\">Age low to high\u003C\u002Fbutton>\n",[45,1055,1056],{"class":47,"line":664},[45,1057,1058],{},"      \u003Chr className=\"my-4\"\u002F>\n",[45,1060,1061],{"class":47,"line":670},[45,1062,791],{},[45,1064,1065],{"class":47,"line":676},[45,1066,796],{},[45,1068,1069],{"class":47,"line":682},[45,1070,1071],{},"          users.map((user) =>(\n",[45,1073,1075],{"class":47,"line":1074},33,[45,1076,1077],{},"            \u003Cli key={ user.email }>\n",[45,1079,1081],{"class":47,"line":1080},34,[45,1082,1083],{},"              { `Name：${user.name.title}.${user.name.first } ${user.name.last}, Age：${user.dob.age}` }\n",[45,1085,1087],{"class":47,"line":1086},35,[45,1088,816],{},[45,1090,1092],{"class":47,"line":1091},36,[45,1093,821],{},[45,1095,1097],{"class":47,"line":1096},37,[45,1098,826],{},[45,1100,1102],{"class":47,"line":1101},38,[45,1103,831],{},[45,1105,1107],{"class":47,"line":1106},39,[45,1108,661],{},[45,1110,1112],{"class":47,"line":1111},40,[45,1113,667],{},[45,1115,1117],{"class":47,"line":1116},41,[45,1118,673],{},[45,1120,1122],{"class":47,"line":1121},42,[45,1123,87],{"emptyLinePlaceholder":86},[45,1125,1127],{"class":47,"line":1126},43,[45,1128,679],{},[45,1130,1132],{"class":47,"line":1131},44,[45,1133,685],{},[17,1135,1136,1137,1140,1141,1143,1144,1146],{},"Sure, the screen displays correctly and the sorting works, but honestly this isn't great. Every time we click a button it fires ",[21,1138,1139],{},"filterUsers",", and ",[21,1142,1139],{}," re-sorts. That's a waste of performance, because all we want is to re-sort, not re-render the whole thing. So we can use ",[21,1145,23],{}," to optimize this.",[17,1148,1149,1150,1152,1153,1156,1157,1160,1161,1163,1164,1167],{},"Quick side note: you might notice that inside ",[21,1151,1139],{},", my ",[21,1154,1155],{},"setUsers"," spreads the array back out with ",[21,1158,1159],{},"setUsers([...newUser]);",". The reason I write it that way is that ",[21,1162,921],{}," mutates the original array directly. So if you just do ",[21,1165,1166],{},"setUsers(newUser);",", you'll find the screen doesn't re-render — because as far as React is concerned, the data didn't change, so it sees no reason to re-render. We have to spread the array so React realizes the data was modified, and then it'll re-render.",[17,1169,1170,1171,1173,1174,1176,1177,1180,1181,1183],{},"Now let's look at the ",[21,1172,23],{}," Hook and how to write it. It's actually really simple — just treat it like you're writing Vue's ",[21,1175,71],{},", except here we specifically watch the ",[21,1178,1179],{},"state"," value and only fire ",[21,1182,23],{}," when it changes:",[36,1185,1187],{"className":524,"code":1186,"language":526,"meta":41,"style":41},"const App = () => {\n  const [ users, setUsers ] = React.useState([]);;\n  const [ state, setState ] = React.useState(false);\n\n  const getUsers = async() => {\n    const { data } = await axios.get('https:\u002F\u002Frandomuser.me\u002Fapi\u002F?results=10');\n    setUsers(data.results);\n  }\n\n  React.useEffect(() => {\n    getUsers();\n  }, []);\n\n  const filterUsers = React.useMemo(() => {\n    return users.sort((a, b) =>  {\n      if(state) {\n        return a.dob.age \u003C b.dob.age ? 1 : -1\n      }\n      return a.dob.age > b.dob.age ? 1 : -1\n    });\n  }, [ state ])\n\n  return (\n    \u003Cdiv>\n      \u003Cbutton onClick={ () => setState(true) } className=\"border-4 border-indigo-500\">Age high to low\u003C\u002Fbutton>\n      \u003Cbutton onClick={ () => setState(false) }className=\"border-4 border-indigo-500 ml-4\">Age low to high\u003C\u002Fbutton>\n      \u003Chr className=\"my-4\"\u002F>\n      \u003Cul>\n        {\n          filterUsers.map((user, index) => (\n            \u003Cli key={ user.email }>\n              { `Name：${user.name.title}.${user.name.first } ${user.name.last}, Age：${user.dob.age}` }\n            \u003C\u002Fli>\n          ))\n        }\n      \u003C\u002Ful>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,1188,1189,1193,1197,1201,1205,1209,1213,1217,1221,1225,1229,1233,1237,1241,1246,1251,1255,1259,1263,1267,1271,1276,1280,1284,1288,1293,1298,1302,1306,1310,1315,1319,1323,1327,1331,1335,1339,1343,1347,1351,1355,1359],{"__ignoreMap":41},[45,1190,1191],{"class":47,"line":48},[45,1192,533],{},[45,1194,1195],{"class":47,"line":83},[45,1196,936],{},[45,1198,1199],{"class":47,"line":90},[45,1200,941],{},[45,1202,1203],{"class":47,"line":108},[45,1204,87],{"emptyLinePlaceholder":86},[45,1206,1207],{"class":47,"line":117},[45,1208,950],{},[45,1210,1211],{"class":47,"line":140},[45,1212,746],{},[45,1214,1215],{"class":47,"line":171},[45,1216,751],{},[45,1218,1219],{"class":47,"line":177},[45,1220,201],{},[45,1222,1223],{"class":47,"line":186},[45,1224,87],{"emptyLinePlaceholder":86},[45,1226,1227],{"class":47,"line":192},[45,1228,764],{},[45,1230,1231],{"class":47,"line":198},[45,1232,975],{},[45,1234,1235],{"class":47,"line":204},[45,1236,774],{},[45,1238,1239],{"class":