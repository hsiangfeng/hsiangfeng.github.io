[{"data":1,"prerenderedAt":1443},["ShallowReactive",2],{"header-locale:\u002Fen\u002Freact\u002F2022\u002F09\u002F27\u002Freact-day-13-usememo\u002F":3,"page:\u002Fen\u002Freact\u002F2022\u002F09\u002F27\u002Freact-day-13-usememo\u002F":4,"alt:\u002Fen\u002Freact\u002F2022\u002F09\u002F27\u002Freact-day-13-usememo\u002F":3,"prev-next:\u002Fen\u002Freact\u002F2022\u002F09\u002F27\u002Freact-day-13-usememo\u002F":1419,"related:\u002Fen\u002Freact\u002F2022\u002F09\u002F27\u002Freact-day-13-usememo\u002F":1428},"\u002Freact\u002F20220927\u002F2876847129\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1402,"date":1403,"description":1404,"extension":1405,"lang":1406,"meta":1407,"navigation":86,"path":1408,"readingMinutes":1409,"seo":1410,"standalone":1411,"stem":1412,"tags":1413,"tldr":1416,"updated":1403,"url":1417,"__hash__":1418},"content\u002Fen\u002FReact\u002Freact-day-13-usememo.md","React Day 13: useMemo, Basically React's Version of Vue Computed","1002914195",{"type":9,"value":10,"toc":1396},"minimark",[11,16,28,32,35,230,241,251,258,475,480,501,507,510,516,522,686,691,699,702,705,711,714,856,861,872,891,906,912,923,1134,1147,1168,1184,1363,1368,1374,1378,1381,1392],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24,25,27],"p",{},"Starting this chapter, we're going to meet a new Hook: ",[21,22,23],"code",{},"useMemo",". But before we dig into ",[21,26,23],{}," itself, let me take you back to Vue for a second and look at something pretty similar — Vue's Computed.",[12,29,31],{"id":30},"vue-computed","Vue Computed",[17,33,34],{},"First, let's jog our memory on how Vue Computed works. Here's a simple example:",[36,37,42],"pre",{"className":38,"code":39,"language":40,"meta":41,"style":41},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","const { createApp, ref, computed } = Vue;\n\nconst app = createApp({\n  setup() {\n    const num1 = ref(2);\n    const total = computed(() => num1.value * 2)\n    \n   