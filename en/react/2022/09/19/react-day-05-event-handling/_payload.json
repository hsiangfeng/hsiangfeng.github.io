(\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,652,653],{},"This is exactly why you keep hearing people say that writing React feels like writing plain JavaScript.",[17,655,656],{},"Here's a quick list of the common React events:",[373,658,659,664,669,674,679,684],{},[376,660,661],{},[31,662,663],{},"onClick",[376,665,666],{},[31,667,668],{},"onChange",[376,670,671],{},[31,672,673],{},"onSubmit",[376,675,676],{},[31,677,678],{},"onKeyDown",[376,680,681],{},[31,682,683],{},"onFocus",[376,685,686],{},[31,687,688],{},"onBlur",[17,690,691,692,694,695,698],{},"And remember: React's syntax is ",[31,693,367],{}," — never ",[31,696,697],{},"on+[eventName]=\"name()\"","!",[17,700,701],{},"Reading descriptions only gets you so far, so I'll write a quick example for each one.",[161,703,663],{"id":273},[17,705,706,707,709],{},"We've already written ",[31,708,663],{}," examples a bunch of times, but let's look at it once more anyway so the pattern really sticks.",[17,711,712,714,715,717],{},[31,713,663],{}," is the most basic click event — when you click, it fires the function you passed in. If you don't pass any arguments and just hand it a function name, React passes in an ",[31,716,308],{}," (the click event) by default:",[44,719,721],{"className":349,"code":720,"language":351,"meta":49,"style":49},"const App = () => {\n  const handler = (event) => {\n    event.preventDefault()\n    window.alert('Click！');\n  }\n\n  return (\n    \u003Cdiv>\n      \u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" onClick={ handler }>Click me\u003C\u002Fa>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n",[31,722,723,728,733,738,743,747,751,756,761,766,771,775,779,783,788,793],{"__ignoreMap":49},[53,724,725],{"class":55,"line":56},[53,726,727],{},"const App = (