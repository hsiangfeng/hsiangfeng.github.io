[{"data":1,"prerenderedAt":1882},["ShallowReactive",2],{"header-locale:\u002Fen\u002Freact\u002F2022\u002F09\u002F19\u002Freact-day-05-event-handling\u002F":3,"page:\u002Fen\u002Freact\u002F2022\u002F09\u002F19\u002Freact-day-05-event-handling\u002F":4,"alt:\u002Fen\u002Freact\u002F2022\u002F09\u002F19\u002Freact-day-05-event-handling\u002F":3,"prev-next:\u002Fen\u002Freact\u002F2022\u002F09\u002F19\u002Freact-day-05-event-handling\u002F":1859,"related:\u002Fen\u002Freact\u002F2022\u002F09\u002F19\u002Freact-day-05-event-handling\u002F":1868},"\u002Freact\u002F20220919\u002F515545639\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1838,"date":1839,"description":1840,"extension":1841,"lang":1842,"meta":1843,"navigation":500,"path":1844,"readingMinutes":1845,"seo":1846,"standalone":1847,"stem":1848,"tags":1849,"tldr":1856,"updated":1839,"url":1857,"__hash__":1858},"content\u002Fen\u002FReact\u002Freact-day-05-event-handling.md","React Basics: Event Handling, and Why React Feels Like Plain JavaScript (5)","1003080494",{"type":9,"value":10,"toc":1822},"minimark",[11,16,20,24,27,43,98,109,120,152,157,160,165,180,186,213,243,248,255,258,262,275,318,323,337,340,347,358,362,369,372,382,386,389,396,399,404,411,641,646,649,652,684,694,697,699,705,713,793,798,804,807,831,921,926,931,934,951,1193,1198,1225,1230,1233,1247,1438,1443,1448,1451,1456,1613,1618,1623,1626,1629,1790,1795,1800,1803,1807,1810,1818],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Let's talk about event handling in React. It's one of those things you'll be doing constantly once you start building anything real, so it's worth slowing down on.",[12,21,23],{"id":22},"event-handling-in-vue","Event handling in Vue",[17,25,26],{},"First, a quick detour through Vue — a lot of us land on React after Vue, so this gives us a nice point of comparison.",[17,28,29,30,34,35,38,39,42],{},"Vue uses the ",[31,32,33],"code",{},"v-on:eventName=\"function\""," pattern. Here's a click event (",[31,36,37],{},"click",") that fires a little greeting function (",[31,40,41],{},"sayHi","):",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-js shiki shiki-themes github-dark-high-contrast","\u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" v-on:click=\"sayHi\">Click me\u003C\u002Fa>\n","js","",[31,51,52],{"__ignoreMap":49},[53,54,57,61,65,69,73,77,80,83,85,87,90,93,95],"span",{"class":55,"line":56},"line",1,[53,58,60],{"class":59},"sMAXC","\u003C",[53,62,64],{"class":63},"sKpQp","a",[53,66,68],{"class":67},"sCcAr"," href",[53,70,72],{"class":71},"sWyjQ","=",[53,74,76],{"class":75},"sTRMh","\"https:\u002F\u002Fisraynotarray.com\u002F\"",[53,78,79],{"class":67}," v-on",[53,81,82],{"class":59},":",[53,84,37],{"class":67},[53,86,72],{"class":71},[53,88,89],{"class":75},"\"sayHi\"",[53,91,92],{"class":59},">Click me\u003C\u002F",[53,94,64],{"class":63},[53,96,97],{"class":59},">\n",[99,100,108],"iframe",{"height":101,"style":102,"scrolling":103,"title":104,"src":105,"frameBorder":103,"loading":106,"allowTransparency":107,"allowFullScreen":107},300,"width: 100%;","no","(12)Vue Options API","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FdymaJrd?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FdymaJrd\">\n  (12)Vue Options API\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,110,111,112,115,116,119],{},"In practice though, you rarely actually type out ",[31,113,114],{},"v-on:",". Most of the time you use the ",[31,117,118],{},"@"," shorthand instead:",[44,121,125],{"className":122,"code":123,"language":124,"meta":49,"style":49},"language-html shiki shiki-themes github-dark-high-contrast","\u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" @click=\"sayHi\">Click me\u003C\u002Fa>\n","html",[31,126,127],{"__ignoreMap":49},[53,128,129,131,133,135,137,139,142,144,146,148,150],{"class":55,"line":56},[53,130,60],{"class":59},[53,132,64],{"class":63},[53,134,68],{"class":67},[53,136,72],{"class":59},[53,138,76],{"class":75},[53,140,141],{"class":67}," @click",[53,143,72],{"class":59},[53,145,89],{"class":75},[53,147,92],{"class":59},[53,149,64],{"class":63},[53,151,97],{"class":59},[99,153,156],{"height":101,"style":102,"scrolling":103,"title":154,"src":155,"frameBorder":103,"loading":106,"allowTransparency":107,"allowFullScreen":107},"(41)Vue v-on:click","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FPoRVELX?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FPoRVELX\">\n  (41)Vue v-on:click\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,158,159],{},"And that's the most basic way to handle events in Vue.",[161,162,164],"h3",{"id":163},"vue-event-modifiers","Vue event modifiers",[17,166,167,168,174,175,179],{},"If you played with the example above, you'll notice that after the alert pops up, the page jumps straight to my ",[64,169,173],{"href":170,"rel":171},"https:\u002F\u002Fisraynotarray.com\u002F",[172],"nofollow","blog"," (",[176,177,178],"del",{},"which, okay, was kind of the plan all along",").",[17,181,182],{},[183,184],"img",{"alt":173,"src":185},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Fithelp2022-react\u002F1660976432055.png",[17,187,188,189,192,193,196,197,201,202,205,206,208,209,212],{},"That's happening because the link has a default behavior — it redirects to the ",[31,190,191],{},"href"," URL, the same way a form's ",[31,194,195],{},"action"," path kicks in on submit. To stop it, Vue gives you ",[198,199,200],"strong",{},"event modifiers",". There are a bunch of them, but I'll only cover one here: ",[31,203,204],{},".prevent",". Just tack ",[31,207,204],{}," onto your ",[31,210,211],{},"@click"," and the redirect problem goes away:",[44,214,216],{"className":122,"code":215,"language":124,"meta":49,"style":49},"\u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" @click.prevent=\"sayHi\">Click me\u003C\u002Fa>\n",[31,217,218],{"__ignoreMap":49},[53,219,220,222,224,226,228,230,233,235,237,239,241],{"class":55,"line":56},[53,221,60],{"class":59},[53,223,64],{"class":63},[53,225,68],{"class":67},[53,227,72],{"class":59},[53,229,76],{"class":75},[53,231,232],{"class":67}," @click.prevent",[53,234,72],{"class":59},[53,236,89],{"class":75},[53,238,92],{"class":59},[53,240,64],{"class":63},[53,242,97],{"class":59},[99,244,247],{"height":101,"style":102,"scrolling":103,"title":245,"src":246,"frameBorder":103,"loading":106,"allowTransparency":107,"allowFullScreen":107},"(42)Vue @click","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FrNdPJYG?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FrNdPJYG\">\n  (42)Vue @click\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,249,250,251,254],{},"So with an ",[198,252,253],{},"event modifier"," we stop the link from jumping away on click.",[17,256,257],{},"Okay, that's our quick refresher on Vue event handling and event modifiers. So what about React? Let's keep going.",[12,259,261],{"id":260},"event-handling-in-react","Event handling in React",[17,263,264,265,267,268,270,271,274],{},"We just recapped that Vue handles events with ",[31,266,114],{}," and ",[31,269,118],{},". React's a little different — but if you've ever written an old-school ",[31,272,273],{},"onclick",", React's approach is going to feel really familiar:",[44,276,278],{"className":122,"code":277,"language":124,"meta":49,"style":49},"\u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" onclick=\"sayHi(event)\">Click me\u003C\u002Fa>\n",[31,279,280],{"__ignoreMap":49},[53,281,282,284,286,288,290,292,295,297,300,303,306,309,312,314,316],{"class":55,"line":56},[53,283,60],{"class":59},[53,285,64],{"class":63},[53,287,68],{"class":67},[53,289,72],{"class":59},[53,291,76],{"class":75},[53,293,294],{"class":67}," onclick",[53,296,72],{"class":59},[53,298,299],{"class":75},"\"",[53,301,41],{"class":302},"sj_SG",[53,304,305],{"class":75},"(",[53,307,308],{"class":59},"event",[53,310,311],{"class":75},")\"",[53,313,92],{"class":59},[53,315,64],{"class":63},[53,317,97],{"class":59},[99,319,322],{"height":101,"style":102,"scrolling":103,"title":320,"src":321,"frameBorder":103,"loading":106,"allowTransparency":107,"allowFullScreen":107},"(40) React JSX - className","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FRwMvQxO?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FRwMvQxO\">\n  (40) React JSX - className\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,324,325,326,328,329,332,333,336],{},"That ",[31,327,273],{}," example is what we call an ",[198,330,331],{},"inline event",", usually written as ",[31,334,335],{},"on+[eventName]=\"function()\"",". In real-world projects we actually try to avoid inline events — I won't get into why here, since that's a whole other topic.",[17,338,339],{},"Back to React.",[17,341,342,343,346],{},"So why did I bother bringing up ",[198,344,345],{},"inline events","? Because React's event handling looks about 87% identical to it. Here's how a click event looks in React:",[44,348,352],{"className":349,"code":350,"language":351,"meta":49,"style":49},"language-jsx shiki shiki-themes github-dark-high-contrast","\u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" onClick={ sayHi }>Click me\u003C\u002Fa>\n","jsx",[31,353,354],{"__ignoreMap":49},[53,355,356],{"class":55,"line":56},[53,357,350],{},[99,359,361],{"height":101,"style":102,"scrolling":103,"title":320,"src":360,"frameBorder":103,"loading":106,"allowTransparency":107,"allowFullScreen":107},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FMWVLQXv?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FMWVLQXv\">\n  (40) React JSX - className\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,363,364,365,368],{},"So yeah, inline events and React event handling are nearly twins, but React's syntax is ",[31,366,367],{},"on+[eventName]={ function }"," — the event name starts with a capital letter and uses camelCase.",[17,370,371],{},"Let me list the two key differences:",[373,374,375,379],"ul",{},[376,377,378],"li",{},"Inline events are all lowercase; React event handling is camelCase.",[376,380,381],{},"Inline events take a string; React event handling takes a function.",[161,383,385],{"id":384},"does-react-have-event-modifiers","Does React have event modifiers?",[17,387,388],{},"At this point you might be wondering...",[17,390,391,392,395],{},"Does React have event modifiers like Vue does? And if so, would you write something like ",[31,393,394],{},"onClick.prevent={ sayHi }","?",[17,397,398],{},"Smart question! And the answer is...",[17,400,401],{},[198,402,403],{},"Nope, no such thing!",[17,405,406,407,410],{},"The reason is simple: React basically feels like writing plain JavaScript, so you have to explicitly call ",[31,408,409],{},"preventDefault();"," yourself to stop the default behavior:",[44,412,414],{"className":46,"code":413,"language":48,"meta":49,"style":49},"const App = () => {\n  const sayHi = (e) => {\n    e.preventDefault()\n    window.alert('Hello！');\n  }\n\n  return (\n    \u003Cdiv>\n      \u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" onClick={ sayHi }>Click me\u003C\u002Fa>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n",[31,415,416,436,460,472,489,495,502,511,522,554,564,570,576,581,604,623],{"__ignoreMap":49},[53,417,418,421,424,427,430,433],{"class":55,"line":56},[53,419,420],{"class":71},"const",[53,422,423],{"class":302}," App",[53,425,426],{"class":71}," =",[53,428,429],{"class":59}," () ",[53,431,432],{"class":71},"=>",[53,434,435],{"class":59}," {\n",[53,437,439,442,445,447,449,453,456,458],{"class":55,"line":438},2,[53,440,441],{"class":71},"  const",[53,443,444],{"class":302}," sayHi",[53,446,426],{"class":71},[53,448,174],{"class":59},[53,450,452],{"class":451},"s_sBn","e",[53,454,455],{"class":59},") ",[53,457,432],{"class":71},[53,459,435],{"class":59},[53,461,463,466,469],{"class":55,"line":462},3,[53,464,465],{"class":59},"    e.",[53,467,468],{"class":302},"preventDefault",[53,470,471],{"class":59},"()\n",[53,473,475,478,481,483,486],{"class":55,"line":474},4,[53,476,477],{"class":59},"    window.",[53,479,480],{"class":302},"alert",[53,482,305],{"class":59},[53,484,485],{"class":75},"'Hello！'",[53,487,488],{"class":59},");\n",[53,490,492],{"class":55,"line":491},5,[53,493,494],{"class":59},"  }\n",[53,496,498],{"class":55,"line":497},6,[53,499,501],{"emptyLinePlaceholder":500},true,"\n",[53,503,505,508],{"class":55,"line":504},7,[53,506,507],{"class":71},"  return",[53,509,510],{"class":59}," (\n",[53,512,514,517,520],{"class":55,"line":513},8,[53,515,516],{"class":59},"    \u003C",[53,518,519],{"class":63},"div",[53,521,97],{"class":59},[53,523,525,528,530,532,534,536,539,542,545,548,550,552],{"class":55,"line":524},9,[53,526,527],{"class":59},"      \u003C",[53,529,64],{"class":63},[53,531,68],{"class":67},[53,533,72