n.io\">CodePen\u003C\u002Fa>.\n",[17,647,648],{},"This is exactly why you keep hearing people say that writing React feels like writing plain JavaScript.",[17,650,651],{},"Here's a quick list of the common React events:",[373,653,654,659,664,669,674,679],{},[376,655,656],{},[31,657,658],{},"onClick",[376,660,661],{},[31,662,663],{},"onChange",[376,665,666],{},[31,667,668],{},"onSubmit",[376,670,671],{},[31,672,673],{},"onKeyDown",[376,675,676],{},[31,677,678],{},"onFocus",[376,680,681],{},[31,682,683],{},"onBlur",[17,685,686,687,689,690,693],{},"And remember: React's syntax is ",[31,688,367],{}," — never ",[31,691,692],{},"on+[eventName]=\"name()\"","!",[17,695,696],{},"Reading descriptions only gets you so far, so I'll write a quick example for each one.",[161,698,658],{"id":273},[17,700,701,702,704],{},"We've already written ",[31,703,658],{}," examples a bunch of times, but let's look at it once more anyway so the pattern really sticks.",[17,706,707,709,710,712],{},[31,708,658],{}," is the most basic click event — when you click, it fires the function you passed in. If you don't pass any arguments and just hand it a function name, React passes in an ",[31,711,308],{}," (the click event) by default:",[44,714,716],{"className":349,"code":715,"language":351,"meta":49,"style":49},"const App = () => {\n  const handler = (event) => {\n    event.preventDefault()\n    window.alert('Click！');\n  }\n\n  return (\n    \u003Cdiv>\n      \u003Ca href=\"https:\u002F\u002Fisraynotarray.com\u002F\" onClick={ handler }>Click me\u003C\u002Fa>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n",[31,717,718,723,728,733,738,742,746,751,756,761,766,770,774,778,783,788],{"__ignoreMap":49},[53,719,720],{"class":55,"line":56},[53,721,722],{},"const App = () => {\n",[53,724,725],{"class":55,"line":438},[53,726,727],{},"  const handler = (event) => {\n",[53,729,730],{"class":55,"line":462},