," prop — but in practice this one gets replaced by ",[38,559,373],{},[17,561,562,563,565,566,569,570,572],{},"So how do we actually use it? First off, ",[38,564,386],{}," is itself a kind of React component, so all you need to do is wrap the outer layer of your components with ",[38,567,568],{},"DataContext"," and attach the value you plan to share across components. Then we tweak the ",[38,571,352],{}," part a little.",[56,574,576],{"className":58,"code":575,"language":60,"meta":61,"style":61},"\u002F\u002F ...snip\nconst Card = ({ data }) => {\n  return (\n    \u003Cdiv>\n      \u003Ch5>產品名稱：{ data.title }\u003C\u002Fh5>\n      \u003CButton\u002F>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst Products = () => {\n  const [ data, setData ] = React.useState({\n    title: 'PlayStation5',\n    price: 75000,\n  });\n\n  return (\n    \u003CDataContext.Provider value={ data }>\n      \u003Cul>\n        \u003Cli key={ data.title }>\n          \u003CCard data={ data } \u002F>\n        \u003C\u002Fli>\n      \u003C\u002Ful>\n    \u003C\u002FDataContext.Provider>\n  )\n}\n\u002F\u002F ...snip\n",[38,577,578,583,587,591,595,599,604,608,612,616,620,624,628,632,636,640,644,648,653,657,661,665,669,673,678,682,686],{"__ignoreMap":61},[65,579,580],{"class":67,"line":68},[65,581,582],{},"\u002F\u002F ...snip\n",[65,584,585],{"class":67,"line":74},[65,586,131],{},[65,588,589],{"class":67,"line":80},[65,590,102],{},[65,592,593],{"class":67,"line":86},[65,594,142],{},[65,596,597],{"class":67,"line":92},[65,598,148],{},[65,600,601],{"class":67,"line":99},[65,602,603],{},"      \u003CButton\u002F>\n",[65,605,606],{"class":67,"line":105},[65,607,160],{},[65,609,610],{"class":67,"line":111},[65,611,114],{},[65,613,614],{"class":67,"line":117},[65,615,120],{},[65,617,618],{"class":67,"line":123},[65,619,96],{"emptyLinePlaceholder":95},[65,621,622],{"class":67,"line":128},[65,623,186],{},[65,625,626],{"class":67,"line":134},[65,627,192],{},[65,629,630],{"class":67,"line":139},[65,631,198],{},[65,