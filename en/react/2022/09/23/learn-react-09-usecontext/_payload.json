2,"src":343,"frameBorder":341,"loading":344,"allowTransparency":345,"allowFullScreen":345},300,"width: 100%;","no","(76) React  Props","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FOJZLqed?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FOJZLqed\">\n  (76) React  Props\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,348,349,350,353,354,357,358,360,361,363,364,367,368,370,371,374],{},"In the example, ",[38,351,352],{},"Card"," only actually uses ",[38,355,356],{},"title",". But because ",[38,359,40],{}," needs both ",[38,362,356],{}," and ",[38,365,366],{},"price",", we're forced to pass the whole data object down just so ",[38,369,40],{}," can use it. That means we end up unintentionally passing a ton of data around, and the data flow keeps getting bigger and more tangled. So this is exactly where we need a technique for cross-component communication — which is the thing this chapter is all about: ",[38,372,373],{},"useContext",".",[12,376,373],{"id":377},"usecontext",[17,379,380,381,383,384,387,388,390,391,393],{},"Before we can use ",[38,382,373],{},", there's one thing we need to meet first: ",[38,385,386],{},"createContext",". When you're setting up cross-component communication, you start by using ",[38,389,386],{}," to create a Context Object, because ",[38,392,373],{}," only works when you hand it a Context Object.",[56,395,397],{"className":58,"code":396,"language":60,"meta":61,"style":61},"const DataContext = React.createContext();\n",[38,398,399],{"__ignoreMap":61},[65,400,401],{"class":67,"line":68},[65,402,396],{},[337,404,406],{"height":339,"style":340,"scrolling":341,"title":342,"src":405,"frameBorder":341,"loading":344,"allowTransparency":345,"allowFullScreen":345},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FrNvNbdy?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FrNvNbdy\">\n  (76) React  Props\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,408,409,410,412],{},"Keep this in mind: ",[38,411,373],{}," only accepts a Context Object.",[56,414,416],{"className":58,"code":415,"language":60,"meta":61,"style":61},"const DataContext = React.createContext();\n\nconst App = () => {\n  \u002F\u002F ✅ Good! This is the correct useContext usage\n  const data = useContext(DataContext);\n\n  \u002F\u002F ❌ Error! Not valid useContext usage\n  const data = useContext('DataContext');\n\n  \u002F\u002F ❌ Error! Not valid useContext usage\n  const data = useContext();\n\n  \u002F\u002F ❌ Error! Not valid useContext usage\n  const data = useContext(DataContext.Provider);\n  return (\n    \u003Cdiv>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n",[38,417,418,422,426,430,435,440,444,449,454,458,462,467,471,475,480,484,488,492,496,500,504,508,512],{"__ignoreMap":61},[65,419,420],{"class":67,"line":68},[65,421,396],{},[65,423,424],{"class":67,"line":74},[65,425,96],{"emptyLinePlaceholder":95},[65,427,428],{"class":67,"line":80},[65,429,281],{},[65,431,432],{"class":67,"line":86},[65,433,434],{},"  \u002F\u002F ✅ Good! This is the correct useContext usage\n",[65,436,437],{"class":67,"line":92},[65,438,439],{},"  const data = useContext(DataContext);\n",[65,441,442],{"class":67,"line":99},[65,443,96],{"emptyLinePlaceholder":95},[65,445,446],{"class":67,"line":105},[65,447,448],{},"  \u002F\u002F ❌ Error! Not valid useContext usage\n",[65,450,451],{"class":67,"line":111},[65,452,453],{},"  const data = useContext('DataContext');\n",[65,455,456],{"class":67,"line":117}