 pay }>點我購買({ data.price } $)\u003C\u002Fbutton>\n  )\n}\n\n\u002F\u002F ...snip\n",[38,717,718,722,726,731,736,741,745,749,753,757,761,765,769,773,777],{"__ignoreMap":61},[65,719,720],{"class":67,"line":68},[65,721,582],{},[65,723,724],{"class":67,"line":74},[65,725,96],{"emptyLinePlaceholder":95},[65,727,728],{"class":67,"line":80},[65,729,730],{},"const Button = () => {\n",[65,732,733],{"class":67,"line":86},[65,734,735],{},"  const data = React.useContent(DataContext);\n",[65,737,738],{"class":67,"line":92},[65,739,740],{},"  \n",[65,742,743],{"class":67,"line":99},[65,744,77],{},[65,746,747],{"class":67,"line":105},[65,748,83],{},[65,750,751],{"class":67,"line":111},[65,752,89],{},[65,754,755],{"class":67,"line":117},[65,756,96],{"emptyLinePlaceholder":95},[65,758,759],{"class":67,"line":123},[65,760,102],{},[65,762,763],{"class":67,"line":128},[65,764,108],{},[65,766,767],{"class":67,"line":134},[65,768,114],{},[65,770,771],{"class":67,"line":139},[65,772,120],{},[65,774,775],{"class":67,"line":145},[65,776,96],{"emptyLinePlaceholder":95},[65,778,779],{"class":67,"line":151},[65,780,582],{},[17,782,783,784,786,787,712],{},"And just like that, you've got cross-component passing working. Notice that ",[38,785,40],{}," no longer receives anything through Props — it pulls the data in via ",[38,788,373],{},[337,790,694],{"height":339,"style":340,"scrolling":341,"title":692,"src":693,"frameBorder":341,"loading":344,"allowTransparency":345,"allowFullScreen":345},[17,792,793],{},"Now let me throw up another diagram so we can see how the data is flowing at this point.",[17,795,796],{},[30,797],{"alt":798,"src":799},"data skipping over Card straight to Button","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Fithelp2022-react\u002F202209040119.png",[17,801,802,803,805,806,808],{},"From the image above you can see the data skips right over ",[38,804,352],{}," and goes straight to the ",[38,807,40],{}," component.",[17,810,811],{},"This concept is basically a dead ringer for Vue's Provide \u002F Inject — you get to decide on your own whenever you want to Inject. Later on we'll get into some simple hands-on building so all these earlier ideas tie together.",[17,813,814,815,817,818,820,821,824],{},"One small thing to watch out for: when you use ",[38,816,535],{},", the only thing it can receive is ",[38,819,543],{},". If you switch it to ",[38,822,823],{},"data={ data }",", it actually won't pass anything through.",[12,826,828],{"id":827},"afterword","Afterword",[17,830,831],{},"This article is also published on my blog:",[528,833,834],{},[531,835,836],{},[837,838,842],"a",{"href":839,"rel":840},"https:\u002F\u002Fisraynotarray.com\u002F",[841],"nofollow","Is Ray not Array",[844,845,846],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":61,"searchDepth":74,"depth":74,"links":848},[849,850,851,852],{"id":14,"depth":74,"text":15},{"id":22,"depth":74,"text":23},{"id":377,"depth":74,"text":373},{"id":827,"depth":74,"text":828},"React","2022-09-23 00:00:01","In the earlier chapters we got a first look at how React passes data between components with Props. The thing is, Props always flow from the top down. That one-way flow keeps your data predictable, but it also creates a classic headache: you end up passing data way too deep. So in this chapter we'll meet something new that fixes exactly that — useContext.","md","en",{},"\u002Fen\u002Freact\u002Flearn-react-09-usecontext","4",{"title":6,"description":855},false,"en\u002FReact\u002Flearn-react-09-usecontext",[865,866,373],"You'll Learn React Eventually, So Why Not Now?","React Basics",null,"\u002Fen\u002Freact\u002F2022\u002F09\u002F23\u002Flearn-react-09-usecontext\u002F","q0balEpGt6AGSJImvXZ_Edg7s06q1hQKMHqhpTpU8HE",{"newer":871,"older":875},{"url":872,"title":873,"date":874},"\u002Fen\u002Freact\u002F2022\u002F09\u002F24\u002Flearn-react-now-10-todolist-part-1\u002F","You'll Learn React Eventually, So Why Not Now? — React Basics: Building a TodoList (Part 1) - (10)","2022-09-24 00:00:01",{"url":876,"title":877,"date":878},"\u002Fen\u002Freact\u002F2022\u002F09\u002F22\u002Freact-08-useeffect\u002F","React Basics: Getting to Know useEffect (and Side Effects) — (8)","2022-09-22 00:00:01",[880,884,889],{"url":881,"title":882,"date":883,"readingMinutes":860},"\u002Fen\u002Freact\u002F2022\u002F10\u002F14\u002Flearn-react-now-30-wrap-up-and-toc\u002F","Learn React Now — Wrap-up Notes & Full Table of Contents (30)","2022-10-14 00:00:01",{"url":885,"title":886,"date":887,"readingMinutes":888},"\u002Fen\u002Freact\u002F2022\u002F10\u002F13\u002Flearn-react-29-react-redux-quick-start\u002F","Learn React Eventually, So Why Not Now? - React Redux: Redux and a Quick Start - (29)","2022-10-13 00:00:01","6",{"url":890,"title":891,"date":892,"readingMinutes":860},"\u002Fen\u002Freact\u002F2022\u002F10\u002F12\u002Freact-day-28-router-lazy-loading\u002F","Why Learn React Eventually? Learn It Now! - React Router Lazy Loading (28)","2022-10-12 00:00:01",1784011710436]