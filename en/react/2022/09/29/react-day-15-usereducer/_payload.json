n",[21,552,553,557,562,567,572,576,580,587,593,599,604,609,614,620,626,631,637,643,649,655,661,667,673,678,683,688,694],{"__ignoreMap":79},[83,554,555],{"class":85,"line":86},[83,556,253],{},[83,558,559],{"class":85,"line":211},[83,560,561],{},"  switch(action.type) {\n",[83,563,564],{"class":85,"line":223},[83,565,566],{},"    default:\n",[83,568,569],{"class":85,"line":339},[83,570,571],{},"      return { count: 0 }\n",[83,573,574],{"class":85,"line":353},[83,575,356],{},[83,577,578],{"class":85,"line":359},[83,579,263],{},[83,581,583],{"class":85,"line":582},7,[83,584,586],{"emptyLinePlaceholder":585},true,"\n",[83,588,590],{"class":85,"line":589},8,[83,591,592],{},"const initialState = {\n",[83,594,596],{"class":85,"line":595},9,[83,597,598],{},"  count: 0,\n",[83,600,602],{"class":85,"line":601},10,[83,603,226],{},[83,605,607],{"class":85,"line":606},11,[83,608,586],{"emptyLinePlaceholder":585},[83,610,612],{"class":85,"line":611},12,[83,613,586],{"emptyLinePlaceholder":585},[83,615,617],{"class":85,"line":616},13,[83,618,619],{},"const App = () => {\n",[83,621,623],{"class":85,"line":622},14,[83,624,625],{},"  const [state, dispatch] = React.useReducer(reducer, initialState);\n",[83,627,629],{"class":85,"line":628},15,[83,630,586],{"emptyLinePlaceholder":585},[83,632,634],{"class":85,"line":633},16,[83,635,636],{},"  return (\n",[83,638,640],{"class":85,"line":639},17,[83,641,642],{},"    \u003Cdiv>\n",[83,644,646],{"class":85,"line":645},18,[83,647,648],{},"      Count: {state.count}\n",[83,650,652],{"class":85,"line":651},19,[83,653,654],{},"      \u003Cbr \u002F>\n",[83,656,658],{"class":85,"line":657},20,[83,659,660],{},"      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"decrement\" })}>Decrement\u003C\u002Fbutton>｜\n",[83,662,664],{"class":85,"line":663},21,[83,665,666],{},"      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() =