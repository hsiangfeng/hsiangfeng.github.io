nt':\n      return {\n        count: state.count + 1\n      };\n    case 'decrement':\n      return {\n        count: state.count - 1\n      };\n    default:\n      return {\n        count: 0\n      }\n  }\n}\n",[21,742,743,765,771,782,788,799,804,813,819,828,832,838,844,852,857,861],{"__ignoreMap":79},[83,744,745,747,749,751,753,755,757,759,761,763],{"class":85,"line":86},[83,746,197],{"class":196},[83,748,300],{"class":299},[83,750,204],{"class":196},[83,752,305],{"class":207},[83,754,167],{"class":308},[83,756,127],{"class":207},[83,758,243],{"class":308},[83,760,315],{"class":207},[83,762,318],{"class":196},[83,764,208],{"class":207},[83,766,767,769],{"class":85,"line":211},[83,768,325],{"class":196},[83,770,328],{"class":207},[83,772,773,776,780],{"class":85,"line":223},[83,774,775],{"class":196},"    case",[83,777,779],{"class":778},"sWayO"," 'increment'",[83,781,336],{"class":207},[83,783,784,786],{"class":85,"line":339},[83,785,342],{"class":196},[83,787,208],{"class":207},[83,789,790,793,796],{"class":85,"line":353},[83,791,792],{"class":207},"        count: state.count ",[83,794,795],{"class":196},"+",[83,797,798],{"class":200}," 1\n",[83,800,801],{"class":85,"line":359},[83,802,803],{"class":207},"      };\n",[83,805,806,808,811],{"class":85,"line":582},[83,807,775],{"class":196},[83,809,810],{"class":778}," 'decrement'",[83,812,336],{"class":207},[83,814,815,817],{"class":85,"line":589},[83,816,342],{"class":196},[83,818,208],{"class":207},[83,820,821,823,826],{"class":85,"line":595},[83,822,792],{"class":207},[83,824,825],{"class":196},"-",[83,827,798],{"class":200},[83,829,830],{"class":85,"line":601},[83,831,803],{"class":207},[83,833,834,836],{"class":85,"line":606},[83,835,333],{"class":196},[83,837,336],{"class":207},[83,839,840,842],{"class":85,"line":611},[83,841,342],{"class":196},[83,843,208],{"class":207},[83,845,846,849],{"class":85,"line":616},[83,847,848],{"class":207},"        count: ",[83,850,851],{"class":200},"0\n",[83,853,854],{"class":85,"line":622},[83,855,856],{"class":207},"      }\n",[83,858,859],{"class":85,"line":628},[83,860,356],{"class":207},[83,862,863],{"class":85,"line":633},[83,864,263],{"class":207},[495,866,869],{"height":497,"style":498,"scrolling":499,"title":867,"src":868,"frameBorder":499,"loading":502,"allowTransparency":503,"allowFullScreen":503},"(117) React useReducer","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FQWrpaaL?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FQWrpaaL\">\n  (117) React useReducer\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[17,871,872,873,875],{},"And there you go — your ",[21,874,23],{}," now works properly.",[17,877,878,879,881,882,884],{},"So what's the difference between ",[21,880,23],{}," and Vuex or Redux? In short, ",[21,883,23],{}," is a Hook that React provides out of the box. Note the \"out of the box\" part — it means you don't need to install anything extra to use it. With Vuex or Redux, though, those are state management libraries that live outside the framework, so you do have to install them separately.",[17,886,887,888,890,891,893,894,896,897,900],{},"Basically, if your project isn't super complex, you can totally get away with just ",[21,889,23],{},". ",[21,892,23],{}," itself is kind of a simplified Redux — but that doesn't mean it fully replaces Redux. What you can do is combine ",[21,895,23],{}," + ",[21,898,899],{},"useContext"," to build a poor-man's Redux:",[74,902,904],{"className":76,"code":903,"language":78,"meta":79,"style":79},"const CountContext = React.createContext();\n\nconst reducer = (state, action) => {\n  switch(action.type) {\n    case 'increment':\n      return {\n        count: state.count + 1\n      };\n    case 'decrement':\n      return {\n        count: state.count - 1\n      };\n    default:\n      return {\n        count: 0\n      }\n  }\n}\n\nconst initialState = {\n  count: 0,\n};\n\nconst Child = () => {\n  const [state, dispatch] = React.useContext(CountContext);\n  return (\n    \u003Cdiv>\n      Child Count: {state.count}\n      \u003Cbr \u002F>\n      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"decrement\" })}>Decrement\u003C\u002Fbutton>｜\n      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"increment\" })}>Increment\u003C\u002Fbutton>\n    \u003C\u002Fdiv>\n  );\n}\n\nconst App = () => {\n  const countReducer = React.useReducer(reducer, initialState);\n\n  return (\n    \u003Cdiv>\n      App Count: {countReducer[0].count}\n      \u003Cbr \u002F>\n      \u003CCountContext.Provider value={countReducer}>\n        \u003CChild \u002F>\n      \u003C\u002FCountContext.Provider>\n    \u003C\u002Fdiv>\n  );\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[21,905,906,911,915,919,923,928,933,938,942,947,951,956,960,964,968,973,977,981,985,989,993,997,1001,1005,1010,1015,1019,1023,1029,1034,1039,1044,1049,1054,1059,1064,1069,1075,1080,1085,1090,1096,1101,1107,1113,1119,1124,1129,1134,1139,1144],{"__ignoreMap":79},[83,907,908],{"class":85,"line":86},[83,909,910],{},"const CountContext = React.createContext();\n",[83,912,913],{"class":85,"line":211},[83,914,586],{"emptyLinePlaceholder":585},[83,916,917],{"class":85,"line":223},[83,918,253],{},[83,920,921],{"class":85,"line":339},[83,922,561],{},[83,924,925],{"class":85,"line":353},[83,926,927],{},"    case 'increment':\n",[83,929,930],{"class":85,"line":359},[83,931,932],{},"      return {\n",[83,934,935],{"class":85,"line":582},[83,936,937],{},"        count: state.count + 1\n",[83,939,940],{"class":85,"line":589},[83,941,803],{},[83,943,944],{"class":85,"line":595},[83,945,946],{},"    case 'decrement':\n",[83,948,949],{"class":85,"line":601},[83,950,932],{},[83,952,953],{"class":85,"line":606},[83,954,955],{},"        count: state.count - 1\n",[83,957,958],{"class":85,"line":611},[83,959,803],{},[83,961,962],{"class":85,"line":616},[83,963,566],{},[83,965,966],{"class":85,"line":622},[83,967,932],{},[83,969,970],{"class":85,"line":628},[83,971,972],{},"        count: 0\n",[83,974,975],{"class":85,"line":633},[83,976,856],{},[83,978,979],{"class":85,"line":639},[83,980,356],{},[83,982,983],{"class":85,"line":645},[83,984,263],{},[83,986,987],{"class":85,"line":651},[83,988,586],{"emptyLinePlaceholder":585},[83,990,991],{"class":85,"line":657},[83,992,592],{},[83,994,995],{"class":85,"line":663},[83,996,598],{},[83,998,999],{"class":85,"line":669},[83,1000,226],{},[83,1002,1003],{"class":85,"line":675},[83,1004,586],{"emptyLinePlaceholder":585},[83,1006,1007],{"class":85,"line":680},[83,1008,1009],{},"const Child = () => {\n",[83,1011,1012],{"class":85,"line":685},[83,1013,1014],{},"  const [state, dispatch] = React.useContext(CountContext);\n",[83,1016,1017],{"class":85,"line":690},[83,1018,636],{},[83,1020,1021],{"class":85,"line":696},[83,1022,642],{},[83,1024,1026],{"class":85,"line":1025},28,[83,1027,1028],{},"      Child Count: {state.count}\n",[83,1030,1032],{"class":85,"line":1031},29,[83,1033,654],{},[83,1035,1037],{"class":85,"line":1036},30,[83,1038,660],{},[83,1040,1042],{"class":85,"line":1041},31,[83,1043,666],{},[83,1045,1047],{"class":85,"line":1046},32,[83,1048,672],{},[83,1050,1052],{"class":85,"line":1051},33,[83,1053,493],{},[83,1055,1057],{"class":85,"line":1056},34,[83,1058,263],{},[83,1060,1062],{"class":85,"line":1061},35,[83,1063,586],{"emptyLinePlaceholder":585},[83,1065,1067],{"class":85,"line":1066},36,[83,1068,619],{},[83,1070,1072],{"class":85,"line":1071},37,[83,1073,1074],{},"  const countReducer = React.useReducer(reducer, initialState);\n",[83,1076,1078],{"class":85,"line":1077},38,[83,1079,586],{"emptyLinePl