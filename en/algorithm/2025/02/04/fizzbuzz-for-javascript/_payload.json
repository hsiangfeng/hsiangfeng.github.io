\n",[44,596,597,615,639,655,667,675,683,687,691],{"__ignoreMap":135},[139,598,599,601,603,605,607,609,611,613],{"class":141,"line":142},[139,600,227],{"class":226},[139,602,230],{"class":145},[139,604,233],{"class":226},[139,606,236],{"class":148},[139,608,240],{"class":239},[139,610,243],{"class":148},[139,612,246],{"class":226},[139,614,249],{"class":148},[139,616,617,619,621,623,625,627,629,631,633,635,637],{"class":141,"line":162},[139,618,254],{"class":226},[139,620,236],{"class":148},[139,622,259],{"class":226},[139,624,262],{"class":148},[139,626,265],{"class":226},[139,628,268],{"class":152},[139,630,271],{"class":148},[139,632,274],{"class":226},[139,634,277],{"class":148},[139,636,280],{"class":226},[139,638,283],{"class":148},[139,640,641,643,645,647,649,651,653],{"class":141,"line":176},[139,642,511],{"class":226},[139,644,514],{"class":148},[139,646,588],{"class":226},[139,648,389],{"class":152},[139,650,521],{"class":226},[139,652,268],{"class":152},[139,654,283],{"class":148},[139,656,657,659,661,663,665],{"class":141,"line":190},[139,658,531],{"class":148},[139,660,291],{"class":145},[139,662,149],{"class":148},[139,664,539],{"class":538},[139,666,542],{"class":148},[139,668,669,671,673],{"class":141,"line":302},[139,670,547],{"class":148},[139,672,550],{"class":226},[139,674,249],{"class":148},[139,676,677,679,681],{"class":141,"line":555},[139,678,531],{"class":148},[139,680,291],{"class":145},[139,682,294],{"class":148},[139,684,685],{"class":141,"line":564},[139,686,567],{"class":148},[139,688,689],{"class":141,"line":570},[139,690,299],{"class":148},[139,692,693],{"class":141,"line":575},[139,694,305],{"class":148},[12,696,697],{},[15,698],{"alt":58,"src":699},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Falgorithm\u002Ffizzbuzz\u002F%E6%88%AA%E5%9C%96%202025-02-05%2022.58.27.png",[12,701,702,703,705,706,708,709,705,712,87,714,716,717,116],{},"When you pass ",[44,704,90],{},", you get ",[44,707,46],{}," — looks right. But when you pass ",[44,710,711],{},"6",[44,713,711],{},[44,715,46],{}," — which breaks the FizzBuzz rule that any multiple of 3 should return ",[44,718,46],{},[206,720,722],{"id":721},"step-3-check-if-its-a-multiple-of-5","Step 3: Check if it's a multiple of 5",[12,724,725,726,728,729,731,732,459],{},"Same idea — when the number is divisible by 5, return ",[44,727,52],{},". Just replace ",[44,730,90],{}," with ",[44,733,104],{},[130,735,737],{"className":132,"code":736,"language":134,"meta":135,"style":135},"const FizzBuzz = (num) => {\n  for (let i = 1; i \u003C= num; i++) {\n    if (i % 3 === 0) {\n      console.log('Fizz');\n    } else if (i % 5 === 0) {\n      console.log('Buzz');\n    } else {\n      console.log(i);\n    }\n  }\n};\n",[44,738,739,757,781,797,809,830,843,851,859,863,868],{"__ignoreMap":135},[139,740,741,743,745,747,749,751,753,755],{"class":141,"line":142},[139,742,227],{"class":226},[139,744,230],{"class":145},[139,746,233],{"class":226},[139,748,236],{"class":148},[139,750,240],{"class":239},[139,752,243],{"class":148},[139,754,246],{"class":226},[139,756,249],{"class":148},[139,758,759,761,763,765,767,769,771,773,775,777,779],{"class":141,"line":162},[139,760,254],{"class":226},[139,762,236],{"class":148},[139,764,259],{"class":226},[139,766,262],{"class":148},[139,768,265],{"class":226},[139,770,268],{"class":152},[139,772,271],{"class":148},[139,774,274],{"class":226},[139,776,277],{"class":148},[139,778,280],{"class":226},[139,780,283],{"class":148},[139,782,783,785,787,789,791,793,795],{"class":141,"line":176},[139,784,511],{"class":226},[139,786,514],{"class":148},[139,788,332],{"class":226},[139,790,389],{"class":152},[139,792,521],{"class":226},[139,794,524],{"class":152},[139,796,283],{"class":148},[139,798,799,801,803,805,807],{"class":141,"line":190},[139,800,531],{"class":148},[139,802,291],{"class":145},[139,804,149],{"class":148},[139,806,539],{"class":538},[139,808,542],{"class":148},[139,810,811,813,815,818,820,822,824,826,828],{"class":141,"line":302},[139,812,547],{"class":148},[139,814,550],{"class":226},[139,816,817],{"class":226}," if",[139,819,514],{"class":148},[139,821,332],{"class":226},[139,823,374],{"class":152},[139,825,521],{"class":226},[139,827,524],{"class":152},[139,829,283],{"class":148},[139,831,832,834,836,838,841],{"class":141,"line":555},[139,833,531],{"class":148},[139,835,291],{"class":145},[139,837,149],{"class":148},[139,839,840],{"class":538},"'Buzz'",[139,842,542],{"class":148},[139,844,845,847,849],{"class":141,"line":564},[139,846,547],{"class":148},[139,848,550],{"class":226},[139,850,249],{"class":148},[139,852,853,855,857],{"class":141,"line":570},[139,854,531],{"class":148},[139,856,291],{"class":145},[139,858,294],{"class":148},[139,860,861],{"class":141,"line":575},[139,862,567],{"class":148},[139,864,866],{"class":141,"line":865},10,[139,867,299],{"class":148},[139,869,871],{"class":141,"line":870},11,[139,872,305],{"class":148},[12,874,875],{},[15,876],{"alt":58,"src":877},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Falgorithm\u002Ffizzbuzz\u002F%E6%88%AA%E5%9C%96%202025-02-05%2022.59.29.png",[206,879,881],{"id":880},"step-4-check-for-fizzbuzz","Step 4: Check for FizzBuzz",[12,883,884,885,887,888,890,891,116],{},"The last condition — when the number is divisible by both ",[44,886,90],{}," and ",[44,889,104],{},", return ",[44,892,58],{},[12,894,895],{},"This touches on the math concept of the least common multiple (LCM) — the smallest number that's a multiple of both. A bit dense in words, so let me show an example.",[12,897,898,899,887,901,903,904,906],{},"For ",[44,900,90],{},[44,902,104],{},", the LCM is ",[44,905,110],{},". Why? Look at their multiples:",[432,908,909,918],{},[40,910,911,912,914,915],{},"Multiples of ",[44,913,90],{},": ",[44,916,917],{},"3, 6, 9, 12, 15, 18, 21, 24, 27, 30",[40,919,911,920,914,922],{},[44,921,104],{},[44,923,924],{},"5, 10, 15, 20, 25, 30",[12,926,898,927,887,930,903,932,459],{},[44,928,929],{},"7",[44,931,96],{}