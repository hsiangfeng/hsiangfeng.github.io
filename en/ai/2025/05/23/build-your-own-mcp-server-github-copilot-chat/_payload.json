[{"data":1,"prerenderedAt":1780},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fai\u002F2025\u002F05\u002F23\u002Fbuild-your-own-mcp-server-github-copilot-chat\u002F":3,"page:\u002Fen\u002Fai\u002F2025\u002F05\u002F23\u002Fbuild-your-own-mcp-server-github-copilot-chat\u002F":4,"alt:\u002Fen\u002Fai\u002F2025\u002F05\u002F23\u002Fbuild-your-own-mcp-server-github-copilot-chat\u002F":3,"prev-next:\u002Fen\u002Fai\u002F2025\u002F05\u002F23\u002Fbuild-your-own-mcp-server-github-copilot-chat\u002F":1756,"related:\u002Fen\u002Fai\u002F2025\u002F05\u002F23\u002Fbuild-your-own-mcp-server-github-copilot-chat\u002F":1765},"\u002Fai\u002F20250523\u002F980109919\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1738,"date":1739,"description":1740,"extension":1741,"lang":1742,"meta":1743,"navigation":474,"path":1744,"readingMinutes":1745,"seo":1746,"standalone":1747,"stem":1748,"tags":1749,"tldr":1753,"updated":1739,"url":1754,"__hash__":1755},"content\u002Fen\u002FAI\u002Fbuild-your-own-mcp-server-github-copilot-chat.md","Build Your Own MCP Server for AI Agents — A Complete Implementation Guide With GitHub Copilot Chat","5172064839",{"type":9,"value":10,"toc":1731},"minimark",[11,19,24,27,31,34,47,58,66,88,91,104,107,123,130,141,162,165,179,182,217,220,227,240,243,247,250,323,326,377,393,396,539,542,546,561,564,567,578,584,591,638,641,736,746,752,902,908,1337,1343,1378,1384,1388,1395,1398,1410,1417,1429,1439,1446,1524,1536,1539,1581,1584,1590,1593,1667,1670,1676,1679,1688,1691,1697,1700,1706,1709,1712,1715,1724,1727],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"MCP Server","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fmcp-ai-chat\u002FChatGPT%20Image%202025%E5%B9%B45%E6%9C%8823%E6%97%A5%20%E4%B8%8B%E5%8D%8805_04_19.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"MCP Server is incredibly popular right now, and major service providers are releasing their own MCP Servers. So to better understand how MCP Server actua