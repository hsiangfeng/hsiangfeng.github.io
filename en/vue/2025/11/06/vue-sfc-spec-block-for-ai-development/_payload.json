:167},"    }`\n",[133,604,605],{"class":135,"line":340},[133,606,607],{"class":139},"  },\n",[133,609,610],{"class":135,"line":346},[133,611,297],{"class":139},[133,613,614],{"class":135,"line":352},[133,615,175],{"emptyLinePlaceholder":174},[133,617,618,621,624],{"class":135,"line":358},[133,619,620],{"class":157},"export",[133,622,623],{"class":157}," default",[133,625,276],{"class":457},[133,627,629,632,635,638],{"class":135,"line":628},23,[133,630,631],{"class":139},"  plugins: [",[133,633,634],{"class":190},"vue",[133,636,637],{"class":139},"(), vueI18nPlugin]",[133,639,447],{"class":457},[133,641,643],{"class":135,"line":642},24,[133,644,297],{"class":457},[12,646,647],{},"Then you can use it like this:",[124,649,651],{"className":126,"code":650,"language":128,"meta":129,"style":129},"\u003Ctemplate>Hello\u003C\u002Ftemplate>\n\n\u003Ci18n lang=\"yaml\">\nmessage: 'world'\nfullWord: 'hello world'\n\u003C\u002Fi18n>\n",[28,652,653,666,670,686,691,696],{"__ignoreMap":129},[133,654,655,657,659,662,664],{"class":135,"line":136},[133,656,140],{"class":139},[133,658,223],{"class":143},[133,660,661],{"class":139},">Hello\u003C\u002F",[133,663,223],{"class":143},[133,665,151],{"class":139},[133,667,668],{"class":135,"line":154},[133,669,175],{"emptyLinePlaceholder":174},[133,671,672,674,677,679,681,684],{"class":135,"line":171},[133,673,140],{"class":139},[133,675,676],{"class":319},"i18n",[133,678,323],{"class":147},[133,680,326],{"class":139},[133,682,683],{"class":167},"\"yaml\"",[133,685,151],{"class":139},[133,687,688],{"class":135,"line":178},[133,689,690],{"class":139},"message: 'world'\n",[133,692,693],{"class":135,"line":203},[133,694,695],{"class":139},"fullWord: 'hello world'\n",[133,697,698,700,702],{"class":135,"line":213},[133,699,206],{"class":139},[133,701,676],{"class":319},[133,703,151],{"class":139},[12,705,706,707,709],{},"Based on this pattern, we just need to tweak the Vite plugin a bit to support our ",[28,708,30],{}," block. Here are two versions — a pure Vite one and a Nuxt one.",[12,711,712],{},"Vite version:",[124,714,716],{"className":393,"code":715,"language":395,"meta":129,"style":129},"import { fileURLToPath, URL } from 'node:url';\n\nimport { defineConfig } from 'vite';\nimport vue from '@vitejs\u002Fplugin-vue';\n\nexport default defineConfig({\n  plugins: [\n    vue(),\n    {\n      name: 'vue-spec-plugin',\n      enforce: 'pre', \u002F\u002F run before other plugins\n      transform(_code, id) {\n        \u002F\u002F more precise regex to match the spec block in .vue files\n        if (\u002F\\.vue\\?vue&type=spec(?:&|$)\u002F.test(id)) {\n          return {\n            code: 'export default {};',\n            map: null,\n          };\n        }\n        \u002F\u002F explicitly return null to skip this file\n        return null;\n      },\n    },\n  ],\n  resolve: {\n    alias: {\n      '@': fileURLToPath(new URL('.\u002Fsrc', import.meta.url)),\n    },\n  },\n});\n",[28,717,718,732,736,750,763,767,779,784,792,797,807,820,836,841,872,879,889,899,904,909,914,924,929,934,941,947,953,989,994,1002],{"__ignoreMap":129},[133,719,720,722,725,727,730],{"class":135,"line":136},[133,721,158],{"class":157},[133,723,724],{"class":139}," { fileURLToPath, URL } ",[133,726,164],{"class":157},[133,728,729],{"class":167}," 'node:url'",[133,731,291],{"class":139},[133,733,734],{"class":135,"line":154},[133,735,175],{"emptyLinePlaceholder":174},[133,737,738,740,743,745,748],{"class":135,"line":171},[133,739,158],{"class":157},[133,741,742],{"class":139}," { defineConfig } ",[133,744,164],{"class":157},[133,746,747],{"class":167}," 'vite'",[133,749,291],{"class":139},[133,751,752,754,756,758,761],{"class":135,"line":178},[133,753,158],{"class":157},[133,755,404],{"class":139},[133,757,164],{"class":157},[133,759,760],{"class":167}," '@vitejs\u002Fplugin-vue'",[133,762,291],{"class":139},[133,764,765],{"class":135,"line":203},[133,766,175],{"emptyLinePlaceholder":174},[133,768,769,771,773,776],{"class":135,"line":