onfig({\n  vite: {\n    plugins: [\n      {\n        name: 'vue-spec-plugin',\n        enforce: 'pre', \u002F\u002F run before other plugins\n        transform(_code, id) {\n          \u002F\u002F more precise regex to match the spec block in .vue files\n          if (\u002F\\.vue\\?vue&type=spec(?:&|$)\u002F.test(id)) {\n            return {\n              code: 'export default {};',\n              map: null,\n            };\n          }\n          \u002F\u002F explicitly return null to skip this file\n          return null;\n        },\n      },\n    ],\n  },\n});\n",[28,1017,1018,1029,1034,1039,1044,1053,1064,1079,1084,1111,1118,1127,1136,1141,1146,1151,1159,1164,1168,1173,1179],{"__ignoreMap":129},[133,1019,1020,1022,1024,1027],{"class":135,"line":136},[133,1021,620],{"class":157},[133,1023,623],{"class":157},[133,1025,1026],{"class":190}," defineNuxtConfig",[133,1028,778],{"class":457},[133,1030,1031],{"class":135,"line":154},[133,1032,1033],{"class":139},"  vite: {\n",[133,1035,1036],{"class":135,"line":171},[133,1037,1038],{"class":139},"    plugins: [\n",[133,1040,1041],{"class":135,"line":178},[133,1042,1043],{"class":139},"      {\n",[133,1045,1046,1049,1051],{"class":135,"line":203},[133,1047,1048],{"class":139},"        name: ",[133,1050,804],{"class":167},[133,1052,447],{"class":139},[133,1054,1055,1058,1060,1062],{"class":135,"line":213},[133,1056,1057],{"class":139},"        enforce: ",[133,1059,814],{"class":167},[133,1061,114],{"class":139},[133,1063,819],{"class":470},[133,1065,1066,1069,1071,1073,1075,1077],{"class":135,"line":218},[133,1067,1068],{"class":190},"        transform",[133,1070,194],{"class":139},[133,1072,829],{"class":457},[133,1074,114],{"class":139},[133,1076,462],{"class":457},[133,1078,465],{"class":139},[133,1080,1081],{"class":135,"line":228},[133,1082,1083],{"class":470},"          \u002F\u002F more precise regex to match the spec block in .vue files\n",[133,1085,1086,1089,1091,1093,1095,1097,1099,1101,1103,1105,1107,1109],{"class":135,"line":244},[133,1087,1088],{"class":157},"          if",[133,1090,479],{"class":139},[133,1092,517],{"class":167},[133,1094,521],{"class":520},[133,1096,634],{"class":167},[133,1098,856],{"class":520},[133,1100,859],{"class":167},[133,1102,862],{"class":157},[133,1104,865],{"class":167},[133,1106,387],{"class":139},[133,1108,490],{"class":190},[133,1110,493],{"class":139},[133,1112,1113,1116],{"class":135,"line":253},[133,1114,1115],{"class":157},"            return",[133,1117,276],{"class":139},[133,1119,1120,1123,1125],{"class":135,"line":258},[133,1121,1122],{"class":139},"              code: ",[133,1124,886],{"class":167},[133,1126,447],{"class":139},[133,1128,1129,1132,1134],{"class":135,"line":271},[133,1130,1131],{"class":139},"              map: ",[133,1133,896],{"class":147},[133,1135,447],{"class":139},[133,1137,1138],{"class":135,"line":279},[133,1139,1140],{"class":139},"            };\n",[133,1142,1143],{"class":135,"line":294},[133,1144,1145],{"class":139},"          }\n",[133,1147,1148],{"class":135,"line":300},[133,1149,1150],{"class":470},"          \u002F\u002F explicitly return null to skip this file\n",[133,1152,1153,1155,1157],{"class":135,"line":309},[133,1154,876],{"class":157},[133,1156,921],{"class":147},[133,1158,291],{"class":139},[133,1160,1161],{"class":135,"line":314},[133,1162,1163],{"class":139},"        },\n",[133,1165,1166],{"class":135,"line":334},[133,1167,928],{"class":139},[133,1169,1170],{"class":135,"line":340},[133,1171,1172],{"class":139},"    ],\n",[133,1174,1175,1177],{"class":135,"line":346},[133,1176,999],{"class":139},[133,1178,447],{"class":457},[133,1180,1181,1183],{"class":135,"line":352},[133,1182,1007],{"class":457},[133,1184,291],{"class":139},[12,1186,1187,1188,1190],{},"That's it — now you can use a ",[28,1189,30],{}," block in your Vue SFC to write spec and requirements.",[12,1192,1193],{},"What are the upsides? Here's what I think:",[40,1195,1196,1202,1208],{},[43,1197,1198,1201],{},[59,1199,1200],{},"Centralized management",": the spec doc lives directly in the component file, easy to read and maintain. Each component carries its own spec, which makes team collaboration and communication smoother.",[43,1203,1204,1207],{},[59,1205,1206],{},"Consistent context",": when AI generates code, it can reference the spec right inside the component, which cuts down on misunderstanding.",[43,1209,1210,1213],{},[59,1211,1212],{},"Fewer docs",": no need to maintain a pile of separate spec docs, less mess overall.",[12,1215,1216,1217,1220],{},"One caveat — this approach only works in ",[28,1218,1219],{},".vue"," files. For plain js\u002Fts files you can't use this, so I'd recommend JSDoc or TypeScript type definitions to describe things instead.",[1222,1223,1225],"h3",{"id":1224},"pair-it-with-eslint-for-block-ordering","Pair it with ESLint for block ordering",[12,1227,1228,1229,1232,1233,1236,1237,1240],{},"Beyond the Vite plugin, if you're using ",[28,1230,1231],{},"eslint-plugin-vue",", you can set the ",[28,1234,1235],{},"vue\u002Fblock-order"," rule to keep the ",[28,1238,1239],{},"\u003Cspec>"," block in a consistent position:",[124,1242,1244],{"className":393,"code":1243,"language":395,"meta":129,"style":129},"\u002F\u002F eslint.config.js\n{\n  files: ['**\u002F*.vue'],\n  rules: {\n    'vue\u002Fblock-order': [\n      'error',\n      { order: ['spec', 'script', 'template', 'style'] },\n    ],\n  },\n}\n",[28,1245,1246,1251,1256,1270,1278,1286,1293,1319,1323,1327],{"__ignoreMap":129},[133,1247,1248],{"class":135,"line":136},[133,1249,1250],{"class":470},"\u002F\u002F eslint.config.js\n",[133,1252,1253],{"class":135,"line":154},[133,1254,1255],{"class":139},"{\n",[133,1257,1258,1261,1264,1267],{"class":135,"line":171},[133,1259,1260],{"class":457},"  files",[133,1262,1263],{"class":139},": [",[133,1265,1266],{"class":167},"'**\u002F*.vue'",[133,1268,1269],{"class":139},"],\n",[133,1271,1272,1275],{"class":135,"line":178},[133,1273,1274],{"class":457},"  rules",[133,1276,1277],{"class":139},": {\n",[133,1279,1280,1283],{"class":135,"line":203},[133,1281,1282],{"class":167},"    'vue\u002Fblock-order'",[133,1284,1285],{"class":139},": [\n",[133,1287,1288,1291],{"class":135,"line":213},[133,1289,1290],{"class":167},"      'error'",[133,1292,447],{"class":139},[133,1294,1295,1298,1301,1303,1306,1308,1311,1313,1316],{"class":135,"line":218},[133,1296,1297],{"class":139},"      { order: [",[133,1299,1300],{"class":167},"'spec'",[133,1302,114],{"class":139},[133,1304,1305],{"class":167},"'script'",[133,1307,114],{"class":139},[133,1309,1310],{"class":167},"'template'",[133,1312,114],{"class":139},[133,1314,1315],{"class":167},"'style'",[133,1317,1318],{"class":139},"] },\n",[133,1320,1321],{"class":135,"line":228},[133,1322,1172],{"class":139},[133,1324,1325],{"class":135,"line":244},[133,1326,607],{"class":139},[133,1328,1329],{"class":135,"line":253},[133,1330,297],{"class":139},[12,1332,1333,1334,1336],{},"That way ",[28,1335,1239],{}," always sits at the top of the file, and your teammates can build a consistent writing habit around it.",[20,1338,1340],{"id":1339},"why-is-vue-sfc-specifically-a-good-fit-for-this","Why is Vue SFC specifically a good fit for this?",[12,1342,1343],{},"You might be wondering — can other frameworks pull off something similar?",[12,1345,1346,1347,114,1349,114,1351,1353,1354,1356],{},"Honestly, not easily. Vue SFC's design philosophy is to keep related things together — ",[28,1348,113],{},[28,1350,117],{},[28,1352,121],{}," all live in the same file, so adding one more ",[28,1355,1239],{}," is a pretty natural extension.",[12,1358,1359,1360,1362],{},"Plus Vue has this built-in trait where one ",[28,1361,1219],{}," file is one component, which gives you a 1:1 mapping between spec and implementation. You won't get confused about which spec belongs to which component, because they're literally in the same file.",[12,1364,1365,1366,1369],{},"React on the other hand doesn't have the SFC concept — one file can hold multiple components, and there's no custom block mechanism. To get something similar you'd mostly have to rely on JSDoc or drop a ",[28,1367,1368],{},".spec.md"," file next to it, but then you lose the colocation advantage. Svelte is also a single-file component but its compiler doesn't support custom blocks, so this approach doesn't translate over either.",[12,1371,1372],{},"In short, Vue SFC's custom blocks are basically the only way among mainstream frontend frameworks to make spec docs a first-class citizen of the component.",[20,1374,1376],{"id":1375},"things-to-watch-out-for","Things to watch out for",[12,1378,1379],{},"This approach is convenient, but there are a few things worth keeping in mind.",[12,1381,1382,1383,1386,1387,1389,1390,1392,1393,1396,1397,1400,1401,1403],{},"The most common one is ",[59,1384,1385],{},"Spec Degradation",". Basically, the code gets updated but the ",[28,1388,1239],{}," doesn't, and over time the spec and the implementation drift apart. My recommendation is to check that ",[28,1391,1239],{}," got updated during Code Review, or add a rule to your AI config file (like ",[28,1394,1395],{},"copilot-instructions.md"," or ",[28,1398,1399],{},"CLAUDE.md",") saying \"update the ",[28,1402,1239],{}," block whenever you modify the component\" — that way AI will maintain the spec for you automatically.",[12,1405,1406,1407,1409],{},"Another thing — ",[28,1408,1239],{}," can only describe a single component's spec, it can't express interactions between multiple components. If you need to describe a whole feature or page-level architecture, you'll still need a separate spec doc for that.",[12,1411,1412,1413,1415,1416,1418],{},"One more easy-to-miss thing is Context Window consumption. The ",[28,1414,1239],{}," block content doesn't get compiled into the final output (since the Vite plugin turns it into an empty module), but AI still counts it when it reads the file. So keep the ",[28,1417,1239],{}," content concise and focused on the key requirements and behavior — no need to stuff a full PRD in there.",[12,1420,1421],{},"Here's the sample code for you to play with:",[40,1423,1424,1431],{},[43,1425,1426],{},[381,1427,1430],{"href":1428,"rel":1429},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fvue-custom-spec",[385],"GitHub - vue-custom-spec",[43,1432,1433],{},[381,1434,1436],{"href":1428,"rel":1435},[385],"vue-custom-spec (Skills)",[20,1438,1440],{"id":1439},"wrap-up","Wrap-up",[12,1442,1443,1444,1446],{},"Overall, using a ",[28,1445,30],{}," custom block in Vue SFC to manage spec docs is a really low-barrier and practical approach. No need to install some complex framework or tool — a simple Vite plugin gets it done, and having the spec sit right next to the code in the same file is also the ideal context source for AI tools.",[12,1448,1449],{},"Of course it's not a silver bullet. Large projects might still need other tools for more complete spec management. But as a starting point for spec-driven development, this approach is genuinely worth trying.",[12,1451,1452],{},"That's it for this post — hope it gives you a fresh angle on Vue SFC paired with AI development.",[20,1454,1456],{"id":1455},"references","References",[40,1458,1459,1466,1473,1479],{},[43,1460,1461],{},[381,1462,1465],{"href":1463,"rel":1464},"https:\u002F\u002Fzenn.dev\u002Fytr0903\u002Farticles\u002F2a3cc9dfba9945",[385],"Vue SFC のカスタムブロックと AI 駆動開発の相性が良い理由",[43,1467,1468],{},[381,1469,1472],{"href":1470,"rel":1471},"https:\u002F\u002Ftech.andpad.co.jp\u002Fentry\u002F2025\u002F10\u002F22\u002F100000",[385],"Vue のカスタムブロックで「気軽に」始める仕様駆動開発のススメ",[43,1474,1475],{},[381,1476,1478],{"href":383,"rel":1477},[385],"SFC Custom Block Integrations - Vue.js",[43,1480,1481],{},[381,1482,1485],{"href":1483,"rel":1484},"https:\u002F\u002Fzenn.dev\u002Fcomm_vue_nuxt\u002Farticles\u002Fccb92948c39db0",[385],"Vue.jsの自作カスタムブロックをViteと連携する便利な活用術",[263,1487,1488],{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html p