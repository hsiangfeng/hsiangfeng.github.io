mplate>\n  \u003Cdiv class=\"home\">\n    \u003Cimg alt=\"Vue logo\" :src=\"logo\">\n    \u003CHelloWorld msg=\"Welcome to Your Vue.js App\"\u002F>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\u003Cscript>\nimport logo from '@\u002Fassets\u002Flogo.png';\nimport HelloWorld from '@\u002Fcomponents\u002FHelloWorld.vue';\n\nexport default {\n  name: 'HomeView',\n  components: {\n    HelloWorld,\n  },\n  data() {\n    return {\n      logo,\n    };\n  },\n};\n\u003C\u002Fscript>\n",[47,374,375,385,403,425,445,455,465,472,482,497,512,517,529,541,547,553,561,574,582,588,594,601,609],{"__ignoreMap":62},[66,376,377,379,382],{"class":68,"line":69},[66,378,73],{"class":72},[66,380,381],{"class":76},"template",[66,383,384],{"class":72},">\n",[66,386,387,390,393,396,398,401],{"class":68,"line":260},[66,388,389],{"class":72},"  \u003C",[66,391,392],{"class":76},"div",[66,394,395],{"class":80}," class",[66,397,84],{"class":72},[66,399,400],{"class":87},"\"home\"",[66,402,384],{"class":72},[66,404,405,408,410,412,414,417,419,421,423],{"class":68,"line":281},[66,406,407],{"class":72},"    \u003C",[66,409,77],{"class":76},[66,411,91],{"class":80},[66,413,84],{"class":72},[66,415,416],{"class":87},"\"Vue logo\"",[66,418,155],{"class":80},[66,420,84],{"class":72},[66,422,96],{"class":87},[66,424,384],{"class":72},[66,426,428,430,434,437,439,442],{"class":68,"line":427},4,[66,429,407],{"class":72},[66,431,433],{"class":432},"szH_Z","HelloWorld",[66,435,436],{"class":80}," msg",[66,438,84],{"class":72},[66,440,441],{"class":87},"\"Welcome to Your Vue.js App\"",[66,443,444],{"class":72},"\u002F>\n",[66,446,448,451,453],{"class":68,"line":447},5,[66,449,450],{"class":72},"  \u003C\u002F",[66,452,392],{"class":76},[66,454,384],{"class":72},[66,456,458,461,463],{"class":68,"line":457},6,[66,459,460],{"class":72},"\u003C\u002F",[66,462,381],{"class":76},[66,464,384],{"class":72},[66,466,468],{"class":68,"line":467},7,[66,469,471],{"emptyLinePlaceholder":470},true,"\n",[66,473,475,477,480],{