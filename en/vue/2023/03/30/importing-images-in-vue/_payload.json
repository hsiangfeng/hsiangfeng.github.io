1,613,615,617],{"class":68,"line":612},23,[66,614,461],{"class":72},[66,616,480],{"class":76},[66,618,385],{"class":72},[17,620,621,622,625,626,629,630,632,633,636],{},"You'll notice ",[47,623,624],{},"logo"," has to be placed inside ",[47,627,628],{},"data"," for the import to work. That's because we're using Options API here, so it has to go through ",[47,631,628],{},". With Composition API, you can use ",[47,634,635],{},"ref"," instead:",[57,638,640],{"className":120,"code":639,"language":122,"meta":62,"style":62},"import { ref } from 'vue';\nimport logo from '@\u002Fassets\u002Flogo.png';\n",[47,641,642,656],{"__ignoreMap":62},[66,643,644,646,649,651,654],{"class":68,"line":69},[66,645,116],{"class":129},[66,647,648],{"class":72}," { ref } ",[66,650,135],{"class":129},[66,652,653],{"class":87}," 'vue'",[66,655,497],{"class":72},[66,657,658,660,662,664,666],{"class":68,"line":260},[66,659,116],{"class":129},[66,661,132],{"class":72},[66,663,135],{"class":129},[66,665,494],{"class":87},[66,667,497],{"class":72},[17,669,670],{},"So the two patterns are slightly different.",[357,672,674],{"id":673},"vue-cli-require","Vue CLI - require",[17,676,677,678,117],{},"The second one uses ",[47,679,349],{},[57,681,683],{"className":59,"code":682,"language":61,"meta":62,"style":62},"\u003Cimg alt=\"Vue logo\" :src=\"require('..\u002Fassets\u002Flogo.png')\">\n",[47,684,685],{"__ignoreMap":62},[66,686,687,689,691,693,695,697,699,701,704],{"class":68,"line":69},[66,688,73],{"class":72},[66,690,77],{"class":76},[66,692,91],{"class":80},[66,694,84],{"class":72},[66,696,417],{"class":87},[66,698,155],{"class":80},[66,700,84],{"class":72},[66,702,703],{"class":87},"\"require('..\u002Fassets\u002Flogo.png')\"",[66,705,385],{"class":72},[17,707,708],{},"This is simpler — you write it inline in the HTML.",[357,710,712],{"id":711},"vue-cli-relative-path","Vue CLI - relative path",[17,714,715],{},"The relative path approach is a bit special. Why does it even work? Vue CLI's docs mention