369],{},":src"," in the HTML:",[57,372,374],{"className":59,"code":373,"language":61,"meta":62,"style":62},"\u003Ctemplate>\n  \u003Cdiv class=\"home\">\n    \u003Cimg alt=\"Vue logo\" :src=\"logo\">\n    \u003CHelloWorld msg=\"Welcome to Your Vue.js App\"\u002F>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\u003Cscript>\nimport logo from '@\u002Fassets\u002Flogo.png';\nimport HelloWorld from '@\u002Fcomponents\u002FHelloWorld.vue';\n\nexport default {\n  name: 'HomeView',\n  components: {\n    HelloWorld,\n  },\n  data() {\n    return {\n      logo,\n    };\n  },\n};\n\u003C\u002Fscript>\n",[47,375,376,386,404,426,446,456,466,473,483,498,513,518,530,542,548,554,562,575,583,589,595,602,610],{"__ignoreMap":62},[66,377,378,380,383],{"class":68,"line":69},[66,379,73],{"class":72},[66,381,382],{"class":76},"template",[66,384,385],{"class":72},">\n",[66,387,388,391,394,397,399,402],{"class":68,"line":260},[66,389,390],{"class":72},"  \u003C",[66,392,393],{"class":76},"div",[66,395,396],{"class":80}," class",[66,398,84],{"class":72},[66,400,401],{"class":87},"\"home\"",[66,403,385],{"class":72},[66,405,406,409,411,413,415,418,420,422,424],{"class":68,"line":282},[66,407,408],{"class":72},"    \u003C",[66,410,77],{"class":76},[66,412,91],{"class":80},[66,414,84],{"class":72},[66,416,417],{"class":87},"\"Vue logo\"",[66,419,155],{"class":80},[66,421,84],{"class":72},[66,423,96],{"class":87},[66,425,385],{"class":72},[66,427,429,431,435,438,440,443],{"class":68,"line":428},4,[66,430,408],{"class":72},[66,432,434],{"class":433},"s37k-","HelloWorld",[66,436,437],{"class":80}," msg",[66,439,84],{"class":72},[66,441,442],{"class":87},"\"Welcome to Your Vue.js App\"",[66,444,445],{"class":72},"\u002F>\n",[66,447,449,452,454],{"class":68,"line":448},5,[66,450,451],{"class":72},"  \u003C\u002F",[66,453,393],{"class":76},[66,455,385],{"class":72},[66,457,459,462,464],{"class":68,"line":458},6,[66,460,461],{"class":72},"\u003C\u002F",[66,463,382],{"class":76},[66,465,385],{"class":7