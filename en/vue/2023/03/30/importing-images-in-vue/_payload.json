72},[17,619,620,621,624,625,628,629,631,632,635],{},"You'll notice ",[47,622,623],{},"logo"," has to be placed inside ",[47,626,627],{},"data"," for the import to work. That's because we're using Options API here, so it has to go through ",[47,630,627],{},". With Composition API, you can use ",[47,633,634],{},"ref"," instead:",[57,637,639],{"className":120,"code":638,"language":122,"meta":62,"style":62},"import { ref } from 'vue';\nimport logo from '@\u002Fassets\u002Flogo.png';\n",[47,640,641,655],{"__ignoreMap":62},[66,642,643,645,648,650,653],{"class":68,"line":69},[66,644,116],{"class":129},[66,646,647],{"class":72}," { ref } ",[66,649,135],{"class":129},[66,651,652],{"class":87}," 'vue'",[66,654,496],{"class":72},[66,656,657,659,661,663,665],{"class":68,"line":260},[66,658,116],{"class":129},[66,660,132],{"class":72},[66,662,135],{"class":129},[66,664,493],{"class":87},[66,666,496],{"class":72},[17,668,669],{},"So the two patterns are slightly different.",[356,671,673],{"id":672},"vue-cli-require","Vue CLI - require",[17,675,676,677,117],{},"The second one uses ",[47,678,348],{},[57,680,682],{"className":59,"code":681,"language":61,"meta":62,"style":62},"\u003Cimg alt=\"Vue logo\" :src=\"require('..\u002Fassets\u002Flogo.png')\">\n",[47,683,684],{"__ignoreMap":62},[66,685,686,688,690,692,694,696,698,700,703],{"class":68,"line":69},[66,687,73],{"class":72},[66,689,77],{"class":76},[66,691,91],{"class":80},[66,693,84],{"class":72},[66,695,416],{"class":87},[66,697,155],{"class":80},[66,699,84],{"class":72},[66,701,702],{"class":87},"\"require('..\u002Fassets\u002Flogo.png')\"",[66,704,384],{"class":72},[17,706,707],{},"This is simpler — you write it inline in the HTML.",[356,709,711],{"id":710},"vue-cli-relative-path","Vue CLI - relative path",[17,713,714],{},"The relative path approach is a bit special. Why does it even work? Vue CLI's docs mention that code like this:",[57,716,718],{"className":59,"code":717,"language":61,"meta":62,"style":62},"\u003Cimg alt=\"