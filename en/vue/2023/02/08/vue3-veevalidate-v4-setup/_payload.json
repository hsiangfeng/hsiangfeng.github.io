[{"data":1,"prerenderedAt":2156},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F":3,"page:\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F":4,"alt:\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F":2133,"related:\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F":2142},"\u002Fvue\u002F20230208\u002F3309208839\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":2116,"date":2117,"description":2118,"extension":2119,"lang":2120,"meta":2121,"navigation":255,"path":2122,"readingMinutes":2123,"seo":2124,"standalone":2125,"stem":2126,"tags":2127,"tldr":2129,"updated":2130,"url":2131,"__hash__":2132},"content\u002Fen\u002FVue\u002Fvue3-veevalidate-v4-setup.md","Vue 3 VeeValidate v4.x Setup Guide","9388029033",{"type":9,"value":10,"toc":2099},"minimark",[11,16,20,24,31,34,37,41,44,70,87,90,96,99,143,146,152,156,159,174,177,191,194,197,211,215,218,223,230,594,601,765,768,774,778,784,1055,1058,1062,1065,1069,1076,1118,1122,1135,1216,1220,1233,1390,1403,1407,1418,1688,1692,1705,1881,1889,2077,2083,2086,2096],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"A quick walkthrough of how to set up VeeValidate v4.x in a Vue 3 project.",[12,21,23],{"id":22},"veevalidate-v4x","VeeValidate v4.x",[17,25,26],{},[27,28],"img",{"alt":29,"src":30},"VeeValidate","https:\u002F\u002Fi.imgur.com\u002FG6I37Km.png",[17,32,33],{},"This post uses VeeValidate v4.x. What's VeeValidate?",[17,35,36],{},"VeeValidate is a Vue.js form validation library. It makes form validation in Vue.js straightforward, with built-in validation rules and error messages out of the box. You can also define custom rules and messages, and best of all it has i18n support.",[12,38,40],{"id":39},"setup","Setup",[17,42,43],{},"This example uses Vite to create the Vue 3 project. Open your terminal:",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"language-bash shiki shiki-themes github-dark-high-contrast","npm create vue@3\n","bash","",[52,53,54],"code",{"__ignoreMap":50},[55,56,59,63,67],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"s_sBn","npm",[55,64,66],{"class":65},"sTRMh"," create",[55,68,69],{"class":65}," vue@3\n",[71,72,73],"blockquote",{},[17,74,75,79,82,83,86],{},[76,77,78],"strong",{},"Note",[52,80,81],{},"npm create vue@3"," is Vue's official Vite starter command. For Vue 2, use ",[52,84,85],{},"npm create vue@2",".",[17,88,89],{},"I'll skip walking through the options — pick what fits your needs. Screenshot for reference.",[17,91,92],{},[27,93],{"alt":94,"src":95},"Options","https:\u002F\u002Fi.imgur.com\u002FE545RDa.png",[17,97,98],{},"Then:",[45,100,102],{"className":47,"code":101,"language":49,"meta":50,"style":50},"cd \u003Cproject-name>\nnpm install\nnpm run dev\n",[52,103,104,124,132],{"__ignoreMap":50},[55,105,106,110,114,117,121],{"class":57,"line":58},[55,107,109],{"class":108},"sCcAr","cd",[55,111,113],{"class":112},"sWyjQ"," \u003C",[55,115,116],{"class":65},"project-nam",[55,118,120],{"class":119},"sMAXC","e",[55,122,123],{"class":112},">\n",[55,125,127,129],{"class":57,"line":126},2,[55,128,62],{"class":61},[55,130,131],{"class":65}," install\n",[55,133,135,137,140],{"class":57,"line":134},3,[55,136,62],{"class":61},[55,138,139],{"class":65}," run",[55,141,142],{"class":65}," dev\n",[17,144,145],{},"Open the browser to see Vue's default page.",[17,147,148],{},[27,149],{"alt":150,"src":151},"Default page","https:\u002F\u002Fi.imgur.com\u002FoPSxW1C.png",[12,153,155],{"id":154},"installing-veevalidate","Installing VeeValidate",[17,157,158],{},"Install VeeValidate:",[45,160,162],{"className":47,"code":161,"language":49,"meta":50,"style":50},"npm install vee-validate\n",[52,163,164],{"__ignoreMap":50},[55,165,166,168,171],{"class":57,"line":58},[55,167,62],{"class":61},[55,169,170],{"class":65}," install",[55,172,173],{"class":65}," vee-validate\n",[17,175,176],{},"VeeValidate doesn't ship with validation rules, so you also need:",[45,178,180],{"className":47,"code":179,"language":49,"meta":50,"style":50},"npm install @vee-validate\u002Frules\n",[52,181,182],{"__ignoreMap":50},[55,183,184,186,188],{"class":57,"line":58},[55,185,62],{"class":61},[55,187,170],{"class":65},[55,189,190],{"class":65}," @vee-validate\u002Frules\n",[17,192,193],{},"Why? Because VeeValidate itself is just the validation engine — you can write your own rules. But VeeValidate also publishes a set of preset rules in a separate package, so install both.",[17,195,196],{},"Also add i18n support:",[45,198,200],{"className":47,"code":199,"language":49,"meta":50,"style":50},"npm install @vee-validate\u002Fi18n\n",[52,201,202],{"__ignoreMap":50},[55,203,204,206,208],{"class":57,"line":58},[55,205,62],{"class":61},[55,207,170],{"class":65},[55,209,210],{"class":65}," @vee-validate\u002Fi18n\n",[12,212,214],{"id":213},"wiring-up-veevalidate","Wiring up VeeValidate",[17,216,217],{},"You can either set it up globally or per-component. Let's look at global first.",[219,220,222],"h3",{"id":221},"global-setup","Global setup",[17,224,225,226,229],{},"In ",[52,227,228],{},"main.js",", import VeeValidate. Here's an annotated version:",[45,231,235],{"className":232,"code":233,"language":234,"meta":50,"style":50},"language-js shiki shiki-themes github-dark-high-contrast","import { createApp } from 'vue'\n\n\u002F\u002F VeeValidate components and core functions\nimport {\n  Field, Form, ErrorMessage, defineRule, configure,\n} from 'vee-validate';\n\u002F\u002F VeeValidate's preset rules\nimport AllRules from '@vee-validate\u002Frules';\n\u002F\u002F VeeValidate's i18n\nimport { localize, setLocale } from '@vee-validate\u002Fi18n';\n\u002F\u002F Traditional Chinese locale file\nimport zhTW from '@vee-validate\u002Fi18n\u002Fdist\u002Flocale\u002F