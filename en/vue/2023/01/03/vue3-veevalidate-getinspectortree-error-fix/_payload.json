[{"data":1,"prerenderedAt":1937},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2023\u002F01\u002F03\u002Fvue3-veevalidate-getinspectortree-error-fix\u002F":3,"page:\u002Fen\u002Fvue\u002F2023\u002F01\u002F03\u002Fvue3-veevalidate-getinspectortree-error-fix\u002F":4,"alt:\u002Fen\u002Fvue\u002F2023\u002F01\u002F03\u002Fvue3-veevalidate-getinspectortree-error-fix\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2023\u002F01\u002F03\u002Fvue3-veevalidate-getinspectortree-error-fix\u002F":1914,"related:\u002Fen\u002Fvue\u002F2023\u002F01\u002F03\u002Fvue3-veevalidate-getinspectortree-error-fix\u002F":1923},"\u002Fvue\u002F20230103\u002F2231742483\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1897,"date":1898,"description":1899,"extension":1900,"lang":1901,"meta":1902,"navigation":128,"path":1903,"readingMinutes":1904,"seo":1905,"standalone":1906,"stem":1907,"tags":1908,"tldr":1911,"updated":1898,"url":1912,"__hash__":1913},"content\u002Fen\u002FVue\u002Fvue3-veevalidate-getinspectortree-error-fix.md","Fixing the 'getInspectorTree' Error When Using VeeValidate in Vue 3","8242733142",{"type":9,"value":10,"toc":1887},"minimark",[11,16,29,33,36,43,46,189,192,197,200,529,535,545,561,826,829,832,838,844,1122,1129,1135,1138,1144,1151,1154,1496,1511,1517,1520,1540,1871,1874,1880,1883],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24,25,28],"p",{},"This post is a quick note on how to fix the \"",[21,22,23],"code",{},"An error occurred in hook 'getInspectorTree' with payload","\" error you get when using VeeValidate. While I'm at it, I'll also cover another oddly behaving VeeValidate issue — the duplicated ",[21,26,27],{},"name"," attribute problem.",[12,30,32],{"id":31},"backendjs-an-error-occurred-in-hook-getinspectortree-with-payload","backend.js: An error occurred in hook 'getInspectorTree' with payload",[17,34,35],{},"Honestly, this error is a bit confusing at first, and under normal conditions you probably won't even hit it — it only shows up after you enable VeeValidate in Vue Devtools. If you're not seeing it, it's because you either haven't enabled Vue Devtools or haven't clicked the VeeValidate tab, like this:",[17,37,38],{},[39,40],"img",{"alt":41,"src":42},"VeeValidate","https:\u002F\u002Fi.imgur.com\u002FlPbgr5e.png",[17,44,45],{},"After you click it, head back to the Console and you'll see a pile of errors:",[47,48,53],"pre",{"className":49,"code":50,"language":51,"meta":52,"style":52},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","An error occurred in hook 'getInspectorTree' with payload: {inspectorId: 'vee-validate-inspector', app: {…}, filter: '', rootNodes: Array(0)}\n\nDOMException: Failed to execute 'btoa' on 'Window': The string to be encoded contains characters outside of the Latin1 range.\n","bash","",[21,54,55,123,130],{"__ignoreMap":52},[56,57,60,64,68,71,74,77,80,83,86,89,92,95,98,101,104,107,110,114,117,120],"span",{"class":58,"line":59},"line",1,[56,61,63],{"class":62},"smYoP","An",[56,65,67],{"class":66},"sWayO"," error",[56,69,70],{"class":66}," occurred",[56,72,73],{"class":66}," in",[56,75,76],{"class":66}," hook",[56,78,79],{"class":66}," 'getInspectorTree'",[56,81,82],{"class":66}," with",[56,84,85],{"class":66}," payload:",[56,87,88],{"class":66}," {inspectorId:",[56,90,91],{"class":66}," 'vee-validate-inspector',",[56,93,94],{"class":66}," app:",[56,96,97],{"class":66}," {…},",[56,99,100],{"class":66}," filter:",[56,102,103],{"class":66}," '',",[56,105,106],{"class":66}," rootNodes:",[56,108,109],{"class":66}," Array",[56,111,113],{"class":112},"s8XSl","(",[56,115,116],{"class":62},"0",[56,118,119],{"class":112},")",[56,121,122],{"class":66},"}\n",[56,124,126],{"class":58,"line":125},2,[56,127,129],{"emptyLinePlaceholder":128},true,"\n",[56,131,133,136,139,142,145,148,151,154,157,160,162,165,168,171,174,177,180,183,186],{"class":58,"line":132},3,[56,134,135],{"class":62},"DOMException:",[56,137,138],{"class":66}," Failed",[56,140,141],{"class":66}," to",[56,143,144],{"class":66}," execute",[56,146,147],{"class":66}," 'btoa'",[56,149,150],{"class":66}," on",[56,152,153],{"class":66}," 'Window':",[56,155,156],{"class":66}," The",[56,158,159],{"class":66}," string",[56,161,141],{"class":66},[56,163,164],{"class":66}," be",[56,166,167],{"class":66}," encoded",[56,169,170],{"class":66}," contains",[56,172,173],{"class":66}," characters",[56,175,176],{"class":66}," outside",[56,178,179],{"class":66}," of",[56,181,182],{"class":66}," the",[56,184,185],{"class":66}," Latin1",[56,187,188],{"class":66}," range.\n",[17,190,191],{},"Your first instinct is probably to copy the error and Google it, but you'll find there's no clear fix out there — so I'm writing this down.",[193,194,196],"h3",{"id":195},"how-to-fix-it","How to fix it",[17,198,199],{},"First, let's look at what our example code currently looks like:",[47,201,205],{"className":202,"code":203,"language":204,"meta":52,"style":52},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Ctemplate>\n  \u003CVForm v-slot=\"{ errors }\">\n    \u003Cdiv>\n      \u003Clabel for=\"account\">帳號\u003C\u002Flabel>\n      \u003CVField\n        id=\"account\"\n        v-model.trim=\"user.account\"\n        name=\"帳號\"\n        type=\"email\"\n        :class=\"{ 'is-invalid': errors['帳號'] }\"\n        rules=\"required|email\"\n      \u002F>\n      \u003CErrorMessage name=\"帳號\" \u002F>\n    \u003C\u002Fdiv>\n    \u003Cdiv>\n      \u003Clabel for=\"password\">密碼\u003C\u002Flabel>\n      \u003CVField\n        id=\"password\"\n        v-model.trim=\"user.password\"\n        name=\"密碼\"\n        type=\"password\"\n        :class=\"{ 'is-invalid': errors['密碼'] }\"\n        rules=\"required\"\n      \u002F>\n      \u003CErrorMessage name=\"密碼\" \u002F>\n    \u003C\u002Fdiv>\n  \u003C\u002FVForm>\n\u003C\u002Ftemplate>\n","html",[21,206,207,219,240,250,274,282,293,304,315,326,337,348,354,373,383,392,413,420,430,440,450,45