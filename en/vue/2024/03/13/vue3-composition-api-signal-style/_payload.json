{"class":48,"line":403},18,[46,405,128],{"class":52},[46,407,147],{"class":56},[46,409,60],{"class":52},[17,411,412],{},"Standard Composition API stuff — nothing surprising for any Vue developer.",[414,415,416],"blockquote",{},[17,417,418,422,423,425,426,428,429],{},[419,420,421],"strong",{},"Note","\nFor a deeper dive on ",[28,424,30],{}," vs ",[28,427,34],{},", see ",[430,431,433],"a",{"href":432},"\u002Fen\u002Fvue\u002F2024\u002F01\u002F06\u002Fvue3-ref-vs-reactive\u002F","Sooner or Later You'll Hit This: What's the Difference Between ref and reactive in Vue 3 Composition API?",[17,435,436],{},"So why bring up variable declarations? Because a friend was complaining...",[17,438,439,440,443,444,447],{},"\"A while back while maintaining a project, one of my teammates accidentally added ",[28,441,442],{},"= null"," to a ",[28,445,446],{},".value"," somewhere. Turned out it was VSCode autocomplete that did it — and it broke a feature. Genuinely scary.\"",[17,449,450],{},"You might say \"well, that's what code review is for\" — but stuff like this does happen. Which reminded me of an interesting section in Vue's docs: under \"Reactivity in Depth\" there's a subsection called \"Connection to Signals\"...",[12,452,454],{"id":453},"signals","Signals",[17,456,457],{},"This topic blew up in the React community a while back, but we're not going to dive into React or signals here — back to Vue.",[17,459,460],{},"Let's start with an example:",[462,463],"code-pen",{"default-tab":464,"height":465,"slug":466,"title":467,"user":468},"result",300,"RwORBXG","Vue Signal","hsiangfeng",[37,470,472],{"className":39,"code":471,"language":41,"meta":42,"style":42},"\u003Ctemplate>\n  \u003Cdiv>\n    \u003Cp>{{ name() }}\u003C\u002Fp>\n    \u003Cbutton @click=\"changeName\">Change name\u003C\u002Fbutton>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\n\u003Cscript setup>\nimport { shallowRef, triggerRef } from 'vue'\n\nfunction createSignal(value, options) {\n  const r = shallowRef(value)\n  const get = () => r.value\n  const set = (v) => {\n    r.value = typeof v === 'function' ? v(r.value) : v\n    if (options?.equals === false) triggerRef(r)\n  }\n  return [get, set]\n}\n\n\nconst [ name, setName ] = createSignal('Who are you?')\n\nconst changeName = () => {\n  setName(\"I'm Ray\")\n}\n\u003C\u002Fscript>\n",[28,473,474,482,490,503,521,529,537,541,545,555,566,570,592,608,626,649,683,704,709,718,723,728,733,763,768,783,796,801],{"__ignoreMap":42},[46,475,476,478,480],{"class":48,"line":49},[46,477,53],{"class":52},[46,479,57],{"class":56},[46,481,60],{"class":52},[46,483,484,486,488],{"class":48,"line":63},[46,485,66],{"class":52},[46,487,69],{"class":56},[46,489,60],{"class":52},[46,491,492,494,496,499,501],{"class":48,"line":74},[46,493,77],{"class":52},[46,495,17],{"class":56},[46,497,498],{"class":52},">{{ name() }}\u003C\u002F",[46,500,17],{"class":56},[46,502,60],{"class":52},[46,504,505,507,509,511,513,515,517,519],{"class":48,"line":89},[46,506,77],{"class":52},[46,508,94],{"class":56},[46,510,98],{"class":97},[46,512,101],{"class":52},[46,514,105],{"class":104},[46,516,108],{"class":52},[46,518,94],{"class":56},[46,520,60],{"class":52},[46,522,523,525,527],{"class":48,"line":115},[46,524,118],{"class":52},[46,526,69],{"class":56},[46,528,60],{"class":52},[46,530,531,533,535],{"class":48,"line":125},[46,532,128],{"class":52},[46,534,57],{"class":56},[46,536,60],{"class":52},[46,538,539],{"class":48,"line":135},[46,540,139],{"emptyLinePlaceholder":138},[46,542,543],{"class":48,"line":142},[46,544,139],{"emptyLinePlaceholder":138},[46,546,547,549,551,553],{"class":48,"line":155},[46,548,53],{"class":52},[46,550,147],{"class":56},[46,552,150],{"class":97},[46,554,60],{"class":52},[46,556,557,559,562,564],{"class":48,"line":171},[46,558,159],{"class":158},[46,560,561],{"class":52}," { shallowRef, triggerRef } ",[46,563,165],{"class":158},[46,565,168],{"class":104},[46,567,568],{"class":48,"line":176},[46,569,139],{"emptyLinePlaceholder":138},[4