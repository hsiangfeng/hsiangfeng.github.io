[{"data":1,"prerenderedAt":1193},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":3,"page:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":4,"alt:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":1169,"related:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":1178},"\u002Fvue\u002F20211024\u002F829255545\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1151,"date":1152,"description":19,"extension":1153,"lang":1154,"meta":1155,"navigation":881,"path":1156,"readingMinutes":1157,"seo":1158,"standalone":1159,"stem":1160,"tags":1161,"tldr":1166,"updated":1152,"url":1167,"__hash__":1168},"content\u002Fen\u002FVue\u002Fvuejs-reset-data-to-initial-values.md","A Quick Trick for Resetting Vue Data to Initial Values","5542580592",{"type":9,"value":10,"toc":1145},"minimark",[11,16,20,24,32,167,326,329,340,344,347,462,465,468,486,498,504,510,513,526,675,680,687,690,694,703,706,717,724,923,930,933,1128,1141],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We often need to reset data to its initial values during development. This post is a quick tip for doing exactly that — and the trick works on both Vue 2 and Vue 3.",[12,21,23],{"id":22},"the-scenario","The scenario",[17,25,26,27,31],{},"We frequently talk to a remote server via AJAX, and after a request finishes, the user's original input still sits in Vue's data. That can cause some annoying issues. Here's a small snippet that simulates a user entering text and clicking a link that triggers AJAX (it's not a real AJAX call — just a ",[28,29,30],"code",{},"setTimeout"," for simulation):",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cdiv id=\"app\">\n  Enter your name:\n  \u003Cinput type=\"text\" v-model=\"myName\">  \n  \u003Cdiv>My name is: {{ myName }}\u003C\u002Fdiv>\n  \u003Cbr>\n  \u003Ca href=\"#\" @click.prevent=\"ajax\">Click to trigger AJAX\u003C\u002Fa>\n\u003C\u002Fdiv>\n","html","",[28,40,41,68,74,102,116,126,157],{"__ignoreMap":38},[42,43,46,50,54,58,61,65],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"s8XSl","\u003C",[42,51,53],{"class":52},"syv7_","div",[42,55,57],{"class":56},"sK3KL"," id",[42,59,60],{"class":48},"=",[42,62,64],{"class":63},"sWayO","\"app\"",[42,66,67],{"class":48},">\n",[42,69,71],{"class":44,"line":70},2,[42,72,73],{"class":48},"  Enter your name:\n",[42,75,77,80,83,86,88,91,94,96,99],{"class":44,"line":76},3,[42,78,79],{"class":48},"  \u003C",[42,81,82],{"class":52},"input",[42,84,85],{"class":56}," type",[42,87,60],{"class":48},[42,89,90],{"class":63},"\"text\"",[42,92,93],{"class":56}," v-model",[42,95,60],{"class":48},[42,97,98],{"class":63},"\"myName\"",[42,100,101],{"class":48},">  \n",[42,103,105,107,109,112,114],{"class":44,"line":104},4,[42,106,79],{"class":48},[42,108,53],{"class":52},[42,110,111],{"class":48},">My name is: {{ myName }}\u003C\u002F",[42,113,53],{"class":52},[42,115,67],{"class":48},[42,117,119,121,124],{"class":44,"line":118},5,[42,120,79],{"class":48},[42,122,123],{"class":52},"br",[42,125,67],{"class":48},[42,127,129,131,134,137,139,142,145,147,150,153,155],{"class":44,"line":128},6,[42,130,79],{"class":48},[42,132,133],{"class":52},"a",[42,135,136],{"class":56}," href",[42,138,60],{"class":48},[42,140,141],{"class":63},"\"#\"",[42,143,144],{"class":56}," @click.prevent",[42,146,60],{"class":48},[42,148,149],{"class":63},"\"ajax\"",[42,151,152],{"class":48},">Click to trigger AJAX\u003C\u002F",[42,154,133],{"class":52},[42,156,67],{"class":48},[42,158,160,163,165],{"class":44,"line":159},7,[42,161,162],{"class":48},"\u003C\u002F",[42,164,53],{"class":52},[42,166,67],{"class":48},[33,168,172],{"className":169,"code":170,"language":171,"meta":38,"style":38},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      setTimeout(() => {\n        console.log('Created successfully!');\n        console.log('But the original data is still there:', this.myName);\n      }, 1500);\n    }\n  }\n}).mount('#app');\n","js",[28,173,174,186,194,203,211,216,221,226,234,248,266,288,299,304,310],{"__ignoreMap":38},[42,175,176,179,183],{"class":44,"line":45},[42,177,178],{"class":48},"Vue.",[42,180,182],{"class":181},"scAaK","createApp",[42,184,185],{"class":48},"({\n",[42,187,188,191],{"class":44,"line":70},[42,189,190],{"class":181},"  data",[42,192,193],{"class":48},"() {\n",[42,195,196,200],{"class":44,"line":76},[42,197,199],{"class":198},"sOudu","    return",[42,201,202],{"class":48}," {\n",[42,204,205,208],{"class":44,"line":104},[42,206,207],{"class":48},"      myName: ",[42,209,210],{"class":63},"''\n",[42,212,213],{"class":44,"line":118},[42,214,215],{"class":48},"    }\n",[42,217,218],{"class":44,"line":128},[42,219,220],{"class":48},"  },\n",[42,222,223],{"class":44,"line":159},[42,224,225],{"class":48},"  methods: {\n",[42,227,229,232],{"class":44,"line":228},8,[42,230,231],{"class":181},"    ajax",[42,233,193],{"class":48},[42,235,237,240,243,246],{"class":44,"line":236},9,[42,238,239],{"class":181},"      setTimeout",[42,241,242],{"class":48},"(() ",[42,244,245],{"class":198},"=>",[42,247,202],{"class":48},[42,249,251,254,257,260,263],{"class":44,"line":250},10,[42,252,253],{"class":48},"        console.",[42,255,256],{"class":181},"log",[42,258,259],{"class":48},"(",[42,261,262],{"class":63},"'Created successfully!'",[42,264,265],{"class":48},");\n",[42,267,269,271,273,275,278,281,285],{"class":44,"line":268},11,[42,270,253],{"class":48},[42,272,256],{"class":181},[42,274,259],{"class":48},[42,276,277],{"class":63},"'But the original data is still there:'",[42,279,280],{"class":48},", ",[42,282,284],{"class":283},"stw71","this",[42,286,287],{"class":48},".myName);\n",[42,289,291,294,297],{"class":44,"line":290},12,[42,292,293],{"class":48},"      }, ",[42,295,296],{"class":283},"1500",[42,298,265],{"class":48},[42,300,302],{"class":44,"line":301},13,[42,303,215],{"class":48},[42,305,307],{"class":44,"line":306},14,[42,308,309],{"class":48},"  }\n",[42,311,313,316,319,321,324],{"class":44,"line":312},15,[42,314,315],{"class":48},"}).",[42,317,318],{"class":181},"mount",[42,320,259],{"class":48},[42,322,323],{"class":63},"'#app'",[42,325,265],{"class":48},[17,327,328],{},"You can try it on the CodePen below:",[330,331,339],"iframe",{"height":332,"style":333,"scrolling":334,"title":335,"src":336,"frameBorder":334,"loading":337,"allowTransparency":338,"allowFullScreen":338},300,"width: 100%;","no","Untitled","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FXWapZja?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FXWapZja\">\n  Untitled\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[12,341,343],{"id":342},"reset-options-api-data","Reset Options API data",[17,345,346],{},"The usual approach is to reassign empty values after the AJAX call:",[33,348,350],{"className":169,"code":349,"language":171,"meta":38,"style":38},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      setTimeout(() => {\n        console.log('Created successfully!');\n        this.myName = '';\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[28,351,352,360,366,372,378,382,386,390,396,406,418,434,442,446,450],{"__ignoreMap":38},[42,353,354,356,358],{"class":44,"line":45},[42,355,178],{"class":48},[42,357,182],{"class":181},[42,359,185],{"class":48},[42,361,362,364],{"class":44,"line":70},[42,363,190],{"class":181},[42,365,193],{"class":48},[42,367,368,370],{"class":44,"line":76},[42,369,199],{"class":198},[42,371,202],{"class":48},[42,373,374,376],{"class":44,"line":104},[42,375,207],{"class":48},[42,377,210],{"class":63},[42,379,380],{"class":44,"line":118},[42,381,215],{"class":48},[42,383,384],{"class":44,"line":128},[42,385,220],{"class":48},[42,387,388],{"class":44,"line":159},[42,389,225],{"class":48},[42,391,392,394],{"class":44,"line":228},[42,393,231],{"class":181},[42,395,193],{"class":48},[42,397,398,400,402,404],{"class":44,"line":236},[42,399,239],{"class":181},[42,401,242],{"class":48},[42,403,245],{"class":198},[42,405,202],{"class":48},[42,407,408,410,412,414,416],{"class":44,"line":250},[42,409,253],{"class":48},[42,411,256],{"class":181},[42,413,259],{"class":48},[42,415,262],{"class":63},[42,417,265],{"class":48},[42,419,420,423,426,428,431],{"class":44,"line":268},[42,421,422],{"class":283},"        this",[42,424,425],{"class":48},".myName ",[42,427,60],{"class":198},[42,429,430],{"class":63}," ''",[42,432,433],{"class":48},";\n",[42,435,436,438,440],{"class":44,"line":290},[42,437,293],{"class":48},[42,439,296],{"class":283},[42,441,265],{"class":48},[42,443,444],{"class":44,"line":301},[42,445,215],{"class":48},[42,447,448],{"class":44,"line":306},[42,449,309],{"class":48},[42,451,452,454,456,458,460],{"class":44,"line":312},[42,453,315],{"class":48},[42,455,318],{"class":181},[42,457,259],{"class":48},[42,459,323],{"class":63},[42,461,265],{"class":48},[17,463,464],{},"But that approach has issues. If you have an object, you have to rewrite all the same properties — with 10 properties you write 10 lines, which is painful and a maintenance hazard.",[17,466,467],{},"So what's a cleaner way? Actually really simple — just write:",[33,469,471],{"className":169,"code":470,"language":171,"meta":38,"style":38},"this.$options.data()\n",[28,472,473],{"__ignoreMap":38},[42,474,475,477,480,483],{"class":44,"line":45},[42,476,284],{"class":283},[42,478,479],{"class":48},".$options.",[42,481,482],{"class":181},"data",[42,484,485],{"class":48},"()\n",[17,487,488,489,497],{},"The Vue docs mention this ",[133,490,494],{"href":491,"rel":492},"https:\u002F\u002Fv3.cn.vuejs.org\u002Fapi\u002Finstance-properties.html#options",[493],"nofollow",[28,495,496],{},"$options"," property. Here's the official description:",[499,500,501],"blockquote",{},[17,502,503],{},"The initialization options used for the current component instance.",[17,505,506],{},[507,508],"img",{"alt":496,"src":509},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVue\u002F%E6%88%AA%E5%9C%96%202022-03-14%2017.08.48.png",[17,511,512],{},"Sounds dry, right? In plain English:",[17,514,515,516,518,519,522,523,525],{},"When Vue finishes initializing, it copies your initial ",[28,517,482],{}," to ",[28,520,521],{},"this.$options",". Since ",[28,524,482],{}," is a function, you have to call it. So you can rewrite the above as:",[33,527,529],{"className":169,"code":528,"language":171,"meta":38,"style":38},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      console.log(this);\n      setTimeout(() => {\n        console.log('Created successfully!');\n        this.myName = this.$options.data().myName\n        console.log('Data reset to initial:', this.myName);\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[28,530,531,539,545,551,557,561,565,569,575,588,598,610,628,645,653,657,662],{"__ignoreMap":38},[42,532,533,535,537],{"class":44,"line":45},[42,534,178],{"class":48},[42,536,182],{"class":181},[42,538,185],{"class":48},[42,540,541,543],{"class":44,"line":70},[42,542,190],{"class":181},[42,544,193],{"class":48},[42,546,547,549],{"class":44,"line":76},[42,548,199],{"class":198},[42,550,202],{"class":48},[42,552,553,555],{"class":44,"line":104},[42,554,207],{"class":48},[42,556,210],{"clas