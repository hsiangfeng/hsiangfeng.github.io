[{"data":1,"prerenderedAt":1192},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":3,"page:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":4,"alt:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":1168,"related:\u002Fen\u002Fvue\u002F2021\u002F10\u002F24\u002Fvuejs-reset-data-to-initial-values\u002F":1177},"\u002Fvue\u002F20211024\u002F829255545\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1150,"date":1151,"description":19,"extension":1152,"lang":1153,"meta":1154,"navigation":880,"path":1155,"readingMinutes":1156,"seo":1157,"standalone":1158,"stem":1159,"tags":1160,"tldr":1165,"updated":1151,"url":1166,"__hash__":1167},"content\u002Fen\u002FVue\u002Fvuejs-reset-data-to-initial-values.md","A Quick Trick for Resetting Vue Data to Initial Values","5542580592",{"type":9,"value":10,"toc":1144},"minimark",[11,16,20,24,32,167,325,328,339,343,346,461,464,467,485,497,503,509,512,525,674,679,686,689,693,702,705,716,723,922,929,932,1127,1140],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We often need to reset data to its initial values during development. This post is a quick tip for doing exactly that — and the trick works on both Vue 2 and Vue 3.",[12,21,23],{"id":22},"the-scenario","The scenario",[17,25,26,27,31],{},"We frequently talk to a remote server via AJAX, and after a request finishes, the user's original input still sits in Vue's data. That can cause some annoying issues. Here's a small snippet that simulates a user entering text and clicking a link that triggers AJAX (it's not a real AJAX call — just a ",[28,29,30],"code",{},"setTimeout"," for simulation):",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cdiv id=\"app\">\n  Enter your name:\n  \u003Cinput type=\"text\" v-model=\"myName\">  \n  \u003Cdiv>My name is: {{ myName }}\u003C\u002Fdiv>\n  \u003Cbr>\n  \u003Ca href=\"#\" @click.prevent=\"ajax\">Click to trigger AJAX\u003C\u002Fa>\n\u003C\u002Fdiv>\n","html","",[28,40,41,68,74,102,116,126,157],{"__ignoreMap":38},[42,43,46,50,54,58,61,65],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sMAXC","\u003C",[42,51,53],{"class":52},"sKpQp","div",[42,55,57],{"class":56},"sCcAr"," id",[42,59,60],{"class":48},"=",[42,62,64],{"class":63},"sTRMh","\"app\"",[42,66,67],{"class":48},">\n",[42,69,71],{"class":44,"line":70},2,[42,72,73],{"class":48},"  Enter your name:\n",[42,75,77,80,83,86,88,91,94,96,99],{"class":44,"line":76},3,[42,78,79],{"class":48},"  \u003C",[42,81,82],{"class":52},"input",[42,84,85],{"class":56}," type",[42,87,60],{"class":48},[42,89,90],{"class":63},"\"text\"",[42,92,93],{"class":56}," v-model",[42,95,60],{"class":48},[42,97,98],{"class":63},"\"myName\"",[42,100,101],{"class":48},">  \n",[42,103,105,107,109,112,114],{"class":44,"line":104},4,[42,106,79],{"class":48},[42,108,53],{"class":52},[42,110,111],{"class":48},">My name is: {{ myName }}\u003C\u002F",[42,113,53],{"class":52},[42,115,67],{"class":48},[42,117,119,121,124],{"class":44,"line":118},5,[42,120,79],{"class":48},[42,122,123],{"class":52},"br",[42,125,67],{"class":48},[42,127,129,131,134,137,139,142,145,147,150,153,155],{"class":44,"line":128},6,[42,130,79],{"class":48},[42,132,133],{"class":52},"a",[42,135,136],{"class":56}," href",[42,138,60],{"class":48},[42,140,141],{"class":63},"\"#\"",[42,143,144],{"class":56}," @click.prevent",[42,146,60],{"class":48},[42,148,149],{"class":63},"\"ajax\"",[42,151,152],{"class":48},">Click to trigger AJAX\u003C\u002F",[42,154,133],{"class":52},[42,156,67],{"class":48},[42,158,160,163,165],{"class":44,"line":159},7,[42,161,162],{"class":48},"\u003C\u002F",[42,164,53],{"class":52},[42,166,67],{"class":48},[33,168,172],{"className":169,"code":170,"language":171,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      setTimeout(() => {\n        console.log('Created successfully!');\n        console.log('But the original data is still there:', this.myName);\n      }, 1500);\n    }\n  }\n}).mount('#app');\n","js",[28,173,174,186,194,203,211,216,221,226,234,248,266,287,298,303,309],{"__ignoreMap":38},[42,175,176,179,183],{"class":44,"line":45},[42,177,178],{"class":48},"Vue.",[42,180,182],{"class":181},"sj_SG","createApp",[42,184,185],{"class":48},"({\n",[42,187,188,191],{"class":44,"line":70},[42,189,190],{"class":181},"  data",[42,192,193],{"class":48},"() {\n",[42,195,196,200],{"class":44,"line":76},[42,197,199],{"class":198},"sWyjQ","    return",[42,201,202],{"class":48}," {\n",[42,204,205,208],{"class":44,"line":104},[42,206,207],{"class":48},"      myName: ",[42,209,210],{"class":63},"''\n",[42,212,213],{"class":44,"line":118},[42,214,215],{"class":48},"    }\n",[42,217,218],{"class":44,"line":128},[42,219,220],{"class":48},"  },\n",[42,222,223],{"class":44,"line":159},[42,224,225],{"class":48},"  methods: {\n",[42,227,229,232],{"class":44,"line":228},8,[42,230,231],{"class":181},"    ajax",[42,233,193],{"class":48},[42,235,237,240,243,246],{"class":44,"line":236},9,[42,238,239],{"class":181},"      setTimeout",[42,241,242],{"class":48},"(() ",[42,244,245],{"class":198},"=>",[42,247,202],{"class":48},[42,249,251,254,257,260,263],{"class":44,"line":250},10,[42,252,253],{"class":48},"        console.",[42,255,256],{"class":181},"log",[42,258,259],{"class":48},"(",[42,261,262],{"class":63},"'Created successfully!'",[42,264,265],{"class":48},");\n",[42,267,269,271,273,275,278,281,284],{"class":44,"line":268},11,[42,270,253],{"class":48},[42,272,256],{"class":181},[42,274,259],{"class":48},[42,276,277],{"class":63},"'But the original data is still there:'",[42,279,280],{"class":48},", ",[42,282,283],{"class":56},"this",[42,285,286],{"class":48},".myName);\n",[42,288,290,293,296],{"class":44,"line":289},12,[42,291,292],{"class":48},"      }, ",[42,294,295],{"class":56},"1500",[42,297,265],{"class":48},[42,299,301],{"class":44,"line":300},13,[42,302,215],{"class":48},[42,304,306],{"class":44,"line":305},14,[42,307,308],{"class":48},"  }\n",[42,310,312,315,318,320,323],{"class":44,"line":311},15,[42,313,314],{"class":48},"}).",[42,316,317],{"class":181},"mount",[42,319,259],{"class":48},[42,321,322],{"class":63},"'#app'",[42,324,265],{"class":48},[17,326,327],{},"You can try it on the CodePen below:",[329,330,338],"iframe",{"height":331,"style":332,"scrolling":333,"title":334,"src":335,"frameBorder":333,"loading":336,"allowTransparency":337,"allowFullScreen":337},300,"width: 100%;","no","Untitled","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FXWapZja?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FXWapZja\">\n  Untitled\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[12,340,342],{"id":341},"reset-options-api-data","Reset Options API data",[17,344,345],{},"The usual approach is to reassign empty values after the AJAX call:",[33,347,349],{"className":169,"code":348,"language":171,"meta":38,"style":38},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      setTimeout(() => {\n        console.log('Created successfully!');\n        this.myName = '';\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[28,350,351,359,365,371,377,381,385,389,395,405,417,433,441,445,449],{"__ignoreMap":38},[42,352,353,355,357],{"class":44,"line":45},[42,354,178],{"class":48},[42,356,182],{"class":181},[42,358,185],{"class":48},[42,360,361,363],{"class":44,"line":70},[42,362,190],{"class":181},[42,364,193],{"class":48},[42,366,367,369],{"class":44,"line":76},[42,368,199],{"class":198},[42,370,202],{"class":48},[42,372,373,375],{"class":44,"line":104},[42,374,207],{"class":48},[42,376,210],{"class":63},[42,378,379],{"class":44,"line":118},[42,380,215],{"class":48},[42,382,383],{"class":44,"line":128},[42,384,220],{"class":48},[42,386,387],{"class":44,"line":159},[42,388,225],{"class":48},[42,390,391,393],{"class":44,"line":228},[42,392,231],{"class":181},[42,394,193],{"class":48},[42,396,397,399,401,403],{"class":44,"line":236},[42,398,239],{"class":181},[42,400,242],{"class":48},[42,402,245],{"class":198},[42,404,202],{"class":48},[42,406,407,409,411,413,415],{"class":44,"line":250},[42,408,253],{"class":48},[42,410,256],{"class":181},[42,412,259],{"class":48},[42,414,262],{"class":63},[42,416,265],{"class":48},[42,418,419,422,425,427,430],{"class":44,"line":268},[42,420,421],{"class":56},"        this",[42,423,424],{"class":48},".myName ",[42,426,60],{"class":198},[42,428,429],{"class":63}," ''",[42,431,432],{"class":48},";\n",[42,434,435,437,439],{"class":44,"line":289},[42,436,292],{"class":48},[42,438,295],{"class":56},[42,440,265],{"class":48},[42,442,443],{"class":44,"line":300},[42,444,215],{"class":48},[42,446,447],{"class":44,"line":305},[42,448,308],{"class":48},[42,450,451,453,455,457,459],{"class":44,"line":311},[42,452,314],{"class":48},[42,454,317],{"class":181},[42,456,259],{"class":48},[42,458,322],{"class":63},[42,460,265],{"class":48},[17,462,463],{},"But that approach has issues. If you have an object, you have to rewrite all the same properties — with 10 properties you write 10 lines, which is painful and a maintenance hazard.",[17,465,466],{},"So what's a cleaner way? Actually really simple — just write:",[33,468,470],{"className":169,"code":469,"language":171,"meta":38,"style":38},"this.$options.data()\n",[28,471,472],{"__ignoreMap":38},[42,473,474,476,479,482],{"class":44,"line":45},[42,475,283],{"class":56},[42,477,478],{"class":48},".$options.",[42,480,481],{"class":181},"data",[42,483,484],{"class":48},"()\n",[17,486,487,488,496],{},"The Vue docs mention this ",[133,489,493],{"href":490,"rel":491},"https:\u002F\u002Fv3.cn.vuejs.org\u002Fapi\u002Finstance-properties.html#options",[492],"nofollow",[28,494,495],{},"$options"," property. Here's the official description:",[498,499,500],"blockquote",{},[17,501,502],{},"The initialization options used for the current component instance.",[17,504,505],{},[506,507],"img",{"alt":495,"src":508},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVue\u002F%E6%88%AA%E5%9C%96%202022-03-14%2017.08.48.png",[17,510,511],{},"Sounds dry, right? In plain English:",[17,513,514,515,517,518,521,522,524],{},"When Vue finishes initializing, it copies your initial ",[28,516,481],{}," to ",[28,519,520],{},"this.$options",". Since ",[28,523,481],{}," is a function, you have to call it. So you can rewrite the above as:",[33,526,528],{"className":169,"code":527,"language":171,"meta":38,"style":38},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      console.log(this);\n      setTimeout(() => {\n        console.log('Created successfully!');\n        this.myName = this.$options.data().myName\n        console.log('Data reset to initial:', this.myName);\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[28,529,530,538,544,550,556,560,564,568,574,587,597,609,627,644,652,656,661],{"__ignoreMap":38},[42,531,532,534,536],{"class":44,"line":45},[42,533,178],{"class":48},[42,535,182],{"class":181},[42,537,185],{"class":48},[42,539,540,542],{"class":44,"line":70},[42,541,190],{"class":181},[42,543,193],{"class":48},[42,545,546,548],{"class":44,"line":76},[42,547,199],{"class":198},[42,549,202],{"class":48},[42,551,552,554],{"class":44,"line":104},[42,553,207],{"class":48},[42,555,210],{"class":63},[42,557,558],{"class":44,"line":118},[42,559,215],{"class":48},[42,561,562],{"class":44,"line":128},[42,563,220],{"class":48},[42,565,566],{"class":44,"line":159},[42,567,225],{"class":48},[42,569,570,572],{"class":44,"line":228},[42,571,231],{"class":181},[42,573,193],{"class":48},[42,575,576,579,581,583,585],{"class":44,"line":236},[42,577,578],{"class":48},"      console.",[42,580,256],{"class":181},[42,582,259],{"class":48},[42,584,283],{"class":56},[42,586,265],{"class":48},[42,588,589,591,593,595],{"class":44,"line":250},[42,590,239],{"class":181},[42,592,242],{"class":48},[42,594,245],{"class":198},[42,596,202],{"class":48},[42,598,599,601,603,605,607],{"class":44,"line":268},[42,600,253],{"class":48},[42,602,256],{"class":181},[42,604,259],{"class":48},[42,606,262],{"class":63},[42,608,265],{"class":48},[42,610,611,613,615,617,620,622,624],{"class":44,"line":289},[42,612,421],{"class":56},[42,614,424],{"class":48},[42,616,60],{"class":198},[42,618,619],{"class":56}," this",[42,621,478],{"class":48},[42,623,481],{"class":181},[42,625,626],{"class":48},"().myName\n",[42,628,629,631,633,635,638,640,642],{"class":44,"line":300},[42,630,253],{"class":48},[42,632,256],{"class":181},[42,634,259],{"class":48},[42,636,637],{"class":63},"'Data reset to initial:'",[42,639,280],{"class":48},[42,641,283],{"class":56},[42,643,286],{"class":48},[42,645,646,648,650],{"class":44,"line":305},[42,647,292],{"class":48},[42,649,295],{"class":56},[42,651,265],{"class":48},[42,653,654],{"class":44,"line":311},[42,655,215],{"class":48},[42,657,659],{"class":44,"line":658},16,[42,660,308],{"class":48},[42,662,664,666,668,670,672],{"class":44,"line":663},17,[42,665,314],{"class":48},[42,667,317],{"class":181},[42,669,259],{"class":48},[42,671,322],{"class":63},[42,673,265],{"class":48},[329,675,678],{"height":331,"style":332,"scrolling":333,"title":676,"src":677,"frameBorder":333,"loading":336,"allowTransparency":337,"allowFullScreen":337},"Reset data trick (1)","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FzYdNRZP?default-t