uerySelector(model.el);\nvar VModel = app.querySelectorAll('[v-model]');\n\nVModel.forEach((element) => {\n  element.addEventListener('input', function() {\n    data[this.getAttribute('v-model')] = this.value;\n  })\n});\n\nObject.keys(data).forEach((key) => {\n  _data[`_${key}`] = data[key];\n  Object.defineProperty(data, key, {\n    enumerable: true,\n    configurable: true,\n    get() {\n      return _data[`_${key}`];\n    },\n    set(val) {\n      var elementKeys = app.querySelectorAll(`[v-model=${key}]`);\n      elementKeys.forEach((item) => {\n        item.value = val; \u002F\u002F update input value too\n        item.innerText = val; \u002F\u002F render to the page\n      })\n      _data[`_${key}`] = val\n    }\n  });\n});\n\nsetTimeout(() => {\n  console.log(data);\n  console.log(_data);\n}, 5000)\n",[21,1609,1610,1618,1628,1636,1640,1648,1652,1656,1660,1670,1682,1696,1714,1718,1734,1750,1772,1776,1780,1784,1804,1824,1832,1840,1848,1854,1871,1875,1885,1907,1923,1933,1944,1949,1968,1973,1978,1983,1988,2001,2013,2023],{"__ignoreMap":75},[79,1611,1612,1614,1616],{"class":81,"line":82},[79,1613,1252],{"class":85},[79,1615,1255],{"class":184},[79,1617,1258],{"class":85},[79,1619,1620,1622,1624,1626],{"class":81,"line":107},[79,1621,173],{"class":172},[79,1623,542],{"class":85},[79,1625,97],{"class":172},[79,1627,271],{"class":85},[79,1629,1630,1632,1634],{"class":81,"line":113},[79,1631,193],{"class":85},[79,1633,196],{"class":100},[79,1635,199],{"class":85},[79,1637,1638],{"class":81,"line":124},[79,1639,204],{"class":85},[79,1641,1642,1644,1646],{"class":81,"line":150},[79,1643,209],{"class":85},[79,1645,212],{"class":100},[79,1647,199],{"class":85},[79,1649,1650],{"class":81,"line":222},[79,1651,219],{"class":85},[79,1653,1654],{"class":81,"line":288},[79,1655,1298],{"class":85},[79,1657,1658],{"class":81,"line":293},[79,1659,647],{"emptyLinePlaceholder":646},[79,1661,1662,1664,1666,1668],{"class":81,"line":725},[79,1663,173],{"class":172},[79,1665,597],{"clas