 !paginationService.has_pre}\")\n          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page - 1)', tabindex='-1') Previous\n        li.page-item(v-for='pages in paginationService.total_pages', :key='pages', :class=\"{'active': paginationService.current_page === pages}\")\n          a.page-link(href='#', @click.prevent='getPagesService(pages)') {{ pages }}\n        li.page-item(:class=\"{'disabled': !paginationService.has_next}\")\n          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page + 1)') Next\n\u003C\u002Ftemplate>\n\n\u003Cscript>\nexport default {\n  props: {\n    paginationService: {\n      type: Object,\n    },\n  },\n  methods: {\n    getPagesService(item) {\n      this.$emit('pageService', item);\n    },\n  },\n};\n\u003C\u002Fscript>\n","pug","",[28,51,52,60,66,72,78,84,90,96,102,108,114,120,127,133,139,145,151,157,163,169,175,181,187,192,197,203],{"__ignoreMap":49},[53,54,57],"span",{"class":55,"line":56},"line",1,[53,58,59],{},"\u003Ctemplate lang=\"pug\">\n",[53,61,63],{"class":55,"line":62},2,[53,64,65],{},"  div\n",[53,67,69],{"class":55,"line":68},3,[53,70,71],{},"    nav(aria-label='Page navigation example')\n",[53,73,75],{"class":55,"line":74},4,[53,76,77],{},"      ul.pagination.justify-content-center\n",[53,79,81],{"class":55,"line":80},5,[53,82,83],{},"        li.page-item(:class=\"{'disabled': !paginationService.has_pre}\")\n",[53,85,87],{"class":55,"line":86},6,[53,88,89],{},"          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page - 1)', tabindex='-1') Previous\n",[53,91,93],{"class":55,"line":92},7,[53,94,95],{},"        li.page-item(v-for='pages in paginationService.total_pages', :key='pages', :class=\"{'active': paginationService.current_page === pages}\")\n",[53,97,99],{"class":55,"line":98},8,[53,100,101],{},"          a.page-link(href='#', @click.prevent='getPagesService(pages)') {{ pages }}\n",[53,103,105],{"class":55,"lin