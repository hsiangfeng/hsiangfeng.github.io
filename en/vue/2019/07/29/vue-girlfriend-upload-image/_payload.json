[{"data":1,"prerenderedAt":548},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2019\u002F07\u002F29\u002Fvue-girlfriend-upload-image\u002F":3,"page:\u002Fen\u002Fvue\u002F2019\u002F07\u002F29\u002Fvue-girlfriend-upload-image\u002F":4,"alt:\u002Fen\u002Fvue\u002F2019\u002F07\u002F29\u002Fvue-girlfriend-upload-image\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2019\u002F07\u002F29\u002Fvue-girlfriend-upload-image\u002F":524,"related:\u002Fen\u002Fvue\u002F2019\u002F07\u002F29\u002Fvue-girlfriend-upload-image\u002F":533},"\u002Fvue\u002F20190729\u002F4147561982\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":508,"date":509,"description":19,"extension":510,"lang":511,"meta":512,"navigation":513,"path":514,"readingMinutes":515,"seo":516,"standalone":517,"stem":518,"tags":519,"tldr":521,"updated":509,"url":522,"__hash__":523},"content\u002Fen\u002FVue\u002Fvue-girlfriend-upload-image.md","Build Yourself a Girlfriend with Vue! — Uploading Images","4618247195",{"type":9,"value":10,"toc":503},"minimark",[11,16,20,24,27,34,50,55,62,68,78,83,90,95,98,472,475,481,485,499],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This is the part I forgot to cover earlier (deserves a slap), so here's a follow-up on uploading product images.",[12,21,23],{"id":22},"api","API",[17,25,26],{},"Open the API docs and you'll see there's a form submission for this.",[17,28,29],{},[30,31],"img",{"alt":32,"src":33},"Form submission","https:\u002F\u002Fi.imgur.com\u002FIYgbMup.png",[17,35,36,37,41,42,45,46,49],{},"Open ",[38,39,40],"code",{},"products.vue"," and add an ",[38,43,44],{},"updateImg"," method. The interesting bit is that we'll use JavaScript's ",[38,47,48],{},"FormData"," — uploading is a slightly special case, and the API doc has an example up top:",[17,51,52],{},[30,53],{"alt":48,"src":54},"https:\u002F\u002Fi.imgur.com\u002FnoqMUr9.png",[17,56,57,58,61],{},"In the template, add a listener that fires when a file is selected, using ",[38,59,60],{},"@change",":",[17,63,64],{},[30,65],{"alt":66,"src":67},"change","https:\u002F\u002Fi.imgur.com\u002FSsAZBuu.png",[17,69,70,71,74,75,61],{},"Once a file is selected, how do we grab it? Usually you can inspect ",[38,72,73],{},"this"," and you'll see ",[38,76,77],{},"$refs",[17,79,80],{},[30,81],{"alt":77,"src":82},"https:\u002F\u002Fi.imgur.com\u002FSgrcTkV.png",[17,84,85,86,89],{},"Drill into ",[38,87,88],{},"files"," and there's the data:",[17,91,92],{},[30,93],{"alt":88,"src":94},"https:\u002F\u002Fi.imgur.com\u002FUEtXUM9.png",[17,96,97],{},"The upload code goes right here:",[99,100,105],"pre",{"className":101,"code":102,"language":103,"meta":104,"style":104},"language-js shiki shiki-themes github-dark-high-contrast","updateImg(){\n  const vm = this;\n  const url = `${process.env.VUE_APP_HEXURL}\u002Fapi\u002F${process.env.VUE_APP_HEXNAME}\u002Fadmin\u002Fupload`;\n  \u002F\u002F grab the file\n  const files = vm.$refs.files.files[0];\n  \u002F\u002F simulate a classic form submission with FormData on the frontend\n  const formData = new FormData();\n  \u002F\u002F then append the field. \"file-to-uploa\" — see the API doc\n  formData.append('file-to-upload', files);\n  \u002F\u002F we're sending formData itself plus an options object\n  vm.$http.post(url, formData, {\n    \u002F\u002F set the form type\n    headers: {\n      'Content-Type': 'multipart\u002Fform-data'\n    }\n  }).then((response) => {\n    if (response.data.success) {\n      vm.$bus.$emit('message:push', response.data.message, 'success');\n      \u002F\u002F a little special — we need to store the uploaded image's URL\n      \u002F\u002F save it to tempProduct.imgUrl\n      \u002F\u002F heads up — use $set to force two-way binding\n      vm.$set(vm.tempProduct,'imgUrl', response.data.imageUrl);\n    }\n  }).catch((error) => {\n    vm.$bus.$emit('message:push', error, 'danger');\n    vm.isLoading = false;\n  })\n},\n","js","",[38,106,107,119,139,186,193,212,218,237,243,261,267,279,285,291,3