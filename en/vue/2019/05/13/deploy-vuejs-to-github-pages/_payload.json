[{"data":1,"prerenderedAt":606},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2019\u002F05\u002F13\u002Fdeploy-vuejs-to-github-pages\u002F":3,"page:\u002Fen\u002Fvue\u002F2019\u002F05\u002F13\u002Fdeploy-vuejs-to-github-pages\u002F":4,"alt:\u002Fen\u002Fvue\u002F2019\u002F05\u002F13\u002Fdeploy-vuejs-to-github-pages\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2019\u002F05\u002F13\u002Fdeploy-vuejs-to-github-pages\u002F":582,"related:\u002Fen\u002Fvue\u002F2019\u002F05\u002F13\u002Fdeploy-vuejs-to-github-pages\u002F":591},"\u002Fvue\u002F20190513\u002F948497494\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":566,"date":567,"description":19,"extension":568,"lang":569,"meta":570,"navigation":571,"path":572,"readingMinutes":573,"seo":574,"standalone":575,"stem":576,"tags":577,"tldr":579,"updated":567,"url":580,"__hash__":581},"content\u002Fen\u002FVue\u002Fdeploy-vuejs-to-github-pages.md","Deploying Vue.js to GitHub Pages","4748949940",{"type":9,"value":10,"toc":557},"minimark",[11,16,20,28,32,35,42,46,49,56,59,65,68,74,78,85,100,106,113,122,129,135,138,144,153,159,166,175,180,183,186,192,195,204,226,229,235,238,247,253,263,266,272,276,290,296,305,308,314,321,330,333,341,347,362,369,378,381,390,393,398,401,405,408,479,482,489,526,530,539,546,553],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Once you've finished building a Vue.js project, the next step is shipping it to GitHub. Here's a quick note on the commands for deploying to GitHub Pages.",[17,21,22,23,27],{},"(Not sure if Git is installed on your machine? In CMD, run ",[24,25,26],"code",{},"git --version"," — if no version number comes back, head over to Git's official site and grab it.)",[12,29,31],{"id":30},"heads-up","Heads up",[17,33,34],{},"This guide is on the harder side, so I'd recommend reading my newer post first — it's easier to follow:",[17,36,37],{},[38,39,41],"a",{"href":40},"\u002Fen\u002Fvue\u002F2020\u002F02\u002F14\u002Fone-command-deploy-vue-cli-to-github-pages\u002F","One-Command Deploy: Vue CLI to GitHub Pages",[12,43,45],{"id":44},"git-github","Git & GitHub",[17,47,48],{},"Before we do any version control on the Vue.js project, we need to create a repo on GitHub. Head over and create one:",[17,50,51],{},[52,53],"img",{"alt":54,"src":55},"Create repo","https:\u002F\u002Fi.imgur.com\u002FsonVTQF.png",[17,57,58],{},"These three fields are required. To use GitHub Pages, the repo has to be Public.",[17,60,61],{},[52,62],{"alt":63,"src":64},"Public","https:\u002F\u002Fi.imgur.com\u002FaRNGqem.png",[17,66,67],{},"Once created, leave this page open — we'll come back to it.",[17,69,70],{},[52,71],{"alt":72,"src":73},"Repo created","https:\u002F\u002Fi.imgur.com\u002FYmbAL1c.png",[12,75,77],{"id":76},"git","Git",[17,79,80,81,84],{},"Before we can push to GitHub Pages, we need to initialize Git in the project folder. Open up your terminal (CMD or whatever your weapon of choice is) and ",[24,82,83],{},"cd"," into the project folder. (I personally use PowerShell — commands are basically the same.)",[86,87,91],"pre",{"className":88,"code":89,"language":76,"meta":90,"style":90},"language-git shiki shiki-themes github-dark-high-contrast","cd project\n","",[24,92,93],{"__ignoreMap":90},[94,95,98],"span",{"class":96,"line":97},"line",1,[94,99,89],{},[17,101,102],{},[52,103],{"alt":104,"src":105},"cd into project","https:\u002F\u002Fi.imgur.com\u002FsYLDvrJ.png",[17,107,108,109,112],{},"Initialize the project (",[24,110,111],{},"init","):",[86,114,116],{"className":88,"code":115,"language":76,"meta":90,"style":90},"git init\n",[24,117,118],{"__ignoreMap":90},[94,119,120],{"class":96,"line":97},[94,121,115],{},[17,123,124,125,128],{},"You'll see a ",[24,126,127],{},".git"," folder appear inside the project folder (usually hidden, so you may need to enable showing hidden files).",[17,130,131],{},[52,132],{"alt":133,"src":134},"git init","https:\u002F\u002Fi.imgur.com\u002FvqZNM92.png",[17,136,137],{},"Stage all the files:",[17,139,140,143],{},[24,141,142],{},"."," means stage everything.",[86,145,147],{"className":88,"code":146,"language":76,"meta":90,"style":90},"git add .\n",[24,148,149],{"__ignoreMap":90},[94,150,151],{"class":96,"line":97},[94,152,146],{},[17,154,155],{},[52,156],{"alt":157,"src":158},"git add","https:\u002F\u002Fi.imgur.com\u002FElfjuYk.png",[17,160,161,162,165],{},"Now write a ",[24,163,164],{},"commit"," message:",[86,167,169],{"className":88,"code":168,"language":76,"meta":90,"style":90},"git commit -m 'first commit'\n",[24,170,171],{"__ignoreMap":90},[94,172,173],{"class":96,"line":97},[94,174,168],{},[17,176,177],{},[52,178],{"alt":164,"src":179},"https:\u002F\u002Fi.imgur.com\u002FoVituYb.png",[17,181,182],{},"Now we'll push the files to the remote Git server. First we need to set the remote.",[17,184,185],{},"You'll find the remote URL in the repo you just created.",[17,187,188],{},[52,189],{"alt":190,"src":191},"repo","https:\u002F\u002Fi.imgur.com\u002FVyAQBUK.png",[17,193,194],{},"Then run:",[86,196,198],{"className":88,"code":197,"language":76,"meta":90,"style":90},"git remote add origin https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FGittest.git\n",[24,199,200],{"__ignoreMap":90},[94,201,202],{"class":96,"line":97},[94,203,197],{},[205,206,207,214,220],"ul",{},[208,209,210,213],"li",{},[24,211,212],{},"git remote"," - remote",[208,215,216,219],{},[24,217,218],{},"add"," - add",[208,221,222,225],{},[24,223,224],{},"origin"," - basically just a name (?), you can rename it but the default is fine.",[17,227,228],{},"After this command nothing visible happens — that's expected.",[17,230,231],{},[52,232],{"alt":233,"src":234},"add remote","https:\u002F\u002Fi.imgur.com\u002F05kY6E6.png",[17,236,237],{},"Now push it out:",[86,239,241],{"className":88,"code":240,"language":76,"meta":90,"style":90},"git push -u origin master\n",[24,242,243],{"__ignoreMap":90},[94,244,245],{"class":96,"line":97},[94,246,240],{},[17,248,249],{},[52,250],{"alt":251,"src":252},"push","https:\u002F\u002Fi.imgur.com\u002F7ah9RUL.png",[17,254,255,256,259,260,262],{},"(In the screenshot I forgot the ",[24,257,258],{},"-u",". Better to include it on the first push to avoid headaches later. If you cloned the repo, you can skip the ",[24,261,258],{},".)",[17,264,265],{},"After pushing, you can see the files on GitHub.",[17,267,268],{},[52,269],{"alt":270,"src":271},"GitHub","https:\u002F\u002Fi.imgur.com\u002F6OsVPvn.png",[12,273,275],{"id":274},"pushing-vuejs-to-github-pages","Pushing Vue.js to GitHub Pages",[205,277,278,287],{},[208,279,280,281,283,284],{},"Make sure you've done ",[24,282,133],{}," on the project files above first ",[285,286],"d",{},[208,288,289],{},"Works on both Vue CLI 2 & 3.",[17,291,292,293,295],{},"First, build the site so we have files the server can use. Run this (remember to ",[24,294,83],{}," into the project folder):",[86,297,299],{"className":88,"code":298,"language":76,"meta":90,"style":90},"npm run build\n",[24,300,301],{"__ignoreMap":90},[94,302,303],{"class":96,"line":97},[94,304,298],{},[17,306,307],{},"The build will look something like this:",[17,309,310],{},[52,311],{"alt":312,"src":313},"build complete","https:\u002F\u002Fi.imgur.com\u002FbCijwxL.png",[17,315,316,317,320],{},"The output is usually inside a ",[24,318,319],{},"dist"," folder, so move into it:",[86,322,324],{"className":88,"code":323,"language":76,"meta":90,"style":90},"cd dist\n",[24,325,326],{"__ignoreMap":90},[94,327,328],{"class":96,"line":97},[94,329,323],{},[17,331,332],{},"Initialize Git again:",[86,334,335],{"className":88,"code":115,"language":76,"meta":90,"style":90},[24,336,337],{"__ignoreMap":90},[94,338,339],{"class":96,"line":97},[94,340,115],{},[17,342,343,344,346],{},"Stage and commit everything in ",[24,345,319],{},":",[86,348,350],{"className":88,"code":349,"language":76,"meta":90,"style":90},"git add .\ngit commit -m 'first'\n",[24,351,352,356],{"__ignoreMap":90},[94,353,354],{"class":96,"line":97},[94,355,146],{},[94,357,359],{"class":96,"line":358},2,[94,360,361],{},"git commit -m 'first'\n",[17,363,364,365,368],{},"Then push to the remote on the ",[24,366,367],{},"gh-pages"," branch:",[86,370,372],{"className":88,"code":371,"language":76,"meta":90,"style":90},"git push -f 'remote repo' master:gh-pages\n",[24,373,374],{"__ignoreMap":90},[94,375,376],{"class":96,"line":97},[94,377,371],{},[17,379,380],{},"For this example that'd be:",[86,382,384],{"className":88,"code":383,"language":76,"meta":90,"style":90},"git push -f https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FGittest.git master:gh-pages\n",[24,385,386],{"__ignoreMap":90},[94,387,388],{"class":96,"line":97},[94,389,383],{},[17,391,392],{},"You'll also notice GitHub has enabled gh-pages for you (in Settings, scroll down to GitHub Pages):",[17,394,395],{},[52,396],{"alt":367,"src":397},"https:\u002F\u002Fi.imgur.com\u002FIWHg6ql.png",[17,399,400],{},"Note:\nOn the GitHub Pages URL, a blue box means \"preparing\", a green box means the site is live.",[12,402,404],{"id":403},"common-gotchas","Common gotchas",[17,406,407],{},"Vue CLI 2:",[409,410,411,425,432],"ol",{},[208,412,413,414,417,418,421,422,142],{},"File path\nThe default Vue file path is ",[24,415,416],{},"assetsPublicPath: '\u002F'",". I recommend changing it to ",[24,419,420],{},"assetsPublicPath: '.\u002F'"," — it's in ",[24,423,424],{},"config\u002Findex.js",[208,426,427,428,431],{},"config\u002Fprod.env.js\nIf you defined custom variables in ",[24,429,430],{},"dev.env.js",", remember to add them here too or you'll hit errors.",[208,433,434,435,438,439,460,463,464],{},"build\u002Futils.js\nIf your CSS uses something like ",[24,436,437],{},"background-image: url(..\u002F..\u002Fassets\u002Fimg\u002Fxxx.jpg);",", you'll find the file can't be located and the asset path looks weird. Fix it like this:",[86,440,444],{"className":441,"code":442,"language":443,"meta":90,"style":90},"language-js shiki shiki-themes github-dark-high-contrast","fallback: 'vue-style-loader'\n","js",[24,445,446],{"__ignoreMap":90},[94,447,448,452,456],{"class":96,"line":97},[94,449,451],{"class":450},"s_sBn","fallback",[94,453,455],{"class":454},"sMAXC",": ",[94,457,459],{"class":458},"sTRMh","'vue-style-loader'\n",[461,462],"br",{},"Then add another line below:",[86,465,467],{"className":441,"code":466,"language":443,"meta":90,"style":90},"publicPath: '..\u002F..\u002F'\n",[24,468,469],{"__ignoreMap":90},[94,470,471,474,476],{"class":96,"line":97},[94,472,473],{"class":450},"publicPath",[94,475,455],{"class":454},[94,477,478],{"class":458},"'..\u002F..\u002F'\n",[17,480,481],{},"Vue CLI 3:",[17,483,484,485,488],{},"In Vue CLI 3, use ",[24,486,487],{},"vue.config.js"," and add:",[86,490,492],{"className":441,"code":491,"language":443,"meta":90,"style":90},"module.exports = {\n  publicPath: '.\u002F'\n}\n",[24,493,494,512,520],{"__ignoreMap":90},[94,495,496,500,502,505,509],{"class":96,"line":97},[94,497,499],{"class":498},"sCcAr","module",[94,501,142],{"class":454},[94,503,504],{"class":498},"exports",[94,506,508],{"class":507},"sWyjQ"," =",[94,510,511],{"class":454}," {\n",[94,513,514,517],{"class":96,"line":358},[94,515,516],{"class":454},"  publicPath: ",[94,518,519],{"class":458},"'.\u002F'\n",[94,521,523],{"class":96,"line":522},3,[94,524,525],{"class":454},"}\n",[12,527,529],{"id":528},"references","References",[17,531,532,538],{},[38,533,537],{"href":534,"rel":535},"https:\u002F\u002Fhfcode.blogspot.com\u002F2019\u002F03\u002Fvue-cli-2xgithubpage.html",[536],"nofollow","HF Code Life"," (article in Mandarin)",[17,540,541,538],{},[38,542,545],{"href":543,"rel":544},"https:\u002F\u002Fgitbook.tw\u002Fchapters\u002Fgithub\u002Fpush-to-github.html",[536],"Git tutorial: How to Push to GitHub",[17,547,548,538],{},[38,549,552],{"href":550,"rel":551},"https:\u002F\u002Fwww.jianshu.com\u002Fp\u002Fcc053119f119",[536],"How to deploy a vue-cli project on GitHub Pages",[554,555,556],"style",{},"html .default .shiki span {color: var(--shiki-default);background: va