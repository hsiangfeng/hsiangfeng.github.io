[{"data":1,"prerenderedAt":268},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2019\u002F08\u002F21\u002Fnuxt-window-or-document-undefined-fix\u002F":3,"page:\u002Fen\u002Fvue\u002F2019\u002F08\u002F21\u002Fnuxt-window-or-document-undefined-fix\u002F":4,"alt:\u002Fen\u002Fvue\u002F2019\u002F08\u002F21\u002Fnuxt-window-or-document-undefined-fix\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2019\u002F08\u002F21\u002Fnuxt-window-or-document-undefined-fix\u002F":244,"related:\u002Fen\u002Fvue\u002F2019\u002F08\u002F21\u002Fnuxt-window-or-document-undefined-fix\u002F":253},"\u002Fvue\u002F20190821\u002F2073039643\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":226,"date":227,"description":228,"extension":229,"lang":230,"meta":231,"navigation":232,"path":233,"readingMinutes":234,"seo":235,"standalone":236,"stem":237,"tags":238,"tldr":241,"updated":227,"url":242,"__hash__":243},"content\u002Fen\u002FVue\u002Fnuxt-window-or-document-undefined-fix.md","Fixing 'window or document undefined' in Nuxt","6309342370",{"type":9,"value":10,"toc":220},"minimark",[11,16,25,29,40,50,79,82,88,95,127,130,134,137,164,167,192,195,199,209,216],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"Recently while developing in Nuxt.js, I hit a ",[21,22,23],"code",{},"window is not defined"," error when importing a package. Here's a note on how to fix it.",[12,26,28],{"id":27},"how-to-fix-it","How to fix it",[17,30,31,32,35,36,39],{},"When Nuxt builds, it bundles anything inside ",[21,33,34],{},"plugins\u002F"," into the server as well. That means some packages won't work because they need access to ",[21,37,38],{},"window",".",[17,41,42,43,45,46,49],{},"Here's an obvious example: create a file under ",[21,44,34],{}," called ",[21,47,48],{},"owlCarousel.js"," with:",[51,52,57],"pre",{"className":53,"code":54,"language":55,"meta":56,"style":56},"language-js shiki shiki-themes github-dark-high-contrast","require('owl.carousel');\n","js","",[21,58,59],{"__ignoreMap":56},[60,61,64,68,72,76],"span",{"class":62,"line":63},"line",1,[60,65,67],{"class":66},"sj_SG","require",[60,69,71],{"class":70},"sMAXC","(",[60,73,75],{"class":74},"sTRMh","'owl.carousel'",[60,77,78],{"class":70},");\n",[17,80,81],{},"And you'll get this error:",[17,83,84],{},[85,86],"img",{"alt":23,"src":87},"https:\u002F\u002Fi.imgur.com\u002FHOTPJWC.png",[17,89,90,91,94],{},"The fix is to keep Nuxt from bundling ",[21,92,93],{},"owl.carousel"," into the server side. Just do this:",[51,96,98],{"className":53,"code":97,"language":55,"meta":56,"style":56},"if (process.client) {\n  require('owl.carousel');\n}\n",[21,99,100,109,121],{"__ignoreMap":56},[60,101,102,106],{"class":62,"line":63},[60,103,105],{"class":104},"sWyjQ","if",[60,107,108],{"class":70}," (process.client) {\n",[60,110,112,115,117,119],{"class":62,"line":111},2,[60,113,114],{"class":66},"  require",[60,116,71],{"class":70},[60,118,75],{"class":74},[60,120,78],{"class":70},[60,122,124],{"class":62,"line":123},3,[60,125,126],{"class":70},"}\n",[17,128,129],{},"In short — only import the package on the client.",[12,131,133],{"id":132},"wrap-up","Wrap-up",[17,135,136],{},"The same applies to Bootstrap. You'll find two versions floating around online:",[51,138,140],{"className":53,"code":139,"language":55,"meta":56,"style":56},"if (process.browser) {\n  require('bootstrap');\n}\n",[21,141,142,149,160],{"__ignoreMap":56},[60,143,144,146],{"class":62,"line":63},[60,145,105],{"class":104},[60,147,148],{"class":70}," (process.browser) {\n",[60,150,151,153,155,158],{"class":62,"line":111},[60,152,114],{"class":66},[60,154,71],{"class":70},[60,156,157],{"class":74},"'bootstrap'",[60,159,78],{"class":70},[60,161,162],{"class":62,"line":123},[60,163,126],{"class":70},[17,165,166],{},"And:",[51,168,170],{"className":53,"code":169,"language":55,"meta":56,"style":56},"if (process.client) {\n  require('bootstrap');\n}\n",[21,171,172,178,188],{"__ignoreMap":56},[60,173,174,176],{"class":62,"line":63},[60,175,105],{"class":104},[60,177,108],{"class":70},[60,179,180,182,184,186],{"class":62,"line":111},[60,181,114],{"class":66},[60,183,71],{"class":70},[60,185,157],{"class":74},[60,187,78],{"class":70},[60,189,190],{"class":62,"line":123},[60,191,126],{"class":70},[17,193,194],{},"I've tested both and they work. But the latter is probably the cleaner choice for production code, since the official docs use that form.",[12,196,198],{"id":197},"references","References",[17,200,201,208],{},[202,203,207],"a",{"href":204,"rel":205},"https:\u002F\u002Fzh.nuxtjs.org\u002Ffaq\u002Fwindow-document-undefined\u002F",[206],"nofollow","Window or Document object undefined?"," (article in Mandarin)",[17,210,211],{},[202,212,215],{"href":213,"rel":214},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt.js\u002Fissues\u002F178",[206],"nuxt.js + bootstrap",[217,218,219],"style",{},"html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}",{"title":56,"searchDepth":111,"depth":111,"links":221},[222,223,224,225],{"id":14,"depth":111,"text":15},{"id":27,"depth":111,"text":28},{"id":132,"depth":111,"text":133},{"id":197,"depth":111,"text":198},"Vue","2019-08-21 11:23:55","Recently while developing in Nuxt.js, I hit a `window is not defined` error when importing a package. Here's a note on how to