71],"strong",{},[28,70,34],{}," installs the package temporarily, then removes it when it's done",". So you avoid global pollution. For packages you use all the time, ",[28,74,30],{}," is still better, otherwise every ",[28,77,34],{}," run downloads the package again.",[12,80,82],{"id":81},"quick-install","Quick install",[17,84,85,88],{},[28,86,87],{},"cd"," into your project directory and run:",[90,91,96],"pre",{"className":92,"code":93,"language":94,"meta":95,"style":95},"language-js shiki shiki-themes github-dark-high-contrast","npx create-nuxt-app\n","js","",[28,97,98],{"__ignoreMap":95},[99,100,103,107,111,114,116],"span",{"class":101,"line":102},"line",1,[99,104,106],{"class":105},"sMAXC","npx create",[99,108,110],{"class":109},"sWyjQ","-",[99,112,113],{"class":105},"nuxt",[99,115,110],{"class":109},[99,117,118],{"class":105},"app\n",[17,120,121],{},"The install takes a moment.",[17,123,124],{},[46,125],{"alt":126,"src":127},"Installing","https:\u002F\u002Fi.imgur.com\u002Fq2is0xL.png",[17,129,130,131,133,134,136],{},"NuxtJS will then ask a bunch of questions. I'm used to ",[28,132,30],{},", so I pick ",[28,135,30],{}," for package manager:",[17,138,139],{},[46,140],{"alt":141,"src":142},"Choose the package manager","https:\u002F\u002Fi.imgur.com\u002FO1wF9qZ.png",[17,144,145],{},"UI framework — I always skip this. Options are:",[147,148,149,153,156,159,162,165,168,171,174,177],"ul",{},[150,151,152],"li",{},"None",[150,154,155],{},"BootstrapVue",[150,157,158],{},"Vuetify",[150,160,161],{},"Bulma",[150,163,164],{},"Tailwind",[150,166,167],{},"Element UI",[150,169,170],{},"Ant Design Vue",[150,172,173],{},"Buefy",[150,175,176],{},"iView",[150,178,179],{},"Tachyons",[17,181,182],{},[46,183],{"alt":184,"src":185},"Choose UI framework","https:\u002F\u002Fi.imgur.com\u002FtCRaVNb.png",[17,187,188],{},"Server framework — also pick None:",[147,190,191,193,196,199,202,205,208,211],{},[150,192,152],{},[150,194,195],{},"Express",[150,197,198],{},"Koa",[150,200,201],{},"Hapi",[150,203,204],{},"Feathers",[150,206,207],{},"Micro",[150,209,210],{},"Fastify",[150,212,213],{},"AdonisJS",[17,215,216],{},[46,217],{"alt":218,"src":219},"Choose custom server framework","https:\u002F\u002Fi.imgur.com\u002FxiIlOz3.png",[17,221,222,223,42],{},"Nuxt modules — I pick ",[28,224,225],{},"axios",[17,227,228],{},[46,229],{"alt":230,"src":231},"Choose Nuxt modules","https:\u002F\u002Fi.imgur.com\u002FK0WS3Uc.png",[17,233,234],{},"Linting tools — I turn on ESLint:",[17,236,237],{},[46,238],{"alt":239,"src":240},"Choose linting tools","https:\u002F\u002Fi.imgur.com\u002FuuB22PL.png",[17,242,243],{},"Test framework — your call:",[17,245,246],{},[46,247],{"alt":248,"src":249},"Test framework","https:\u002F\u002Fi.imgur.com\u002FEKJbsVq.png",[17,251,252],{},"Rendering mode — for NuxtJS the obvious answer is SSR:",[17,254,255],{},[46,256],{"alt":257,"src":258},"Choose rendering mode","https:\u002F\u002Fi.imgur.com\u002FRIs69qO.png",[17,260,261],{},"Done. Install begins.",[17,263,264],{},[46,265],{"alt":266,"src":267},"Full setup","https:\u002F\u002Fi.imgur.com\u002FSMGUvRC.png",[12,269,271],{"id":270},"running-nuxtjs","Running NuxtJS",[17,273,274],{},"Nuxt gives you three default commands:",[147,276,277,287],{},[150,278,279,280],{},"Dev mode (local server)\n",[147,281,282],{},[150,283,284],{},[28,285,286],{},"npm run dev",[150,288,289,290],{},"Production\n",[147,291,292,297],{},[150,293,294],{},[28,295,296],{},"npm run build",[150,298,299],{},[28,300,301],{},"npm run start",[17,303,304,305,307],{},"Once the install finishes, run ",[28,306,286],{}," to start NuxtJS:",[17,309,310],{},[46,311],{"alt":312,"src":313},"Running","https:\u002F\u002Fi.imgur.com\u002FRRFFY18.png",[17,315,316,317,320],{},"Default server URL is ",[28,318,319],{},"localhost:3000",". If you see this when you visit, your Nuxt project is up:",[17,322,323],{},[46,324],{"alt":325,"src":326},"Project up","https:\u002F\u002Fi.imgur.com\u002FT3RhlEj.png",[12,328,330],{"id":329},"reference","Ref