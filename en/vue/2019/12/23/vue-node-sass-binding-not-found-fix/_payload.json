[{"data":1,"prerenderedAt":122},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F":3,"page:\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F":4,"alt:\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F":3,"prev-next:\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F":98,"related:\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F":107},"\u002Fvue\u002F20191223\u002F2765841171\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":81,"date":82,"description":83,"extension":84,"lang":85,"meta":86,"navigation":87,"path":88,"readingMinutes":89,"seo":90,"standalone":91,"stem":92,"tags":93,"tldr":95,"updated":82,"url":96,"__hash__":97},"content\u002Fen\u002FVue\u002Fvue-node-sass-binding-not-found-fix.md","Fixing 'Node Sass could not find a binding' in a Vue Project","1786254711",{"type":9,"value":10,"toc":74},"minimark",[11,16,25,29,36,46,50,61,65],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"I hit a ",[21,22,23],"code",{},"Node Sass could not find a binding for your current environment"," error in a Vue CLI 2 project recently, so here's a quick note on how to fix it.",[12,26,28],{"id":27},"the-problem","The problem",[17,30,31,32,35],{},"The project is on Vue CLI 2, so I ran ",[21,33,34],{},"npm start"," and got this:",[37,38,44],"pre",{"className":39,"code":41,"language":42,"meta":43},[40],"language-text","Module build failed: Error: Missing binding D:\\vue\\node_modules\\node-sass\\vendor\\win32-x64-67\\binding.node\nNode Sass could not find a binding for your current environment: Windows 64-bit with Node.js 11.x\n\nFound bindings for the following environments:\n  - OS X 64-bit with Node.js 12.x\n\nThis usually happens because your environment has changed since running `npm install`.\nRun `npm rebuild node-sass` to download the binding for your current environment.\n","text","",[21,45,41],{"__ignoreMap":43},[12,47,49],{"id":48},"how-to-fix-it","How to fix it",[17,51,52,53,56,57,60],{},"The fix is super simple — just run ",[21,54,55],{},"npm rebuild node-sass"," inside the project. The root cause is a wrong-version ",[21,58,59],{},"node-sass"," install.",[12,62,64],{"id":63},"references","References",[17,66,67],{},[68,69,73],"a",{"href":70,"rel":71},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F37986800\u002Fnode-sass-couldnt-find-a-binding-for-your-current-environment",[72],"nofollow","Node Sass couldn't find a binding for your current environment",{"title":43,"searchDepth":75,"depth":75,"links":76},2,[77,78,79,80],{"id":14,"depth":75,"text":15},{"id":27,"depth":75,"text":28},{"id":48,"depth":75,"text":49},{"id":63,"depth":75,"text":64},"Vue","2019-12-23 10:16:07","I hit a `Node Sass could not find a binding for your current environment` error in a Vue CLI 2 project recently, so here's a quick note on how to fix it.","md","en",{},true,"\u002Fen\u002Fvue\u002Fvue-node-sass-binding-not-found-fix","1",{"title":6,"description":83},false,"en\u002FVue\u002Fvue-node-sass-binding-not-found-fix",[81,94],"Troubleshooting",null,"\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F","bFUKgtcqlheevkv75L98xQDfhvx8cwMrC0LEyoMEtqk",{"newer":99,"older":103},{"url":100,"title":101,"date":102},"\u002Fen\u002Fhexo\u002F2019\u002F12\u002F25\u002Fswitch-hexo-next-to-algolia-search\u002F","Switching Hexo NexT to Algolia Search","2019-12-25 16:58:13",{"url":104,"title":105,"date":106},"\u002Fen\u002Fgulp\u002F2019\u002F12\u002F20\u002Fgulp-deploy-typeerror-cannot-read-property-fix\u002F","Gulp deploy Throws TypeError: Cannot read property 0 of null","2019-12-20 14:48:05",[108,113,117],{"url":109,"title":110,"date":111,"readingMinutes":112},"\u002Fen\u002Fvue\u002F2025\u002F12\u002F04\u002Fvue-nuxt-project-folder-structure\u002F","Vue\u00