[{"data":1,"prerenderedAt":558},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvscode\u002F2021\u002F07\u002F09\u002Fvscode-auto-fix-eslint-errors-on-save\u002F":3,"page:\u002Fen\u002Fvscode\u002F2021\u002F07\u002F09\u002Fvscode-auto-fix-eslint-errors-on-save\u002F":4,"alt:\u002Fen\u002Fvscode\u002F2021\u002F07\u002F09\u002Fvscode-auto-fix-eslint-errors-on-save\u002F":3,"prev-next:\u002Fen\u002Fvscode\u002F2021\u002F07\u002F09\u002Fvscode-auto-fix-eslint-errors-on-save\u002F":534,"related:\u002Fen\u002Fvscode\u002F2021\u002F07\u002F09\u002Fvscode-auto-fix-eslint-errors-on-save\u002F":543},"\u002Fvscode\u002F20210709\u002F4359299\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":516,"date":517,"description":518,"extension":519,"lang":520,"meta":521,"navigation":522,"path":523,"readingMinutes":524,"seo":525,"standalone":526,"stem":527,"tags":528,"tldr":531,"updated":517,"url":532,"__hash__":533},"content\u002Fen\u002FVSCode\u002Fvscode-auto-fix-eslint-errors-on-save.md","Auto-fixing ESLint Errors in VSCode (on Save and on Format)","1716517093",{"type":9,"value":10,"toc":506},"minimark",[11,16,20,24,42,49,52,62,65,69,72,77,80,95,98,105,108,120,126,129,135,138,144,147,199,205,208,214,218,225,231,234,248,253,256,286,289,293,297,300,312,321,327,330,343,346,352,355,360,363,368,374,410,413,446,449,481,485,488,496,499,502],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This post is a quick walkthrough on getting VSCode to auto-fix ESLint warnings and errors, including the formatting side of things.",[12,21,23],{"id":22},"read-this-first","Read this first",[25,26,27],"blockquote",{},[17,28,29,33,34,41],{},[30,31,32],"strong",{},"Note","\nESLint later decided to drop its code-formatting features, so going forward ESLint shouldn't conflict with Prettier as much. I've also written a Prettier intro: ",[35,36,40],"a",{"href":37,"rel":38},"https:\u002F\u002Fisraynotarray.com\u002F\u002Fjavascript\u002F20231031\u002F1586150719\u002F",[39],"nofollow","You'll end up using Prettier anyway — why not start with it? (article in Mandarin)",". I'm leaving this post as-is though, since some older projects still apply.",[17,43,44,45,48],{},"A note before diving in: if you're not confident with JavaScript yet, or you're a brand new dev, I'd strongly recommend ",[30,46,47],{},"not"," using this feature. Over-relying on tools before you understand how to fix errors yourself weakens your fundamentals and leaves you stuck when VSCode can't auto-fix something.",[17,50,51],{},"This feature is more suited for:",[53,54,55,59],"ul",{},[56,57,58],"li",{},"People with solid fundamentals who want to learn JS via ESLint",[56,60,61],{},"People who want to enforce a consistent code style on themselves",[17,63,64],{},"If you're either of those, this is great.",[12,66,68],{"id":67},"auto-fix-eslint-on-save","Auto-fix ESLint on save",[17,70,71],{},"Two ways to set this up.",[73,74,76],"h3",{"id":75},"global-vscode-setting","Global VSCode setting",[17,78,79],{},"The simplest: enable ESLint auto-fix globally. Every save triggers a fix.",[53,81,82,89],{},[56,83,84,85],{},"Windows: ",[86,87,88],"code",{},"Ctrl + S",[56,90,91,92],{},"Mac: ",[86,93,94],{},"Cmd + S",[17,96,97],{},"Click the gear icon → Settings.",[17,99,100],{},[101,102],"img",{"alt":103,"src":104},"Settings","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2009.51.45.png",[17,106,107],{},"If you can't find that, use the shortcut:",[53,109,110,115],{},[56,111,84,112],{},[86,113,114],{},"Ctrl + ,",[56,116,91,117],{},[86,118,119],{},"Cmd + ,",[17,121,122],{},[101,123],{"alt":124,"src":125},"Settings shortcut","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2009.55.29.png",[17,127,128],{},"Click \"Open Settings (JSON)\" at the top.",[17,130,131],{},[101,132],{"alt":133,"src":134},"Open Settings JSON","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96_2021-07-09_09_57_30.png",[17,136,137],{},"You'll see a JSON file.",[17,139,140],{},[101,141],{"alt":142,"src":143},"JSON file","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2010.01.53.png",[17,145,146],{},"Paste this into it:",[148,149,154],"pre",{"className":150,"code":151,"language":152,"meta":153,"style":153},"language-json shiki shiki-themes github-dark-high-contrast","\u002F\u002F Auto-fix ESLint on save\n\"editor.codeActionsOnSave\": {\n    \"source.fixAll.eslint\": true,\n},\n","json","",[86,155,156,165,176,193],{"__ignoreMap":153},[157,158,161],"span",{"class":159,"line":160},"line",1,[157,162,164],{"class":163},"sQrFR","\u002F\u002F Auto-fix ESLint on save\n",[157,166,168,172],{"class":159,"line":167},2,[157,169,171],{"class":170},"sTRMh","\"editor.codeActionsOnSave\"",[157,173,175],{"class":174},"sMAXC",": {\n",[157,177,179,183,186,190],{"class":159,"line":178},3,[157,180,182],{"class":181},"sKpQp","    \"source.fixAll.eslint\"",[157,184,185],{"class":174},": ",[157,187,189],{"class":188},"sCcAr","true",[157,191,192],{"class":174},",\n",[157,194,196],{"class":159,"line":195},4,[157,197,198],{"class":174},"},\n",[17,200,201],{},[101,202],{"alt":203,"src":204},"codeActionsOnSave","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2010.03.20.png",[17,206,207],{},"Now open a project full of ESLint errors and hit save — you'll see them auto-fix.",[17,209,210],{},[101,211],{"alt":212,"src":213},"Auto-fixing","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002FJul-09-2021%2010-13-00.gif",[73,215,217],{"id":216},"project-level-vscode-setting","Project-level VSCode setting",[17,219,220,221,224],{},"Sometimes you only want this for a specific project, not your whole machine. In that case, create a ",[86,222,223],{},".vscode"," folder in your project.",[17,226,227],{},[101,228],{"alt":229,"src":230},".vscode folder","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2010.18.05.png",[17,232,233],{},"This folder holds project-scoped VSCode settings — same concept as the global settings, just scoped to one project.",[17,235,236,237,240,241,243,244,247],{},"Inside, create a file called ",[86,238,239],{},"settings.json"," (note: ",[86,242,239],{},", not ",[86,245,246],{},"setting.json",").",[17,249,250],{},[101,251],{"alt":239,"src":252},"https:\u002F\u002Fi.imgur.com\u002F1SRJlBt.png",[17,254,255],{},"Paste this in:",[148,257,259],{"className":150,"code":258,"language":152,"meta":153,"style":153},"{\n  \"eslint.autoFixOnSave\": true, \u002F\u002F auto-format on save\n}\n",[86,260,261,266,281],{"__ignoreMap":153},[157,262,263],{"class":159,"line":160},[157,264,265],{"class":174},"{\n",[157,267,268,271,273,275,278],{"class":159,"line":167},[157,269,270],{"class":181},"  \"eslint.autoFixOnSave\"",[157,272,185],{"class":174},[157,274,189],{"class":188},[157,276,277],{"class":174},", ",[157,279,280],{"class":163},"\u002F\u002F auto-format on save\n",[157,282,283],{"class":159,"line":178},[157,284,285],{"class":174},"}\n",[17,287,288],{},"Same auto-fix-on-save behaviour as the global setting.",[17,290,291],{},[101,292],{"alt":212,"src":213},[12,294,296],{"id":295},"fix-eslint-via-format-document","Fix ESLint via Format Document",[17,298,299],{},"The other approach is to use VSCode's Format Document feature.",[53,301,302,307],{},[56,303,84,304],{},[86,305,306],{},"Shift + Alt + F",[56,308,91,309],{},[86,310,311],{},"Cmd + Option + F",[17,313,314,315,320],{},"The catch is VSCode's built-in formatter uses Prettier style, which conflicts with ESLint. Most people install the ",[35,316,319],{"href":317,"rel":318},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=esbenp.prettier-vscode",[39],"Prettier - Code formatter"," extension (some VSCode versions install it by default — though mine didn't, so I haven't run into that). But Prettier's style and ESLint's style clash.",[17,322,323],{},[101,324],{"alt":325,"src":326},"Prettier vs ESLint conflict","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002FJul-09-2021%2010-43-21.gif",[17,328,329],{},"A few fixes:",[53,331,332,335],{},[56,333,334],{},"Use the auto-fix-on-save setup above",[56,336,337,338],{},"Install ",[35,339,342],{"href":340,"rel":341},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=rvest.vs-code-prettier-eslint",[39],"Prettier ESLint",[17,344,345],{},"After installing Prettier ESLint, the first time you hit the format shortcut, this dialog pops up.",[17,347,348],{},[101,349],{"alt":350,"src":351},"Style picker","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2010.48.19.png",[17,353,354],{},"Click Configure and pick Prettier ESLint.",[17,356,357],{},[101,358],{"alt":350,"src":359},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-07-09%2010.49.34.png",[17,361,362],{},"That resolves the Prettier vs ESLint conflict.",[17,364,365],{},[101,366],{"alt":342,"src":367},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002FJul-09-2021%2010-51-14.gif",[17,369,370,371,373],{},"If the dialog never shows up, open ",[86,372,239],{}," and find:",[148,375,377],{"className":150,"code":376,"language":152,"meta":153,"style":153},"{\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"....\"\n  },\n}\n",[86,378,379,383,390,400,405],{"__ignoreMap":153},[157,380,381],{"class":159,"line":160},[157,382,265],{"class":174},[157,384,385,388],{"class":159,"line":167},[157,386,387],{"class":181},"  \"[javascript]\"",[157,389,175],{"class":174},[157,391,392,395,397],{"class":159,"line":178},[157,393,394],{"class":181},"    \"editor.defaultFormatter\"",[157,396,185],{"class":174},[157,398,399],{"class":170},"\"....\"\n",[157,401,402],{"class":159,"line":195},[157,403,404],{"class":174},"  },\n",[157,406,408],{"class":159,"line":407},5,[157,409,285],{"class":174},[17,411,412],{},"Change it to:",[148,414,416],{"className":150,"code":415,"language":152,"meta":153,"style":153},"{\n  \"[javascript]\": {\n      \"editor.defaultFormatter\": \"rvest.vs-code-prettier-eslint\"\n  },\n}\n",[86,417,418,422,428,438,442],{"__ignoreMap":153},[157,419,420],{"class":159,"line":160},[157,421,265],{"class":174},[157,423,424,426],{"class":159,"line":167},[157,425,387],{"class":181},[157,427,175],{"class":174},[157,429,430,433,435],{"class":159,"line":178},[157,431,432],{"class":181},"      \"editor.defaultFormatter\"",[157,434,185],{"class":174},[157,436,437],{"class":170},"\"rvest.vs-code-prettier-eslint\"\n",[157,439,440],{"class":159,"line":195},[157,441,404],{"class":174},[157,443,444],{"class":159,"line":407},[157,445,285],{"class":174},[17,447,448],{},"Some people have it set to VSCode's TS-language formatter by default, which is why the dialog doesn't show:",[148,450,452],{"className":150,"code":451,"language":152,"meta":153,"style":153},"{\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"vscode.typescript-language-features\"\n  },\n}\n",[86,453,454,458,464,473,477],{"__ignoreMap":153},[157,455,456],{"class":159,"line":160},[157,457,265],{"class":174},[157,459,460,462],{"class":159,"line":167},[157,461,387],{"class":181},[157,463,175],{"class":174},[157,465,466,468,470],{"class":159,"line":178},[157,467,394],{"class":181},[157,469,185],{"class":174},[157,471,472],{"class":170},"\"vscode.typescript-language-features\"\n",[157,474,475],{"class":159,"line":195},[157,476,404],{"class":174},[157,478,479],{"class":159,"line":407},[157,480,285],{"class":174},[12,482,484],{"id":483},"bonus","Bonus",[17,486,487],{},"You might be wondering what the actual difference is between these two approaches:",[53,489,490,493],{},[56,491,492],{},"Save Auto Fix ESLint",[56,494,495],{},"Format Document Auto Fix ESLint",[17,497,498],{},"Short version: the save-time fix kicks in when you save, so it depends on ESLint warnings being present — if no ESLint warning, no fix. The format-document approach reformats according to ESLint rules every time you trigger the format command.",[17,500,501],{},"Which is better? Whichever fits your workflow.",[503,504,505],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":153,"searchDepth":167,"depth":167,"links":507},[508,509,510,514,515],{"id":14,"depth":167,"text":15},{"id":22,"depth":167,"text":23},{"id":67,"depth":167,"text":68,"children":511},[512,513],{"id":75,"depth":178,"text":76},{"id":216,"depth":178,"text":217},{"id":295,"depth":167,"text":296},{"id":483,"depth":167,"text":484},"VSCode","2021-07-09 09:41:16","A walkthrough on how to make VSCode auto-fix ESLint warnings and errors, including how to handle formatting conflicts between ESLint and Prettier.","md","en",{},true,"\u002Fen\u002Fvscode\u002Fvscode-auto-fix-eslint-errors-on-save","3",{"title":6,"description":518},false,"en\u002FVSCode\u002Fvscode-auto-fix-eslint-errors-on-save",[516,529,342,530],"ESLint","Prettier",null,"\u002Fen\u002Fvscode\u002F2021\u002F07\u002F09\u002Fvscode-auto-fix-eslint-errors-on-save\u002F","inKY1c4NydfLEmFN67wQiXJLlb5bBdaV9gxHEiwwiGk",{"newer":535,"older":539},{"url":536,"title":537,"date":538},"\u002Fen\u002Fgit\u002F2021\u002F07\u002F09\u002Fgithub-ssh-ed25519-setup\u002F","Connecting to GitHub With SSH (Ed25519)","2021-07-09 22:43:03",{"url":540,"title":541,"date":542},"\u002Fen\u002Fvscode\u002F2021\u002F07\u002F04\u002Fhow-to-change-vscode-language\u002F","How to Change VSCode's Language in a Few Quick Steps","2021-07-04 11:34:50",[544,549,554],{"url":545,"title":546,"date":547,"readingMinutes":548},"\u002Fen\u002Fvscode\u002F2025\u002F04\u002F24\u002Fvscode-cannot-find-git-set-git-path\u002F","VSCode 'Can't Find Git, Install It or Use git.path' — How to Fix","2025-04-24 09:52:23","1",{"url":550,"title":551,"date":552,"readingMinutes":553},"\u002Fen\u002Fvscode\u002F2024\u002F09\u002F08\u002Fgithub-copilot-tips-and-tricks-deep-dive\u002F","GitHub Copilot Feels Awkward? You Might Just Not Know These Tricks","2024-09-08 13:06:00","5",{"url":555,"title":556,"date":557,"readingMinutes":548},"\u002Fen\u002Fvscode\u002F2023\u002F10\u002F26\u002Fvscode-vue-custom-component-syntax-highlight-fix\u002F","Vue Custom Components Lost Their Highlighting in VSCode — Here's the Fix","2023-10-26 11:03:07",1784010293149]