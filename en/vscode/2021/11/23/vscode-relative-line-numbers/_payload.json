[{"data":1,"prerenderedAt":116},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvscode\u002F2021\u002F11\u002F23\u002Fvscode-relative-line-numbers\u002F":3,"page:\u002Fen\u002Fvscode\u002F2021\u002F11\u002F23\u002Fvscode-relative-line-numbers\u002F":4,"alt:\u002Fen\u002Fvscode\u002F2021\u002F11\u002F23\u002Fvscode-relative-line-numbers\u002F":3,"prev-next:\u002Fen\u002Fvscode\u002F2021\u002F11\u002F23\u002Fvscode-relative-line-numbers\u002F":93,"related:\u002Fen\u002Fvscode\u002F2021\u002F11\u002F23\u002Fvscode-relative-line-numbers\u002F":102},"\u002Fvscode\u002F20211123\u002F335355052\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":75,"date":76,"description":77,"extension":78,"lang":79,"meta":80,"navigation":81,"path":82,"readingMinutes":83,"seo":84,"standalone":85,"stem":86,"tags":87,"tldr":90,"updated":76,"url":91,"__hash__":92},"content\u002Fen\u002FVSCode\u002Fvscode-relative-line-numbers.md","Switch VSCode to Relative Line Numbers (Handy for Vim Users)","2663599132",{"type":9,"value":10,"toc":68},"minimark",[11,16,20,24,36,39,46,49,55,59,62],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"I've slowly been switching to Vim\u002FVi for development and writing in VSCode, so here's a quick note on how to turn on relative line numbers.",[12,21,23],{"id":22},"relative-vs-absolute-line-numbers","Relative vs absolute line numbers",[17,25,26,27,31,32,35],{},"If you're a Vim\u002FVi user, you basically want relative line numbers in VSCode — Vim navigation is all about relative jumps like ",[28,29,30],"code",{},"4j",", ",[28,33,34],{},"V4k",", and so on. So here's how to switch over.",[17,37,38],{},"What's the difference between relative and absolute? Absolute line numbers just show the actual line number next to each line:",[17,40,41],{},[42,43],"img",{"alt":44,"src":45},"Absolute line numbers","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVSCode\u002F%E6%88%AA%E5%9C%96%202021-11-23%2014.34.28.png",[17,47,48],{},"Re