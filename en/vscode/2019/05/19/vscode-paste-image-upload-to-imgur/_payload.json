[{"data":1,"prerenderedAt":411},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fvscode\u002F2019\u002F05\u002F19\u002Fvscode-paste-image-upload-to-imgur\u002F":3,"page:\u002Fen\u002Fvscode\u002F2019\u002F05\u002F19\u002Fvscode-paste-image-upload-to-imgur\u002F":4,"alt:\u002Fen\u002Fvscode\u002F2019\u002F05\u002F19\u002Fvscode-paste-image-upload-to-imgur\u002F":3,"prev-next:\u002Fen\u002Fvscode\u002F2019\u002F05\u002F19\u002Fvscode-paste-image-upload-to-imgur\u002F":387,"related:\u002Fen\u002Fvscode\u002F2019\u002F05\u002F19\u002Fvscode-paste-image-upload-to-imgur\u002F":396},"\u002Fvscode\u002F20190519\u002F2164825737\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":111,"date":372,"description":373,"extension":374,"lang":375,"meta":376,"navigation":377,"path":378,"readingMinutes":379,"seo":380,"standalone":381,"stem":382,"tags":383,"tldr":384,"updated":372,"url":385,"__hash__":386},"content\u002Fen\u002FVSCode\u002Fvscode-paste-image-upload-to-imgur.md","Paste Images Straight to Imgur from VSCode","6112841800",{"type":9,"value":10,"toc":366},"minimark",[11,16,20,27,30,40,44,60,63,73,79,82,90,96,99,105,108,112,121,127,139,144,147,202,205,211,218,224,227,233,236,242,245,251,254,258,261,267,270,281,287,290,296,299,305,308,314,325,331,337,359,362],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"I switched to VSCode for writing posts, but uploading images through the Imgur website and copying the URL back into the Markdown file every single time was painful. I found an extension that solves this — it looks like this:",[17,21,22],{},[23,24],"img",{"alt":25,"src":26},"Demo","https:\u002F\u002Fi.imgur.com\u002FjPm7V6t.gif",[17,28,29],{},"So here's how to install and use it.",[31,32,33],"blockquote",{},[17,34,35,39],{},[36,37,38],"strong",{},"Note","\nThis post covers Imgur, but after 2025-05-16 Imgur stopped letting Taiwan IPs upload images. If you're in Taiwan, you might want to switch to a different image hosting service.",[12,41,43],{"id":42},"imgur","Imgur",[17,45,46,47,53,54,59],{},"First, open ",[48,49,43],"a",{"href":50,"rel":51},"https:\u002F\u002Fimgur.com\u002F",[52],"nofollow",", register an account and log in. Then head to ",[48,55,58],{"href":56,"rel":57},"https:\u002F\u002Fapi.imgur.com\u002Foauth2\u002Faddclient",[52],"Imgur API"," to apply for API credentials.",[17,61,62],{},"Fill in the highlighted fields:",[64,65,66,70],"ul",{},[67,68,69],"li",{},"Application name: anything you'll remember",[67,71,72],{},"Authorization type: OAuth 2 authorization without a callback URL",[17,74,75],{},[23,76],{"alt":77,"src":78},"Application form","https:\u002F\u002Fi.imgur.com\u002FbaiboMe.png",[17,80,81],{},"After submitting, you'll get two things — make sure to copy and save them.",[64,83,84,87],{},[67,85,86],{},"Client ID",[67,88,89],{},"Client secret",[17,91,92],{},[23,93],{"alt":94,"src":95},"Credentials","https:\u002F\u002Fi.imgur.com\u002FJDbWQvj.png",[17,97,98],{},"If you lose them, you can look them up here, but Client secret will need to be regenerated.",[17,100,101],{},[23,102],{"alt":103,"src":104},"Lookup","https:\u002F\u002Fi.imgur.com\u002FS2YXgWJ.png",[17,106,107],{},"Note: don't close the page yet — we'll come back to it.",[12,109,111],{"id":110},"vscode","VSCode",[17,113,114,115,120],{},"Now install the extension. Search for ",[48,116,119],{"href":117,"rel":118},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=MaxfieldWalker.vscode-imgur",[52],"vscode-imgur"," in the Extensions panel.",[17,122,123],{},[23,124],{"alt":125,"src":126},"Extension","https:\u002F\u002Fi.imgur.com\u002FDPrgqT0.png",[17,128,129,130,134,135,138],{},"Open VSCode settings — usually ",[131,132,133],"code",{},"Ctrl + ,"," (Windows) — or go to Settings and find ",[131,136,137],{},"settings.json",".",[17,140,141],{},[23,142],{"alt":137,"src":143},"https:\u002F\u002Fi.imgur.com\u002FkQuW99p.png",[17,145,146],{},"Paste in:",[148,149,154],"pre",{"className":150,"code":151,"language":152,"meta":153,"style":153},"language-json shiki shiki-themes github-dark-high-contrast","\"vscode-imgur.client_id\": \"your imgur client_id\",\n\"vscode-imgur.client_secret\": \"your imgur client_secret\",\n\"vscode-imgur.preferUserUpload\": true,\n","json","",[131,155,156,175,188],{"__ignoreMap":153},[157,158,161,165,169,172],"span",{"class":159,"line":160},"line",1,[157,162,164],{"class":163},"sTRMh","\"vscode-imgur.client_id\"",[157,166,168],{"class":167},"sMAXC",": ",[157,170,171],{"class":163},"\"your imgur client_id\"",[157,173,174],{"class":167},",\n",[157,176,178,181,183,186],{"class":159,"line":177},2,[157,179,180],{"class":163},"\"vscode-imgur.client_secret\"",[157,182,168],{"class":167},[157,184,185],{"class":163},"\"your imgur client_secret\"",[157,187,174],{"class":167},[157,189,191,194,196,200],{"class":159,"line":190},3,[157,192,193],{"class":163},"\"vscode-imgur.preferUserUpload\"",[157,195,168],{"class":167},[157,197,199],{"class":198},"sCcAr","true",[157,201,174],{"class":167},[17,203,204],{},"Now find any image, right-click and copy it.",[17,206,207],{},[23,208],{"alt":209,"src":210},"Copy image","https:\u002F\u002Fi.imgur.com\u002Fin5Seuu.png",[17,212,213,214,217],{},"In your Markdown file in VSCode, hit ",[131,215,216],{},"Ctrl + Alt + V",". It'll pause and pop this dialog:",[17,219,220],{},[23,221],{"alt":222,"src":223},"Dialog","https:\u002F\u002Fi.imgur.com\u002F6RdhBy0.png",[17,225,226],{},"Switch over to your browser — Imgur will say vscode-imgur wants to upload images on your behalf. Hit Allow.",[17,228,229],{},[23,230],{"alt":231,"src":232},"Allow","https:\u002F\u002Fi.imgur.com\u002FtPJjSUI.png",[17,234,235],{},"Imgur will show you a PIN. Copy it.",[17,237,238],{},[23,239],{"alt":240,"src":241},"PIN","https:\u002F\u002Fi.imgur.com\u002FzZy5t5T.png",[17,243,244],{},"Paste the PIN back in VSCode:",[17,246,247],{},[23,248],{"alt":249,"src":250},"Paste PIN","https:\u002F\u002Fi.imgur.com\u002FJau7SQ6.png",[17,252,253],{},"Done — you can now upload images directly.",[12,255,257],{"id":256},"album-sorting","Album sorting",[17,259,260],{},"If you want uploaded images sorted into an album, head to Imgur and create one.",[17,262,263],{},[23,264],{"alt":265,"src":266},"Create album","https:\u002F\u002Fi.imgur.com\u002F04iAW7S.png",[17,268,269],{},"Fill in the fields. The bottom option is up to you — I use public.",[64,271,272,275,278],{},[67,273,274],{},"public — public",[67,276,277],{},"Hidden — hidden",[67,279,280],{},"Secret — secret (locked?)",[17,282,283],{},[23,284],{"alt":285,"src":286},"Album options","https:\u002F\u002Fi.imgur.com\u002FtwZFX0a.png",[17,288,289],{},"After creating, I'd suggest uploading one image to it first. Then click your gallery profile at the top.",[17,291,292],{},[23,293],{"alt":294,"src":295},"Gallery profile","https:\u002F\u002Fi.imgur.com\u002FguezJvh.png",[17,297,298],{},"Then click Albums.",[17,300,301],{},[23,302],{"alt":303,"src":304},"Albums","https:\u002F\u002Fi.imgur.com\u002FjZ6ERtG.png",[17,306,307],{},"If you uploaded an image already, you'll see it here. Click into it.",[17,309,310],{},[23,311],{"alt":312,"src":313},"Album view","https:\u002F\u002Fi.imgur.com\u002FP3mPkGf.png",[17,315,316,317,320,321,324],{},"Grab the album code from the URL — in my case it's ",[131,318,319],{},"d7B2zub"," (after ",[131,322,323],{},"a\u002F","). Remember this code.",[17,326,327],{},[23,328],{"alt":329,"src":330},"Album code","https:\u002F\u002Fi.imgur.com\u002F8DQzjCk.png",[17,332,333,334,336],{},"Back in VSCode, open ",[131,335,137],{}," and paste:",[148,338,340],{"className":150,"code":339,"language":152,"meta":153,"style":153},"\"vscode-imgur.album_id\": \"your album code\", \u002F\u002F mine is d7B2zub\n",[131,341,342],{"__ignoreMap":153},[157,343,344,347,349,352,355],{"class":159,"line":160},[157,345,346],{"class":163},"\"vscode-imgur.album_id\"",[157,348,168],{"class":167},[157,350,351],{"class":163},"\"your album code\"",[157,353,354],{"class":167},", ",[157,356,358],{"class":357},"sQrFR","\u002F\u002F mine is d7B2zub\n",[17,360,361],{},"That's it — try pasting images directly into VSCode now.",[363,364,365],"style",{},"html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":153,"searchDepth":177,"depth":177,"links":367},[368,369,370,371],{"id":14,"depth":177,"text":15},{"id":42,"depth":177,"text":43},{"id":110,"depth":177,"text":111},{"id":256,"depth":177,"text":257},"2019-05-19 20:15:56","I switched to VSCode for writing posts, but having to upload images through the Imgur website and copy the URL every time was painful. Then I found an extension that handles it inside VSCode — here's how to set it up.","md","en",{},true,"\u002Fen\u002Fvscode\u002Fvscode-paste-image-upload-to-imgur","2",{"title":6,"description":373},false,"en\u002FVSCode\u002Fvscode-paste-image-upload-to-imgur",[111,43],null,"\u002Fen\u002Fvscode\u002F2019\u002F05\u002F19\u002Fvscode-paste-image-upload-to-imgur\u002F","PoK-W_HTqr_ExYCEY1NRXusG0DdqjGrsppIBOXNCuQ4",{"newer":388,"older":392},{"url":389,"title":390,"date":391},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-33-syntax-parser\u002F","[JS Weird World] No.33 Quick Reminder: The Syntax Parser","2019-05-19 21:10:00",{"url":393,"title":394,"date":395},"\u002Fen\u002Fjsweirdworld\u002F2019\u002