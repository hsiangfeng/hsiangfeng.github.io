[{"data":1,"prerenderedAt":78},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fcategories\u002Fnodejs\u002Fpage\u002F10\u002F":3,"category-page:en:nodejs:10":4,"author-stats:en:full":75},null,{"category":5,"posts":6,"total":73,"totalPages":74},"Nodejs",[7,16,23,30,36,43,49,55,61,67],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F22\u002Fkoa-saga-login-2\u002F","Koa Saga: Member Login (2)","2019-07-22 14:29:41",[12,13],"Node.js","Koa Saga","We've got the login UI and basics in place. Now let's talk about password handling.","2",{"url":17,"title":18,"date":19,"updated":3,"category":5,"tags":20,"description":21,"readingMinutes":22},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F21\u002Fkoa-saga-login-1\u002F","Koa Saga: Member Login (1)","2019-07-21 16:15:21",[12,13],"We've covered a lot — time to level up and build a member login. But first, some prep.","1",{"url":24,"title":25,"date":26,"updated":3,"category":5,"tags":27,"description":28,"readingMinutes":29},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F20\u002Fkoa-saga-mysql-sequelize-4\u002F","Koa Saga: MySQL — sequelize (4)","2019-07-20 17:26:04",[12,13],"We've handled queries. Now let's POST form data and insert into the database.","3",{"url":31,"title":32,"date":33,"updated":3,"category":5,"tags":34,"description":35,"readingMinutes":15},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F20\u002Fkoa-saga-mysql-sequelize-3\u002F","Koa Saga: MySQL — sequelize (3)","2019-07-20 11:57:11",[12,13],"We've seen migrations as a way to transfer schema (not data) between databases. Now let's see how to use sequelize for form data + insert in the actual app.",{"url":37,"title":38,"date":39,"updated":3,"category":5,"tags":40,"description":42,"readingMinutes":22},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F18\u002Fsequelize-cli-typeerror-fix\u002F","Sequelize-cli TypeError: How to Fix It","2019-07-18 19:35:57",[12,41],"Sequelize","R