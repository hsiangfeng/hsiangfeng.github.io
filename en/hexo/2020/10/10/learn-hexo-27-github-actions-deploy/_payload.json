Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-09-16%2017.46.12.png",[12,498,500],{"id":499},"extra","Extra",[17,502,503,504,156],{},"If auto-deploy isn't working, the culprit might be this block in ",[69,505,506],{},"hexo\u002F_config.yml",[78,508,510],{"className":180,"code":509,"language":182,"meta":83,"style":83},"deploy:\n  type: git\n  repo: https:\u002F\u002Fgithub.com\u002Fjc-eng\u002Fjc-eng.github.io.git # https:\u002F\u002Fgithub.com\u002F[your-username]\u002F[your-username].github.io.git\n  branch: master # using master as the main branch here\n  message: 'ithelpt'\n",[69,511,512,519,529,542,555],{"__ignoreMap":83},[87,513,514,517],{"class":89,"line":90},[87,515,516],{"class":189},"deploy",[87,518,222],{"class":193},[87,520,521,524,526],{"class":89,"line":201},[87,522,523],{"class":189},"  type",[87,525,194],{"class":193},[87,527,528],{"class":197},"git\n",[87,530,531,534,536,539],{"class":89,"line":208},[87,532,533],{"class":189},"  repo",[87,535,194],{"class":193},[87,537,538],{"class":197},"https:\u002F\u002Fgithub.com\u002Fjc-eng\u002Fjc-eng.github.io.git",[87,540,541],{"class":211}," # https:\u002F\u002Fgithub.com\u002F[your-username]\u002F[your-username].github.io.git\n",[87,543,544,547,549,552],{"class":89,"line":215},[87,545,546],{"class":189},"  branch",[87,548,194],{"class":193},[87,550,551],{"class":197},"master",[87,553,554],{"class":211}," # using master as the main branch here\n",[87,556,557,560,562],{"class":89,"line":225},[87,558,559],{"class":189},"  message",[87,561,194],{"class":193},[87,563,564],{"class":197},"'ithelpt'\n",[17,566,567],{},"You need to switch from HTTPS mode to SSH mode, because GitHub Actions uses SSH:",[78,569,571],{"className":180,"code":570,"language":182,"meta":83,"style":83},"deploy:\n  type: git\n  repo: git@github.com:jc-eng\u002Fjc-eng.github.io.git\n  branch: master # using master as the main branch here\n  message: 'ithelpt'\n",[69,572,573,579,587,596,606],{"__ignoreMap":83},[87,574,575,577],{"class