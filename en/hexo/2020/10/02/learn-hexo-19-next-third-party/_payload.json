,"Search Services\n",[33,64,65],{},[36,66,67],{},"Search",[36,69,70,71],{},"Chat Services\n",[33,72,73],{},[36,74,75],{},"Chat widgets",[36,77,78,79],{},"Tags Settings\n",[33,80,81],{},[36,82,83],{},"Tag services",[17,85,86],{},"NexT integrates these really well — most of them just need you to sign up for an account, paste in an ID, and you're done. A few might need an enable toggle on top of that. I'll cover a few I think are worth using.",[12,88,90],{"id":89},"widget-pack","WIDGET PACK",[17,92,93],{},"First up is WIDGET PACK, a star-rating comment system. You can see a demo on their site:",[17,95,96],{},[97,98],"img",{"alt":99,"src":100},"DEMO","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-09-03%2022.23.56.png",[17,102,103],{},"NexT already integrates it, so you just fill in the App ID and toggle it on. Note: only the star rating works through NexT.",[105,106,111],"pre",{"className":107,"code":108,"language":109,"meta":110,"style":110},"language-yml shiki shiki-themes github-dark-high-contrast","rating:\n  enable: false\n  id:     # \u003Capp_id>\n  color:  fc6423\n","yml","",[28,112,113,126,139,152],{"__ignoreMap":110},[114,115,118,122],"span",{"class":116,"line":117},"line",1,[114,119,121],{"class":120},"sKpQp","rating",[114,123,125],{"class":124},"sMAXC",":\n",[114,127,129,132,135],{"class":116,"line":128},2,[114,130,131],{"class":120},"  enable",[114,133,134],{"class":124},": ",[114,136,138],{"class":137},"sCcAr","false\n",[114,140,142,145,148],{"class":116,"line":141},3,[114,143,144],{"class":120},"  id",[114,146,147],{"class":124},":     ",[114,149,151],{"class":150},"sQrFR","# \u003Capp_id>\n",[114,153,155,158,161],{"class":116,"line":154},4,[114,156,157],{"class":120},"  color",[114,159,160],{"class":124},":  ",[114,162,164],{"class":163},"sTRMh","fc6423\n",[17,166,167,168,175],{},"Sign up at the ",[169,170,174],"a",{"href":171,"rel":172},"https