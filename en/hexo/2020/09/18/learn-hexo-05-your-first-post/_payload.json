[{"data":1,"prerenderedAt":255},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fhexo\u002F2020\u002F09\u002F18\u002Flearn-hexo-05-your-first-post\u002F":3,"page:\u002Fen\u002Fhexo\u002F2020\u002F09\u002F18\u002Flearn-hexo-05-your-first-post\u002F":4,"alt:\u002Fen\u002Fhexo\u002F2020\u002F09\u002F18\u002Flearn-hexo-05-your-first-post\u002F":3,"prev-next:\u002Fen\u002Fhexo\u002F2020\u002F09\u002F18\u002Flearn-hexo-05-your-first-post\u002F":232,"related:\u002Fen\u002Fhexo\u002F2020\u002F09\u002F18\u002Flearn-hexo-05-your-first-post\u002F":241},"\u002Fhexo\u002F20200918\u002F1800712118\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":213,"date":214,"description":19,"extension":215,"lang":216,"meta":217,"navigation":218,"path":219,"readingMinutes":220,"seo":221,"standalone":222,"stem":223,"tags":224,"tldr":229,"updated":214,"url":230,"__hash__":231},"content\u002Fen\u002FHexo\u002Flearn-hexo-05-your-first-post.md","(5) Learning Hexo from Scratch - Your First Post","8112170081",{"type":9,"value":10,"toc":206},"minimark",[11,16,20,24,27,36,42,45,48,52,60,66,74,80,87,92,102,108,111,115,118,124,149,157,160,166,169,179,188,191,197,200],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Next up we'll create your first blog post. Before we start, I'd recommend using Visual Studio Code to write your articles.",[12,21,23],{"id":22},"visual-studio-code","Visual Studio Code",[17,25,26],{},"Before we begin, grab Visual Studio Code from the official site.",[17,28,29],{},[30,31,35],"a",{"href":32,"rel":33},"https:\u002F\u002Fcode.visualstudio.com\u002F",[34],"nofollow","Visual Studio Code official site",[17,37,38],{},[39,40],"img",{"alt":23,"src":41},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-18%2013.57.52.png",[17,43,44],{},"The official site will give you the installer for your OS automatically.",[17,46,47],{},"From here on I'll just call Visual Studio Code \"VSCode\".",[12,49,51],{"id":50},"create-your-first-post","Create your first post",[17,53,54,55,59],{},"Now let's open the Hexo project we created back in \"",[30,56,58],{"href":57},"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F16\u002Flearn-hexo-03-install-hexo\u002F","Learning Hexo from Scratch - How to Install Hexo","\" in VSCode.",[17,61,62],{},[39,63],{"alt":64,"src":65},"Open Hexo","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-18%2014.03.55.png",[17,67,68,69,73],{},"You'll need to open the VSCode terminal. The shortcut is Ctrl + ",[70,71,72],"code",{},"(backtick) on Mac, or Ctrl +"," on Windows — same key, just lives under the Esc key on most keyboards.",[17,75,76],{},[39,77],{"alt":78,"src":79},"Terminal","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-18%2014.09.01.png",[17,81,82,83,86],{},"In the terminal, run ",[70,84,85],{},"hexo new 'My First Blog Post'",". Once it runs you'll see a message like:",[17,88,89],{},[70,90,91],{},"INFO  Created: ~\u002FitHelp\u002FitHelpHexo\u002Fsource\u002F_posts\u002FMy-First-Blog-Post.md",[17,93,94,95,98,99,101],{},"What this means: Hexo just created a Markdown file under ",[70,96,97],{},"_posts",". You can navigate to that folder to check. If it created correctly, you should have at least two posts in ",[70,100,97],{}," — one is the default starter article, the other is the one we just created.",[17,103,104],{},[39,105],{"alt":106,"src":107},"My first blog post","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-18%2014.12.38.png",[17,109,110],{},"Congrats — you've successfully created your first blog post.",[12,112,114],{"id":113},"markdown-content","Markdown content",[17,116,117],{},"Let's take a look at the article we just created. By default it includes a few fields:",[17,119,120],{},[39,121],{"alt":122,"src":123},"Default fields (just don't want you knowing exactly when I wrote this XD)","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-18%2014.20.03.png",[125,126,127,134,143],"ul",{},[128,129,130,133],"li",{},[70,131,132],{},"title"," - Article title",[128,135,136,139,140],{},[70,137,138],{},"date"," - Article timestamp, set to the moment you created the post. Format looks like ",[70,141,142],{},"2020-00-00 00:01:10",[128,144,145,148],{},[70,146,147],{},"tags"," - Tags",[17,150,151,152,156],{},"The actual article content goes below, in Markdown. If you're not familiar with Markdown, you can check out my earlier post \"",[30,153,155],{"href":154},"\u002Fother\u002F20191111\u002F1875438261\u002F","Markdown Basics & Beginner Tutorial (article in Mandarin)","\".",[17,158,159],{},"The interesting bits are \"code blocks\" and \"inline code\". Most Hexo themes support code highlighting, and the highlighting only applies to code blocks. The syntax is straightforward, so here's the example:",[17,161,162],{},[39,163],{"alt":164,"src":165},"Code highlighting","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-07-18%2014.32.58.png",[17,167,168],{},"Just write the language name right after the opening triple backticks. Common ones:",[170,171,177],"pre",{"className":172,"code":174,"language":175,"meta":176},[173],"language-text","javascript or js\nhtml\ncss\nscss\nsass\njson\nphp\npython\njava\n...etc.\n","text","",[70,178,174],{"__ignoreMap":176},[17,180,181,182,187],{},"Code highlighting is usually powered by highlight.js. If you want to check whether a specific language is supported, you can look it up ",[30,183,186],{"href":184,"rel":185},"https:\u002F\u002Fhighlightjs.org\u002Fstatic\u002Fdemo\u002F",[34],"here",".",[17,189,190],{},"\"Inline code\" is slightly different from a code block — it's usually wrapped inside a sentence. Just add a single backtick before and after the snippet:",[17,192,193],{},[39,194],{"alt":195,"src":196},"Inline code","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-07-18%2014.36.47.png",[17,198,199],{},"So that's a quick walkthrough of creating your first blog post, code blocks, and inline code. Looks simple, but there's a few small gotchas in there!",[17,201,202,203],{},"See you in the next one ",[204,205],"d",{},{"title":176,"searchDepth":207,"depth":207,"links":208},2,[209,210,211,212],{"id":14,"depth":207,"text":15},{"id":22,"depth":207,"text":23},{"id":50,"depth":207,"text":51},{"id":113,"depth":207,"text":114},"Hexo","2020-09-18 08:20:55","md","en",{},true,"\u002Fen\u002Fhexo\u002Flearn-hexo-05-your-first-post","2",{"title":6,"description":19},false,"en\u002FHexo\u002Flearn-hexo-05-your-first-post",[213,225,226,227,228],"Learning Hexo from Scratch","iThome Ironman 2020","VSCode","Markdown",null,"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F18\u002Flearn-hexo-05-your-first-post\u002F","WiLVSnZFrWXAf2uj0Hbwfuxiehg5hU1F1X0XwM4hBEk",{"newer":233,"older":237},{"url":234,"title":235,"date":236},"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F19\u002Flearn-hexo-06-essential-commands\u002F","(6) Learning Hexo from Scratch - Hexo Commands You Can't Forget","2020-09-19 21:16:39",{"url":238,"title":239,"date":240},"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F17\u002Flearn-hexo-04-directory-structure\u002F","(4) Learning Hexo from Scratch - Understanding the Hexo Directory Structure","2020-09-17 08:24:47",[242,246,251],{"url":243,"title":244,"date":245,"readingMinutes":220},"\u002Fen\u002Fhexo\u002F2022\u002F10\u002F30\u002Ffix-hexo-updated-date-on-ci-deploy\u002F","Fix: All Posts Show Updated Date After Hexo Upgrade or CI Deploy","2022-10-30 11:52:35",{"url":247,"title":248,"date":249,"readingMinutes":250},"\u002Fen\u002Fhexo\u002F2020\u002F11\u002F01\u002Flearn-hexo-33-updating-next-theme\u002F","(33) Learning Hexo from Scratch - Extras: Updating the NexT Theme","2020-11-01 13:21:00","3",{"url":252,"title":253,"date":254,"readingMinutes":220},"\u002Fen\u002Fhexo\u002F2020\u002F10\u002F31\u002Flearn-hexo-32-updating-hexo\u002F","(32) Learning Hexo from Scratch - Extras: Updating Hexo","2020-10-31 14:01:51",1784010275089]