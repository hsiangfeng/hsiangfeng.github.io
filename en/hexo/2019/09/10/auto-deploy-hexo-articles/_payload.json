something fails, Travis CI emails you about it ↓",[17,590,591],{},[30,592],{"alt":593,"src":594},"Errors during setup","https:\u002F\u002Fi.imgur.com\u002FOyooMsI.png",[12,596,598],{"id":597},"references","References",[58,600,601,608,615],{},[61,602,603],{},[64,604,607],{"href":605,"rel":606},"https:\u002F\u002Fsegmentfault.com\u002Fa\u002F1190000009054888",[68],"Auto-deploy Hexo with Travis (Chinese)",[61,609,610],{},[64,611,614],{"href":612,"rel":613},"http:\u002F\u002Fduansm.top\u002F2018\u002F08\u002F05\u002Fhexo-travis\u002F",[68],"Hexo+GitHub blog setup (3): Travis CI auto-deploy (Chinese)",[61,616,617],{},[64,618,621],{"href":619,"rel":620},"https:\u002F\u002Fwww.slmt.tw\u002Fblog\u002F2019\u002F04\u002F26\u002Fhexo-auto-deploy\u002F",[68],"Using Travis CI to auto-deploy a Hexo blog (Chinese)",[623,624,625],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":326,"searchDepth":340,"depth":340,"links":627},[628,629,630,631,632,633,634],{"id":14,"depth":340,"text":15},{"id":22,"depth":340,"text":23},{"id":44,"depth":340,"text":45},{"id":147,"depth":340,"text":148},{"id":196,"depth":340,"text":197},{"id":302,"depth":340,"text":303},{"id":597,"depth":340,"text":598},"Hexo","2019-09-10 09:12:37","md","en",{},true,"\u002Fen\u002Fhexo\u002Fauto-deploy-hexo-articles","3",{"title":6,"description":19},false,"en\u002FHexo\u002Fauto-deploy-hexo-articles",[635,116],null,"\u002Fen\u002Fhexo\u002F2019\u002F09\u002F10\u002Fauto-deploy-hexo-articles\u002F","7H7_F0M2bs7QFfDWI7sDn2pCU-LHXlAR02_l0N1fniE",{"newer":651,"older":655},{"url":652,"title":653,"date":654},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F","Learning ThinkPHP from Scratch Day 10 - The View","2019-09-11 00:01:36",{"url":656,"title":657,"date":658},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F10\u002Fthinkphp-day-09-controller\u002F","Learning ThinkPHP from Scratch Day 9 - Writing Your First Controller","2019-09-10 00:07:30",[660,665,669],{"url":661,"title":662,"date":663,"readingMinutes":664},"\u002Fen\u002Fhexo\u002F2022\u002F10\u002F30\u002Ffix-hexo-updated-date-on-ci-deploy\u002F","Fix: All Posts Show Updated Date After Hexo Upgrade or CI Deploy","2022-10-30 11:52:35","2",{"url":666,"title":667,"date":668,"readingMinutes":642},"\u002Fen\u002Fhexo\u002F2020\u002F11\u002F01\u002Flearn-hexo-33-updating-next-theme\u002F","(33) Learning Hexo from Scratch - Extras: Updating the NexT Theme","2020-11-01 13:21:00",{"url":670,"title":671,"date":672,"readingMinutes":664},"\u002Fen\u002Fhexo\u002F2020\u002F10\u002F31\u002Flearn-hexo-32-updating-hexo\u002F","(32) Learning Hexo from Scratch - Extras: Updating Hexo","2020-10-31 14:01:51",1784010274970]