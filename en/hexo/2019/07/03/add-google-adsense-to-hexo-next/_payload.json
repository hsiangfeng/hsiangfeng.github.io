[{"data":1,"prerenderedAt":700},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fhexo\u002F2019\u002F07\u002F03\u002Fadd-google-adsense-to-hexo-next\u002F":3,"page:\u002Fen\u002Fhexo\u002F2019\u002F07\u002F03\u002Fadd-google-adsense-to-hexo-next\u002F":4,"alt:\u002Fen\u002Fhexo\u002F2019\u002F07\u002F03\u002Fadd-google-adsense-to-hexo-next\u002F":3,"prev-next:\u002Fen\u002Fhexo\u002F2019\u002F07\u002F03\u002Fadd-google-adsense-to-hexo-next\u002F":677,"related:\u002Fen\u002Fhexo\u002F2019\u002F07\u002F03\u002Fadd-google-adsense-to-hexo-next\u002F":686},"\u002Fhexo\u002F20190703\u002F893132670\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":659,"date":660,"description":661,"extension":662,"lang":663,"meta":664,"navigation":665,"path":666,"readingMinutes":667,"seo":668,"standalone":669,"stem":670,"tags":671,"tldr":674,"updated":660,"url":675,"__hash__":676},"content\u002Fen\u002FHexo\u002Fadd-google-adsense-to-hexo-next.md","Adding Google AdSense to Hexo NexT","7623139800",{"type":9,"value":10,"toc":636},"minimark",[11,16,20,23,27,32,42,46,51,55,58,61,85,88,99,102,106,113,117,124,128,134,138,144,147,151,154,160,164,167,178,181,189,192,293,297,304,385,389,396,438,442,452,551,558,564,568,576,582,585,591,599,604,607,613,620,625,629,632],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Long time no Hexo post. This one walks through applying for Google AdSense and modifying the template — mainly modifications, since I've already applied.",[17,21,22],{},"(Note: the last section requires you to have been approved. But you can prep the template and config beforehand, so once you're approved you just fill in the info.)",[12,24,26],{"id":25},"environment-for-this-post","Environment for this post",[28,29,31],"h3",{"id":30},"hexo-version","Hexo version",[33,34,35,39],"ul",{},[36,37,38],"li",{},"hexo: 3.8.0",[36,40,41],{},"hexo-cli: 2.0.0",[28,43,45],{"id":44},"next-version","NexT version",[33,47,48],{},[36,49,50],{},"NexT: 7.1.0",[12,52,54],{"id":53},"setup","Setup",[17,56,57],{},"This is technically my second application, so the flow here is for re-applying. The first-time application flow you can Google — nothing super tricky.",[17,59,60],{},"Google AdSense application criteria (these aren't officially published, just my best guess):",[33,62,63,66,69,72,75],{},[36,64,65],{},"Site content can't be content-farm style (i.e. junk articles)",[36,67,68],{},"Applicant has to be 18+",[36,70,71],{},"Site must have been live for at least six months (one of my sites took over 7 months to get approved)",[36,73,74],{},"Content must be substantive and exceed a certain volume (my other site had over 60 posts when approved)",[36,76,77,78],{},"No offensive content — see the ",[79,80,84],"a",{"href":81,"rel":82},"https:\u002F\u002Fsupport.google.com\u002Fadsense\u002Fanswer\u002F1344080",[83],"nofollow","official guidelines",[17,86,87],{},"After approval, a few things you have to be careful about:",[33,89,90,93,96],{},[36,91,92],{},"Don't click your own ads",[36,94,95],{},"People on the same network as you shouldn't click your ads",[36,97,98],{},"Don't encourage or ask others to click ads",[17,100,101],{},"If you violate any of these, Google will close your account. Seriously, don't.",[28,103,105],{"id":104},"open-the-google-adsense-dashboard","Open the Google AdSense dashboard",[17,107,108],{},[79,109,112],{"href":110,"rel":111},"https:\u002F\u002Fwww.google.com\u002Fadsense",[83],"Google AdSense",[28,114,116],{"id":115},"sites-add-site","Sites > Add site",[17,118,119],{},[120,121],"img",{"alt":122,"src":123},"Add site","https:\u002F\u002Fi.imgur.com\u002FwhcUrrk.png",[28,125,127],{"id":126},"enter-your-domain-and-click-next","Enter your domain and click next",[17,129,130],{},[120,131],{"alt":132,"src":133},"Enter domain","https:\u002F\u002Fi.imgur.com\u002FyeoQrON.png",[28,135,137],{"id":136},"copy-the-code","Copy the code",[17,139,140],{},[120,141],{"alt":142,"src":143},"Copy code","https:\u002F\u002Fi.imgur.com\u002FCnAJKaX.png",[17,145,146],{},"Then click submit.",[28,148,150],{"id":149},"wait-for-review","Wait for review",[17,152,153],{},"Approval takes 7-14 days. While you wait, modify the template so you're ready to go once you're approved.",[17,155,156],{},[120,157],{"alt":158,"src":159},"Waiting for review","https:\u002F\u002Fi.imgur.com\u002FJ69B4Ig.png",[12,161,163],{"id":162},"modifying-the-next-template","Modifying the NexT template",[17,165,166],{},"A few places to modify — you can decide which ones to actually do:",[33,168,169,172,175],{},[36,170,171],{},"Sidebar (the site nav column)",[36,173,174],{},"NexT config file",[36,176,177],{},"header",[17,179,180],{},"I personally don't insert ads in the middle of articles or at the top, for UX reasons.",[12,182,184,185],{"id":183},"modify-the-theme-_configyml","Modify the theme ",[186,187,188],"code",{},"_config.yml",[17,190,191],{},"Add this somewhere:",[193,194,199],"pre",{"className":195,"code":196,"language":197,"meta":198,"style":198},"language-yml shiki shiki-themes github-dark-high-contrast","# Google AdSense\ngoogle_adsense:\n  enable: true\n  google_ad_client_id: ca-pub-000000 # change to your own\n  enable_page_level_ads: true\n  ## siderbar_enable — used after creating an ad unit\n  siderbar_enable: true # enable sidebar ad\n  siderbar_data_ad_slot: 0000000 # ad slot ID\n","yml","",[186,200,201,210,221,234,249,259,265,279],{"__ignoreMap":198},[202,203,206],"span",{"class":204,"line":205},"line",1,[202,207,209],{"class":208},"sQrFR","# Google AdSense\n",[202,211,213,217],{"class":204,"line":212},2,[202,214,216],{"class":215},"sKpQp","google_adsense",[202,218,220],{"class":219},"sMAXC",":\n",[202,222,224,227,230],{"class":204,"line":223},3,[202,225,226],{"class":215},"  enable",[202,228,229],{"class":219},": ",[202,231,233],{"class":232},"sCcAr","true\n",[202,235,237,240,242,246],{"class":204,"line":236},4,[202,238,239],{"class":215},"  google_ad_client_id",[202,241,229],{"class":219},[202,243,245],{"class":244},"