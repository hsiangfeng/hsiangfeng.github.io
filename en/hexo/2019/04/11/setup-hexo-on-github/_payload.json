",[142],"nofollow","blog"," — fewer landmines.",[12,146,148],{"id":147},"_2-install-hexo","2. Install Hexo",[17,150,151],{},"Hexo is installed via command line, so open your terminal and run:",[35,153,157],{"className":154,"code":155,"language":156,"meta":41,"style":41},"language-js shiki shiki-themes github-dark-high-contrast","npm install hexo-cli -g\n","js",[43,158,159],{"__ignoreMap":41},[160,161,164,168,172,175,177],"span",{"class":162,"line":163},"line",1,[160,165,167],{"class":166},"sMAXC","npm install hexo",[160,169,171],{"class":170},"sWyjQ","-",[160,173,174],{"class":166},"cli ",[160,176,171],{"class":170},[160,178,179],{"class":166},"g\n",[17,181,182],{},[23,183],{"alt":184,"src":185},"hexo-cli install","https:\u002F\u002Fi.imgur.com\u002F0eziTqZ.png",[55,187,188],{},[58,189,190,191,194],{},"This installs Hexo-Cli globally (",[43,192,193],{},"-g",") via npm.\nShould be done in a few seconds.",[12,196,198],{"id":197},"_3-create-a-hexo-project","3. Create a Hexo project",[17,200,201,204,205,208],{},[43,202,203],{},"cd"," into the directory where you want to create the project, then run (replace ",[43,206,207],{},"projectname"," with your own):",[35,210,214],{"className":211,"code":212,"language":213,"meta":41,"style":41},"language-cmd shiki shiki-themes github-dark-high-contrast","hexo init projectname\n","cmd",[43,215,216],{"__ignoreMap":41},[160,217,218],{"class":162,"line":163},[160,219,212],{},[55,221,222],{},[58,223,224],{},"This initialises a new Hexo project.",[17,226,227],{},[23,228],{"alt":229,"src":230},"Init Hexo","https:\u002F\u002Fi.imgur.com\u002FglBzpwE.png",[12,232,234],{"id":233},"enter-the-hexo-directory","Enter the Hexo directory",[17,236,237,238,240],{},"Once created, ",[43,239,203],{}," into the new folder:",[35,242,244],{"className":211,"code":243,"language":213,"meta":41,"style":41},"cd projectname\n",[43,245,246],{"__ignoreMap":41},[160,247,248],{"class":162,"line":163},[160,249,243],{},[17,251,252],{},[23,253],{"alt":254,"src":255},