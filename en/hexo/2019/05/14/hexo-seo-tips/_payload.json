5],{"id":274},"next-footer","NexT Footer",[17,277,278,279,281],{},"Crawlers follow all links on a page and visit each one. If they wander off via your footer, they might not come back. The footer has a copyright notice, so add a ",[24,280,108],{}," to those links.",[17,283,284,285,288,289,292],{},"Find NexT's ",[24,286,287],{},"footer.swig"," (usually at ",[24,290,291],{},"hexo-theme-next-master\\layout\\_partials\\footer.swig",").",[294,295,296],"ol",{},[48,297,298,299],{},"Search for ",[24,300,301],{},"theme-next.org",[17,303,304],{},"Original line:",[73,306,308],{"className":75,"code":307,"language":77,"meta":78,"style":78},"{{ __('footer.theme') }} – {{ next_url('https:\u002F\u002Ftheme-next.org', 'NexT.' + theme.scheme, {class: 'theme-link'}) }}\n",[24,309,310],{"__ignoreMap":78},[82,311,312],{"class":84,"line":85},[82,313,307],{},[17,315,316],{},"Change to:",[73,318,320],{"className":75,"code":319,"language":77,"meta":78,"style":78},"#}{{ __('footer.theme') }} – \u003Ca href='https:\u002F\u002Ftheme-next.org' class='theme-link' rel='external nofollow'> NexT.Pisces \u003C\u002Fa>{#\n",[24,321,322],{"__ignoreMap":78},[82,323,324],{"class":84,"line":85},[82,325,319],{},[294,327,328],{"start":162},[48,329,298,330],{},[24,331,332],{},"hexo.io",[17,334,304],{},[73,336,338],{"className":75,"code":337,"language":77,"meta":78,"style":78},"{{ __('footer.powered', next_url('https:\u002F\u002Fhexo.io', 'Hexo', {class: 'theme-link'})) }}\n",[24,339,340],{"__ignoreMap":78},[82,341,342],{"class":84,"line":85},[82,343,337],{},[17,345,316],{},[73,347,349],{"className":75,"code":348,"language":77,"meta":78,"style":78},"\u003Ca href='https:\u002F\u002Fhexo.io' class='theme-link' rel='external nofollow'> Hexo \u003C\u002Fa>\n",[24,350,351],{"__ignoreMap":78},[82,352,353],{"class":84,"line":85},[82,354,348],{},[17,356,357,358,361],{},"Basically, any non-friend-link can have ",[24,359,360],{},"rel=\"external nofollow\""," added, so crawlers don't wander off.",[40,363,364],{"id":364},"hexo-autonofollow",[17,366,367,368,370],{},"If editing templates is too annoying, try the ",[24,369,364],{}," plugin instead.\n(Personally I don't love editing templates either — makes updates painful.)",[73,372,374],{"className":75,"code":373,"language":77,"meta":78,"style":78},"npm install hexo-autonofollow --save\n",[24,375,376],{"__ignoreMap":78},[82,377,378],{"class":84,"line":85},[82,379,373],{},[17,381,382,383,137,385,387],{},"Then add this at the end of the main ",[24,384,265],{},[24,386,140],{},", not the theme):",[73,389,391],{"className":75,"code":390,"language":77,"meta":78,"style":78},"nofollow:\n    enable: true\n    exclude:  # friend-link sites you want to exclude from nofollow\n    - exclude1.com\n    - exclude2.com\n",[24,392,393,398,403,408,413],{"__ignoreMap":78},[82,394,395],{"class":84,"line":85},[82,396,397],{},"nofollow:\n",[82,399,400],{"class":84,"line":162},[82,401,402],{},"    enable: true\n",[82,404,405],{"class":84,"line":168},[82,406,407],{},"    exclude:  # friend-link sites you want to exclude from nofollow\n",[82,409,410],{"class":84,"line":174},[82,411,412],{},"    - exclude1.com\n",[82,414,415],{"class":84,"line":180},[82,416,417],{},"    - exclude2.com\n",[17,419,420,421,34],{},"After this, all non-friend-link sites get ",[24,422,360],{},[17,424,425],{},[113,426],{"alt":115,"src":427},"https:\u002F\u002Fi.imgur.com\u002FnxwpiYx.png",[17,429,430,431,266],{},"If you don't have friend links, just skip ",[24,432,433],{},"exclude",[73,435,437],{"className":75,"code":436,"language":77,"meta":78,"style":78},"nofollow:\n    enable: true\n",[24,438,439,443],{"__ignoreMap":78},[82,440,441],{"class":84,"line":85},[82,442,397],{},[82,444,445],{"class":84,"line":162},[82,446,402],{},[12,448,450],{"id":449},"keyword-description","keyword & description",[17,452,453],{},"Google has stated their crawler doesn't really look at keyword & description, but let's verify they show up correctly in your posts.",[17,455,456],{},[113,457],{"alt":115,"sr