[{"data":1,"prerenderedAt":473},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fhexo\u002F2019\u002F12\u002F06\u002Fsetup-gitalk-on-hexo-next\u002F":3,"page:\u002Fen\u002Fhexo\u002F2019\u002F12\u002F06\u002Fsetup-gitalk-on-hexo-next\u002F":4,"alt:\u002Fen\u002Fhexo\u002F2019\u002F12\u002F06\u002Fsetup-gitalk-on-hexo-next\u002F":3,"prev-next:\u002Fen\u002Fhexo\u002F2019\u002F12\u002F06\u002Fsetup-gitalk-on-hexo-next\u002F":450,"related:\u002Fen\u002Fhexo\u002F2019\u002F12\u002F06\u002Fsetup-gitalk-on-hexo-next\u002F":459},"\u002Fhexo\u002F20191206\u002F2397475810\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":434,"date":435,"description":436,"extension":437,"lang":284,"meta":438,"navigation":439,"path":440,"readingMinutes":441,"seo":442,"standalone":443,"stem":444,"tags":445,"tldr":447,"updated":435,"url":448,"__hash__":449},"content\u002Fen\u002FHexo\u002Fsetup-gitalk-on-hexo-next.md","Setting Up Gitalk Comments on Hexo NexT in 10 Minutes","1857479320",{"type":9,"value":10,"toc":423},"minimark",[11,16,20,24,29,40,44,54,58,63,67,70,77,80,86,89,95,98,104,107,113,119,122,128,132,142,151,158,163,288,291,297,301,308,400,405,408,414,419],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"I switched my year-old Disqus setup to GitHub Gitalk. The main reason — Disqus comment notifications kept getting lost, and sometimes I wouldn't notice replies until weeks or months later. So this post is a quick walkthrough on enabling Gitalk.",[12,21,23],{"id":22},"environment","Environment",[25,26,28],"h3",{"id":27},"versions-environment","Versions & environment",[30,31,37],"pre",{"className":32,"code":34,"language":35,"meta":36},[33],"language-text","OS: Windows 10 X64\nNode.js: V11.7.0\nIDE: VS Code\n","text","",[38,39,34],"code",{"__ignoreMap":36},[25,41,43],{"id":42},"hexo-version","Hexo version",[45,46,47,51],"ul",{},[48,49,50],"li",{},"hexo: 3.8.0",[48,52,53],{},"hexo-cli: 2.0.0",[25,55,57],{"id":56},"next-version","NexT version",[45,59,60],{},[48,61,62],{},"NexT: 7.1.0",[12,64,66],{"id":65},"create-a-github-oauth-app","Create a GitHub OAuth App",[17,68,69],{},"Gitalk needs a GitHub OAuth App. Head to GitHub → Settings:",[17,71,72],{},[73,74],"img",{"alt":75,"src":76},"Settings","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-49-41.png",[17,78,79],{},"Then Developer settings:",[17,81,82],{},[73,83],{"alt":84,"src":85},"Developer settings","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-50-14.png",[17,87,88],{},"Then OAuth Apps:",[17,90,91],{},[73,92],{"alt":93,"src":94},"OAuth Apps","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-50-53.png",[17,96,97],{},"Click \"New OAuth App\" at the top:",[17,99,100],{},[73,101],{"alt":102,"src":103},"New OAuth App","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-51-40.png",[17,105,106],{},"Fill in:",[30,108,111],{"className":109,"code":110,"language":35,"meta":36},[33],"Application name\nHomepage URL → your blog URL\nApplication description\nAuthorization callback URL → your blog URL\n",[38,112,110],{"__ignoreMap":36},[17,114,115],{},[73,116],{"alt":117,"src":118},"Fill in fields","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_17-29-09.png",[17,120,121],{},"After submitting, you'll get a Client ID and Client Secret. Don't share these — you'll need them shortly.",[17,123,124],{},[73,125],{"alt":126,"src":127},"OAuth ID","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_17-29-27.png",[12,129,131],{"id":130},"gitalk","Gitalk",[17,133,134,135,141],{},"Quick intro on why Gitalk — ",[136,137,131],"a",{"href":138,"rel":139},"https:\u002F\u002Fgithub.com\u002Fgitalk\u002Fgitalk",[140],"nofollow"," is a comment plugin built on top of GitHub. Most engineers already have a GitHub account, and Gitalk supports Markdown in comments, so it's great for technical readers.",[17,143,144,145,150],{},"Here's a ",[136,146,149],{"href":147,"rel":148},"https:\u002F\u002Fgitalk.github.io\u002F",[140],"Gitalk demo",".",[17,152,153,154,157],{},"Now open the NexT theme's ",[38,155,156],{},"_config.yml",", search for \"Gitalk\", fill in the fields:",[17,159,160],{},[73,161],{"alt":131,"src":162},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_21-03-34.png",[30,164,168],{"className":165,"code":166,"language":167,"meta":36,"style":36},"language-yml shiki shiki-themes github-dark-high-contrast","gitalk:\n  enable: true\n  github_id:  # GitHub author username\n  repo: hsiangfeng.github.io # your repo name, usually your blog domain\n  client_id: xxxxxxxx # Client ID from earlier\n  client_secret: xxxxxxxx # Client Secret from earlier\n  admin_user: hsiangfeng # admin username\n  distraction_free_mode: true\n  language: en # language\n","yml",[38,169,170,182,195,208,223,237,250,264,274],{"__ignoreMap":36},[171,172,175,178],"span",{"class":173,"line":174},"line",1,[171,176,130],{"class":177},"sKpQp",[171,179,181],{"class":180},"sMAXC",":\n",[171,183,185,188,191],{"class":173,"line":184},2,[171,186,187],{"class":177},"  enable",[171,189,190],{"class":180},": ",[171,192,194],{"class":193},"sCcAr","true\n",[171,196,198,201,204],{"class":173,"line":197},3,[171,199,200],{"class":177},"  github_id",[171,202,203],{"class":180},":  ",[171,205,207],{"class":206},"sQrFR","# GitHub author username\n",[171,209,211,214,216,220],{"class":173,"line":210},4,[171,212,213],{"class":177},"  repo",[171,215,190],{"class":180},[171,217,219],{"class":218},"sTRMh","hsiangfeng.github.io",[171,221,222],{"class":206}," # your repo name, usually your blog domain\n",[171,224,226,229,231,234],{"class":173,"line":225},5,[171,227,228],{"class":177},"  client_id",[171,230,190],{"class":180},[171,232,233],{"class":218},"xxxxxxxx",[171,235,236],{"class":206}," # Client ID from earlier\n",[171,238,240,243,245,247],{"class":173,"line":239},6,[171,241,242],{"class":177},"  client_secret",[171,244,190],{"class":180},[171,246,233],{"class":218},[171,248,249],{"class":206}," # Client Secret from earlier\n",[171,251,253,256,258,261],{"class":173,"line":252},7,[171,254,255],{"class":177},"  admin_user",[171,257,190],{"class":180},[171,259,260],{"class":218},"hsiangfeng",[171,262,263],{"class":206}," # admin username\n",[171,265,267,270,272],{"class":173,"line":266},8,[171,268,269],{"class":177},"  distraction_free_mode",[171,271,190],{"class":180},[171,273,194],{"class":193},[171,275,277,280,282,285],{"class":173,"line":276},9,[171,278,279],{"class":177},"  language",[171,281,190],{"class":180},[171,283,284],{"class":218},"en",[171,286,287],{"class":206}," # language\n",[17,289,290],{},"Deploy to your blog and you'll see the comment section. Note: the first time you use it, you have to enable OAuth — visit any post and click the enable prompt once. Otherwise it'll show \"Please contact xxx to initialise the comments\".",[17,292,293],{},[73,294],{"alt":295,"src":296},"Enabled","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_17-40-58.png",[12,298,300],{"id":299},"extra","Extra",[17,302,303,304,307],{},"When someone comments via Gitalk, Gitalk opens an issue in your GitHub repo. You can add a ",[38,305,306],{},"labels"," line to categorise those issues so they don't get messy:",[30,309,311],{"className":165,"code":310,"language":167,"meta":36,"style":36},"gitalk:\n  enable: true\n  github_id:  # GitHub author username\n  repo: hsiangfeng.github.io # your repo name\n  client_id: xxxxxxxx\n  client_secret: xxxxxxxx\n  admin_user: hsiangfeng\n  distraction_free_mode: true\n  language: en\n  labels: Gitalk\n",[38,312,313,319,327,335,346,355,363,372,380,389],{"__ignoreMap":36},[171,314,315,317],{"class":173,"line":174},[171,316,130],{"class":177},[171,318,181],{"class":180},[171,320,321,323,325],{"class":173,"line":184},[171,322,187],{"class":177},[171,324,190],{"class":180},[171,326,194],