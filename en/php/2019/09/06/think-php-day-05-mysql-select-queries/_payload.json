[{"data":1,"prerenderedAt":860},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F":836,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F":845},"\u002Fphp\u002F20190906\u002F241727046\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":817,"date":818,"description":819,"extension":820,"lang":821,"meta":822,"navigation":823,"path":824,"readingMinutes":494,"seo":825,"standalone":826,"stem":827,"tags":828,"tldr":833,"updated":818,"url":834,"__hash__":835},"content\u002Fen\u002FPHP\u002Fthink-php-day-05-mysql-select-queries.md","Day5-Learning ThinkPHP from Scratch-MySQL Basics-Data Part 2 (SELECT Queries)","1002842924",{"type":9,"value":10,"toc":799},"minimark",[11,16,20,24,27,56,62,65,72,76,83,86,195,198,204,209,217,244,249,252,257,261,279,311,316,325,331,335,345,375,380,386,389,393,413,420,447,450,456,459,463,470,497,502,508,512,515,525,529,536,556,561,564,570,573,597,602,605,610,614,624,647,652,655,661,665,668,795],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time I only covered INSERT, UPDATE, and DELETE syntax, but there was one thing I deliberately skipped: SELECT. The reason is that querying actually has a ton of possible combinations, so I wanted to pull it out into its own post. Enough talk — let me show you why this one deserved to be split out.",[12,21,23],{"id":22},"querying-all-columns","Querying all columns",[17,25,26],{},"First, let's start with the most basic and simplest syntax: querying every column of data in a table.",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-sql shiki shiki-themes github-dark-high-contrast","SELECT * FROM hw_table;\n","sql","",[35,36,37],"code",{"__ignoreMap":33},[38,39,42,46,49,52],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","SELECT",[38,47,48],{"class":44}," *",[38,50,51],{"class":44}," FROM",[38,53,55],{"class":54},"sMAXC"," hw_table;\n",[17,57,58,59],{},"Command breakdown: ",[35,60,61],{},"SELECT * FROM [table name];",[17,63,64],{},"If you've been following along from the last post, you should normally only have one row in the result ↓",[17,66,67],{},[68,69],"img",{"alt":70,"src":71},"Only one row","https:\u002F\u002Fi.imgur.com\u002FBammqqJ.png",[12,73,75],{"id":74},"querying","Querying",[17,77,78,79,82],{},"Now things get a little trickier, but this is also the heart of querying: the conditional query. A conditional query usually comes with a ",[35,80,81],{},"where"," followed by a condition, and depending on the condition you tack on, you'll get different results.",[17,84,85],{},"Before we get hands-on, though, I'd suggest running the following command first to quickly drop in a few sample rows, so we can actually see the effects later:",[28,87,89],{"className":30,"code":88,"language":32,"meta":33,"style":33},"INSERT INTO hw_table (name, height, weight) VALUES ('王小明', 177.6, 70.5),('王小明', 156.6, 47.5),('陳春嬌', 172.6,46.7);\n",[35,90,91],{"__ignoreMap":33},[38,92,93,96,99,102,105,108,111,114,117,121,124,128,131,134,136,139,141,144,147,149,151,154,156,158,160,163,165,167,169,172,174,177,179,181,184,187,189,192],{"class":40,"line":41},[38,94,95],{"class":44},"INSERT INTO",[38,97,98],{"class":54}," hw_table (",[38,100,101],{"class":44},"name",[38,103,104],{"class":54},", height, ",[38,106,107],{"class":44},"weight",[38,109,110],{"class":54},") ",[38,112,113],{"class":44},"VALUES",[38,115,116],{"class":54}," (",[38,118,120],{"class":119},"sTRMh","'王小明'",[38,122,123],{"class":54},", ",[38,125,127],{"class":126},"sCcAr","177",[38,129,130],{"class":54},".",[38,132,133],{"class":126},"6",[38,135,123],{"class":54},[38,137,138],{"class":126},"70",[38,140,130],{"class":54},[38,142,143],{"class":126},"5",[38,145,146],{"class":54},"),(",[38,148,120],{"class":119},[38,150,123],{"class":54},[38,152,153],{"class":126},"156",[38,155,130],{"class":54},[38,157,133],{"class":126},[38,159,123],{"class":54},[38,161,162],{"class":126},"47",[38,164,130],{"class":54},[38,166,143],{"class":126},[38,168,146],{"class":54},[38,170,171],{"class":119},"'陳春嬌'",[38,173,123],{"class":54},[38,175,176],{"class":126},"172",[38,178,130],{"class":54},[38,180,133],{"class":126},[38,182,183],{"class":54},",",[38,185,186],{"class":126},"46",[38,188,130],{"class":54},[38,190,191],{"class":126},"7",[38,193,194],{"class":54},");\n",[17,196,197],{},"So at this point our table should have four rows in it ↓",[17,199,200],{},[68,201],{"alt":202,"src":203},"Four rows","https:\u002F\u002Fi.imgur.com\u002FTmXnDpv.png",[205,206,208],"h3",{"id":207},"conditional-query","Conditional query",[17,210,211,212,216],{},"First up, the basic conditional query. Say we want to find only people named ",[213,214,215],"strong",{},"王小明"," — the syntax would look like this:",[28,218,220],{"className":30,"code":219,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table WHERE name='王小明';\n",[35,221,222],{"__ignoreMap":33},[38,223,224,226,228,230,233,236,239,241],{"class":40,"line":41},[38,225,45],{"class":44},[38,227,48],{"class":44},[38,229,51],{"class":44},[38,231,232],{"class":54}," hw_table ",[38,234,235],{"class":44},"WHERE",[38,237,238],{"class":44}," name=",[38,240,120],{"class":119},[38,242,243],{"class":54},";\n",[17,245,58,246],{},[35,247,248],{},"SELECT * FROM [table name] WHERE [condition];",[17,250,251],{},"After running it, you'll see the result only returns people named 王小明 ↓",[17,253,254],{},[68,255],{"alt":215,"src":256},"https:\u002F\u002Fi.imgur.com\u002FUZyboyX.png",[205,258,260],{"id":259},"conditional-query-with-and","Conditional query with AND",[17,262,263,264,267,268,272,273,275,276,278],{},"If you want the result to be a bit more focused (more specific) — say you only want to find someone who weighs exactly ",[213,265,266],{},"70.5"," kg ",[269,270,271],"em",{},"and"," happens to be named ",[213,274,215],{}," — we can use ",[35,277,271],{}," to attach another condition and narrow things down:",[28,280,282],{"className":30,"code":281,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table WHERE name='王小明' and weight='70.5';\n",[35,283,284],{"__ignoreMap":33},[38,285,286,288,290,292,294,296,298,300,303,306,309],{"class":40,"line":41},[38,287,45],{"class":44},[38,289,48],{"class":44},[38,291,51],{"class":44},[38,293,232],{"class":54},[38,295,235],{"class":44},[38,297,238],{"class":44},[38,299,120],{"class":119},[38,301,302],{"class":44}," and",[38,304,305],{"class":44}," weight=",[38,307,308],{"class":119},"'70.5'",[38,310,243],{"class":54},[17,312,58,313],{},[35,314,315],{},"SELECT * FROM [table name] WHERE [condition] and [condition];",[17,317,318,319,321,322,324],{},"That way you'll find the person named ",[213,320,215],{}," who also weighs ",[213,323,266],{}," kg ↓",[17,326,327],{},[68,328],{"alt":329,"src":330},"You can see the search result has a faint orange box around it","https:\u002F\u002Fi.imgur.com\u002FhBCpmJT.png",[205,332,334],{"id":333},"conditional-query-with-or","Conditional query with OR",[17,336,337,338,341,342,344],{},"When we want to query people named both ",[213,339,340],{},"陳春嬌"," and ",[213,343,215],{}," at the same time, we can write it like this:",[28,346,348],{"className":30,"code":347,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table WHERE name='陳春嬌' OR name='王小明';\n",[35,349,350],{"__ignoreMap":33},[38,351,352,354,356,358,360,362,364,366,369,371,373],{"class":40,"line":41},[38,353,45],{"class":44},[38,355,48],{"class":44},[38,357,51],{"class":44},[38,359,232],{"class":54},[38,361,235],{"class":44},[38,363,238],{"class":44},[38,365,171],{"class":119},[38,367,368],{"class":44}," OR",[38,370,238],{"class":44},[38,372,120],{"class":119},[38,374,243],{"class":54},[17,376,58,377],{},[35,378,379],{},"SELECT * FROM [table name] WHERE [condition] or [condition];",[17,381,382],{},[68,383],{"alt":384,"src":385},"OR","https:\u002F\u002Fi.imgur.com\u002FI17UzMS.png",[17,387,388],{},"And if one of them doesn't exist, it won't break the query — it'll just list whatever does match. So if there were no 陳春嬌 but there was a 王小明, it would just list 王小明.",[205,390,392],{"id":391},"a-note-on-conditional-queries","A note on conditional queries",[17,394,395,396,399,400,123,403,123,406,123,409,412],{},"Lastly, a quick add-on about conditional queries. You can actually throw ",[213,397,398],{},"operators"," into them too (",[35,401,402],{},"=",[35,404,405],{},">",[35,407,408],{},"\u003C",[35,410,411],{},"!=","). So what's an operator? Let's just look at an example.",[17,414,415,416,419],{},"Say I want to find people taller than ",[213,417,418],{},"170 cm"," — I can write it like this:",[28,421,423],{"className":30,"code":422,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table WHERE height > 170;\n",[35,424,425],{"__ignoreMap":33},[38,426,427,429,431,433,435,437,440,442,445],{"class":40,"line":41},[38,428,45],{"class":44},[38,430,48],{"class":44},[38,432,51],{"class":44},[38,434,232],{"class":54},[38,436,235],{"class":44},[38,438,439],{"class":54}," height ",[38,441,405],{"class":44},[38,443,444],{"class":126}," 170",[38,446,243],{"class":54},[17,448,449],{},"After running it, we find the two people taller than 170 ↓",[17,451,452],{},[68,453],{"alt":454,"src":455},"Two people","https:\u002F\u002Fi.imgur.com\u002FPbmwDMI.png",[17,457,458],{},"The rest of the operator conditions are basically the same, so I won't bother demoing them — the syntax is pretty much identical.",[12,460,462],{"id":461},"querying-a-specific-number-of-rows","Querying a specific number of rows",[17,464,465,466,469],{},"What if I only want to grab, say, rows 3 through 4 when querying? That's where the ",[35,467,468],{},"LIMIT"," syntax comes in:",[28,471,473],{"className":30,"code":472,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table LIMIT 2,4;\n",[35,474,475],{"__ignoreMap":33},[38,476,477,479,481,483,485,487,490,492,495],{"class":40,"line":41},[38,478,45],{"class":44},[38,480,48],{"class":44},[38,482,51],{"class":44},[38,484,232],{"class":54},[38,486,468],{"class":44},[38,488,489],{"class":126}," 2",[38,491,183],{"class":54},[38,493,494],{"class":126},"4",[38,496,243],{"class":54},[17,498,58,499],{},[35,500,501],{},"SELECT * FROM [table name] LIMIT [value1],[value2];",[17,503,504],{},[68,505],{"alt":506,"src":507},"Querying specific rows","https:\u002F\u002Fi.imgur.com\u002FIXpr72N.png",[12,509,511],{"id":510},"sorting-query-results","Sorting query results",[17,513,514],{},"Finally, let's talk about sorting. Sorting is a super common thing to do, and it mainly comes in two modes:",[516,517,518,522],"ul",{},[519,520,521],"li",{},"Ascending (ASC)",[519,523,524],{},"Descending (DESC)",[205,526,528],{"id":527},"sorting-query-results-in-ascending-order","Sorting query results in ascending order",[17,530,531,532,535],{},"Sorting usually involves one piece of syntax: ",[35,533,534],{},"ORDER BY",". The default sort is ascending, so let's try sorting by height:",[28,537,539],{"className":30,"code":538,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table ORDER BY height;\n",[35,540,541],{"__ignoreMap":33},[38,542,543,545,547,549,551,553],{"class":40,"line":41},[38,544,45],{"class":44},[38,546,48],{"class":44},[38,548,51],{"class":44},[38,550,232],{"class":54},[38,552,534],{"class":44},[38,554,555],{"class":54}," height;\n",[17,557,58,558],{},[35,559,560],{},"SELECT * FROM [table name] ORDER BY [column];",[17,562,563],{},"You can see the heights go from smallest to largest ↓",[17,565,566],{},[68,567],{"alt":568,"src":569},"Ascending sort","https:\u002F\u002Fi.imgur.com\u002FExADZGI.png",[17,571,572],{},"That said, I personally like to spell it out explicitly to avoid any weird surprises. Here's the full ascending syntax:",[28,574,576],{"className":30,"code":575,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table ORDER BY height ASC;\n",[35,577,578],{"__ignoreMap":33},[38,579,580,582,584,586,588,590,592,595],{"class":40,"line":41},[38,581,45],{"class":44},[38,583,48],{"class":44},[38,585,51],{"class":44},[38,587,232],{"class":54},[38,589,534],{"class":44},[38,591,439],{"class":54},[38,593,594],{"class":44},"ASC",[38,596,243],{"class":54},[17,598,58,599],{},[35,600,601],{},"SELECT * FROM [table name] ORDER BY [column] ASC;",[17,603,604],{},"And of course the result is the same ↓",[17,606,607],{},[68,608],{"alt":568,"src":609},"https:\u002F\u002Fi.imgur.com\u002FfUCyKHl.png",[205,611,613],{"id":612},"sorting-query-results-in-descending-order","Sorting query results in descending order",[17,615,616,617,619,620,623],{},"So what about descending order? Just swap the ",[35,618,594],{}," from before for ",[35,621,622],{},"DESC",":",[28,625,627],{"className":30,"code":626,"language":32,"meta":33,"style":33},"SELECT * FROM hw_table ORDER BY height DESC;\n",[35,628,629],{"__ignoreMap":33},[38,630,631,633,635,637,639,641,643,645],{"class":40,"line":41},[38,632,45],{"class":44},[38,634,48],{"class":44},[38,636,51],{"class":44},[38,638,232],{"class":54},[38,640,534],{"class":44},[38,642,439],{"class":54},[38,644,622],{"class":44},[38,646,243],{"class":54},[17,648,58,649],{},[35,650,651],{},"SELECT * FROM [table name] ORDER BY [column] DESC;",[17,653,654],{},"And now you'll see it go from largest to smallest.",[17,656,657],{},[68,658],{"alt":659,"src":660},"Descending sort","https:\u002F\u002Fi.imgur.com\u002FeTBQWhE.png",[12,662,664],{"id":663},"wrap-up","Wrap-up",[17,666,667],{},"Let's wrap up by rounding up all the SQL commands we covered in this post.",[669,670,671,684],"table",{},[672,673,674],"thead",{},[675,676,677,681],"tr",{},[678,679,680],"th",{},"Operation",[678,682,683],{},"SQL syntax",[685,686,687,700,712,725,739,754,770,783],"tbody",{},[675,688,689,693],{},[690,691,692],"td",{},"Query all columns",[690,694,695,696,699],{},"SELECT * FROM ",[38,697,698],{},"table name",";",[675,701,702,704],{},[690,703,208],{},[690,705,695,706,708,709,699],{},[38,707,698],{}," WHERE ",[38,710,711],{},"condition",[675,713,714,717],{},[690,715,716],{},"Conditional query AND",[690,718,695,719,708,721,341,723,699],{},[38,720,698],{},[38,722,711],{},[38,724,711],{},[675,726,727,730],{},[690,728,729],{},"Conditional query OR",[690,731,695,732,708,734,736,737],{},[38,733,698],{},[38,735,711],{}," or ",[38,738,711],{},[675,740,741,744],{},[690,742,743],{},"Conditional query (operator)",[690,745,695,746,708,748,751,752,699],{},[38,747,698],{},[38,749,750],{},"column"," > ",[38,753,711],{},[675,755,756,759],{},[690,757,758],{},"Query specific number of rows",[690,760,695,761,763,764,183,767,699],{},[38,762,698],{}," LIMIT ",[38,765,766],{},"value1",[38,768,769],{},"value2",[675,771,772,775],{},[690,773,774],{},"Sort results ascending",[690,776,695,777,779,780,782],{},[38,778,698],{}," ORDER BY ",[38,781,750],{}," ASC;",[675,784,785,788],{},[690,786,787],{},"Sort results descending",[690,789,695,790,779,792,794],{},[38,791,698],{},[38,793,750],{}," DESC;",[796,797,798],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":33,"searchDepth":800,"depth":800,"links":801},2,[802,803,804,811,812,816],{"id":14,"depth":800,"text":15},{"id":22,"depth":800,"text":23},{"id":74,"depth":800,"text":75,"children":805},[806,808,809,810],{"id":207,"depth":807,"text":208},3,{"id":259,"depth":807,"text":260},{"id":333,"depth":807,"text":334},{"id":391,"depth":807,"text":392},{"id":461,"depth":800,"text":462},{"id":510,"depth":800,"text":511,"children":813},[814,815],{"id":527,"depth":807,"text":528},{"id":612,"depth":807,"text":613},{"id":663,"depth":800,"text":664},"PHP","2019-09-06 00:07:55","Last time I only covered INSERT, UPDATE, and DELETE, but I left out one thing on purpose: SELECT. The reason is that SELECT has so many possible combinations that it really deserves its own post. So in this one we'll dig into querying all columns, conditional queries with WHERE, AND\u002FOR, operators, LIMIT, and sorting with ORDER BY. Let me show you why I split this out into a separate article.","md","en",{},true,"\u002Fen\u002Fphp\u002Fthink-php-day-05-mysql-select-queries",{"title":6,"description":819},false,"en\u002FPHP\u002Fthink-php-day-05-mysql-select-queries",[817,829,830,831,832],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","11th iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F06\u002Fthink-php-day-05-mysql-select-queries\u002F","8iQiG5S5jpHSZ3NAjtYfCocA8KXcfKxarHZsaJ7GdMg",{"newer":837,"older":841},{"url":838,"title":839,"date":840},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F07\u002Fthinkphp-day-06-installing-thinkphp\u002F","ThinkPHP Day 6: Installing ThinkPHP with Composer","2019-09-07 00:01:37",{"url":842,"title":843,"date":844},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F05\u002Fthinkphp-day-04-mysql-data-crud-01\u002F","Day 4 - Learning ThinkPHP from Scratch: MySQL Data Basics, Part 1 (CRUD)","2019-09-05 00:02:55",[846,851,856],{"url":847,"title":848,"date":849,"readingMinutes":850},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":852,"title":853,"date":854,"readingMinutes":855},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02","3",{"url":857,"title":858,"date":859,"readingMinutes":494},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01",1784011709320]