[{"data":1,"prerenderedAt":719},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F23\u002Fthink-php-day-22-builtin-tags-02\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F23\u002Fthink-php-day-22-builtin-tags-02\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F23\u002Fthink-php-day-22-builtin-tags-02\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F23\u002Fthink-php-day-22-builtin-tags-02\u002F":695,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F23\u002Fthink-php-day-22-builtin-tags-02\u002F":704},"\u002Fphp\u002F20190923\u002F464471552\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":675,"date":676,"description":677,"extension":678,"lang":679,"meta":680,"navigation":681,"path":682,"readingMinutes":683,"seo":684,"standalone":685,"stem":686,"tags":687,"tldr":692,"updated":676,"url":693,"__hash__":694},"content\u002Fen\u002FPHP\u002Fthink-php-day-22-builtin-tags-02.md","ThinkPHP from Scratch Day 22 - Comparison & Conditional Tags","1002747896",{"type":9,"value":10,"toc":662},"minimark",[11,16,20,24,27,32,47,56,86,97,104,107,173,176,205,212,218,241,292,298,304,313,319,323,335,378,382,385,403,406,412,418,424,430,441,455,474,477,481,491,495,501,545,548,552,569,621,625,642,649,652,658],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This post covers another batch of built-in tags: the comparison and conditional tags. You'll end up using these all over the place, so let's go through what they are.",[12,21,23],{"id":22},"comparison-tags","Comparison tags",[17,25,26],{},"The docs file these under \"comparison tags.\" I personally thought \"decision tags\" might be a slightly better name, but eh, I'll respect the official wording here.",[28,29,31],"h3",{"id":30},"eq-or-equal-tag","eq or equal tag",[17,33,34,35,39,40,43,44,46],{},"In the wild, the comparison tag you'll see most often is ",[36,37,38],"code",{},"eq",", or sometimes ",[36,41,42],{},"neq",". Let me start with what ",[36,45,38],{}," does.",[17,48,49,51,52,55],{},[36,50,38],{}," is basically just ",[36,53,54],{},"if",". And honestly, most ThinkPHP comparison tags don't stray far from this pattern:",[57,58,63],"pre",{"className":59,"code":60,"language":61,"meta":62,"style":62},"language-html shiki shiki-themes github-dark-high-contrast","{comparison-tag name=\"variable\" value=\"value\"}\n  content\n{\u002Fcomparison-tag}\n","html","",[36,64,65,74,80],{"__ignoreMap":62},[66,67,70],"span",{"class":68,"line":69},"line",1,[66,71,73],{"class":72},"sMAXC","{comparison-tag name=\"variable\" value=\"value\"}\n",[66,75,77],{"class":68,"line":76},2,[66,78,79],{"class":72},"  content\n",[66,81,83],{"class":68,"line":82},3,[66,84,85],{"class":72},"{\u002Fcomparison-tag}\n",[17,87,88,89,92,93,96],{},"Next, I'll create a ",[36,90,91],{},"hello.html"," under ",[36,94,95],{},"about\u002Fview"," ↓",[17,98,99],{},[100,101],"img",{"alt":102,"src":103},"hello","https:\u002F\u002Fi.imgur.com\u002F1yM6ejU.png",[17,105,106],{},"Then I'll write a small example in the Controller:",[57,108,112],{"className":109,"code":110,"language":111,"meta":62,"style":62},"language-php shiki shiki-themes github-dark-high-contrast","public function helloeq($name){\n    return $this->assign('name',$name)->fetch('hello');\n}\n","php",[36,113,114,130,168],{"__ignoreMap":62},[66,115,116,120,123,127],{"class":68,"line":69},[66,117,119],{"class":118},"sWyjQ","public",[66,121,122],{"class":118}," function",[66,124,126],{"class":125},"sj_SG"," helloeq",[66,128,129],{"class":72},"($name){\n",[66,131,132,135,139,142,145,148,152,155,157,160,162,165],{"class":68,"line":76},[66,133,134],{"class":118},"    return",[66,136,138],{"class":137},"sCcAr"," $this",[66,140,141],{"class":118},"->",[66,143,144],{"class":125},"assign",[66,146,147],{"class":72},"(",[66,149,151],{"class":150},"sTRMh","'name'",[66,153,154],{"class":72},",$name)",[66,156,141],{"class":118},[66,158,159],{"class":125},"fetch",[66,161,147],{"class":72},[66,163,164],{"class":150},"'hello'",[66,166,167],{"class":72},");\n",[66,169,170],{"class":68,"line":82},[66,171,172],{"class":72},"}\n",[17,174,175],{},"Here's the route too, so you don't have to type a bunch of stuff in a sec:",[57,177,179],{"className":109,"code":178,"language":111,"meta":62,"style":62},"Route::get('\u002Fabout\u002Fhelloeq\u002F:name', 'about\u002Findex\u002Fall');\n",[36,180,181],{"__ignoreMap":62},[66,182,183,186,189,192,194,197,200,203],{"class":68,"line":69},[66,184,185],{"class":137},"Route",[66,187,188],{"class":118},"::",[66,190,191],{"class":125},"get",[66,193,147],{"class":72},[66,195,196],{"class":150},"'\u002Fabout\u002Fhelloeq\u002F:name'",[66,198,199],{"class":72},", ",[66,201,202],{"class":150},"'about\u002Findex\u002Fall'",[66,204,167],{"class":72},[17,206,207,208,211],{},"Basically, when we visit ",[36,209,210],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fhelloeq\u002F:name",", we'll see the name that gets passed back ↓",[17,213,214],{},[100,215],{"alt":216,"src":217},"Backend passing a value to the frontend","https:\u002F\u002Fi.imgur.com\u002FyDhJ47H.png",[17,219,220,221,223,224,227,228,231,232,227,234,237,238,240],{},"With all that set up, we can write the ",[36,222,38],{}," tag. Say the rule is: if the name coming in isn't ",[36,225,226],{},"Ray",", show ",[36,229,230],{},"Who are you? I don't know you",", and if it equals ",[36,233,226],{},[36,235,236],{},"Hello, admin",". We can write the tag inside ",[36,239,91],{}," like this:",[57,242,244],{"className":59,"code":243,"language":61,"meta":62,"style":62},"{eq name=\"name\" value=\"Ray\"}\n  \u003Cspan>Hello, admin\u003C\u002Fspan>\n{else\u002F}\n  \u003Cspan>Who are you? I don't know you\u003C\u002Fspan>\n{\u002Feq}\n",[36,245,246,251,267,272,286],{"__ignoreMap":62},[66,247,248],{"class":68,"line":69},[66,249,250],{"class":72},"{eq name=\"name\" value=\"Ray\"}\n",[66,252,253,256,259,262,264],{"class":68,"line":76},[66,254,255],{"class":72},"  \u003C",[66,257,66],{"class":258},"sKpQp",[66,260,261],{"class":72},">Hello, admin\u003C\u002F",[66,263,66],{"class":258},[66,265,266],{"class":72},">\n",[66,268,269],{"class":68,"line":82},[66,270,271],{"class":72},"{else\u002F}\n",[66,273,275,277,279,282,284],{"class":68,"line":274},4,[66,276,255],{"class":72},[66,278,66],{"class":258},[66,280,281],{"class":72},">Who are you? I don't know you\u003C\u002F",[66,283,66],{"class":258},[66,285,266],{"class":72},[66,287,289],{"class":68,"line":288},5,[66,290,291],{"class":72},"{\u002Feq}\n",[17,293,294,295,297],{},"First let's pass in the value ",[36,296,226],{}," and see what shows up ↓",[17,299,300],{},[100,301],{"alt":302,"src":303},"Hello admin appears","https:\u002F\u002Fi.imgur.com\u002FlA9I0VS.png",[17,305,306,307,309,310,96],{},"What about passing in something other than ",[36,308,226],{},"? Say ",[36,311,312],{},"Mr. QQ",[17,314,315],{},[100,316],{"alt":317,"src":318},"Mr. QQ, I don't know you","https:\u002F\u002Fi.imgur.com\u002FrZfa1lI.png",[28,320,322],{"id":321},"neq-or-notequal-tag","neq or notequal tag",[17,324,325,326,328,329,331,332,334],{},"So what about the ",[36,327,42],{}," tag? Above we saw ",[36,330,38],{}," means equals, so ",[36,333,42],{}," means not-equals. I won't do a full example here, I'll just give you the syntax:",[57,336,338],{"className":59,"code":337,"language":61,"meta":62,"style":62},"{neq name=\"name\" value=\"Ray\"}\n  \u003Cspan>Hello, admin\u003C\u002Fspan>\n{else\u002F}\n  \u003Cspan>Who are you? I don't know you\u003C\u002Fspan>\n{\u002Fneq}\n",[36,339,340,345,357,361,373],{"__ignoreMap":62},[66,341,342],{"class":68,"line":69},[66,343,344],{"class":72},"{neq name=\"name\" value=\"Ray\"}\n",[66,346,347,349,351,353,355],{"class":68,"line":76},[66,348,255],{"class":72},[66,350,66],{"class":258},[66,352,261],{"class":72},[66,354,66],{"class":258},[66,356,266],{"class":72},[66,358,359],{"class":68,"line":82},[66,360,271],{"class":72},[66,362,363,365,367,369,371],{"class":68,"line":274},[66,364,255],{"class":72},[66,366,66],{"class":258},[66,368,281],{"class":72},[66,370,66],{"class":258},[66,372,266],{"class":72},[66,374,375],{"class":68,"line":288},[66,376,377],{"class":72},"{\u002Fneq}\n",[28,379,381],{"id":380},"other-comparison-tags","Other comparison tags",[17,383,384],{},"There are a few more tags you'll use a lot: greater-than, greater-than-or-equal, less-than, less-than-or-equal. The syntax is all the same, and the key thing is they all stick to this same structure:",[57,386,388],{"className":59,"code":387,"language":61,"meta":62,"style":62},"{comparison-tag name=\"variable\" value=\"value\"}\ncontent\n{\u002Fcomparison-tag}\n",[36,389,390,394,399],{"__ignoreMap":62},[66,391,392],{"class":68,"line":69},[66,393,73],{"class":72},[66,395,396],{"class":68,"line":76},[66,397,398],{"class":72},"content\n",[66,400,401],{"class":68,"line":82},[66,402,85],{"class":72},[17,404,405],{},"So I'll just give you the syntax without separate examples, since they're all written the same way:",[17,407,408,409],{},"Greater than: ",[36,410,411],{},"{gt name=\"variable\" value=\"value\"}content{\u002Fgt}",[17,413,414,415],{},"Greater than or equal: ",[36,416,417],{},"{egt name=\"variable\" value=\"value\"}content{\u002Fegt}",[17,419,420,421],{},"Less than: ",[36,422,423],{},"{lt name=\"variable\" value=\"value\"}content{\u002Flt}",[17,425,426,427],{},"Less than or equal: ",[36,428,429],{},"{elt name=\"variable\" value=\"value\"}content{\u002Felt}",[17,431,432,433,440],{},"For the details, check out this page on ",[434,435,439],"a",{"href":436,"rel":437},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354085",[438],"nofollow","comparison tags"," (page in Mandarin).",[17,442,443,444,447,448,451,452,454],{},"There's also another way to write it: use the ",[36,445,446],{},"compare"," tag and pass in a ",[36,449,450],{},"type",". Taking ",[36,453,38],{}," as an example:",[57,456,458],{"className":59,"code":457,"language":61,"meta":62,"style":62},"{compare name=\"variable\" value=\"value\" type=\"eq\"}\n  content\n{\u002Fcompare}\n",[36,459,460,465,469],{"__ignoreMap":62},[66,461,462],{"class":68,"line":69},[66,463,464],{"class":72},"{compare name=\"variable\" value=\"value\" type=\"eq\"}\n",[66,466,467],{"class":68,"line":76},[66,468,79],{"class":72},[66,470,471],{"class":68,"line":82},[66,472,473],{"class":72},"{\u002Fcompare}\n",[17,475,476],{},"And that's all the different ways to write comparison tags.",[12,478,480],{"id":479},"conditional-tags","Conditional tags",[17,482,483,484,486,487,490],{},"Conditional tags are a bit like the ones above, but you'll see more familiar syntax here, stuff like ",[36,485,54],{}," and ",[36,488,489],{},"switch",". I won't do many examples, because the effect is pretty much the same as the comparison tags above...",[28,492,494],{"id":493},"if-tag","if tag",[17,496,497,498,500],{},"Basically, when you write conditional tags you can write them just like you'd write actual code. As an example, rewriting ",[36,499,91],{},"'s comparison tag as a conditional tag looks like this:",[57,502,504],{"className":59,"code":503,"language":61,"meta":62,"style":62},"{if ($name == 'Ray')}\n  \u003Cspan>Hello, admin\u003C\u002Fspan>\n{else \u002F}\n  \u003Cspan>Who are you? I don't know you\u003C\u002Fspan>\n{\u002Fif}\n",[36,505,506,511,523,528,540],{"__ignoreMap":62},[66,507,508],{"class":68,"line":69},[66,509,510],{"class":72},"{if ($name == 'Ray')}\n",[66,512,513,515,517,519,521],{"class":68,"line":76},[66,514,255],{"class":72},[66,516,66],{"class":258},[66,518,261],{"class":72},[66,520,66],{"class":258},[66,522,266],{"class":72},[66,524,525],{"class":68,"line":82},[66,526,527],{"class":72},"{else \u002F}\n",[66,529,530,532,534,536,538],{"class":68,"line":274},[66,531,255],{"class":72},[66,533,66],{"class":258},[66,535,281],{"class":72},[66,537,66],{"class":258},[66,539,266],{"class":72},[66,541,542],{"class":68,"line":288},[66,543,544],{"class":72},"{\u002Fif}\n",[17,546,547],{},"Feels a bit more familiar with conditional tags, right? But you might be thinking, \"then I'll just write conditional tags, why bother with comparison tags?\" The thing is, on a system I maintained before, plenty of engineers used the comparison tags. So if you've already seen this stuff, then when you run into it you won't be left scratching your head.",[28,549,551],{"id":550},"switch-tag","switch tag",[17,553,554,555,557,558,486,561,564,565,568],{},"The ",[36,556,489],{}," tag works just like writing PHP, with ",[36,559,560],{},"case",[36,562,563],{},"default",". The one big difference is you don't need ",[36,566,567],{},"break;",". The syntax looks like this:",[57,570,572],{"className":59,"code":571,"language":61,"meta":62,"style":62},"{switch $name}\n  {case Ray}\n    \u003Cspan>Hello, admin\u003C\u002Fspan>\n  {\u002Fcase}\n  {default\u002F}\u003Cspan>Who are you? I don't know you\u003C\u002Fspan>\n{\u002Fswitch}\n",[36,573,574,579,584,597,602,615],{"__ignoreMap":62},[66,575,576],{"class":68,"line":69},[66,577,578],{"class":72},"{switch $name}\n",[66,580,581],{"class":68,"line":76},[66,582,583],{"class":72},"  {case Ray}\n",[66,585,586,589,591,593,595],{"class":68,"line":82},[66,587,588],{"class":72},"    \u003C",[66,590,66],{"class":258},[66,592,261],{"class":72},[66,594,66],{"class":258},[66,596,266],{"class":72},[66,598,599],{"class":68,"line":274},[66,600,601],{"class":72},"  {\u002Fcase}\n",[66,603,604,607,609,611,613],{"class":68,"line":288},[66,605,606],{"class":72},"  {default\u002F}\u003C",[66,608,66],{"class":258},[66,610,281],{"class":72},[66,612,66],{"class":258},[66,614,266],{"class":72},[66,616,618],{"class":68,"line":617},6,[66,619,620],{"class":72},"{\u002Fswitch}\n",[12,622,624],{"id":623},"wrap-up","Wrap-up",[17,626,627,628,631,632,631,635,631,638,641],{},"So those are the more common tags. There are other built-in tags too, like the range tags ",[36,629,630],{},"in"," \u002F ",[36,633,634],{},"notin",[36,636,637],{},"between",[36,639,640],{},"notbetween",". I'd personally recommend checking the official dev manual for those, since they go into more detail, and honestly I've never used the range tags myself.",[17,643,644,648],{},[434,645,480],{"href":646,"rel":647},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354086",[438]," (page in Mandarin)",[17,650,651],{},"Finally, I'll cram as many tags as I can into the example, which also makes it handy to look back on ↓",[17,653,654],{},[100,655],{"alt":656,"src":657},"Built-in tags","https:\u002F\u002Fi.imgur.com\u002FByRLoxA.png",[659,660,661],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}",{"title":62,"searchDepth":76,"depth":76,"links":663},[664,665,670,674],{"id":14,"depth":76,"text":15},{"id":22,"depth":76,"text":23,"children":666},[667,668,669],{"id":30,"depth":82,"text":31},{"id":321,"depth":82,"text":322},{"id":380,"depth":82,"text":381},{"id":479,"depth":76,"text":480,"children":671},[672,673],{"id":493,"depth":82,"text":494},{"id":550,"depth":82,"text":551},{"id":623,"depth":76,"text":624},"PHP","2019-09-23 00:01:06","This post covers another batch of built-in tags: comparison and conditional tags. You'll run into these a lot in real ThinkPHP projects, so I'll walk through eq, neq, the greater-than \u002F less-than family, and then the more familiar if and switch tags. By the end you'll know which one to reach for and why both styles still show up in legacy code.","md","en",{},true,"\u002Fen\u002Fphp\u002Fthink-php-day-22-builtin-tags-02","4",{"title":6,"description":677},false,"en\u002FPHP\u002Fthink-php-day-22-builtin-tags-02",[675,688,689,690,691],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","11th iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F23\u002Fthink-php-day-22-builtin-tags-02\u002F","vnZz17EA2LjXI0d4PGJ6U1bdPFIOg8uGmg-_hiCBwqw",{"newer":696,"older":700},{"url":697,"title":698,"date":699},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F23\u002Fjs-from-zero-ep08-anonymous-functions\u002F","JS From Zero EP.8 — Anonymous Functions and IIFEs","2019-09-23 00:02:02",{"url":701,"title":702,"date":703},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F22\u002Fthinkphp-day-21-built-in-tags-01\u002F","ThinkPHP Built-in Tags (1): Looping with volist, for, and foreach","2019-09-22 00:01:20",[705,710,715],{"url":706,"title":707,"date":708,"readingMinutes":709},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":711,"title":712,"date":713,"readingMinutes":714},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02","3",{"url":716,"title":717,"date":718,"readingMinutes":683},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01",1784013071390]