[{"data":1,"prerenderedAt":1679},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F30\u002Fthink-php-day-29-cli-commands-and-migrations\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F30\u002Fthink-php-day-29-cli-commands-and-migrations\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F30\u002Fthink-php-day-29-cli-commands-and-migrations\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F30\u002Fthink-php-day-29-cli-commands-and-migrations\u002F":1654,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F30\u002Fthink-php-day-29-cli-commands-and-migrations\u002F":1663},"\u002Fphp\u002F20190930\u002F81339708\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1634,"date":1635,"description":1636,"extension":1637,"lang":1638,"meta":1639,"navigation":1640,"path":1641,"readingMinutes":1642,"seo":1643,"standalone":1644,"stem":1645,"tags":1646,"tldr":1651,"updated":1635,"url":1652,"__hash__":1653},"content\u002Fen\u002FPHP\u002Fthink-php-day-29-cli-commands-and-migrations.md","ThinkPHP CLI Commands and Database Migrations (Day 29)","1002803329",{"type":9,"value":10,"toc":1615},"minimark",[11,16,20,24,32,35,68,73,87,94,98,116,122,133,137,151,154,158,172,182,186,213,228,232,256,259,263,282,285,291,295,307,313,317,330,336,347,387,392,406,411,438,460,463,562,565,571,578,584,587,643,650,655,670,675,679,686,692,719,738,741,1113,1137,1141,1155,1161,1167,1173,1181,1187,1192,1195,1206,1210,1228,1234,1240,1585,1592,1598,1602,1608,1611],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Next up we're going to get to know some of ThinkPHP's commonly used basic CLI commands. But the main focus of this post is migrations, because they're going to affect how we work in the later chapters.",[12,21,23],{"id":22},"the-basic-commands","The basic commands",[17,25,26,27,31],{},"The command we use most often during development is ",[28,29,30],"code",{},"php think run",". It basically spins up a local server so we can develop and debug easily. But ThinkPHP gives us way more commands than just that one.",[17,33,34],{},"The format for ThinkPHP commands is always the same kind of pattern:",[36,37,42],"pre",{"className":38,"code":39,"language":40,"meta":41,"style":41},"language-php shiki shiki-themes github-dark-high-contrast","php think [command name]\n","php","",[28,43,44],{"__ignoreMap":41},[45,46,49,52,55,59,62,65],"span",{"class":47,"line":48},"line",1,[45,50,40],{"class":51},"sCcAr",[45,53,54],{"class":51}," think",[45,56,58],{"class":57},"sMAXC"," [",[45,60,61],{"class":51},"command",[45,63,64],{"class":51}," name",[45,66,67],{"class":57},"]\n",[69,70,72],"h3",{"id":71},"check-the-framework-version-number","Check the framework version number",[36,74,76],{"className":38,"code":75,"language":40,"meta":41,"style":41},"php think version\n",[28,77,78],{"__ignoreMap":41},[45,79,80,82,84],{"class":47,"line":48},[45,81,40],{"class":51},[45,83,54],{"class":51},[45,85,86],{"class":51}," version\n",[17,88,89],{},[90,91],"img",{"alt":92,"src":93},"framework version number","https:\u002F\u002Fi.imgur.com\u002Fy5grdMh.png",[69,95,97],{"id":96},"check-the-think-console-version-number","Check the Think console version number",[36,99,101],{"className":38,"code":100,"language":40,"meta":41,"style":41},"php think -V\n",[28,102,103],{"__ignoreMap":41},[45,104,105,107,109,113],{"class":47,"line":48},[45,106,40],{"class":51},[45,108,54],{"class":51},[45,110,112],{"class":111},"sWyjQ"," -",[45,114,115],{"class":51},"V\n",[17,117,118],{},[90,119],{"alt":120,"src":121},"console version number","https:\u002F\u002Fi.imgur.com\u002F05fCjzc.png",[17,123,124,125,128,129,132],{},"Heads up here: ",[28,126,127],{},"-V"," is NOT the same as ",[28,130,131],{},"version",". They're two different things.",[69,134,136],{"id":135},"start-the-local-server","Start the local server",[36,138,140],{"className":38,"code":139,"language":40,"meta":41,"style":41},"php think run\n",[28,141,142],{"__ignoreMap":41},[45,143,144,146,148],{"class":47,"line":48},[45,145,40],{"class":51},[45,147,54],{"class":51},[45,149,150],{"class":51}," run\n",[17,152,153],{},"No need to explain this one — we've used it a ton in the earlier chapters. Once you run it, it spins up a local server.",[69,155,157],{"id":156},"clear-the-cache","Clear the cache",[36,159,161],{"className":38,"code":160,"language":40,"meta":41,"style":41},"php think clear\n",[28,162,163],{"__ignoreMap":41},[45,164,165,167,169],{"class":47,"line":48},[45,166,40],{"class":51},[45,168,54],{"class":51},[45,170,171],{"class":51}," clear\n",[17,173,174,177,178,181],{},[28,175,176],{},"clear"," wipes all the files inside the ",[28,179,180],{},"runtime"," folder.",[69,183,185],{"id":184},"create-a-controller","Create a Controller",[36,187,189],{"className":38,"code":188,"language":40,"meta":41,"style":41},"php think make:controller [path]\n",[28,190,191],{"__ignoreMap":41},[45,192,193,195,197,200,203,206,208,211],{"class":47,"line":48},[45,194,40],{"class":51},[45,196,54],{"class":51},[45,198,199],{"class":51}," make",[45,201,202],{"class":57},":",[45,204,205],{"class":51},"controller",[45,207,58],{"class":57},[45,209,210],{"class":51},"path",[45,212,67],{"class":57},[17,214,215,216,219,220,223,224,227],{},"Just pass a path after this command and it'll auto-generate things for you. For example ",[28,217,218],{},"message\u002Findex"," will create a ",[28,221,222],{},"message"," folder with a ",[28,225,226],{},"controller\u002Findex.php"," inside it.",[69,229,231],{"id":230},"create-a-model","Create a Model",[36,233,235],{"className":38,"code":234,"language":40,"meta":41,"style":41},"php think make:MODEL [path]\n",[28,236,237],{"__ignoreMap":41},[45,238,239,241,243,245,247,250,252,254],{"class":47,"line":48},[45,240,40],{"class":51},[45,242,54],{"class":51},[45,244,199],{"class":51},[45,246,202],{"class":57},[45,248,249],{"class":51},"MODEL",[45,251,58],{"class":57},[45,253,210],{"class":51},[45,255,67],{"class":57},[17,257,258],{},"Same deal as creating a Controller.",[69,260,262],{"id":261},"list-all-current-routes","List all current routes",[36,264,266],{"className":38,"code":265,"language":40,"meta":41,"style":41},"php think route:list\n",[28,267,268],{"__ignoreMap":41},[45,269,270,272,274,277,279],{"class":47,"line":48},[45,271,40],{"class":51},[45,273,54],{"class":51},[45,275,276],{"class":51}," route",[45,278,202],{"class":57},[45,280,281],{"class":51},"list\n",[17,283,284],{},"Run it and you'll see all the routes that are already registered ↓",[17,286,287],{},[90,288],{"alt":289,"src":290},"all routes","https:\u002F\u002Fi.imgur.com\u002FQN7XoDU.png",[69,292,294],{"id":293},"list-all-commands","List all commands",[36,296,298],{"className":38,"code":297,"language":40,"meta":41,"style":41},"php think\n",[28,299,300],{"__ignoreMap":41},[45,301,302,304],{"class":47,"line":48},[45,303,40],{"class":51},[45,305,306],{"class":51}," think\n",[17,308,309],{},[90,310],{"alt":311,"src":312},"all commands","https:\u002F\u002Fi.imgur.com\u002FCqxKF1o.png",[12,314,316],{"id":315},"database-migrations","Database migrations",[17,318,319,320,323,324,326,327,329],{},"Now I'll briefly introduce one of ThinkPHP's extension packages — ",[28,321,322],{},"think-migration",". As the name suggests, ",[28,325,322],{}," helps us migrate the database, but to use it you have to install it through Composer first. So why am I specifically calling out ",[28,328,322],{},"? Mainly because in the past, whenever we migrated a database, most of the time we did it with a SQL dump file ↓",[17,331,332],{},[90,333],{"alt":334,"src":335},"SQL","https:\u002F\u002Fi.imgur.com\u002FEExhNv0.png",[17,337,338,339,341,342,344,345,202],{},"But don't be scared of ",[28,340,322],{},". The thing is, normally you can't version-control a database with a raw SQL file, but a migration is just code, so ",[28,343,322],{}," files get committed into Git version control. And if one day your requirements change and you need to move from MySQL to a different database, don't worry too much either — usually you just need a small tweak. So let's go ahead and install ",[28,346,322],{},[36,348,350],{"className":38,"code":349,"language":40,"meta":41,"style":41},"composer require topthink\u002Fthink-migration=2.0.*\n",[28,351,352],{"__ignoreMap":41},[45,353,354,357,360,363,366,369,372,375,378,381,384],{"class":47,"line":48},[45,355,356],{"class":51},"composer",[45,358,359],{"class":111}," require",[45,361,362],{"class":51}," topthink",[45,364,365],{"class":111},"\u002F",[45,367,368],{"class":51},"think",[45,370,371],{"class":111},"-",[45,373,374],{"class":51},"migration",[45,376,377],{"class":111},"=",[45,379,380],{"class":51},"2.0",[45,382,383],{"class":111},".",[45,385,386],{"class":111},"*\n",[17,388,389],{},[90,390],{"alt":322,"src":391},"https:\u002F\u002Fi.imgur.com\u002F84ZHLIc.png",[17,393,394,395,398,399,402,403,405],{},"Heads up: for the steps coming next, make sure you've set up ",[28,396,397],{},"database.php"," properly, otherwise nothing will work. Now we can run ",[28,400,401],{},"php think"," to see what commands ",[28,404,322],{}," gives us ↓",[17,407,408],{},[90,409],{"alt":374,"src":410},"https:\u002F\u002Fi.imgur.com\u002FMxirz1P.png",[17,412,413,414,417,418,417,421,417,424,417,427,430,431,434,435,437],{},"Next we want to migrate our database. We've basically got six tables: ",[28,415,416],{},"hw_table",", ",[28,419,420],{},"think_account",[28,422,423],{},"think_db",[28,425,426],{},"think_message",[28,428,429],{},"think_new_user",", and ",[28,432,433],{},"think_user",". But one thing to watch out for here: when we create migration files for the tables, the name has to start with an uppercase letter and use camelCase. Take ",[28,436,416],{}," as an example — the command would be:",[36,439,441],{"className":38,"code":440,"language":40,"meta":41,"style":41},"php think migrate:create HwTable\n",[28,442,443],{"__ignoreMap":41},[45,444,445,447,449,452,454,457],{"class":47,"line":48},[45,446,40],{"class":51},[45,448,54],{"class":51},[45,450,451],{"class":51}," migrate",[45,453,202],{"class":57},[45,455,456],{"class":51},"create",[45,458,459],{"class":51}," HwTable\n",[17,461,462],{},"So from that we can figure out the create-migration commands for all six tables:",[36,464,466],{"className":38,"code":465,"language":40,"meta":41,"style":41},"php think migrate:create HwTable\nphp think migrate:create ThinkAccount\nphp think migrate:create ThinkDb\nphp think migrate:create ThinkMessage\nphp think migrate:create ThinkNewUser\nphp think migrate:create ThinkUser\n",[28,467,468,482,498,514,530,546],{"__ignoreMap":41},[45,469,470,472,474,476,478,480],{"class":47,"line":48},[45,471,40],{"class":51},[45,473,54],{"class":51},[45,475,451],{"class":51},[45,477,202],{"class":57},[45,479,456],{"class":51},[45,481,459],{"class":51},[45,483,485,487,489,491,493,495],{"class":47,"line":484},2,[45,486,40],{"class":51},[45,488,54],{"class":51},[45,490,451],{"class":51},[45,492,202],{"class":57},[45,494,456],{"class":51},[45,496,497],{"class":51}," ThinkAccount\n",[45,499,501,503,505,507,509,511],{"class":47,"line":500},3,[45,502,40],{"class":51},[45,504,54],{"class":51},[45,506,451],{"class":51},[45,508,202],{"class":57},[45,510,456],{"class":51},[45,512,513],{"class":51}," ThinkDb\n",[45,515,517,519,521,523,525,527],{"class":47,"line":516},4,[45,518,40],{"class":51},[45,520,54],{"class":51},[45,522,451],{"class":51},[45,524,202],{"class":57},[45,526,456],{"class":51},[45,528,529],{"class":51}," ThinkMessage\n",[45,531,533,535,537,539,541,543],{"class":47,"line":532},5,[45,534,40],{"class":51},[45,536,54],{"class":51},[45,538,451],{"class":51},[45,540,202],{"class":57},[45,542,456],{"class":51},[45,544,545],{"class":51}," ThinkNewUser\n",[45,547,549,551,553,555,557,559],{"class":47,"line":548},6,[45,550,40],{"class":51},[45,552,54],{"class":51},[45,554,451],{"class":51},[45,556,202],{"class":57},[45,558,456],{"class":51},[45,560,561],{"class":51}," ThinkUser\n",[17,563,564],{},"Which gives us these migration files ↓",[17,566,567],{},[90,568],{"alt":569,"src":570},"migration files","https:\u002F\u002Fi.imgur.com\u002FEab23kZ.png",[17,572,573,574,577],{},"Once they're created, you can run ",[28,575,576],{},"php think migrate:status"," to check the status of the migration files ↓",[17,579,580],{},[90,581],{"alt":582,"src":583},"migrate:status","https:\u002F\u002Fi.imgur.com\u002FJzcaKY1.png",[17,585,586],{},"By the way, if you're following along with this post and also using XAMPP, you'll probably hit the following error:",[36,588,592],{"className":589,"code":590,"language":591,"meta":41,"style":41},"language-sql shiki shiki-themes github-dark-high-contrast","[InvalidArgumentException]\nThere was a problem creating the schema table: SQLSTATE[42000]: Syntax error or acce\nss violation: 1067 Invalid default value for 'end_time'\n","sql",[28,593,594,599,619],{"__ignoreMap":41},[45,595,596],{"class":47,"line":48},[45,597,598],{"class":57},"[InvalidArgumentException]\n",[45,600,601,604,607,610,613,616],{"class":47,"line":484},[45,602,603],{"class":57},"There was a problem creating the ",[45,605,606],{"class":111},"schema",[45,608,609],{"class":111}," table",[45,611,612],{"class":57},": SQLSTATE[42000]: Syntax error ",[45,614,615],{"class":111},"or",[45,617,618],{"class":57}," acce\n",[45,620,621,624,627,630,633,636,639],{"class":47,"line":500},[45,622,623],{"class":57},"ss violation: ",[45,625,626],{"class":51},"1067",[45,628,629],{"class":57}," Invalid ",[45,631,632],{"class":111},"default",[45,634,635],{"class":111}," value",[45,637,638],{"class":111}," for",[45,640,642],{"class":641},"sTRMh"," 'end_time'\n",[17,644,645,646,649],{},"To fix this, just open ",[28,647,648],{},"my.ini"," to get into the config file ↓",[17,651,652],{},[90,653],{"alt":648,"src":654},"https:\u002F\u002Fi.imgur.com\u002FuM68JPF.png",[17,656,657,658,661,662,665,666,669],{},"Then search for ",[28,659,660],{},"sql_mode",", change the original ",[28,663,664],{},"sql_mode=NO_ZERO_IN_DATE,NO_ZERO_DATE,NO_ENGINE_SUBSTITUTION"," to just ",[28,667,668],{},"sql_mode=",", and restart. That'll sort it out.",[17,671,672],{},[90,673],{"alt":648,"src":674},"https:\u002F\u002Fi.imgur.com\u002FpO525Sj.png",[69,676,678],{"id":677},"migration-files","Migration files",[17,680,681,682,685],{},"The migration files we just created are pretty empty by default — all you'll see inside is a ",[28,683,684],{},"change()"," method ↓",[17,687,688],{},[90,689],{"alt":690,"src":691},"empty and lonely","https:\u002F\u002Fi.imgur.com\u002FwulBS96.png",[17,693,694,695,697,698,701,702,705,706,708,709,430,712,714,715,718],{},"Next, delete ",[28,696,684],{}," and rewrite it as ",[28,699,700],{},"up()"," and ",[28,703,704],{},"down()",". ",[28,707,700],{}," runs its contents when we execute ",[28,710,711],{},"php think migrate:run",[28,713,704],{}," runs on ",[28,716,717],{},"migrate:rollback",". So what goes inside? The main bits of syntax we'll use are:",[720,721,722,728,733],"ul",{},[723,724,725],"li",{},[28,726,727],{},"addColumn()",[723,729,730],{},[28,731,732],{},"dropTable()",[723,734,735],{},[28,736,737],{},"create()",[17,739,740],{},"Here I'll use the message board table as an example to write one out:",[36,742,744],{"className":38,"code":743,"language":40,"meta":41,"style":41},"public function up()\n{\n    $table = $this->table('message'); \u002F\u002F the Think_ prefix is added automatically on load\n    $table->addColumn('title', 'string', ['limit'=> 15, 'default'=>'', 'comment' => 'title'])\n    ->addColumn('content', 'text', ['default'=>'', 'comment' => 'message content'])\n    ->addColumn('author', 'string', ['limit'=> 20, 'default'=>'', 'comment' => 'author'])\n    ->addColumn('email', 'string', ['limit'=> 128, 'default'=>'', 'comment' => 'email'])\n    ->addColumn('create_time', 'timestamp', ['default'=>'CURRENT_TIMESTAMP', 'comment' => 'created at'])\n    ->addColumn('last_modify_time', 'timestamp', ['default'=>'CURRENT_TIMESTAMP','update' => 'CURRENT_TIMESTAMP', 'comment' 