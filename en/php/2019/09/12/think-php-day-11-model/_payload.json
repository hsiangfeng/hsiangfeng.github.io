[{"data":1,"prerenderedAt":766},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F":742,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F":751},"\u002Fphp\u002F20190912\u002F1469012740\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":724,"date":725,"description":726,"extension":727,"lang":728,"meta":729,"navigation":86,"path":730,"readingMinutes":731,"seo":732,"standalone":733,"stem":734,"tags":735,"tldr":739,"updated":725,"url":740,"__hash__":741},"content\u002Fen\u002FPHP\u002Fthink-php-day-11-model.md","Learning ThinkPHP from Scratch Day 11 - Defining Models","1002652868",{"type":9,"value":10,"toc":717},"minimark",[11,16,20,24,36,42,45,131,138,141,145,148,155,161,176,182,193,196,334,341,345,351,420,426,444,447,706,710,713],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This chapter is a little shorter. It mostly covers the basics of defining a Model, but the thing is, in normal development you don't really do much setup on the Model side, so you'll notice this chapter genuinely doesn't have a whole lot to it.",[12,21,23],{"id":22},"getting-started","Getting started",[17,25,26,27,31,32,35],{},"Defining a Model is pretty simple, but before that we need to create the Model folder first. ThinkPHP doesn't give you a Model folder by default, so we'll create a ",[28,29,30],"code",{},"model"," folder under ",[28,33,34],{},"about"," and add a new file called about.php:",[17,37,38],{},[39,40],"img",{"alt":34,"src":41},"https:\u002F\u002Fi.imgur.com\u002F3isRFXF.png",[17,43,44],{},"And defining the Model only takes this much:",[46,47,52],"pre",{"className":48,"code":49,"language":50,"meta":51,"style":51},"language-php shiki shiki-themes github-dark-high-contrast","\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n}\n","php","",[28,53,54,67,81,88,99,104,119,125],{"__ignoreMap":51},[55,56,59,63],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"sWyjQ","\u003C?",[55,64,66],{"class":65},"sCcAr","php\n",[55,68,70,73,77],{"class":57,"line":69},2,[55,71,72],{"class":61},"namespace",[55,74,76],{"class":75},"s_sBn"," app\\about\\model",[55,78,80],{"class":79},"sMAXC",";\n",[55,82,84],{"class":57,"line":83},3,[55,85,87],{"emptyLinePlaceholder":86},true,"\n",[55,89,91,94,97],{"class":57,"line":90},4,[55,92,93],{"class":61},"use",[55,95,96],{"class":65}," think\\Model",[55,98,80],{"class":79},[55,100,102],{"class":57,"line":101},5,[55,103,87],{"emptyLinePlaceholder":86},[55,105,107,110,113,116],{"class":57,"line":106},6,[55,108,109],{"class":61},"class",[55,111,112],{"class":75}," about",[55,114,115],{"class":61}," extends",[55,117,118],{"class":65}," Model\n",[55,120,122],{"class":57,"line":121},7,[55,123,124],{"class":79},"{\n",[55,126,128],{"class":57,"line":127},8,[55,129,130],{"class":79},"}\n",[17,132,133,134,137],{},"The one line you really need to watch out for in there is ",[28,135,136],{},"use think\\Model;",". This tells ThinkPHP that we want to use the Model core library, and if you leave this line out, it won't run properly.",[17,139,140],{},"Okay, congrats, you've finished a basic Model definition (?!). But just defining a Model isn't enough — after all, a Model talks to the DB, so next we need to set up the database.",[12,142,144],{"id":143},"connecting-to-the-database","Connecting to the database",[17,146,147],{},"Once we've done the above, we need to wire up the database connection, otherwise the Model can't do anything with the DB.",[17,149,150,151,154],{},"The database config file lives at ",[28,152,153],{},"project\u002Fconfig\u002Fdatabase.php",". You just fill in the relevant fields:",[17,156,157],{},[39,158],{"alt":159,"src":160},"database","https:\u002F\u002Fi.imgur.com\u002Fh0HdCM4.png",[17,162,163,164,167,168,171,172,175],{},"Basically you only need to fill in ",[28,165,166],{},"hostname",", ",[28,169,170],{},"username",", and ",[28,173,174],{},"password",". Based on my MySQL setup, here's how I filled it in:",[17,177,178],{},[39,179],{"alt":180,"src":181},"MySQL","https:\u002F\u002Fi.imgur.com\u002F6UiCius.png",[17,183,184,185,188,189,192],{},"There's one extra field I filled in though — ",[28,186,187],{},"prefix",". The database I created uses a prefix, so I set it to ",[28,190,191],{},"think_",".",[17,194,195],{},"Next we'll add a table (we'll use it in later chapters). I'll just hand you the SQL directly:",[46,197,201],{"className":198,"code":199,"language":200,"meta":51,"style":51},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_user (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  weight int(5) NOT NULL default 0,\n  height float(5) NOT NULL default 0,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql",[28,202,203,218,241,268,291,313,321],{"__ignoreMap":51},[55,204,205,208,211,215],{"class":57,"line":58},[55,206,207],{"class":61},"CREATE",[55,209,210],{"class":61}," TABLE",[55,212,214],{"class":213},"sj_SG"," think_user",[55,216,217],{"class":79}," (\n",[55,219,220,223,226,229,232,235,238],{"class":57,"line":69},[55,221,222],{"class":79},"  id ",[55,224,225],{"class":61},"int",[55,227,228],{"class":79},"(",[55,230,231],{"class":65},"10",[55,233,234],{"class":79},") ",[55,236,237],{"class":61},"NOT NULL",[55,239,240],{"class":79}," auto_increment,\n",[55,242,243,246,249,251,254,256,258,261,265],{"class":57,"line":83},[55,244,245],{"class":61},"  name",[55,247,248],{"class":61}," varchar",[55,250,228],{"class":79},[55,252,253],{"class":65},"5",[55,255,234],{"class":79},[55,257,237],{"class":61},[55,259,260],{"class":61}," default",[55,262,264],{"class":263},"sTRMh"," ''",[55,266,267],{"class":79},",\n",[55,269,270,273,276,278,280,282,284,286,289],{"class":57,"line":90},[55,271,272],{"class":61},"  weight",[55,274,275],{"class":61}," int",[55,277,228],{"class":79},[55,279,253],{"class":65},[55,281,234],{"class":79},[55,283,237],{"class":61},[55,285,260],{"class":61},[55,287,288],{"class":65}," 0",[55,290,267],{"class":79},[55,292,293,296,299,301,303,305,307,309,311],{"class":57,"line":101},[55,294,295],{"class":79},"  height ",[55,297,298],{"class":61},"float",[55,300,228],{"class":79},[55,302,253],{"class":65},[55,304,234],{"class":79},[55,306,237],{"class":61},[55,308,260],{"class":61},[55,310,288],{"class":65},[55,312,267],{"class":79},[55,314,315,318],{"class":57,"line":106},[55,316,317],{"class":61},"  PRIMARY KEY",[55,319,320],{"class":79}," (id)\n",[55,322,323,326,329,332],{"class":57,"line":121},[55,324,325],{"class":79},") AUTO_INCREMENT",[55,327,328],{"class":61},"=",[55,330,331],{"class":65},"1",[55,333,80],{"class":79},[17,335,336,337,340],{},"You'll notice my table name has a prefix on it too, which is going to help us out in the later operations. The main reason is that when I set up database.php earlier, I filled in ",[28,338,339],{},"prefix => 'think_'",", so every table I create has to carry that prefix, otherwise ThinkPHP won't find it.",[12,342,344],{"id":343},"pointing-a-model-at-a-table","Pointing a Model at a table",[17,346,347,348,350],{},"Since I set the prefix ",[28,349,191],{}," for both the database and tables in database.php, when we point at a table next, we have to write it like this:",[46,352,354],{"className":48,"code":353,"language":50,"meta":51,"style":51},"\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n  protected $table = 'think_user';\n}\n",[28,355,356,362,370,374,382,386,396,400,415],{"__ignoreMap":51},[55,357,358,360],{"class":57,"line":58},[55,359,62],{"class":61},[55,361,66],{"class":65},[55,363,364,366,368],{"class":57,"line":69},[55,365,72],{"class":61},[55,367,76],{"class":75},[55,369,80],{"class":79},[55,371,372],{"class":57,"line":83},[55,373,87],{"emptyLinePlaceholder":86},[55,375,376,378,380],{"class":57,"line":90},[55,377,93],{"class":61},[55,379,96],{"class":65},[55,381,80],{"class":79},[55,383,384],{"class":57,"line":101},[55,385,87],{"emptyLinePlaceholder":86},[55,387,388,390,392,394],{"class":57,"line":106},[55,389,109],{"class":61},[55,391,112],{"class":75},[55,393,115],{"class":61},[55,395,118],{"class":65},[55,397,398],{"class":57,"line":121},[55,399,124],{"class":79},[55,401,402,405,408,410,413],{"class":57,"line":127},[55,403,404],{"class":61},"  protected",[55,406,407],{"class":79}," $table ",[55,409,328],{"class":61},[55,411,412],{"class":263}," 'think_user'",[55,414,80],{"class":79},[55,416,418],{"class":57,"line":417},9,[55,419,130],{"class":79},[17,421,422,423,425],{},"You can also write the short form and let ThinkPHP tack on ",[28,424,191],{}," for you — I just personally prefer writing it out in full:",[46,427,429],{"className":48,"code":428,"language":50,"meta":51,"style":51},"protected $table = 'think_user';\n",[28,430,431],{"__ignoreMap":51},[55,432,433,436,438,440,442],{"class":57,"line":58},[55,434,435],{"class":61},"protected",[55,437,407],{"class":79},[55,439,328],{"class":61},[55,441,412],{"class":263},[55,443,80],{"class":79},[17,445,446],{},"And if you want this Model to connect to a different database, that's fine too. You just write in the settings to override the originals:",[46,448,450],{"className":48,"code":449,"language":50,"meta":51,"style":51},"\u003C?php\nnamespace app\\about\\model;\n\nuse think\\Model;\n\nclass about extends Model\n{\n  protected $connection = [\n    \u002F\u002F database type\n    'type' => 'mysql',\n    \u002F\u002F database IP\n    'hostname' => '127.0.0.1',\n    \u002F\u002F database name\n    'database' => 'test',\n    \u002F\u002F username\n    'username' => 'root',\n    \u002F\u002F password\n    'password' => '',\n    \u002F\u002F database port\n    'hostport' => '',\n    \u002F\u002F params\n    'params' => [],\n    \u002F\u002F charset\n    'charset' => 'utf8',\n    \u002F\u002F prefix\n    'prefix' => 'think_',\n    \u002F\u002F Debug mode\n    'debug' => true,\n    ];\n}\n",[28,451,452,458,466,470,478,482,492,496,508,514,528,534,547,553,566,572,585,591,603,609,621,627,638,644,657,663,676,682,695,701],{"__ignoreMap":51},[55,453,454,456],{"class":57,"line":58},[55,455,62],{"class":61},[55,457,66],{"class":65},[55,459,460,462,464],{"class":57,"line":69},[55,461,72],{"class":61},[55,463,76],{"class":75},[55,465,80],{"class":79},[55,467,468],{"class":57,"line":83},[55,469,87],{"emptyLinePlaceholder":86},[55,471,472,474,476],{"class":57,"line":90},[55,473,93],{"class":61},[55,475,96],{"class":65},[55,477,80],{"class":79},[55,479,480],{"class":57,"line":101},[55,481,87],{"emptyLinePlaceholder":86},[55,483,484,486,488,490],{"class":57,"line":106},[55,485,109],{"class":61},[55,487,112],{"class":75},[55,489,115],{"class":61},[55,491,118],{"class":65},[55,493,494],{"class":57,"line":121},[55,495,124],{"class":79},[55,497,498,500,503,505],{"class":57,"line":127},[55,499,404],{"class":61},[55,501,502],{"class":79}," $connection ",[55,504,328],{"class":61},[55,506,507],{"class":79}," [\n",[55,509,510],{"class":57,"line":417},[55,511,513],{"class":512},"sQrFR","    \u002F\u002F database type\n",[55,515,517,520,523,526],{"class":57,"line":516},10,[55,518,519],{"class":263},"    'type'",[55,521,522],{"class":61}," =>",[55,524,525],{"class":263}," 'mysql'",[55,527,267],{"class":79},[55,529,531],{"class":57,"line":530},11,[55,532,533],{"class":512},"    \u002F\u002F database IP\n",[55,535,537,540,542,545],{"class":57,"line":536},12,[55,538,539],{"class":263},"    'hostname'",[55,541,522],{"class":61},[55,543,544],{"class":263}," '127.0.0.1'",[55,546,267],{"class":79},[55,548,550],{"class":57,"line":549},13,[55,551,552],{"class":512},"    \u002F\u002F database name\n",[55,554,556,559,561,564],{"class":57,"line":555},14,[55,557,558],{"class":263},"    'database'",[55,560,522],{"class":61},[55,562,563],{"class":263}," 'test'",[55,565,267],{"class":79},[55,567,569],{"class":57,"line":568},15,[55,570,571],{"class":512},"    \u002F\u002F username\n",[55,573,575,578,580,583],{"class":57,"line":574},16,[55,576,577],{"class":263},"    'username'",[55,579,522],{"class":61},[55,581,582],{"class":263}," 'root'",[55,584,267],{"class":79},[55,586,588],{"class":57,"line":587},17,[55,589,590],{"class":512},"    \u002F\u002F password\n",[55,592,594,597,599,601],{"class":57,"line":593},18,[55,595,596],{"class":263},"    'password'",[55,598,522],{"class":61},[55,600,264],{"class":263},[55,602,267],{"class":79},[55,604,606],{"class":57,"line":605},19,[55,607,608],{"class":512},"    \u002F\u002F database port\n",[55,610,612,615,617,619],{"class":57,"line":611},20,[55,613,614],{"class":263},"    'hostport'",[55,616,522],{"class":61},[55,618,264],{"class":263},[55,620,267],{"class":79},[55,622,624],{"class":57,"line":623},21,[55,625,626],{"class":512},"    \u002F\u002F params\n",[55,628,630,633,635],{"class":57,"line":629},22,[55,631,632],{"class":263},"    'params'",[55,634,522],{"class":61},[55,636,637],{"class":79}," [],\n",[55,639,641],{"class":57,"line":640},23,[55,642,643],{"class":512},"    \u002F\u002F charset\n",[55,645,647,650,652,655],{"class":57,"line":646},24,[55,648,649],{"class":263},"    'charset'",[55,651,522],{"class":61},[55,653,654],{"class":263}," 'utf8'",[55,656,267],{"class":79},[55,658,660],{"class":57,"line":659},25,[55,661,662],{"class":512},"    \u002F\u002F prefix\n",[55,664,666,669,671,674],{"class":57,"line":665},26,[55,667,668],{"class":263},"    'prefix'",[55,670,522],{"class":61},[55,672,673],{"class":263}," 'think_'",[55,675,267],{"class":79},[55,677,679],{"class":57,"line":678},27,[55,680,681],{"class":512},"    \u002F\u002F Debug mode\n",[55,683,685,688,690,693],{"class":57,"line":684},28,[55,686,687],{"class":263},"    'debug'",[55,689,522],{"class":61},[55,691,692],{"class":65}," true",[55,694,267],{"class":79},[55,696,698],{"class":57,"line":697},29,[55,699,700],{"class":79},"    ];\n",[55,702,704],{"class":57,"line":703},30,[55,705,130],{"class":79},[12,707,709],{"id":708},"wrapping-up","Wrapping up",[17,711,712],{},"Walking through it like this, honestly it's all pretty vague right now. So in the later chapters we'll gradually pair up Controller + Model operations to make the concepts stick.",[714,715,716],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":51,"searchDepth":69,"depth":69,"links":718},[719,720,721,722,723],{"id":14,"depth":69,"text":15},{"id":22,"depth":69,"text":23},{"id":143,"depth":69,"text":144},{"id":343,"depth":69,"text":344},{"id":708,"depth":69,"text":709},"PHP","2019-09-12 00:03:18","This chapter is a little shorter. It mostly covers the basics of defining a Model. In normal development you don't really tweak the Model much, so you'll notice there genuinely isn't a whole lot here. We'll walk through defining a Model, connecting to the database, and pointing a Model at a specific table.","md","en",{},"\u002Fen\u002Fphp\u002Fthink-php-day-11-model","3",{"title":6,"description":726},false,"en\u002FPHP\u002Fthink-php-day-11-model",[724,180,736,737,738],"ThinkPHP 5.1","Learning ThinkPHP from Scratch","2019 iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F","prq9PTXLmcrUvZtRXYbnTw6hqfZAW6wO8xXe5hLtQf8",{"newer":743,"older":747},{"url":744,"title":745,"date":746},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F","Learning ThinkPHP from Scratch Day 12 - Routing","2019-09-13 00:01:52",{"url":748,"title":749,"date":750},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F","Learning ThinkPHP from Scratch Day 10 - The View","2019-09-11 00:01:36",[752,757,761],{"url":753,"title":754,"date":755,"readingMinutes":756},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":758,"title":759,"date":760,"readingMinutes":731},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02",{"url":762,"title":763,"date":764,"readingMinutes":765},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01","4",1784011709392]