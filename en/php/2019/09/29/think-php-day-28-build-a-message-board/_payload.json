[{"data":1,"prerenderedAt":1299},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F":1275,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F":1284},"\u002Fphp\u002F20190929\u002F691833817\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1256,"date":1257,"description":19,"extension":1258,"lang":1259,"meta":1260,"navigation":1261,"path":1262,"readingMinutes":1263,"seo":1264,"standalone":1265,"stem":1266,"tags":1267,"tldr":1272,"updated":1257,"url":1273,"__hash__":1274},"content\u002Fen\u002FPHP\u002Fthink-php-day-28-build-a-message-board.md","Day 28 - Learning ThinkPHP from Scratch: Building a Message Board","1002795410",{"type":9,"value":10,"toc":1237},"minimark",[11,16,20,24,27,32,42,46,57,61,69,73,81,95,98,273,277,280,297,300,464,467,481,484,491,495,498,640,643,660,666,669,673,676,681,684,1014,1017,1021,1024,1028,1043,1047,1054,1057,1132,1135,1178,1181,1192,1196,1203,1209,1220,1226,1230,1233],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We've covered most of the ThinkPHP basics by now, so this post walks through building a simple message board. I won't go deep into the code though — the focus here is on planning the message board, since it's basically just combining the techniques from earlier posts. I'll drop the GitHub repo at the end as a reference.",[12,21,23],{"id":22},"message-board-features","Message board features",[17,25,26],{},"First, let's plan out what features a message board might need:",[28,29,31],"h3",{"id":30},"member-system","Member system",[33,34,35,39],"ul",{},[36,37,38],"li",{},"Register an account",[36,40,41],{},"Log in",[28,43,45],{"id":44},"message-board-login-required","Message board (login required)",[33,47,48,51,54],{},[36,49,50],{},"Add a message",[36,52,53],{},"Delete a message",[36,55,56],{},"Edit a message",[28,58,60],{"id":59},"message-board-no-login-needed","Message board (no login needed)",[33,62,63,66],{},[36,64,65],{},"Home page",[36,67,68],{},"View messages",[12,70,72],{"id":71},"members","Members",[17,74,75,76,80],{},"Here we'll reuse the database we created in earlier chapters — ",[77,78,79],"code",{},"it_think_sql"," — and add a members table inside it. The members part needs a table dedicated to storing member data, and the main columns are:",[33,82,83,86,89,92],{},[36,84,85],{},"Account (logging in with email)",[36,87,88],{},"Password",[36,90,91],{},"Name",[36,93,94],{},"Nickname",[17,96,97],{},"So based on this plan, we can write the SQL command to create the members table:",[99,100,105],"pre",{"className":101,"code":102,"language":103,"meta":104,"style":104},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_new_user (\n  id int(10) NOT NULL auto_increment,\n  email varchar(15) NOT NULL default '',\n  password varchar(32) NOT NULL default '',\n  name varchar(6) NOT NULL default '',\n  nikename varchar(6) NOT NULL default '',\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql","",[77,106,107,127,152,180,204,227,249,258],{"__ignoreMap":104},[108,109,112,116,119,123],"span",{"class":110,"line":111},"line",1,[108,113,115],{"class":114},"sWyjQ","CREATE",[108,117,118],{"class":114}," TABLE",[108,120,122],{"class":121},"sj_SG"," think_new_user",[108,124,126],{"class":125},"sMAXC"," (\n",[108,128,130,133,136,139,143,146,149],{"class":110,"line":129},2,[108,131,132],{"class":125},"  id ",[108,134,135],{"class":114},"int",[108,137,138],{"class":125},"(",[108,140,142],{"class":141},"sCcAr","10",[108,144,145],{"class":125},") ",[108,147,148],{"class":114},"NOT NULL",[108,150,151],{"class":125}," auto_increment,\n",[108,153,155,158,161,163,166,168,170,173,177],{"class":110,"line":154},3,[108,156,157],{"class":125},"  email ",[108,159,160],{"class":114},"varchar",[108,162,138],{"class":125},[108,164,165],{"class":141},"15",[108,167,145],{"class":125},[108,169,148],{"class":114},[108,171,172],{"class":114}," default",[108,174,176],{"class":175},"sTRMh"," ''",[108,178,179],{"class":125},",\n",[108,181,183,186,189,191,194,196,198,200,202],{"class":110,"line":182},4,[108,184,185],{"class":114},"  password",[108,187,188],{"class":114}," varchar",[108,190,138],{"class":125},[108,192,193],{"class":141},"32",[108,195,145],{"class":125},[108,197,148],{"class":114},[108,199,172],{"class":114},[108,201,176],{"class":175},[108,203,179],{"class":125},[108,205,207,210,212,214,217,219,221,223,225],{"class":110,"line":206},5,[108,208,209],{"class":114},"  name",[108,211,188],{"class":114},[108,213,138],{"class":125},[108,215,216],{"class":141},"6",[108,218,145],{"class":125},[108,220,148],{"class":114},[108,222,172],{"class":114},[108,224,176],{"class":175},[108,226,179],{"class":125},[108,228,230,233,235,237,239,241,243,245,247],{"class":110,"line":229},6,[108,231,232],{"class":125},"  nikename ",[108,234,160],{"class":114},[108,236,138],{"class":125},[108,238,216],{"class":141},[108,240,145],{"class":125},[108,242,148],{"class":114},[108,244,172],{"class":114},[108,246,176],{"class":175},[108,248,179],{"class":125},[108,250,252,255],{"class":110,"line":251},7,[108,253,254],{"class":114},"  PRIMARY KEY",[108,256,257],{"class":125}," (id)\n",[108,259,261,264,267,270],{"class":110,"line":260},8,[108,262,263],{"class":125},") AUTO_INCREMENT",[108,265,266],{"class":114},"=",[108,268,269],{"class":141},"1",[108,271,272],{"class":125},";\n",[12,274,276],{"id":275},"message-board","Message board",[17,278,279],{},"Next we create the message board table. A typical message board has a message title, content, and author, so the main columns are:",[33,281,282,285,288,291,294],{},[36,283,284],{},"Title",[36,286,287],{},"Content",[36,289,290],{},"Author",[36,292,293],{},"Published time",[36,295,296],{},"Last modified time",[17,298,299],{},"We can write the SQL command based on the plan above:",[99,301,303],{"className":101,"code":302,"language":103,"meta":104,"style":104},"CREATE TABLE think_message (\n  id int(10) NOT NULL auto_increment,\n  title varchar(15) NOT NULL default '',\n  content text NOT NULL default '',\n  author varchar(6) NOT NULL default '',\n  email varchar(6) NOT NULL default '',\n  create_time timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,\n  last_modify_time timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n",[77,304,305,316,332,353,370,391,411,427,446,453],{"__ignoreMap":104},[108,306,307,309,311,314],{"class":110,"line":111},[108,308,115],{"class":114},[108,310,118],{"class":114},[108,312,313],{"class":121}," think_message",[108,315,126],{"class":125},[108,317,318,320,322,324,326,328,330],{"class":110,"line":129},[108,319,132],{"class":125},[108,321,135],{"class":114},[108,323,138],{"class":125},[108,325,142],{"class":141},[108,327,145],{"class":125},[108,329,148],{"class":114},[108,331,151],{"class":125},[108,333,334,337,339,341,343,345,347,349,351],{"class":110,"line":154},[108,335,336],{"class":125},"  title ",[108,338,160],{"class":114},[108,340,138],{"class":125},[108,342,165],{"class":141},[108,344,145],{"class":125},[108,346,148],{"class":114},[108,348,172],{"class":114},[108,350,176],{"class":175},[108,352,179],{"class":125},[108,354,355,358,361,364,366,368],{"class":110,"line":182},[108,356,357],{"class":125},"  content ",[108,359,360],{"class":114},"text",[108,362,363],{"class":114}," NOT NULL",[108,365,172],{"class":114},[108,367,176],{"class":175},[108,369,179],{"class":125},[108,371,372,375,377,379,381,383,385,387,389],{"class":110,"line":206},[108,373,374],{"class":125},"  author ",[108,376,160],{"class":114},[108,378,138],{"class":125},[108,380,216],{"class":141},[108,382,145],{"class":125},[108,384,148],{"class":114},[108,386,172],{"class":114},[108,388,176],{"class":175},[108,390,179],{"class":125},[108,392,393,395,397,399,401,403,405,407,409],{"class":110,"line":229},[108,394,157],{"class":125},[108,396,160],{"class":114},[108,398,138],{"class":125},[108,400,216],{"class":141},[108,402,145],{"class":125},[108,404,148],{"class":114},[108,406,172],{"class":114},[108,408,176],{"class":175},[108,410,179],{"class":125},[108,412,413,416,419,421,424],{"class":110,"line":251},[108,414,415],{"class":125},"  create_time ",[108,417,418],{"class":114},"timestamp",[108,420,363],{"class":114},[108,422,423],{"class":114}," DEFAULT",[108,425,426],{"class":125}," CURRENT_TIMESTAMP,\n",[108,428,429,432,434,436,438,441,444],{"class":110,"line":260},[108,430,431],{"class":125},"  last_modify_time ",[108,433,418],{"class":114},[108,435,363],{"class":114},[108,437,423],{"class":114},[108,439,440],{"class":125}," CURRENT_TIMESTAMP ",[108,442,443],{"class":114},"ON UPDATE",[108,445,426],{"class":125},[108,447,449,451],{"class":110,"line":448},9,[108,450,254],{"class":114},[108,452,257],{"class":125},[108,454,456,458,460,462],{"class":110,"line":455},10,[108,457,263],{"class":125},[108,459,266],{"class":114},[108,461,269],{"class":141},[108,463,272],{"class":125},[17,465,466],{},"There are two unfamiliar things above, both about time. Let me add a quick note on what these two do:",[33,468,469,475],{},[36,470,471,474],{},[77,472,473],{},"CURRENT_TIMESTAMP"," - automatically inserts the time",[36,476,477,480],{},[77,478,479],{},"UPDATE CURRENT_TIMESTAMP"," - automatically updates if the row gets updated",[17,482,483],{},"The effect looks like this ↓",[17,485,486],{},[487,488],"img",{"alt":489,"src":490},"Auto-update timestamp","https:\u002F\u002Fi.imgur.com\u002FBXTMEIs.png",[12,492,494],{"id":493},"route-planning","Route planning",[17,496,497],{},"Next we can plan out the routes. There are mainly these:",[499,500,501,517],"table",{},[502,503,504],"thead",{},[505,506,507,511,514],"tr",{},[508,509,510],"th",{},"Feature",[508,512,513],{},"Route",[508,515,516],{},"Method",[518,519,520,532,542,553,562,572,582,592,601,611,621,630],"tbody",{},[505,521,522,526,529],{},[523,524,525],"td",{},"Login screen",[523,527,528],{},"\u002Fmessage\u002Fuser\u002Flogin",[523,530,531],{},"GET",[505,533,534,537,540],{},[523,535,536],{},"Signup screen",[523,538,539],{},"\u002Fmessage\u002Fuser\u002Fsignup",[523,541,531],{},[505,543,544,547,550],{},[523,545,546],{},"Member registration",[523,548,549],{},"\u002Fmessage\u002Fuser\u002Fcreate",[523,551,552],{},"POST",[505,554,555,558,560],{},[523,556,557],{},"Member login",[523,559,528],{},[523,561,552],{},[505,563,564,567,570],{},[523,565,566],{},"Member logout",[523,568,569],{},"\u002Fmessage\u002Fuser\u002Fsignout",[523,571,552],{},[505,573,574,577,580],{},[523,575,576],{},"Message board home",[523,578,579],{},"\u002Fmessage\u002Findex",[523,581,531],{},[505,583,584,587,590],{},[523,585,586],{},"Add message screen",[523,588,589],{},"\u002Fmessage\u002Fcreate",[523,591,531],{},[505,593,594,597,599],{},[523,595,596],{},"Add message",[523,598,589],{},[523,600,552],{},[505,602,603,606,609],{},[523,604,605],{},"View message",[523,607,608],{},"\u002Fmessage\u002Fcontent\u002F:id",[523,610,531],{},[505,612,613,616,619],{},[523,614,615],{},"Show edit message",[523,617,618],{},"\u002Fmessage\u002Fedit\u002F:id",[523,620,531],{},[505,622,623,626,628],{},[523,624,625],{},"Edit message",[523,627,618],{},[523,629,552],{},[505,631,632,635,638],{},[523,633,634],{},"Delete message",[523,636,637],{},"\u002Fmessage\u002Fdelete\u002F:id",[523,639,552],{},[12,641,642],{"id":642},"application",[17,644,645,646,649,650,652,653,656,657,659],{},"Next we'll create a ",[77,647,648],{},"message"," folder under ",[77,651,642],{},". Here let's try something new — generating a Controller with a command. Open CMD, move into the project directory, and try typing ",[77,654,655],{},"php think make:controller message\u002FIndex",". You should find it created under ",[77,658,642],{}," ↓",[17,661,662],{},[487,663],{"alt":664,"src":665},"Generated controller","https:\u002F\u002Fi.imgur.com\u002Fr4G0YOu.png",[17,667,668],{},"Of course you can also create it manually if you want, to avoid a pile of default code.",[12,670,672],{"id":671},"file-structure","File structure",[17,674,675],{},"So the file structure of the message board ends up looking like this ↓",[17,677,678],{},[487,679],{"alt":672,"src":680},"https:\u002F\u002Fi.imgur.com\u002F6uI4x1q.png",[17,682,683],{},"I won't provide the actual contents — there's just too much of it, and honestly it's pretty similar to the earlier chapters, just combining techniques. Except for the routes, which I'll provide here:",[99,685,689],{"className":686,"code":687,"language":688,"meta":104,"style":104},"language-php shiki shiki-themes github-dark-high-contrast","\u002F\u002F 留言板功能\n\u002F\u002F 會員相關\n\u002F\u002F 登入畫面\nRoute::get('\u002Fmessage\u002Fuser\u002Flogin', 'message\u002Fuser\u002Findex');\n\u002F\u002F 註冊畫面\nRoute::get('\u002Fmessage\u002Fuser\u002Fsignup', 'message\u002Fuser\u002Fsignup');\n\u002F\u002F 會員註冊\nRoute::post('\u002Fmessage\u002Fuser\u002Fcreate', 'message\u002Fuser\u002Fsave');\n\u002F\u002F 會員登入\nRoute::get('\u002Fmessage\u002Fuser\u002Flogin', 'message\u002Fuser\u002Flogin');\n\u002F\u002F 會員登出\nRoute::get('\u002Fmessage\u002Fuser\u002Fsignout', 'message\u002Fuser\u002Fsignout');\n\u002F\u002F 留言版相關\n\u002F\u002F 留言版首頁\nRoute::get('\u002Fmessage\u002Findex', 'message\u002Findex\u002Findex');\n\u002F\u002F 新增留言\nRoute::get('\u002Fmessage\u002Fcreate', 'message\u002Findex\u002Fcreate');\nRoute::post('\u002Fmessage\u002Fcreate', 'message\u002Findex\u002Fsave');\n\u002F\u002F 查看留言\nRoute::get('\u002Fmessage\u002Fcontent\u002F:id', 'message\u002Findex\u002Fpost');\n\u002F\u002F 編輯留言\nRoute::get('\u002Fmessage\u002Fedit\u002F:id', 'message\u002Findex\u002Fread');\nRoute::post('\u002Fmessage\u002Fedit\u0