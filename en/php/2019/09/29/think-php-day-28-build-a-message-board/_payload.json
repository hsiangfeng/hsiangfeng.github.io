:1026},"using-disabled-on-an-input","Using disabled on an input",[17,1029,1030,1031,1034,1035,1038,1039,1042],{},"If an ",[77,1032,1033],{},"input"," field uses ",[77,1036,1037],{},"disabled",", the backend can't get the field's value. So here I'd suggest using ",[77,1040,1041],{},"readonly"," instead — then you can read the value just fine.",[28,1044,1046],{"id":1045},"how-to-use-model-update","How to use model update",[17,1048,1049,1050,1053],{},"Since I didn't cover ",[77,1051,1052],{},"update"," in the Model series — there are quite a few ways to do an update — let me briefly mention the two main approaches:",[17,1055,1056],{},"First approach:",[99,1058,1060],{"className":686,"code":1059,"language":688,"meta":104,"style":104},"$content = indexModel::where('id', '=', $id)->select();\n$contentData = input();\n$content[0]->update($contentData); \u002F\u002F Note: querying with the constructor returns an array.\n",[77,1061,1062,1099,1111],{"__ignoreMap":104},[108,1063,1064,1067,1069,1072,1074,1077,1079,1082,1084,1087,1090,1093,1096],{"class":110,"line":111},[108,1065,1066],{"class":125},"$content ",[108,1068,266],{"class":114},[108,1070,1071],{"class":141}," indexModel",[108,1073,713],{"class":114},[108,1075,1076],{"class":121},"where",[108,1078,138],{"class":125},[108,1080,1081],{"class":175},"'id'",[108,1083,724],{"class":125},[108,1085,1086],{"class":175},"'='",[108,1088,1089],{"class":125},", $id)",[108,1091,1092],{"class":114},"->",[108,1094,1095],{"class":121},"select",[108,1097,1098],{"class":125},"();\n",[108,1100,1101,1104,1106,1109],{"class":110,"line":129},[108,1102,1103],{"class":125},"$contentData ",[108,1105,266],{"class":114},[108,1107,1108],{"class":121}," input",[108,1110,1098],{"class":125},[108,1112,1113,1116,1119,1122,1124,1126,1129],{"class":110,"line":154},[108,1114,1115],{"class":125},"$content[",[108,1117,1118],{"class":141},"0",[108,1120,1121],{"class":125},"]",[108,1123,1092],{"class":114},[108,1125,1052],{"class":121},[108,1127,1128],{"class":125},"($contentData); ",[108,1130,1131],{"class":695},"\u002F\u002F Note: querying with the constructor returns an array.\n",[17,1133,1134],{},"Second approach:",[99,1136,1138],{"className":686,"code":1137,"language":688,"meta":104,"style":104},"$content = indexModel::get($id);\n$contentData = input();\n$content->save($contentData);\n",[77,1139,1140,1155,1165],{"__ignoreMap":104},[108,1141,1142,1144,1146,1148,1150,1152],{"class":110,"line":111},[108,1143,1066],{"class":125},[108,1145,266],{"class":114},[108,1147,1071],{"class":141},[108,1149,713],{"class":114},[108,1151,716],{"class":121},[108,1153,1154],{"class":125},"($id);\n",[108,1156,1157,1159,1161,1163],{"class":110,"line":129},[108,1158,1103],{"class":125},[108,1160,266],{"class":114},[108,1162,1108],{"class":121},[108,1164,1098],{"class":125},[108,1166,1167,1170,1172,1175],{"class":110,"line":154},[108,1168,1169],{"class":125},"$content",[108,1171,1092],{"class":114},[108,1173,1174],{"class":121},"save",[108,1176,1177],{"class":125},"($contentData);\n",[17,1179,1180],{},"There are actually quite a few more ways to update, but personally I'm more used to the first one, because if you also write SQL commands it feels pretty intuitive.",[17,1182,1183,1184,1191],{},"For more detail, check the ",[1185,1186,1190],"a",{"href":1187,"rel":1188},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5\u002F135189",[1189],"nofollow","official manual",".",[28,1193,1195],{"id":1194},"outputting-html-tags-to-the-template","Outputting HTML tags to the template",[17,1197,1198,1199,1202],{},"Normally, if you just use ",[77,1200,1201],{},"{$content}",", you might run into the awkward situation where even the HTML tags get output ↓",[17,1204,1205],{},[487,1206],{"alt":1207,"src":1208},"HTML tags output directly","https:\u002F\u002Fi.imgur.com\u002FLDRDlsy.png",[17,1210,1211,1212,1215,1216,1219],{},"To fix this, you just add ",[77,1213,1214],{},"raw",", so you should write it like ",[77,1217,1218],{},"{$content|raw}"," — that way ThinkPHP successfully converts the HTML ↓",[17,1221,1222],{},[487,1223],{"alt":1224,"src":1225},"Rendered successfully","https:\u002F\u002Fi.imgur.com\u002Fz3w9Dcq.png",[12,1227,1229],{"id":1228},"wrap-up","Wrap-up",[17,1231,1232],{},"The plan from the start was never meant to be super detailed, so consider it a little challenge left for you (?)\n\n",[1234,1235,1236],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":104,"searchDepth":129,"depth":129,"links":1238},[1239,1240,1245,1246,1247,1248,1249,1250,1255],{"id":14,"depth":129,"text":15},{"id":22,"depth":129,"text":23,"children":1241},[1242,1243,1244],{"id":30,"depth":154,"text":31},{"id":44,"depth":154,"text":45},{"id":59,"depth":154,"text":60},{"id":71,"depth":129,"text":72},{"id":275,"depth":129,"text":276},{"id":493,"depth":129,"text":494},{"id":642,"depth":129,"text":642},{"id":671,"depth":129,"text":672},{"id":1019,"depth":129,"text":1020,"children":1251},[1252,1253,1254],{"id":1026,"depth":154,"text":1027},{"id":1045,"depth":154,"text":1046},{"id":1194,"depth":154,"text":1195},{"id":1228,"depth":129,"text":1229},"PHP","2019-0