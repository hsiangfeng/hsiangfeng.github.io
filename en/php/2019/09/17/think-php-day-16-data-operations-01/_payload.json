[{"data":1,"prerenderedAt":1156},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F":1132,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F17\u002Fthink-php-day-16-data-operations-01\u002F":1141},"\u002Fphp\u002F20190917\u002F3037813271\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1113,"date":1114,"description":1115,"extension":1116,"lang":1117,"meta":1118,"navigation":101,"path":1119,"readingMinutes":1120,"seo":1121,"standalone":1122,"stem":1123,"tags":1124,"tldr":1129,"updated":1114,"url":1130,"__hash__":1131},"content\u002Fen\u002FPHP\u002Fthink-php-day-16-data-operations-01.md","ThinkPHP Day 16 - Talking to the DB Without a Model","1002692463",{"type":9,"value":10,"toc":1099},"minimark",[11,16,20,24,27,54,61,68,71,187,191,198,290,308,313,320,374,381,385,429,433,440,481,485,525,529,532,779,783,790,877,880,888,891,897,901,911,968,979,1085,1088,1092,1095],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"When you hit this post you're probably a little confused about why we're suddenly jumping from basic Model operations over to raw data operations. The main reason is that I want you to see something: you can actually work with your data using native SQL too, without going through a Model at all. So let's take a look at how that works.",[12,21,23],{"id":22},"getting-started","Getting started",[17,25,26],{},"First off, if we want to work with the DB inside a Controller, we have to pull in the library ThinkPHP gives us — otherwise there's no way to touch the DB:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-php shiki shiki-themes github-dark-high-contrast","use think\\Db;\n","php","",[35,36,37],"code",{"__ignoreMap":33},[38,39,42,46,50],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","use",[38,47,49],{"class":48},"sCcAr"," think\\Db",[38,51,53],{"class":52},"sMAXC",";\n",[17,55,56,57,60],{},"To avoid mixing things up (and because I personally like to keep every piece of code I write), I created a separate folder called ",[35,58,59],{},"dbexample"," with the related files in it. I won't dump the full contents here ↓",[17,62,63],{},[64,65],"img",{"alt":66,"src":67},"Folder structure","https:\u002F\u002Fi.imgur.com\u002FSXsSo3p.png",[17,69,70],{},"The starting content of the main Controller looks like this:",[28,72,74],{"className":30,"code":73,"language":32,"meta":33,"style":33},"\u003C?php\nnamespace app\\dbexample\\controller;\n\nuse think\\Controller;\n\nuse think\\Db;\n\nclass Index extends Controller\n{\n    public function index()\n    {\n    }\n}\n",[35,75,76,84,96,103,113,118,127,132,147,153,169,175,181],{"__ignoreMap":33},[38,77,78,81],{"class":40,"line":41},[38,79,80],{"class":44},"\u003C?",[38,82,83],{"class":48},"php\n",[38,85,87,90,94],{"class":40,"line":86},2,[38,88,89],{"class":44},"namespace",[38,91,93],{"class":92},"s_sBn"," app\\dbexample\\controller",[38,95,53],{"class":52},[38,97,99],{"class":40,"line":98},3,[38,100,102],{"emptyLinePlaceholder":101},true,"\n",[38,104,106,108,111],{"class":40,"line":105},4,[38,107,45],{"class":44},[38,109,110],{"class":48}," think\\Controller",[38,112,53],{"class":52},[38,114,116],{"class":40,"line":115},5,[38,117,102],{"emptyLinePlaceholder":101},[38,119,121,123,125],{"class":40,"line":120},6,[38,122,45],{"class":44},[38,124,49],{"class":48},[38,126,53],{"class":52},[38,128,130],{"class":40,"line":129},7,[38,131,102],{"emptyLinePlaceholder":101},[38,133,135,138,141,144],{"class":40,"line":134},8,[38,136,137],{"class":44},"class",[38,139,140],{"class":92}," Index",[38,142,143],{"class":44}," extends",[38,145,146],{"class":48}," Controller\n",[38,148,150],{"class":40,"line":149},9,[38,151,152],{"class":52},"{\n",[38,154,156,159,162,166],{"class":40,"line":155},10,[38,157,158],{"class":44},"    public",[38,160,161],{"class":44}," function",[38,163,165],{"class":164},"sj_SG"," index",[38,167,168],{"class":52},"()\n",[38,170,172],{"class":40,"line":171},11,[38,173,174],{"class":52},"    {\n",[38,176,178],{"class":40,"line":177},12,[38,179,180],{"class":52},"    }\n",[38,182,184],{"class":40,"line":183},13,[38,185,186],{"class":52},"}\n",[12,188,190],{"id":189},"raw-sql","Raw SQL",[17,192,193,194,197],{},"We've covered raw SQL syntax earlier, so let's start by creating a table called ",[35,195,196],{},"think_db",":",[28,199,203],{"className":200,"code":201,"language":202,"meta":33,"style":33},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_db (\n  id int(10) NOT NULL auto_increment,\n  name varchar(5) NOT NULL default '',\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql",[35,204,205,219,242,269,277],{"__ignoreMap":33},[38,206,207,210,213,216],{"class":40,"line":41},[38,208,209],{"class":44},"CREATE",[38,211,212],{"class":44}," TABLE",[38,214,215],{"class":164}," think_db",[38,217,218],{"class":52}," (\n",[38,220,221,224,227,230,233,236,239],{"class":40,"line":86},[38,222,223],{"class":52},"  id ",[38,225,226],{"class":44},"int",[38,228,229],{"class":52},"(",[38,231,232],{"class":48},"10",[38,234,235],{"class":52},") ",[38,237,238],{"class":44},"NOT NULL",[38,240,241],{"class":52}," auto_increment,\n",[38,243,244,247,250,252,255,257,259,262,266],{"class":40,"line":98},[38,245,246],{"class":44},"  name",[38,248,249],{"class":44}," varchar",[38,251,229],{"class":52},[38,253,254],{"class":48},"5",[38,256,235],{"class":52},[38,258,238],{"class":44},[38,260,261],{"class":44}," default",[38,263,265],{"class":264},"sTRMh"," ''",[38,267,268],{"class":52},",\n",[38,270,271,274],{"class":40,"line":105},[38,272,273],{"class":44},"  PRIMARY KEY",[38,275,276],{"class":52}," (id)\n",[38,278,279,282,285,288],{"class":40,"line":115},[38,280,281],{"class":52},") AUTO_INCREMENT",[38,283,284],{"class":44},"=",[38,286,287],{"class":48},"1",[38,289,53],{"class":52},[17,291,292,293,296,297,300,301,304,305,307],{},"Now we can start writing native SQL inside the Controller — the usual create, read, update, delete stuff. One thing to watch out for: we'll write our raw SQL through the ",[35,294,295],{},"Db"," library we just imported. The base method is ",[35,298,299],{},"Db::execute",", and the only exception is queries, which use ",[35,302,303],{},"Db::query",". Everything else goes through ",[35,306,299],{},".",[309,310,312],"h3",{"id":311},"inserting-data","Inserting data",[17,314,315,316,319],{},"The way to do it is pretty simple — you just drop your SQL statement inside ",[35,317,318],{},"Db::execute('SQL statement')"," and you're done. Here's an example of inserting a row:",[28,321,323],{"className":30,"code":322,"language":32,"meta":33,"style":33},"$result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\ndump($result);\n",[35,324,325,366],{"__ignoreMap":33},[38,326,327,330,332,335,338,341,343,346,349,352,355,357,360,363],{"class":40,"line":41},[38,328,329],{"class":52},"$result ",[38,331,284],{"class":44},[38,333,334],{"class":48}," Db",[38,336,337],{"class":44},"::",[38,339,340],{"class":164},"execute",[38,342,229],{"class":52},[38,344,345],{"class":264},"'",[38,347,348],{"class":44},"INSERT INTO",[38,350,351],{"class":264}," think_db (",[38,353,354],{"class":44},"name",[38,356,235],{"class":264},[38,358,359],{"class":44},"VALUE",[38,361,362],{"class":264}," (\"王大明\")'",[38,364,365],{"class":52},");\n",[38,367,368,371],{"class":40,"line":86},[38,369,370],{"class":164},"dump",[38,372,373],{"class":52},"($result);\n",[17,375,376,377,380],{},"One thing you absolutely have to remember: add ",[35,378,379],{},"dump()"," after the statement, otherwise your SQL won't actually run.",[309,382,384],{"id":383},"updating-data","Updating data",[28,386,388],{"className":30,"code":387,"language":32,"meta":33,"style":33},"$result = Db::execute('UPDATE think_db SET name=\"QQ 先生\"');\ndump($result);\n",[35,389,390,423],{"__ignoreMap":33},[38,391,392,394,396,398,400,402,404,406,409,412,415,418,421],{"class":40,"line":41},[38,393,329],{"class":52},[38,395,284],{"class":44},[38,397,334],{"class":48},[38,399,337],{"class":44},[38,401,340],{"class":164},[38,403,229],{"class":52},[38,405,345],{"class":264},[38,407,408],{"class":44},"UPDATE",[38,410,411],{"class":264}," think_db ",[38,413,414],{"class":44},"SET",[38,416,417],{"class":44}," name=",[38,419,420],{"class":264},"\"QQ 先生\"'",[38,422,365],{"class":52},[38,424,425,427],{"class":40,"line":86},[38,426,370],{"class":164},[38,428,373],{"class":52},[309,430,432],{"id":431},"querying-data","Querying data",[17,434,435,436,439],{},"Like I mentioned, queries are the one case that uses ",[35,437,438],{},"Db::query()",", so keep that in mind when you write it:",[28,441,443],{"className":30,"code":442,"language":32,"meta":33,"style":33},"$result = Db::query('SELECT think_db SET name=\"QQ 先生\"');\ndump($result);\n",[35,444,445,475],{"__ignoreMap":33},[38,446,447,449,451,453,455,458,460,462,465,467,469,471,473],{"class":40,"line":41},[38,448,329],{"class":52},[38,450,284],{"class":44},[38,452,334],{"class":48},[38,454,337],{"class":44},[38,456,457],{"class":164},"query",[38,459,229],{"class":52},[38,461,345],{"class":264},[38,463,464],{"class":44},"SELECT",[38,466,411],{"class":264},[38,468,414],{"class":44},[38,470,417],{"class":44},[38,472,420],{"class":264},[38,474,365],{"class":52},[38,476,477,479],{"class":40,"line":86},[38,478,370],{"class":164},[38,480,373],{"class":52},[309,482,484],{"id":483},"deleting-data","Deleting data",[28,486,488],{"className":30,"code":487,"language":32,"meta":33,"style":33},"$result = Db::query('DELETE think_db SET name=\"QQ 先生\"');\ndump($result);\n",[35,489,490,519],{"__ignoreMap":33},[38,491,492,494,496,498,500,502,504,506,509,511,513,515,517],{"class":40,"line":41},[38,493,329],{"class":52},[38,495,284],{"class":44},[38,497,334],{"class":48},[38,499,337],{"class":44},[38,501,457],{"class":164},[38,503,229],{"class":52},[38,505,345],{"class":264},[38,507,508],{"class":44},"DELETE",[38,510,411],{"class":264},[38,512,414],{"class":44},[38,514,417],{"class":44},[38,516,420],{"class":264},[38,518,365],{"class":52},[38,520,521,523],{"class":40,"line":86},[38,522,370],{"class":164},[38,524,373],{"class":52},[309,526,528],{"id":527},"the-full-code","The full code",[17,530,531],{},"Now we can wrap each of those insert, update, query, and delete statements into its own function, then hit the Controller through routes to run them:",[28,533,535],{"className":30,"code":534,"language":32,"meta":33,"style":33},"public function add() \n{\n  $result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\n  dump($result);\n}\npublic function update() \n{\n  $result = Db::execute('UPDATE think_db SET name=\"QQ 先生\" WHERE name=\"王大明\"');\n  dump($result);\n}\npublic function select() \n{\n  $result = Db::query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\n  dump($result);\n}\npublic function delete() \n{\n  $result = Db::execute('DELETE FROM think_db WHERE name=\"QQ 先生\"');\n  dump($result);\n}\n",[35,536,537,550,554,585,592,596,607,611,648,654,658,669,673,707,714,719,731,736,767,774],{"__ignoreMap":33},[38,538,539,542,544,547],{"class":40,"line":41},[38,540,541],{"class":44},"public",[38,543,161],{"class":44},[38,545,546],{"class":164}," add",[38,548,549],{"class":52},"() \n",[38,551,552],{"class":40,"line":86},[38,553,152],{"class":52},[38,555,556,559,561,563,565,567,569,571,573,575,577,579,581,583],{"class":40,"line":98},[38,557,558],{"class":52},"  $result ",[38,560,284],{"class":44},[38,562,334],{"class":48},[38,564,337],{"class":44},[38,566,340],{"class":164},[38,568,229],{"class":52},[38,570,345],{"class":264},[38,572,348],{"class":44},[38,574,351],{"class":264},[38,576,354],{"class":44},[38,578,235],{"class":264},[38,580,359],{"class":44},[38,582,362],{"class":264},[38,584,365],{"class":52},[38,586,587,590],{"class":40,"line":105},[38,588,589],{"class":164},"  dump",[38,591,373],{"class":52},[38,593,594],{"class":40,"line":115},[38,595,186],{"class":52},[38,597,598,600,602,605],{"class":40,"line":120},[38,599,541],{"class":44},[38,601,161],{"class":44},[38,603,604],{"class":164}," update",[38,606,549],{"class":52},[38,608,609],{"class":40,"line":129},[38,610,152],{"class":52},[38,612,613,615,617,619,621,623,625,627,629,631,633,635,638,641,643,646],{"class":40,"line":134},[38,614,558],{"class":52},[38,616,284],{"class":44},[38,618,334],{"class":48},[38,620,337],{"class":44},[38,622,340],{"class":164},[38,624,229],{"class":52},[38,626,345],{"class":264},[38,628,408],{"class":44},[38,630,411],{"class":264},[38,632,414],{"class":44},[38,634,417],{"class":44},[38,636,637],{"class":264},"\"QQ 先生\" ",[38,639,640],{"class":44},"WHERE",[38,642,417],{"class":44},[38,644,645],{"class":264},"\"王大明\"'",[38,647,365],{"class":52},[38,649,650,652],{"class":40,"line":149},[38,651,589],{"class":164},[38,653,373],{"class":52},[38,655,656],{"class":40,"line":155},[38,657,186],{"class":52},[38,659,660,662,664,667],{"class":40,"line":171},[38,661,541],{"class":44},[38,663,161],{"class":44},[38,665,666],{"class":164}," select",[38,668,549],{"class":52},[38,670,671],{"class":40,"line":177},[38,672,152],{"class":52},[38,674,675,677,679,681,683,685,687,689,691,694,697,699,701,703,705],{"class":40,"line":183},[38,676,558],{"class":52},[38,678,284],{"class":44},[38,680,334],{"class":48},[38,682,337],{"class":44},[38,684,457],{"class":164},[38,686,229],{"class":52},[38,688,345],{"class":264},[38,690,464],{"class":44},[38,692,693],{"class":44}," *",[38,695,696],{"class":44}," FROM",[38,698,411],{"class":264},[38,700,640],{"class":44},[38,702,417],{"class":44},[38,704,420],{"class":264},[38,706,365],{"class":52},[38,708,710,712],{"class":40,"line":709},14,[38,711,589],{"class":164},[38,713,373],{"class":52},[38,715,717],{"class":40,"line":716},15,[38,718,186],{"class":52},[38,720,722,724,726,729],{"class":40,"line":721},16,[38,723,541],{"class":44},[38,725,161],{"class":44},[38,727,728],{"class":164}," delete",[38,730,549],{"class":52},[38,732,734],{"class":40,"line":733},17,[38,735,152],{"class":52},[38,737,739,741,743,745,747,749,751,753,755,757,759,761,763,765],{"class":40,"line":738},18,[38,740,558],{"class":52},[38,742,284],{"class":44},[38,744,334],{"class":48},[38,746,337],{"class":44},[38,748,340],{"class":164},[38,750,229],{"class":52},[38,752,345],{"class":264},[38,754,508],{"class":44},[38,756,696],{"class":44},[38,758,411],{"class":264},[38,760,640],{"class":44},[38,762,417],{"class":44},[38,764,420],{"class":264},[38,766,365],{"class":52},[38,768,770,772],{"class":40,"line":769},19,[38,771,589],{"class":164},[38,773,373],{"class":52},[38,775,777],{"class":40,"line":776},20,[38,778,186],{"class":52},[309,780,782],{"id":781},"routes","Routes",[17,784,785,786,789],{},"There's not much to say about registering the routes — since this is just a demo, I'm using ",[35,787,788],{},"get"," the whole way through:",[28,791,793],{"className":30,"code":792,"language":32,"meta":33,"style":33},"Route::get('\u002Fdbexample\u002Fadd', 'dbexample\u002Findex\u002Fadd');\nRoute::get('\u002Fdbexample\u002Fupdate', 'dbexample\u002Findex\u002Fupdate');\nRoute::get('\u002Fdbexample\u002Fselect', 'dbexample\u002Findex\u002Fselect');\nRoute::get('\u002Fdbexample\u002Fdelete', 'dbexample\u002Findex\u002Fdelete');\n",[35,794,795,817,837,857],{"__ignoreMap":33},[38,796,797,800,802,804,806,809,812,815],{"class":40,"line":41},[38,798,799],{"class":48},"Route",[38,801,337],{"class":44},[38,803,788],{"class":164},[38,805,229],{"class":52},[38,807,808],{"class":264},"'\u002Fdbexample\u002Fadd'",[38,810,811],{"class":52},", ",[38,813,814],{"class":264},"'dbexample\u002Findex\u002Fadd'",[38,816,365],{"class":52},[38,818,819,821,823,825,827,830,832,835],{"class":40,"line":86},[38,820,799],{"class":48},[38,822,337],{"class":44},[38,824,788],{"class":164},[38,826,229],{"class":52},[38,828,829],{"class":264},"'\u002Fdbexample\u002Fupdate'",[38,831,811],{"class":52},[38,833,834],{"class":264},"'dbexample\u002Findex\u002Fupdate'",[38,836,365],{"class":52},[38,838,839,841,843,845,847,850,852,855],{"class":40,"line":98},[38,840,799],{"class":48},[38,842,337],{"class":44},[38,844,788],{"class":164},[38,846,229],{"class":52},[38,848,849],{"class":264},"'\u002Fdbexample\u002Fselect'",[38,851,811],{"class":52},[38,853,854],{"class":264},"'dbexample\u002Findex\u002Fselect'",[38,856,365],{"class":52},[38,858,859,861,863,865,867,870,872,875],{"class":40,"line":105},[38,860,799],{"class":48},[38,862,337],{"class":44},[38,864,788],{"class":164},[38,866,229],{"class":52},[38,868,869],{"class":264},"'\u002Fdbexample\u002Fdelete'",[38,871,811],{"class":52},[38,873,874],{"class":264},"'dbexample\u002Findex\u002Fdelete'",[38,876,365],{"class":52},[17,878,879],{},"I'd suggest visiting the URLs in the order below to avoid running into \"can't access\" errors.",[28,881,886],{"className":882,"code":884,"language":885,"meta":33},[883],"language-text","Suggested order: add → update → select → delete (otherwise you might hit an error)\n","text",[35,887,884],{"__ignoreMap":33},[17,889,890],{},"Here I'll just show the query result ↓",[17,892,893],{},[64,894],{"alt":895,"src":896},"A query through the query method returns an array","https:\u002F\u002Fi.imgur.com\u002FcGE4Bss.png",[12,898,900],{"id":899},"switching-database-connections","Switching database connections",[17,902,903,904,906,907,910],{},"You can also switch your database connection through one of ",[35,905,295],{},"'s methods, namely ",[35,908,909],{},"Db::connect([database connection])",". Here's an example:",[28,912,914],{"className":30,"code":913,"language":32,"meta":33,"style":33},"$result = Db::connect('mysql:\u002F\u002Froot:123456@localhost:3306\u002Fithelp')->query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result);\n",[35,915,916,962],{"__ignoreMap":33},[38,917,918,920,922,924,926,929,931,934,937,940,942,944,946,948,950,952,954,956,958,960],{"class":40,"line":41},[38,919,329],{"class":52},[38,921,284],{"class":44},[38,923,334],{"class":48},[38,925,337],{"class":44},[38,927,928],{"class":164},"connect",[38,930,229],{"class":52},[38,932,933],{"class":264},"'mysql:\u002F\u002Froot:123456@localhost:3306\u002Fithelp'",[38,935,936],{"class":52},")",[38,938,939],{"class":44},"->",[38,941,457],{"class":164},[38,943,229],{"class":52},[38,945,345],{"class":264},[38,947,464],{"class":44},[38,949,693],{"class":44},[38,951,696],{"class":44},[38,953,411],{"class":264},[38,955,640],{"class":44},[38,957,417],{"class":44},[38,959,420],{"class":264},[38,961,365],{"class":52},[38,963,964,966],{"class":40,"line":86},[38,965,370],{"class":164},[38,967,373],{"class":52},[17,969,970,971,974,975,978],{},"That said, this approach isn't great — it mainly makes your code messy and hard to maintain. So normally we add a file called config.php under ",[35,972,973],{},"application",", use the database.php content under ",[35,976,977],{},"project\u002Fconfig"," as a template, turn it into an array, and pass in the relevant parameters like this:",[28,980,982],{"className":30,"code":981,"language":32,"meta":33,"style":33},"$result1 = Db::connect('qq1')->query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result2);\n$result2 = Db::connect('qq2')->query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result2);\n",[35,983,984,1028,1035,1079],{"__ignoreMap":33},[38,985,986,989,991,993,995,997,999,1002,1004,1006,1008,1010,1012,1014,1016,1018,1020,1022,1024,1026],{"class":40,"line":41},[38,987,988],{"class":52},"$result1 ",[38,990,284],{"class":44},[38,992,334],{"class":48},[38,994,337],{"class":44},[38,996,928],{"class":164},[38,998,229],{"class":52},[38,1000,1001],{"class":264},"'qq1'",[38,1003,936],{"class":52},[38,1005,939],{"class":44},[38,1007,457],{"class":164},[38,1009,229],{"class":52},[38,1011,345],{"class":264},[38,1013,464],{"class":44},[38,1015,693],{"class":44},[38,1017,696],{"class":44},[38,1019,411],{"class":264},[38,1021,640],{"class":44},[38,1023,417],{"class":44},[38,1025,420],{"class":264},[38,1027,365],{"class":52},[38,1029,1030,1032],{"class":40,"line":86},[38,1031,370],{"class":164},[38,1033,1034],{"class":52},"($result2);\n",[38,1036,1037,1040,1042,1044,1046,1048,1050,1053,1055,1057,1059,1061,1063,1065,1067,1069,1071,1073,1075,1077],{"class":40,"line":98},[38,1038,1039],{"class":52},"$result2 ",[38,1041,284],{"class":44},[38,1043,334],{"class":48},[38,1045,337],{"class":44},[38,1047,928],{"class":164},[38,1049,229],{"class":52},[38,1051,1052],{"class":264},"'qq2'",[38,1054,936],{"class":52},[38,1056,939],{"class":44},[38,1058,457],{"class":164},[38,1060,229],{"class":52},[38,1062,345],{"class":264},[38,1064,464],{"class":44},[38,1066,693],{"class":44},[38,1068,696],{"class":44},[38,1070,411],{"class":264},[38,1072,640],{"class":44},[38,1074,417],{"class":44},[38,1076,420],{"class":264},[38,1078,365],{"class":52},[38,1080,1081,1083],{"class":40,"line":105},[38,1082,370],{"class":164},[38,1084,1034],{"class":52},[17,1086,1087],{},"So that's how you switch database connections. I won't actually demo the example above though, because honestly I've never used this in real development, and it's a situation I rarely run into.",[12,1089,1091],{"id":1090},"wrapping-up","Wrapping up",[17,1093,1094],{},"So we can see that working with data without going through a Model is a real pain, and these actions don't really fit the MVC mindset either — after all, we never split the Model's logic out. So as your system grows bigger and bigger, it ends up being a headache to maintain.",[1096,1097,1098],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sMAXC, html 