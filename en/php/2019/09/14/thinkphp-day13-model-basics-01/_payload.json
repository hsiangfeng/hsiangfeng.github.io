ss":130},[45,605,472],{"class":108},[45,607,127],{"class":69},[45,609,577],{"class":130},[45,611,249],{"class":69},[45,613,615,617,619],{"class":47,"line":614},23,[45,616,484],{"class":69},[45,618,421],{"class":242},[45,620,249],{"class":69},[45,622,624,626,628,630,632,635,638,640,643],{"class":47,"line":623},24,[45,625,418],{"class":69},[45,627,455],{"class":242},[45,629,458],{"class":108},[45,631,127],{"class":69},[45,633,634],{"class":130},"\"submit\"",[45,636,637],{"class":108}," value",[45,639,127],{"class":69},[45,641,642],{"class":130},"\"Submit\"",[45,644,249],{"class":69},[45,646,648,651,653],{"class":47,"line":647},25,[45,649,650],{"class":69},"  \u003C\u002F",[45,652,394],{"class":242},[45,654,249],{"class":69},[45,656,658,660,662],{"class":47,"line":657},26,[45,659,359],{"class":69},[45,661,370],{"class":242},[45,663,249],{"class":69},[45,665,667,669,671],{"class":47,"line":666},27,[45,668,359],{"class":69},[45,670,232],{"class":242},[45,672,249],{"class":69},[12,674,676],{"id":675},"the-controller","The Controller",[17,678,679],{},"Now we'll add two Controller methods. One is dedicated to displaying the form, and the other handles receiving the form data.",[17,681,682],{},"First, the method that shows the form page — and tells ThinkPHP which HTML file we want to render:",[36,684,686],{"className":38,"code":685,"language":40,"meta":41,"style":41},"public function user () {\n  $title = '新增資料';\n\n  $this->assign('title',$title);\n  return $this -> fetch('index');\n}\n",[31,687,688,702,714,718,737,758],{"__ignoreMap":41},[45,689,690,693,696,699],{"class":47,"line":48},[45,691,692],{"class":51},"public",[45,694,695],{"class":51}," function",[45,697,698],{"class":177}," user",[45,700,701],{"class":69}," () {\n",[45,703,704,707,709,712],{"class":47,"line":59},[45,705,706],{"class":69},"  $title ",[45,708,127],{"class":51},[45,710,711],{"class":130}," '新增資料'",[45,713,70],{"class":69},[45,715,716],{"class":47,"line":73},[45,717,77],{"emptyLinePlaceholder":76},[45,719,720,723,726,729,731,734],{"class":47,"line":80},[45,721,722],{"class":55},"  $this",[45,724,725],{"class":51},"->",[45,727,728],{"class":177},"assign",[45,730,180],{"class":69},[45,732,733],{"class":130},"'title'",[45,735,736],{"class":69},",$title);\n",[45,738,739,742,745,748,751,753,756],{"class":47,"line":91},[45,740,741],{"class":51},"  return",[45,743,744],{"class":55}," $this",[45,746,747],{"class":51}," ->",[45,749,750],{"class":177}," fetch",[45,752,180],{"class":69},[45,754,755],{"class":130},"'index'",[45,757,192],{"class":69},[45,759,760],{"class":47,"line":96},[45,761,139],{"class":69},[17,763,764,765,768],{},"ThinkPHP's ",[31,766,767],{},"assign()"," method lets us pass variable data into the form view. Now we can fire up the browser and check it out. ↓",[17,770,771],{},[772,773],"img",{"alt":774,"src":775},"The form rendered in the browser","https:\u002F\u002Fi.imgur.com\u002FVeyFx0d.png",[17,777,778],{},"With the page done, it's time to build the method that receives the data. Let's start with a quick bit of test code — I'll walk through it right after:",[36,780,782],{"className":38,"code":781,"language":40,"meta":41,"style":41},"public function create ($name, $height, $weight) {\n    return '姓名：'.$name.'\u003Cbr\u002F>'.'身高：'.$height.'\u003Cbr\u002F>'.'體重：'.$weight;\n}\n",[31,783,784,796,839],{"__ignoreMap":41},[45,785,786,788,790,793],{"class":47,"line":48},[45,787,692],{"class":51},[45,789,695],{"class":51},[45,791,792],{"class":177}," create",[45,794,795],{"class":69}," ($name, $height, $weight) {\n",[45,797,798,801,804,807,810,812,815,817,820,822,825,827,829,831,834,836],{"class":47,"line":59},[45,799,800],{"class":51},"    return",[45,802,803],{"class":130}," '姓名：'",[45,805,806],{"class":51},".",[45,808,809],{"class":69},"$name",[45,811,806],{"class":51},[45,813,814],{"class":130},"'\u003Cbr\u002F>'",[45,816,806],{"class":51},[45,818,819],{"class":130},"'身高：'",[45,821,806],{"class":51},[45,823,824],{"class":69},"$height",[45,826,806],{"class":51},[45,828,814],{"class":130},[45,830,806],{"class":51},[45,832,833],{"class":130},"'體重：'",[45,835,806],{"class":51},[45,837,838],{"class":69},"$weight;\n",[45,840,841],{"class":47,"line":73},[45,842,139],{"class":69},[17,844,845],{},"Now head back to the form, fill in the fields, and hit Submit. ↓",[17,847,848],{},[772,849],{"alt":850,"src":851},"Submitting the form","https:\u002F\u002Fi.imgur.com\u002Fybnutj4.png",[17,853,854],{},"If everything's working, you should see the data you just submitted. ↓",[17,856,857],{},[772,858],{"alt":859,"src":860},"The returned result","https:\u002F\u002Fi.imgur.com\u002FDPxEd7U.png",[17,862,863],{},"So from that flow you can see we successfully sent data to the backend, and the backend sent a result back to the screen. But how does this actually work? And how does the Controller grab the form field data?",[17,865,866,867,869,870,873,874,876,877,879,880,883],{},"When you submit a ",[31,868,394],{},", ThinkPHP reads the ",[31,871,872],{},"name"," attribute of each ",[31,875,455],{}," field — and that ",[31,878,872],{}," happens to match up with the parameters on the ",[31,881,882],{},"function",". So as long as I write the matching variable names, I can pull the form field data right out.",[12,885,887],{"id":886},"wrapping-up","Wrapping up",[17,889,890,891,894,895,898],{},"After writing JavaScript for so long, I got tripped up for a second on this line: ",[31,892,893],{},"return '姓名：'.$name.'\u003Cbr\u002F>'.'身高：'.$height.'\u003Cbr\u002F>'.'體重：'.$weight;",". I kept writing it as ",[31,896,897],{},"return '姓名：' + $name + '\u003Cbr\u002F>'+ '身高：' + $height + '\u003Cbr\u002F>' + '體重：' + $weight;",". Habits are a scary thing (?!)",[900,901,902],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html pre.shiki code .smYoP, html code.shi