:",[36,163,165],{"className":38,"code":164,"language":40,"meta":41,"style":41},"Route::get('\u002Fabout\u002Fuser', 'about\u002Findex\u002Fuser');\nRoute::post('\u002Fabout\u002Fcreate', 'about\u002Findex\u002Fcreate');\n",[31,166,167,193],{"__ignoreMap":41},[45,168,169,172,175,178,181,184,187,190],{"class":47,"line":48},[45,170,171],{"class":55},"Route",[45,173,174],{"class":51},"::",[45,176,156],{"class":177},"scAaK",[45,179,180],{"class":69},"(",[45,182,183],{"class":130},"'\u002Fabout\u002Fuser'",[45,185,186],{"class":69},", ",[45,188,189],{"class":130},"'about\u002Findex\u002Fuser'",[45,191,192],{"class":69},");\n",[45,194,195,197,199,201,203,206,208,211],{"class":47,"line":59},[45,196,171],{"class":55},[45,198,174],{"class":51},[45,200,160],{"class":177},[45,202,180],{"class":69},[45,204,205],{"class":130},"'\u002Fabout\u002Fcreate'",[45,207,186],{"class":69},[45,209,210],{"class":130},"'about\u002Findex\u002Fcreate'",[45,212,192],{"class":69},[17,214,215,216,219,220,223,224,227],{},"Now let's build an HTML page so we have something to render, and a way to send data to ",[31,217,218],{},"about\u002Findex\u002Fcreate",". Under ",[31,221,222],{},"about\u002Fview",", create a folder and an HTML file at ",[31,225,226],{},"index\u002Findex.html",". Here's the content:",[36,229,233],{"className":230,"code":231,"language":232,"meta":41,"style":41},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \u003Ctitle>{$title}\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>{$title}\u003C\u002Fh1>\n  \u003Cform action=\"\u002Fabout\u002Fcreate\" method=\"post\">\n    \u003Cdiv>\n      \u003Clabel for=\"name\">Name\u003C\u002Flabel>\n      \u003Cinput type=\"text\" name=\"name\" id=\"nam