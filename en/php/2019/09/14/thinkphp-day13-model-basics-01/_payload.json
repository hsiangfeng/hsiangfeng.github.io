[{"data":1,"prerenderedAt":953},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F14\u002Fthinkphp-day13-model-basics-01\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F14\u002Fthinkphp-day13-model-basics-01\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F14\u002Fthinkphp-day13-model-basics-01\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F14\u002Fthinkphp-day13-model-basics-01\u002F":929,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F14\u002Fthinkphp-day13-model-basics-01\u002F":938},"\u002Fphp\u002F20190914\u002F278976166\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":910,"date":911,"description":912,"extension":913,"lang":914,"meta":915,"navigation":76,"path":916,"readingMinutes":917,"seo":918,"standalone":919,"stem":920,"tags":921,"tldr":926,"updated":911,"url":927,"__hash__":928},"content\u002Fen\u002FPHP\u002Fthinkphp-day13-model-basics-01.md","ThinkPHP Day 13 — Wiring Up the Model: Routes, Controllers, and Your First Form","1002668706",{"type":9,"value":10,"toc":903},"minimark",[11,16,20,24,27,35,140,143,147,162,213,228,673,677,680,683,762,769,776,779,843,846,852,855,861,864,884,888,899],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"From here on we're going to start pulling together some of the stuff we covered earlier to do basic Model operations. So this time we'll bring the Controller and Route into the picture too.",[12,21,23],{"id":22},"getting-started","Getting started",[17,25,26],{},"Back in the Model chapter we already defined a basic Model. But a Model on its own doesn't do much — we still need some basic moves to actually operate it. So here we'll write a Controller to drive the Model.",[17,28,29,30,34],{},"In most cases you don't really need to touch the Model to do the basic operations coming up. Let's open ",[31,32,33],"code",{},"project\u002Fapplication\u002Fabout\u002Fmodel\u002Fabout.php"," and drop in the following code (we already pre-defined th