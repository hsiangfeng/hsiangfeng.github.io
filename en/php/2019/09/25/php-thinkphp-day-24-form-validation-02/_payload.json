[{"data":1,"prerenderedAt":731},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F":707,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F":716},"\u002Fphp\u002F20190925\u002F1108470009\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":688,"date":689,"description":690,"extension":691,"lang":692,"meta":693,"navigation":65,"path":694,"readingMinutes":695,"seo":696,"standalone":697,"stem":698,"tags":699,"tldr":704,"updated":689,"url":705,"__hash__":706},"content\u002Fen\u002FPHP\u002Fphp-thinkphp-day-24-form-validation-02.md","Day 24 - Learning ThinkPHP from Scratch: Form Validation (2)","1002763734",{"type":9,"value":10,"toc":682},"minimark",[11,16,20,24,27,240,243,250,277,280,457,468,474,481,487,490,496,502,508,512,515,583,590,641,652,656,675,678],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time we got basic form validation working, but honestly that was only half the story. That's why I split this into two parts. So let's keep going with form validation.",[12,21,23],{"id":22},"sending-form-error-messages-to-the-front-end","Sending form error messages to the front end",[17,25,26],{},"First, let me recap where we left off in the previous post:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-php shiki shiki-themes github-dark-high-contrast","protected $batchValidate = true;\n\npublic function add() {\n    $user = new userModel;\n    $userData = input();\n    $result = $this->validate($userData, 'User');\n    if(true !== $result) {\n        return json($result);\n    }\n    if($user->save($userData)){\n        return '新增成功';\n    } else {\n        return $user->getError();\n    }\n}\n","php","",[35,36,37,60,67,83,99,113,140,158,170,176,192,202,214,229,234],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","protected",[38,47,49],{"class":48},"sMAXC"," $batchValidate ",[38,51,52],{"class":44},"=",[38,54,56],{"class":55},"sCcAr"," true",[38,58,59],{"class":48},";\n",[38,61,63],{"class":40,"line":62},2,[38,64,66],{"emptyLinePlaceholder":65},true,"\n",[38,68,70,73,76,80],{"class":40,"line":69},3,[38,71,72],{"class":44},"public",[38,74,75],{"class":44}," function",[38,77,79],{"class":78},"sj_SG"," add",[38,81,82],{"class":48},"() {\n",[38,84,86,89,91,94,97],{"class":40,"line":85},4,[38,87,88],{"class":48},"    $user ",[38,90,52],{"class":44},[38,92,93],{"class":44}," new",[38,95,96],{"class":55}," userModel",[38,98,59],{"class":48},[38,100,102,105,107,110],{"class":40,"line":101},5,[38,103,104],{"class":48},"    $userData ",[38,106,52],{"class":44},[38,108,109],{"class":78}," input",[38,111,112],{"class":48},"();\n",[38,114,116,119,121,124,127,130,133,137],{"class":40,"line":115},6,[38,117,118],{"class":48},"    $result ",[38,120,52],{"class":44},[38,122,123],{"class":55}," $this",[38,125,126],{"class":44},"->",[38,128,129],{"class":78},"validate",[38,131,132],{"class":48},"($userData, ",[38,134,136],{"class":135},"sTRMh","'User'",[38,138,139],{"class":48},");\n",[38,141,143,146,149,152,155],{"class":40,"line":142},7,[38,144,145],{"class":44},"    if",[38,147,148],{"class":48},"(",[38,150,151],{"class":55},"true",[38,153,154],{"class":44}," !==",[38,156,157],{"class":48}," $result) {\n",[38,159,161,164,167],{"class":40,"line":160},8,[38,162,163],{"class":44},"        return",[38,165,166],{"class":78}," json",[38,168,169],{"class":48},"($result);\n",[38,171,173],{"class":40,"line":172},9,[38,174,175],{"class":48},"    }\n",[38,177,179,181,184,186,189],{"class":40,"line":178},10,[38,180,145],{"class":44},[38,182,183],{"class":48},"($user",[38,185,126],{"class":44},[38,187,188],{"class":78},"save",[38,190,191],{"class":48},"($userData)){\n",[38,193,195,197,200],{"class":40,"line":194},11,[38,196,163],{"class":44},[38,198,199],{"class":135}," '新增成功'",[38,201,59],{"class":48},[38,203,205,208,211],{"class":40,"line":204},12,[38,206,207],{"class":48},"    } ",[38,209,210],{"class":44},"else",[38,212,213],{"class":48}," {\n",[38,215,217,219,222,224,227],{"class":40,"line":216},13,[38,218,163],{"class":44},[38,220,221],{"class":48}," $user",[38,223,126],{"class":44},[38,225,226],{"class":78},"getError",[38,228,112],{"class":48},[38,230,232],{"class":40,"line":231},14,[38,233,175],{"class":48},[38,235,237],{"class":40,"line":236},15,[38,238,239],{"class":48},"}\n",[17,241,242],{},"What we have so far is: when validation fails, it returns a JSON screen ↓",[17,244,245],{},[246,247],"img",{"alt":248,"src":249},"Batch validation","https:\u002F\u002Fi.imgur.com\u002FOcYYHT2.png",[17,251,252,253,256,257,260,261,264,265,268,269,272,273,276],{},"So in this post we'll try to send those validation error messages to the front end. The sending itself isn't hard. You might think you can just use ",[35,254,255],{},"assign()"," to pass the params forward and then ",[35,258,259],{},"fetch()"," to pick the template. But that approach is actually wrong, because doing it that way messes up the URL. The correct way is to use ",[35,262,263],{},"redirect()"," to redirect again. You might ask, \"OK, but what about the error messages?\" That's where ThinkPHP's flash feature comes in, namely the ",[35,266,267],{},"Session::flash"," method, which we use to carry the error messages. The thing is, ",[35,270,271],{},"flash"," is built on top of the ",[35,274,275],{},"session"," library, so there's a bit of setup to write first. Let's take a look at how to do it.",[17,278,279],{},"First up, we need to import Session:",[28,281,283],{"className":30,"code":282,"language":32,"meta":33,"style":33},"use think\\facade\\Session; \u002F\u002F Don't import use think\\Session; it'll throw an error\n\npublic function add() {\n    $user = new userModel;\n    $userData = input();\n    $result = $this->validate($userData, 'User');\n    if(true !== $result) {\n        Session::flash('error', $result); \u002F\u002F Store the error message\n        $this->redirect('\u002Fuser\u002Fsignup');\n    }\n    if($user->save($userData)){\n        return '新增成功';\n    } else {\n        return $user->getError();\n    }\n}\n",[35,284,285,300,304,314,326,336,354,366,387,404,408,420,428,436,448,452],{"__ignoreMap":33},[38,286,287,290,293,296],{"class":40,"line":41},[38,288,289],{"class":44},"use",[38,291,292],{"class":55}," think\\facade\\Session",[38,294,295],{"class":48},"; ",[38,297,299],{"class":298},"sQrFR","\u002F\u002F Don't import use think\\Session; it'll throw an error\n",[38,301,302],{"class":40,"line":62},[38,303,66],{"emptyLinePlaceholder":65},[38,305,306,308,310,312],{"class":40,"line":69},[38,307,72],{"class":44},[38,309,75],{"class":44},[38,311,79],{"class":78},[38,313,82],{"class":48},[38,315,316,318,320,322,324],{"class":40,"line":85},[38,317,88],{"class":48},[38,319,52],{"class":44},[38,321,93],{"class":44},[38,323,96],{"class":55},[38,325,59],{"class":48},[38,327,328,330,332,334],{"class":40,"line":101},[38,329,104],{"class":48},[38,331,52],{"class":44},[38,333,109],{"class":78},[38,335,112],{"class":48},[38,337,338,340,342,344,346,348,350,352],{"class":40,"line":115},[38,339,118],{"class":48},[38,341,52],{"class":44},[38,343,123],{"class":55},[38,345,126],{"class":44},[38,347,129],{"class":78},[38,349,132],{"class":48},[38,351,136],{"class":135},[38,353,139],{"class":48},[38,355,356,358,360,362,364],{"class":40,"line":142},[38,357,145],{"class":44},[38,359,148],{"class":48},[38,361,151],{"class":55},[38,363,154],{"class":44},[38,365,157],{"class":48},[38,367,368,371,374,376,378,381,384],{"class":40,"line":160},[38,369,370],{"class":55},"        Session",[38,372,373],{"class":44},"::",[38,375,271],{"class":78},[38,377,148],{"class":48},[38,379,380],{"class":135},"'error'",[38,382,383],{"class":48},", $result); ",[38,385,386],{"class":298},"\u002F\u002F Store the error message\n",[38,388,389,392,394,397,399,402],{"class":40,"line":172},[38,390,391],{"class":55},"        $this",[38,393,126],{"class":44},[38,395,396],{"class":78},"redirect",[38,398,148],{"class":48},[38,400,401],{"class":135},"'\u002Fuser\u002Fsignup'",[38,403,139],{"class":48},[38,405,406],{"class":40,"line":178},[38,407,175],{"class":48},[38,409,410,412,414,416,418],{"class":40,"line":194},[38,411,145],{"class":44},[38,413,183],{"class":48},[38,415,126],{"class":44},[38,417,188],{"class":78},[38,419,191],{"class":48},[38,421,422,424,426],{"class":40,"line":204},[38,423,163],{"class":44},[38,425,199],{"class":135},[38,427,59],{"class":48},[38,429,430,432,434],{"class":40,"line":216},[38,431,207],{"class":48},[38,433,210],{"class":44},[38,435,213],{"class":48},[38,437,438,440,442,444,446],{"class":40,"line":231},[38,439,163],{"class":44},[38,441,221],{"class":48},[38,443,126],{"class":44},[38,445,226],{"class":78},[38,447,112],{"class":48},[38,449,450],{"class":40,"line":236},[38,451,175],{"class":48},[38,453,455],{"class":40,"line":454},16,[38,456,239],{"class":48},[17,458,459,460,463,464,467],{},"Next we can go straight to the front-end template and render the error messages. To render a ",[35,461,462],{},"Session"," value in HTML you use ",[35,465,466],{},"{$Request.session.xxx}",". The data is an object, so we have to specify a name, otherwise you'll get an error. So how do we figure out the name? Earlier we output the error messages as JSON on the screen ↓",[17,469,470],{},[246,471],{"alt":472,"src":473},"JSON","https:\u002F\u002Fi.imgur.com\u002F8cZ3kLk.png",[17,475,476,477,480],{},"So we fill it in like this: ",[35,478,479],{},"{$Request.session.error.email}",", and the rest of the error messages follow the same pattern. The result looks like this ↓",[17,482,483],{},[246,484],{"alt":485,"src":486},"HTML","https:\u002F\u002Fi.imgur.com\u002FRVM6eHc.png",[17,488,489],{},"Now let's refresh the page, fill in only the Email field, and submit the form to see what happens ↓",[17,491,492],{},[246,493],{"alt":494,"src":495},"Error message","https:\u002F\u002Fi.imgur.com\u002FW5zYyaU.png",[17,497,498,499,501],{},"And since the nice thing about ",[35,500,271],{}," is that it gets deleted after a single use, all we have to do is hit F5 and the error message is gone forever ~~ ↓",[17,503,504],{},[246,505],{"alt":506,"src":507},"Gone for good","https:\u002F\u002Fi.imgur.com\u002FSsSUgNZ.png",[12,509,511],{"id":510},"simplifying-template-output","Simplifying template output",[17,513,514],{},"There's also one spot here that we can simplify. I didn't show this code earlier, but the original method that displays the signup controller looked like this:",[28,516,518],{"className":30,"code":517,"language":32,"meta":33,"style":33},"public function getSignup()\n{\n    $this->assign(\"title\", \"註冊頁面\");\n    return $this->fetch('signup');\n}\n",[35,519,520,532,537,560,579],{"__ignoreMap":33},[38,521,522,524,526,529],{"class":40,"line":41},[38,523,72],{"class":44},[38,525,75],{"class":44},[38,527,528],{"class":78}," getSignup",[38,530,531],{"class":48},"()\n",[38,533,534],{"class":40,"line":62},[38,535,536],{"class":48},"{\n",[38,538,539,542,544,547,549,552,555,558],{"class":40,"line":69},[38,540,541],{"class":55},"    $this",[38,543,126],{"class":44},[38,545,546],{"class":78},"assign",[38,548,148],{"class":48},[38,550,551],{"class":135},"\"title\"",[38,553,554],{"class":48},", ",[38,556,557],{"class":135},"\"註冊頁面\"",[38,559,139],{"class":48},[38,561,562,565,567,569,572,574,577],{"class":40,"line":85},[38,563,564],{"class":44},"    return",[38,566,123],{"class":55},[38,568,126],{"class":44},[38,570,571],{"class":78},"fetch",[38,573,148],{"class":48},[38,575,576],{"class":135},"'signup'",[38,578,139],{"class":48},[38,580,581],{"class":40,"line":101},[38,582,239],{"class":48},[17,584,585,586,589],{},"ThinkPHP provides something called a helper function that lets us quickly render a given template, namely the ",[35,587,588],{},"View()"," method. So we can simplify it to this:",[28,591,593],{"className":30,"code":592,"language":32,"meta":33,"style":33},"public function getSignup()\n{\n    return View('signup')->assign(\"title\", \"註冊頁面\");\n}\n",[35,594,595,605,609,637],{"__ignoreMap":33},[38,596,597,599,601,603],{"class":40,"line":41},[38,598,72],{"class":44},[38,600,75],{"class":44},[38,602,528],{"class":78},[38,604,531],{"class":48},[38,606,607],{"class":40,"line":62},[38,608,536],{"class":48},[38,610,611,613,616,618,620,623,625,627,629,631,633,635],{"class":40,"line":69},[38,612,564],{"class":44},[38,614,615],{"class":78}," View",[38,617,148],{"class":48},[38,619,576],{"class":135},[38,621,622],{"class":48},")",[38,624,126],{"class":44},[38,626,546],{"class":78},[38,628,148],{"class":48},[38,630,551],{"class":135},[38,632,554],{"class":48},[38,634,557],{"class":135},[38,636,139],{"class":48},[38,638,639],{"class":40,"line":85},[38,640,239],{"class":48},[17,642,643,644,647,648,651],{},"No need to second-guess it, it really is that simple. One line is all it takes to output data to the template we want. If you don't want to use ",[35,645,646],{},"$this->fetch('signup');",", you can also switch to ",[35,649,650],{},"return View('signup')",". So there's another way to write it for your reference.",[12,653,655],{"id":654},"wrap-up","Wrap-up",[17,657,658,659,662,663,666,667,670,671,674],{},"In this chapter I got stuck for a while on importing Session, because the docs say to import ",[35,660,661],{},"use think\\Session",". But after importing that, when I used ",[35,664,665],{},"Session::flash()"," I'd hit ",[35,668,669],{},"Non-static method think\\Session::flash() should not be called statically",". Switching to ",[35,672,673],{},"use think\\facade\\Session;"," fixed it. Just something to watch out for.",[17,676,677],{},"Next time we'll talk about form Tokens ~",[679,680,681],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":33,"searchDepth":62,"depth":62,"links":683},[684,685,686,687],{"id":14,"depth":62,"text":15},{"id":22,"depth":62,"text":23},{"id":510,"depth":62,"text":511},{"id":654,"depth":62,"text":655},"PHP","2019-09-25 00:00:05","Last time we got basic form validation working, but honestly that was only half the story. That's why I split this into two parts. In this one we'll send validation error messages back to the front end using ThinkPHP's flash feature, then simplify our template output with the View() helper. Let's keep going with form validation.","md","en",{},"\u002Fen\u002Fphp\u002Fphp-thinkphp-day-24-form-validation-02","3",{"title":6,"description":690},false,"en\u002FPHP\u002Fphp-thinkphp-day-24-form-validation-02",[688,700,701,702,703],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","11th iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F25\u002Fphp-thinkphp-day-24-form-validation-02\u002F","Ga5I1GwaTtcYPy2lJyNF1E5bIPZ6XM7TVD5q0srCljo",{"newer":708,"older":712},{"url":709,"title":710,"date":711},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F25\u002Fjs-from-zero-10-conditionals\u002F","Learning JS From Zero — Day 10: if, else, and switch","2019-09-25 00:00:10",{"url":713,"title":714,"date":715},"\u002Fen\u002Fmisc\u002F2019\u002F09\u002F24\u002Fcustomize-windows-terminal-with-oh-my-posh\u002F","Customize Windows Terminal with oh-my-posh (PowerShell Prompt + Windows Terminal Setup)","2019-09-24 13:53:52",[717,722,726],{"url":718,"title":719,"date":720,"readingMinutes":721},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":723,"title":724,"date":725,"readingMinutes":695},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02",{"url":727,"title":728,"date":729,"readingMinutes":730},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01","4",1784013071413]