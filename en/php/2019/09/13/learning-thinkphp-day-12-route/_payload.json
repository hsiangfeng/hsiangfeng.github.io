[{"data":1,"prerenderedAt":671},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F":647,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F":656},"\u002Fphp\u002F20190913\u002F1270939931\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":627,"date":628,"description":629,"extension":630,"lang":631,"meta":632,"navigation":633,"path":634,"readingMinutes":635,"seo":636,"standalone":637,"stem":638,"tags":639,"tldr":644,"updated":628,"url":645,"__hash__":646},"content\u002Fen\u002FPHP\u002Flearning-thinkphp-day-12-route.md","Learning ThinkPHP from Scratch Day 12 - Routing","1002660787",{"type":9,"value":10,"toc":620},"minimark",[11,16,20,24,27,34,38,46,52,55,60,71,77,88,94,100,105,109,119,122,169,172,194,197,321,330,347,372,375,406,413,438,441,447,450,474,480,486,489,498,501,553,559,562,587,594,600,604,607,610,616],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We've already gone through the basic MVC structure and the core definitions, so now it's time to actually try things out. But before we do that, there's one more thing we need to understand first - Route. For modern development, routing is a really important foundation.",[12,21,23],{"id":22},"route","Route",[17,25,26],{},"I've actually written a similar article about routing before, so I won't go too deep into it here - I'll just drop the link for you to check out. The examples there are based on Express.js, but conceptually it's pretty much the same idea.",[17,28,29],{},[30,31,33],"a",{"href":32},"\u002Fnodejs\u002F20190630\u002F931792585\u002F","Fullstack Warrior's Path Node.js Basics - Express Route (article in Mandarin)",[12,35,37],{"id":36},"getting-started","Getting started",[17,39,40,41,45],{},"First off, when you initialize a ThinkPHP project, it already sets up some default routes for us. So we can open ",[42,43,44],"code",{},"project\u002Froute\u002Frouter.php"," to see what it prepared for us ↓",[17,47,48],{},[49,50],"img",{"alt":23,"src":51},"https:\u002F\u002Fi.imgur.com\u002FG3E8FrI.png",[17,53,54],{},"Right at the top of router.php we can see a few basic Route settings ↓",[17,56,57],{},[49,58],{"alt":23,"src":59},"https:\u002F\u002Fi.imgur.com\u002FiJBga2W.png",[17,61,62,63,66,67,70],{},"From this we can tell that when we hit ",[42,64,65],{},"http:\u002F\u002Flocalhost:8000\u002Fthink",", we get a returned value, which is ",[42,68,69],{},"hello,ThinkPHP5!"," ↓",[17,72,73],{},[49,74],{"alt":75,"src":76},"ThinkPHP5","https:\u002F\u002Fi.imgur.com\u002FHsfuCZ0.png",[17,78,79,80,83,84,87],{},"So what happens if we hit ",[42,81,82],{},"http:\u002F\u002Flocalhost:8000\u002Fhello\u002F:name","? Notice that the thing tacked on at the end is a dynamic route (",[42,85,86],{},":name","), so if you don't pass in any data you'll end up with an error ↓",[17,89,90],{},[49,91],{"alt":92,"src":93},"Dynamic route","https:\u002F\u002Fi.imgur.com\u002Fr6fTxlf.png",[17,95,96,97,70],{},"So the correct way to hit it is like this: ",[42,98,99],{},"http:\u002F\u002Flocalhost:8000\u002Fhello\u002FRay",[17,101,102],{},[49,103],{"alt":92,"src":104},"https:\u002F\u002Fi.imgur.com\u002F5oJJcNe.png",[12,106,108],{"id":107},"a-look-at-route","A look at Route",[17,110,111,112,115,116],{},"According to the official docs, the basic Route definition is ",[42,113,114],{},"Route::rule('Route expression', 'Route address', 'request type');",". But honestly I find that kind of hard to parse, so I reorganized it into this: ",[42,117,118],{},"Route::rule('access URL', 'Controller', 'HTTP request');",[17,120,121],{},"So going by the example, we can write it like this:",[123,124,129],"pre",{"className":125,"code":126,"language":127,"meta":128,"style":128},"language-php shiki shiki-themes github-dark-high-contrast","Route::rule('hello\u002F:name', 'index\u002Fhello', 'GET');\n","php","",[42,130,131],{"__ignoreMap":128},[132,133,136,139,143,147,151,155,158,161,163,166],"span",{"class":134,"line":135},"line",1,[132,137,23],{"class":138},"sCcAr",[132,140,142],{"class":141},"sWyjQ","::",[132,144,146],{"class":145},"sj_SG","rule",[132,148,150],{"class":149},"sMAXC","(",[132,152,154],{"class":153},"sTRMh","'hello\u002F:name'",[132,156,157],{"class":149},", ",[132,159,160],{"class":153},"'index\u002Fhello'",[132,162,157],{"class":149},[132,164,165],{"class":153},"'GET'",[132,167,168],{"class":149},");\n",[17,170,171],{},"And the Route types ThinkPHP accepts are the following:",[173,174,175,179,182,185,188,191],"ul",{},[176,177,178],"li",{},"GET",[176,180,181],{},"POST",[176,183,184],{},"PUT",[176,186,187],{},"DELETE",[176,189,190],{},"PATCH",[176,192,193],{},"＊ - wildcard request",[17,195,196],{},"But you'll notice the example the official docs gives is a different version from what I wrote. The official one is basically a simplified version of Route, and I personally prefer the simplified setup too, so it's totally fine to rewrite it like this:",[123,198,200],{"className":125,"code":199,"language":127,"meta":128,"style":128},"Route::get('hello\u002F:name', 'index\u002Fhello');\nRoute::post('hello\u002F:name', 'index\u002Fhello');\nRoute::put('hello\u002F:name', 'index\u002Fhello');\nRoute::delete('hello\u002F:name', 'index\u002Fhello');\nRoute::patch('hello\u002F:name', 'index\u002Fhello');\nRoute::any('hello\u002F:name', 'index\u002Fhello');\n",[42,201,202,221,241,261,281,301],{"__ignoreMap":128},[132,203,204,206,208,211,213,215,217,219],{"class":134,"line":135},[132,205,23],{"class":138},[132,207,142],{"class":141},[132,209,210],{"class":145},"get",[132,212,150],{"class":149},[132,214,154],{"class":153},[132,216,157],{"class":149},[132,218,160],{"class":153},[132,220,168],{"class":149},[132,222,224,226,228,231,233,235,237,239],{"class":134,"line":223},2,[132,225,23],{"class":138},[132,227,142],{"class":141},[132,229,230],{"class":145},"post",[132,232,150],{"class":149},[132,234,154],{"class":153},[132,236,157],{"class":149},[132,238,160],{"class":153},[132,240,168],{"class":149},[132,242,244,246,248,251,253,255,257,259],{"class":134,"line":243},3,[132,245,23],{"class":138},[132,247,142],{"class":141},[132,249,250],{"class":145},"put",[132,252,150],{"class":149},[132,254,154],{"class":153},[132,256,157],{"class":149},[132,258,160],{"class":153},[132,260,168],{"class":149},[132,262,264,266,268,271,273,275,277,279],{"class":134,"line":263},4,[132,265,23],{"class":138},[132,267,142],{"class":141},[132,269,270],{"class":145},"delete",[132,272,150],{"class":149},[132,274,154],{"class":153},[132,276,157],{"class":149},[132,278,160],{"class":153},[132,280,168],{"class":149},[132,282,284,286,288,291,293,295,297,299],{"class":134,"line":283},5,[132,285,23],{"class":138},[132,287,142],{"class":141},[132,289,290],{"class":145},"patch",[132,292,150],{"class":149},[132,294,154],{"class":153},[132,296,157],{"class":149},[132,298,160],{"class":153},[132,300,168],{"class":149},[132,302,304,306,308,311,313,315,317,319],{"class":134,"line":303},6,[132,305,23],{"class":138},[132,307,142],{"class":141},[132,309,310],{"class":145},"any",[132,312,150],{"class":149},[132,314,154],{"class":153},[132,316,157],{"class":149},[132,318,160],{"class":153},[132,320,168],{"class":149},[17,322,323,324,326,327,329],{},"Finally let me explain the Route setup a bit. Because the official docs description ",[42,325,114],{}," is honestly kind of confusing, that's exactly why I reorganized it into ",[42,328,118],{},".",[17,331,332,333,336,337,339,340,342,343,346],{},"Let me use ",[42,334,335],{},"Route::get('hello\u002F:name', 'index\u002Fhello');"," as an example. In ",[42,338,335],{},", the first parameter represents the URL, which is ",[42,341,82],{},", and the second parameter ",[42,344,345],{},"index\u002Fhello"," is the Controller you want to access. So the result is this:",[123,348,350],{"className":125,"code":349,"language":127,"meta":128,"style":128},"Route::get('[Route URL]', 'Controller');\n",[42,351,352],{"__ignoreMap":128},[132,353,354,356,358,360,362,365,367,370],{"class":134,"line":135},[132,355,23],{"class":138},[132,357,142],{"class":141},[132,359,210],{"class":145},[132,361,150],{"class":149},[132,363,364],{"class":153},"'[Route URL]'",[132,366,157],{"class":149},[132,368,369],{"class":153},"'Controller'",[132,371,168],{"class":149},[17,373,374],{},"So the simplified version is way easier to understand than the manual's wording - you just need to read it like this and you'll get it:",[123,376,378],{"className":125,"code":377,"language":127,"meta":128,"style":128},"Route::[HTTP request]('[Route URL]', 'Controller');\n",[42,379,380],{"__ignoreMap":128},[132,381,382,384,386,389,392,395,398,400,402,404],{"class":134,"line":135},[132,383,23],{"class":138},[132,385,142],{"class":141},[132,387,388],{"class":149},"[",[132,390,391],{"class":138},"HTTP",[132,393,394],{"class":138}," request",[132,396,397],{"class":149},"](",[132,399,364],{"class":153},[132,401,157],{"class":149},[132,403,369],{"class":153},[132,405,168],{"class":149},[17,407,408,409,412],{},"Once we understand the idea above, we can try adding a new Route. For example, let's say I want hitting ",[42,410,411],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fqq123"," to show the index under the about Controller:",[123,414,416],{"className":125,"code":415,"language":127,"meta":128,"style":128},"Route::get('\u002Fabout\u002Fqq123', 'about\u002Findex\u002Findex');\n",[42,417,418],{"__ignoreMap":128},[132,419,420,422,424,426,428,431,433,436],{"class":134,"line":135},[132,421,23],{"class":138},[132,423,142],{"class":141},[132,425,210],{"class":145},[132,427,150],{"class":149},[132,429,430],{"class":153},"'\u002Fabout\u002Fqq123'",[132,432,157],{"class":149},[132,434,435],{"class":153},"'about\u002Findex\u002Findex'",[132,437,168],{"class":149},[17,439,440],{},"Then when we hit that route we get the expected result ↓",[17,442,443],{},[49,444],{"alt":445,"src":446},"About","https:\u002F\u002Fi.imgur.com\u002FRMKPex6.png",[17,448,449],{},"One thing to watch out for when registering routes - don't write it like this:",[123,451,453],{"className":125,"code":452,"language":127,"meta":128,"style":128},"Route::get('\u002Fabout\u002Fqq123', 'about\u002Findex');\n",[42,454,455],{"__ignoreMap":128},[132,456,457,459,461,463,465,467,469,472],{"class":134,"line":135},[132,458,23],{"class":138},[132,460,142],{"class":141},[132,462,210],{"class":145},[132,464,150],{"class":149},[132,466,430],{"class":153},[132,468,157],{"class":149},[132,470,471],{"class":153},"'about\u002Findex'",[132,473,168],{"class":149},[17,475,476,477,479],{},"Because when you browse to ",[42,478,411],{},", this will only give you an error ↓",[17,481,482],{},[49,483],{"alt":484,"src":485},"Error","https:\u002F\u002Fi.imgur.com\u002FmMAVDis.png",[17,487,488],{},"Finally, here's a little mnemonic to help you register routes correctly. Say I want to register the index route:",[17,490,491,495,496,329],{},[492,493,494],"strong",{},"Register the Route to about's index controller, then the index method inside it",", so it's ",[42,497,435],{},[17,499,500],{},"To verify the mnemonic, let me add another bit of code to about's index Controller:",[123,502,504],{"className":125,"code":503,"language":127,"meta":128,"style":128},"public function sayhi ($name = 'undefined')\n    {\n        return 'Hi：' . $name;\n    }\n",[42,505,506,529,534,548],{"__ignoreMap":128},[132,507,508,511,514,517,520,523,526],{"class":134,"line":135},[132,509,510],{"class":141},"public",[132,512,513],{"class":141}," function",[132,515,516],{"class":145}," sayhi",[132,518,519],{"class":149}," ($name ",[132,521,522],{"class":141},"=",[132,524,525],{"class":153}," 'undefined'",[132,527,528],{"class":149},")\n",[132,530,531],{"class":134,"line":223},[132,532,533],{"class":149},"    {\n",[132,535,536,539,542,545],{"class":134,"line":243},[132,537,538],{"class":141},"        return",[132,540,541],{"class":153}," 'Hi：'",[132,543,544],{"class":141}," .",[132,546,547],{"class":149}," $name;\n",[132,549,550],{"class":134,"line":263},[132,551,552],{"class":149},"    }\n",[17,554,555,556],{},"Now let's run through the mnemonic again: ",[492,557,558],{},"Register the Route to about's index controller, then the sayhi method inside it",[17,560,561],{},"So you just register the route like this:",[123,563,565],{"className":125,"code":564,"language":127,"meta":128,"style":128},"Route::get('\u002Fabout\u002Fsayhi', 'about\u002Findex\u002Fsayhi');\n",[42,566,567],{"__ignoreMap":128},[132,568,569,571,573,575,577,580,582,585],{"class":134,"line":135},[132,570,23],{"class":138},[132,572,142],{"class":141},[132,574,210],{"class":145},[132,576,150],{"class":149},[132,578,579],{"class":153},"'\u002Fabout\u002Fsayhi'",[132,581,157],{"class":149},[132,583,584],{"class":153},"'about\u002Findex\u002Fsayhi'",[132,586,168],{"class":149},[17,588,589,590,593],{},"This way, when you hit ",[42,591,592],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fsayhi",", you'll see the result ↓",[17,595,596],{},[49,597],{"alt":598,"src":599},"Hi：undefined","https:\u002F\u002Fi.imgur.com\u002FshwjqEo.png",[12,601,603],{"id":602},"wrapping-up","Wrapping up",[17,605,606],{},"If you don't get this route registration part figured out, it's pretty easy to get confused about how to register to the controller and method you actually want. While writing this article, I got a little stuck myself - clearly my skills still need work~ (sigh)",[17,608,609],{},"Also, this routing concept is connected to the MVC pattern chapter I covered earlier ↓",[17,611,612],{},[49,613],{"alt":614,"src":615},"Flow architecture diagram","https:\u002F\u002Fi.imgur.com\u002FZ6cu71b.png",[617,618,619],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":128,"searchDepth":223,"depth":223,"links":621},[622,623,624,625,626],{"id":14,"depth":223,"text":15},{"id":22,"depth":223,"text":23},{"id":36,"depth":223,"text":37},{"id":107,"depth":223,"text":108},{"id":602,"depth":223,"text":603},"PHP","2019-09-13 00:01:52","We've covered the basic MVC structure and the core definitions, so now it's time to get our hands dirty. But before we do, there's one more thing we need to understand first - Route. For modern development, routing is a really important foundation, and ThinkPHP makes it pretty straightforward once you get the hang of it.","md","en",{},true,"\u002Fen\u002Fphp\u002Flearning-thinkphp-day-12-route","4",{"title":6,"description":629},false,"en\u002FPHP\u002Flearning-thinkphp-day-12-route",[627,640,641,642,643],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F13\u002Flearning-thinkphp-day-12-route\u002F","wc4TdgDSM4q2_xOs08zhayN7fM6ryP4ufN-Ht7iR5S0",{"newer":648,"older":652},{"url":649,"title":650,"date":651},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F14\u002Fthinkphp-day13-model-basics-01\u002F","ThinkPHP Day 13 — Wiring Up the Model: Routes, Controllers, and Your First Form","2019-09-14 00:09:41",{"url":653,"title":654,"date":655},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F12\u002Fthink-php-day-11-model\u002F","Learning ThinkPHP from Scratch Day 11 - Defining Models","2019-09-12 00:03:18",[657,662,667],{"url":658,"title":659,"date":660,"readingMinutes":661},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":663,"title":664,"date":665,"readingMinutes":666},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02","3",{"url":668,"title":669,"date":670,"readingMinutes":635},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01",1784012784962]