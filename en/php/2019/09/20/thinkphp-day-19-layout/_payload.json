[{"data":1,"prerenderedAt":959},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F20\u002Fthinkphp-day-19-layout\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F20\u002Fthinkphp-day-19-layout\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F20\u002Fthinkphp-day-19-layout\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F20\u002Fthinkphp-day-19-layout\u002F":935,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F20\u002Fthinkphp-day-19-layout\u002F":944},"\u002Fphp\u002F20190920\u002F2923257467\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":915,"date":916,"description":917,"extension":918,"lang":919,"meta":920,"navigation":921,"path":922,"readingMinutes":923,"seo":924,"standalone":925,"stem":926,"tags":927,"tldr":932,"updated":916,"url":933,"__hash__":934},"content\u002Fen\u002FPHP\u002Fthinkphp-day-19-layout.md","ThinkPHP from Scratch Day 19: Building Layouts with the Built-in Template Engine","1002716220",{"type":9,"value":10,"toc":908},"minimark",[11,16,20,24,27,35,42,45,51,62,67,81,84,246,249,270,276,361,365,372,464,467,473,476,482,485,489,496,501,507,525,531,710,716,722,745,763,781,791,873,876,882,897,901,904],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This time we're going to talk about Layout. ThinkPHP comes with its own HTML template engine, so in this post I'll walk through how to build a Layout with it.",[12,21,23],{"id":22},"a-basic-layout","A basic Layout",[17,25,26],{},"Most of the time we reach for an HTML template engine because we want to reuse shared chunks of markup — things like the header and footer. And like I mentioned earlier, ThinkPHP already has its own template engine built in, so I'll use some of the View pages we made in previous posts as the example here.",[17,28,29,30,34],{},"I'll use the ",[31,32,33],"code",{},"getAllUser.html"," we built earlier:",[17,36,37],{},[38,39],"img",{"alt":40,"src":41},"getAllUser","https:\u002F\u002Fi.imgur.com\u002FhDcK3Ab.png",[17,43,44],{},"The plan is to split the content into three blocks:",[17,46,47],{},[38,48],{"alt":49,"src":50},"three blocks","https:\u002F\u002Fi.imgur.com\u002FFZtQ5se.png",[17,52,53,54,57,58,61],{},"Next, create a folder called ",[31,55,56],{},"layout"," under ",[31,59,60],{},"view\u002Findex",":",[17,63,64],{},[38,65],{"alt":56,"src":66},"https:\u002F\u002Fi.imgur.com\u002FwwegBzi.png",[17,68,69,70,72,73,76,77,80],{},"Then inside that ",[31,71,56],{}," folder, create two HTML files — ",[31,74,75],{},"header"," and ",[31,78,79],{},"footer"," — and drop the content into them the way I showed in the image above.",[17,82,83],{},"header.html:",[85,86,91],"pre",{"className":87,"code":88,"language":89,"meta":90,"style":90},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \u003Ctitle>{$title}\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n","html","",[31,92,93,113,133,143,162,187,211,226,236],{"__ignoreMap":90},[94,95,98,102,106,110],"span",{"class":96,"line":97},"line",1,[94,99,101],{"class":100},"s8XSl","\u003C!",[94,103,105],{"class":104},"syv7_","DOCTYPE",[94,107,109],{"class":108},"sK3KL"," html",[94,111,112],{"class":100},">\n",[94,114,116,119,121,124,127,131],{"class":96,"line":115},2,[94,117,118],{"class":100},"\u003C",[94,120,89],{"class":104},[94,122,123],{"class":108}," lang",[94,125,126],{"class":100},"=",[94,128,130],{"class":129},"sWayO","\"en\"",[94,132,112],{"class":100},[94,134,136,138,141],{"class":96,"line":135},3,[94,137,118],{"class":100},[94,139,140],{"class":104},"head",[94,142,112],{"class":100},[94,144,146,149,152,155,157,160],{"class":96,"line":145},4,[94,147,148],{"class":100},"  \u003C",[94,150,151],{"class":104},"meta",[94,153,154],{"class":108}," c