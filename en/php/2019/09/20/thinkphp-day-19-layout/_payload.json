ssfully","https:\u002F\u002Fi.imgur.com\u002FEoxXtfw.png",[17,474,475],{},"And if it fails, what does that look like?",[17,477,478],{},[38,479],{"alt":480,"src":481},"the failure case, no header","https:\u002F\u002Fi.imgur.com\u002FQoOFKbj.png",[17,483,484],{},"So from this we can tell that ThinkPHP's built-in template support is pretty capable. And of course we can simplify this layout even further.",[12,486,488],{"id":487},"a-more-advanced-layout","A more advanced layout",[17,490,491,492,495],{},"Now I'll show you a slightly more advanced way to lay things out. First, create a ",[31,493,494],{},"layout.html"," and put it directly in the View root folder:",[17,497,498],{},[38,499],{"alt":56,"src":500},"https:\u002F\u002Fi.imgur.com\u002FOnl2fDn.png",[17,502,503,504,506],{},"Then fill ",[31,505,494],{}," with this:",[85,508,510],{"className":87,"code":509,"language":89,"meta":90,"style":90},"{include file=\"index\u002Flayout\u002Fheader\" \u002F}\n{__CONTENT__}\n{include file=\"index\u002Flayout\u002Ffooter\" \u002F}\n",[31,511,512,516,521],{"__ignoreMap":90},[94,513,514],{"class":96,"line":97},[94,515,381],{"class":100},[94,517,518],{"class":96,"line":115},[94,519,520],{"class":100},"{__CONTENT__}\n",[94,522,523],{"class":96,"line":135},[94,524,463],{"class":100},[17,526,527,528,530],{},"Then change the original ",[31,529,33],{}," to this:",[85,532,536],{"className":533,"code":534,"language":535,"meta":90,"style":90},"language-php shiki shiki-themes github-dark-high-contrast","{layout name=\"layout\" \u002F}\n\u003Ch1>{$title}\u003C\u002Fh1>\n{volist name=\"user\" id=\"list\"}\n\u003Cul>\n  \u003Cli>Name:{$list.name}\u003C\u002Fli>\n  \u003Cli>Weight:{$list.weight}\u003C\u002Fli>\n  \u003Cli>Height:{$list.height}\u003C\u002Fli>\n\u003C\u002Ful>\n{\u002Fvolist}\n","php",[31,537,538,559,577,601,609,638,664,690,698],{"__ignoreMap":90},[94,539,540,543,545,547,550,553,556],{"class":96,"line":97},[94,541,542],{"class":100},"{",[94,544,56],{"class":108},[94,546,171],{"cla