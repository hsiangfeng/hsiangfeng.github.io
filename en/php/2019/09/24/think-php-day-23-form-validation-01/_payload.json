[{"data":1,"prerenderedAt":1376},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F24\u002Fthink-php-day-23-form-validation-01\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F24\u002Fthink-php-day-23-form-validation-01\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F24\u002Fthink-php-day-23-form-validation-01\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F24\u002Fthink-php-day-23-form-validation-01\u002F":1353,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F24\u002Fthink-php-day-23-form-validation-01\u002F":1362},"\u002Fphp\u002F20190924\u002F3094489394\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1334,"date":1335,"description":1336,"extension":1337,"lang":1338,"meta":1339,"navigation":274,"path":1340,"readingMinutes":1341,"seo":1342,"standalone":1343,"stem":1344,"tags":1345,"tldr":1350,"updated":1335,"url":1351,"__hash__":1352},"content\u002Fen\u002FPHP\u002Fthink-php-day-23-form-validation-01.md","ThinkPHP Day 23: Form Validation, Part 1","1002755815",{"type":9,"value":10,"toc":1327},"minimark",[11,16,20,24,27,181,188,195,198,204,210,213,217,220,237,244,250,257,355,387,457,464,467,568,571,575,582,624,631,811,814,819,822,974,985,1020,1026,1032,1156,1167,1307,1313,1317,1320,1323],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Whenever you submit a form, there's usually some kind of validation kicking in behind the scenes. So what about ThinkPHP? It turns out ThinkPHP comes with its own form validation feature, so in this post I'll walk through how to use ThinkPHP's built-in validation mechanism.",[12,21,23],{"id":22},"getting-set-up","Getting set up",[17,25,26],{},"First, to make the validation actually show something meaningful, we need to create a new table to store accounts. Here's the SQL for you:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-sql shiki shiki-themes github-dark-high-contrast","CREATE TABLE think_account (\n  id int(10) NOT NULL auto_increment,\n  email varchar(15) NOT NULL default '',\n  password varchar(10) NOT NULL default 0,\n  gender int(2) NOT NULL default 0,\n  PRIMARY KEY (id)\n) AUTO_INCREMENT=1;\n","sql","",[35,36,37,57,82,110,134,157,166],"code",{"__ignoreMap":33},[38,39,42,46,49,53],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","CREATE",[38,47,48],{"class":44}," TABLE",[38,50,52],{"class":51},"sj_SG"," think_account",[38,54,56],{"class":55},"sMAXC"," (\n",[38,58,60,63,66,69,73,76,79],{"class":40,"line":59},2,[38,61,62],{"class":55},"  id ",[38,64,65],{"class":44},"int",[38,67,68],{"class":55},"(",[38,70,72],{"class":71},"sCcAr","10",[38,74,75],{"class":55},") ",[38,77,78],{"class":44},"NOT NULL",[38,80,81],{"class":55}," auto_increment,\n",[38,83,85,88,91,93,96,98,100,103,107],{"class":40,"line":84},3,[38,86,87],{"class":55},"  email ",[38,89,90],{"class":44},"varchar",[38,92,68],{"class":55},[38,94,95],{"class":71},"15",[38,97,75],{"class":55},[38,99,78],{"class":44},[38,101,102],{"class":44}," default",[38,104,106],{"class":105},"sTRMh"," ''",[38,108,109],{"class":55},",\n",[38,111,113,116,119,121,123,125,127,129,132],{"class":40,"line":112},4,[38,114,115],{"class":44},"  password",[38,117,118],{"class":44}," varchar",[38,120,68],{"class":55},[38,122,72],{"class":71},[38,124,75],{"class":55},[38,126,78],{"class":44},[38,128,102],{"class":44},[38,130,131],{"class":71}," 0",[38,133,109],{"class":55},[38,135,137,140,142,144,147,149,151,153,155],{"class":40,"line":136},5,[38,138,139],{"class":55},"  gender ",[38,141,65],{"class":44},[38,143,68],{"class":55},[38,145,146],{"class":71},"2",[38,148,75],{"class":55},[38,150,78],{"class":44},[38,152,102],{"class":44},[38,154,131],{"class":71},[38,156,109],{"class":55},[38,158,160,163],{"class":40,"line":159},6,[38,161,162],{"class":44},"  PRIMARY KEY",[38,164,165],{"class":55}," (id)\n",[38,167,169,172,175,178],{"class":40,"line":168},7,[38,170,171],{"class":55},") AUTO_INCREMENT",[38,173,174],{"class":44},"=",[38,176,177],{"class":71},"1",[38,179,180],{"class":55},";\n",[17,182,183,184,187],{},"Next, create a ",[35,185,186],{},"user"," folder, and inside the view folder create two pages: a sign-up page (signup.html) and a sign-in page (signin.html). I won't include the markup for these here ↓",[17,189,190],{},[191,192],"img",{"alt":193,"src":194},"Sign-up and sign-in pages","https:\u002F\u002Fi.imgur.com\u002FotFAGCe.png",[17,196,197],{},"So the screens will look like this ↓",[17,199,200],{},[191,201],{"alt":202,"src":203},"Sign-up page","https:\u002F\u002Fi.imgur.com\u002Fhf9tjri.png",[17,205,206],{},[191,207],{"alt":208,"src":209},"Sign-in page","https:\u002F\u002Fi.imgur.com\u002F4bZYjfk.png",[17,211,212],{},"I'm also skipping the routing and controller parts, since we've written those plenty of times already.",[12,214,216],{"id":215},"form-validation","Form validation",[17,218,219],{},"ThinkPHP provides form validation out of the box. You just need to pull in the library:",[28,221,225],{"className":222,"code":223,"language":224,"meta":33,"style":33},"language-php shiki shiki-themes github-dark-high-contrast","use think\\Validate;\n","php",[35,226,227],{"__ignoreMap":33},[38,228,229,232,235],{"class":40,"line":41},[38,230,231],{"class":44},"use",[38,233,234],{"class":71}," think\\Validate",[38,236,180],{"class":55},[17,238,239,240,243],{},"But ThinkPHP does things a little differently here. It wants you to create a folder to hold the validation source code, so you set up ",[35,241,242],{},"user\u002Fvalidate\u002Fuser.php"," like this ↓",[17,245,246],{},[191,247],{"alt":248,"src":249},"validate","https:\u002F\u002Fi.imgur.com\u002FndDkxUg.png",[17,251,252,253,256],{},"And the contents of ",[35,254,255],{},"user.php"," look like this:",[28,258,260],{"className":222,"code":259,"language":224,"meta":33,"style":33},"\u003C?php\n\nnamespace app\\user\\validate;\n\nuse think\\Validate;\n\nclass user extends Validate\n{\n  protected $rule = [];\n  protected $message = [];\n}\n",[35,261,262,270,276,287,291,299,303,317,323,337,349],{"__ignoreMap":33},[38,263,264,267],{"class":40,"line":41},[38,265,266],{"class":44},"\u003C?",[38,268,269],{"class":71},"php\n",[38,271,272],{"class":40,"line":59},[38,273,275],{"emptyLinePlaceholder":274},true,"\n",[38,277,278,281,285],{"class":40,"line":84},[38,279,280],{"class":44},"namespace",[38,282,284],{"class":283},"s_sBn"," app\\user\\validate",[38,286,180],{"class":55},[38,288,289],{"class":40,"line":112},[38,290,275],{"emptyLinePlaceholder":274},[38,292,293,295,297],{"class":40,"line":136},[38,294,231],{"class":44},[38,296,234],{"class":71},[38,298,180],{"class":55},[38,300,301],{"class":40,"line":159},[38,302,275],{"emptyLinePlaceholder":274},[38,304,305,308,311,314],{"class":40,"line":168},[38,306,307],{"class":44},"class",[38,309,310],{"class":283}," user",[38,312,313],{"class":44}," extends",[38,315,316],{"class":71}," Validate\n",[38,318,320],{"class":40,"line":319},8,[38,321,322],{"class":55},"{\n",[38,324,326,329,332,334],{"class":40,"line":325},9,[38,327,328],{"class":44},"  protected",[38,330,331],{"class":55}," $rule ",[38,333,174],{"class":44},[38,335,336],{"class":55}," [];\n",[38,338,340,342,345,347],{"class":40,"line":339},10,[38,341,328],{"class":44},[38,343,344],{"class":55}," $message ",[38,346,174],{"class":44},[38,348,336],{"class":55},[38,350,352],{"class":40,"line":351},11,[38,353,354],{"class":55},"}\n",[17,356,357,358,361,362,365,366,368,369,371,372,375,376,379,380,383,384,386],{},"There are two variables in here: ",[35,359,360],{},"$rule"," and ",[35,363,364],{},"$message",". ",[35,367,360],{}," is the fields you want to validate along with their rules, while ",[35,370,364],{}," holds the error messages to display. We have three fields to fill in — ",[35,373,374],{},"email",", ",[35,377,378],{},"password",", and ",[35,381,382],{},"gender"," — and since ",[35,385,360],{}," is an array, you can write it like this:",[28,388,390],{"className":222,"code":389,"language":224,"meta":33,"style":33},"protected $rule = [\n  'email' => 'require|email', \u002F\u002F Email must be present and a valid email format\n  'password' => 'require|min:8|max:30', \u002F\u002F required, min length 8, max length 30\n  'gender' => 'require|number',\u002F\u002F required, only accepts a number\n];\n",[35,391,392,404,421,436,452],{"__ignoreMap":33},[38,393,394,397,399,401],{"class":40,"line":41},[38,395,396],{"class":44},"protected",[38,398,331],{"class":55},[38,400,174],{"class":44},[38,402,403],{"class":55}," [\n",[38,405,406,409,412,415,417],{"class":40,"line":59},[38,407,408],{"class":105},"  'email'",[38,410,411],{"class":44}," =>",[38,413,414],{"class":105}," 'require|email'",[38,416,375],{"class":55},[38,418,420],{"class":419},"sQrFR","\u002F\u002F Email must be present and a valid email format\n",[38,422,423,426,428,431,433],{"class":40,"line":84},[38,424,425],{"class":105},"  'password'",[38,427,411],{"class":44},[38,429,430],{"class":105}," 'require|min:8|max:30'",[38,432,375],{"class":55},[38,434,435],{"class":419},"\u002F\u002F required, min length 8, max length 30\n",[38,437,438,441,443,446,449],{"class":40,"line":112},[38,439,440],{"class":105},"  'gender'",[38,442,411],{"class":44},[38,444,445],{"class":105}," 'require|number'",[38,447,448],{"class":55},",",[38,450,451],{"class":419},"\u002F\u002F required, only accepts a number\n",[38,453,454],{"class":40,"line":136},[38,455,456],{"class":55},"];\n",[17,458,459,460,463],{},"Multiple validations are just separated by ",[35,461,462],{},"|",", like above.",[17,465,466],{},"What about the messages? The more validation rules you have, the more messages you'll naturally want to send back to the user. The system does have default messages, but honestly it's better to write your own:",[28,468,470],{"className":222,"code":469,"language":224,"meta":33,"style":33},"protected $message = [\n  'email.require' => 'Email is required',\n  'email.email'=> 'Email format is invalid',\n  'password.require' => 'Password is required',\n  'password.min' => 'Password must be at least 8 characters',\n  'password.max' => 'Password must be at most 30 characters',\n  'gender.require' => 'Gender is required',\n  'gender' => 'Gender must be a number'\n];\n",[35,471,472,482,494,507,519,531,543,555,564],{"__ignoreMap":33},[38,473,474,476,478,480],{"class":40,"line":41},[38,475,396],{"class":44},[38,477,344],{"class":55},[38,479,174],{"class":44},[38,481,403],{"class":55},[38,483,484,487,489,492],{"class":40,"line":59},[38,485,486],{"class":105},"  'email.require'",[38,488,411],{"class":44},[38,490,491],{"class":105}," 'Email is required'",[38,493,109],{"class":55},[38,495,496,499,502,505],{"class":40,"line":84},[38,497,498],{"class":105},"  'email.email'",[38,500,501],{"class":44},"=>",[38,503,504],{"class":105}," 'Email format is invalid'",[38,506,109],{"class":55},[38,508,509,512,514,517],{"class":40,"line":112},[38,510,511],{"class":105},"  'password.require'",[38,513,411],{"class":44},[38,515,516],{"class":105}," 'Password is required'",[38,518,109],{"class":55},[38,520,521,524,526,529],{"class":40,"line":136},[38,522,523],{"class":105},"  'password.min'",[38,525,411],{"class":44},[38,527,528],{"class":105}," 'Password must be at least 8 characters'",[38,530,109],{"class":55},[38,532,533,536,538,541],{"class":40,"line":159},[38,534,535],{"class":105},"  'password.max'",[38,537,411],{"class":44},[38,539,540],{"class":105}," 'Password must be at most 30 characters'",[38,542,109],{"class":55},[38,544,545,548,550,553],{"class":40,"line":168},[38,546,547],{"class":105},"  'gender.require'",[38,549,411],{"class":44},[38,551,552],{"class":105}," 'Gender is required'",[38,554,109],{"class":55},[38,556,557,559,561],{"class":40,"line":319},[38,558,440],{"class":105},[38,560,411],{"class":44},[38,562,563],{"class":105}," 'Gender must be a number'\n",[38,565,566],{"class":40,"line":325},[38,567,456],{"class":55},[17,569,570],{},"And that's the form validation done.",[12,572,574],{"id":573},"the-controller","The controller",[17,576,577,578,581],{},"Next we modify the controller. We'll put the form handling in the ",[35,579,580],{},"add()"," method, and have it return the data we just sent:",[28,583,585],{"className":222,"code":584,"language":224,"meta":33,"style":33},"public function add($email, $password, $gender) {\n    return $email. $password. $gender;\n}\n",[35,586,587,601,620],{"__ignoreMap":33},[38,588,589,592,595,598],{"class":40,"line":41},[38,590,591],{"class":44},"public",[38,593,594],{"class":44}," function",[38,596,597],{"class":51}," add",[38,599,600],{"class":55},"($email, $password, $gender) {\n",[38,602,603,606,609,612,615,617],{"class":40,"line":59},[38,604,605],{"class":44},"    return",[38,607,608],{"class":55}," $email",[38,610,611],{"class":44},".",[38,613,614],{"class":55}," $password",[38,616,611],{"class":44},[38,618,619],{"class":55}," $gender;\n",[38,621,622],{"class":40,"line":84},[38,623,354],{"class":55},[17,625,626,627,630],{},"So how do you actually run the validation? You just add a ",[35,628,629],{},"validate('data', 'validator name')"," and you're set. I'll hook up the database here too, so we can see it working for real:",[28,632,634],{"className":222,"code":633,"language":224,"meta":33,"style":33},"public function add($email, $password, $gender) {\n  $user = new userModel;\n  $user->email = $email;\n  $user->password = $password;\n  $user->gender = $gender;\n  $result = $this->validate($user,'User');\n  if($result){\n  return $result;\n  }\n  if($user->save()){\n      return 'Added successfully';\n  } else {\n      return $user->getError();\n  }\n}\n",[35,635,636,646,661,677,691,704,727,735,743,748,763,773,785,801,806],{"__ignoreMap":33},[38,637,638,640,642,644],{"class":40,"line":41},[38,639,591],{"class":44},[38,641,594],{"class":44},[38,643,597],{"class":51},[38,645,600],{"class":55},[38,647,648,651,653,656,659],{"class":40,"line":59},[38,649,650],{"class":55},"  $user ",[38,652,174],{"class":44},[38,6