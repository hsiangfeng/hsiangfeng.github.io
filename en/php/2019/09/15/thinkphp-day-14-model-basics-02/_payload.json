[{"data":1,"prerenderedAt":584},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F15\u002Fthinkphp-day-14-model-basics-02\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F15\u002Fthinkphp-day-14-model-basics-02\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F15\u002Fthinkphp-day-14-model-basics-02\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F15\u002Fthinkphp-day-14-model-basics-02\u002F":560,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F15\u002Fthinkphp-day-14-model-basics-02\u002F":569},"\u002Fphp\u002F20190915\u002F2341995377\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":41,"date":541,"description":542,"extension":543,"lang":544,"meta":545,"navigation":546,"path":547,"readingMinutes":548,"seo":549,"standalone":550,"stem":551,"tags":552,"tldr":557,"updated":541,"url":558,"__hash__":559},"content\u002Fen\u002FPHP\u002Fthinkphp-day-14-model-basics-02.md","ThinkPHP from Scratch Day 14 - Model Basics, Part 2: Inserting Data","1002676625",{"type":9,"value":10,"toc":535},"minimark",[11,16,20,24,36,68,78,100,104,107,132,139,142,205,212,215,221,312,319,322,478,481,488,507,513,516,521,524,528,531],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time we got most of the Model boilerplate ready. Now it's time to actually start writing some basic data operations.",[12,21,23],{"id":22},"the-setup","The setup",[17,25,26,27,31,32,35],{},"Last post we already built a ",[28,29,30],"code",{},"create"," controller method, but right now all it does is pull the form data the frontend sends to the backend. Now we actually want to save that data into the ",[28,33,34],{},"think_user"," table we created. First, we need to add a line up top telling the Controller which Model we want to use:",[37,38,43],"pre",{"className":39,"code":40,"language":41,"meta":42,"style":42},"language-PHP shiki shiki-themes github-dark-high-contrast","use app\\about\\model\\about as aboutModel;\n","PHP","",[28,44,45],{"__ignoreMap":42},[46,47,50,54,58,61,64],"span",{"class":48,"line":49},"line",1,[46,51,53],{"class":52},"sWyjQ","use",[46,55,57],{"class":56},"sCcAr"," app\\about\\model\\about",[46,59,60],{"class":52}," as",[46,62,63],{"class":56}," aboutModel",[46,65,67],{"class":66},"sMAXC",";\n",[17,69,70,71,74,75,77],{},"Then we need to instantiate ",[28,72,73],{},"aboutModel",". To do that, we just drop one simple line inside the ",[28,76,30],{}," method:",[37,79,83],{"className":80,"code":81,"language":82,"meta":42,"style":42},"language-php shiki shiki-themes github-dark-high-contrast","$user = new aboutModel;\n","php",[28,84,85],{"__ignoreMap":42},[46,86,87,90,93,96,98],{"class":48,"line":49},[46,88,89],{"class":66},"$user ",[46,91,92],{"class":52},"=",[46,94,95],{"class":52}," new",[46,97,63],{"class":56},[46,99,67],{"class":66},[12,101,103],{"id":102},"inserting-data","Inserting data",[17,105,106],{},"Okay, so we've got the Model instantiated. But how do we actually insert data into the table?",[17,108,109,110,113,114,117,118,121,122,125,126,128,129,131],{},"Our table has three columns: ",[28,111,112],{},"name",", ",[28,115,116],{},"height",", and ",[28,119,120],{},"weight",". We point at each column using the arrow ",[28,123,124],{},"->",". I never really explained what ",[28,127,124],{}," is before — basically ",[28,130,124],{}," means \"calling something.\" I'm calling this class method, or that class property. Thinking about it that way makes it less of a headache.",[17,133,134,135,138],{},"And what about the other one, ",[28,136,137],{},"=>","? That one's for defining arrays.",[17,140,141],{},"So we can call each column name and assign a value into it like this:",[37,143,145],{"className":80,"code":144,"language":82,"meta":42,"style":42},"$user = new aboutModel;\n$user->name = $name;\n$user->height = $height;\n$user->weight = $weight;\n",[28,146,147,159,175,190],{"__ignoreMap":42},[46,148,149,151,153,155,157],{"class":48,"line":49},[46,150,89],{"class":66},[46,152,92],{"class":52},[46,154,95],{"class":52},[46,156,63],{"class":56},[46,158,67],{"class":66},[46,160,162,165,167,170,172],{"class":48,"line":161},2,[46,163,164],{"class":66},"$user",[46,166,124],{"class":52},[46,168,169],{"class":66},"name ",[46,171,92],{"class":52},[46,173,174],{"class":66}," $name;\n",[46,176,178,180,182,185,187],{"class":48,"line":177},3,[46,179,164],{"class":66},[46,181,124],{"class":52},[46,183,184],{"class":66},"height ",[46,186,92],{"class":52},[46,188,189],{"class":66}," $height;\n",[46,191,193,195,197,200,202],{"class":48,"line":192},4,[46,194,164],{"class":66},[46,196,124],{"class":52},[46,198,199],{"class":66},"weight ",[46,201,92],{"class":52},[46,203,204],{"class":66}," $weight;\n",[17,206,207,208,211],{},"In plain English: I'm calling the Model's columns and assigning values into them. Last but not least, remember to add ",[28,209,210],{},"$user -> save();"," — that's how you tell the Model \"hey, save this data.\"",[17,213,214],{},"Congrats, you just wrote your first insert operation (wait, what?!). No really, don't doubt it, it's that simple.",[17,216,217,218,220],{},"Finally, how do we know the data actually made it into the table? Since ",[28,219,210],{}," returns a boolean, we can add a check to confirm whether the insert succeeded:",[37,222,224],{"className":80,"code":223,"language":82,"meta":42,"style":42},"if($user -> save()) {\n  return '['.$user->name'.,ID是'.$user->id.']新增成功'\n} else {\n  $user->getError(); \u002F\u002F output the error\n}\n",[28,225,226,243,278,289,306],{"__ignoreMap":42},[46,227,228,231,234,236,240],{"class":48,"line":49},[46,229,230],{"class":52},"if",[46,232,233],{"class":66},"($user ",[46,235,124],{"class":52},[46,237,239],{"class":238},"sj_SG"," save",[46,241,242],{"class":66},"()) {\n",[46,244,245,248,252,255,257,259,261,264,266,268,270,273,275],{"class":48,"line":161},[46,246,247],{"class":52},"  return",[46,249,251],{"class":250},"sTRMh"," '['",[46,253,254],{"class":52},".",[46,256,164],{"class":66},[46,258,124],{"class":52},[46,260,112],{"class":66},[46,262,263],{"class":250},"'.,ID是'",[46,265,254],{"class":52},[46,267,164],{"class":66},[46,269,124],{"class":52},[46,271,272],{"class":66},"id",[46,274,254],{"class":52},[46,276,277],{"class":250},"']新增成功'\n",[46,279,280,283,286],{"class":48,"line":177},[46,281,282],{"class":66},"} ",[46,284,285],{"class":52},"else",[46,287,288],{"class":66}," {\n",[46,290,291,294,296,299,302],{"class":48,"line":192},[46,292,293],{"class":66},"  $user",[46,295,124],{"class":52},[46,297,298],{"class":238},"getError",[46,300,301],{"class":66},"(); ",[46,303,305],{"class":304},"sQrFR","\u002F\u002F output the error\n",[46,307,309],{"class":48,"line":308},5,[46,310,311],{"class":66},"}\n",[17,313,314,315,318],{},"Logic-wise: if the insert succeeds, return a \"success\" message; if it fails, use ",[28,316,317],{},"getError()"," to output the error message.",[17,320,321],{},"So the full code looks like this:",[37,323,325],{"className":80,"code":324,"language":82,"meta":42,"style":42},"public function create ($name, $height, $weight) {\n    $user = new aboutModel;\n    $user->name = $name;\n    $user->height = $height;\n    $user->weight = $weight;\n    if($user -> save()){\n        return '名稱：'.$user->name.',ID：'.$user->id.'。\u003Cbr\u002F>新增成功';\n      }else {\n        $user->getError(); \u002F\u002F output the error\n      }\n}\n",[28,326,327,341,354,367,379,391,406,443,453,467,473],{"__ignoreMap":42},[46,328,329,332,335,338],{"class":48,"line":49},[46,330,331],{"class":52},"public",[46,333,334],{"class":52}," function",[46,336,337],{"class":238}," create",[46,339,340],{"class":66}," ($name, $height, $weight) {\n",[46,342,343,346,348,350,352],{"class":48,"line":161},[46,344,345],{"class":66},"    $user ",[46,347,92],{"class":52},[46,349,95],{"class":52},[46,351,63],{"class":56},[46,353,67],{"class":66},[46,355,356,359,361,363,365],{"class":48,"line":177},[46,357,358],{"class":66},"    $user",[46,360,124],{"class":52},[46,362,169],{"class":66},[46,364,92],{"class":52},[46,366,174],{"class":66},[46,368,369,371,373,375,377],{"class":48,"line":192},[46,370,358],{"class":66},[46,372,124],{"class":52},[46,374,184],{"class":66},[46,376,92],{"class":52},[46,378,189],{"class":66},[46,380,381,383,385,387,389],{"class":48,"line":308},[46,382,358],{"class":66},[46,384,124],{"class":52},[46,386,199],{"class":66},[46,388,92],{"class":52},[46,390,204],{"class":66},[46,392,394,397,399,401,403],{"class":48,"line":393},6,[46,395,396],{"class":52},"    if",[46,398,233],{"class":66},[46,400,124],{"class":52},[46,402,239],{"class":238},[46,404,405],{"class":66},"()){\n",[46,407,409,412,415,417,419,421,423,425,428,430,432,434,436,438,441],{"class":48,"line":408},7,[46,410,411],{"class":52},"        return",[46,413,414],{"class":250}," '名稱：'",[46,416,254],{"class":52},[46,418,164],{"class":66},[46,420,124],{"class":52},[46,422,112],{"class":66},[46,424,254],{"class":52},[46,426,427],{"class":250},"',ID：'",[46,429,254],{"class":52},[46,431,164],{"class":66},[46,433,124],{"class":52},[46,435,272],{"class":66},[46,437,254],{"class":52},[46,439,440],{"class":250},"'。\u003Cbr\u002F>新增成功'",[46,442,67],{"class":66},[46,444,446,449,451],{"class":48,"line":445},8,[46,447,448],{"class":66},"      }",[46,450,285],{"class":52},[46,452,288],{"class":66},[46,454,456,459,461,463,465],{"class":48,"line":455},9,[46,457,458],{"class":66},"        $user",[46,460,124],{"class":52},[46,462,298],{"class":238},[46,464,301],{"class":66},[46,466,305],{"class":304},[46,468,470],{"class":48,"line":469},10,[46,471,472],{"class":66},"      }\n",[46,474,476],{"class":48,"line":475},11,[46,477,311],{"class":66},[17,479,480],{},"Now we can try submitting the form and see what we get back ↓",[17,482,483],{},[484,485],"img",{"alt":486,"src":487},"Name's even skinnier than me...","https:\u002F\u002Fi.imgur.com\u002FpmaRDOS.png",[17,489,490,491,494,495,499,500,503,504,254],{},"If you hit the error ",[28,492,493],{},"Access denied for user 'user'@'localhost' (using password: YES)",", it means the username\u002Fpassword for your database connection is wrong (",[496,497,498],"del",{},"I'm definitely not going to admit I forgot to fill in the password while writing this","). You can fix it by editing ",[28,501,502],{},"database.php"," under ",[28,505,506],{},"project\u002Fconfig",[17,508,509],{},[484,510],{"alt":511,"src":512},"Insert succeeded","https:\u002F\u002Fi.imgur.com\u002FdKuKnJ5.png",[17,514,515],{},"Finally, we can open up Navicat and check whether the data really made it into the table ↓",[17,517,518],{},[484,519],{"alt":511,"src":520},"https:\u002F\u002Fi.imgur.com\u002FmketglS.png",[17,522,523],{},"So that's a full insert operation, start to finish~",[12,525,527],{"id":526},"wrapping-up","Wrapping up",[17,529,530],{},"I got stuck in a weird spot while writing this, to the point where I had no choice but to reinstall the database — burned almost half an hour on it. Next post, we'll get into querying data~",[532,533,534],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":42,"searchDepth":161,"depth":161,"links":536},[537,538,539,540],