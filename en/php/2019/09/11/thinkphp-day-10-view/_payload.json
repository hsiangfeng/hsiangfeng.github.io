[{"data":1,"prerenderedAt":805},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F":781,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F11\u002Fthinkphp-day-10-view\u002F":790},"\u002Fphp\u002F20190911\u002F2404668874\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":762,"date":763,"description":764,"extension":765,"lang":766,"meta":767,"navigation":302,"path":768,"readingMinutes":769,"seo":770,"standalone":771,"stem":772,"tags":773,"tldr":778,"updated":763,"url":779,"__hash__":780},"content\u002Fen\u002FPHP\u002Fthinkphp-day-10-view.md","Learning ThinkPHP from Scratch Day 10 - The View","1002644949",{"type":9,"value":10,"toc":755},"minimark",[11,16,20,24,44,239,242,246,257,264,270,384,395,402,416,422,425,431,446,536,545,551,555,571,686,700,706,715,721,724,727,731,742,751],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This time we're going to look at the View part of MVC, basically the visual layer. Last time we covered the basics of defining a Controller, so now it's the View's turn, and we'll get to the Model after that. We'll also pick up a little bit of HTML templating along the way.",[12,21,23],{"id":22},"getting-started","Getting started",[17,25,26,27,31,32,35,36,39,40,43],{},"First, head into your project's ",[28,29,30],"code",{},"application\\about"," folder and create a ",[28,33,34],{},"view"," folder. Inside that, create a ",[28,37,38],{},"hello_world"," folder (heads up: uppercase letters get converted to lowercase), and inside that create a ",[28,41,42],{},"HelloWorld.html",". Here's the starting content for the View:",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"langu