,{"class":68},[54,165,86],{"class":60},[54,167,168],{"class":89},"\"ie=edge\"",[54,170,72],{"class":60},[54,172,174,176,179,182,184],{"class":56,"line":173},7,[54,175,108],{"class":60},[54,177,178],{"class":64},"title",[54,180,181],{"class":60},">This is the greeting screen\u003C\u002F",[54,183,178],{"class":64},[54,185,72],{"class":60},[54,187,189,192,194],{"class":56,"line":188},8,[54,190,191],{"class":60},"\u003C\u002F",[54,193,100],{"class":64},[54,195,72],{"class":60},[54,197,199,201,204],{"class":56,"line":198},9,[54,200,78],{"class":60},[54,202,203],{"class":64},"body",[54,205,72],{"class":60},[54,207,209,211,214,217,219],{"class":56,"line":208},10,[54,210,108],{"class":60},[54,212,213],{"class":64},"h1",[54,215,216],{"class":60},">Say Hi!\u003C\u002F",[54,218,213],{"class":64},[54,220,72],{"class":60},[54,222,224,226,228],{"class":56,"line":223},11,[54,225,191],{"class":60},[54,227,203],{"class":64},[54,229,72],{"class":60},[54,231,233,235,237],{"class":56,"line":232},12,[54,234,191],{"class":60},[54,236,49],{"class":64},[54,238,72],{"class":60},[17,240,241],{},"That's a basic View definition. But remember from the MVC architecture chapter: the user first requests a page from the Controller. So later on I'll pair this with a Controller to show you how to render the screen onto the View page we want.",[12,243,245],{"id":244},"rendering-the-view","Rendering the View",[17,247,248,249,252,253,256],{},"We know the user requests a page from the Controller, so let's open ",[28,250,251],{},"about\u002Fcontroller\u002FHelloWorld.php"," and tweak the code. If I want to throw out a specific page, I can use the ",[28,254,255],{},"fetch()"," method.",[17,258,259,260,263],{},"Normally, if you call it without any arguments, it'll automatically grab the template name matching the current action, for example it'll auto-fetch ",[28,261,262],{},"index.html",". But that's kind of hard to grasp just by talking about it, and personally I prefer specifying the page myself, so let's actually write some code and try it out.",[17,265,266,267,269],{},"First open ",[28,268,251],{}," and paste in the example below:",[45,271,275],{"className":272,"code":273,"language":274,"meta":50,"style":50},"language-php shiki shiki-themes github-dark-high-contrast","\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        return $this->fetch();\n    }\n}\n","php",[28,276,277,286,298,304,314,318,332,337,352,357,374,379],{"__ignoreMap":50},[54,278,279,283],{"class":56,"line":57},[54,280,282],{"class":281},"sWyjQ","\u003C?",[54,284,285],{"class":68},"php\n",[54,287,288,291,295],{"class":56,"line":75},[54,289,290],{"class":281},"namespace",[54,292,294],{"class":293},"s_sBn"," app\\about\\controller",[54,296,297],{"class":60},";\n",[54,299,300],{"class":56,"line":95},[54,301,303],{"emptyLinePlaceholder":302},true,"\n",[54,305,306,309,312],{"class":56,"line":105},[54,307,308],{"class":281},"use",[54,310,311],{"class":68}," think\\Controller",[54,313,297],{"class":60},[54,315,316],{"class":56,"line":124},[54,317,303],{"emptyLinePlaceholder":302},[54,319,320,323,326,329],{"class":56,"line":149},[54,321,322],{"class":281},"class",[54,324,325],{"class":293}," HelloWorld",[54,327,328],{"class":281}," extends",[54,330,331],{"class":68}," Controller\n",[54,333,334],{"class":56,"line":173},[54,335,336],{"class":60},"{\n",[54,338,339,342,345,349],{"class":56,"line":188},[54,340,341],{"class":281},"    public",[54,343,344],{"class":281}," function",[54,346,348],{"class":347},"sj_SG"," Hello",[54,350,351],{"class":60},"()\n",[54,353,354],{"class":56,"line":198},[54,355,356],{"class":60},"    {\n",[54,358,359,362,365,368,371],{"class":56,"line":208},[54,360,361],{"class":281},"        return",[54,363,364],{"class":68}," $this",[54,366,367],{"class":281},"->",[54,369,370],{"class":347},"fetch",[54,372,373],{"class":60},"();\n",[54,375,376],{"class":56,"line":223},[54,377,378],{"class":60},"    }\n",[54,380,381],{"class":56,"line":232},[54,382,383],{"class":60},"}\n",[17,385,386,387,390,391,394],{},"Then open your terminal and run ",[28,388,389],{},"php think run",". Next, open your browser and visit ",[28,392,393],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Fhello_world\u002Fhello",":",[17,396,397],{},[398,399],"img",{"alt":400,"src":401},"Errors out saying it can't find the template","https:\u002F\u002Fi.imgur.com\u002FOVUbs0x.png",[17,403,404,405,408,409,412,413,415],{},"The reason is that we didn't specify a template, and the Controller function is named ",[28,406,407],{},"Hello",", so ThinkPHP automatically goes looking for ",[28,410,411],{},"hello.html",". But we don't have that file yet, so let's create a ",[28,414,411],{}," and visit again:",[17,417,418],{},[398,419],{"alt":420,"src":421},"hello","https:\u002F\u002Fi.imgur.com\u002FlpP50Qd.png",[17,423,424],{},"After revisiting, the View renders successfully:",[17,426,427],{},[398,428],{"alt":429,"src":430},"Auto-resolving the template","https:\u002F\u002Fi.imgur.com\u002FzKDTuL9.png",[17,432,433,434,436,437,439,440,442,443,445],{},"But what if we want visiting ",[28,435,393],{}," to pop up the ",[28,438,42],{}," page instead? Then we just tweak ",[28,441,251],{}," and pass the HTML filename we want to render into ",[28,444,255],{},". Here's an example:",[45,447,449],{"className":272,"code":448,"language":274,"meta":50,"style":50},"\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        return $this->fetch('HelloWorld');\n    }\n}\n",[28,450,451,457,465,469,477,481,491,495,505,509,528,532],{"__ignoreMap":50},[54,452,453,455],{"class":56,"line":57},[54,454,282],{"class":281},[54,456,285],{"class":68},[54,458,459,461,463],{"class":56,"line":75},[54,460,290],{"class":281},[54,462,294],{"class":293},[54,464,297],{"class":60},[54,466,467],{"class":56,"line":95},[54,468,303],{"emptyLinePlaceholder":302},[54,470,471,473,475],{"class":56,"line":105},[54,472,308],{"class":281},[54,474,311],{"class":68},[54,476,297],{"class":60},[54,478,479],{"class":56,"line":124},[54,480,303],{"emptyLinePlaceholder":302},[54,482,483,485,487,489],{"class":56,"line":149},[54,484,322],{"class":281},[54,486,325],{"class":293},[54,488,328],{"class":281},[54,490,331],{"class":68},[54,492,493],{"class":56,"line":173},[54,494,336],{"class":60},[54,496,497,499,501,503],{"class":56,"line":188},[54,498,341],{"class":281},[54,500,344],{"class":281},[54,502,348],{"class":347},[54,504,351],{"class":60},[54,506,507],{"class":56,"line":198},[54,508,356],{"class":60},[54,510,511,513,515,517,519,522,525],{"class":56,"line":208},[54,512,361],{"class":281},[54,514,364],{"class":68},[54,516,367],{"class":281},[54,518,370],{"class":347},[54,520,521],{"class":60},"(",[54,523,524],{"class":89},"'HelloWorld'",[54,526,527],{"class":60},");\n",[54,529,530],{"class":56,"line":223},[54,531,378],{"class":60},[54,533,534],{"class":56,"line":232},[54,535,383],{"class":60},[17,537,538,539,541,542,544],{},"Now when we visit ",[28,540,393],{},", it automatically resolves the ",[28,543,42],{}," template:",[17,546,547],{},[398,548],{"alt":549,"src":550},"HelloWorld","https:\u002F\u002Fi.imgur.com\u002FZRadyMm.png",[12,552,554],{"id":553},"the-template-engine","The template engine",[17,556,557,558,561,562,565,566,568,569,269],{},"ThinkPHP comes with a built-in template engine, and it's really simple to use. You just wrap things in ",[28,559,560],{},"{$ }"," inside your HTML. But make sure you actually pass the parameter, otherwise it'll error out. The way you send parameters to the front end is with ",[28,563,564],{},"assign()",", which goes right before ",[28,567,255],{},". Let's open ",[28,570,251],{},[45,572,574],{"className":272,"code":573,"language":274,"meta":50,"style":50},"\u003C?php\nnamespace app\\about\\controller;\n\nuse think\\Controller;\n\nclass HelloWorld extends Controller\n{\n    public function Hello()\n    {\n        $name = 'iThome';\n        return $this->assign('name',$name) -> fetch(); \u002F\u002F assign('the parameter name you plan to send to the front end', value)\n    }\n}\n",[28,575,576,582,590,594,602,606,616,620,630,634,646,677,681],{"__ignoreMap":50},[54,577,578,580],{"class":56,"line":57},[54,579,282],{"class":281},[54,581,285],{"class":68},[54,583,584,586,588],{"class":56,"line":75},[54,585,290],{"class":281},[54,587,294],{"class":293},[54,589,297],{"class":60},[54,591,592],{"class":56,"line":95},[54,593,303],{"emptyLinePlaceholder":302},[54,595,596,598,600],{"class":56,"line":105},[54,597,308],{"class":281},[54,599,311],{"class":68},[54,601,297],{"class":60},[54,603,604],{"class":56,"line":124},[54,605,303],{"emptyLinePlaceholder":302},[54,607,608,610,612,614],{"class":56,"line":149},[54,609,322],{"class":281},[54,611,325],{"class":293},[54,613,328],{"class":281},[54,615,331],{"class":68},[54,617,618],{"class":56,"line":173},[54,619,336],{"class":60},[54,621,622,624,626,628],{"class":56,"line":188},[54,623,341],{"class":281},[54,625,344],{"class":281},[54,627,348],{"class":347},[54,629,351],{"class":60},[54,631,632],{"class":56,"line":198},[54,633,356],{"class":60},[54,635,636,639,641,644],{"class":56,"line":208},[54,637,638],{"class":60},"        $name ",[54,640,86],{"class":281},[54,642,643],{"class":89}," 'iThome'",[54,645,297],{"class":60},[54,647,648,650,652,654,657,659,662,665,667,670,673],{"class":56,"line":223},[54,649,361],{"class":281},[54,651,364],{"class":68},[54,653,367],{"class":281},[54,655,656],{"class":347},"assign",[54,658,521],{"class":60},[54,660,661],{"class":89},"'name'",[54,663,664],{"class":60},",$name) ",[54,666,367],{"class":281},[54,668,669],{"class":347}," fetch",[54,671,672],{"class":60},"(); ",[54,674,676],{"class":675},"sQrFR","\u002F\u002F assign('the parameter name you plan to send to the front end', value)\n",[54,678,679],{"class":56,"line":232},[54,680,378],{"class":60},[54,682,684],{"class":56,"line":683},13,[54,685,383],{"class":60},[17,687,688,689,692,693,696,697,699],{},"Next, open ",[28,690,691],{},"application\u002Fabout\u002Fview\u002Fhello_world\u002Fhello.html"," and add this little line inside the body: ",[28,694,695],{},"\u003Ch5>This is a parameter passed through the Controller: a Hello, {$name}!\u003C\u002Fh5>",". Now revisit ",[28,698,393],{}," and you'll see the result:",[17,701,702],{},[398,703],{"alt":704,"src":705},"iThome","https:\u002F\u002Fi.imgur.com\u002FdKGyML8.png",[17,707,708,709,711,712,394],{},"If you don't want to use the ",[28,710,560],{}," syntax for parsing, ThinkPHP actually gives you an option to change it. You'll find the relevant settings under ",[28,713,714],{},"config\u002Ftemplate.php",[17,716,717],{},[398,718],{"alt":719,"src":720},"template","https:\u002F\u002Fi.imgur.com\u002Fn7Pg8sC.png",[17,722,723],{},"Personally I wouldn't recommend changing this option, since it'll just confuse whoever maintains the project later.",[17,725,726],{},"Going forward I'll gradually cover more HTML templating alongside the actual examples, showing which other HTML template features you can use. Basically anything you can think of, ThinkPHP's built-in HTML templating has it, like the usual loops and conditionals.",[12,728,730],{"id":729},"wrapping-up","Wrapping up",[17,732,733,734,741],{},"The official docs also offer a third-party template engine that works a bit like AngularJS's template engine. For the specifics, check out ",[735,736,740],"a",{"href":737,"rel":738},"https:\u002F\u002Fwww.kancloud.cn\u002Fshuai\u002Fphp-angular",[739],"nofollow","this manual",".",[17,743,744,745,750],{},"There's also a Twig template engine option, ",[735,746,749],{"href":747,"rel":748},"https:\u002F\u002Fgithub.com\u002Fyunwuxin\u002Fthink-twig",[739],"think-twig",". Personally I lean toward sticking with native development, mostly because I'm not sure whether other template engines might have compatibility issues with ThinkPHP.",[752,753,754]