[{"data":1,"prerenderedAt":1134},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F18\u002Fthinkphp-day-17-data-operations-query-builder\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F18\u002Fthinkphp-day-17-data-operations-query-builder\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F18\u002Fthinkphp-day-17-data-operations-query-builder\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F18\u002Fthinkphp-day-17-data-operations-query-builder\u002F":1110,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F18\u002Fthinkphp-day-17-data-operations-query-builder\u002F":1119},"\u002Fphp\u002F20190918\u002F629335687\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1090,"date":1091,"description":1092,"extension":1093,"lang":1094,"meta":1095,"navigation":1096,"path":1097,"readingMinutes":1098,"seo":1099,"standalone":1100,"stem":1101,"tags":1102,"tldr":1107,"updated":1091,"url":1108,"__hash__":1109},"content\u002Fen\u002FPHP\u002Fthinkphp-day-17-data-operations-query-builder.md","Day 17 - Learning ThinkPHP from Scratch: Data Operations with the Query Builder","1002700382",{"type":9,"value":10,"toc":1077},"minimark",[11,16,20,24,27,36,40,56,61,64,122,125,181,184,216,219,223,230,280,289,293,296,327,333,375,378,429,432,436,439,480,484,498,665,668,675,715,718,975,979,982,1043,1061,1065,1073],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"In the last post on data operations, we wrote everything with raw SQL commands. So what about this one? This time we're going to use a feature ThinkPHP gives us — the query builder — to handle our data operations.",[12,21,23],{"id":22},"the-query-builder","The Query Builder",[17,25,26],{},"I'm not totally sure why the official docs translate it the way they do, but basically ThinkPHP wraps up a bunch of SQL commands into ready-made methods, mainly so we can do data operations more easily. And these operations are built on PDO (PHP Data Objects) parameter binding. PDO protects your system from SQL injection, so you don't have to manually escape special characters yourself.",[17,28,29,30,35],{},"If you want to read up on SQL injection, I wrote another article about it. It's maybe not the best explanation, but there are some small examples you can look at: ",[31,32,34],"a",{"href":33},"\u002Fnodejs\u002F20190717\u002F3433181406\u002F","The Legend of a Full-Stack Warrior named Koa - MySQL chapter - SQL injection"," (article in Mandarin)",[12,37,39],{"id":38},"how-to-write-it","How to write it",[17,41,42,43,47,48,51,52,55],{},"Since I want to keep the previous code around for comparison, I'll keep writing inside the ",[44,45,46],"code",{},"dbexample"," controller. But for the methods written with the query builder, I'm going to slap a prefix on all of them — ",[44,49,50],{},"sqlXxx",". So the insert method becomes ",[44,53,54],{},"sqlAdd",", and so on.",[57,58,60],"h3",{"id":59},"inserting-data","Inserting data",[17,62,63],{},"The query builder syntax is super clean, so let's start with the insert:",[65,66,71],"pre",{"className":67,"code":68,"language":69,"meta":70,"style":70},"language-php shiki shiki-themes github-dark-high-contrast","Db::table('think_db')->insert(['name'=>'陳春嬌']);\n","php","",[44,72,73],{"__ignoreMap":70},[74,75,78,82,86,90,94,98,101,104,107,110,113,116,119],"span",{"class":76,"line":77},"line",1,[74,79,81],{"class":80},"sCcAr","Db",[74,83,85],{"class":84},"sWyjQ","::",[74,87,89],{"class":88},"sj_SG","table",[74,91,93],{"class":92},"sMAXC","(",[74,95,97],{"class":96},"sTRMh","'think_db'",[74,99,100],{"class":92},")",[74,102,103],{"class":84},"->",[74,105,106],{"class":88},"insert",[74,108,109],{"class":92},"([",[74,111,112],{"class":96},"'name'",[74,114,115],{"class":84},"=>",[74,117,118],{"class":96},"'陳春嬌'",[74,120,121],{"class":92},"]);\n",[17,123,124],{},"And that's it — a basic insert method, done. Let's quickly compare the raw SQL version against the query builder version. Here's the raw SQL:",[65,126,128],{"className":67,"code":127,"language":69,"meta":70,"style":70},"$result = Db::execute('INSERT INTO think_db (name) VALUE (\"王大明\")');\ndump($result);\n",[44,129,130,172],{"__ignoreMap":70},[74,131,132,135,138,141,143,146,148,151,154,157,160,163,166,169],{"class":76,"line":77},[74,133,134],{"class":92},"$result ",[74,136,137],{"class":84},"=",[74,139,140],{"class":80}," Db",[74,142,85],{"class":84},[74,144,145],{"class":88},"execute",[74,147,93],{"class":92},[74,149,150],{"class":96},"'",[74,152,153],{"class":84},"INSERT INTO",[74,155,156],{"class":96}," think_db (",[74,158,159],{"class":84},"name",[74,161,162],{"class":96},") ",[74,164,165],{"class":84},"VALUE",[74,167,168],{"class":96}," (\"王大明\")'",[74,170,171],{"class":92},");\n",[74,173,175,178],{"class":76,"line":174},2,[74,176,177],{"class":88},"dump",[74,179,180],{"class":92},"($result);\n",[17,182,183],{},"And here's the query builder version that ThinkPHP gives us:",[65,185,186],{"className":67,"code":68,"language":69,"meta":70,"style":70},[44,187,188],{"__ignoreMap":70},[74,189,190,192,194,196,198,200,202,204,206,208,210,212,214],{"class":76,"line":77},[74,191,81],{"class":80},[74,193,85],{"class":84},[74,195,89],{"class":88},[74,197,93],{"class":92},[74,199,97],{"class":96},[74,201,100],{"class":92},[74,203,103],{"class":84},[74,205,106],{"class":88},[74,207,109],{"class":92},[74,209,112],{"class":96},[74,211,115],{"class":84},[74,213,118],{"class":96},[74,215,121],{"class":92},[17,217,218],{},"Way cleaner by comparison. The only extra thing is you have to specify the table name, otherwise ThinkPHP has no idea where you want to insert the data.",[57,220,222],{"id":221},"updating-data","Updating data",[17,224,225,226,229],{},"What about updating? It's actually pretty simple too, but you bring along a ",[44,227,228],{},"where"," — a condition that decides which row gets updated:",[65,231,233],{"className":67,"code":232,"language":69,"meta":70,"style":70},"Db::table('think_db')->where('name','陳春嬌')->updata(['name'=>'陳秋嬌']);\n",[44,234,235],{"__ignoreMap":70},[74,236,237,239,241,243,245,247,249,251,253,255,257,260,262,264,266,269,271,273,275,278],{"class":76,"line":77},[74,238,81],{"class":80},[74,240,85],{"class":84},[74,242,89],{"class":88},[74,244,93],{"class":92},[74,246,97],{"class":96},[74,248,100],{"class":92},[74,250,103],{"class":84},[74,252,228],{"class":88},[74,254,93],{"class":92},[74,256,112],{"class":96},[74,258,259],{"class":92},",",[74,261,118],{"class":96},[74,263,100],{"class":92},[74,265,103],{"class":84},[74,267,268],{"class":88},"updata",[74,270,109],{"class":92},[74,272,112],{"class":96},[74,274,115],{"class":84},[74,276,277],{"class":96},"'陳秋嬌'",[74,279,121],{"class":92},[17,281,282,283,285,286,288],{},"Just note that you have to call ",[44,284,228],{}," first and then ",[44,287,268],{},", otherwise you'll run into an error.",[57,290,292],{"id":291},"querying-data","Querying data",[17,294,295],{},"Querying can be split into \"select everything\" and \"select one\". Let me write the \"select everything\" version first:",[65,297,299],{"className":67,"code":298,"language":69,"meta":70,"style":70},"Db::table('think_db')->select(); \u002F\u002F super short (?!)\n",[44,300,301],{"__ignoreMap":70},[74,302,303,305,307,309,311,313,315,317,320,323],{"class":76,"line":77},[74,304,81],{"class":80},[74,306,85],{"class":84},[74,308,89],{"class":88},[74,310,93],{"class":92},[74,312,97],{"class":96},[74,314,100],{"class":92},[74,316,103],{"class":84},[74,318,319],{"class":88},"select",[74,321,322],{"class":92},"(); ",[74,324,326],{"class":325},"sQrFR","\u002F\u002F super short (?!)\n",[17,328,329,330,332],{},"And the single query? Same deal — you pair it with ",[44,331,228],{}," to do the lookup:",[65,334,336],{"className":67,"code":335,"language":69,"meta":70,"style":70},"Db::table('think_db')->where('name','陳秋嬌')->select(); \u002F\u002F still super short (?!)\n",[44,337,338],{"__ignoreMap":70},[74,339,340,342,344,346,348,350,352,354,356,358,360,362,364,366,368,370,372],{"class":76,"line":77},[74,341,81],{"class":80},[74,343,85],{"class":84},[74,345,89],{"class":88},[74,347,93],{"class":92},[74,349,97],{"class":96},[74,351,100],{"class":92},[74,353,103],{"class":84},[74,355,228],{"class":88},[74,357,93],{"class":92},[74,359,112],{"class":96},[74,361,259],{"class":92},[74,363,277],{"class":96},[74,365,100],{"class":92},[74,367,103],{"class":84},[74,369,319],{"class":88},[74,371,322],{"class":92},[74,373,374],{"class":325},"\u002F\u002F still super short (?!)\n",[17,376,377],{},"We can also look back at the single-query raw SQL we wrote in the last post:",[65,379,381],{"className":67,"code":380,"language":69,"meta":70,"style":70},"$result = Db::query('SELECT * FROM think_db WHERE name=\"QQ 先生\"');\ndump($result);\n",[44,382,383,423],{"__ignoreMap":70},[74,384,385,387,389,391,393,396,398,400,403,406,409,412,415,418,421],{"class":76,"line":77},[74,386,134],{"class":92},[74,388,137],{"class":84},[74,390,140],{"class":80},[74,392,85],{"class":84},[74,394,395],{"class":88},"query",[74,397,93],{"class":92},[74,399,150],{"class":96},[74,401,402],{"class":84},"SELECT",[74,404,405],{"class":84}," *",[74,407,408],{"class":84}," FROM",[74,410,411],{"class":96}," think_db ",[74,413,414],{"class":84},"WHERE",[74,416,417],{"class":84}," name=",[74,419,420],{"class":96},"\"QQ 先生\"'",[74,422,171],{"class":92},[74,424,425,427],{"class":76,"line":174},[74,426,177],{"class":88},[74,428,180],{"class":92},[17,430,431],{},"You can see that data operations written with the query builder really are a lot simpler. But you do still need to understand the basic SQL underneath, otherwise it'll feel like you're doing magic tricks.",[57,433,435],{"id":434},"deleting-data","Deleting data",[17,437,438],{},"I bet that after all that practice above, the clever you already knows how to write the delete. Before deleting data, you absolutely have to filter with a condition first and then run the delete — otherwise things can go tragically wrong:",[65,440,442],{"className":67,"code":441,"language":69,"meta":70,"style":70},"Db::table('think_db')->where('name','陳秋嬌')->delete();\n",[44,443,444],{"__ignoreMap":70},[74,445,446,448,450,452,454,456,458,460,462,464,466,468,470,472,474,477],{"class":76,"line":77},[74,447,81],{"class":80},[74,449,85],{"class":84},[74,451,89],{"class":88},[74,453,93],{"class":92},[74,455,97],{"class":96},[74,457,100],{"class":92},[74,459,103],{"class":84},[74,461,228],{"class":88},[74,463,93],{"class":92},[74,465,112],{"class":96},[74,467,259],{"class":92},[74,469,277],{"class":96},[74,471,100],{"class":92},[74,473,103],{"class":84},[74,475,476],{"class":88},"delete",[74,478,479],{"class":92},"();\n",[57,481,483],{"id":482},"simplifying-the-syntax","Simplifying the syntax",[17,485,486,487,489,490,493,494,497],{},"There's another trick: we can shorten the ",[44,488,89],{}," call so we don't have to type out ",[44,491,492],{},"think_",". By setting things up in ",[44,495,496],{},"database.php",", we can have ThinkPHP automatically add the prefix for us. That works too:",[65,499,501],{"className":67,"code":500,"language":69,"meta":70,"style":70},"Db::table('db')->insert(['name'=>'陳春嬌']);\nDb::table('db')->where('name','陳春嬌')->updata(['name'=>'陳秋嬌']);\nDb::table('db')->select();\nDb::table('db')->where('name','陳秋嬌')->select();\nDb::table('db')->where('name','陳秋嬌')->delete();\n",[44,502,503,532,574,595,630],{"__ignoreMap":70},[74,504,505,507,509,511,513,516,518,520,522,524,526,528,530],{"class":76,"line":77},[74,506,81],{"class":80},[74,508,85],{"class":84},[74,510,89],{"class":88},[74,512,93],{"class":92},[74,514,515],{"class":96},"'db'",[74,517,100],{"class":92},[74,519,103],{"class":84},[74,521,106],{"class":88},[74,523,109],{"class":92},[74,525,112],{"class":96},[74,527,115],{"class":84},[74,529,118],{"class":96},[74,531,121],{"class":92},[74,533,534,536,538,540,542,544,546,548,550,552,554,556,558,560,562,564,566,568,570,572],{"class":76,"line":174},[74,535,81],{"class":80},[74,537,85],{"class":84},[74,539,89],{"class":88},[74,541,93],{"class":92},[74,543,515],{"class":96},[74,545,100],{"class":92},[74,547,103],{"class":84},[74,549,228],{"class":88},[74,551,93],{"class":92},[74,553,112],{"class":96},[74,555,259],{"class":92},[74,557,118],{"class":96},[74,559,100],{"class":92},[74,561,103],{"class":84},[74,563,268],{"class":88},[74,565,109],{"class":92},[74,567,112],{"class":96},[74,569,115],{"class":84},[74,571,277],{"class":96},[74,573,121],{"class":92},[74,575,577,579,581,583,585,587,589,591,593],{"class":76,"line":576},3,[74,578,81],{"class":80},[74,580,85],{"class":84},[74,582,89],{"class":88},[74,584,93],{"class":92},[74,586,515],{"class":96},[74,588,100],{"class":92},[74,590,103],{"class":84},[74,592,319],{"class":88},[74,594,479],{"class":92},[74,596,598,600,602,604,606,608,610,612,614,616,618,620,622,624,626,628],{"class":76,"line":597},4,[74,599,81],{"class":80},[74,601,85],{"class":84},[74,603,89],{"class":88},[74,605,93],{"class":92},[74,607,515],{"class":96},[74,609,100],{"class":92},[74,611,103],{"class":84},[74,613,228],{"class":88},[74,615,93],{"class":92},[74,617,112],{"class":96},[74,619,259],{"class":92},[74,621,277],{"class":96},[74,623,100],{"class":92},[74,625,103],{"class":84},[74,627,319],{"class":88},[74,629,479],{"class":92},[74,631,633,635,637,639,641,643,645,647,649,651,653,655,657,659,661,663],{"class":76,"line":632},5,[74,634,81],{"class":80},[74,636,85],{"class":84},[74,638,89],{"class":88},[74,640,93],{"class":92},[74,642,515],{"class":96},[74,644,100],{"class":92},[74,646,103],{"class":84},[74,648,228],{"class":88},[74,650,93],{"class":92},[74,652,112],{"class":96},[74,654,259],{"class":92},[74,656,277],{"class":96},[74,658,100],{"class":92},[74,660,103],{"class":84},[74,662,476],{"class":88},[74,664,479],{"class":92},[17,666,667],{},"The upside is that when the table name changes, we don't have to go back and adjust all these blocks. Personally though, I'm more used to writing out the prefix.",[17,669,670,671,674],{},"Of course we can simplify the code even further. For example, instead of writing ",[44,672,673],{},"table('db')"," on every single line, we can shorten it like this:",[65,676,678],{"className":67,"code":677,"language":69,"meta":70,"style":70},"$db = db('db');\n$db->insert(['name'=>'陳春嬌']);\n",[44,679,680,696],{"__ignoreMap":70},[74,681,682,685,687,690,692,694],{"class":76,"line":77},[74,683,684],{"class":92},"$db ",[74,686,137],{"class":84},[74,688,689],{"class":88}," db",[74,691,93],{"class":92},[74,693,515],{"class":96},[74,695,171],{"class":92},[74,697,698,701,703,705,707,709,711,713],{"class":76,"line":174},[74,699,700],{"class":92},"$db",[74,702,103],{"class":84},[74,704,106],{"class":88},[74,706,109],{"class":92},[74,708,112],{"class":96},[74,710,115],{"class":84},[74,712,118],{"class":96},[74,714,121],{"class":92},[17,716,717],{},"And after all the shortening, the full code ends up looking this clean:",[65,719,721],{"className":67,"code":720,"language":69,"meta":70,"style":70},"public function sqlAdd()\n{\n  $db = db('db');\n  $db->insert(['name'=>'陳春嬌']);\n}\npublic function sqlUpdata()\n{\n  $db = db('db');\n  $db->where('name','陳春嬌')->updata(['name'=>'陳秋嬌']);\n}\npublic function sqlSelect()\n{\n  $db = db('db');\n  $db->where('name','陳秋嬌')->select();\n}\npublic function sqlDelete()\n{\n  $db = db('db');\n  $db->where('name','陳秋嬌')->delete();\n}\n",[44,722,723,737,742,757,776,781,793,798,813,846,851,863,868,883,908,913,925,930,945,970],{"__ignoreMap":70},[74,724,725,728,731,734],{"class":76,"line":77},[74,726,727],{"class":84},"public",[74,729,730],{"class":84}," function",[74,732,733],{"class":88}," sqlAdd",[74,735,736],{"class":92},"()\n",[74,738,739],{"class":76,"line":174},[74,740,741],{"class":92},"{\n",[74,743,744,747,749,751,753,755],{"class":76,"line":576},[74,745,746],{"class":92},"  $db ",[74,748,137],{"class":84},[74,750,689],{"class":88},[74,752,93],{"class":92},[74,754,515],{"class":96},[74,756,171],{"class":92},[74,758,759,762,764,766,768,770,772,774],{"class":76,"line":597},[74,760,761],{"class":92},"  $db",[74,763,103],{"class":84},[74,765,106],{"class":88},[74,767,109],{"class":92},[74,769,112],{"class":96},[74,771,115],{"class":84},[74,773,118],{"class":96},[74,775,121],{"class":92},[74,777,778],{"class":76,"line":632},[74,779,780],{"class":92},"}\n",[74,782,784,786,788,791],{"class":76,"line":783},6,[74,785,727],{"class":84},[74,787,730],{"class":84},[74,789,790],{"class":88}," sqlUpdata",[74,792,736],{"class":92},[74,794,796],{"class":76,"line":795},7,[74,797,741],{"class":92},[74,799,801,803,805,807,809,811],{"class":76,"line":800},8,[74,802,746],{"class":92},[74,804,137],{"class":84},[74,806,689],{"class":88},[74,808,93],{"class":92},[74,810,515],{"class":96},[74,812,171],{"class":92},[74,814,816,818,820,822,824,826,828,830,832,834,836,838,840,842,844],{"class":76,"line":815},9,[74,817,761],{"class":92},[74,819,103],{"class":84},[74,821,228],{"class":88},[74,823,93],{"class":92},[74,825,112],{"class":96},[74,827,259],{"class":92},[74,829,118],{"class":96},[74,831,100],{"class":92},[74,833,103],{"class":84},[74,835,268],{"class":88},[74,837,109],{"class":92},[74,839,112],{"class":96},[74,841,115],{"class":84},[74,843,277],{"class":96},[74,845,121],{"class":92},[74,847,849],{"class":76,"line":848},10,[74,850,780],{"class":92},[74,852,854,856,858,861],{"class":76,"line":853},11,[74,855,727],{"class":84},[74,857,730],{"class":84},[74,859,860],{"class":88}," sqlSelect",[74,862,736],{"class":92},[74,864,866],{"class":76,"line":865},12,[74,867,741],{"class":92},[74,869,871,873,875,877,879,881],{"class":76,"line":870},13,[74,872,746],{"class":92},[74,874,137],{"class":84},[74,876,689],{"class":88},[74,878,93],{"class":92},[74,880,515],{"class":96},[74,882,171],{"class":92},[74,884,886,888,890,892,894,896,898,900,902,904,906],{"class":76,"line":885},14,[74,887,761],{"class":92},[74,889,103],{"class":84},[74,891,228],{"class":88},[74,893,93],{"class":92},[74,895,112],{"class":96},[74,897,259],{"class":92},[74,89