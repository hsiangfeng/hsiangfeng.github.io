14],{"class":96},"'id'",[74,1016,259],{"class":92},[74,1018,1019],{"class":96},"'desc'",[74,1021,100],{"class":92},[74,1023,103],{"class":84},[74,1025,1026],{"class":88},"limit",[74,1028,93],{"class":92},[74,1030,1031],{"class":96},"'2'",[74,1033,100],{"class":92},[74,1035,103],{"class":84},[74,1037,319],{"class":88},[74,1039,322],{"class":92},[74,1041,1042],{"class":325},"\u002F\u002F sort descending, and limit the query to two rows\n",[17,1044,1045,1046,1049,1050,1053,1054,1060],{},"The two you'll usually see most are ",[44,1047,1048],{},"order()"," and ",[44,1051,1052],{},"limit()",", but there are plenty of others you can use too. I'd recommend checking the ",[31,1055,1059],{"href":1056,"rel":1057},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354005",[1058],"nofollow","official dev manual"," for the full list.",[12,1062,1064],{"id":1063},"wrap-up","Wrap-up",[17,1066,1067,1068,1072],{},"I didn't cover route registration here, because I've already gone over it plenty of times, so I'll skip the setup this time. Next up I'm planning to circle back to the ",[1069,1070,1071],"strong",{},"Model basic operations"," series — after all, we now know how to do data operations with both raw SQL commands and the query builder, and the query builder in particular is something we'll be using a lot down the road.",[1074,1075,1076],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki s