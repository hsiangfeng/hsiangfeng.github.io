[{"data":1,"prerenderedAt":748},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F28\u002Fthinkphp-day-27-pagination\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F28\u002Fthinkphp-day-27-pagination\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F28\u002Fthinkphp-day-27-pagination\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F28\u002Fthinkphp-day-27-pagination\u002F":724,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F28\u002Fthinkphp-day-27-pagination\u002F":733},"\u002Fphp\u002F20190928\u002F142867792\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":705,"date":706,"description":707,"extension":708,"lang":709,"meta":710,"navigation":562,"path":711,"readingMinutes":712,"seo":713,"standalone":714,"stem":715,"tags":716,"tldr":721,"updated":706,"url":722,"__hash__":723},"content\u002Fen\u002FPHP\u002Fthinkphp-day-27-pagination.md","ThinkPHP Pagination: Built-in Pages and a Custom Bootstrap Style","1002787491",{"type":9,"value":10,"toc":698},"minimark",[11,16,20,24,40,47,53,152,155,161,168,338,345,351,358,362,365,380,386,389,394,401,407,425,445,511,514,520,524,541,606,609,614,621,673,676,681,685,694],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Next up I want to talk about a feature pretty much every website needs at some point: pagination. ThinkPHP actually gives you pagination out of the box, so the question is just how to use it. That's what this post is about.",[12,21,23],{"id":22},"pagination","Pagination",[17,25,26,27,31,32,35,36,39],{},"ThinkPHP comes with pagination built in. It's a pretty basic style, but all you really need to do is call ",[28,29,30],"code",{},"paginate()"," and pair it with some HTML and you're done. Let me just show you with code. For the example I'm going to reuse the ",[28,33,34],{},"all()"," method in ",[28,37,38],{},"about\u002Fcontroller\u002Findex.php"," and modify it. But before that, here's what the data looks like right now.",[17,41,42],{},[43,44],"img",{"alt":45,"src":46},"I've added the data up to 10 records","https:\u002F\u002Fi.imgur.com\u002FDeBLU5c.png",[17,48,49,50,52],{},"Say I only want to output 5 records per page and then flip to the next page. I'll just copy ",[28,51,34],{}," and rewrite it like this:",[54,55,60],"pre",{"className":56,"code":57,"language":58,"meta":59,"style":59},"language-php shiki shiki-themes github-dark-high-contrast","public function page() {\n    $user = aboutModel::paginate(5);\n    return $this->assign('user', $user)->fetch('page');\n}\n","php","",[28,61,62,82,110,146],{"__ignoreMap":59},[63,64,67,71,74,78],"span",{"class":65,"line":66},"line",1,[63,68,70],{"class":69},"sWyjQ","public",[63,72,73],{"class":69}," function",[63,75,77],{"class":76},"sj_SG"," page",[63,79,81],{"class":80},"sMAXC","() {\n",[63,83,85,88,91,95,98,101,104,107],{"class":65,"line":84},2,[63,86,87],{"class":80},"    $user ",[63,89,90],{"class":69},"=",[63,92,94],{"class":93},"sCcAr"," aboutModel",[63,96,97],{"class":69},"::",[63,99,100],{"class":76},"paginate",[63,102,103],{"class":80},"(",[63,105,106],{"class":93},"5",[63,108,109],{"class":80},");\n",[63,111,113,116,119,122,125,127,131,134,136,139,141,144],{"class":65,"line":112},3,[63,114,115],{"class":69},"    return",[63,117,118],{"class":93}," $this",[63,120,121],{"class":69},"->",[63,123,124],{"class":76},"assign",[63,126,103],{"class":80},[63,128,130],{"class":129},"sTRMh","'user'",[63,132,133],{"class":80},", $user)",[63,135,121],{"class":69},[63,137,138],{"class":76},"fetch",[63,140,103],{"class":80},[63,142,143],{"class":129},"'page'",[63,145,109],{"class":80},[63,147,149],{"class":65,"line":148},4,[63,150,151],{"class":80},"}\n",[17,153,154],{},"Under normal conditions you should see only 5 records showing up.",[17,156,157],{},[43,158],{"alt":159,"src":160},"Five records","https:\u002F\u002Fi.imgur.com\u002FZYreTXP.png",[17,162,163,164,167],{},"Next, create a ",[28,165,166],{},"page.html"," view with the following content:",[54,