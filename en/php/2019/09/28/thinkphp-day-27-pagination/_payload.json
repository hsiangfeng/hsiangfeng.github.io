],{"class":80},[63,257,258],{"class":129},"\"list-group-item\"",[63,260,261],{"class":80},">Name:{$list.name}\u003C\u002F",[63,263,230],{"class":187},[63,265,199],{"class":80},[63,267,269,271,273,275,277,279,282,284],{"class":65,"line":268},7,[63,270,227],{"class":80},[63,272,230],{"class":187},[63,274,191],{"class":93},[63,276,90],{"class":80},[63,278,258],{"class":129},[63,280,281],{"class":80},">Weight:{$list.weight}\u003C\u002F",[63,283,230],{"class":187},[63,285,199],{"class":80},[63,287,289,291,293,295,297,299,302,304],{"class":65,"line":288},8,[63,290,227],{"class":80},[63,292,230],{"class":187},[63,294,191],{"class":93},[63,296,90],{"class":80},[63,298,258],{"class":129},[63,300,301],{"class":80},">Height:{$list.height}\u003C\u002F",[63,303,230],{"class":187},[63,305,199],{"class":80},[63,307,309,312,314],{"class":65,"line":308},9,[63,310,311],{"class":80},"  \u003C\u002F",[63,313,212],{"class":187},[63,315,199],{"class":80},[63,317,319],{"class":65,"line":318},10,[63,320,321],{"class":80},"  {\u002Fvolist}\n",[63,323,325],{"class":65,"line":324},11,[63,326,327],{"class":80},"  {$user|raw}\n",[63,329,331,334,336],{"class":65,"line":330},12,[63,332,333],{"class":80},"\u003C\u002F",[63,335,188],{"class":187},[63,337,199],{"class":80},[17,339,340,341,344],{},"The key part here is ",[28,342,343],{},"{$user|raw}"," — ThinkPHP automatically swaps that out for the pagination control.",[17,346,347],{},[43,348],{"alt":349,"src":350},"Basic style","https:\u002F\u002Fi.imgur.com\u002FPDINlQG.png",[17,352,353,354,357],{},"You might also run into another way of writing it, ",[28,355,356],{},"{$user->render()|raw}",". The result is exactly the same, so just pick whichever one you like.",[12,359,361],{"id":360},"customizing-the-pagination-style","Customizing the pagination style",[17,363,364],{},"Honestly, customizing the pagination style is a bit of a hassle, but the default look is pretty plain, so let's fix it up.",[17,366,367,368,371,372,375,376,379],{},"First, head to ",[28,369,370],{},"thinkphp\u002Flibrary\u002Fpaginator\u002Fdirver\u002F",", make a copy of ",[28,373,374],{},"Bootstrap.php"," in there, and rename it to ",[28,377,378],{},"BootstrapPages.php",".",[17,381,382],{},[43,383],{"alt":384,"src":385},"Remember to rename the class to BootstrapPages too","https:\u002F\u002Fi.imgur.com\u002FYFaT957.png",[17,387,388],{},"Now let's take a look at what the default basic pagination HTML actually looks like.",[17,390,391],{},[43,392],{"alt":349,"src":393},"https:\u002F\u002Fi.imgur.com\u002FVTi0iky.png",[17,395,396,397,400],{},"Next, open up the Bootstrap component and check the ",[28,398,399],{},"className"," for the pagination.",[17,402,403],{},[43,404],{"alt":405,"src":406},"Pages","https:\u002F\u002Fi.imgur.com\u002F6pqsCY7.png",[17,408,409,410,413,414,417,418,421,422,424],{},"So the spots we need to modify are ",[28,411,412],{},"getAvailablePageWrapper()",", ",[28,415,416],{},"getDisabledTextWrapper()",", and ",[28,419,420],{},"getActivePageWrapper()"," — we just add the matching ",[28,423,399],{}," to each.",[17,426,427,428,431,432,435,436,438,439,441,442,444],{},"Now create a file called ",[28,429,430],{},"paginate.php"," under ",[28,433,434],{},"config",". Since we're plugging in our own ",[28,437,100],{},", we need to tell ThinkPHP to use the settings in our ",[28,440,430],{}," instead of the built-in ",[28,443,100],{}," config. The content goes like this:",[54,446,448],{"className":56,"code":447,"language":58,"meta":59,"style":59},"\u003C?php\nreturn [\n    'type'      => 'BootstrapPages',\n    'var_page'  => 'page',\n    'list_rows' => 15,\n];\n",[28,449,450,458,466,480,493,506],{"__ignoreMap":59},[63,451,452,455],{"class":65,"line":66},[63,453,454],{"class":69},"\u003C?",[63,456,457],{"class":93},"php\n",[63,459,460,463],{"class":65,"line":84},[63,461,462],{"class":69},"return",[63,464,465],{"class":80}," [\n",[63,467,468,471,474,477],{"class":65,"line":112},[63,469,470],{"class":129},"    'type'",[63,472,473],{"class":69},"      =>",[63,475,476],{"class":129}," 'BootstrapPages'",[63,478,479],{"class":80},",\n",[63,481,482,485,488,491],{"class":65,"line":148},[63,483,484],{"class":129},"    'var_page'",[63,486,487],{"class":69},"  =>",[63,489,490],{"class":129}," 'page'",[63,492,479],{"class":80},[63,494,495,498,501,504],{"class":65,"line":224},[63,496,497],{"class":129},"    'list_rows'",[63,499,500],{"class":69}," =>",[63,502,503],{"class":93}," 15",[63,505,479],{"class":80},[63,507,508],{"class":65,"line":247},[63,509,510],{"class":80},"];\n",[17,512,513],{},"And finally we can check whether our pagination style actually got loaded.",[17,515,516],{},[43,517],{"alt":518,"src":519},"Pagination component","https:\u002F\u002Fi.imgur.com\u002FpFQ8IFY.png",[12,521,523],{"id":522},"moving-it-into-extend","Moving it into extend",[17,525,526,527,529,530,532,533,536,537,540],{},"Now let me walk through another way to load it — and honestly this is the one I'd recommend. First, take the ",[28,528,378],{}," that's sitting in ",[28,531,370],{}," and move it out into the ",[28,534,535],{},"extend"," folder at the root of the project. Then change the namespace to ",[28,538,539],{},"bootstrap"," (here are the first few lines as an example):",[54,542,544],{"className":56,"code":543,"language":58,"meta":59,"style":59},"namespace bootstrap;\n\nuse think\\Paginator;\n\nclass BootstrapPages extends Paginator\n{\n  ...\n}\n",[28,545,546,558,564,574,578,592,597,602],{"__ignoreMap":59},[63,547,548,551,555],{"class":65,"line":66},[63,549,550],{"class":69},"namespace",[63,552,554],{"class":553},"s_sBn"," bootstrap",[63,556,557],{"class":80},";\n",[63,559,560],{"class":65,"line":84},[63,561,563],{"emptyLinePlaceholder":562},true,"\n",[63,565,566,569,572],{"class":65,"line":112},[63,567,568],{"class":69},"use",[63,570,571],{"class":93}," think\\Paginator",[63,573,557],{"class":80},[63,575,576],{"class":65,"line":148},[63,577,563],{"emptyLinePlaceholder":562},[63,579,580,583,586,589],{"class":65,"line":224},[63,581,582],{"class":69},"class",[63,584,585],{"class":553}," BootstrapPages",[63,587,588],{"class":69}," extends",[63,590,591],{"class":93}," Paginator\n",[63,593,594],{"class":65,"line":247},[63,595,596],{"class":80},"{\n",[63,598,599],{"class":65,"line":268},[63,600,601],{"class":69},"  ...\n",[63,603,604],{"class":65,"line":288},[63,605,151],{"class":80},[17,607,608],{},"So right now the directory structure looks like this.",[17,610,611],{},[43,612],{"alt":535,"src":613},"https:\u002F\u002Fi.imgur.com\u002FMvlw7wr.png",[17,615,616,617,620],{},"Next, open the ",[28,618,619],{},"config\u002Fpaginate.php"," file we created earlier and change the content to this:",[54,622,624],{"className":56,"code":623,"language":58,"meta":59,"style":59},"\u003C?php\nreturn [\n    'type'      => 'bootstrap\\BootstrapPages',\n    'var_page'  => 'page',\n    'list_rows' => 15,\n];\n",[28,625,626,632,638,649,659,669],{"__ignoreMap":59},[63,627,628,630],{"class":65,"line":66},[63,629,454],{"class":69},[63,631,457],{"class":93},[63,633,634,636],{"class":65,"line":84},[63,635,462],{"class":69},[63,637,465],{"class":80},[63,639,640,642,644,647],{"class":65,"line":112},[63,641,470],{"class":129},[63,643,473],{"class":69},[63,645,646],{"class":129}," 'bootstrap\\BootstrapPages'",[63,648,479],{"class":80},[63,650,651,653,655,657],{"class":65,"line":148},[63,652,484],{"class":129},[63,654,487],{"class":69},[63,656,490],{"class":129},[63,658,479],{"class":80},[63,660,661,663,665,667],{"class":65,"line":224},[63,662,497],{"class":129},[63,664,500],{"class":69},[63,666,503],{"class":93},[63,668,479],{"class":80},[63,670,671],{"class":65,"line":247},[63,672,510],{"class":80},[17,674,675],{},"And the result is the same — the pagination component still shows up just fine.",[17,677,678],{},[43,679],{"alt":518,"src":680},"https:\u002F\u002Fi.imgur.com\u002FWAdRkMl.png",[12,682,684],{"id":683},"wrapping-up","Wrapping up",[17,686,687,688,690,691,693],{},"This post mainly covered how to create your own file inside the ThinkPHP core. But generally speaking, anything you modify yourself or any third-party extension is better off living in ",[28,689,535],{},". The main reason is you don't want to touch the core code, because the core might need updating down the line and that would overwrite your file. That's exactly why I also showed the ",[28,692,535],{}," approach — and in practice, that's the one I'd lean on.",[695,696,697],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}",{"title":59,"searchDepth":84,"depth":84,"links":699},[700,701,702,703,704],{"id":14,"depth":84,"text":15},{"id":22,"depth":84,"text":23},{"id":360,"depth":84,"text":361},{"id":522,"depth":84,"text":523},{"id":683,"depth":84,"text":684},"PHP","2019-09-28 00:00:10","Pagination is one of those features pretty much every site needs, and the good news is ThinkPHP ships with it out of the box. In this post we'll call paginate(), wire it up with some HTML, and get a working pager. Then we'll go a step further and override the default Bootstrap style with our own. Finally, I'll show you the cleaner way to load that custom paginator from the extend folder instead of hacking the core.","md","en",{},"\u002Fen\u002Fphp\u002Fthinkphp-day-27-pagination","3",{"title":6,"description":707},false,"en\u002FPHP\u002Fthinkphp-day-27-pagination",[705,717,718,719,720],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","2019 iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F28\u002Fthinkphp-day-27-pagination\u002F","bkU6Ny4l_Bjf2kNo2Vkh3M-nWwalYRoo1AInbbeulhY",{"newer":725,"older":729},{"url":726,"title":727,"date":728},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F29\u002Fthink-php-day-28-build-a-message-board\u002F","Day 28 - Learning ThinkPHP from Scratch: Building a Message Board","2019-09-29 00:00:05",{"url":730,"title":731,"date":732},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F28\u002Fjs-from-zero-ep-13-dom\u002F","JS From Zero EP.13: What Is the DOM, Really?","2019-09-28 00:00:05",[734,739,743],{"url":735,"title":736,"date":737,"readingMinutes":738},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":740,"title":741,"date":742,"readingMinutes":712},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02",{"url":744,"title":745,"date":746,"readingMinutes":747},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01","4",1784010286266]