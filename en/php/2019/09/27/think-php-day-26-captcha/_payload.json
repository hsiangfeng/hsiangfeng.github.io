,573],{},"Now when the user hovers over the captcha image, they'll see the ",[570,571,572],"strong",{},"Refresh captcha"," tooltip ↓",[17,575,576],{},[84,577],{"alt":578,"src":579},"Refresh captcha tooltip","https:\u002F\u002Fi.imgur.com\u002Fm6GW1oy.png",[17,581,582,583,585],{},"Next up is the JavaScript to actually refresh the captcha image. All we really need to do is re-assign the ",[28,584,68],{}," image path:",[33,587,591],{"className":588,"code":589,"language":590,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","const captchaImg = document.getElementById('captchaImg');\ncaptchaImg.addEventListener('click',(e) => {\n  e.preventDefault();\n  captchaImg.src = \"\u002Fcaptcha\";\n})\n","js",[28,592,593,620,648,659,672],{"__ignoreMap":38},[42,594,595,598,601,604,607,611,614,617],{"class":44,"line":45},[42,596,597],{"class":52},"const",[42,599,600],{"class":48}," captchaImg",[42,602,603],{"class":52}," =",[42,605,606],{"class":109}," document.",[42,608,610],{"class":609},"sj_SG","getElementById",[42,612,613],{"class":109},"(",[42,615,616],{"class":148},"'captchaImg'",[42,618,619],{"class":109},");\n",[42,621,622,625,628,630,633,636,640,643,645],{"class":44,"line":120},[42,623,624],{"class":109},"captchaImg.",[42,626,627],{"class":609},"addEventListener",[42,629,613],{"class":109},[42,631,632],{"class":148},"'click'",[42,634,635],{"class":109},",(",[42,637,639],{"class":638},"s_sBn","e",[42,641,642],{"class":109},") ",[42,644,334],{"class":52},[42,646,647],{"class":109}," {\n",[42,649,650,653,656],{"class":44,"line":135},[42,651,652],{"class":109},"  e.",[42,654,655],{"class":609},"preventDefault",[42,657,658],{"class":109},"();\n",[42,660,661,664,666,669],{"class":44,"line":184},[42,662,663],{"class":109},"  captchaImg.src ",[42,665,71],{"class":52},[42,667,668],{"class":148}," \"\u002Fcaptcha\"",[42,670,671],{"class":109},";\n",[42,673,674],{"class":44,"line":351},[42,675,676],{"class":109},"})\n",[17,678,679],{},"And that gives us click-to-refresh.",[17,681,682,683,686,687,689],{},"One last thing — here's a super-condensed shorthand version of click-to-refresh. Just add ",[28,684,685],{},"onclick=\"this.src='{:captcha_src()}'\""," to the ",[28,688,84],{}," tag and you're done:",[33,691,693],{"className":100,"code":692,"language":102,"meta":38,"style":38},"\u003Cdiv>\n  \u003Cdiv>\u003Cimg src=\"{:captcha_src()}\" alt=\"captcha\" id=\"captchaImg\" style=\"cursor: pointer;\" onclick=\"this.src='{:captcha_src()}'\" title=\"Refresh captcha\"\u002F>\u003C\u002Fdiv>\n  \u003Cinput type=\"text\" name=\"captcha\" id=\"captcha\" class=\"form-control\" placeholder=\"captcha\">\n  \u003Cspan class=\"text-danger\">{$Request.session.error.captcha}\u003C\u002Fspan>\n\u003C\u002Fdiv>\n",[28,694,695,703,770,808,826],{"__ignoreMap":38},[42,696,697,699,701],{"class":44,"line":45},[42,698,110],{"class":109},[42,700,114],{"class":113},[42,702,117],{"class":109},[42,704,705,707,709,711,713,715,717,719,721,723,725,727,729,731,733,735,737,740,742,745,748,750,753,755,758,760,762,764,766,768],{"class":44,"line":120},[42,706,123],{"class":109},[42,708,114],{"class":113},[42,710,219],{"class":109},[42,712,84],{"class":113},[42,714,224],{"class":48},[42,716,71],{"class":109},[42,718,229],{"class":148},[42,720,232],{"class":48},[42,722,71],{"class":109},[42,724,157],{"class":148},[42,726,160],{"class":48},[42,728,71],{"class":109},[42,730,476],{"class":148},[42,732,479],{"class":48},[42,734,71],{"class":109},[42,736,484],{"class":148},[42,738,739],{"class":48}," onclick",[42,741,71],{"class":109},[42,743,744],{"class":148},"\"",[42,746,747],{"class":48},"this",[42,749,77],{"class":148},[42,751,752],{"class":109},"src",[42,754,71],{"class":52},[42,756,757],{"class":148},"'{:captcha_src()}'\"",[42,759,487],{"class":48},[42,761,71],{"class":109},[42,763,492],{"class":148},[42,765,495],{"class":109},[42,767,114],{"class":113},[42,769,117],{"class":109},[42,771,772,774,776,778,780,782,784,786,788,790,792,794,796,798,800,802,