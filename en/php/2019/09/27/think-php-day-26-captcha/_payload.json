[{"data":1,"prerenderedAt":1024},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F27\u002Fthink-php-day-26-captcha\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F27\u002Fthink-php-day-26-captcha\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F27\u002Fthink-php-day-26-captcha\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F27\u002Fthink-php-day-26-captcha\u002F":1000,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F27\u002Fthink-php-day-26-captcha\u002F":1009},"\u002Fphp\u002F20190927\u002F3311186145\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":981,"date":982,"description":983,"extension":984,"lang":985,"meta":986,"navigation":347,"path":987,"readingMinutes":988,"seo":989,"standalone":990,"stem":991,"tags":992,"tldr":997,"updated":982,"url":998,"__hash__":999},"content\u002Fen\u002FPHP\u002Fthink-php-day-26-captcha.md","Day 26 - Learning ThinkPHP from Scratch: Adding a Captcha","1002779572",{"type":9,"value":10,"toc":973},"minimark",[11,16,20,24,32,81,88,92,95,98,192,198,290,293,299,309,393,396,402,405,411,421,425,435,566,574,580,586,677,680,690,834,838,845,951,955,969],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This post is about ThinkPHP's captcha feature. ThinkPHP gives you captcha support out of the box, and honestly, unless you've got some special requirement, the built-in one is plenty.",[12,21,23],{"id":22},"getting-started","Getting started",[17,25,26,27,31],{},"The captcha stuff in ThinkPHP lives in an extension package, so before you can use it you need to install ",[28,29,30],"code",{},"think-captcha"," via Composer. Open up cmd, move into your project folder, and run this:",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-php shiki shiki-themes github-dark-high-contrast","composer require topthink\u002Fthink-captcha=2.0.*\n","php","",[28,40,41],{"__ignoreMap":38},[42,43,46,50,54,57,60,63,66,69,72,75,78],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sCcAr","composer",[42,51,53],{"class":52},"sWyjQ"," require",[42,55,56],{"class":48}," topthink",[42,58,59],{"class":52},"\u002F",[42,61,62],{"class":48},"think",[42,64,65],{"class":52},"-",[42,67,68],{"class":48},"captcha",[42,70,71],{"class":52},"=",[42,73,74],{"class":48},"2.0",[42,76,77],{"class":52},".",[42,79,80],{"class":52},"*\n",[17,82,83],{},[84,85],"img",{"alt":86,"src":87},"Installing the extension package","https:\u002F\u002Fi.imgur.com\u002F2idyfWV.png",[12,89,91],{"id":90},"how-to-use-it","How to use it",[17,93,94],{},"Actually using the captcha is super simple. There are two ways to write it, and you just drop one of them into your HTML template to make the captcha show up.",[17,96,97],{},"First way, generated by ThinkPHP itself:",[33,99,103],{"className":100,"code":101,"language":102,"meta":38,"style":38},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cdiv>\n  \u003Cdiv>{:captcha_img()}\u003C\u002Fdiv>\n  \u003Cinput type=\"text\" name=\"captcha\" id=\"captcha\" class=\"form-control\" placeholder=\"captcha\">\n\u003C\u002Fdiv>\n","html",[28,104,105,118,133,182],{"__ignoreMap":38},[42,106,107,111,115],{"class":44,"line":45},[42,108,110],{"class":109},"sMAXC","\u003C",[42,112,114],{"class":113},"sKpQp","div",[42,116,117],{"class":109},">\n",[42,119,121,124,126,129,131],{"class":44,"line":120},2,[42,122,123],{"class":109},"  \u003C",[42,125,114],{"class":113},[42,127,128],{"class":109},">{:captcha_img()}\u003C\u002F",[42,130,114],{"class":113},[42,132,117],{"class":109},[42,134,136,138,141,144,146,150,153,155,158,161,163,165,168,170,173,176,178,180],{"class":44,"line":135},3,[42,137,123],{"class":109},[42,139,140],{"class":113},"input",[42,142,143],{"class":48}," type",[42,145,71],{"class":109},[42,147,149],{"class":148},"sTRMh","\"text\"",[42,151,152],{"class":48}," name",[42,154,71],{"class":109},[42,156,157],{"class":148},"\"captcha\"",[42,159,160],{"class":48}," id",[42,162,71],{"class":109},[42,164,157],{"class":148},[42,166,167],{"class":48}," class",[42,169,71],{"class":109},[42,171,172],{"class":148},"\"form-control\"",[42,174,175],{"class":48}," placeholder",[42,177,71],{"class":109},[42,179,157],{"class":148},[42,181,117],{"class":109},[42,183,185,188,190],{"class":44,"line":184},4,[42,186,187],{"class":109},"\u003C\u002F",[42,189,114],{"class":113},[42,191,117],{"class":109},[17,193,194,195,197],{},"The other way uses an ",[28,196,84],{}," tag. I personally recommend this one, because it matters for stuff we'll cover later:",[33,199,201],{"className":100,"code":200,"language":102,"meta":38,"style":38},"\u003Cdiv>\n  \u003Cdiv>\u003Cimg src=\"{:captcha_src()}\" alt=\"captcha\" \u002F>\u003C\u002Fdiv>\n  \u003Cinput type=\"text\" name=\"captcha\" id=\"captcha\" class=\"form-control\" placeholder=\"captcha\">\n\u003C\u002Fdiv>\n",[28,202,203,211,244,282],{"__ignoreMap":38},[42,204,205,207,209],{"class":44,"line":45},[42,206,110],{"class":109},[42,208,114],{"class":113},[42,210,117],{"class":109},[42,212,213,215,217,220,222,225,227,230,233,235,237,240,242],{"class":44,"line":120},[42,214,123],{"class":109},[42,216,114],{"class":113},[42,218,219],{"class":109},">\u003C",[42,221,84],{"class":113},[42,223,224],{"class":48}," src",[42,226,71],{"class":109},[42,228,229],{"class":148},"\"{:captcha_src()}\"",[42,231,232],{"class":48}," alt",[42,234,71],{"class":109},[42,236,157],{"class":148},[42,238,239],{"class":109}," \u002F>\u003C\u002F",[42,241,114],{"class":113},[42,243,117],{"class":109},[42,245,246,248,250,252,254,256,258,260,262,264,266,268,270,272,274,276,278,280],{"class":44,"line":135},[42,247,123],{"class":109},[42,249,140],{"class":113},[42,251,143],{"class":48},[42,253,71],{"class":109},[42,255,149],{"class":148},[42,257,152],{"class":48},[42,259,71],{"class":109},[42,261,157],{"class":148},[42,263,160],{"class":48},[42,265,71],{"class":109},[42,267,157],{"class":148},[42,269,167],{"class":48},[42,271,71],{"class":109},[42,273,172],{"class":148},[42,275,175],{"class":48},[42,277,71],{"class":109},[42,279,157],{"class":148},[42,281,117],{"class":109},[42,283,284,286,288],{"class":44,"line":184},[42,285,187],{"class":109},[42,287,114],{"class":113},[42,289,117],{"class":109},[17,291,292],{},"And just like that, the captcha shows up on the front end ↓",[17,294,295],{},[84,296],{"alt":297,"src":298},"Captcha showing on the page","https:\u002F\u002Fi.imgur.com\u002FkywQtDv.png",[17,300,301,302,305,306,308],{},"There's one more thing to do though. When a user leaves the captcha blank or types it wrong, we need to show them an error message. So we pair this with form validation. Open up the form validator at ",[28,303,304],{},"validate\u002FUser.php"," and add the ",[28,307,68],{}," rule plus the error messages:",[33,310,312],{"className":35,"code":311,"language":37,"meta":38,"style":38},"protected $rule = [\n    'captcha'=>'require|captcha'\n];\n\nprotected $message = [\n    'captcha.require'=>'Captcha is required',\n    'captcha.captcha'=>'Incorrect captcha',\n];\n",[28,313,314,327,338,343,349,361,375,388],{"__ignoreMap":38},[42,315,316,319,322,324],{"class":44,"line":45},[42,317,318],{"class":52},"protected",[42,320,321],{"class":109}," $rule ",[42,323,71],{"class":52},[42,325,326],{"class":109}," [\n",[42,328,329,332,335],{"class":44,"line":120},[42,330,331],{"class":148},"    'captcha'",[42,333,334],{"class":52},"=>",[42,336,337],{"class":148},"'require|captcha'\n",[42,339,340],{"class":44,"line":135},[42,341,342],{"class":109},"];\n",[42,344,345],{"class":44,"line":184},[42,346,348],{"emptyLinePlaceholder":347},true,"\n",[42,350,352,354,357,359],{"class":44,"line":351},5,[42,353,318],{"class":52},[42,355,356],{"class":109}," $message ",[42,358,71],{"class":52},[42,360,326],{"class":109},[42,362,364,367,369,372],{"class":44,"line":363},6,[42,365,366],{"class":148},"    'captcha.require'",[42,368,334],{"class":52},[42,370,371],{"class":148},"'Captcha is required'",[42,373,374],{"class":109},",\n",[42,376,378,381,383,386],{"class":44,"line":377},7,[42,379,380],{"class":148},"    'captcha.captcha'",[42,382,334],{"class":52},[42,384,385],{"class":148},"'Incorrect captcha'",[42,387,374],{"class":109},[42,389,391],{"class":44,"line":390},8,[42,392,342],{"class":109},[17,394,395],{},"That gets us the captcha error messages. Let's actually test it. First, what happens with a blank captcha ↓",[17,397,398],{},[84,399],{"alt":400,"src":401},"Captcha is required","https:\u002F\u002Fi.imgur.com\u002F3qXRDet.png",[17,403,404],{},"And if I deliberately type the wrong captcha, what error do I get? ↓",[17,406,407],{},[84,408],{"alt":409,"src":410},"Incorrect captcha","https:\u002F\u002Fi.imgur.com\u002FiRmLIAR.png",[17,412,413,414],{},"You can also customize the captcha — things like switching to Chinese characters, changing the size, the blur level, and so on. I won't go into the details here, but you can check the official manual → ",[415,416,420],"a",{"href":417,"rel":418},"https:\u002F\u002Fwww.kancloud.cn\u002Fmanual\u002Fthinkphp5_1\u002F354122",[419],"nofollow","link",[12,422,424],{"id":423},"click-to-refresh-the-captcha","Click to refresh the captcha",[17,426,427,428,431,432,434],{},"ThinkPHP's captcha doesn't come with a click-to-refresh feature, so here's how I do it. I did try building click-to-refresh with ",[28,429,430],{},"{:captcha_img()}",", but it sometimes just doesn't respond, so I personally recommend going with the ",[28,433,84],{}," tag approach:",[33,436,438],{"className":100,"code":437,"language":102,"meta":38,"style":38},"\u003Cdiv>\n  \u003Cdiv>\u003Cimg src=\"{:captcha_src()}\" alt=\"captcha\" id=\"captchaImg\" style=\"cursor: pointer;\" title=\"Refresh captcha\"\u002F>\u003C\u002Fdiv>\n  \u003Cinput type=\"text\" name=\"captcha\" id=\"captcha\" class=\"form-control\" placeholder=\"captcha\">\n  \u003Cspan class=\"text-danger\">{$Request.session.error.captcha}\u003C\u002Fspan>\n\u003C\u002Fdiv>\n",[28,439,440,448,500,538,558],{"__ignoreMap":