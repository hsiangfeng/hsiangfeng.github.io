[{"data":1,"prerenderedAt":885},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F16\u002Fthinkphp-day-15-model-queries\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F16\u002Fthinkphp-day-15-model-queries\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F16\u002Fthinkphp-day-15-model-queries\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F16\u002Fthinkphp-day-15-model-queries\u002F":861,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F16\u002Fthinkphp-day-15-model-queries\u002F":870},"\u002Fphp\u002F20190916\u002F2939346668\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":841,"date":842,"description":843,"extension":844,"lang":845,"meta":846,"navigation":847,"path":848,"readingMinutes":849,"seo":850,"standalone":851,"stem":852,"tags":853,"tldr":858,"updated":842,"url":859,"__hash__":860},"content\u002Fen\u002FPHP\u002Fthinkphp-day-15-model-queries.md","Day15 - Learning ThinkPHP from Scratch: Model Basics (3)","1002684544",{"type":9,"value":10,"toc":834},"minimark",[11,16,20,24,27,97,101,126,135,238,241,248,255,261,267,273,276,280,291,399,402,408,419,517,524,778,785,791,794,815,819,830],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time we learned how to insert data through the Model. But what about reading it back? How do you actually query data? So in this post I'll walk through how to use the Model to do queries.",[12,21,23],{"id":22},"getting-started","Getting started",[17,25,26],{},"First we need to register two routes, otherwise nothing below will work:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-php shiki shiki-themes github-dark-high-contrast","Route::get('\u002Fabout\u002Flist', 'about\u002Findex\u002Fall');\nRoute::get('\u002Fabout\u002F:id', 'about\u002Findex\u002Fselect'); \u002F\u002F This is a dynamic route. I'll explain it more later.\n","php","",[35,36,37,71],"code",{"__ignoreMap":33},[38,39,42,46,50,54,58,62,65,68],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sCcAr","Route",[38,47,49],{"class":48},"sWyjQ","::",[38,51,53],{"class":52},"sj_SG","get",[38,55,57],{"class":56},"sMAXC","(",[38,59,61],{"class":60},"sTRMh","'\u002Fabout\u002Flist'",[38,63,64],{"class":56},", ",[38,66,67],{"class":60},"'about\u002Findex\u002Fall'",[38,69,70],{"class":56},");\n",[38,72,74,76,78,80,82,85,87,90,93],{"class":40,"line":73},2,[38,75,45],{"class":44},[38,77,49],{"class":48},[38,79,53],{"class":52},[38,81,57],{"class":56},[38,83,84],{"class":60},"'\u002Fabout\u002F:id'",[38,86,64],{"class":56},[38,88,89],{"class":60},"'about\u002Findex\u002Fselect'",[38,91,92],{"class":56},"); ",[38,94,96],{"class":95},"sQrFR","\u002F\u002F This is a dynamic route. I'll explain it more later.\n",[12,98,100],{"id":99},"fetching-a-single-record","Fetching a single record",[17,102,103,104,107,108,111,112,115,116,64,119,115,122,125],{},"The most basic query is grabbing a single record. First, open up the ",[35,105,106],{},"about\u002Fcontroller\u002Findex.php"," file, and let's build a method that fetches data using ",[35,109,110],{},"id",". The idea is that visiting the URL ",[35,113,114],{},"\u002Fabout\u002F1"," shows the person whose ",[35,117,118],{},"id = 1",[35,120,121],{},"\u002Fabout\u002F2",[35,123,124],{},"id = 2",", and so on. That's what a dynamic route is — basically a route that changes based on the URL you type in.",[17,127,128,129,131,132,134],{},"Here we'll query by ",[35,130,110],{},", and on the Model side we'll use the ",[35,133,53],{}," method and pass in a parameter. It's clearer to just show you the example code:",[28,136,138],{"className":30,"code":137,"language":32,"meta":33,"style":33},"public function select($id) {\n    $user = aboutModel::get($id);\n    echo $user->name.'\u003Cbr\u002F>';\n    echo $user->height.'\u003Cbr\u002F>';\n    echo $user->weight.'\u003Cbr\u002F>';\n}\n",[35,139,140,154,172,196,214,232],{"__ignoreMap":33},[38,141,142,145,148,151],{"class":40,"line":41},[38,143,144],{"class":48},"public",[38,146,147],{"class":48}," function",[38,149,150],{"class":52}," select",[38,152,153],{"class":56},"($id) {\n",[38,155,156,159,162,165,167,169],{"class":40,"line":73},[38,157,158],{"class":56},"    $user ",[38,160,161],{"class":48},"=",[38,163,164],{"class":44}," aboutModel",[38,166,49],{"class":48},[38,168,53],{"class":52},[38,170,171],{"class":56},"($id);\n",[38,173,175,178,181,184,187,190,193],{"class":40,"line":174},3,[38,176,177],{"class":44},"    echo",[38,179,180],{"class":56}," $user",[38,182,183],{"class":48},"->",[38,185,186],{"class":56},"name",[38,188,189],{"class":48},".",[38,191,192],{"class":60},"'\u003Cbr\u002F>'",[38,194,195],{"class":56},";\n",[38,197,199,201,203,205,208,210,212],{"class":40,"line":198},4,[38,200,177],{"class":44},[38,202,180],{"class":56},[38,204,183],{"class":48},[38,206,207],{"class":56},"height",[38,209,189],{"class":48},[38,211,192],{"class":60},[38,213,195],{"class":56},[38,215,217,219,221,223,226,228,230],{"class":40,"line":216},5,[38,218,177],{"class":44},[38,220,180],{"class":56},[38,222,183],{"class":48},[38,224,225],{"class":56},"weight",[38,227,189],{"class":48},[38,229,192],{"class":60},[38,231,195],{"class":56},[38,233,235],{"class":40,"line":234},6,[38,236,237],{"class":56},"}\n",[17,239,240],{},"I've gone ahead and seeded about 5 sample rows beforehand ↓",[17,242,243],{},[244,245],"img",{"alt":246,"src":247},"Sample data","https:\u002F\u002Fi.imgur.com\u002FgNeUYQ3.png",[17,249,250,251,254],{},"Now let's try visiting ",[35,252,253],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002F1"," ↓",[17,256,257],{},[244,258],{"alt":259,"src":260},"Wang Da-ming","https:\u002F\u002Fi.imgur.com\u002FRkh5t2j.png",[17,262,263,264,254],{},"Of course you can try hitting any route from 1 to 5 at random, like ",[35,265,266],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002F3",[17,268,269],{},[244,270],{"alt":271,"src":272},"Chen Chun-jiao","https:\u002F\u002Fi.imgur.com\u002FnC7I4OU.png",[17,274,275],{},"And that's how you fetch a single record.",[12,277,279],{"id":278},"listing-all-records","Listing all records",[17,281,282,283,286,287,290],{},"We have a way to query a single record by id, so naturally there's also a way to query everything. For Model operations, we'll use the ",[35,284,285],{},"all()"," method, so it looks like ",[35,288,289],{},"$user = aboutModel::all();",". But the data that comes back has to be handled with a loop, because what you get back is an array. So let's look at the example code~",[28,292,294],{"className":30,"code":293,"language":32,"meta":33,"style":33},"public function all() {\n    $user = aboutModel::all();\n    foreach($user as $list) {\n        echo $list->name.'\u003Cbr\u002F>';\n        echo $list->height.'\u003Cbr\u002F>';\n        echo $list->weight.'\u003Cbr\u002F>';\n    }\n}\n",[35,295,296,308,324,338,356,372,388,394],{"__ignoreMap":33},[38,297,298,300,302,305],{"class":40,"line":41},[38,299,144],{"class":48},[38,301,147],{"class":48},[38,303,304],{"class":52}," all",[38,306,307],{"class":56},"() {\n",[38,309,310,312,314,316,318,321],{"class":40,"line":73},[38,311,158],{"class":56},[38,313,161],{"class":48},[38,315,164],{"class":44},[38,317,49],{"class":48},[38,319,320],{"class":52},"all",[38,322,323],{"class":56},"();\n",[38,325,326,329,332,335],{"class":40,"line":174},[38,327,328],{"class":48},"    foreach",[38,330,331],{"class":56},"($user ",[38,333,334],{"class":48},"as",[38,336,337],{"class":56}," $list) {\n",[38,339,340,343,346,348,350,352,354],{"class":40,"line":198},[38,341,342],{"class":44},"        echo",[38,344,345],{"class":56}," $list",[38,347,183],{"class":48},[38,349,186],{"class":56},[38,351,189],{"class":48},[38,353,192],{"class":60},[38,355,195],{"class":56},[38,357,358,360,362,364,366,368,370],{"class":40,"line":216},[38,359,342],{"class":44},[38,361,345],{"class":56},[38,363,183],{"class":48},[38,365,207],{"class":56},[38,367,189],{"class":48},[38,369,192],{"class":60},[38,371,195],{"class":56},[38,373,374,376,378,380,382,384,386],{"class":40,"line":234},[38,375,342],{"class":44},[38,377,345],{"class":56},[38,379,183],{"class":48},[38,381,225],{"class":56},[38,383,189],{"class":48},[38,385,192],{"class":60},[38,387,195],{"class":56},[38,389,391],{"class":40,"line":390},7,[38,392,393],{"class":56},"    }\n",[38,395,397],{"class":40,"line":396},8,[38,398,237],{"class":56},[17,400,401],{},"Basically this is enough to pull all the data and return it to the homepage ↓",[17,403,404],{},[244,405],{"alt":406,"src":407},"Data list","https:\u002F\u002Fi.imgur.com\u002FUtmsGyd.png",[17,409,410,411,414,415,418],{},"But here I'll write a second example. Let's try sending the data to the frontend, so we'll use ",[35,412,413],{},"assign()"," and then ",[35,416,417],{},"fetch()"," to render it onto a specific HTML template:",[28,420,422],{"className":30,"code":421,"language":32,"meta":33,"style":33},"public function all() {\n    $user = aboutModel::all();\n    $title = '全部使用者資料';\n    $this->assign('title', $title);\n    return $this->assign('user', $user)->fetch('getAllUser'); \u002F\u002F Don't forget to return on the last line, otherwise you won't see the template~\n}\n",[35,423,424,434,448,460,478,513],{"__ignoreMap":33},[38,425,426,428,430,432],{"class":40,"line":41},[38,427,144],{"class":48},[38,429,147],{"class":48},[38,431,304],{"class":52},[38,433,307],{"class":56},[38,435,436,438,440,442,444,446],{"class":40,"line":73},[38,437,158],{"class":56},[38,439,161],{"class":48},[38,441,164],{"class":44},[38,443,49],{"class":48},[38,445,320],{"class":52},[38,447,323],{"class":56},[38,449,450,453,455,458],{"class":40,"line":174},[38,451,452],{"class":56},"    $title ",[38,454,161],{"class":48},[38,456,457],{"class":60}," '全部使用者資料'",[38,459,195],{"class":56},[38,461,462,465,467,470,472,475],{"class":40,"line":198},[38,463,464],{"class":44},"    $this",[38,466,183],{"class":48},[38,468,469],{"class":52},"assign",[38,471,57],{"class":56},[38,473,474],{"class":60},"'title'",[38,476,477],{"class":56},", $title);\n",[38,479,480,483,486,488,490,492,495,498,500,503,505,508,510],{"class":40,"line":216},[38,481,482],{"class":48},"    return",[38,484,485],{"class":44}," $this",[38,487,183],{"class":48},[38,489,469],{"class":52},[38,491,57],{"class":56},[38,493,494],{"class":60},"'user'",[38,496,497],{"class":56},", $user)",[38,499,183],{"class":48},[38,501,502],{"class":52},"fetch",[38,504,57],{"class":56},[38,506,507],{"class":60},"'getAllUser'",[38,509,92],{"class":56},[38,511,512],{"class":95},"\u002F\u002F Don't forget to return on the last line, otherwise you won't see the template~\n",[38,514,515],{"class":40,"line":234},[38,516,237],{"class":56},[17,518,519,520,523],{},"Next we need to create a getAllUser.html under ",[35,521,522],{},"about\u002Fview\u002Findex",". I'll provide the contents directly — here's the example:",[28,525,529],{"className":526,"code":527,"language":528,"meta":33,"style":33},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n  \u003Ctitle>{$title}\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>{$title}\u003C\u002Fh1>\n  {volist name=\"user\" id=\"list\"}\n  \u003Cul>\n    \u003Cli>姓名:{$list.name}\u003C\u002Fli>\n    \u003Cli>體重:{$list.weight}\u003C\u002Fli>\n    \u003Cli>身高:{$list.height}\u003C\u002Fli>\n  \u003C\u002Ful>\n  {\u002Fvolist}\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html",[35,530,531,546,563,572,590,614,637,651,660,670,684,690,700,716,730,744,754,760,769],{"__ignoreMap":33},[38,532,533,536,540,543],{"class":40,"line":41},[38,534,535],{"class":56},"\u003C!",[38,537,539],{"class":538},"sKpQp","DOCTYPE",[38,541,542],{"class":44}," html",[38,544,545],{"class":56},">\n",[38,547,548,551,553,556,558,561],{"class":40,"line":73},[38,549,550],{"class":56},"\u003C",[38,552,528],{"class":538},[38,554,555],{"class":44}," lang",[38,557,161],{"class":56},[38,559,560],{"class":60},"\"en\"",[38,562,545],{"class":56},[38,564,565,567,570],{"class":40,"line":174},[38,566,550],{"class":56},[38,568,569],{"class":538},"head",[38,571,545],{"class":56},[38,573,574,577,580,583,585,588],{"class":40,"line":198},[38,575,576],{"class":56},"  \u003C",[38,578,579],{"class":538},"meta",[38,581,582],{"class":44}," charset",[38,584,161],{"class":56},[38,586,587],{"class":60},"\"UTF-8\"",[38,589,545],{"class":56},[38,591,592,594,596,599,601,604,607,609,612],{"class":40,"line":216},[38,593,576],{"class":56},[38,595,579],{"class":538},[38,597,598],{"class":44}," name",[38,600,161],{"class":56},[38,602,603],{"class":60},"\"viewport\"",[38,605,606],{"class":44}," content",[38,608,161],{"class":56},[38,610,611],{"class":60},"\"width=device-width, initial-scale=1.0\"",[38,613,545],{"class":56},[38,615,616,618,620,623,625,628,630,632,635],{"class":40,"line":234},[38,617,576],{"class":56},[38,619,579],{"class":538},[38,621,622],{"class":44}," http-equiv",[38,624,161],{"class":56},[38,626,627],{"class":60},"\"X-UA-Compatible\"",[38,629,606],{"class":44},[38,631,161],{"class":56},[38,633,634],{"class":60},"\"ie=edge\"",[38,636,545],{"class":56},[38,638,639,641,644,647,649],{"class":40,"line":390},[38,640,576],{"class":56},[38,642,643],{"class":538},"title",[38,645,646],{"class":56},">{$title}\u003C\u002F",[38,648,643],{"class":538},[38,650,545],{"class":56},[38,652,653,656,658],{"class":40,"line":396},[38,654,655],{"class":56},"\u003C\u002F",[38,657,569],{"class":538},[38,659,545],{"class":56},[38,661,663,665,668],{"class":40,"line":662},9,[38,664,550],{"class":56},[38,666,667],{"class":538},"body",[38,669,545],{"class":56},[38,671,673,675,678,680,682],{"class":40,"line":672},10,[38,674,576],{"class":56},[38,676,677],{"class":538},"h1",[38,679,646],{"class":56},[38,681,677],{"class":538},[38,683,545],{"class":56},[38,685,687],{"class":40,"line":686},11,[38,688,689],{"class":56},"  {volist name=\"user\" id=\"list\"}\n",[38,691,693,695,698],{"class":40,"line":692},12,[38,694,576],{"class":56},[38,696,697],{"class":538},"ul",[38,699,545],{"class":56},[38,701,703,706,709,712,714],{"class":40,"line":702},13,[38,704,705],{"class":56},"    \u003C",[38,707,708],{"class":538},"li",[38,710,711],{"class":56},">姓名:{$list.name}\u003C\u002F",[38,713,708],{"class":538},[38,715,545],{"class":56},[38,717,719,721,723,726,728],{"class":40,"line":718},14,[38,720,705],{"class":56},[38,722,708],{"class":538},[38,724,725],{"class":56},">體重:{$list.weight}\u003C\u002F",[38,727,708],{"class":538},[38,729,545],{"class":56},[38,731,733,735,737,740,742],{"class":40,"line":732},15,[38,734,705],{"class":56},[38,736,708],{"class":538},[38,738,739],{"class":56},">身高:{$list.height}\u003C\u002F",[38,741,708],{"class":538},[38,743,545],{"class":56},[38,745,747,750,752],{"class":40,"line":746},16,[38,748,749],{"class":56},"  \u003C\u002F",[38,751,697],{"class":538},[38,753,545],{"class":56},[38,755,757],{"class":40,"line":756},17,[38,758,759],{"class":56},"  {\u002Fvolist}\n",[38,761,763,765,767],{"class":40,"line":762},18,[38,764,655],{"class":56},[38,766,667],{"class":538},[38,768,545],{"class":56},[38,770,772,774,776],{"class":40,"line":771},19,[38,773,655],{"class":56},[38,775,528],{"class":538},[38,777,545],{"class":56},[17,779,780,781,784],{},"Don't worry if you see something unfamiliar in there — I'll explain it in a moment. Once you've created it, you can visit ",[35,782,783],{},"http:\u002F\u002Flocalhost:8000\u002Fabout\u002Flist"," to check whether the data loads successfully ↓",[17,786,787],{},[244,788],{"alt":789,"src":790},"Data list rendered on the frontend","https:\u002F\u002Fi.imgur.com\u002FuvMSEXv.png",[17,792,793],{},"And just like that, we've successfully fetched all the user data and rendered it on the frontend.",[17,795,796,797,800,801,804,805,807,808,811,812,814],{},"Finally, let me circle back to that weird little bit inside the HTML, namely ",[35,798,799],{},"{volist name=\"user\" id=\"list\"}",". ",[35,802,803],{},"volist"," is a built-in tag that ThinkPHP provides, and it can loop over the data we passed in from the backend. I'll cover these built-in tags one by one later on, but in practice the ones you'll use most are ",[35,806,803],{}," and ",[35,809,810],{},"eq",". I won't get into ",[35,813,810],{}," for now — we'll have a chance to use it later — and I'll give these built-in tags a more detailed write-up in a later chapter.",[12,816,818],{"id":817},"wrapping-up","Wrapping up",[17,820,821,822,826,827,829],{},"In the next chapter I'm going to step away from the ",[823,824,825],"strong",{},"Model Basics"," series for a bit and jump over to raw data operations. After all, sometimes we may not want to go through the Model to work with data — we just want to do it inside the Controller. So the next post will hop over to data operations to get a feel for the difference between manipulating things through the Model versus writing your own SQL. Once that's covered, we'll come back and continue the ",[823,828,825],{}," series.",[831,832,833],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}",{"title":33,"searchDepth":73,"depth":73,"links":835},[836,837,838,839,840],{"id":14,"depth":73,"text":15},{"id":22,"depth":73,"text":23},{"id":99,"depth":73,"text":100},{"id":278,"depth":73,"text":279},{"id":817,"depth":73,"text":818},"PHP","2019-09-16 00:01:10","Last time we learned how to insert data through the Model. But what about reading it back? How do you actually query data? So this post is all about using the Model to pull records — fetching a single row by id, grabbing the whole list, and even passing that data to the frontend to render it.","md","en",{},true,"\u002Fen\u002Fphp\u002Fthinkphp-day-15-model-queries","3",{"title":6,"description":843},false,"en\u002FPHP\u002Fthinkphp-day-15-model-queries",[841,854,855,856,857],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","11th iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F16\u002Fthinkphp-day-15-model-queries\u002F","M6dfmXdbHrnsXo8RDqMqqqGHa96HebtZncKU8fl8Qng",{"newer":862,"older":866},{"url":863,"title":864,"date":865},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F16\u002Fjs-from-zero-ep01-javascript-intro\u002F","Re:Zero — Learning JS in Another World, Day 1: What Even Is JavaScript?","2019-09-16 00:01:27",{"url":867,"title":868,"date":869},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F15\u002Fre-zero-learning-js-00-table-of-contents\u002F","RE: Learning JavaScript From Zero — EP.0: The Table of Contents (and Why I Started)","2019-09-15 11:06:12",[871,876,880],{"url":872,"title":873,"date":874,"readingMinutes":875},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":877,"title":878,"date":879,"readingMinutes":849},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02",{"url":881,"title":882,"date":883,"readingMinutes":884},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01","4",1784011709444]