[{"data":1,"prerenderedAt":679},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F":655,"related:\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F":664},"\u002Fphp\u002F20190919\u002F503019302\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":636,"date":637,"description":638,"extension":639,"lang":640,"meta":641,"navigation":81,"path":642,"readingMinutes":643,"seo":644,"standalone":645,"stem":646,"tags":647,"tldr":652,"updated":637,"url":653,"__hash__":654},"content\u002Fen\u002FPHP\u002Fthinkphp-day-18-model-basics-4.md","ThinkPHP from Scratch Day 18 — Model Basics (4): Conditional Queries, Delete, and JSON","1002708301",{"type":9,"value":10,"toc":628},"minimark",[11,16,20,24,40,100,108,112,119,126,133,188,191,198,204,242,248,257,300,303,308,311,315,330,361,375,459,470,476,479,485,489,495,528,531,556,559,563,570,597,600,624],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"haha, I wandered off and now I've wandered right back. Hit me, I'm an idiot (gets smacked). Anyway, this time I want to fill in some gaps around querying — like how to run a conditional query with a Model, and once you've got the data back, how to sort it.",[12,21,23],{"id":22},"a-quick-recap","A quick recap",[17,25,26,30,31,35,36,39],{},[27,28,29],"del",{},"Let me take you back to a past life — no wait",", let me just recap the earlier Model basics. We learned that you can use ",[32,33,34],"code",{},"get()"," and ",[32,37,38],{},"all()"," to fetch a single record or list out a bunch of them:",[41,42,47],"pre",{"className":43,"code":44,"language":45,"meta":46,"style":46},"language-php shiki shiki-themes github-dark-high-contrast","$user = aboutModel::get($id);\n\n$user = aboutModel::all();\n","php","",[32,48,49,76,83],{"__ignoreMap":46},[50,51,54,58,62,66,69,73],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sMAXC","$user ",[50,59,61],{"class":60},"sWyjQ","=",[50,63,65],{"class":64},"sCcAr"," aboutModel",[50,67,68],{"class":60},"::",[50,70,72],{"class":71},"sj_SG","get",[50,74,75],{"class":56},"($id);\n",[50,77,79],{"class":52,"line":78},2,[50,80,82],{"emptyLinePlaceholder":81},true,"\n",[50,84,86,88,90,92,94,97],{"class":52,"line":85},3,[50,87,57],{"class":56},[50,89,61],{"class":60},[50,91,65],{"class":64},[50,93,68],{"class":60},[50,95,96],{"class":71},"all",[50,98,99],{"class":56},"();\n",[17,101,102,103,107],{},"But the ",[104,105,106],"strong",{},"Model Basics"," series never touched on conditions or sorting, so this post covers a few more of those Model basics.",[12,109,111],{"id":110},"conditional-queries","Conditional queries",[17,113,114,115,118],{},"For the next few examples I'll be writing the code inside ",[32,116,117],{},"about\u002Fcontroller\u002Findex.php",".",[17,120,121,122,125],{},"After the last couple of data-operation posts, you can probably see how convenient it is to work with data through a Model. So here I want to show you how to do a conditional query with a Model. Honestly it's just a matter of tacking on the ",[32,123,124],{},"where()"," method, but I'll pair it with the technique we learned earlier — the query builder.",[17,127,128,129,132],{},"So let's say I want to filter the ",[32,130,131],{},"user"," table for my classmates' heights, and I only want the ones taller than 170 cm:",[41,134,136],{"className":43,"code":135,"language":45,"meta":46,"style":46},"$user = aboutModel::where('height', '>', 170)->select();\necho $user;\n",[32,137,138,180],{"__ignoreMap":46},[50,139,140,142,144,146,148,151,154,158,161,164,166,169,172,175,178],{"class":52,"line":53},[50,141,57],{"class":56},[50,143,61],{"class":60},[50,145,65],{"class":64},[50,147,68],{"class":60},[50,149,150],{"class":71},"where",[50,152,153],{"class":56},"(",[50,155,157],{"class":156},"sTRMh","'height'",[50,159,160],{"class":56},", ",[50,162,163],{"class":156},"'>'",[50,165,160],{"class":56},[50,167,168],{"class":64},"170",[50,170,171],{"class":56},")",[50,173,174],{"class":60},"->",[50,176,177],{"class":71},"select",[50,179,99],{"class":56},[50,181,182,185],{"class":52,"line":78},[50,183,184],{"class":64},"echo",[50,186,187],{"class":56}," $user;\n",[17,189,190],{},"The result comes back as an array object, like this ↓",[17,192,193],{},[194,195],"img",{"alt":196,"src":197},"array object","https:\u002F\u002Fi.imgur.com\u002FOZMuhST.png",[17,199,200,201,203],{},"Of course you don't have to use the builder for filtering — you can also do it with the ",[32,202,38],{}," method:",[41,205,207],{"className":43,"code":206,"language":45,"meta":46,"style":46},"$user = aboutModel::all(['name' => 'QQ先生']);\necho $user;\n",[32,208,209,236],{"__ignoreMap":46},[50,210,211,213,215,217,219,221,224,227,230,233],{"class":52,"line":53},[50,212,57],{"class":56},[50,214,61],{"class":60},[50,216,65],{"class":64},[50,218,68],{"class":60},[50,220,96],{"class":71},[50,222,223],{"class":56},"([",[50,225,226],{"class":156},"'name'",[50,228,229],{"class":60}," =>",[50,231,232],{"class":156}," 'QQ先生'",[50,234,235],{"class":56},"]);\n",[50,237,238,240],{"class":52,"line":78},[50,239,184],{"class":64},[50,241,187],{"class":56},[17,243,244],{},[194,245],{"alt":246,"src":247},"returned array","https:\u002F\u002Fi.imgur.com\u002FLGzhxA6.png",[17,249,250,251,253,254,256],{},"The way ",[32,252,38],{}," does filtering is by passing in an array of conditions. But what if you want to query multiple records? Can ",[32,255,38],{}," handle that?",[41,258,260],{"className":43,"code":259,"language":45,"meta":46,"style":46},"$user = aboutModel::all(['name' => 'QQ先生','name' => '王小明']);\necho $user;\n",[32,261,262,294],{"__ignoreMap":46},[50,263,264,266,268,270,272,274,276,278,280,282,285,287,289,292],{"class":52,"line":53},[50,265,57],{"class":56},[50,267,61],{"class":60},[50,269,65],{"class":64},[50,271,68],{"class":60},[50,273,96],{"class":71},[50,275,223],{"class":56},[50,277,226],{"class":156},[50,279,229],{"class":60},[50,281,232],{"class":156},[50,283,284],{"class":56},",",[50,286,226],{"class":156},[50,288,229],{"class":60},[50,290,291],{"class":156}," '王小明'",[50,293,235],{"class":56},[50,295,296,298],{"class":52,"line":78},[50,297,184],{"class":64},[50,299,187],{"class":56},[17,301,302],{},"Let's just look at what comes back ↓",[17,304,305],{},[194,306],{"alt":307,"src":247},"QQ先生 disappeared",[17,309,310],{},"So as you can see, if you want to do anything more complicated, I'd recommend writing it with the query builder. It's more intuitive and easier to maintain.",[12,312,314],{"id":313},"deleting-records","Deleting records",[17,316,317,318,321,322,325,326,329],{},"Next up is how to delete, using the ",[32,319,320],{},"delete()"," method. When you delete, I'd strongly suggest matching on the primary key (the ",[32,323,324],{},"key",") — otherwise you might run into ",[104,327,328],{},"accidentally wiping the wrong data",". The delete itself is dead simple:",[41,331,333],{"className":43,"code":332,"language":45,"meta":46,"style":46},"$user = aboutModel::get($id);\n$user->delete();\n",[32,334,335,349],{"__ignoreMap":46},[50,336,337,339,341,343,345,347],{"class":52,"line":53},[50,338,57],{"class":56},[50,340,61],{"class":60},[50,342,65],{"class":64},[50,344,68],{"class":60},[50,346,72],{"class":71},[50,348,75],{"class":56},[50,350,351,354,356,359],{"class":52,"line":78},[50,352,353],{"class":56},"$user",[50,355,174],{"class":60},[50,357,358],{"class":71},"delete",[50,360,99],{"class":56},[17,362,363,364,366,367,370,371,374],{},"You read that right, it really is that short. When the delete succeeds, ",[32,365,320],{}," returns a boolean (",[32,368,369],{},"true"," or ",[32,372,373],{},"false","), so you can check the return value to decide whether it worked:",[41,376,378],{"className":43,"code":377,"language":45,"meta":46,"style":46},"$user = aboutModel::get($id);\nif ($user->delete()) {\n  return '刪除成功'.$user->id;\n} else {\n  return $user->getError();\n}\n",[32,379,380,394,409,426,438,453],{"__ignoreMap":46},[50,381,382,384,386,388,390,392],{"class":52,"line":53},[50,383,57],{"class":56},[50,385,61],{"class":60},[50,387,65],{"class":64},[50,389,68],{"class":60},[50,391,72],{"class":71},[50,393,75],{"class":56},[50,395,396,399,402,404,406],{"class":52,"line":78},[50,397,398],{"class":60},"if",[50,400,401],{"class":56}," ($user",[50,403,174],{"class":60},[50,405,358],{"class":71},[50,407,408],{"class":56},"()) {\n",[50,410,411,414,417,419,421,423],{"class":52,"line":85},[50,412,413],{"class":60},"  return",[50,415,416],{"class":156}," '刪除成功'",[50,418,118],{"class":60},[50,420,353],{"class":56},[50,422,174],{"class":60},[50,424,425],{"class":56},"id;\n",[50,427,429,432,435],{"class":52,"line":428},4,[50,430,431],{"class":56},"} ",[50,433,434],{"class":60},"else",[50,436,437],{"class":56}," {\n",[50,439,441,443,446,448,451],{"class":52,"line":440},5,[50,442,413],{"class":60},[50,444,445],{"class":56}," $user",[50,447,174],{"class":60},[50,449,450],{"class":71},"getError",[50,452,99],{"class":56},[50,454,456],{"class":52,"line":455},6,[50,457,458],{"class":56},"}\n",[17,460,461,462,465,466,469],{},"I've already registered the route here: ",[32,463,464],{},"Route::get('\u002Fabout\u002Fdelete\u002F:id', 'about\u002Findex\u002Fdelete');",". So you just hit the route and it deletes that specific record. For example, say I want to delete ",[50,467,468],{},"QQ先生"," ↓",[17,471,472],{},[194,473],{"alt":474,"src":475},"delete succeeded","https:\u002F\u002Fi.imgur.com\u002FvZrrbbg.png",[17,477,478],{},"And of course we can check the table to confirm QQ先生 really is gone ↓",[17,480,481],{},[194,482],{"alt":483,"src":484},"QQ先生 really is gone now","https:\u002F\u002Fi.imgur.com\u002Foc0dIJd.png",[12,486,488],{"id":487},"outputting-json","Outputting JSON",[17,490,491,492,494],{},"Last thing — I'll cover how to output JSON. I'll use the ",[32,493,38],{}," method here. With front-end and back-end being separated these days, most development is API-based and returns JSON, so outputting JSON is pretty important. The good news is it's easy, because ThinkPHP already provides a method for it. You just write:",[41,496,498],{"className":43,"code":497,"language":45,"meta":46,"style":46},"$user = aboutModel::all();\nreturn $user->toJson();\n",[32,499,500,514],{"__ignoreMap":46},[50,501,502,504,506,508,510,512],{"class":52,"line":53},[50,503,57],{"class":56},[50,505,61],{"class":60},[50,507,65],{"class":64},[50,509,68],{"class":60},[50,511,96],{"class":71},[50,513,99],{"class":56},[50,515,516,519,521,523,526],{"class":52,"line":78},[50,517,518],{"class":60},"return",[50,520,445],{"class":56},[50,522,174],{"class":60},[50,524,525],{"class":71},"toJson",[50,527,99],{"class":56},[17,529,530],{},"ThinkPHP also has an even shorter way to do it — except the \"shorter way\" is just… the normal way. The normal way already outputs JSON:",[41,532,534],{"className":43,"code":533,"language":45,"meta":46,"style":46},"$user = aboutModel::all();\nreturn $user;\n",[32,535,536,550],{"__ignoreMap":46},[50,537,538,540,542,544,546,548],{"class":52,"line":53},[50,539,57],{"class":56},[50,541,61],{"class":60},[50,543,65],{"class":64},[50,545,68],{"class":60},[50,547,96],{"class":71},[50,549,99],{"class":56},[50,551,552,554],{"class":52,"line":78},[50,553,518],{"class":60},[50,555,187],{"class":56},[17,557,558],{},"But I figured it was still worth pointing out that this works.",[12,560,562],{"id":561},"wrapping-up","Wrapping up",[17,564,565,566,569],{},"One last thing — if you hit a ",[32,567,568],{},"Trying to get property 'name' of non-object"," error, that comes from a slightly sloppy route registration I set up in an earlier chapter. This route is the culprit:",[41,571,573],{"className":43,"code":572,"language":45,"meta":46,"style":46},"Route::get('\u002Fabout\u002F:id', 'about\u002Findex\u002Fselect');\n",[32,574,575],{"__ignoreMap":46},[50,576,577,580,582,584,586,589,591,594],{"class":52,"line":53},[50,578,579],{"class":64},"Route",[50,581,68],{"class":60},[50,583,72],{"class":71},[50,585,153],{"class":56},[50,587,588],{"class":156},"'\u002Fabout\u002F:id'",[50,590,160],{"class":56},[50,592,593],{"class":156},"'about\u002Findex\u002Fselect'",[50,595,596],{"class":56},");\n",[17,598,599],{},"You just need to change it to the following and you're good:",[41,601,603],{"className":43,"code":602,"language":45,"meta":46,"style":46},"Route::get('\u002Fabout\u002Fselect\u002F:id', 'about\u002Findex\u002Fselect');\n",[32,604,605],{"__ignoreMap":46},[50,606,607,609,611,613,615,618,620,622],{"class":52,"line":53},[50,608,579],{"class":64},[50,610,68],{"class":60},[50,612,72],{"class":71},[50,614,153],{"class":56},[50,616,617],{"class":156},"'\u002Fabout\u002Fselect\u002F:id'",[50,619,160],{"class":56},[50,621,593],{"class":156},[50,623,596],{"class":56},[625,626,627],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":46,"searchDepth":78,"depth":78,"links":629},[630,631,632,633,634,635],{"id":14,"depth":78,"text":15},{"id":22,"depth":78,"text":23},{"id":110,"depth":78,"text":111},{"id":313,"depth":78,"text":314},{"id":487,"depth":78,"text":488},{"id":561,"depth":78,"text":562},"PHP","2019-09-19 00:01:05","haha, I wandered off and now I've wandered right back. This time I want to fill in some gaps around querying — how do you run a conditional query with a Model, and how do you sort the results afterwards? We'll also cover deleting records and outputting JSON, which matters a lot now that everyone builds APIs.","md","en",{},"\u002Fen\u002Fphp\u002Fthinkphp-day-18-model-basics-4","3",{"title":6,"description":638},false,"en\u002FPHP\u002Fthinkphp-day-18-model-basics-4",[636,648,649,650,651],"MySQL","ThinkPHP 5.1","Learning ThinkPHP from Scratch","11th iThome Ironman Contest",null,"\u002Fen\u002Fphp\u002F2019\u002F09\u002F19\u002Fthinkphp-day-18-model-basics-4\u002F","9dXIFwlxL1i7spoCf1-PFyueCMubLDo2s7VjPZrAqUY",{"newer":656,"older":660},{"url":657,"title":658,"date":659},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F19\u002Fjs-from-zero-04-events-and-listeners\u002F","RE: Learning JS From Zero — Day 4: Events and Event Listeners","2019-09-19 00:01:10",{"url":661,"title":662,"date":663},"\u002Fen\u002Flearning\u002F2019\u002F09\u002F18\u002Fabout-the-freelance-service\u002F","About the Freelance Project Service","2019-09-18 12:53:13",[665,670,674],{"url":666,"title":667,"date":668,"readingMinutes":669},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":671,"title":672,"date":673,"readingMinutes":643},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learning ThinkPHP From Scratch: The End Is Just Another Beginning","2019-10-02 00:00:02",{"url":675,"title":676,"date":677,"readingMinutes":678},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F01\u002Fthinkphp-day-30-deploy-to-heroku\u002F","Day 30 - Learning ThinkPHP from Scratch: Deploying to Heroku","2019-10-01 00:00:01","4",1784010286136]