[{"data":1,"prerenderedAt":149},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fphp\u002F2019\u002F07\u002F29\u002Fcomposer-installation\u002F":3,"page:\u002Fen\u002Fphp\u002F2019\u002F07\u002F29\u002Fcomposer-installation\u002F":4,"alt:\u002Fen\u002Fphp\u002F2019\u002F07\u002F29\u002Fcomposer-installation\u002F":3,"prev-next:\u002Fen\u002Fphp\u002F2019\u002F07\u002F29\u002Fcomposer-installation\u002F":124,"related:\u002Fen\u002Fphp\u002F2019\u002F07\u002F29\u002Fcomposer-installation\u002F":133},"\u002Fphp\u002F20190729\u002F3880646315\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":108,"date":109,"description":19,"extension":110,"lang":111,"meta":112,"navigation":113,"path":114,"readingMinutes":115,"seo":116,"standalone":117,"stem":118,"tags":119,"tldr":121,"updated":121,"url":122,"__hash__":123},"content\u002Fen\u002FPHP\u002Fcomposer-installation.md","Installing Composer","8064631538",{"type":9,"value":10,"toc":100},"minimark",[11,16,20,24,27,31,42,48,55,60,67,72,75,81,84,88,95],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"A quick note on how to install Composer.",[12,21,23],{"id":22},"composer","Composer",[17,25,26],{},"Before installing, a quick intro to what Composer is — Composer is a PHP package manager. You can think of it like NPM. You'll see Composer a lot during Laravel setup, because Laravel is installed via Composer. Composer is basically a must-have for modern PHP development.",[12,28,30],{"id":29},"how-to-install","How to install",[17,32,33,34,41],{},"First, open the Composer ",[35,36,40],"a",{"href":37,"rel":38},"https:\u002F\u002Fgetcomposer.org\u002Fdownload\u002F",[39],"nofollow","official site",":",[17,43,44],{},[45,46],"img",{"alt":23,"src":47},"https:\u002F\u002Fi.imgur.com\u002FyvlYsez.png",[17,49,50,51,41],{},"Click ",[52,53,54],"code",{},"Composer-Setup.exe",[17,56,57],{},[45,58],{"alt":54,"src":59},"https:\u002F\u002Fi.imgur.com\u002FC8eOZUc.png",[17,61,62,63,66],{},"In the next step, just point it at ",[52,64,65],{},"PHP.exe"," to start the install (I'm being lazy and using XAMPP here):",[17,68,69],{},[45,70],{"alt":65,"src":71},"https:\u002F\u002Fi.imgur.com\u002F3aKtFfw.png",[17,73,74],{},"You can leave this blank and just hit Next:",[17,76,77],{},[45,78],{"alt":79,"src":80},"Next","https:\u002F\u002Fi.imgur.com\u002FvMG0UXu.png",[17,82,83],{},"Keep clicking Next until it finishes...",[12,85,87],{"id":86},"verifying-the-install","Verifying the install",[17,89,90,91,94],{},"Just run ",[52,92,93],{},"Composer -V"," in the command line — if you see a version number, you're good:",[17,96,97],{},[45,98],{"alt":93,"src":99},"https:\u002F\u002Fi.imgur.com\u002FVGGGiVN.png",{"title":101,"searchDepth":102,"depth":102,"links":103},"",2,[104,105,106,107],{"id":14,"depth":102,"text":15},{"id":22,"depth":102,"text":23},{"id":29,"depth":102,"text":30},{"id":86,"depth":102,"text":87},"PHP","2019-07-29 20:48:44","md","en",{},true,"\u002Fen\u002Fphp\u002Fcomposer-installation","1",{"title":6,"description":19},false,"en\u002FPHP\u002Fcomposer-installation",[120,108,23],"Environment Setup",null,"\u002Fen\u002Fphp\u002F2019\u002F07\u002F29\u002Fcomposer-installation\u002F","dO4WC9bQSA-HRQAUV00XquKmf9iPEdbKBhtNqHNgwgE",{"newer":125,"older":129},{"url":126,"title":127,"date":128},"\u002Fen\u002Fhexo\u002F2019\u002F07\u002F30\u002Fhexo-command-not-found\u002F","Hexo Command Not Found","2019-07-30 11:51:48",{"url":130,"title":131,"date":132},"\u002Fen\u002Fmysql\u002F2019\u002F07\u002F29\u002Finstalling-mysql-8-0-17\u002F","Installing MySQL 8.0.17.0 (on Windows)","2019-07-29 17:53:31",[134,139,144],{"url":135,"title":136,"date":137,"readingMinutes":138},"\u002Fen\u002Fphp\u002F2022\u002F04\u002F17\u002Fmac-xampp-apache-wont-start-fix\u002F","Fixing Mac XAMPP Apache Won't Start","2022-04-17 14:32:41","2",{"url":140,"title":141,"date":142,"readingMinutes":143},"\u002Fen\u002Fphp\u002F2019\u002F10\u002F02\u002Fthinkphp-day-31-the-end-is-just-another-beginning\u002F","Day 31 - Learni