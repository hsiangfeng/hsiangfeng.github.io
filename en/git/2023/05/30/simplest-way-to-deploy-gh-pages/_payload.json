css",[41,418,419,426,440,452],{"__ignoreMap":71},[195,420,421,423],{"class":197,"line":198},[195,422,370],{"class":205},[195,424,425],{"class":201}," {\n",[195,427,428,431,434,437],{"class":197,"line":216},[195,429,430],{"class":209},"  background-color",[195,432,433],{"class":201},": ",[195,435,436],{"class":209},"black",[195,438,439],{"class":201},";\n",[195,441,442,445,447,450],{"class":197,"line":236},[195,443,444],{"class":209},"  color",[195,446,433],{"class":201},[195,448,449],{"class":209},"white",[195,451,439],{"class":201},[195,453,454],{"class":197,"line":246},[195,455,456],{"class":201},"}\n",[172,458,460],{"id":459},"init-git","Init git",[12,462,463,464,186],{},"I'll create an empty repo called ",[41,465,466],{},"example-gh-pages",[12,468,469],{},[15,470],{"alt":466,"src":471},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2009.59.39.png",[12,473,474,475,477],{},"Then init Git in the ",[41,476,181],{}," folder and push to GitHub:",[65,479,483],{"className":480,"code":481,"language":482,"meta":71,"style":71},"language-bash shiki shiki-themes github-dark-high-contrast","git init # init git\ngit add . # stage everything\ngit commit -m \"first commit\" # commit\ngit branch -M main # rename branch to main\ngit remote add origin git@github.com:hsiangfeng\u002Fexample-gh-pages.git # add remote\ngit push -u origin main # push main and set upstream\n","bash",[41,484,485,498,511,527,543,561],{"__ignoreMap":71},[195,486,487,491,494],{"class":197,"line":198},[195,488,490],{"class":489},"s_sBn","git",[195,492,493],{"class":230}," init",[195,495,497],{"class":496},"sQrFR"," # init git\n",[195,499,500,502,505,508],{"class":197,"line":216},[195,501,490],{"class":489},[195,503,504],{"class":230}," add",[195,506,507],{"class":230}," .",[195,509,510],{"class":496}," # stage everything\n",[195,512,513,515,518,521,524],{"class":197,"line":236},[195,514,490],{"class":489},[195,516,517],{"class":230}," commit",[195,519,520],{"class":209}," -m",[195,522,523],{"class":230}," \"first commit\"",[195,525,526],{"class":496}," # commit\n",[195,528,529,531,534,537,540],{"class":197,"line":246},[195,530,490],{"class":489},[195,532,533],{"class":230}," branch",[195,535,536],{"class":209}," -M",[195,538,539],{"class":230}," main",[195,541,542],{"class":496}," # rename branch to main\n",[195,544,545,547,550,552,555,558],{"class":197,"line":265},[195,546,490],{"class":489},[195,548,549],{"class":230}," remote",[195,551,504],{"class":230},[195,553,554],{"class":230}," origin",[195,556,557],{"class":230}," git@github.com:hsiangfeng\u002Fexample-gh-pages.git",[195,559,560],{"class":496}," # add remote\n",[195,562,563,565,568,571,573,575],{"class":197,"line":290},[195,564,490],{"class":489},[195,566,567],{"class":230}," push",[195,569,570],{"class":209}," -u",[195,572,554],{"class":230},[195,574,539],{"class":230},[195,576,577],{"class":496}," # push main and set upstream\n",[75,579,580],{},[12,581,582,584,587],{},[80,583,82],{},[41,585,586],{},"git remote add origin git@github.com:hsiangfeng\u002Fexample-gh-pages.git"," will look different for you — substitute your own username and repo name.",[12,589,590,591,594],{},"After ",[41,592,593],{},"git push -u origin main",", your GitHub repo should look like this:",[12,596,597],{},[15,598],{"alt":599,"src":600},"GitHub","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2010.07.51.png",[172,602,604],{"id":603},"use-the-gh-pages-package","Use the gh-pages package",[12,606,607],{},"So what's next? If it were a pure static site (no build step), you'd just create a gh-pages branch in your repo, push your code there, and GitHub auto-deploys. But this approach has a problem: you'd have to push source to main AND push compiled files to gh-pages — humans make mistakes doing that. To cut down on mistakes, we use the gh-pages npm package.",[12,609,610],{},"Back in your project folder, run:",[65,612,614],{"className":480,"code":613,"language":482,"meta":71,"style":71},"npm init -y # init npm\nnpm install gh-pages # install gh-pages\n",[41,615,616,629],{"__ignoreMap":71},[195,617,618,621,623,626],{"class":197,"line":198},[195,619,620],{"class":489},"npm",[195,622,493],{"class":230},[195,624,625],{"class":209}," -y",[195,627,628],{"class":496}," # init npm\n",[195,630,631,633,636,639],{"class":197,"line":216},[195,632,620],{"class":489},[195,634,635],{"class":230}," install",[195,637,638],{"class":230}," gh-pages",[195,640,641],{"class":496}," # install gh-pages\n",[12,643,644,645,648],{},"Create a ",[41,646,647],{},".gitignore"," with:",[65,650,653],{"className":651,"code":652,"language":70,"meta":71},[68],"node_modules\n",[41,654,652],{"__ignoreMap":71},[12,656,657,659,660,663,664,95],{},[41,658,647],{}," tells Git to skip certain files — like ",[41,661,662],{},"node_modules",", which is huge and can always be regenerated via ",[41,665,666],{},"npm install",[12,668,669,670,673],{},"Edit ",[41,671,672],{},"package.json"," to look like this:",[65,675,679],{"className":676,"code":677,"language":678,"meta":71,"style":71},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"name\": \"example\",\n  \"version\": \"1.0.0\",\n  \"description\": \"\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\",\n    \"deploy\": \"gh-pages -d src\"\n  },\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"git+https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages.git\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"bugs\": {\n    \"url\": \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages\u002Fissues\"\n  },\n  \"homepage\": \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages#readme\",\n  \"dependencies\": {\n    \"gh-pages\": \"^5.0.0\"\n  }\n}\n","json",[41,680,681,686,699,711,723,735,743,767,777,782,7