ground-color: black;\n  color: white;\n}\n","css",[41,416,417,424,439,451],{"__ignoreMap":71},[193,418,419,421],{"class":195,"line":196},[193,420,368],{"class":203},[193,422,423],{"class":199}," {\n",[193,425,426,430,433,436],{"class":195,"line":214},[193,427,429],{"class":428},"stw71","  background-color",[193,431,432],{"class":199},": ",[193,434,435],{"class":428},"black",[193,437,438],{"class":199},";\n",[193,440,441,444,446,449],{"class":195,"line":234},[193,442,443],{"class":428},"  color",[193,445,432],{"class":199},[193,447,448],{"class":428},"white",[193,450,438],{"class":199},[193,452,453],{"class":195,"line":244},[193,454,455],{"class":199},"}\n",[170,457,459],{"id":458},"init-git","Init git",[12,461,462,463,184],{},"I'll create an empty repo called ",[41,464,465],{},"example-gh-pages",[12,467,468],{},[15,469],{"alt":465,"src":470},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2009.59.39.png",[12,472,473,474,476],{},"Then init Git in the ",[41,475,179],{}," folder and push to GitHub:",[65,478,482],{"className":479,"code":480,"language":481,"meta":71,"style":71},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","git init # init git\ngit add . # stage everything\ngit commit -m \"first commit\" # commit\ngit branch -M main # rename branch to main\ngit remote add origin git@github.com:hsiangfeng\u002Fexample-gh-pages.git # add remote\ngit push -u origin main # push main and set upstream\n","bash",[41,483,484,497,510,526,542,560],{"__ignoreMap":71},[193,485,486,490,493],{"class":195,"line":196},[193,487,489],{"class":488},"smYoP","git",[193,491,492],{"class":228}," init",[193,494,496],{"class":495},"sGBqm"," # init git\n",[193,498,499,501,504,507],{"class":195,"line":214},[193,500,489],{"class":488},[193,502,503],{"class":228}," add",[193,505,506],{"class":228}," .",[193,508,509],{"class":495}," # stage everything\n",[193,511,512,514,517,520,523],{"class"