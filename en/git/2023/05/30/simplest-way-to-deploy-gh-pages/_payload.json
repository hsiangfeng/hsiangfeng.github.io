, we use the gh-pages npm package.",[12,606,607],{},"Back in your project folder, run:",[65,609,611],{"className":479,"code":610,"language":481,"meta":71,"style":71},"npm init -y # init npm\nnpm install gh-pages # install gh-pages\n",[41,612,613,626],{"__ignoreMap":71},[193,614,615,618,620,623],{"class":195,"line":196},[193,616,617],{"class":488},"npm",[193,619,492],{"class":228},[193,621,622],{"class":428}," -y",[193,624,625],{"class":495}," # init npm\n",[193,627,628,630,633,636],{"class":195,"line":214},[193,629,617],{"class":488},[193,631,632],{"class":228}," install",[193,634,635],{"class":228}," gh-pages",[193,637,638],{"class":495}," # install gh-pages\n",[12,640,641,642,645],{},"Create a ",[41,643,644],{},".gitignore"," with:",[65,647,650],{"className":648,"code":649,"language":70,"meta":71},[68],"node_modules\n",[41,651,649],{"__ignoreMap":71},[12,653,654,656,657,660,661,93],{},[41,655,644],{}," tells Git to skip certain files — like ",[41,658,659],{},"node_modules",", which is huge and can always be regenerated via ",[41,662,663],{},"npm install",[12,665,666,667,670],{},"Edit ",[41,668,669],{},"package.json"," to look like this:",[65,672,676],{"className":673,"code":674,"language":675,"meta":71,"style":71},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  \"name\": \"example\",\n  \"version\": \"1.0.0\",\n  \"description\": \"\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\",\n    \"deploy\": \"gh-pages -d src\"\n  },\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"git+https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages.git\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"bugs\": {\n    \"url\": \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages\u002Fissues\"\n  },\n  \"homepage\": \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages#readme\",\n  \"dependenc