[{"data":1,"prerenderedAt":902},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F":3,"page:\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F":4,"alt:\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F":3,"prev-next:\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F":878,"related:\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F":887},"\u002Fgit\u002F20221230\u002F27133639\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":542,"date":862,"description":863,"extension":864,"lang":865,"meta":866,"navigation":201,"path":867,"readingMinutes":868,"seo":869,"standalone":870,"stem":871,"tags":872,"tldr":874,"updated":875,"url":876,"__hash__":877},"content\u002Fen\u002FGit\u002Fgit-filename-case-sensitivity-fix.md","Git Filename Case Sensitivity Issues and How to Fix Them","3639271727",{"type":9,"value":10,"toc":853},"minimark",[11,16,20,24,27,68,71,121,124,131,134,150,157,222,237,241,244,249,264,267,281,288,309,334,343,375,385,390,406,411,538,544,554,569,573,588,591,609,622,627,707,717,817,829,835,839,849],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"A lot of people get burned by Git's case-insensitive filename behavior. So this post is dedicated to reproducing the issue and showing how to fix it.",[12,21,23],{"id":22},"reproducing-the-issue","Reproducing the issue",[17,25,26],{},"Let's trigger this first so it actually sticks. Create a folder and a file:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir test\ncd test\ntouch readme.md\n","bash","",[35,36,37,50,59],"code",{"__ignoreMap":33},[38,39,42,46],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"s_sBn","mkdir",[38,47,49],{"class":48},"sTRMh"," test\n",[38,51,53,57],{"class":40,"line":52},2,[38,54,56],{"class":55},"sCcAr","cd",[38,58,49],{"class":48},[38,60,62,65],{"class":40,"line":61},3,[38,63,64],{"class":44},"touch",[38,66,67],{"class":48}," readme.md\n",[17,69,70],{},"Add it to Git and push to GitHub:",[28,72,74],{"className":30,"code":73,"language":32,"meta":33,"style":33},"git init\ngit add .\ngit commit -m \"init\"\ngit push origin main\n",[35,75,76,84,94,107],{"__ignoreMap":33},[38,77,78,81],{"class":40,"line":41},[38,79,80],{"class":44},"git",[38,82,83],{"class":48}," init\n",[38,85,86,88,91],{"class":40,"line":52},[38,87,80],{"class":44},[38,89,90],{"class":48}," add",[38,92,93],{"class":48}," .\n",[38,95,96,98,101,104],{"class":40,"line":61},[38,97,80],{"class":44},[38,99,100],{"class":48}," commit",[38,102,103],{"class":55}," -m",[38,105,106],{"class":48}," \"init\"\n",[38,108,110,112,115,118],{"class":40,"line":109},4,[38,111,80],{"class":44},[38,113,114],{"class":48}," push",[38,116,117],{"class":48}," origin",[38,119,120],{"class":48}," main\n",[17,122,123],{},"At this point your remote repo should look like:",[17,125,126],{},[127,128],"img",{"alt":129,"src":130},"GitHub","https:\u002F\u002Fi.imgur.com\u002FGoZjV4a.png",[17,132,133],{},"Now let's rename the file to README.md:",[28,135,137],{"className":30,"code":136,"language":32,"meta":33,"style":33},"mv readme.md README.md\n",[35,138,139],{"__ignoreMap":33},[38,140,141,144,147],{"class":40,"line":41},[38,142,143],{"class":44},"mv",[38,145,146],{"class":48}," readme.md",[38,148,149],{"class":48}," README.md\n",[17,151,152,153,156],{},"Run ",[35,154,155],{},"git status"," and you'll see:",[28,158,160],{"className":30,"code":159,"language":32,"meta":33,"style":33},"On branch main\nYour branch is up to date with 'origin\u002Fmain'.\n\nnothing to commit, working tree clean\n",[35,161,162,172,197,203],{"__ignoreMap":33},[38,163,164,167,170],{"class":40,"line":41},[38,165,166],{"class":44},"On",[38,168,169],{"class":48}," branch",[38,171,120],{"class":48},[38,173,174,177,179,182,185,188,191,194],{"class":40,"line":52},[38,175,176],{"class":44},"Your",[38,178,169],{"class":48},[38,180,181],{"class":48}," is",[38,183,184],{"class":48}," up",[38,186,187],{"class":48}," to",[38,189,190],{"class":48}," date",[38,192,193],{"class":48}," with",[38,195,196],{"class":48}," 'origin\u002Fmain'.\n",[38,198,199],{"class":40,"line":61},[38,200,202],{"emptyLinePlaceholder":201},true,"\n",[38,204,205,208,210,213,216,219],{"class":40,"line":109},[38,206,207],{"class":44},"nothing",[38,209,187],{"class":48},[38,211,212],{"class":48}," commit,",[38,214,215],{"class":48}," working",[38,217,218],{"class":48}," tree",[38,220,221],{"class":48}," clean\n",[17,223,224,225,228,229,232,233,236],{},"Now try ",[35,226,227],{},"git add ."," — and Git doesn't react at all. Why? Because by default Git treats ",[35,230,231],{},"readme.md"," and ",[35,234,235],{},"README.md"," as the same file, so it sees no change.",[12,238,240],{"id":239},"how-to-fix-it","How to fix it",[17,242,243],{},"Two approaches. The first is a Git config tweak, the second is a Git command.",[245,246,248],"h3",{"id":247},"git-config","Git config",[17,250,251,252,255,256,259,260,263],{},"Git has a setting that controls case sensitivity for filenames: ",[35,253,254],{},"git config core.ignorecase",". Setting this to ",[35,257,258],{},"false"," makes Git treat differently-cased files as different files, so it'll properly detect changes. By default it's ",[35,261,262],{},"true"," (ignoring case).",[17,265,266],{},"Rename README.md back first:",[28,268,270],{"className":30,"code":269,"language":32,"meta":33,"style":33},"mv README.md readme.md\n",[35,271,272],{"__ignoreMap":33},[38,273,274,276,279],{"class":40,"line":41},[38,275,143],{"class":44},[38,277,278],{"class":48}," README.md",[38,280,67],{"class":48},[17,282,283,284,287],{},"Then set ",[35,285,286],{},"core.ignorecase"," to false:",[28,289,291],{"className":30,"code":290,"language":32,"meta":33,"style":33},"git config --local core.ignorecase false\n",[35,292,293],{"__ignoreMap":33},[38,294,295,297,300,303,306],{"class":40,"line":41},[38,296,80],{"class":44},[38,298,299],{"class":48}," config",[38,301,302],{"class":55}," --local",[38,304,305],{"class":48}," core.ignorecase",[38,307,308],{"class":55}," false\n",[310,311,312],"blockquote",{},[17,313,314,318,319,322,323,326,327,329,330,333],{},[315,316,317],"strong",{},"Note","\nThere's also a global version of this setting, but using it means setting up a global Git config file, and it affects every project where you run ",[35,320,321],{},"git init",". I'd just use local — that way it only affects the current project.\nAlso, if you set ",[35,324,325],{},"git config --local core.ignorecase false"," locally and push to the remote, the remote repo also picks up ",[35,328,325],{},", so when you ",[35,331,332],{},"git clone"," later you don't have to set it again.",[17,335,336,337,339,340,342],{},"A quick word on ",[35,338,262],{}," vs ",[35,341,258],{},":",[344,345,346,361],"ul",{},[347,348,349,351,352],"li",{},[35,350,262],{},": Git ignores case\n",[344,353,354],{},[347,355,356,232,358,360],{},[35,357,231],{},[35,359,235],{}," are the same file",[347,362,363,365,366],{},[35,364,258],{},": Git treats differently-cased filenames as different files\n",[344,367,368],{},[347,369,370,232,372,374],{},[35,371,231],{},[35,373,235],{}," are different files",[310,376,377],{},[17,378,379,381,382,384],{},[315,380,317],{},"\nRunning ",[35,383,254],{}," (no value) shows the current project's setting.",[17,386,387,388,342],{},"Now rename the file. I'm using ",[35,389,143],{},[28,391,393],{"className":30,"code":392,"language":32,"meta":33,"style":33},"mv -f readme.md README.md\n",[35,394,395],{"__ignoreMap":33},[38,396,397,399,402,404],{"class":40,"line":41},[38,398,143],{"class":44},[38,400,401],{"class":55}," -f",[38,403,146],{"class":48},[38,405,149],{"class":48},[17,407,408,409,342],{},"Then ",[35,410,155],{},[28,412,414],{"className":30,"code":413,"language":32,"meta":33,"style":33},"On branch main\nYour branch is up to date with 'origin\u002Fmain'.\n\nUntracked files:\n  (use \"git add \u003Cfile>...\" to include in what will be committed)\n        README.md\n\nnothing added to commit but untracked files present (use \"git add\" to track)\n",[35,415,416,424,442,446,454,490,496,501],{"__ignoreMap":33},[38,417,418,420,422],{"class":40,"line":41},[38,419,166],{"class":44},[38,421,169],{"class":48},[38,423,120],{"class":48},[38,425,426,428,430,432,434,436,438,440],{"class":40,"line":52},[38,427,176],{"class":44},[38,429,169],{"class":48},[38,431,181],{"class":48},[38,433,184],{"class":48},[38,435,187],{"class":48},[38,437,190],{"class":48},[38,439,193],{"class":48},[38,441,196],{"class":48},[38,443,444],{"class":40,"line":61},[38,445,202],{"emptyLinePlaceholder":201},[38,447,448,451],{"class":40,"line":109},[38,449,450],{"class":44},"Untracked",[38,452,453],{"class":48}," files:\n",[38,455,457,461,464,467,469,472,475,478,481,484,487],{"class":40,"line":456},5,[38,458,460],{"class":459},"sMAXC","  (",[38,462,463],{"class":44},"use",[38,465,466],{"class":48}," \"git add \u003Cfile>...\"",[38,468,187],{"class":48},[38,470,471],{"class":48}," include",[38,473,474],{"class":48}," in",[38,476,477],{"class":48}," what",[38,479,480],{"class":48}," will",[38,482,483],{"class":48}," be",[38,485,486],{"class":48}," committed",[38,488,489],{"class":459},")\n",[38,491,493],{"class":40,"line":492},6,[38,494,495],{"class":44},"        README.md\n",[38,497,499],{"class":40,"line":498},7,[38,500,202],{"emptyLinePlaceholder":201},[38,502,504,506,509,511,513,516,519,522,525,528,531,533,536],{"class":40,"line":503},8,[38,505,207],{"class":44},[38,507,508],{"class":48}," added",[38,510,187],{"class":48},[38,512,100],{"class":48},[38,514,515],{"class":48}," but",[38,517,518],{"class":48}," untracked",[38,520,521],{"class":48}," files",[38,523,524],{"class":48}," present",[38,526,527],{"class":459}," (use ",[38,529,530],{"class":48},"\"git add\"",[38,532,187],{"class":48},[38,534,535],{"class":48}," track",[38,537,489],{"class":459},[17,539,540],{},[127,541],{"alt":542,"src":543},"Git","https:\u002F\u002Fi.imgur.com\u002FiAwhXj3.png",[17,545,546,547,549,550,553],{},"Now Git actually detects the change — so you can ",[35,548,227],{},", ",[35,551,552],{},"git commit",", etc.",[310,555,556],{},[17,557,558,560,561,563,564,232,566,568],{},[315,559,317],{},"\nYou should set ",[35,562,286],{}," during project init — if you do it later, you have a high chance of running into edge cases like two files (",[35,565,235],{},[35,567,231],{},") showing up on the remote after a push. Set it at the start to avoid the gotchas.",[245,570,572],{"id":571},"use-gits-built-in-command","Use Git's built-in command",[17,574,575,576,579,580,583,584,587],{},"Git also has a built-in command for renaming: ",[35,577,578],{},"git mv",". It changes the filename and Git detects the change properly. This is the simplest path — and what I ",[315,581,582],{},"recommend",". Format: ",[35,585,586],{},"git mv \u003Cold name> \u003Cnew name>",".",[17,589,590],{},"So:",[28,592,594],{"className":30,"code":593,"language":32,"meta":33,"style":33},"git mv -f readme.md README.md\n",[35,595,596],{"__ignoreMap":33},[38,597,598,600,603,605,607],{"class":40,"line":41},[38,599,80],{"class":44},[38,601,602],{"class":48}," mv",[38,604,401],{"class":55},[38,606,146],{"class":48},[38,608,149],{"class":48},[310,610,611],{},[17,612,613,615,617,618,621],{},[315,614,317],{},[35,616,578],{}," works for moving and renaming files. ",[35,619,620],{},"-f"," means force.",[17,623,152,624,626],{},[35,625,155],{}," and you get:",[28,628,630],{"className":30,"code":629,"language":32,"meta":33,"style":33},"On branch main\nYour branch is up to date with 'origin\u002Fmain'.\n\nChanges to be committed:\n  (use \"git restore --staged \u003Cfile>...\" to unstage)\n        renamed:    readme.md -> README.md\n",[35,631,632,640,658,662,674,690],{"__ignoreMap":33},[38,633,634,636,638],{"class":40,"line":41},[38,635,166],{"class":44},[38,637,169],{"class":48},[38,639,120],{"class":48},[38,641,642,644,646,648,650,652,654,656],{"class":40,"line":52},[38,643,176],{"class":44},[38,645,169],{"class":48},[38,647,181],{"class":48},[38,649,184],{"class":48},[38,651,187],{"class":48},[38,653,190],{"class":48},[38,655,193],{"class":48},[38,657,196],{"class":48},[38,659,660],{"class":40,"line":61},[38,661,202],{"emptyLinePlaceholder":201},[38,663,664,667,669,671],{"class":40,"line":109},[38,665,666],{"class":44},"Changes",[38,668,187],{"class":48},[38,670,483],{"class":48},[38,672,673],{"class":48}," committed:\n",[38,675,676,678,680,683,685,688],{"class":40,"line":456},[38,677,460],{"class":459},[38,679,463],{"class":44},[38,681,682],{"class":48}," \"git restore --staged \u003Cfile>...\"",[38,684,187],{"class":48},[38,686,687],{"class":48}," unstage",[38,689,489],{"class":459},[38,691,692,695,698,701,705],{"class":40,"line":492},[38,693,694],{"class":44},"        renamed:",[38,696,697],{"class":48},"    readme.md",[38,699,700],{"class":459}," -",[38,702,704],{"class":703},"sWyjQ",">",[38,706,149],{"class":48},[17,708,709,710,713,714,716],{},"Notice the difference from before — this says ",[35,711,712],{},"renamed",", while the ",[35,715,143],{}," approach said:",[28,718,719],{"className":30,"code":413,"language":32,"meta":33,"style":33},[35,720,721,729,747,751,757,781,785,789],{"__ignoreMap":33},[38,722,723,725,727],{"class":40,"line":41},[38,724,166],{"class":44},[38,726,169],{"class":48},[38,728,120],{"class":48},[38,730,731,733,735,737,739,741,743,745],{"class":40,"line":52},[38,732,176],{"class":44},[38,734,169],{"class":48},[38,736,181],{"class":48},[38,738,184],{"class":48},[38,740,187],{"class":48},[38,742,190],{"class":48},[38,744,193],{"class":48},[38,746,196],{"class":48},[38,748,749],{"class":40,"line":61},[38,750,202],{"emptyLinePlaceholder":201},[38,752,753,755],{"class":40,"line":109},[38,754,450],{"class":44},[38,756,453],{"class":48},[38,758,759,761,763,765,767,769,771,773,775,777,779],{"class":40,"line":456},[38,760,460],{"class":459},[38,762,463],{"class":44},[38,764,466],{"class":48},[38,766,187],{"class":48},[38,768,471],{"class":48},[38,770,474],{"class":48},[38,772,477],{"class":48},[38,774,480],{"class":48},[38,776,483],{"class":48},[38,778,486],{"class":48},[38,780,489],{"class":459},[38,782,783],{"class":40,"line":492},[38,784,495],{"class":44},[38,786,787],{"class":40,"line":498},[38,788,202],{"emptyLinePlaceholder":201},[38,790,791,793,795,797,799,801,803,805,807,809,811,813,815],{"class":40,"line":503},[38,792,207],{"class":44},[38,794,508],{"class":48},[38,796,187],{"class":48},[38,798,100],{"class":48},[38,800,515],{"class":48},[38,802,518],{"class":48},[38,804,521],{"class":48},[38,806,524],{"class":48},[38,808,527],{"class":459},[38,810,530],{"class":48},[38,812,187],{"class":48},[38,814,535],{"class":48},[38,816,489],{"class":459},[17,818,819,820,823,824,232,826,828],{},"That's a big difference. With ",[35,821,822],{},"Untracked files",", you're essentially creating a new file — which has a high chance of ending up with duplicate files on the remote (both ",[35,825,231],{},[35,827,235],{},").",[17,830,831,832,834],{},"So the Git command approach is the cleaner one. Whenever you need to rename a file, use ",[35,833,578],{}," — it's the safer bet.",[12,836,838],{"id":837},"wrap-up","Wrap-up",[17,840,841,842,844,845,848],{},"Funny enough — while writing this post I got bitten by this exact issue. I'm so used to using ",[35,843,143],{}," that I kept wondering why something looked off. Halfway through writing I realized I should've used ",[35,846,847],{},"git mv -f",". So this post doubled as a refresher for me.",[850,851,852],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}",{"title":33,"searchDepth":52,"depth":52,"links":854},[855,856,857,861],{"id":14,"depth":52,"text":15},{"id":22,"depth":52,"text":23},{"id":239,"depth":52,"text":240,"children":858},[859,860],{"id":247,"depth":61,"text":248},{"id":571,"depth":61,"text":572},{"id":837,"depth":52,"text":838},"2022-12-30 10:28:35","Git treats readme.md and README.md as the same file on macOS or Windows, so renaming silently does nothing. How to reproduce the trap and two clean ways to fix it.","md","en",{},"\u002Fen\u002Fgit\u002Fgit-filename-case-sensitivity-fix","4",{"title":6,"description":863},false,"en\u002FGit\u002Fgit-filename-case-sensitivity-fix",[542,129,873],"Troubleshooting",null,"2022-02-13 15:10:00","\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F","YswUhbnGU2FWU2i7h6H2Ag1SChZXKWdzXv8lnlT0SII",{"newer":879,"older":883},{"url":880,"title":881,"date":882},"\u002Fen\u002Fgsap\u002F2023\u002F01\u002F02\u002Fgsap3-fx-12-control-animations\u002F","(12) Fun Frontend Effects With GSAP3 - Controlling Animations","2023-01-02 15:33:00",{"url":884,"title":885,"date":886},"\u002Fen\u002Fnodejs\u002F2022\u002F12\u002F25\u002Fupload-files-to-firebase-storage-with-nodejs\u002F","Step-by-Step: Uploading Files to Firebase Storage with Node.js","2022-12-25 17:00:00",[888,892,897],{"url":889,"title":890,"date":891,"readingMinutes":868},"\u002Fen\u002Fgit\u002F2026\u002F02\u002F26\u002Fgit-push-force-with-lease-better-than-force\u002F","A Safer Alternative to git push --force: git push --force-with-lease","2026-02-26 09:39:40",{"url":893,"title":894,"date":895,"readingMinutes":896},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F22\u002Fgit-default-branch-master-to-main\u002F","Git init Shows a master Branch Hint? Here's How to Set main as Default","2026-01-22 16:20:40","3",{"url":898,"title":899,"date":900,"readingMinutes":901},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F21\u002Fgit-worktree-multiple-ai-agents-one-project\u002F","What Is Git Worktree? The Secret to Running Multiple AI Agents in One Project","2026-01-21 16:04:27","5",1784012772691]