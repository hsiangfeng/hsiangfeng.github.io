[{"data":1,"prerenderedAt":185},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F":3,"page:\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F":4,"alt:\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F":3,"prev-next:\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F":160,"related:\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F":169},"\u002Fgit\u002F20190802\u002F1198998279\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":144,"date":145,"description":19,"extension":146,"lang":147,"meta":148,"navigation":149,"path":150,"readingMinutes":151,"seo":152,"standalone":153,"stem":154,"tags":155,"tldr":157,"updated":157,"url":158,"__hash__":159},"content\u002Fen\u002FGit\u002Frename-github-branch.md","Renaming a Branch on GitHub","9279819988",{"type":9,"value":10,"toc":137},"minimark",[11,16,20,24,27,36,40,48,55,62,68,75,84,90,96,104,110,113,119,122,128,131],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Sometimes you need to rename a branch on GitHub, but you can't just delete and recreate it — that would wipe all the commit history. So here's how to rename a branch properly and push the rename to GitHub.",[12,21,23],{"id":22},"setup","Setup",[17,25,26],{},"I'll use this repo as the example:",[17,28,29,30],{},"Repo: ",[31,32,33],"a",{"href":33,"rel":34},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FotherCSS",[35],"nofollow",[12,37,39],{"id":38},"renaming-the-branch","Renaming the branch",[17,41,42,43,47],{},"First, ",[44,45,46],"code",{},"cd"," into the project directory.",[17,49,50],{},[51,52],"img",{"alt":53,"src":54},"Move into directory","https:\u002F\u002Fi.imgur.com\u002FcIYSA9L.png",[17,56,57,58,61],{},"Run ",[44,59,60],{},"git branch -a"," to check all branches.",[17,63,64],{},[51,65],{"alt":66,"src":67},"All branches","https:\u002F\u002Fi.imgur.com\u002FY6fSm0Z.png",[17,69,70,71,74],{},"Say I want to rename master → develop. Run ",[44,72,73],{},"git branch -m master develop",".",[76,77,78],"blockquote",{},[17,79,80,81],{},"Command format: ",[44,82,83],{},"git branch -m [old branch name] [new branch name]",[17,85,86],{},[51,87],{"alt":88,"src":89},"Rename branch","https:\u002F\u002Fi.imgur.com\u002FM1bnyFl.png",[17,91,92,93,74],{},"Now push to GitHub: ",[44,94,95],{},"git push origin develop :master",[76,97,98],{},[17,99,80,100,103],{},[44,101,102],{},"git push origin [new branch name] :[old branch name]"," (note the colon before the old branch name)",[17,105,106],{},[51,107],{"alt":108,"src":109},"Push","https:\u002F\u002Fi.imgur.com\u002F9YBR2HM.png",[17,111,112],{},"You'll see red text in your terminal — that's normal. The master branch can't just be renamed casually, so GitHub auto-creates a new branch for you instead.",[17,114,115],{},[51,116],{"alt":117,"src":118},"ERROR","https:\u002F\u002Fi.imgur.com\u002FnFhVxEz.png",[17,120,121],{},"So now you can use the same flow to rename develop to whatever you actually want — say, css_develop.",[17,123,124],{},[51,125],{"alt":126,"src":127},"css_develop","https:\u002F\u002Fi.imgur.com\u002FdSRiVYX.png",[17,129,130],{},"Head back to GitHub and you'll see the branch has been renamed, and all the commits are still intact.",[17,132,133],{},[51,134],{"alt":135,"src":136},"Branch renamed","https:\u002F\u002Fi.imgur.com\u002FQEpkYPn.png",{"title":138,"searchDepth":139,"depth":139,"links":140},"",2,[141,142,143],{"id":14,"depth":139,"text":15},{"id":22,"depth":139,"text":23},{"id":38,"depth":139,"text":39},"Git","2019-08-02 10:52:04","md","en",{},true,"\u002Fen\u002Fgit\u002Frename-github-branch","1",{"title":6,"description":19},false,"en\u002FGit\u002Frename-github-branch",[156,144],"GitHub",null,"\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F","y_jsayw1tv3UiF6Dm9DOrSvFrB1WyDSWcQB5LxNJfms",{"newer":161,"older":165},{"url":162,"title":163,"date":164},"\u002F