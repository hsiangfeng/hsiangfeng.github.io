,200],{},[37,201,202],{},"git add index",[17,204,205],{},"Stage all files:",[41,207,208],{},[44,209,210],{},[37,211,212],{},"git add .",[17,214,215,216],{},"Commit staged changes: ",[37,217,218],{},"git commit -m 'commit message'",[41,220,221],{},[44,222,223],{},[37,224,225],{},"git commit -m 'first'",[12,227,229],{"id":228},"checking-status-history","Checking status & history",[17,231,232],{},"Check status:",[41,234,235],{},[44,236,237],{},[37,238,158],{},[17,240,241],{},"Show history:",[41,243,244],{},[44,245,246],{},[37,247,248],{},"git log",[12,250,252],{"id":251},"branches","Branches",[17,254,255],{},"Show all branches:",[41,257,258],{},[44,259,260],{},[37,261,262],{},"git branch",[17,264,265,266],{},"Create a new branch: ",[37,267,268],{},"git branch [branch name]",[41,270,271],{},[44,272,273],{},[37,274,275],{},"git branch develop",[17,277,278,279],{},"Switch branches: ",[37,280,281],{},"git checkout [branch name]",[41,283,284],{},[44,285,286],{},[37,287,288],{},"git checkout develop",[17,290,291,292],{},"Delete a branch: ",[37,293,294],{},"git branch -D [branch name]",[41,296,297],{},[44,298,299],{},[37,300,301],{},"git branch -D develop",[17,303,304,305],{},"Merge a branch into the current one: ",[37,306,307],{},"git merge [branch name]",[41,309,310],{},[44,311,312,313],{},"If you're on master: ",[37,314,315],{},"git merge develop",[99,317,319],{"id":318},"remote-git-operations","Remote Git operations",[17,321,175,322],{},[37,323,178],{},[41,325,326],{},[44,327,328],{},[37,329,330],{},"git clone https:\u002F\u002Fgithub.com\u002FRay\u002FPug-Sweetaste.git",[17,332,333,334],{},"Clone into a specific folder: ",[37,335,336],{},"git clone [Url] [path]",[41,338,339],{},[44,340,341],{},[37,342,343],{},"git clone https:\u002F\u002Fgithub.com\u002FRay\u002FPug-Sweetaste.git theme\u002Fpug",[17,345,346,347],{},"List remotes: ",[37,348,349],{},"git remote",[17,351,352],{},[62,353],{"alt":354,"src":355},"remote","https:\u002F\u002Fi.imgur.com\u002FFqf1xsr.png",[17,357