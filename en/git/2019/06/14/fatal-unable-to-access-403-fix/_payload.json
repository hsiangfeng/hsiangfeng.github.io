[{"data":1,"prerenderedAt":121},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgit\u002F2019\u002F06\u002F14\u002Ffatal-unable-to-access-403-fix\u002F":3,"page:\u002Fen\u002Fgit\u002F2019\u002F06\u002F14\u002Ffatal-unable-to-access-403-fix\u002F":4,"alt:\u002Fen\u002Fgit\u002F2019\u002F06\u002F14\u002Ffatal-unable-to-access-403-fix\u002F":3,"prev-next:\u002Fen\u002Fgit\u002F2019\u002F06\u002F14\u002Ffatal-unable-to-access-403-fix\u002F":96,"related:\u002Fen\u002Fgit\u002F2019\u002F06\u002F14\u002Ffatal-unable-to-access-403-fix\u002F":105},"\u002Fgit\u002F20190614\u002F391412804\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":79,"date":80,"description":81,"extension":82,"lang":83,"meta":84,"navigation":85,"path":86,"readingMinutes":87,"seo":88,"standalone":89,"stem":90,"tags":91,"tldr":93,"updated":93,"url":94,"__hash__":95},"content\u002Fen\u002FGit\u002Ffatal-unable-to-access-403-fix.md","fatal: unable to access XXX The requested URL returned error: 403","4128048039",{"type":9,"value":10,"toc":73},"minimark",[11,16,29,33,36,39,46,49,54,61,66],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24,25,28],"p",{},"I was pushing code to GitHub today and ran into something weird — every time I ran ",[21,22,23],"code",{},"git push",", it kept throwing ",[21,26,27],{},"remote: Permission to xxx.git denied to user.",". Here's how I fixed it.",[12,30,32],{"id":31},"whats-going-on","What's going on",[17,34,35],{},"Usually this means you're pushing to a repo you don't have access to. But if you used to be able to push and it suddenly stopped working, it might be that someone else (user B) borrowed your machine and logged into their own GitHub account to pull a repo. Then user B's credentials overrode user A's, and now every push hits a permission error. To fix it, you have to clear user B's saved credentials in Windows Credential Manager — otherwise the permission error keeps coming back.",[17,37,38],{},"Open Control Panel → User Accounts → Manage Windows Credentials.",[17,40,41],{},[42,43],"img",{"alt":44,"src":45},"Image","https:\u002F\u002Fi.imgur.com\u002F5IkhTAb.png",[17,47,48],{},"Remove user B's credentials.",[17,50,51],{},[42,52],{"alt":44,"src":53},"https:\u002F\u002Fi.imgur.com\u002FNcvIP2Q.png",[17,55,56,57,60],{},"Now run ",[21,58,59],{},"git push origin master"," again, and this window will pop up.",[17,62,63],{},[42,64],{"alt":44,"src":65},"https:\u002F\u002Fi.imgur.com\u002Fj8roQWT.png",[17,67,68,69,72],{},"Enter your credentials and ",[21,70,71],{},"push"," works again.",{"title":74,"searchDepth":75,"depth":75,"links":76},"",2,[77,78],{"id":14,"depth":75,"text":15},{"id":31,"depth":75,"text":32},"Git","2019-06-14 21:38:14","Something weird happened today when I ran git push — it kept throwing `remote: Permission to xxx.git denied to user.`. Here's how I fixed it.","md","en",{},true,"\u002Fen\u002Fgit\u002Ffatal-unable-to-access-403-fix","1",{"title":6,"description":81},false,"en\u002FGit\u002Ffatal-unable-to-access-403-fix",[92,79],"GitHub",null,"\u002Fen\u002Fgit\u002F2019\u002F06\u002F14\u002Ffatal-unable-to-access-403-fix\u002F","lHPK2F37eAffHZ1SwClJBtRfycZR5pnWvuT_QVFymzE",{"newer":97,"older":101},{"url":98,"title":99,"date":100},"\u002Fen\u002Fgit\u002F2019\u002F06\u002F15\u002Fbasic-git-commands\u002F","Basic Git Commands","2019-06-15 13:59:25",{"url":102,"title":103,"date":104},"\u002Fen\u002Fmisc\u002F2019\u002F06\u002F14\u002Fuser-story-for-frontend-development\u002F","User Stories from a Frontend Dev's Perspective","2019-06-14 21:07:23",[106,111,116],{"url":107,"title":108,"date":109,"readingMinutes":110},"\u002Fen\u002Fgit\u002F2026\u002F02\u002F26\u002Fgit-push-force-with-lease-better-than-force\u002F","A Safer Alternative to git push --force: git push --force-with-lease","2026-02-26 09:39:40","4",{"url":112,"title":113,"date":114,"readingMinutes":115},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F22\u002Fgit-default-branch-master-to-main\u002F","Git init Shows a master Branch Hint? Here's How to Set main as Default","2026-01-22 16:20:40","3",{"url":117,"title":118,"date":119,"readingMinutes":120},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F21\u002Fgit-worktree-multiple-ai-agents-one-project\u002F","What Is Git Worktree? The Secret to Running Multiple AI Agents in One Project","2026-01-21 16:04:27","5",1784087325151]