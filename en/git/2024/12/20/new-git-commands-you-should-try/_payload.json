[{"data":1,"prerenderedAt":679},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F":3,"page:\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F":4,"alt:\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F":3,"prev-next:\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F":655,"related:\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F":664},"\u002Fgit\u002F20241220\u002F649474526\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":637,"date":638,"description":639,"extension":640,"lang":641,"meta":642,"navigation":643,"path":644,"readingMinutes":645,"seo":646,"standalone":647,"stem":648,"tags":649,"tldr":652,"updated":638,"url":653,"__hash__":654},"content\u002Fen\u002FGit\u002Fnew-git-commands-you-should-try.md","New Git Commands You Should Start Using","4265649747",{"type":9,"value":10,"toc":624},"minimark",[11,19,24,27,31,55,60,71,105,114,122,140,149,152,282,285,296,322,325,458,464,468,489,520,537,540,553,558,562,565,607,610,614],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"New Git commands you should start using","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fgit\u002Fgit-new-commit\u002Fgit_new.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"Quick writeup on some newer Git commands I've found genuinely useful and worth sharing.",[20,28,30],{"id":29},"new-commands","New commands",[12,32,33,34,38,39,38,42,38,45,48,49,54],{},"The Git commands you usually reach for are stuff like ",[35,36,37],"code",{},"git add",", ",[35,40,41],{},"git commit",[35,43,44],{},"git push",[35,46,47],{},"git pull"," (see ",[50,51,53],"a",{"href":52},"\u002Fen\u002Fgit\u002F2019\u002F06\u002F15\u002Fbasic-git-commands\u002F","this post"," for more), but Git has shipped some newer commands worth knowing about. Here's a quick tour.",[56,57,59],"h3",{"id":58},"git-switch","git switch",[12,61,62,63,66,67,70],{},"We used to use ",[35,64,65],{},"git checkout"," for switching branches. When I first learned Git, I found ",[35,68,69],{},"checkout"," super confusing — the literal translation is \"checkout\" like at a store, but in Git it means \"switch\". And it does more than switching branches — it does...",[72,73,74,81,87,93,99],"ul",{},[75,76,77,80],"li",{},[35,78,79],{},"git checkout \u003Cbranch>",": switch to a branch",[75,82,83,86],{},[35,84,85],{},"git checkout -b \u003Cbranch>",": create and switch to a new branch",[75,88,89,92],{},[35,90,91],{},"git checkout -",": switch to the previous branch",[75,94,95,98],{},[35,96,97],{},"git checkout -- \u003Cfile>",": discard changes in the working directory",[75,100,101,104],{},[35,102,103],{},"git checkout \u003Ccommit>",": view a specific commit",[12,106,107,108,110,111,113],{},"So ",[35,109,65],{}," does a lot — which is overwhelming for beginners. That's where ",[35,112,59],{}," comes in.",[12,115,116,118,119,121],{},[35,117,59],{}," shipped in Git 2.23. It's specifically for switching branches — way more focused than ",[35,120,65],{},", and easier for beginners.",[72,123,124,129,134],{},[75,125,126,80],{},[35,127,128],{},"git switch \u003Cbranch>",[75,130,131,86],{},[35,132,133],{},"git switch -c \u003Cbranch>",[75,135,136,139],{},[35,137,138],{},"git switch -",": switch to the previous branch (e.g. develop → master)",[12,141,142,143,145,146,148],{},"Yep — that simple. ",[35,144,59],{}," is just for switching branches. Cleaner mental model than ",[35,147,65],{},".",[12,150,151],{},"Here's a comparison table:",[153,154,155,173],"table",{},[156,157,158],"thead",{},[159,160,161,165,169],"tr",{},[162,163,164],"th",{},"Feature",[162,166,167],{},[35,168,59],{},[162,170,171],{},[35,172,65],{},[174,175,176,193,210,225,243,256,269],"tbody",{},[159,177,178,185,189],{},[179,180,181],"td",{},[182,183,184],"strong",{},"Switch branch",[179,186,187],{},[35,188,128],{},[179,190,191],{},[35,192,79],{},[159,194,195,200,205],{},[179,196,197],{},[182,198,199],{},"Create + switch new branch",[179,201,202],{},[35,203,204],{},"git switch -c \u003Cnew-branch>",[179,206,207],{},[35,208,209],{},"git checkout -b \u003Cnew-branch>",[159,211,212,217,221],{},[179,213,214],{},[182,215,216],{},"Switch to previous branch",[179,218,219],{},[35,220,138],{},[179,222,223],{},[35,224,91],{},[159,226,227,232,238],{},[179,228,229],{},[182,230,231],{},"Restore files",[179,233,234,235],{},"Not supported, use ",[35,236,237],{},"git restore",[179,239,240],{},[35,241,242],{},"git checkout \u003Cfile>",[159,244,245,250,253],{},[179,246,247],{},[182,248,249],{},"Semantic clarity",[179,251,252],{},"Focused on branch ops",[179,254,255],{},"Multi-purpose, can confuse",[159,257,258,263,266],{},[179,259,260],{},[182,261,262],{},"Git version",[179,264,265],{},"2.23+",[179,267,268],{},"All versions",[159,270,271,276,279],{},[179,272,273],{},[182,274,275],{},"Specialization",[179,277,278],{},"Branch-focused",[179,280,281],{},"Both branch and file ops",[56,283,237],{"id":284},"git-restore",[12,286,287,289,290,292,293,148],{},[35,288,237],{}," also came out of the ",[35,291,65],{}," split — same goal of making things semantically clear. It's specifically for ",[182,294,295],{},"restoring files",[72,297,298,304,310,316],{},[75,299,300,303],{},[35,301,302],{},"git restore \u003Cfile>",": restore a file",[75,305,306,309],{},[35,307,308],{},"git restore --staged \u003Cfile>",": unstage a file",[75,311,312,315],{},[35,313,314],{},"git restore --source=HEAD --staged --worktree \u003Cfile>",": restore staged + working tree to original state",[75,317,318,321],{},[35,319,320],{},"git restore .",": restore all files",[12,323,324],{},"Comparison table:",[153,326,327,341],{},[156,328,329],{},[159,330,331,333,337],{},[162,332,164],{},[162,334,335],{},[35,336,65],{},[162,338,339],{},[35,340,237],{},[174,342,343,358,374,391,406,420,435,448],{},[159,344,345,350,354],{},[179,346,347],{},[182,348,349],{},"Restore file in working dir",[179,351,352],{},[35,353,242],{},[179,355,356],{},[35,357,302],{},[159,359,360,365,370],{},[179,361,362],{},[182,363,364],{},"Unstage a staged change",[179,366,367],{},[35,368,369],{},"git reset \u003Cfile>",[179,371,372],{},[35,373,308],{},[159,375,376,381,386],{},[179,377,378],{},[182,379,380],{},"Restore to a specific commit",[179,382,383],{},[35,384,385],{},"git checkout \u003Ccommit> -- \u003Cfile>",[179,387,388],{},[35,389,390],{},"git restore --source=\u003Ccommit> \u003Cfile>",[159,392,393,398,402],{},[179,394,395],{},[182,396,397],{},"Restore working dir + staging",[179,399,400],{},[35,401,385],{},[179,403,404],{},[35,405,314],{},[159,407,408,412,416],{},[179,409,410],{},[182,411,184],{},[179,413,414],{},[35,415,79],{},[179,417,234,418],{},[35,419,59],{},[159,421,422,426,430],{},[179,423,424],{},[182,425,199],{},[179,427,428],{},[35,429,209],{},[179,431,234,432],{},[35,433,434],{},"git switch -c",[159,436,437,442,445],{},[179,438,439],{},[182,440,441],{},"Use case",[179,443,444],{},"Branch switch + file restore",[179,446,447],{},"File restore only",[159,449,450,454,456],{},[179,451,452],{},[182,453,262],{},[179,455,268],{},[179,457,265],{},[12,459,460,461,463],{},"Side-by-side like this, you can see ",[35,462,65],{}," is the more confusing one.",[56,465,467],{"id":466},"git-maintenance","git maintenance",[12,469,470,471,38,474,477,478,38,481,484,485,488],{},"As projects grow, you end up using ",[35,472,473],{},"git status",[35,475,476],{},"git log"," a lot, and those start slowing down. The old way to fix this was to manually run ",[35,479,480],{},"git gc",[35,482,483],{},"git repack",", etc. Git 2.30+ added ",[35,486,487],{},"git maintenance start"," which automates these.",[72,490,491,497,502,508,514],{},[75,492,493,496],{},[35,494,495],{},"git maintenance run",": run maintenance now",[75,498,499,501],{},[35,500,487],{},": run maintenance in the background",[75,503,504,507],{},[35,505,506],{},"git maintenance stop",": stop background maintenance",[75,509,510,513],{},[35,511,512],{},"git maintenance register",": register a repo for maintenance",[75,515,516,519],{},[35,517,518],{},"git maintenance unregister",": unregister a repo",[12,521,522,523,525,526,528,529,532,533,536],{},"People sometimes ask about the difference between ",[35,524,487],{}," and ",[35,527,512],{},". In short: ",[35,530,531],{},"register"," adds the current repo as a maintenance target (without running anything). ",[35,534,535],{},"start"," runs maintenance on the registered repos.",[12,538,539],{},"So the standard flow is:",[541,542,543,548],"ol",{},[75,544,545,547],{},[35,546,512],{},": register the repo",[75,549,550,552],{},[35,551,487],{},": start the background maintenance",[12,554,555,556,148],{},"That's it. If you just want to run maintenance once, use ",[35,557,495],{},[56,559,561],{"id":560},"other-commands","Other commands",[12,563,564],{},"These are the ones I'm actually using. There are more, like:",[72,566,567,572,577,582,587,592,597,602],{},[75,568,569],{},[35,570,571],{},"git sparse-checkout",[75,573,574],{},[35,575,576],{},"git log --remerge-diff",[75,578,579],{},[35,580,581],{},"git blame --ignore-rev",[75,583,584],{},[35,585,586],{},"git range-diff",[75,588,589],{},[35,590,591],{},"git worktree",[75,593,594],{},[35,595,596],{},"git rebase --update-refs",[75,598,599],{},[35,600,601],{},"git bugreport",[75,603,604],{},[35,605,606],{},"git for-each-repo",[12,608,609],{},"I haven't actually used these, so I won't go into detail — 80\u002F20 rule.",[20,611,613],{"id":612},"references","References",[72,615,616],{},[75,617,618],{},[50,619,623],{"href":620,"rel":621},"https:\u002F\u002Fappwrite.io\u002Fblog\u002Fpost\u002F10-git-commands-you-should-start-using?ref=dailydev",[622],"nofollow","10 new Git commands you should start using today",{"title":625,"searchDepth":626,"depth":626,"links":627},"",2,[628,629,636],{"id":22,"depth":626,"text":23},{"id":29,"depth":626,"text":30,"children":630},[631,633,634,635],{"id":58,"depth":632,"text":59},3,{"id":284,"depth":632,"text":237},{"id":466,"depth":632,"text":467},{"id":560,"depth":632,"text":561},{"id":612,"depth":626,"text":613},"Git","2024-12-20 23:30:28","A quick writeup on some newer Git commands I've found genuinely useful and worth sharing.","md","en",{},true,"\u002Fen\u002Fgit\u002Fnew-git-commands-you-should-try","3",{"title":6,"description":639},false,"en\u002FGit\u002Fnew-git-commands-you-should-try",[637,650,651],"New Commands","Git Commands",null,"\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F","IAynWEu74-28Di2XgzTG2A92VZKeU7rYRMsGG9DFNGo",{"newer":656,"older":660},{"url":657,"title":658,"date":659},"\u002Fen\u002Flearning\u002F2024\u002F12\u002F21\u002Fwhat-to-do-after-traffic-accident-3-acceptance-help\u002F","What to Do When You Get in a Traffic Accident? — Acceptance and Getting Help (3)","2024-12-21 14:18:53",{"url":661,"title":662,"date":663},"\u002Fen\u002Fdocker\u002F2024\u002F12\u002F19\u002Fdockerize-vite-vue-project\u002F","How to Dockerize a Vite + Vue Project","2024-12-19 16:36:18",[665,670,674],{"url":666,"title":667,"date":668,"readingMinutes":669},"\u002Fen\u002Fgit\u002F2026\u002F02\u002F26\u002Fgit-push-force-with-lease-better-than-force\u002F","A Safer Alternative to git push --force: git push --force-with-lease","2026-02-26 09:39:40","4",{"url":671,"title":672,"date":673,"readingMinutes":645},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F22\u002Fgit-default-branch-master-to-main\u002F","Git init Shows a master Branch Hint? Here's How to Set main as Default","2026-01-22 16:20:40",{"url":675,"title":676,"date":677,"readingMinutes":678},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F21\u002Fgit-worktree-multiple-ai-agents-one-project\u002F","What Is Git Worktree? The Secret to Running Multiple AI Agents in One Project","2026-01-21 16:04:27","5",1784011698347]