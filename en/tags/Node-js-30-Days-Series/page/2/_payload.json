[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Fen\u002Ftags\u002FNode-js-30-Days-Series\u002Fpage\u002F2\u002F":3,"tag-page:en:Node-js-30-Days-Series:2":4,"author-stats:en:full":78},null,{"tag":5,"slug":6,"posts":7,"total":76,"totalPages":77},"Node.js 30 Days Series","Node-js-30-Days-Series",[8,17,24,30,36,43,49,57,63,69],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F05\u002Fday-21-discord-basics\u002F","Day 21 - Discord Basics","2023-10-05 00:00:01","Nodejs",[14,5],"Node.js","In the previous post we got the basic Discord setup ready. Now of course we'll continue with Discord.","4",{"url":18,"title":19,"date":20,"updated":20,"category":12,"tags":21,"description":22,"readingMinutes":23},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F","Day 20 - Discord Bot?","2023-10-04 00:00:01",[14,5],"Beyond scraping, Node.js can do a lot more. Now we'll introduce another application — Bots.","3",{"url":25,"title":26,"date":27,"updated":27,"category":12,"tags":28,"description":29,"readingMinutes":16},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F03\u002Fday-19-crontab-plus-nodejs\u002F","Day 19 - Crontab + Node.js","2023-10-03 00:00:01",[14,5],"In the previous post we got a basic concept of Crontab. Now of course we need to apply it to a real example, otherwise knowing it isn't useful. So this post implements a Crontab + Node.js example.",{"url":31,"title":32,"date":33,"updated":33,"category":12,"tags":34,"description":35,"readingMinutes":23},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F02\u002Fday-18-getting-to-know-crontab\u002F","Day 18 - Getting to Know Crontab","2023-10-02 00:00:01",[14,5],"By now you've learned a fair bit. You may have noticed that some systems seem to do things \"automatically\". So now we'll introduce scheduled task execution (crontab).",{"url":37,"title":38,"date":39,"updated":39,"catego