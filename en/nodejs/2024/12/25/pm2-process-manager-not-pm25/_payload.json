[{"data":1,"prerenderedAt":1252},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F":1230,"related:\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F":1239},"\u002Fnodejs\u002F20241225\u002F794319627\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1213,"date":1214,"description":1215,"extension":1216,"lang":1217,"meta":1218,"navigation":1055,"path":1219,"readingMinutes":1220,"seo":1221,"standalone":1222,"stem":1223,"tags":1224,"tldr":1227,"updated":1214,"url":1228,"__hash__":1229},"content\u002Fen\u002FNodejs\u002Fpm2-process-manager-not-pm25.md","PM2 Is Process Manager, Not PM2.5","7943196321",{"type":9,"value":10,"toc":1197},"minimark",[11,19,24,27,31,34,40,43,66,69,72,76,79,129,132,152,155,167,178,189,192,201,208,212,215,233,236,255,259,262,270,273,289,292,306,309,315,320,325,328,333,339,351,354,359,362,365,381,387,390,513,517,520,549,552,594,597,603,610,629,632,668,671,678,683,715,718,741,748,751,772,775,798,802,808,829,832,846,850,853,873,876,889,893,902,922,925,938,942,945,948,951,963,966,969,1181,1184,1190,1193],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"PM2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002Fpm2-logo-1.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"PM2 stands for Process Manager 2 — a Node.js process management tool. Not the abbreviation for Particulate Matter 2.5. So don't confuse them.",[20,28,30],{"id":29},"what-is-pm2-process-manager-2","What is PM2 (Process Manager 2)?",[12,32,33],{},"The common description goes:",[35,36,37],"blockquote",{},[12,38,39],{},"PM2 is a Node.js process management tool for the JavaScript runtime.",[12,41,42],{},"That sentence is short but loaded. Let's break it down — you'll probably understand PM2 better:",[44,45,46,54,60],"ul",{},[47,48,49,53],"li",{},[50,51,52],"strong",{},"JavaScript runtime",": when JavaScript executes, it creates an environment — what we call the runtime. The runtime executes JavaScript code.",[47,55,56,59],{},[50,57,58],{},"Node.js",": a JavaScript runtime built on Chrome's V8 engine that lets JavaScript run on servers and use system APIs.",[47,61,62,65],{},[50,63,64],{},"Process management tool",": a tool that manages processes. A process is a running program — a process manager lets us control these programs.",[12,67,68],{},"So PM2 is a tool for managing Node.js processes. But why do we need it?",[12,70,71],{},"Simplest scenario: you have a Node.js app you want kept running. The app might crash due to an unexpected bug — and without PM2, that's when you get the on-call page. PM2 helps prevent that.",[20,73,75],{"id":74},"setting-up-the-initial-environment","Setting up the initial environment",[12,77,78],{},"Let's set up a simple environment so PM2's value becomes clearer. Build a quick Node.js app:",[80,81,86],"pre",{"className":82,"code":83,"language":84,"meta":85,"style":85},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir pm2-example\ncd pm2-example\nexpress --no-view\nnpm install\n","bash","",[87,88,89,102,111,120],"code",{"__ignoreMap":85},[90,91,94,98],"span",{"class":92,"line":93},"line",1,[90,95,97],{"class":96},"s_sBn","mkdir",[90,99,101],{"class":100},"sTRMh"," pm2-example\n",[90,103,105,109],{"class":92,"line":104},2,[90,106,108],{"class":107},"sCcAr","cd",[90,110,101],{"class":100},[90,112,114,117],{"class":92,"line":113},3,[90,115,116],{"class":96},"express",[90,118,119],{"class":107}," --no-view\n",[90,121,123,126],{"class":92,"line":122},4,[90,124,125],{"class":96},"npm",[90,127,128],{"class":100}," install\n",[12,130,131],{},"What we did:",[44,133,134,140,143,149],{},[47,135,136,137],{},"Created a folder ",[87,138,139],{},"pm2-example",[47,141,142],{},"cd'd into it",[47,144,145,146,148],{},"Used ",[87,147,116],{}," to scaffold an Express app, no view engine (we just want a simple API)",[47,150,151],{},"Installed Express dependencies",[12,153,154],{},"Build the habit — after creating a project, always run it once to make sure it works:",[80,156,158],{"className":82,"code":157,"language":84,"meta":85,"style":85},"npm start\n",[87,159,160],{"__ignoreMap":85},[90,161,162,164],{"class":92,"line":93},[90,163,125],{"class":96},[90,165,166],{"class":100}," start\n",[12,168,169,170,177],{},"Test the API with ",[171,172,176],"a",{"href":173,"rel":174},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20211207\u002F427026\u002F",[175],"nofollow","Postman",":",[80,179,183],{"className":180,"code":181,"language":182,"meta":85,"style":85},"language-txt shiki shiki-themes github-dark-high-contrast","GET http:\u002F\u002Flocalhost:3000\u002Fusers\n","txt",[87,184,185],{"__ignoreMap":85},[90,186,187],{"class":92,"line":93},[90,188,181],{},[12,190,191],{},"You should get:",[80,193,195],{"className":180,"code":194,"language":182,"meta":85,"style":85},"respond with a resource\n",[87,196,197],{"__ignoreMap":85},[90,198,199],{"class":92,"line":93},[90,200,194],{},[12,202,203,204,207],{},"Your project is working. Now we'll tweak it so PM2 can manage it instead of you running ",[87,205,206],{},"npm start"," manually.",[20,209,211],{"id":210},"installing-pm2","Installing PM2",[12,213,214],{},"Open the terminal:",[80,216,218],{"className":82,"code":217,"language":84,"meta":85,"style":85},"npm install pm2 -g\n",[87,219,220],{"__ignoreMap":85},[90,221,222,224,227,230],{"class":92,"line":93},[90,223,125],{"class":96},[90,225,226],{"class":100}," install",[90,228,229],{"class":100}," pm2",[90,231,232],{"class":107}," -g\n",[12,234,235],{},"Done. Very simple. With yarn:",[80,237,239],{"className":82,"code":238,"language":84,"meta":85,"style":85},"yarn global add pm2\n",[87,240,241],{"__ignoreMap":85},[90,242,243,246,249,252],{"class":92,"line":93},[90,244,245],{"class":96},"yarn",[90,247,248],{"class":100}," global",[90,250,251],{"class":100}," add",[90,253,254],{"class":100}," pm2\n",[20,256,258],{"id":257},"pm2-basics","PM2 basics",[12,260,261],{},"Usage is simple. The main command to remember:",[44,263,264],{},[47,265,266,269],{},[87,267,268],{},"pm2 start \u003Cfilename>",": start an application",[12,271,272],{},"That's it. To start a project directly:",[80,274,276],{"className":82,"code":275,"language":84,"meta":85,"style":85},"pm2 start app.js\n",[87,277,278],{"__ignoreMap":85},[90,279,280,283,286],{"class":92,"line":93},[90,281,282],{"class":96},"pm2",[90,284,285],{"class":100}," start",[90,287,288],{"class":100}," app.js\n",[12,290,291],{},"But our project was scaffolded by Express, so:",[80,293,295],{"className":82,"code":294,"language":84,"meta":85,"style":85},"pm2 start bin\u002Fwww\n",[87,296,297],{"__ignoreMap":85},[90,298,299,301,303],{"class":92,"line":93},[90,300,282],{"class":96},[90,302,285],{"class":100},[90,304,305],{"class":100}," bin\u002Fwww\n",[12,307,308],{},"You'll see:",[12,310,311],{},[15,312],{"alt":313,"src":314},"Start","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.31.39.png",[12,316,317,318,177],{},"The terminal looks totally different. Before, with ",[87,319,206],{},[12,321,322],{},[15,323],{"alt":206,"src":324},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.37.07.png",[12,326,327],{},"With PM2, requests and console output don't appear in the terminal — PM2 moves the running process to the background, so we don't have to worry about the project stopping when we close the terminal.",[329,330,332],"h3",{"id":331},"view-pm2-status-and-list","View PM2 status and list",[12,334,335,336,177],{},"So how do we check PM2's status? ",[87,337,338],{},"pm2 list",[80,340,342],{"className":82,"code":341,"language":84,"meta":85,"style":85},"pm2 list\n",[87,343,344],{"__ignoreMap":85},[90,345,346,348],{"class":92,"line":93},[90,347,282],{"class":96},[90,349,350],{"class":100}," list\n",[12,352,353],{},"You'll see the projects running under PM2:",[12,355,356],{},[15,357],{"alt":17,"src":358},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.46.29.png",[12,360,361],{},"It's like a dashboard for PM2 projects with basic info.",[12,363,364],{},"There are multiple equivalent commands:",[44,366,367,372,377],{},[47,368,369],{},[87,370,371],{},"pm2 status",[47,373,374],{},[87,375,376],{},"pm2 ls",[47,378,379],{},[87,380,338],{},[12,382,383,384,386],{},"They all show PM2 projects. I personally use ",[87,385,338],{},".",[12,388,389],{},"What each column means:",[44,391,392,398,412,422,431,445,451,457,482,488,494,500],{},[47,393,394,397],{},[87,395,396],{},"id",": auto-generated project ID from PM2",[47,399,400,403,404,407,408,411],{},[87,401,402],{},"name",": project name, usually the filename — defaults to whatever comes after the command (",[87,405,406],{},"bin\u002Fwww"," → ",[87,409,410],{},"www",")",[47,413,414,417,418,421],{},[87,415,416],{},"namespace",": project namespace, defaults to ",[87,419,420],{},"default"," — think of it as a group",[47,423,424,427,428],{},[87,425,426],{},"version",": project version, taken from ",[87,429,430],{},"package.json",[47,432,433,436,437,440,441,444],{},[87,434,435],{},"mode",": project mode, usually ",[87,438,439],{},"fork"," (single process) or ",[87,442,443],{},"cluster"," (multi-process)",[47,446,447,450],{},[87,448,449],{},"pid",": process ID",[47,452,453,456],{},[87,454,455],{},"uptime",": how long it's been running",[47,458,459,462,463,466,467,469,470,469,473,469,476,469,479],{},[87,460,461],{},"status",": usually ",[87,464,465],{},"online",". Possible values: ",[87,468,465],{},", ",[87,471,472],{},"stopped",[87,474,475],{},"errored",[87,477,478],{},"launching",[87,480,481],{},"unknown",[47,483,484,487],{},[87,485,486],{},"cpu",": CPU usage",[47,489,490,493],{},[87,491,492],{},"mem",": memory usage",[47,495,496,499],{},[87,497,498],{},"user",": user running it",[47,501,502,505,506,469,509,512],{},[87,503,504],{},"watching",": whether file watching is on (usually ",[87,507,508],{},"false",[87,510,511],{},"true"," when enabled)",[329,514,516],{"id":515},"view-pm2-logs","View PM2 logs",[12,518,519],{},"To view logs:",[80,521,523],{"className":82,"code":522,"language":84,"meta":85,"style":85},"pm2 logs \u003Cproject name\u002FID\u002Fnamespace>\n",[87,524,525],{"__ignoreMap":85},[90,526,527,529,532,536,539,542,546],{"class":92,"line":93},[90,528,282],{"class":96},[90,530,531],{"class":100}," logs",[90,533,535],{"class":534},"sWyjQ"," \u003C",[90,537,538],{"class":100},"project",[90,540,541],{"class":100}," name\u002FID\u002Fnamespac",[90,543,545],{"class":544},"sMAXC","e",[90,547,548],{"class":534},">\n",[12,550,551],{},"For our example:",[80,553,555],{"className":82,"code":554,"language":84,"meta":85,"style":85},"pm2 logs 0 # 0 is the project ID\npm2 logs www # www is the project name\npm2 logs default # default is the namespace\n",[87,556,557,570,582],{"__ignoreMap":85},[90,558,559,561,563,566],{"class":92,"line":93},[90,560,282],{"class":96},[90,562,531],{"class":100},[90,564,565],{"class":107}," 0",[90,567,569],{"class":568},"sQrFR"," # 0 is the project ID\n",[90,571,572,574,576,579],{"class":92,"line":104},[90,573,282],{"class":96},[90,575,531],{"class":100},[90,577,578],{"class":100}," www",[90,580,581],{"class":568}," # www is the project name\n",[90,583,584,586,588,591],{"class":92,"line":113},[90,585,282],{"class":96},[90,587,531],{"class":100},[90,589,590],{"class":100}," default",[90,592,593],{"class":568}," # default is the namespace\n",[12,595,596],{},"You'll keep seeing the project's logs:",[12,598,599],{},[15,600],{"alt":601,"src":602},"Logs","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.54.51.png",[12,604,605,606,609],{},"Detailed ",[87,607,608],{},"pm2 logs"," options:",[44,611,612,617,623],{},[47,613,614,616],{},[87,615,608],{},": all project logs",[47,618,619,622],{},[87,620,621],{},"pm2 logs \u003Cname\u002FID>",": specific project's logs",[47,624,625,628],{},[87,626,627],{},"pm2 logs \u003Cnamespace>",": like a group view — you can categorize projects and see all logs in that group",[12,630,631],{},"With additional flags you can be more precise:",[44,633,634,640,646,652,662],{},[47,635,636,639],{},[87,637,638],{},"pm2 logs --out",": only stdout (normal output)",[47,641,642,645],{},[87,643,644],{},"pm2 logs --err",": only error output",[47,647,648,651],{},[87,649,650],{},"pm2 logs --json > logs.json",": output as JSON so you can process it programmatically",[47,653,654,657,658,661],{},[87,655,656],{},"pm2 logs \u003Cname\u002FID> | grep \"keyword\"",": filter logs by keyword — e.g. ",[87,659,660],{},"pm2 logs www | grep \"GET\""," shows only GET logs",[47,663,664,667],{},[87,665,666],{},"pm2 logs \u003Cname\u002FID> --lines 100",": show only the last 100 lines",[12,669,670],{},"That covers the common usage.",[329,672,674,675],{"id":673},"passing-flags-to-pm2-start","Passing flags to ",[87,676,677],{},"pm2 start",[12,679,680,682],{},[87,681,677],{}," isn't just a simple command — you can pass flags for more options:",[44,684,685,691,697,703,709],{},[47,686,687,690],{},[87,688,689],{},"--name",": set project name",[47,692,693,696],{},[87,694,695],{},"--watch",": watch for file changes, auto-restart on change",[47,698,699,702],{},[87,700,701],{},"--cron-restart",": restart on a cron schedule",[47,704,705,708],{},[87,706,707],{},"--max-memory-restart",": restart when memory usage exceeds a threshold",[47,710,711,714],{},[87,712,713],{},"--namespace",": set namespace",[12,716,717],{},"Common usage:",[80,719,721],{"className":82,"code":720,"language":84,"meta":85,"style":85},"pm2 start bin\u002Fwww --name \"hexschool-example\" --watch\n",[87,722,723],{"__ignoreMap":85},[90,724,725,727,729,732,735,738],{"class":92,"line":93},[90,726,282],{"class":96},[90,728,285],{"class":100},[90,730,731],{"class":100}," bin\u002Fwww",[90,733,734],{"class":107}," --name",[90,736,737],{"class":100}," \"hexschool-example\"",[90,739,740],{"class":107}," --watch\n",[12,742,743,744,747],{},"Sets the project name to ",[87,745,746],{},"hexschool-example",", watches for file changes, and auto-restarts on change.",[12,749,750],{},"To set the namespace:",[80,752,754],{"className":82,"code":753,"language":84,"meta":85,"style":85},"pm2 start bin\u002Fwww --namespace \"hexschool\" --watch\n",[87,755,756],{"__ignoreMap":85},[90,757,758,760,762,764,767,770],{"class":92,"line":93},[90,759,282],{"class":96},[90,761,285],{"class":100},[90,763,731],{"class":100},[90,765,766],{"class":107}," --namespace",[90,768,769],{"class":100}," \"hexschool\"",[90,771,740],{"class":107},[12,773,774],{},"To set both name and namespace:",[80,776,778],{"className":82,"code":777,"language":84,"meta":85,"style":85},"pm2 start bin\u002Fwww --name \"hexschool-example\" --namespace \"hexschool\" --watch\n",[87,779,780],{"__ignoreMap":85},[90,781,782,784,786,788,790,792,794,796],{"class":92,"line":93},[90,783,282],{"class":96},[90,785,285],{"class":100},[90,787,731],{"class":100},[90,789,734],{"class":107},[90,791,737],{"class":100},[90,793,766],{"class":107},[90,795,769],{"class":100},[90,797,740],{"class":107},[329,799,801],{"id":800},"restart-a-project","Restart a project",[12,803,804,805,177],{},"When something goes wrong, restart with ",[87,806,807],{},"pm2 restart",[80,809,811],{"className":82,"code":810,"language":84,"meta":85,"style":85},"pm2 restart \u003Cname\u002FID\u002Fnamespace>\n",[87,812,813],{"__ignoreMap":85},[90,814,815,817,820,822,825,827],{"class":92,"line":93},[90,816,282],{"class":96},[90,818,819],{"class":100}," restart",[90,821,535],{"class":534},[90,823,824],{"class":100},"name\u002FID\u002Fnamespac",[90,826,545],{"class":544},[90,828,548],{"class":534},[12,830,831],{},"To restart everything:",[80,833,835],{"className":82,"code":834,"language":84,"meta":85,"style":85},"pm2 restart all\n",[87,836,837],{"__ignoreMap":85},[90,838,839,841,843],{"class":92,"line":93},[90,840,282],{"class":96},[90,842,819],{"class":100},[90,844,845],{"class":100}," all\n",[329,847,849],{"id":848},"stop-a-project","Stop a project",[12,851,852],{},"To stop:",[80,854,856],{"className":82,"code":855,"language":84,"meta":85,"style":85},"pm2 stop \u003Cname\u002FID\u002Fnamespace>\n",[87,857,858],{"__ignoreMap":85},[90,859,860,862,865,867,869,871],{"class":92,"line":93},[90,861,282],{"class":96},[90,863,864],{"class":100}," stop",[90,866,535],{"class":534},[90,868,824],{"class":100},[90,870,545],{"class":544},[90,872,548],{"class":534},[12,874,875],{},"To stop everything:",[80,877,879],{"className":82,"code":878,"language":84,"meta":85,"style":85},"pm2 stop all\n",[87,880,881],{"__ignoreMap":85},[90,882,883,885,887],{"class":92,"line":93},[90,884,282],{"class":96},[90,886,864],{"class":100},[90,888,845],{"class":100},[329,890,892],{"id":891},"delete-a-project","Delete a project",[12,894,895,898,899,177],{},[87,896,897],{},"pm2 stop"," only stops a project — it doesn't delete it. To delete, use ",[87,900,901],{},"pm2 delete",[80,903,905],{"className":82,"code":904,"language":84,"meta":85,"style":85},"pm2 delete \u003Cname\u002FID\u002Fnamespace>\n",[87,906,907],{"__ignoreMap":85},[90,908,909,911,914,916,918,920],{"class":92,"line":93},[90,910,282],{"class":96},[90,912,913],{"class":100}," delete",[90,915,535],{"class":534},[90,917,824],{"class":100},[90,919,545],{"class":544},[90,921,548],{"class":534},[12,923,924],{},"Delete all:",[80,926,928],{"className":82,"code":927,"language":84,"meta":85,"style":85},"pm2 delete all\n",[87,929,930],{"__ignoreMap":85},[90,931,932,934,936],{"class":92,"line":93},[90,933,282],{"class":96},[90,935,913],{"class":100},[90,937,845],{"class":100},[20,939,941],{"id":940},"pm2-advanced-config-ecosystem-file","PM2 advanced config (Ecosystem File)",[12,943,944],{},"PM2 has an advanced config file called Ecosystem File. It supports JavaScript, JSON, and YAML.",[12,946,947],{},"In practice, ecosystem.config.js (JavaScript) is the most common.",[12,949,950],{},"To generate one, PM2 auto-creates it for you:",[80,952,954],{"className":82,"code":953,"language":84,"meta":85,"style":85},"pm2 ecosystem\n",[87,955,956],{"__ignoreMap":85},[90,957,958,960],{"class":92,"line":93},[90,959,282],{"class":96},[90,961,962],{"class":100}," ecosystem\n",[12,964,965],{},"It generates an Ecosystem File based on your current project environment.",[12,967,968],{},"The format looks like:",[80,970,974],{"className":971,"code":972,"language":973,"meta":85,"style":85},"language-javascript shiki shiki-themes github-dark-high-contrast","module.exports = {\n  apps : [{\n    script: 'index.js',\n    watch: '.'\n  }, {\n    script: '.\u002Fservice-worker\u002F',\n    watch: ['.\u002Fservice-worker']\n  }],\n\n  deploy : {\n    production : {\n      user : 'SSH_USERNAME',\n      host : 'SSH_HOSTMACHINE',\n      ref  : 'origin\u002Fmaster',\n      repo : 'GIT_REPOSITORY',\n      path : 'DESTINATION_PATH',\n      'pre-deploy-local': '',\n      'post-deploy' : 'npm install && pm2 reload ecosystem.config.js --env production',\n      'pre-setup': ''\n    }\n  }\n};\n","javascript",[87,975,976,992,997,1008,1016,1022,1032,1044,1050,1057,1063,1069,1080,1091,1102,1113,1124,1138,1152,1163,1169,1175],{"__ignoreMap":85},[90,977,978,981,983,986,989],{"class":92,"line":93},[90,979,980],{"class":107},"module",[90,982,386],{"class":544},[90,984,985],{"class":107},"exports",[90,987,988],{"class":534}," =",[90,990,991],{"class":544}," {\n",[90,993,994],{"class":92,"line":104},[90,995,996],{"class":544},"  apps : [{\n",[90,998,999,1002,1005],{"class":92,"line":113},[90