opy it to my own GitHub account.",[17,36,37],{},[38,39],"img",{"alt":40,"src":41},"fork","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fgithub-fork.jpg",[17,43,44],{},"Click \"Create Fork\".",[17,46,47],{},[38,48],{"alt":49,"src":50},"fork setting","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffork_setting.png",[52,53,54],"blockquote",{},[17,55,56,60],{},[57,58,59],"strong",{},"Note","\nIf you see \"The repository freyja already exists on this account.\", you've already forked — no need to fork again.",[17,62,63],{},"You'll now have a new repo under your account:",[17,65,66],{},[38,67],{"alt":68,"src":69},"Fork Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffork_setting2.jpg",[17,71,72],{},"(The red box will usually show your GitHub account name.)",[17,74,75],{},"In your forked repo, click \"Code\" and copy the project URL.",[17,77,78],{},[38,79],{"alt":80,"src":81},"Copy Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fcopy_url.jpg",[17,83,84],{},"Open your terminal:",[86,87,92],"pre",{"className":88,"code":89,"language":90,"meta":91,"style":91},"language-bash shiki shiki-themes github-dark-high-contrast","git clone [URL you just copied]\n","bash","",[93,94,95],"code",{"__ignoreMap":91},[96,97,100,104,108,112,115,118],"span",{"class":98,"line":99},"line",1,[96,101,103],{"class":102},"s_sBn","git",[96,105,107],{"class":106},"sTRMh"," clone",[96,109,111],{"class":110},"sMAXC"," [URL ",[96,113,114],{"class":106},"you",[96,116,117],{"class":106}," just",[96,119,120],{"class":106}," copied]\n",[17,122,123],{},"That clones the project locally.",[12,125,127],{"id":126},"init-environment","Init environment",[17,129,130],{},"cd into the project and install packages:",[86,132,134],{"className":88,"code":133,"language":90,"meta":91,"style":91},"cd freyja\nnpm install\n",[93,135,136,145],{"__ignoreMap":91},[96,137,138,142],{"class":98,"line":99},[96,139,141],{"class":140},"sCcAr","cd",[96,143,144],{"class":106}," freyja\n",[96,146,148,151],{"class":98,"line":147},2,[96,149,150],{"class":102},"npm",[96,152,153],{"class":106}," install\n",[52,155,156],{},[17,157,158,160],{},[57,159,59],{},"\nThis project requires Node.js 18.16.0 or above.",[17,162,163,164,167,168,171],{},"After restoring packages, set up environment variables. Copy ",[93,165,166],{},".env.example"," to ",[93,169,170],{},".env",":",[86,173,175],{"className":88,"code":174,"language":90,"meta":91,"style":91},"cp .env.example .env\n",[93,176,177],{"__ignoreMap":91},[96,178,179,182,185],{"class":98,"line":99},[96,180,181],{"class":102},"cp",[96,183,184],{"class":106}," .env.example",[96,186,187],{"class":106}," .env\n",[17,189,190],{},[38,191],{"alt":192,"src":193},"cp env","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fenv_cp.jpg",[17,195,196,197,171],{},"Open ",[93,198,170],{},[86,200,202],{"className":88,"code":201,"language":90,"meta":91,"style":91},"# Environment variable, dev or production (development, production)\nNODE_ENV = \"development\"\n\n# Server port\nPORT = 3005\n\n# MongoDB connection\nDATABASE =\n# MongoDB password\nDATABASE_PASSWORD =\n\n# JWT Token expiration\nJWT_EXPIRES_DAY = \"7d\"\n# JWT Token secret\nJWT_SECRET = \"hexschool\"\n\n# Gmail account\nEMAILER_USER =\n# Gmail app password\nEMAILER_PASSWORD =\n",[93,203,204,210,221,228,234,245,250,256,265,271,279,284,290,301,307,318,323,329,337,343],{"__ignoreMap":91},[96,205,206],{"class":98,"line":99},[96,207,209],{"class":208},"sQrFR","# Environment variable, dev or production (development, production)\n",[96,211,212,215,218],{"class":98,"line":147},[96,213,214],{"class":102},"NODE_ENV",[96,216,217],{"class":106}," =",[96,219,220],{"class":106}," \"development\"\n",[96,222,224],{"class":98,"line":223},3,[96,225,227],{"emptyLinePlaceholder":226},true,"\n",[96,229,231],{"class":98,"line":230},4,[96,232,233],{"class":208},"# Server port\n",[96,235,237,240,242],{"class":98,"line":236},5,[96,238,239],{"class":102},"PORT",[96,241,217],{"class":106},[96,243,244],{"class":140}," 3005\n",[96,246,248],{"class":98,"line":247},6,[96,249,227],{"emptyLinePlaceholder":226},[96,251,253],{"class":98,"line":252},7,[96,254,255],{"class":208},"# MongoDB connection\n",[96,257,259,262],{"class":98,"line":258},8,[96,260,261],{"class":102},"DATABASE",[96,263,264],{"class":106}," =\n",[96,266,268],{"class":98,"line":267},9,[96,269,270],{"class":208},"# MongoDB password\n",[96,272,274,277],{"class":98,"line":273},10,[96,275,276],{"class":102},"DATABASE_PASSWORD",[96,278,264],{"class":106},[96,280,282],{"class":98,"line":281},11,[96,283,227],{"emptyLinePlaceholder":226},[96,285,287],{"class":98,"line":286},12,[96,288,289],{"class":208},"# JWT Token expiration\n",[96,291,293,296,298],{"class":98,"line":292},13,[96,294,295],{"class":102},"JWT_EXPIRES_DAY",[96,297,217],{"class":106},[96,299,300],{"class":106}," \"7d\"\n",[96,302,304],{"class":98,"line":303},14,[96,305,306],{"class":208},"# JWT Token secret\n",[96,308,310,313,315],{"class":98,"line":309},15,[96,311,312],{"class":102},"JWT_SECRET",[96,314,217],{"class":106},[96,316,317],{"class":106}," \"hexschool\"\n",[96,319,321],{"class":98,"line":320},16,[96,322,227],{"emptyLinePlaceholder":226},[96,324,326],{"class":98,"line":325},17,[96,327,328],{"class":208},"# Gmail account\n",[96,330,332,335],{"class":98,"line":331},18,[96,333,334],{"class":102},"EMAILER_USER",[96,336,264],{"class":106},[96,338,340],{"class":98,"line":339},19,[96,341,342],{"class":208},"# Gmail app password\n",[96,344,346,349],{"class":98,"line":345},20,[96,347,348],{"class":102},"EMAILER_PASSWORD",[96,350,264],{"class":106},[17,352,353],{},"You need to prepare:",[355,356,357,361],"ul",{},[358,359,360],"li",{},"MongoDB connection and password",[358,362,363],{},"Gmail account and app password",[17,365,366],{},"Let's set them up.",[368,369,360],"h3",{"id":370},"mongodb-connection-and-password",[17,372,373,374,378],{},"We'll use MongoDB Atlas as our database (I'll skip signup). Click ",[28,375,33],{"href":376,"rel":377},"https:\u002F\u002Fwww.mongodb.com\u002F",[32]," and click \"Sign in\":",[17,380,381],{},[38,382],{"alt":383,"src":384},"Sign in","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FMongoDB_sigin.jpg",[17,386,387],{},"Choose your sign-in method.",[17,389,390],{},[38,391],{"alt":383,"src":392},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fmongodb_sigin_account.png",[17,394,395],{},"I went with GitHub.",[17,397,398],{},"If it's a brand-new account, you'll be asked to create an organization.",[17,400,401],{},[38,402],{"alt":403,"src":404},"Organizations","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fmogodb_Organizations.png",[17,406,407],{},"Click \"Create Organization\", enter a name, choose \"MongoDB Atlas\", and save.",[17,409,410],{},[38,411],{"alt":412,"src":413},"Create Organization","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FCreate_Organization.jpg",[17,415,416],{},"Next page is \"Members and Security\". You can invite others, or just click \"Create Organization\" (defaults are fine).",[17,418,419],{},[38,420],{"alt":421,"src":422},"Members and Security","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FCreate_Organization2.jpg",[17,424,425],{},"Now create a project. MongoDB Atlas is organization-scoped, hence needing the org first. Click \"New Project\".",[17,427,428],{},[38,429],{"alt":430,"src":431},"New Project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FProjects.jpg",[17,433,434],{},"Name it whatever — I called mine \"freyja-project\".",[17,436,437],{},[38,438],{"alt":439,"src":440},"freyja-project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffreyja-project.png",[17,442,443],{},"Next step asks about inviting people — click \"Create Project\". On the project home page, click \"Create\" to deploy a database.",[17,445,446],{},[38,447],{"alt":448,"src":449},"Create Db","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fcreate_db.jpg",[17,451,452],{},"On the \"Deploy your database\" page, choose \"M0 Free\" and click \"Create\".",[17,454,455],{},[38,456],{"alt":457,"src":458},"Deploy your database","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FDeploy_your_database.jpg",[52,460,461],{},[17,462,463,465],{},[57,464,59],{},"\nProvider and Region are which cloud and which region to host in — defaults are fine.",[17,467,468],{},"You'll go through MongoDB quick start. Note your username and password — you need these to connect to the database. Click \"Create User\".",[17,470,471],{},[38,472],{"alt":473,"src":474},"Security Quickstart","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FSecurity_Quickstart.jpg",[17,476,477,478,481],{},"Scroll down for IP whitelist setup. Since this is practice, enter ",[93,479,480],{},"0.0.0.0\u002F0"," and click \"Add Entry\", then \"Finish And Close\".",[17,483,484],{},[38,485],{"alt":486,"src":487},"Network Access","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FNetwork%20Access.png",[52,489,490],{},[17,491,492,494,495,497],{},[57,493,59],{},"\nIn production, you'd set a fixed IP. For practice we use ",[93,496,480],{}," which allows any IP.",[17,499,500],{},"Click the \"Connect\" button.",[17,502,503],{},[38,504],{"alt":505,"src":506},"Connect Db","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FConnent_Db.jpg",[17,508,509],{},"A popup appears. Choose \"Connect your application\" → \"Driver\" → \"Node.js\", copy the connection string.",[17,511,512],{},[38,513],{"alt":514,"src":515},"Connect Db2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FConnect%20Db2.jpg",[17,517,518,519,521,522,524,525,527,528,531],{},"That's our MongoDB connection string. Copy it, go back to ",[93,520,170],{},", update ",[93,523,261],{}," and ",[93,526,276],{},", and replace ",[93,529,530],{},"\u003Cpassword>"," with your password:",[86,533,537],{"className":534,"code":535,"language":536,"meta":91,"style":91},"language-env shiki shiki-themes github-dark-high-contrast","# MongoDB connection\nDATABASE = \"mongodb+srv:\u002F\u002Ftypescript-30-ray:\u003Cpassword>@cluster0.937ixka.mongodb.net\u002F?retryWrites=true&w=majority\"\n# MongoDB password\nDATABASE_PASSWORD = jqZsdqdwqwd31 # don't worry, this is fake\n","env",[93,538,539,543,548,552],{"__ignoreMap":91},[96,540,541],{"class":98,"line":99},[96,542,255],{},[96,544,545],{"class":98,"line":147},[96,546,547],{},"DATABASE = \"mongodb+srv:\u002F\u002Ftypescript-30-ray:\u003Cpassword>@cluster0.937ixka.mongodb.net\u002F?retryWrites=true&w=majority\"\n",[96,549,550],{"class":98,"line":223},[96,551,270],{},[96,553,554],{"class":98,"line":230},[96,555,556],{},"DATABASE_PASSWORD = jqZsdqdwqwd31 # don't worry, this is fake\n",[17,558,559],{},"MongoDB setup done.",[368,561,363],{"id":562},"gmail-account-and-app-password",[17,564,565,566,571],{},"Now get the Gmail account and app password. Go to Google Account settings → \"",[28,567,570],{"href":568,"rel":569},"https:\u002F\u002Fmyaccount.google.com\u002Fu\u002F1\u002Fsecurity",[32],"Security","\".",[17,573,574],{},[38,575],{"alt":576,"src":577},"Google Account","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnodemailer-google-email\u002F2023-07-22%2012.19.15.png",[17,579,580,581,584],{},"Make sure ",[57,582,583],{},"2-Step Verification"," is on first, otherwise Google won't let you continue.",[17,586,587],{},[38,588],{"alt":589,"src":590},"Two Security","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FTwo%20Security.jpg",[17,592,593],{},"Once that's confirmed, search \"App passwords\" in the top bar and click it.",[17,595,596],{},[38,597],{"alt":598,"src":599},"Application Password","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password.png",[52,601,602],{},[17,603,604,606],{},[57,605,59],{},"\nEarlier you could find \"App passwords\" directly on the page, but now you have to search.",[17,608,609],{},"On the \"App passwords\" page, enter \"freyja\" for App Name and click \"Create\".",[17,611,612],{},[38,613],{"alt":598,"src":614},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password2.jpg",[17,616,617],{},"A 16-character password (four groups of four) pops up, like:",[86,619,624],{"className":620,"code":622,"language":623,"meta":91},[621],"language-text","abba dqwd asbc d3hr # fake password\n","text",[93,625,622],{"__ignoreMap":91},[17,627,628],{},[38,629],{"alt":630,"src":631},"Application Password3","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password3.jpg",[17,633,634,635,521,637,524,639,171],{},"Back in ",[93,636,170],{},[93,638,334],{},[93,640,348],{},[86,642,644],{"className":534,"code":643,"language":536,"meta":91,"style":91},"# Gmail account\nEMAILER_USER = \"example@gmail.com\" # the Gmail account you used for the app password\n# Gmail app password\nEMAILER_PASSWORD = \"abba dqwd asbc d3hr\" # the app password you got\n",[93,645,646,650,655,659],{"__ignoreMap":91},[96,647,648],{"class":98,"line":99},[96,649,328],{},[96,651,652],{"class":98,"line":147},[96,653,654],{},"EMAILER_USER = \"example@gmail.com\" # the Gmail account you used for the app password\n",[96,656,657],{"class":98,"line":223},[96,658,342],{},[96,660,661],{"class":98,"line":230},[96,662,663],{},"EMAILER_PASSWORD = \"abba dqwd asbc d3hr\" # the app password you got\n",[17,665,666],{},"All environment variables are now set. Time to run the project:",[86,668,670],{"className":88,"code":669,"language":90,"meta":91,"style":91},"npm run dev\n",[93,671,672],{"__ignoreMap":91},[96,673,674,676,679],{"class":98,"line":99},[96,675,150],{"class":102},[96,677,678],{"class":106}," run",[96,680,681],{"class":106}," dev\n",[17,683,684],{},"You should see:",[17,686,687],{},[38,688],{"alt":689,"src":690},"npm run dev","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fstart.png",[17,692,693],{},"Backend done.",[12,695,697],{"id":696},"deploy-to-rendercom","Deploy to Render.com",[17,699,700,701,706],{},"Open \"",[28,702,705],{"href":703,"rel":704},"https:\u002F\u002Frender.com\u002F",[32],"Render.com","\", click \"Sign up\", and log in.",[52,708,709],{},[17,710,711,713],{},[57,712,59],{},"\nIf you haven't signed up, do that first (I recommend GitHub login).",[17,715,716],{},"Click \"New\" at the top, then \"New Web Service\".",[17,718,719],{},[38,720],{"alt":721,"src":722},"Web Service","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FRender_Dashboard.jpg",[17,724,725],{},"On \"Create a new Web Service\", select \"Build and deploy from a Git repository\" and click Next.",[17,727,728],{},[38,729],{"alt":730,"src":731},"Build and deploy from a Git repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy_setp1.jpg",[17,733,734],{},"In the \"Connect a repository\" field, search for the name we forked — \"freyja\". Select it and click Connect.",[17,736,737],{},[38,738],{"alt":739,"src":740},"Connect a Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fconnect_repository.jpg",[52,742,743],{},[17,744,745,747],{},[57,746,59],{},"\nIf you can't find it, your Render.com account isn't linked to the same GitHub account as your fork, or GitHub doesn't have proper Render.com permissions.",[17,749,750],{},"Fill in:",[355,752,753,756,759],{},[358,754,755],{},"Name: \"freyja\"",[358,757,758],{},"Instance Type: \"Free\"",[358,760,761,762],{},"Environment Variables: match the contents of ",[93,763,170],{},[17,765,766],{},"It'll look like:",[17,768,769],{},[38,770],{"alt":771,"src":772},"Environment Variables","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FEnvironment%20Variables.jpg",[52,774,775],{},[17,776,777,779],{},[57,778,59],{},"\nYou don't need to set PORT or NODE_ENV — Dockerfile handles those. When filling in Environment Variables, don't add quotes.",[17,781,782],{},"Click \"Create Web Service\" and Render.com starts deploying.",[17,784,785],{},"When you see this, deployment succeeded:",[17,787,788],{},[38,789],{"alt":790,"src":791},"Deploy succeeded","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy.jpg",[17,793,794],{},"Scroll up to find your Render.com URL and click it to view your project.",[17,796,797],{},[38,798],{"alt":790,"src":799},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy_2.jpg",[52,801,802],{},[17,803,804,806,807,810],{},[57,805,59],{},"\nHitting the URL directly returns a JSON object. Append ",[93,808,809],{},"swagger"," to the URL to get the API docs.",[17,812,813],{},"That's the full deployment guide.",[815,816,817],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-defa