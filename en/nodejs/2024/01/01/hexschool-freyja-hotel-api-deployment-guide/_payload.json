opy it to my own GitHub account.",[17,36,37],{},[38,39],"img",{"alt":40,"src":41},"fork","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fgithub-fork.jpg",[17,43,44],{},"Click \"Create Fork\".",[17,46,47],{},[38,48],{"alt":49,"src":50},"fork setting","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffork_setting.png",[52,53,56],"callout",{"title":54,"type":55},"Note","note",[17,57,58],{},"If you see \"The repository freyja already exists on this account.\", you've already forked — no need to fork again.",[17,60,61],{},"You'll now have a new repo under your account:",[17,63,64],{},[38,65],{"alt":66,"src":67},"Fork Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffork_setting2.jpg",[17,69,70],{},"(The red box will usually show your GitHub account name.)",[17,72,73],{},"In your forked repo, click \"Code\" and copy the project URL.",[17,75,76],{},[38,77],{"alt":78,"src":79},"Copy Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fcopy_url.jpg",[17,81,82],{},"Open your terminal:",[84,85,90],"pre",{"className":86,"code":87,"language":88,"meta":89,"style":89},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","git clone [URL you just copied]\n","bash","",[91,92,93],"code",{"__ignoreMap":89},[94,95,98,102,106,110,113,116],"span",{"class":96,"line":97},"line",1,[94,99,101],{"class":100},"smYoP","git",[94,103,105],{"class":104},"sWayO"," clone",[94,107,109],{"class":108},"s8XSl"," [URL ",[94,111,112],{"class":104},"you",[94,114,115],{"class":104}," just",[94,117,118],{"class":104}," copied]\n",[17,120,121],{},"That clones the project locally.",[12,123,125],{"id":124},"init-environment","Init environment",[17,127,128],{},"cd into the project and install packages:",[84,130,132],{"className":86,"code":131,"language":88,"meta":89,"style":89},"cd freyja\nnpm install\n",[91,133,134,143],{"__ignoreMap":89},[94,135,136,140],{"class":96,"line":97},[94,137,139],{"class":138},"stw71","cd",[94,141,142],{"class":104}," freyja\n",[94,144,146,149],{"class":96,"line":145},2,[94,147,148],{"class":100},"npm",[94,150,151],{"class":104}," install\n",[52,153,154],{"title":54,"type":55},[17,155,156],{},"This project requires Node.js 18.16.0 or above.",[17,158,159,160,163,164,167],{},"After restoring packages, set up environment variables. Copy ",[91,161,162],{},".env.example"," to ",[91,165,166],{},".env",":",[84,169,171],{"className":86,"code":170,"language":88,"meta":89,"style":89},"cp .env.example .env\n",[91,172,173],{"__ignoreMap":89},[94,174,175,178,181],{"class":96,"line":97},[94,176,177],{"class":100},"cp",[94,179,180],{"class":104}," .env.example",[94,182,183],{"class":104}," .env\n",[17,185,186],{},[38,187],{"alt":188,"src":189},"cp env","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fenv_cp.jpg",[17,191,192,193,167],{},"Open ",[91,194,166],{},[84,196,198],{"className":86,"code":197,"language":88,"meta":89,"style":89},"# Environment variable, dev or production (development, production)\nNODE_ENV = \"development\"\n\n# Server port\nPORT = 3005\n\n# MongoDB connection\nDATABASE =\n# MongoDB password\nDATABASE_PASSWORD =\n\n# JWT Token expiration\nJWT_EXPIRES_DAY = \"7d\"\n# JWT Token secret\nJWT_SECRET = \"hexschool\"\n\n# Gmail account\nEMAILER_USER =\n# Gmail app password\nEMAILER_PASSWORD =\n",[91,199,200,206,217,224,230,241,246,252,261,267,275,280,286,297,303,314,319,325,333,339],{"__ignoreMap":89},[94,201,202],{"class":96,"line":97},[94,203,205],{"class":204},"sGBqm","# Environment variable, dev or production (development, production)\n",[94,207,208,211,214],{"class":96,"line":145},[94,209,210],{"class":100},"NODE_ENV",[94,212,213],{"class":104}," =",[94,215,216],{"class":104}," \"development\"\n",[94,218,220],{"class":96,"line":219},3,[94,221,223],{"emptyLinePlaceholder":222},true,"\n",[94,225,227],{"class":96,"line":226},4,[94,228,229],{"class":204},"# Server port\n",[94,231,233,236,238],{"class":96,"line":232},5,[94,234,235],{"class":100},"PORT",[94,237,213],{"class":104},[94,239,240],{"class":138}," 3005\n",[94,242,244],{"class":96,"line":243},6,[94,245,223],{"emptyLinePlaceholder":222},[94,247,249],{"class":96,"line":248},7,[94,250,251],{"class":204},"# MongoDB connection\n",[94,253,255,258],{"class":96,"line":254},8,[94,256,257],{"class":100},"DATABASE",[94,259,260],{"class":104}," =\n",[94,262,264],{"class":96,"line":263},9,[94,265,266],{"class":204},"# MongoDB password\n",[94,268,270,273],{"class":96,"line":269},10,[94,271,272],{"class":100},"DATABASE_PASSWORD",[94,274,260],{"class":104},[94,276,278],{"class":96,"line":277},11,[94,279,223],{"emptyLinePlaceholder":222},[94,281,283],{"class":96,"line":282},12,[94,284,285],{"class":204},"# JWT Token expiration\n",[94,287,289,292,294],{"class":96,"line":288},13,[94,290,291],{"class":100},"JWT_EXPIRES_DAY",[94,293,213],{"class":104},[94,295,296],{"class":104}," \"7d\"\n",[94,298,300],{"class":96,"line":299},14,[94,301,302],{"class":204},"# JWT Token secret\n",[94,304,306,309,311],{"class":96,"line":305},15,[94,307,308],{"class":100},"JWT_SECRET",[94,310,213],{"class":104},[94,312,313],{"class":104}," \"hexschool\"\n",[94,315,317],{"class":96,"line":316},16,[94,318,223],{"emptyLinePlaceholder":222},[94,320,322],{"class":96,"line":321},17,[94,323,324],{"class":204},"# Gmail account\n",[94,326,328,331],{"class":96,"line":327},18,[94,329,330],{"class":100},"EMAILER_USER",[94,332,260],{"class":104},[94,334,336],{"class":96,"line":335},19,[94,337,338],{"class":204},"# Gmail app password\n",[94,340,342,345],{"class":96,"line":341},20,[94,343,344],{"class":100},"EMAILER_PASSWORD",[94,346,260],{"class":104},[17,348,349],{},"You need to prepare:",[351,352,353,357],"ul",{},[354,355,356],"li",{},"MongoDB connection and password",[354,358,359],{},"Gmail account and app password",[17,361,362],{},"Let's set them up.",[364,365,356],"h3",{"id":366},"mongodb-connection-and-password",[17,368,369,370,374],{},"We'll use MongoDB Atlas as our database (I'll skip signup). Click ",[28,371,33],{"href":372,"rel":373},"https:\u002F\u002Fwww.mongodb.com\u002F",[32]," and click \"Sign in\":",[17,376,377],{},[38,378],{"alt":379,"src":380},"Sign in","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FMongoDB_sigin.jpg",[17,382,383],{},"Choose your sign-in method.",[17,385,386],{},[38,387],{"alt":379,"src":388},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fmongodb_sigin_account.png",[17,390,391],{},"I went with GitHub.",[17,393,394],{},"If it's a brand-new account, you'll be asked to create an organization.",[17,396,397],{},[38,398],{"alt":399,"src":400},"Organizations","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fmogodb_Organizations.png",[17,402,403],{},"Click \"Create Organization\", enter a name, choose \"MongoDB Atlas\", and save.",[17,405,406],{},[38,407],{"alt":408,"src":409},"Create Organization","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FCreate_Organization.jpg",[17,411,412],{},"Next page is \"Members and Security\". You can invite others, or just click \"Create Organization\" (defaults are fine).",[17,414,415],{},[38,416],{"alt":417,"src":418},"Members and Security","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FCreate_Organization2.jpg",[17,420,421],{},"Now create a project. MongoDB Atlas is organization-scoped, hence needing the org first. Click \"New Project\".",[17,423,424],{},[38,425],{"alt":426,"src":427},"New Project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FProjects.jpg",[17,429,430],{},"Name it whatever — I called mine \"freyja-project\".",[17,432,433],{},[38,434],{"alt":435,"src":436},"freyja-project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffreyja-project.png",[17,438,439],{},"Next step asks about inviting people — click \"Create Project\". On the project home page, click \"Create\" to deploy a database.",[17,441,442],{},[38,443],{"alt":444,"src":445},"Create Db","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fcreate_db.jpg",[17,447,448],{},"On the \"Deploy your database\" page, choose \"M0 Free\" and click \"Create\".",[17,450,451],{},[38,452],{"alt":453,"src":454},"Deploy your database","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FDeploy_your_database.jpg",[52,456,457],{"title":54,"type":55},[17,458,459],{},"Provider and Region are which cloud and which region to host in — defaults are fine.",[17,461,462],{},"You'll go through MongoDB quick start. Note your username and password — you need these to connect to the database. Click \"Create User\".",[17,464,465],{},[38,466],{"alt":467,"src":468},"Security Quickstart","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FSecurity_Quickstart.jpg",[17,470,471,472,475],{},"Scroll down for IP whitelist setup. Since this is practice, enter ",[91,473,474],{},"0.0.0.0\u002F0"," and click \"Add Entry\", then \"Finish And Close\".",[17,477,478],{},[38,479],{"alt":480,"src":481},"Network Access","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FNetwork%20Access.png",[52,483,484],{"title":54,"type":55},[17,485,486,487,489],{},"In production, you'd set a fixed IP. For practice we use ",[91,488,474],{}," which allows any IP.",[17,491,492],{},"Click the \"Connect\" button.",[17,494,495],{},[38,496],{"alt":497,"src":498},"Connect Db","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FConnent_Db.jpg",[17,500,501],{},"A popup appears. Choose \"Connect your application\" → \"Driver\" → \"Node.js\", copy the connection string.",[17,503,504],{},[38,505],{"alt":506,"src":507},"Connect Db2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FConnect%20Db2.jpg",[17,509,510,511,513,514,516,517,519,520,523],{},"That's our MongoDB connection string. Copy it, go back to ",[91,512,166],{},", update ",[91,515,257],{}," and ",[91,518,272],{},", and replace ",[91,521,522],{},"\u003Cpassword>"," with your password:",[84,525,529],{"className":526,"code":527,"language":528,"meta":89,"style":89},"language-env shiki shiki-themes github-light github-light github-dark-high-contrast","# MongoDB connection\nDATABASE = \"mongodb+srv:\u002F\u002Ftypescript-30-ray:\u003Cpassword>@cluster0.937ixka.mongodb.net\u002F?retryWrites=true&w=majority\"\n# MongoDB password\nDATABASE_PASSWORD = jqZsdqdwqwd31 # don't worry, this is fake\n","env",[91,530,531,535,540,544],{"__ignoreMap":89},[94,532,533],{"class":96,"line":97},[94,534,251],{},[94,536,537],{"class":96,"line":145},[94,538,539],{},"DATABASE = \"mongodb+srv:\u002F\u002Ftypescript-30-ray:\u003Cpassword>@cluster0.937ixka.mongodb.net\u002F?retryWrites=true&w=majority\"\n",[94,541,542],{"class":96,"line":219},[94,543,266],{},[94,545,546],{"class":96,"line":226},[94,547,548],{},"DATABASE_PASSWORD = jqZsdqdwqwd31 # don't worry, this is fake\n",[17,550,551],{},"MongoDB setup done.",[364,553,359],{"id":554},"gmail-account-and-app-password",[17,556,557,558,563],{},"Now get the Gmail account and app password. Go to Google Account settings → \"",[28,559,562],{"href":560,"rel":561},"https:\u002F\u002Fmyaccount.google.com\u002Fu\u002F1\u002Fsecurity",[32],"Security","\".",[17,565,566],{},[38,567],{"alt":568,"src":569},"Google Account","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnodemailer-google-email\u002F2023-07-22%2012.19.15.png",[17,571,572,573,577],{},"Make sure ",[574,575,576],"strong",{},"2-Step Verification"," is on first, otherwise Google won't let you continue.",[17,579,580],{},[38,581],{"alt":582,"src":583},"Two Security","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FTwo%20Security.jpg",[17,585,586],{},"Once that's confirmed, search \"App passwords\" in the top bar and click it.",[17,588,589],{},[38,590],{"alt":591,"src":592},"Application Password","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password.png",[52,594,595],{"title":54,"type":55},[17,596,597],{},"Earlier you could find \"App passwords\" directly on the page, but now you have to search.",[17,599,600],{},"On the \"App passwords\" page, enter \"freyja\" for App Name and click \"Create\".",[17,602,603],{},[38,604],{"alt":591,"src":605},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password2.jpg",[17,607,608],{},"A 16-character password (four groups of four) pops up, like:",[84,610,615],{"className":611,"code":613,"language":614,"meta":89},[612],"language-text","abba dqwd asbc d3hr # fake password\n","text",[91,616,613],{"__ignoreMap":89},[17,618,619],{},[38,620],{"alt":621,"src":622},"Application Password3","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password3.jpg",[17,624,625,626,513,628,516,630,167],{},"Back in ",[91,627,166],{},[91,629,330],{},[91,631,344],{},[84,633,635],{"className":526,"code":634,"language":528,"meta":89,"style":89},"# Gmail account\nEMAILER_USER = \"example@gmail.com\" # the Gmail account you used for the app password\n# Gmail app password\nEMAILER_PASSWORD = \"abba dqwd asbc d3hr\" # the app password you got\n",[91,636,637,641,646,650],{"__ignoreMap":89},[94,638,639],{"class":96,"line":97},[94,640,324],{},[94,642,643],{"class":96,"line":145},[94,644,645],{},"EMAILER_USER = \"example@gmail.com\" # the Gmail account you used for the app password\n",[94,647,648],{"class":96,"line":219},[94,649,338],{},[94,651,652],{"class":96,"line":226},[94,653,654],{},"EMAILER_PASSWORD = \"abba dqwd asbc d3hr\" # the app password you got\n",[17,656,657],{},"All environment variables are now set. Time to run the project:",[84,659,661],{"className":86,"code":660,"language":88,"meta":89,"style":89},"npm run dev\n",[91,662,663],{"__ignoreMap":89},[94,664,665,667,670],{"class":96,"line":97},[94,666,148],{"class":100},[94,668,669],{"class":104}," run",[94,671,672],{"class":104}," dev\n",[17,674,675],{},"You should see:",[17,677,678],{},[38,679],{"alt":680,"src":681},"npm run dev","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fstart.png",[17,683,684],{},"Backend done.",[12,686,688],{"id":687},"deploy-to-rendercom","Deploy to Render.com",[17,690,691,692,697],{},"Open \"",[28,693,696],{"href":694,"rel":695},"https:\u002F\u002Frender.com\u002F",[32],"Render.com","\", click \"Sign up\", and log in.",[52,699,700],{"title":54,"type":55},[17,701,702],{},"If you haven't signed up, do that first (I recommend GitHub login).",[17,704,705],{},"Click \"New\" at the top, then \"New Web Service\".",[17,707,708],{},[38,709],{"alt":710,"src":711},"Web Service","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FRender_Dashboard.jpg",[17,713,714],{},"On \"Create a new Web Service\", select \"Build and deploy from a Git repository\" and click Next.",[17,716,717],{},[38,718],{"alt":719,"src":720},"Build and deploy from a Git repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy_setp1.jpg",[17,722,723],{},"In the \"Connect a repository\" field, search for the name we forked — \"freyja\". Select it and click Connect.",[17,725,726],{},[38,727],{"alt":728,"src":729},"Connect a Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fconnect_repository.jpg",[52,731,732],{"title":54,"type":55},[17,733,734],{},"If you can't find it, your Render.com account isn't linked to the same GitHub account as your fork, or GitHub doesn't have proper Render.com permissions.",[17,736,737],{},"Fill in:",[351,739,740,743,746],{},[354,741,742],{},"Name: \"freyja\"",[354,744,745],{},"Instance Type: \"Free\"",[354,747,748,749],{},"Environment Variables: match the contents of ",[91,750,166],{},[17,752,753],{},"It'll look like:",[17,755,756],{},[38,757],{"alt":758,"src":759},"Environment Variables","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FEnvironment%20Variables.jpg",[52,761,762],{"title":54,"type":55},[17,763,764],{},"You don't need to set PORT or NODE_ENV — Dockerfile handles those. When filling in Environment Variables, don't add quotes.",[17,766,767],{},"Click \"Create Web Service\" and Render.com starts deploying.",[17,769,770],{},"When you see this, deployment succeeded:",[17,772,773],{},[38,774],{"alt":775,"src":776},"Deploy succeeded","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy.jpg",[17,778,779],{},"Scroll up to find your Render.com URL and click it to view your project.",[17,781,782],{},[38,783],{"alt":775,"src":784},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy_2.jpg",[52,786,787],{"title":54,"type":55},[17,788,789,790,793],{},"Hitting the URL directly returns a JSON object. Append ",[91,791,792],{},"swagger"," to the URL to get the API docs.",[17,795,796],{},"That's the full deployment guide.",[798,799,800],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark