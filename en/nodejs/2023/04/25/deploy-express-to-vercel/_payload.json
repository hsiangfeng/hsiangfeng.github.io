[{"data":1,"prerenderedAt":370},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2023\u002F04\u002F25\u002Fdeploy-express-to-vercel\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2023\u002F04\u002F25\u002Fdeploy-express-to-vercel\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2023\u002F04\u002F25\u002Fdeploy-express-to-vercel\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2023\u002F04\u002F25\u002Fdeploy-express-to-vercel\u002F":346,"related:\u002Fen\u002Fnodejs\u002F2023\u002F04\u002F25\u002Fdeploy-express-to-vercel\u002F":355},"\u002Fnodejs\u002F20230425\u002F1940966356\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":330,"date":331,"description":26,"extension":332,"lang":333,"meta":334,"navigation":335,"path":336,"readingMinutes":337,"seo":338,"standalone":339,"stem":340,"tags":341,"tldr":343,"updated":331,"url":344,"__hash__":345},"content\u002Fen\u002FNodejs\u002Fdeploy-express-to-vercel.md","Deploying Express to Vercel","6940691365",{"type":9,"value":10,"toc":324},"minimark",[11,19,24,27,30,33,60,63,68,78,83,86,92,95,101,104,110,120,123,128,131,155,161,167,171,180,187,190,269,272,279,285,288,294,302,306,320],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Vercel","https:\u002F\u002Fi.imgur.com\u002FHFmqtfp.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"A note on deploying Express to Vercel — the steps and the gotchas.",[20,28,6],{"id":29},"deploying-express-to-vercel",[12,31,32],{},"The Express project here is scaffolded with Express Generator:",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-bash shiki shiki-themes github-dark-high-contrast","express --view=ejs express-vercel\n","bash","",[41,42,43],"code",{"__ignoreMap":39},[44,45,48,52,56],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"s_sBn","express",[44,53,55],{"class":54},"sCcAr"," --view=ejs",[44,57,59],{"class":58},"sTRMh"," express-vercel\n",[12,61,62],{},"So the structure looks like this:",[12,64,65],{},[15,66],{"alt":51,"src":67},"https:\u002F\u002Fi.imgur.com\u002F59hLusV.png",[12,69,70,71,77],{},"Next, deploy this project to ",[72,73,17],"a",{"href":74,"rel":75},"https:\u002F\u002Fvercel.com\u002Flogin",[76],"nofollow",". Open the Vercel site and sign in — I'm using GitHub.",[12,79,80],{},[15,81],{"alt":17,"src":82},"https:\u002F\u002Fi.imgur.com\u002FIp21rin.png",[12,84,85],{},"I've used Vercel before, so I click New Project in the top right. If it's your first time, you'll see this screen:",[12,87,88],{},[15,89],{"alt":90,"src":91},"New Project","https:\u002F\u002Fi.imgur.com\u002FDw3htsD.png",[12,93,94],{},"Search for your project name and click Import.",[12,96,97],{},[15,98],{"alt":99,"src":100},"Import","https:\u002F\u002Fi.imgur.com\u002Fv3gDvoz.png",[12,102,103],{},"Fill in the Project Name and Environment Variables as needed. We don't need env vars here, so just click Deploy.",[12,105,106],{},[15,107],{"alt":108,"src":109},"Deploy","https:\u002F\u002Fi.imgur.com\u002FLHar1tf.png",[111,112,113],"blockquote",{},[12,114,115,119],{},[116,117,118],"strong",{},"Note","\nYou'll notice Framework Preset doesn't have Express or Node.js — that's normal.",[12,121,122],{},"Deploy is really fast. A moment later you'll land on this screen:",[12,124,125],{},[15,126],{"alt":108,"src":127},"https:\u002F\u002Fi.imgur.com\u002F3Pc8Rzh.png",[12,129,130],{},"Now go to the project console — there's a Visit button. Click it and you'll see:",[34,132,134],{"className":36,"code":133,"language":38,"meta":39,"style":39},"404: NOT_FOUND Code: NOT_FOUND ID: hkg1::z24c5-1682413583568-853a71174389\n",[41,135,136],{"__ignoreMap":39},[44,137,138,141,144,147,149,152],{"class":46,"line":47},[44,139,140],{"class":50},"404:",[44,142,143],{"class":58}," NOT_FOUND",[44,145,146],{"class":58}," Code:",[44,148,143],{"class":58},[44,150,151],{"class":58}," ID:",[44,153,154],{"class":58}," hkg1::z24c5-1682413583568-853a71174389\n",[12,156,157],{},[15,158],{"alt":159,"src":160},"404: NOT_FOUND","https:\u002F\u002Fi.imgur.com\u002FKh9cbuu.png",[12,162,163,164,166],{},"So we successfully deployed Express to Vercel, but there's more to do — otherwise you'll keep hitting ",[41,165,159],{},".",[20,168,170],{"id":169},"the-fix","The fix",[12,172,173,174,179],{},"So how do we fix it? I found ",[72,175,178],{"href":176,"rel":177},"https:\u002F\u002Fvercel.com\u002Fguides\u002Fusing-express-with-vercel",[76],"Using Express.js with Vercel",", but it doesn't quite match our case — that guide is for APIs, and our project also serves pages.",[12,181,182,183,186],{},"But it does mention something important — the ",[41,184,185],{},"vercel.json"," file, used to configure Vercel. We can use that to solve our problem.",[12,188,189],{},"The content's simple:",[34,191,195],{"className":192,"code":193,"language":194,"meta":39,"style":39},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"builds\": [{ \"src\": \"app.js\", \"use\": \"@now\u002Fnode\" }],\n  \"routes\": [{ \"src\": \"(.*)\", \"dest\": \"app.js\" }]\n}\n","json",[41,196,197,203,236,263],{"__ignoreMap":39},[44,198,199],{"class":46,"line":47},[44,200,202],{"class":201},"sMAXC","{\n",[44,204,206,210,213,216,219,222,225,228,230,233],{"class":46,"line":205},2,[44,207,209],{"class":208},"sKpQp","  \"builds\"",[44,211,212],{"class":201},": [{ ",[44,214,215],{"class":208},"\"src\"",[44,217,218],{"class":201},": ",[44,220,221],{"class":58},"\"app.js\"",[44,223,224],{"class":201},", ",[44,226,227],{"class":208},"\"use\"",[44,229,218],{"class":201},[44,231,232],{"class":58},"\"@now\u002Fnode\"",[44,234,235],{"class":201}," }],\n",[44,237,239,242,244,246,248,251,253,256,258,260],{"class":46,"line":238},3,[44,240,241],{"class":208},"  \"routes\"",[44,243,212],{"class":201},[44,245,215],{"class":208},[44,247,218],{"class":201},[44,249,250],{"class":58},"\"(.*)\"",[44,252,224],{"class":201},[44,254,255],{"class":208},"\"dest\"",[44,257,218],{"class":201},[44,259,221],{"class":58},[44,261,262],{"class":201}," }]\n",[44,264,266],{"class":46,"line":265},4,[44,267,268],{"class":201},"}\n",[12,270,271],{},"Deploy with this file in place, and the page renders correctly.",[111,273,274],{},[12,275,276,278],{},[116,277,118],{},"\nVercel auto-detects commits, so you don't need to manually redeploy.",[12,280,281],{},[15,282],{"alt":283,"src":284},"Express","https:\u002F\u002Fi.imgur.com\u002FkQh22Es.png",[12,286,287],{},"And the API that couldn't be hit before now works too:",[12,289,290],{},[15,291],{"alt":292,"src":293},"API","https:\u002F\u002Fi.imgur.com\u002FDBhrkHN.png",[12,295,296,297,166],{},"For more on this config file, see ",[72,298,301],{"href":299,"rel":300},"https:\u002F\u002Fvercel.com\u002Fdocs\u002Fconcepts\u002Fprojects\u002Fproject-configuration",[76],"Configuring Projects with vercel.json",[20,303,305],{"id":304},"references","References",[307,308,309,315],"ul",{},[310,311,312],"li",{},[72,313,301],{"href":299,"rel":314},[76],[310,316,317],{},[72,318,178],{"href":176,"rel":319},[76],[321,322,323],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}",{"title":39,"searchDepth":205,"depth":205,"links":325},[326,327,328,329],{"id":22,"depth":205,"text":23},{"id":29,"depth":205,"text":6},