[{"data":1,"prerenderedAt":604},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2023\u002F02\u002F14\u002Fvue-cli-vite-correct-build-path\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2023\u002F02\u002F14\u002Fvue-cli-vite-correct-build-path\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2023\u002F02\u002F14\u002Fvue-cli-vite-correct-build-path\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2023\u002F02\u002F14\u002Fvue-cli-vite-correct-build-path\u002F":580,"related:\u002Fen\u002Fnodejs\u002F2023\u002F02\u002F14\u002Fvue-cli-vite-correct-build-path\u002F":589},"\u002Fnodejs\u002F20230214\u002F796256725\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":563,"date":564,"description":19,"extension":565,"lang":566,"meta":567,"navigation":396,"path":568,"readingMinutes":569,"seo":570,"standalone":571,"stem":572,"tags":573,"tldr":577,"updated":564,"url":578,"__hash__":579},"content\u002Fen\u002FNodejs\u002Fvue-cli-vite-correct-build-path.md","Setting the Correct Build Path for Vue CLI and Vite","2502957766",{"type":9,"value":10,"toc":556},"minimark",[11,16,20,24,36,43,49,52,62,66,76,127,138,144,198,218,221,225,233,278,287,293,307,368,382,441,456,460,478,549,552],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This post covers how to properly set the build path for Vue CLI and Vite. It actually matters a lot — if you don't set it right, both your local dev and post-build paths will break. So here's how to do it correctly.",[12,21,23],{"id":22},"the-path-problem","The path problem",[17,25,26,27,31,32,35],{},"The build path config is mostly for the build output, but a lot of people set ",[28,29,30],"code",{},"publicPath"," or ",[28,33,34],{},"base"," incorrectly. These two properties shouldn't be set carelessly. Basically, if during local dev your terminal shows something like this:",[17,37,38],{},[39,40],"img",{"alt":41,"src":42},"Vite","https:\u002F\u002Fi.imgur.com\u002FlChYr73.png",[17,44,45],{},[39,46],{"alt":47,"src":48},"Vue Cli","https:\u002F\u002Fi.imgur.com\u002FChdzKwA.png",[17,50,51],{},"Then your path is wrong. So this post walks through how to set the build path properly.",[53,54,55],"blockquote",{},[17,56,57,61],{},[58,59,60],"strong",{},"Note","\nWhy does the build path need to be set correctly? The main reason is to keep dev and deployment environments separate, which matters most for static asset paths — images, CSS, JS, that kind of thing. So setting it right is extra important.",[12,63,65],{"id":64},"setting-up-vue-cli","Setting up Vue CLI",[17,67,68,69,72,73,75],{},"Let's start with Vue CLI. Usually before deploying a Vue CLI build to GitHub Pages, we create a ",[28,70,71],{},"vue.config.js"," and add a ",[28,74,30],{}," property — the value is the path we want, like:",[77,78,83],"pre",{"className":79,"code":80,"language":81,"meta":82,"style":82},"language-js shiki shiki-themes github-dark-high-contrast","module.exports = {\n  publicPath: '.\u002F',\n};\n","js","",[28,84,85,108,121],{"__ignoreMap":82},[86,87,90,94,98,101,105],"span",{"class":88,"line":89},"line",1,[86,91,93],{"class":92},"sCcAr","module",[86,95,97],{"class":96},"sMAXC",".",[86,99,100],{"class":92},"exports",[86,102,104],{"class":103},"sWyjQ"," =",[86,106,107],{"class":96}," {\n",[86,109,111,114,118],{"class":88,"line":110},2,[86,112,113],{"class":96},"  publicPath: ",[86,115,117],{"class":116},"sTRMh","'.\u002F'",[86,119,120],{"class":96},",\n",[86,122,124],{"class":88,"line":123},3,[86,125,126],{"class":96},"};\n",[17,128,129,130,137],{},"This works, but the ",[131,132,136],"a",{"href":133,"rel":134},"https:\u002F\u002Fcli.vuejs.org\u002Fzh\u002Fconfig\u002F#publicpath",[135],"nofollow","Vue CLI official docs"," actually recommend a different pattern:",[17,139,140],{},[39,141],{"alt":142,"src":143},"Vue Cli publicPath","https:\u002F\u002Fi.imgur.com\u002FuwzkJA4.png",[77,145,147],{"className":79,"code":146,"language":81,"meta":82,"style":82},"module.exports = {\n  publicPath: process.env.NODE_ENV === 'production'\n    ? '\u002Fproduction-sub-path\u002F'\n    : '\u002F'\n}\n",[28,148,149,161,175,183,192],{"__ignoreMap":82},[86,150,151,153,155,157,159],{"class":88,"line":89},[86,152,93],{"class":92},[86,154,97],{"class":96},[86,156,100],{"class":92},[86,158,104],{"class":103},[86,160,107],{"class":96},[86,162,163,166,169,172],{"class":88,"line":110},[86,164,165],{"class":96},"  publicPath: process.env.",[86,167,168],{"class":92},"NODE_ENV",[86,170,171],{"class":103}," ===",[86,173,174],{"class":116}," 'production'\n",[86,176,177,180],{"class":88,"line":123},[86,178,179],{"class":103},"    ?",[86,181,182],{"class":116}," '\u002Fproduction-sub-path\u002F'\n",[86,184,186,189],{"class":88,"line":185},4,[86,187,188],{"class":103},"    :",[86,190,191],{"class":116}," '\u002F'\n",[86,193,195],{"class":88,"line":194},5,[86,196,197],{"class":96},"}\n",[53,199,200],{},[17,201,202,204,207,208,211,212,214,215,97],{},[58,203,60],{},[28,205,206],{},"production-sub-path"," is your GitHub Pages repository — mine is ",[28,209,210],{},"vue3-example",", so my ",[28,213,206],{}," would be ",[28,216,217],{},"\u002Fvue3-example\u002F",[17,219,220],{},"This way both the build path and the local dev path stay correct.",[12,222,224],{"id":223},"setting-up-vite","Setting up Vite",[17,226,227,228,72,231,75],{},"Vite is similar. Usually before deploying a Vite build to GitHub Pages, we create a ",[28,229,230],{},"vite.config.js",[28,232,34],{},[77,234,236],{"className":79,"code":235,"language":81,"meta":82,"style":82},"\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...other settings skipped\n  base: '.\u002F'\n})\n",[28,237,238,244,260,265,273],{"__ignoreMap":82},[86,239,240],{"class":88,"line":89},[86,241,243],{"class":242},"sQrFR","\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\n",[86,245,246,249,252,256],{"class":88,"line":110},[86,247,248],{"class":103},"export",[86,250,251],{"class":103}," default",[86,253,255],{"class":254},"sj_SG"," defineConfig",[86,257,259],{"class":258},"s_sBn","({\n",[86,261,262],{"class":88,"line":123},[86,263,264],{"class":242},"  \u002F\u002F ...other settings skipped\n",[86,266,267,270],{"class":88,"line":185},[86,268,269],{"class":96},"  base: ",[86,271,272],{"class":116},"'.\u002F'\n",[86,274,275],{"class":88,"line":194},[86,276,277],{"class":258},"})\n",[17,279,280,281,286],{},"This is in the official docs too, but interestingly the ",[131,282,285],{"href":283,"rel":284},"https:\u002F\u002Fcn.vitejs.dev\u002Fconfig\u002Fshared-options.html#base",[135],"docs"," don't suggest a recommended pattern this time.",[17,288,289],{},[39,290],{"alt":291,"src":292},"Vite Base","https:\u002F\u002Fi.imgur.com\u002FoO5JIwQ.png",[17,294,295,296,299,300,303,304,306],{},"So does that mean we just always write ",[28,297,298],{},".\u002F"," or hardcode ",[28,301,302],{},"\u002Frepo-name\u002F","? Actually no — that would break local dev. Like Vue CLI, we still need to set ",[28,305,34],{}," based on the environment. So you might happily write something like:",[77,308,310],{"className":79,"code":309,"language":81,"meta":82,"style":82},"\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...other settings skipped\n  base: import.meta.env.MODE === 'production' ? '\u002Fproduction-sub-path\u002F' : '\u002F'\n})\n",[28,311,312,316,326,330,364],{"__ignoreMap":82},[86,313,314],{"class":88,"line":89},[86,315,243],{"class":242},[86,317,318,320,322,324],{"class":88,"line":110},[86,319,248],{"class":103},[86,321,251],{"class":103},[86,323,255],{"class":254},[86,325,259],{"class":258},[86,327,328],{"class":88,"line":123},[86,329,264],{"class":242},[86,331,332,334,337,339,342,345,348,350,353,356,359,362],{"class":88,"line":185},[86,333,269],{"class":96},[86,335,336],{"class":103},"import",[86,338,97],{"class":96},[86,340,341],{"class":92},"meta",[86,343,344],{"class":96},".env.",[86,346,347],{"class":92},"MODE",[86,349,171],{"class":103},[86,351,352],{"class":116}," 'production'",[86,354,355],{"class":103}," ?",[86,357,358],{"class":116}," '\u002Fproduction-sub-path\u002F'",[86,360,361],{"class":103}," :",[86,363,191],{"class":116},[86,365,366],{"class":88,"line":194},[86,367,277],{"class":258},[17,369,370,371,374,375,377,378,381],{},"But you'll find this errors out, because ",[28,372,373],{},"import.meta"," isn't available in ",[28,376,230],{},". So we have to use ",[28,379,380],{},"process.env"," instead, and the final version looks like this:",[77,383,385],{"className":79,"code":384,"language":81,"meta":82,"style":82},"\u002F* global process *\u002F\n\n\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...other settings skipped\n  base: process.env.NODE_ENV === 'production' ? '\u002Fproduction-sub-path\u002F' : '\u002F'\n})\n",[28,386,387,392,398,402,412,416,436],{"__ignoreMap":82},[86,388,389],{"class":88,"line":89},[86,390,391],{"class":242},"\u002F* global process *\u002F\n",[86,393,394],{"class":88,"line":110},[86,395,397],{"emptyLinePlaceholder":396},true,"\n",[86,399,400],{"class":88,"line":123},[86,401,243],{"class":242},[86,403,404,406,408,410],{"class":88,"line":185},[86,405,248],{"class":103},[86,407,251],{"class":103},[86,409,255],{"class":254},[86,411,259],{"class":258},[86,413,414],{"class":88,"line":194},[86,415,264],{"class":242},[86,417,419,422,424,426,428,430,432,434],{"class":88,"line":418},6,[86,420,421],{"class":96},"  base: process.env.",[86,423,168],{"class":92},[86,425,171],{"class":103},[86,427,352],{"class":116},[86,429,355],{"class":103},[86,431,358],{"class":116},[86,433,361],{"class":103},[86,435,191],{"class":116},[86,437,439],{"class":88,"line":438},7,[86,440,277],{"class":258},[53,442,443],{},[17,444,445,447,448,451,452,455],{},[58,446,60],{},"\nSince ",[28,449,450],{},"process"," is a Node.js global, we add ",[28,453,454],{},"\u002F* global process *\u002F"," at the top of the file so ESLint doesn't complain