lass":240},[149,1575,1576],{"class":159},"\"^2.0.0\"",[149,1578,257],{"class":240},[149,1580,1582,1585,1587,1590],{"class":151,"line":1581},21,[149,1583,1584],{"class":247},"        \"supports-color\"",[149,1586,251],{"class":240},[149,1588,1589],{"class":159},"\"^5.5.0\"",[149,1591,257],{"class":240},[149,1593,1595,1598,1600,1603],{"class":151,"line":1594},22,[149,1596,1597],{"class":247},"        \"touch\"",[149,1599,251],{"class":240},[149,1601,1602],{"class":159},"\"^3.1.0\"",[149,1604,257],{"class":240},[149,1606,1608,1611,1613],{"class":151,"line":1607},23,[149,1609,1610],{"class":247},"        \"undefsafe\"",[149,1612,251],{"class":240},[149,1614,1615],{"class":159},"\"^2.0.5\"\n",[149,1617,1619],{"class":151,"line":1618},24,[149,1620,1621],{"class":240},"      }\n",[149,1623,1625],{"class":151,"line":1624},25,[149,1626,1627],{"class":240},"    },\n",[149,1629,1631],{"class":151,"line":1630},26,[149,1632,1440],{"class":663},[149,1634,1636],{"class":151,"line":1635},27,[149,1637,526],{"class":240},[149,1639,1641],{"class":151,"line":1640},28,[149,1642,372],{"class":240},[12,1644,1645,1646,1648,1649,1651,1652,1654],{},"You'll see ",[41,1647,381],{}," also records other package versions — these are ",[41,1650,381],{},"'s dependencies. So when you run ",[41,1653,1089],{}," in different environments, it installs based on the versions in package-lock.json — preventing mismatched versions across environments from breaking the project.",[12,1656,1657],{},"So package-lock.json is a really important file.",[20,1659,1661],{"id":1660},"what-about-node_modules","What about node_modules?",[12,1663,1664],{},"node_modules…",[12,1666,1667],{},[15,1668],{"alt":1669,"src":1670},"node_modules","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fnode_modules_to_be.png",[12,1672,1673],{},"…is a black hole. End of story.",[12,1675,1676],{},"There's a reason node_modules has been jokingly called a black hole. Every time you install a package, a folder gets created in node_modules containing all the package's files. So when you've installed lots of packages, node_modules gets really big — sometimes over 100MB (my personal record is around 500MB). At that point you'll notice node_modules is just like a black hole — you have no idea what's in it, just that it keeps getting fatter.",[12,1678,1679],{},"So you basically just need to know it's where packages we'll use are stored. As for what's actually in there, you really don't need to care.",[12,1681,1682,1683,1688],{},"If you do care, you might consider a different package manager like ",[614,1684,1687],{"href":1685,"rel":1686},"https:\u002F\u002Fpnpm.io\u002F",[618],"pnpm"," — which makes node_modules much smaller because it shares packages across projects. But I won't go into details — covering pnpm could easily take three more days.",[20,1690,1692],{"id":1691},"building-your-first-nodejs-project","Building your first Node.js project",[12,1694,1695],{},"Wow, so much yapping — and we're finally about to build a Node.js project. Let's start with a simple one.",[12,1697,1698],{},"Node.js comes with many built-in modules. Since JavaScript is a powerful language, we can build a simple server with it. Let's do that.",[12,1700,1701],{},"In your terminal, type this (in the example folder we just created):",[140,1703,1705],{"className":142,"code":1704,"language":144,"meta":145,"style":145},"touch index.js\n",[41,1706,1707],{"__ignoreMap":145},[149,1708,1709,1712],{"class":151,"line":152},[149,1710,1711],{"class":155},"touch",[149,1713,1714],{"class":159}," index.js\n",[12,1716,1717],{},"The Node.js official docs provide a simple example, so I'll just use that:",[140,1719,1723],{"className":1720,"code":1721,"language":1722,"meta":145,"style":145},"language-js shiki shiki-themes github-dark-high-contrast","const http = require('node:http');\n\nconst hostname = '127.0.0.1';\nconst port = 3000;\n\nconst server = http.createServer((req, res) => {\n  res.statusCode = 