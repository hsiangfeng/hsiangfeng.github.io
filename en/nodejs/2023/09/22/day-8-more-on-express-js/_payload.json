,928,930,932,934,936,938,940],{"class":47,"line":48},[45,920,136],{"class":66},[45,922,139],{"class":62},[45,924,67],{"class":66},[45,926,927],{"class":70},"'\u002Ftodos\u002F:id'",[45,929,147],{"class":66},[45,931,151],{"class":150},[45,933,154],{"class":66},[45,935,157],{"class":150},[45,937,160],{"class":66},[45,939,163],{"class":51},[45,941,166],{"class":66},[45,943,944,946,948,951,953,955,958],{"class":47,"line":77},[45,945,221],{"class":51},[45,947,224],{"class":66},[45,949,950],{"class":55},"id",[45,952,235],{"class":66},[45,954,238],{"class":51},[45,956,957],{"class":66}," req.params; ",[45,959,960],{"class":435},"\u002F\u002F Get the dynamic route parameter\n",[45,962,963],{"class":47,"line":92},[45,964,842],{"class":435},[45,966,967],{"class":47,"line":108},[45,968,184],{"class":66},[12,970,971],{},"What about query strings?",[35,973,975],{"className":37,"code":974,"language":39,"meta":40,"style":40},"app.get('\u002Ftodos', (req, res) => {\n  const { keyword } = req.query; \u002F\u002F Get the query string parameter\n  \u002F\u002F...other code omitted\n});\n",[42,976,977,1001,1020,1024],{"__ignoreMap":40},[45,978,979,981,983,985,987,989,991,993,995,997,999],{"class":47,"line":48},[45,980,136],{"class":66},[45,982,139],{"class":62},[45,984,67],{"class":66},[45,986,144],{"class":70},[45,988,147],{"class":66},[45,990,151],{"class":150},[45,992,154],{"class":66},[45,994,157],{"class":150},[45,996,160],{"class":66},[45,998,163],{"class":51},[45,1000,166],{"class":66},[45,1002,1003,1005,1007,1010,1012,1014,1017],{"class":47,"line":77},[45,1004,221],{"class":51},[45,1006,224],{"class":66},[45,1008,1009],{"class":55},"keyword",[45,1011,235],{"class":66},[45,1013,238],{"class":51},[45,1015,1016],{"class":66}," req.query; ",[45,1018,1019],{"class":435},"\u002F\u002F Get the query string parameter\n",[45,1021,1022],{"class":47,"line":92},[45,1023,842],{"class":435},[45,1025,1026],{"class":47,"line":108},[45,1027,184],{"class":66},[12,1029,1030,1031,1034,1035,533],{},"Interestingly, query strings don't need any special config. As long as your URL has ",[42,1032,1033],{},"?",", it gets auto-parsed as a query string, and you can access the parameters via ",[42,1036,1037],{},"req.query",[12,1039,1040,1041,1043,1044,1047,1048,1051,1052,533],{},"Query strings are commonly used for searching — e.g., ",[42,1042,788],{}," searches for articles containing the keyword ",[42,1045,1046],{},"Express",". They're also commonly used for pagination combined with keywords — e.g., ",[42,1049,1050],{},"https:\u002F\u002Fisraynotarray.com\u002Fposts?page=1&keyword=Express"," gets the first page of articles searching for ",[42,1053,1046],{},[725,1055,1056],{},[12,1057,1058,1060,1061,1064,1065,1067,1068,1070,1071,154,1073,1075,1076,1078],{},[730,1059,732],{},"\nFor multiple query strings, use ",[42,1062,1063],{},"&"," to chain them. Query strings start with ",[42,1066,1033],{},", and parameters are chained with ",[42,1069,1063],{},". So you'll see ",[42,1072,1033],{},[42,1074,1063],{},", and ",[42,1077,238],{}," symbols.",[12,1080,1081],{},"One important reminder about query strings: if your query string contains special characters, spaces, or non-alphanumeric characters, you have to handle it specially or you'll get errors.",[12,1083,1084],{},"What does that mean? We know a query string combination looks like this:",[35,1086,1090],{"className":1087,"code":1088,"language":1089,"meta":40,"style":40},"language-txt shiki shiki-themes github-dark-high-contrast","?page=1&keyword=Express\n","txt",[42,1091,1092],{"__ignoreMap":40},[45,1093,1094],{"class":47,"line":48},[45,1095,1088],{},[12,1097,1098],{},"So if you wanted to pass \"ray&array\" as the keyword, your query string would look like:",[35,1100,1102],{"className":1087,"code":1101,"language":1089,"meta":40,"style":40},"?page=1&keyword=ray&array\n",[42,1103,1104],{"__ignoreMap":40},[45,1105,1106],{"class":47,"line":48},[45,1107,1101],{},[12,1109,1110],{},"This causes parsing errors. So you have to convert special characters, spaces, or non-alphanumeric characters to URL encoding, like:",[35,1112,1114],{"className":1087,"code":1113,"language":1089,"meta":40,"style":40},"?page=1&keyword=ray%26array\n",[42,1115,1116],{"__ignoreMap":40},[45,1117,1118],{"class":47,"line":48},[45,1119,1113],{},[725,1121,1122],{},[12,1123,1124,1126,1127,1130],{},[730,1125,732],{},"\nURL encoding (also called percent encoding or URL escaping) converts special characters, spaces, or non-alphanumeric characters to ",[42,1128,1129],{},"%"," plus the hexadecimal code.",[12,1132,1133,1134,1137],{},"Quick mention of how the frontend handles this — usually with ",[42,1135,1136],{},"encodeURIComponent",":",[35,1139,1141],{"className":37,"code":1140,"language":39,"meta":40,"style":40},"const keyword = 'ray&array';\n\nconst encodedKeyword = encodeURIComponent(keyword);\n\nconsole.log(encodedKeyword); \u002F\u002F ray%26array\n",[42,1142,1143,1157,1161,1176,1180],{"__ignoreMap":40},[45,1144,1145,1147,1150,1152,1155],{"class":47,"line":48},[45,1146,52],{"class":51},[45,1148,1149],{"class":55}," keyword",[45,1151,59],{"class":51},[45,1153,1154],{"class":70}," 'ray&array'",[45,1156,105],{"class":66},[45,1158,1159],{"class":47,"line":77},[45,1160,112],{"emptyLinePlaceholder":111},[45,1162,1163,1165,1168,1170,1173],{"class":47,"line":92},[45,1164,52],{"class":51},[45,1166,1167],{"class":55}," encodedKeyword",[45,1169,59],{"class":51},[45,1171,1172],{"class":62}," encodeURIComponent",[45,1174,1175],{"class":66},"(keyword);\n",[45,1177,1178],{"class":47,"line":108},[45,1179,112],{"emptyLinePlaceholder":111},[45,1181,1182,1185,1188,1191],{"class":47,"line":115},[45,1183,1184],{"class":66},"console.",[45,1186,1187],{"class":62},"log",[45,1189,1190],{"class":66},"(encodedKeyword); ",[45,1192,1193],{"class":435},"\u002F\u002F ray%26array\n",[12,1195,1196],{},"Now that we have a basic idea of query string gotchas, back to Express.js.",[12,1198,1199],{},"In real-world dev, we usually put routes in separate files, like:",[35,1201,1203],{"className":37,"code":1202,"language":39,"meta":40,"style":40},"\u002F\u002F routes\u002Ftodos.js\nconst express = require('express');\nconst router = express.Router();\n\nrouter.get('\u002F', (req, res) => {\n  \u002F\u002F...other code omitted\n});\n\nrouter.post('\u002F', (req, res) => {\n  \u002F\u002F...other code omitted\n});\n\nmodule.exports = router;\n",[42,1204,1205,1210,1226,1243,1247,1272,1276,1280,1284,1308,1312,1316,1320],{"__ignoreMap":40},[45,1206,1207],{"class":47,"line":48},[45,1208,1209],{"class":435},"\u002F\u002F routes\u002Ftodos.js\n",[45,1211,1212,1214,1216,1218,1220,1222,1224],{"class":47,"line":77},[45,1213,52],{"class":51},[45,1215,56],{"class":55},[45,1217,59],{"class":51},[45,1219,63],{"class":62},[45,1221,67],{"class":66},[45,1223,71],{"class":70},[45,1225,74],{"class":66},[45,1227,1228,1230,1233,1235,1238,1241],{"class":47,"line":92},[45,1229,52],{"class":51},[45,1231,1232],{"class":55}," router",[45,1234,59],{"class":51},[45,1236,1237],{"class":66}," express.",[45,1239,1240],{"class":62},"Router",[45,1242,89],{"class":66},[45,1244,1245],{"class":47,"line":108},[45,1246,112],{"emptyLinePlaceholder":111},[45,1248,1249,1252,1254,1256,1258,1260,1262,1264,1266,1268,1270],{"class":47,"line":115},[45,1250,1251],{"class":66},"router.",[45,1253,139],{"class":62},[45,1255,67],{"class":66},[45,1257,649],{"class":70},[45,1259,147],{"class":66},[45,1261,151],{"class":150},[45,1263,154],{"class":66},[45,1265,157],{"class":150},[45,1267,160],{"class":66},[45,1269,163],{"class":51},[45,1271,166],{"class":66},[45,1273,1274],{"class":47,"line":128},[45,1275,842],{"class":435},[45,1277,1278],{"class":47,"line":133},[45,1279,184],{"class":66},[45,1281,1282],{"class":47,"line":169},[45,1283,112],{"emptyLinePlaceholder":111},[45,1285,1286,1288,1290,1292,1294,1296,1298,1300,1302,1304,1306],{"class":47,"line":181},[45,1287,1251],{"class":66},[45,1289,197],{"class":62},[45,1291,67],{"class":66},[45,1293,649],{"class":70},[45,1295,147],{"class":66},[45,1297,151],{"class":150},[45,1299,154],{"class":66},[45,1301,157],{"class":150},[45,1303,160],{"class":66},[45,1305,163],{"class":51},[45,1307,166],{"class":66},[45,1309,1310],{"class":47,"line":187},[45,1311,842],{"class":435},[45,1313,1314],{"class":47,"line":192},[45,1315,184],{"class":66},[45,1317,1318],{"class":47,"line":218},[45,1319,112],{"emptyLinePlaceholder":111},[45,1321,1322,1325,1327,1330,1332],{"class":47,"line":244},[45,1323,1324],{"class":55},"module",[45,1326,533],{"class":66},[45,1328,1329],{"class":55},"exports",[45,1331,59],{"class":51},[45,1333,1334],{"class":66}," router;\n",[35,1336,1338],{"className":37,"code":1337,"language":39,"meta":40,"style":40},"\u002F\u002F app.js\nconst express = require('express');\n\u002F\u002F...other code omitted\nconst todosRouter = require('.\u002Froutes\u002Ftodos');\n\napp.use('\u002Ftodos', todosRouter);\n\n\u002F\u002F...other code omitted\n",[42,1339,1340,1345,1361,1365,1383,1387,1400,1404],{"__ignoreMap":40},[45,1341,1342],{"class":47,"line":48},[45,1343,1344],{"class":435},"\u002F\u002F app.js\n",[45,1346,1347,1349,1351,1353,1355,1357,1359],{"class":47,"line":77},[45,1348,52],{"class":51},[45,1350,56],{"class":55},[45,1352,59],{"class":51},[45,1354,63],{"class":62},[45,1356,67],{"class":66},[45,1358,71],{"class":70},[45,1360,74],{"class":66},[45,1362,1363],{"class":47,"line":92},[45,1364,809],{"class":435},[45,1366,1367,1369,1372,1374,1376,1378,1381],{"class":47,"line":108},[45,1368,52],{"class":51},[45,1370,1371],{"class":55}," todosRouter",[45,1373,59],{"class":51},[45,1375,63],{"class":62},[45,1377,67],{"class":66},[45,1379,1380],{"class":70},"'.\u002Froutes\u002Ftodos'",[45,1382,74],{"class":66},[45,1384,1385],{"class":47,"line":115},[45,1386,112],{"emptyLinePlaceholder":111},[45,1388,1389,1391,1393,1395,1397],{"class":47,"line":128},[45,1390,136],{"class":66},[45,1392,629],{"class":62},[45,1394,67],{"class":66},[45,1396,144],{"class":70},[45,1398,1399],{"class":66},", todosRouter);\n",[45,1401,1402],{"class":47,"line":133},[45,1403,112],{"emptyLinePlaceholder":111},[45,1405,1406],{"class":47,"line":169},[45,1407,809],{"class":435},[12,1409,1410],{},"Why do we do this? In real-world dev, our routes won't be just a few — a project might have dozens of routes, so we need to organize them. Splitting routes by file is one way.",[12,1412,1413],{},"This way the code is more organized and readable. If your project isn't that complex, you don't necessarily need to do this. But if your project is complex, this is a must.",[20,1415,1417],{"id":1416},"about-project-folder-structure","About project folder structure",[12,1419,1420],{},"Speaking of separating routes into folders, let me also mention project folder structure.",[12,1422,1423],{},"Project folders don't have hard rules about structure. Here are some common folders:",[760,1425,1426,1432,1438,1444,1450,1456,1462,1468,1474,1480],{},[763,1427,1428,1431],{},[42,1429,1430],{},"routes",": routes",[763,1433,1434,1437],{},[42,1435,1436],{},"controllers",": controllers",[763,1439,1440,1443],{},[42,1441,1442],{},"models",": models",[763,1445,1446,1449],{},[42,1447,1448],{},"middlewares",": middleware",[763,1451,1452,1455],{},[42,1453,1454],{},"public",": static assets",[763,1457,1458,1461],{},[42,1459,1460],{},"views",": views",[763,1463,1464,1467],{},[42,1465,1466],{},"utils",": utilities",[763,1469,1470,1473],{},[42,1471,1472],{},"tests",": tests",[763,1475,1476,1479],{},[42,1477,1478],{},"config",": configuration",[763,1481,1482,1485],{},[42,1483,1484],{},"services",": services",[12,1487,1488,1489,1491,1492,1494],{},"This is a common structure, but you can adjust based on your needs. For example, if your project doesn't need tests, you don't need a ",[42,1490,1472],{}," folder. Or if your project is API-only, you don't need a ",[42,1493,1460],{}," folder.",[725,1496,1497],{},[12,1498,1499,1501,1502,533],{},[730,1500,732],{},"\nControllers + Models + Views together are called the MVC architecture. In the early days without MVC, code was written all together, which made it hard to maintain. MVC was created to solve this — see ",[737,1503,1506],{"href":1504,"rel":1505},"https:\u002F\u002Fisraynotarray.com\u002Fphp\u002F20190909\u002F3519693707\u002F",[741],"Day 8 - Learning ThinkPHP from Basics - MVC pattern (article in Mandarin)",[12,1508,1509],{},"Beyond the basic MVC folders, middlewares, and routes covered earlier, let me briefly cover a few more.",[1511,1512,1513],"h3",{"id":1454},"Public",[12,1515,1516,1517,1519,1520,1522,1523,533],{},"The ",[42,1518,1454],{}," folder is mostly for static assets — images, CSS, JavaScript, etc. — assets that don't need processing. We can put these directly in ",[42,1521,1454],{}," so they can be accessed via URL, like ",[42,1524,1525],{},"https:\u002F\u002Fisraynotarray.com\u002Fimages\u002Flogo.png",[725,1527,1528],{},[12,1529,1530,1532],{},[730,1531,732],{},"\nEven though Public is mainly for static assets, don't put sensitive resources here — passwords, keys, etc. — because these can be directly accessed via URL, causing security issues.",[1511,1534,1466],{"id":1466},[12,1536,1537,1539],{},[42,1538,1466],{}," stands for utilities — usually for general-purpose utility programs. For example…",[12,1541,1542],{},"Date handling:",[35,1544,1546],{"className":37,"code":1545,"language":39,"meta":40,"style":40},"\u002F\u002F utils\u002FdateUtils.js\nfunction formatDate(date, format) {\n  \u002F\u002F Date format conversion logic\n}\n\nmodule.exports = formatDate;\n",[42,1547,1548,1553,1574,1579,1583,1587],{"__ignoreMap":40},[45,1549,1550],{"class":47,"line":48},[45,1551,1552],{"class":435},"\u002F\u002F utils\u002FdateUtils.js\n",[45,1554,1555,1558,1561,1563,1566,1568,1571],{"class":47,"line":77},[45,1556,1557],{"class":51},"function",[45,1559,1560],{"class":62}," formatDate",[45,1562,67],{"class":66},[45,1564,1565],{"class":150},"date",[45,1567,154],{"class":66},[45,1569,1570],{"class":150},"format",[45,1572,1573],{"class":66},") {\n",[45,1575,1576],{"class":47,"line":92},[45,1577,1578],{"class":435},"  \u002F\u002F Date format conversion logic\n",[45,1580,1581],{"class":47,"line":108},[45,1582,616],{"class":66},[45,1584,1585],{"class":47,"line":115},[45,1586,112],{"emptyLinePlaceholder":111},[45,1588,1589,1591,1593,1595,1597],{"class":47,"line":128},[45,1590,1324],{"class":55},[45,1592,533],{"class":66},[45,1594,1329],{"class":55},[45,1596,59],{"class":51},[45,1598,1599],{"class":66}," formatDate;\n",[12,1601,1602],{},"Email validation:",[35,1604,1606],{"className":37,"code":1605,"language":39,"meta":40,"style":40},"\u002F\u002F utils\u002FemailUtils.js\nfunction validateEmail(email) {\n  \u002F\u002F Email validation logic\n}\n\nmodule.exports = validateEmail;\n",[42,1607,1608,1613,1627,1632,1636,1640],{"__ignoreMap":40},[45,1609,1610],{"class":47,"line":48},[45,1611,1612],{"class":435},"\u002F\u002F utils\u002FemailUtils.js\n",[45,1614,1615,1617,1620,1622,1625],{"class":47,"line":77},[45,1616,1557],{"class":51},[45,1618,1619],{"class":62}," validateEmail",[45,1621,67],{"class":66},[45,1623,1624],{"class":150},"email",[45,1626,1573],{"class":66},[45,1628,1629],{"class":47,"line":92},[45,1630,1631],{"class":435},"  \u002F\u002F Email validation logic\n",[45,1633,1634],{"class":47,"line":108},[45,1635,616],{"class":66},[45,1637,1638],{"class":47,"line":115},[45,1639,112],{"emptyLinePlaceholder":111},[45,1641,1642,1644,1646,1648,1650],{"class":47,"line":128},[45,1643,1324],{"class":55},[45,1645,533],{"class":66},[45,1647,1329],{"class":55},[45,1649,59],{"class":51},[45,1651,1652],{"class":66}," validateEmail;\n",[12,1654,1655,1656,1658,1659,1137],{},"These more general-purpose pieces of code go in the ",[42,1657,1466],{}," folder. The benefit is we can easily import them via ",[42,1660,1661],{},"require",[35,1663,1665],{"className":37,"code":1664,"language":39,"meta":40,"style":40},"const formatDate = require('.\u002Futils\u002FdateUtils');\n\nconst date = new Date();\n\nconst formattedDate = formatDate(date, 'yyyy-MM-dd');\n",[42,1666,1667,1684,1688,1704,1708],{"__ignoreMap":40},[45,1668,1669,1671,1673,1675,1677,1679,1682],{"class":47,"line":48},[45,1670,52],{"class":51},[45,1672,1560],{"class":55},[45,1674,59],{"class":51},[45,1676,63],{"class":62},[45,1678,67],{"class":66},[45,1680,1681],{"class":70},"'.\u002Futils\u002FdateUtils'",[45,1683,74],{"class":66},[45,1685,1686],{"class":47,"line":77},[45,1687,112],{"emptyLinePlaceholder":111},[45,1689,1690,1692,1695,1697,1700,1702],{"class":47,"line":92},[45,1691,52],{"class":51},[45,1693,1694],{"class":55}," date",[45,1696,59],{"class":51},[45,1698,1699],{"class":51}," new",[45,1701,270],{"class":62},[45,1703,89],{"class":66},[45,1705,1706],{"class":47,"line":108},[45,1707,112],{"emptyLinePlaceholder":111},[45,1709,1710,1712,1715,1717,1719,1722,1725],{"class":47,"line":115},[45,1711,52],{"class":51},[45,1713,1714],{"class":55}," formattedDate",[45,1716,59],{"class":51},[45,1718,1560],{"class":62},[45,1720,1721],{"class":66},"(date, ",[45,1723,1724],{"class":70},"'yyyy-MM-dd'",[45,1726,74],{"class":66},[1511,1728,1478],{"id":1478},[12,1730,1731],{},"This folder is simpler — usually contains config files related to the project, like:",[760,1733,1734,1737,1740,1743],{},[763,1735,1736],{},"DB connection settings",[763,1738,1739],{},"Env variable settings",[763,1741,1742],{},"Log settings",[763,1744,1745],{},"Site settings",[12,1747,1748],{},"And more — won't list all here.",[1511,1750,1484],{"id":1484},[12,1752,1753,1755],{},[42,1754,1484],{}," usually contains code related to business logic. For example, blog-related logic:",[35,1757,1759],{"className":37,"code":1758,"language":39,"meta":40,"style":40},"\u002F\u002F services\u002FArticleService.js\nconst Article = require('..\u002Fmodels\u002FArticle');\n\nfunction createArticle(title, content) {\n  \u002F\u002F Create a new article\n  const newArticle = articleModel.create({ title, content });\n  return newArticle;\n}\n\nfunction getArticleById(articleId) {\n  \u002F\u002F Get an article by ID\n  const article = articleModel.findById(articleId);\n  return article;\n}\n\nfunction getAllArticles() {\n  \u002F\u002F Get all articles\n  const articles = articleModel.find();\n  return articles;\n}\n\nfunction updateArticle(articleId, newData) {\n  \u002F\u002F Update article content\n  const updatedArticle = articleModel.findByIdAndUpdate(articleId, newData, { new: true });\n  return updatedArticle;\n}\n\nfunction deleteArticle(articleId) {\n  \u002F\u002F Delete an article\n  const deletedArticle = articleModel.findByIdAndDelete(articleId);\n  return deletedArticle;\n}\n\nmodule.exports = {\n  createArticle,\n  getArticleById,\n  getAllArticles,\n  updateArticle,\n  deleteArticle\n};\n",[42,1760,1761,1766,1784,1788,1806,1811,1829,1837,1841,1845,1859,1864,1881,1888,1892,1896,1906,1911,1927,1934,1938,1942,1960,1965,1987,1994,1998,2002,2015,2020,2036,2043,2047,2051,2063,2069,2075,2081,2087,2093],{"__ignoreMap":40},[45,1762,1763],{"class":47,"line":48},[45,1764,1765],{"class":435},"\u002F\u002F services\u002FArticleService.js\n",[45,1767,1768,1770,1773,1775,1777,1779,1782],{"class":47,"line":77},[45,1769,52],{"class":51},[45,1771,1772],{"class":55}," Article",[45,1774,59],{"class":51},[45,1776,63],{"class":62},[45,1778,67],{"class":66},[45,1780,1781],{"class":70},"'..\u002Fmodels\u002FArticle'",[45,1783,74],{"class":66},[45,1785,1786],{"class":47,"line":92},[45,1787,112],{"emptyLinePlaceholder":111},[45,1789,1790,1792,1795,1797,1799,1801,1804],{"class":47,"line":108},[45,1791,1557],{"class":51},[45,1793,1794],{"class":62}," createArticle",[45,1796,67],{"class":66},[45,1798,227],{"class":150},[45,1800,154],{"class":66},[45,1802,1803],{"class":150},"content",[45,1805,1573],{"class":66},[45,1807,1808],{"class":47,"line":115},[45,1809,1810],{"class":435},"  \u002F\u002F Create a new article\n",[45,1812,1813,1815,1818,1820,1823,1826],{"class":47,"line":128},[45,1814,221],{"class":51},[45,1816,1817],{"class":55}," newArticle",[45,181