36],{"class":66},[45,628,629],{"class":62},"use",[45,631,632],{"class":66},"(jsonParserMiddleware);\n",[45,634,636],{"class":47,"line":635},29,[45,637,112],{"emptyLinePlaceholder":111},[45,639,641,643,645,647,650,652,654,656,658,660,662],{"class":47,"line":640},30,[45,642,136],{"class":66},[45,644,197],{"class":62},[45,646,67],{"class":66},[45,648,649],{"class":70},"'\u002F'",[45,651,147],{"class":66},[45,653,151],{"class":150},[45,655,154],{"class":66},[45,657,157],{"class":150},[45,659,160],{"class":66},[45,661,163],{"class":51},[45,663,166],{"class":66},[45,665,667,669,671],{"class":47,"line":666},31,[45,668,172],{"class":66},[45,670,175],{"class":62},[45,672,673],{"class":66},"(req.body);\n",[45,675,677],{"class":47,"line":676},32,[45,678,184],{"class":66},[45,680,682],{"class":47,"line":681},33,[45,683,112],{"emptyLinePlaceholder":111},[45,685,687,689,691,693,695],{"class":47,"line":686},34,[45,688,136],{"class":66},[45,690,329],{"class":62},[45,692,67],{"class":66},[45,694,334],{"class":55},[45,696,337],{"class":66},[12,698,699],{},"This post continues from Express.js to introduce Routing.",[12,701,702],{},"Routing is super important in web development — calling it the bridge that connects web pages isn't an exaggeration, since that's literally what it does. It's one of the core components of any website.",[12,704,705],{},"OK enough talk, let's set up a scenario.",[12,707,708,709,712,713,717,718,720,721,533],{},"Say you type ",[42,710,711],{},"https:\u002F\u002Fisraynotarray.com\u002F"," in your browser — you'll see my blog \"homepage\" (",[714,715,716],"del",{},"plug intended","). The URL ",[42,719,711],{}," corresponds to our \"homepage\" route, and that route is ",[42,722,723],{},"\u002F",[725,726,727],"blockquote",{},[12,728,729,733,735,736,533],{},[730,731,732],"strong",{},"Note",[42,734,711],{}," is what's called a URL. If you don't have a concept of URLs, see my earlier post ",[737,738,742],"a",{"href":739,"rel":740},"https:\u002F\u002Fisraynotarray.com\u002Fhexo\u002F20201005\u002F1370103497\u002F",[741],"nofollow","(22) Learning Hexo - SEO - URL impact on SEO (article in Mandarin)",[12,744,745,746,749,750,533],{},"When you type ",[42,747,748],{},"https:\u002F\u002Fisraynotarray.com\u002Flinks\u002F",", you enter my \"more info\" links page. That route is ",[42,751,752],{},"\u002Flinks",[12,754,755],{},"Our website returns content based on the route the user inputs. The URL path directs the user's request to the correct handler function, which returns different content based on our needs.",[12,757,758],{},"Of course this is just a simple example. Routing is widely used in practice — for example:",[760,761,762,768,774,784],"ul",{},[763,764,765,767],"li",{},[42,766,711],{},": homepage",[763,769,770,773],{},[42,771,772],{},"https:\u002F\u002Fisraynotarray.com\u002Fposts\u002F",": article list",[763,775,776,779,780,783],{},[42,777,778],{},"https:\u002F\u002Fisraynotarray.com\u002Fposts\u002F:id",": article content, where ",[42,781,782],{},":id"," is the article ID — also called dynamic routing",[763,785,786,789,790,793],{},[42,787,788],{},"https:\u002F\u002Fisraynotarray.com\u002Fsearch?keyword=Express",": search page, where ",[42,791,792],{},"?keyword=Express"," is the search keyword — called a query string",[12,795,796],{},"I'm sure you've got the concept of routing now. Let's go back to our Express.js example.",[12,798,799],{},"We wrote a simple routing example earlier:",[35,801,803],{"className":37,"code":802,"language":39,"meta":40,"style":40},"\u002F\u002F...other code omitted\n\napp.get('\u002Ftodos', (req, res) => {\n  \u002F\u002F...other code omitted\n});\n\napp.post('\u002Ftodos', (req, res) => {\n  \u002F\u002F...other code omitted\n});\n\n\u002F\u002F...other code omitted\n",[42,804,805,810,814,838,843,847,851,875,879,883,887],{"__ignoreMap":40},[45,806,807],{"class":47,"line":48},[45,808,809],{"class":435},"\u002F\u002F...other code omitted\n",[45,811,812],{"class":47,"line":77},[45,813,112],{"emptyLine