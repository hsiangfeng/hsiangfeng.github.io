ark-high-contrast","const express = require('express');\nconst app = express();\nconst port = 3000;\n\nconst data = [];\n\napp.get('\u002Ftodos', (req, res) => {\n  res.send(data);\n});\n\napp.post('\u002Ftodos', (req, res) => {\n  const { title, completed } = req.body;\n\n  data.push({\n      id: new Date().getTime(),\n      title: cacheBody.title,\n      completed: cacheBody.completed,\n   });\n\n  res.send(data);\n});\n\napp.listen(3000)\n","js","",[42,43,44,75,90,106,113,126,131,167,179,185,190,216,242,247,259,280,286,292,298,303,312,317,322],"code",{"__ignoreMap":40},[45,46,49,53,57,60,64,68,72],"span",{"class":47,"line":48},"line",1,[45,50,52],{"class":51},"sWyjQ","const",[45,54,56],{"class":55},"sCcAr"," express",[45,58,59],{"class":51}," =",[45,61,63],{"class":62},"sj_SG"," require",[45,65,67],{"class":66},"sMAXC","(",[45,69,71],{"class":70},"sTRMh","'express'",[45,73,74],{"class":66},");\n",[45,76,78,80,83,85,87],{"class":47,"line":77},2,[45,79,52],{"class":51},[45,81,82],{"class":55}," app",[45,84,59],{"class":51},[45,86,56],{"class":62},[45,88,89],{"class":66},"();\n",[45,91,93,95,98,100,103],{"class":47,"line":92},3,[45,94,52],{"class":51},[45,96,97],{"class":55}," port",[45,99,59],{"class":51},[45,101,102],{"class":55}," 3000",[45,104,105],{"class":66},";\n",[45,107,109],{"class":47,"line":108},4,[45,110,112],{"emptyLinePlaceholder":111},true,"\n",[45,114,116,118,121,123],{"class":47,"line":115},5,[45,117,52],{"class":51},[45,119,120],{"class":55}," data",[45,122,59],{"class":51},[45,124,125],{"class":66}," [];\n",[45,127,129],{"class":47,"line":128},6,[45,130,112],{"emptyLinePlaceholder":111},[45,132,134,137,140,142,145,148,152,155,158,161,164],{"class":47,"line":133},7,[45,135,136],{"class":66},"app.",[45,138,139],{"class":62},"get",[45,141,67],{"class":66},[45,143,144],{"class":70},"'\u002Ftodos'",[45,146,147],{"class":66},", (",[45,149,151],{"class":150},"s_sBn","req",[45,153,154],{"class":66},", ",[45,156,157],{"class":150},"res",[45,159,160],{"cla