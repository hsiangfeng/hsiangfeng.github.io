,{"class":148},[44,916,153],{"class":152},[44,918,430],{"class":65},[44,920,433],{"class":152},[12,922,923],{},"Now we avoid the issue of accepting API requests before Mongoose successfully connects to MongoDB Atlas.",[20,925,927],{"id":926},"defining-a-schema","Defining a Schema",[12,929,930],{},"Before interacting with MongoDB (e.g., CRUD), we have to define a Schema so Mongoose knows what the data we're accessing looks like.",[34,932,934],{"className":130,"code":933,"language":132,"meta":39,"style":39},"const todoSchema = new mongoose.Schema({\n  id: Number,\n  title: String,\n  completed: Boolean,\n});\n",[41,935,936,955,960,965,970],{"__ignoreMap":39},[44,937,938,940,943,945,948,950,953],{"class":46,"line":47},[44,939,140],{"class":139},[44,941,942],{"class":65}," todoSchema",[44,944,145],{"class":139},[44,946,947],{"class":139}," new",[44,949,680],{"class":152},[44,951,952],{"class":148},"Schema",[44,954,354],{"class":152},[44,956,957],{"class":46,"line":162},[44,958,959],{"class":152},"  id: Number,\n",[44,961,962],{"class":46,"line":177},[44,963,964],{"class":152},"  title: String,\n",[44,966,967],{"class":46,"line":184},[44,968,969],{"class":152},"  completed: Boolean,\n",[44,971,972],{"class":46,"line":197},[44,973,280],{"class":152},[975,976,979],"callout",{"title":977,"type":978},"Note","note",[12,980,981],{},"CRUD stands for Create, Read, Update, Delete — what we commonly call \"create-read-update-delete\".",[12,983,984],{},"What's a Schema? Schema is a concept used to define MongoDB structure — it specifies data types, field names, default values, etc. So we know how to access data when we operate on it.",[12,986,987,988,990,991,993],{},"In the example above, we defined a todoSchema with two fields — ",[41,989,323],{}," and ",[41,992,328],{}," — typed as String and Boolean.",[12,995,996],{},"Anything outside these Schema properties gets ignored. So if we try to insert extra fields, they'll be ignored and won't be saved to the database.",[12,998,999],{},"Schema ensures data consistency and integrity.",[20,1001,1003],{"id":1002},"defining-a-model","Defining a Model",[12,1005,1006],{},"After defining a Schema, we build a Model. A Model usually maps to a specific Schema, and each Model maps to a collection in the database. So we use the Model to access database data.",[34,1008,1010],{"className":130,"code":1009,"language":132,"meta":39,"style":39},"const todoSchema = new mongoose.Schema({\n  id: Number,\n  title: String,\n  completed: Boolean,\n});\n\nconst Todo = mongoose.model('Todo', todoSchema);\n",[41,1011,1012,1028,1032,1036,1040,1044,1048],{"__ignoreMap":39},[44,1013,1014,1016,1018,1020,1022,1024,1026],{"class":46,"line":47},[44,1015,140],{"class":139},[44,1017,942],{"class":65},[44,1019,145],{"class":139},[44,1021,947],{"class":139},[44,1023,680],{"class":152},[44,1025,952],{"class":148},[44,1027,354],{"class":152},[44,1029,1030],{"class":46,"line":162},[44,1031,959],{"class":152},[44,1033,1034],{"class":46,"line":177},[44,1035,964],{"class":152},[44,1037,1038],{"class":46,"line":184},[44,1039,969],{"class":152},[44,1041,1042],{"class":46,"line":197},[44,1043,280],{"class":152},[44,1045,1046],{"class":46,"line":202},[44,1047,181],{"emptyLinePlaceholder":180},[44,1049,1050,1052,1055,1057,1059,1062,1064,1067],{"class":46,"line":207},[44,1051,140],{"class":139},[44,1053,1054],{"class":65}," Todo",[44,1056,145],{"class":139},[44,1058,680],{"class":152},[44,1060,1061],{"class":148},"model",[44,1063,153],{"class":152},[44,1065,1066],{"class":54},"'Todo'",[44,1068,1069],{"class":152},", todoSchema);\n",[12,1071,1072,1073,1076,1077,1079,1080,1082,1083,1085],{},"You can think of ",[41,1074,1075],{},"mongoose.model"," as the ",[41,1078,363],{}," instantiation concept — they're used similarly. The difference is ",[41,1081,1075],{}," builds a Model while ",[41,1084,363],{}," creates an instance.",[12,1087,1088],{},"With this Model, we can do CRUD operations on the database.",[20,1090,1092],{"id":1091},"accessing-the-data