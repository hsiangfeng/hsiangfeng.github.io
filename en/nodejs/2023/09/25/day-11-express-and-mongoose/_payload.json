,[44,919,432],{"class":152},[12,921,922],{},"Now we avoid the issue of accepting API requests before Mongoose successfully connects to MongoDB Atlas.",[20,924,926],{"id":925},"defining-a-schema","Defining a Schema",[12,928,929],{},"Before interacting with MongoDB (e.g., CRUD), we have to define a Schema so Mongoose knows what the data we're accessing looks like.",[34,931,933],{"className":130,"code":932,"language":132,"meta":39,"style":39},"const todoSchema = new mongoose.Schema({\n  id: Number,\n  title: String,\n  completed: Boolean,\n});\n",[41,934,935,954,959,964,969],{"__ignoreMap":39},[44,936,937,939,942,944,947,949,952],{"class":46,"line":47},[44,938,140],{"class":139},[44,940,941],{"class":65}," todoSchema",[44,943,145],{"class":139},[44,945,946],{"class":139}," new",[44,948,679],{"class":152},[44,950,951],{"class":148},"Schema",[44,953,353],{"class":152},[44,955,956],{"class":46,"line":162},[44,957,958],{"class":152},"  id: Number,\n",[44,960,961],{"class":46,"line":177},[44,962,963],{"class":152},"  title: String,\n",[44,965,966],{"class":46,"line":184},[44,967,968],{"class":152},"  completed: Boolean,\n",[44,970,971],{"class":46,"line":197},[44,972,279],{"class":152},[974,975,976],"blockquote",{},[12,977,978,982],{},[979,980,981],"strong",{},"Note","\nCRUD stands for Create, Read, Update, Delete — what we commonly call \"create-read-update-delete\".",[12,984,985],{},"What's a Schema? Schema is a concept used to define MongoDB structure — it specifies data types, field names, default values, etc. So we know how to access data when we operate on it.",[12,987,988,989,991,992,994],{},"In the example above, we defined a todoSchema with two fields — ",[41,990,322],{}," and ",[41,993,327],{}," — typed as String and Boolean.",[12,996,997],{},"Anything outside these Schema properties gets ignored. So if we try to insert extra fields, they'll be ignored and won't be saved to the database.",[12,999,1000],{},"Schema ensures data consistency and integrity.",[20,1002,1004],{"id":1003},"defining-a-model","Defining a Model",[12,1006,1007],{},"After defining a Schema, we build a Model. A Model usually maps to a specific Schema, and each Model maps to a collection in the database. So we use the Model to access database data.",[34,1009,1011],{"className":130,"code":1010,"language":132,"meta":39,"style":39},"const todoSchema = new mongoose.Schema({\n  id: Number,\n  title: String,\n  completed: Boolean,\n});\n\nconst Todo = mongoose.model('Todo', todoSchema);\n",[41,1012,1013,1029,1033,1037,1041,1045,1049],{"__ignoreMap":39},[44,1014,1015,1017,1019,1021,1023,1025,1027],{"class":46,"line":47},[44,1016,140],{"class":139},[44,1018,941],{"class":65},[44,1020,145],{"class":139},[44,1022,946],{"class":139},[44,1024,679],{"class":152},[44,1026,951],{"class":148},[44,1028,353],{"class":152},[44,1030,1031],{"class":46,"line":162},[44,1032,958],{"class":152},[44,1034,1035],{"class":46,"line":177},[44,1036,963],{"class":152},[44,1038,1039],{"class":46,"line":184},[44,1040,968],{"class":152},[44,1042,1043],{"class":46,"line":197},[44,1044,279],{"class":152},[44,1046,1047],{"class":46,"line":202},[44,1048,181],{"emptyLinePlaceholder":180},[44,1050,1051,1053,1056,1058,1060,1063,1065,1068],{"class":46,"line":207},[44,1052,140],{"class":139},[44,1054,1055],{"class":65}," Todo",[44,1057,145],{"class":139},[44,1059,679],{"class":152},[44,1061,1062],{"class":148},"model",[44,1064,153],{"class":152},[44,1066,1067],{"class":54},"'Todo'",[44,1069,1070],{"class":152},", todoSchema);\n",[12,1072,1073,1074,1077,1078,1080,1081,1083,1084,1086],{},"You can think of ",[41,1075,1076],{},"mongoose.model"," as the ",[41,1079,362],{}," instantiation concept — they're used similarly. The difference is ",[41,1082,1076],{}," builds a Model while ",[41,1085,362],{}," creates an instance.",[12,1088,1089],{},"With this Model, we can do CRUD operations on the database.",[20,1091,1093],{"id":1092},"accessing-the-database-and-writing-data","Accessing the database and writing d