and those requests need to operate on the database, errors will happen.",[12,597,598],{},"How do we solve this annoying problem? We can use the Middleware we learned earlier. We add a Middleware that checks whether connection is successful — if not, return an error message; if so, continue to the next Middleware.",[34,600,602],{"className":130,"code":601,"language":132,"meta":39,"style":39},"const express = require('express');\nconst mongoose = require('mongoose');\nconst app = express();\n\nasync function connectMongoDB () {\n  try {\n    await mongoose.connect('mongodb+srv:\u002F\u002Fexample:example@cluster0.zyfzacs.mongodb.net\u002F?retryWrites=true&w=majority')\n    console.log('Connected to MongoDB...')\n    connectStatus = true;\n  } catch (error) {\n    console.log(error)\n  }\n}\n\nconnectMongoDB()\n\n\u002F\u002F ...other code omitted\n\napp.use(express.json());\n\napp.use((req, res, next) => {\n  if (connectStatus) {\n    next();\n  } else {\n    res.status(503).send({\n      status: false,\n      message: 'Server is not ready'\n    });\n  }\n})\n\n\u002F\u002F ...other code omitted\n\napp.listen(3000)\n",[41,603,604,620,636,648,652,666,673,689,702,715,726,735,740,745,749,757,761,765,769,781,785,811,819,826,835,855,867,876,882,887,893,898,903,908],{"__ignoreMap":39},[44,605,606,608,610,612,614,616,618],{"class":46,"line":47},[44,607,140],{"class":139},[44,609,99],{"class":65},[44,611,145],{"class":139},[44,613,149],{"class":148},[44,615,153],{"class":152},[44,617,156],{"class":54},[44,619,159],{"class":152},[44,621,622,624,626,628,630,632,634],{"class":46,"line":162},[44,623,140],{"class":139},[44,625,464],{"class":65},[44,627,145],{"class":139},[44,629,149],{"class":148},[44,631,153],{"class":152},[44,633,473],{"class":54},[44,635,159],{"class":152},[44,637,638,640,642,644,646],{"class":46,"line":177},[44,639,140],{"class":139},[44,641,167],{"class":65},[44,643,145],{"class":139},[44,645,99],{"class":148},[44,647,174],{"class":152},[44,649,650],{"class":