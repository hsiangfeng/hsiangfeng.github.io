happen.",[12,596,597],{},"How do we solve this annoying problem? We can use the Middleware we learned earlier. We add a Middleware that checks whether connection is successful — if not, return an error message; if so, continue to the next Middleware.",[34,599,601],{"className":130,"code":600,"language":132,"meta":39,"style":39},"const express = require('express');\nconst mongoose = require('mongoose');\nconst app = express();\n\nasync function connectMongoDB () {\n  try {\n    await mongoose.connect('mongodb+srv:\u002F\u002Fexample:example@cluster0.zyfzacs.mongodb.net\u002F?retryWrites=true&w=majority')\n    console.log('Connected to MongoDB...')\n    connectStatus = true;\n  } catch (error) {\n    console.log(error)\n  }\n}\n\nconnectMongoDB()\n\n\u002F\u002F ...other code omitted\n\napp.use(express.json());\n\napp.use((req, res, next) => {\n  if (connectStatus) {\n    next();\n  } else {\n    res.status(503).send({\n      status: false,\n      message: 'Server is not ready'\n    });\n  }\n})\n\n\u002F\u002F ...other code omitted\n\napp.listen(3000)\n",[41,602,603,619,635,647,651,665,672,688,701,714,725,734,739,744,748,756,760,764,768,780,784,810,818,825,834,854,866,875,881,886,892,897,902,907],{"__ignoreMap":39},[44,604,605,607,609,611,613,615,617],{"class":46,"line":47},[44,606,140],{"class":139},[44,608,99],{"class":65},[44,610,145],{"class":139},[44,612,149],{"class":148},[44,614,153],{"class":152},[44,616,156],{"class":54},[44,618,159],{"class":152},[44,620,621,623,625,627,629,631,633],{"class":46,"line":162},[44,622,140],{"class":139},[44,624,463],{"class":65},[44,626,145],{"class":139},[44,628,149],{"class":148},[44,630,153],{"class":152},[44,632,472],{"class":54},[44,634,159],{"class":152},[44,636,637,639,641,643,645],{"class":46,"line":177},[44,638,140],{"class":139},[44,640,167],{"class":65},[44,642,145],{"class":139},[44,644,99],{"class":148},[44,646,174],{"class":152},[44,648,649],{"class":46,"line":184},[44,650,181],{"emptyLinePlaceholder":180},[44,652