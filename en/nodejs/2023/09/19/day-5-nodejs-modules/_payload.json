4],{"class":115},[91,1726,1727,1730,1732,1734,1736],{"class":93,"line":152},[91,1728,1729],{"class":115},"  console.",[91,1731,263],{"class":108},[91,1733,266],{"class":115},[91,1735,1266],{"class":387},[91,1737,391],{"class":115},[91,1739,1740,1742,1744,1746,1748],{"class":93,"line":158},[91,1741,1729],{"class":115},[91,1743,263],{"class":108},[91,1745,266],{"class":115},[91,1747,1279],{"class":387},[91,1749,1282],{"class":115},[91,1751,1752],{"class":93,"line":165},[91,1753,1754],{"class":115},"});\n",[91,1756,1757,1759,1761,1763,1765],{"class":93,"line":189},[91,1758,260],{"class":115},[91,1760,263],{"class":108},[91,1762,266],{"class":115},[91,1764,1293],{"class":387},[91,1766,391],{"class":115},[12,1768,1769],{},"Output:",[81,1771,1773],{"className":1301,"code":1772,"language":1303,"meta":86,"style":86},"Program starts\nProgram ends\nModule A starts loading\nModule A finished loading\nModule A is loaded\nMessage: Hello, World!\n",[88,1774,1775,1781,1787,1797,1807,1817],{"__ignoreMap":86},[91,1776,1777,1779],{"class":93,"line":94},[91,1778,1311],{"class":1310},[91,1780,1314],{"class":387},[91,1782,1783,1785],{"class":93,"line":101},[91,1784,1311],{"class":1310},[91,1786,1369],{"class":387},[91,1788,1789,1791,1793,1795],{"class":93,"line":137},[91,1790,1319],{"class":1310},[91,1792,1322],{"class":387},[91,1794,1325],{"class":387},[91,1796,1328],{"class":387},[91,1798,1799,1801,1803,1805],{"class":93,"line":152},[91,1800,1319],{"class":1310},[91,1802,1322],{"class":387},[91,1804,1337],{"class":387},[91,1806,1328],{"class":387},[91,1808,1809,1811,1813,1815],{"class":93,"line":158},[91,1810,1319],{"class":1310},[91,1812,1322],{"class":387},[91,1814,1348],{"class":387},[91,1816,1351],{"class":387},[91,1818,1819,1821,1823],{"class":93,"line":165},[91,1820,1356],{"class":1310},[91,1822,1359],{"class":387},[91,1824,1362],{"class":387},[12,1826,1827],{},"That's the power of ES Modules.",[67,1829,1830],{"title":69,"type":70},[12,1831,1832],{},"CommonJS is still more common in practice — it's Node.js's default module system after all.",[20,1834,1836],{"id":1835},"mjs-cjs-files",".mjs & .cjs files",[12,1838,1839,1840,1050,1843,1846],{},"Finally, an even more interesting thing — the ",[88,1841,1842],{},".mjs",[88,1844,1845],{},".cjs"," extensions.",[12,1848,1849,1850,1050,1852,1854,1855,1858,1859,1050,1861,1863],{},"OMG, what the heck are ",[88,1851,1842],{},[88,1853,1845],{},"? We all know ",[88,1856,1857],{},".js"," is for JavaScript files — so what are ",[88,1860,1842],{},[88,1862,1845],{},"?",[12,1865,1866],{},"Are they Meow JavaScript and Cat JavaScript?",[12,1868,1869],{},[15,1870],{"alt":1871,"src":1872},"Cat","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1690967014192.png",[12,1874,1875],{},"Of course not!",[12,1877,1878,1050,1880,1882],{},[88,1879,1842],{},[88,1881,1845],{}," officially stand for ECMAScript Modules and CommonJS Modules.",[67,1884,1885],{"title":69,"type":70},[12,1886,1887,1888,1890],{},"Some people jokingly call ",[88,1889,1842],{}," Michael Jackson Script — but that's just a joke, don't take it seriously.",[12,1892,1893,1894,1050,1896,1898,1899,1901,1902,1904,1905,1907],{},"How are ",[88,1895,1842],{},[88,1897,1845],{}," different from regular ",[88,1900,1857],{},"? As mentioned earlier, the main purpose is to clearly tell developers and Node.js which module system this file uses. So when you use ",[88,1903,1842],{},", Node.js knows you're using ES Modules; when you use ",[88,1906,1845],{},", Node.js knows you're using CommonJS.",[12,1909,1910,1911,1913,1914,1917,1918,1920,1921,1924,1925,1927],{},"So these extensions exist so developers can clearly know which module system a file uses, instead of having to check ",[88,1912,1398],{},"'s ",[88,1915,1916],{},"type",". Think about it — if we set ",[88,1919,1916],{}," to ",[88,1922,1923],{},"esm"," in Node.js, can you tell from a ",[88,1926,1857],{}," file whether it's ES Modules or CommonJS just by looking? That's where these extensions come in.",[12,1929,1930],{},"A quick summary:",[630,1932,1933,1946,1951],{},[633,1934,1935,1937,1938,1920,1940,1942,1943,1945],{},[88,1936,1857],{},": Node.js defaults to CommonJS, unless you set ",[88,1939,1916],{},[88,1941,987],{}," in ",[88,1944,1398],{},", which switches to ES Modules",[633,1947,1948,1950],{},[88,1949,1842],{},": explicitly tells Node.js this file uses ES Modules",[633,1952,1953,1955],{},[88,1954,1845],{},": explicitly tells Node.js this file uses CommonJS",[12,1957,1958,1959,1913,1961,990],{},"With this summary, you can quickly tell which module system a file uses without checking ",[88,1960,1398],{},[88,1962,1916],{},[12,1964,1965],{},"That's a wrap for this post, see you in the next one.",[20,1967,1969],{"id":1968},"random-thoughts","Random thoughts",[12,1971,1972],{},"To this day I still mainly use CommonJS — it's Node.js's default module system, and some frameworks still have issues when switching to ESM. So personally, I stick with CommonJS.",[1974,1975,1976],"style",{},"html pre.shiki code .sGBqm, html code.shiki .sGBqm{--shiki-light:#6A737D;--shiki-default:#6A737D;--shiki-dark:#BDC4CC}html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syBk-, html code.shiki .syBk-{--shiki-light:#E36209;--shiki-default:#E36209;--shiki-dark:#FFB757}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: v