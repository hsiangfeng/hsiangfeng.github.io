6,317],{"class":108},"multiply",[91,319,266],{"class":115},[91,321,275],{"class":274},[91,323,122],{"class":115},[91,325,280],{"class":274},[91,327,283],{"class":115},[12,329,330,331,334],{},"In the example above, each calculation method is wrapped in a function. But as features grow, our ",[88,332,333],{},"index.js"," gets bloated and hard to maintain. So we use modularity to extract calculation-related functions into their own module:",[81,336,338],{"className":83,"code":337,"language":85,"meta":86,"style":86},"\u002F\u002F index.js\nconst {\n  add,\n  subtract,\n  multiply,\n} = require('.\u002Fcalculator');\n\nconsole.log(add(1, 2));\nconsole.log(subtract(1, 2));\nconsole.log(multiply(1, 2));\n",[88,339,340,344,350,358,365,372,392,396,416,436],{"__ignoreMap":86},[91,341,342],{"class":93,"line":94},[91,343,98],{"class":97},[91,345,346,348],{"class":93,"line":101},[91,347,105],{"class":104},[91,349,134],{"class":115},[91,351,352,355],{"class":93,"line":137},[91,353,354],{"class":274},"  add",[91,356,357],{"class":115},",\n",[91,359,360,363],{"class":93,"line":152},[91,361,362],{"class":274},"  subtract",[91,364,357],{"class":115},[91,366,367,370],{"class":93,"line":158},[91,368,369],{"class":274},"  multiply",[91,371,357],{"class":115},[91,373,374,377,380,383,385,389],{"class":93,"line":165},[91,375,376],{"class":115},"} ",[91,378,379],{"class":104},"=",[91,381,382],{"class":108}," require",[91,384,266],{"class":115},[91,386,388],{"class":387},"sWayO","'.\u002Fcalculator'",[91,390,391],{"class":115},");\n",[91,393,394],{"class":93,"line":189},[91,395,162],{"emptyLinePlaceholder":161},[91,397,398,400,402,404,406,408,410,412,414],{"class":93,"line":201},[91,399,260],{"class":115},[91,401,263],{"class":108},[91,403,266],{"class":115},[91,405,269],{"class":108},[91,407,266],{"class":115},[91,409,275],{"class":274},[91,411,122],{"class":115},[91,413,280],{"class":274},[91,415,283],{"class":115},[91,417,418,420,422,424,426,428,430,432,434],{"class":93,"line":206},[91,41