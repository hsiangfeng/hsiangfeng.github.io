73,974],{"class":115},".a ",[91,976,379],{"class":104},[91,978,979],{"class":274}," 1",[91,981,982],{"class":115},";\n",[91,984,985,988,991,993,995,998,1000],{"class":93,"line":152},[91,986,987],{"class":274},"module",[91,989,990],{"class":115},".",[91,992,590],{"class":274},[91,994,112],{"class":104},[91,996,997],{"class":115}," { b: ",[91,999,280],{"class":274},[91,1001,1002],{"class":115}," };\n",[91,1004,1005],{"class":93,"line":158},[91,1006,162],{"emptyLinePlaceholder":161},[91,1008,1009],{"class":93,"line":165},[91,1010,1011],{"class":97},"\u002F\u002F app.js\n",[91,1013,1014,1016,1019,1021,1023,1025,1028],{"class":93,"line":189},[91,1015,105],{"class":104},[91,1017,1018],{"class":274}," moduleA",[91,1020,112],{"class":104},[91,1022,382],{"class":108},[91,1024,266],{"class":115},[91,1026,1027],{"class":387},"'.\u002FmoduleA'",[91,1029,391],{"class":115},[91,1031,1032,1034,1036,1039],{"class":93,"line":201},[91,1033,260],{"class":115},[91,1035,263],{"class":108},[91,1037,1038],{"class":115},"(moduleA); ",[91,1040,1041],{"class":97},"\u002F\u002F { b: 2 }\n",[12,1043,1044,1045,1047,1048,1050,1051,1053],{},"So you can have multiple ",[88,1046,590],{},", but ",[88,1049,669],{}," and ",[88,1052,590],{}," — pick one.",[12,1055,1056,1057,670,1060,1063,1064,1067],{},"When importing modules, watch the import method. If you're importing your own module, prefix with ",[88,1058,1059],{},".\u002F",[88,1061,1062],{},"..\u002F",". If you're importing a built-in module, no prefix needed (so-called relative vs absolute paths). Node.js assumes it's a third-party module (likely something installed via npm) and looks in ",[88,1065,1066],{},"node_modules",":",[81,1069,1071],{"className":83,"code":1070,"language":85,"meta":86,"style":86},"\u002F\u002F Import your own module\nconst moduleA = require('.\u002FmoduleA');\n\n\u002F\u002F Import built-in module\nconst fs = require('fs');\n\n\u002F\u002F Import third-party module\nconst _ = require('lodash');\n",[88,1072,1073,1078,1094,1098,1103,1121,1125,1130],{"__ignoreMap":86},[91,1074,1075],{"class":93,"line":94},[91,1076,1077],{"class":97},"\u002F\u002F Import your own module\n",[91,1079,1080,1082,1084,1086,1088,1090,1092],{"class":93,"line":101},[91,1081,105],{"class":104},[91,1083,1018],{"class":274},[91,1085,112],{"class":104},[91,1087,382],{"class":108},[91,1089,266],{"class":115},[91,1091,1027],{"class":387},[91,1093,391],{"class":115},[91,1095,1096],{"class":93,"line":137},[91,1097,162],{"emptyLinePlaceholder":161},[91,1099,1100],{"class":93,"line":152},[91,1101,1102],{"class":97},"\u002F\u002F Import built-in module\n",[91,1104,1105,1107,1110,1112,1114,1116,1119],{"class":93,"line":158},[91,1106,105],{"class":104},[91,1108,1109],{"class":274}," fs",[91,1111,112],{"class":104},[91,1113,382],{"class":108},[91,1115,266],{"class":115},[91,1117,1118],{"class":387},"'fs'",[91,1120,391],{"class":115},[91,1122,1123],{"class":93,"line":165},[91,1124,162],{"emptyLinePlaceholder":161},[91,1126,1127],{"class":93,"line":189},[91,1128,1129],{"class":97},"\u002F\u002F Import third-party module\n",[91,1131,1132,1134,1137,1139,1141,1143,1146],{"class":93,"line":201},[91,1133,105],{"class":104},[91,1135,1136],{"class":274}," _",[91,1138,112],{"class":104},[91,1140,382],{"class":108},[91,1142,266],{"class":115},[91,1144,1145],{"class":387},"'lodash'",[91,1147,391],{"class":115},[12,1149,1150],{},"When searching, Node.js looks in this order: \"custom module\", \"built-in module\", \"third-party module\".",[12,1152,1153,1154,670,1156,1158,1159,990],{},"If your imported module name starts with ",[88,1155,1059],{},[88,1157,1062],{},", Node.js treats it as a \"custom module\" and finds the file based on relative or absolute path. Without those prefixes, it assumes you're importing a \"built-in module\" or \"third-party module\" and searches ",[88,1160,1066],{},[12,1162,1163,1164,1168],{},"One more thing — CommonJS imports are ",[1165,1166,1167],"strong",{},"synchronous",". Meaning when you import a module, execution waits until the module is fully loaded before continuing. What does that look like? An example:",[81,1170,1172],{"className":83,"code":1171,"language":85,"meta":86,"style":86},"\u002F\u002F moduleA.js\nconsole.log('Module A starts loading');\nexports.message = 'Hello, World!';\nconsole.log('Module A finished loading');\n",[88,1173,1174,1178,1191,1205],{"__ignoreMap":86},[91,1175,1176],{"class":93,"line":94},[91,1177,962],{"class":97},[91,1179,1180,1182,1184,1186,1189],{"class":93,"line":101},[91,1181,260],{"class":115},[91,1183,263],{"class":108},[91,1185,266],{"class":115},[91,1187,1188],{"class":387},"'Module A starts loading'",[91,1190,391],{"class":115},[91,1192,1193,1195,1198,1200,1203],{"class":93,"line":137},[91,1194,590],{"class":274},[91,1196,1197],{"class":115},".message ",[91,1199,379],{"class":104},[91,1201,1202],{"class":387}," 'Hello, World!'",[91,1204,982],{"class":115},[91,1206,1207,1209,1211,1213,1216],{"class":93,"line":152},[91,1208,260],{"class":115},[91,1210,263],{"class":108},[91,1212,266],{"class":115},[91,1214,1215],{"class":387},"'Module A finished loading'",[91,1217,391],{"class":115},[81,1219,1221],{"className":83,"code":1220,"language":85,"meta":86,"style":86},"\u002F\u002F index.js\nconsole.log('Program starts');\nconst moduleA = require('.\u002FmoduleA');\nconsole.log('Module A is loaded');\nconsole.log('Message:', moduleA.message);\nconsole.log('Program ends');\n",[88,1222,1223,1227,1240,1256,1269,1283],{"__ignoreMap":86},[91,1224,1225],{"class":93,"line":94},[91,1226,98],{"class":97},[91,1228,1229,1231,1233,1235,1238],{"class":93,"line":101},[91,1230,260],{"class":115},[91,1232,263],{"class":108},[91,1234,266],{"class":115},[91,1236,1237],{"class":387},"'Program starts'",[91,1239,391],{"class":115},[91,1241,1242,1244,1246,1248,1250,1252,1254],{"class":93,"line":137},[91,1243,105],{"class":104},[91,1245,1018],{"class":274},[91,1247,112],{"class":104},[91,1249,382],{"class":108},[91,1251,266],{"class":115},[91,1253,1027],{"class":387},[91,1255,391],{"class":115},[91,1257,1258,1260,1262,1264,1267],{"class":93,"line":152},[91,1259,260],{"class":115},[91,1261,263],{"class":108},[91,1263,266],{"class":115},[91,1265,1266],{"class":387},"'Module A is loaded'",[91,1268,391],{"class":115},[91,1270,1271,1273,1275,1277,1280],{"class":93,"line":158},[91,1272,260],{"class":115},[91,1274,263],{"class":108},[91,1276,266],{"class":115},[91,1278,1279],{"class":387},"'Message:'",[91,1281,1282],{"class":115},", moduleA.message);\n",[91,1284,1285,1287,1289,1291,1294],{"class":93,"line":165},[91,1286,260],{"class":115},[91,1288,263],{"class":108},[91,1290,266],{"class":115},[91,1292,1293],{"class":387},"'Program ends'",[91,1295,391],{"class":115},[12,1297,1298],{},"You'll get this output:",[81,1300,1304],{"className":1301,"code":1302,"language":1303,"meta":86,"style":86},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","Program starts\nModule A starts loading\nModule A finished loading\nModule A is loaded\nMessage: Hello, World!\nProgram ends\n","bash",[88,1305,1306,1315,1329,1340,1352,1363],{"__ignoreMap":86},[91,1307,1308,1312],{"class":93,"line":94},[91,1309,1311],{"class":1310},"smYoP","Program",[91,1313,1314],{"class":387}," starts\n",[91,1316,1317,1320,1323,1326],{"class":93,"line":101},[91,1318,1319],{"class":1310},"Module",[91,1321,1322],{"class":387}," A",[91,1324,1325],{"class":387}," starts",[91,1327,1328],{"class":387}," loading\n",[91,1330,1331,1333,1335,1338],{"class":93,"line":137},[91,1332,1319],{"class":1310},[91,1334,1322],{"class":387},[91,1336,1337],{"class":387}," finished",[91,1339,1328],{"class":387},[91,1341,1342,1344,1346,1349],{"class":93,"line":152},[91,1343,1319],{"class":1310},[91,1345,1322],{"class":387},[91,1347,1348],{"class":387}," is",[91,1350,1351],{"class":387}," loaded\n",[91,1353,1354,1357,1360],{"class":93,"line":158},[91,1355,1356],{"class":1310},"Message:",[91,1358,1359],{"class":387}," Hello,",[91,1361,1362],{"class":387}," World!\n",[91,1364,1365,1367],{"class":93,"line":165},[91,1366,1311],{"class":1310},[91,1368,1369],{"class":387}," ends\n",[12,1371,1372],{},"In some cases, this synchronous import behavior causes problems with large modules — execution time gets longer. So with the arrival of ES Modules, async imports became a thing.",[67,1374,1375],{"title":69,"type":70},[12,1376,1377],{},"CommonJS was originally called ServerJS, proposed by Mozilla engineers, then renamed CommonJS — so CommonJS can also be called ServerJS. People proposed deprecating CommonJS as early as 2013, but it's still Node.js's default module system. ES Modules might replace it in the future.",[20,1379,1381],{"id":1380},"es-modules","ES Modules",[12,1383,1384,1385,1389],{},"I mentioned ES Modules is ECMAScript's module system. Since I've previously written about it, if you're curious I'd recommend reading my earlier post: ",[38,1386,1388],{"href":40,"rel":1387},[42],"What is ESM (ES6 Modules or JavaScript Modules)? (article in Mandarin)",". I won't deep-dive here.",[12,1391,1392],{},"But that doesn't mean I'll just skip over it. Let me talk about how to use ES Modules in Node.js.",[12,1394,1395,1396,1067],{},"To use ES Modules in Node.js, add this to your ",[88,1397,1398],{},"package.json",[81,1400,1404],{"className":1401,"code":1402,"language":1403,"meta":86,"style":86},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  \u002F\u002F ...other settings omitted\n  \"type\": \"module\",\n   \u002F\u002F ...other settings omitted\n}\n","json",[88,1405,1406,1411,1416,1430,1435],{"__ignoreMap":86},[91,1407,1408],{"class":93,"line":94},[91,1409,1410],{"class":115},"{\n",[91,1412,1413],{"class":93,"line":101},[91,1414,1415],{"class":97},"  \u002F\u002F ...other settings omitted\n",[91,1417,1418,1422,1425,1428],{"class":93,"line":137},[91,1419,1421],{"class":1420},"sWTrB","  \"type\"",[91,1423,1424],{"class":115},": ",[91,1426,1427],{"class":387},"\"module\"",[91,1429,357],{"class":115},[91,1431,1432],{"class":93,"line":152},[91,1433,1434],{"class":97},"   \u002F\u002F ...other settings omitted\n",[91,1436,1437],{"class":93,"line":158},[91,1438,1439],{"class":115},"}\n",[12,1441,1442],{},"This tells Node.js you want to use ES Modules instead of CommonJS. By default, Node.js uses CommonJS, so you have to tell it.",[12,1444,1445,1446,1448],{},"Here's the previous ",[88,1447,642],{}," rewritten as ES Modules:",[81,1450,1452],{"className":83,"code":1451,"language":85,"meta":86,"style":86},"\u002F\u002F calculator.js\nconst add = (a, b) => {\n  return a + b;\n};\n\nconst subtract = (a, b) => {\n  return a - b;\n};\n\nconst multiply = (a, b) => {\n  return a * b;\n};\n\nexport { add, subtract, multiply };\n",[88,1453,1454,1458,1480,1490,1494,1498,1520,1530,1534,1538,1560,1570,1574,1578],{"__ignoreMap":86},[91,1455,1456],{"class":93,"line":94},[91,1457,465],{"class":97},[91,1459,1460,1462,1464,1466,1468,1470,1472,1474,1476,1478],{"class":93,"line":101},[91,1461,105],{"class":104},[91,1463,109],{"class":108},[91,1465,112],{"class":104},[91,1467,116],{"class":115},[91,1469,38],{"class":119},[91,1471,122],{"class":115},[91,1473,125],{"class":119},[91,1475,128],{"class":115},[91,1477,131],{"class":104},[91,1479,134],{"class":115},[91,1481,1482,1484,1486,1488],{"class":93,"line":137},[91,1483,140],{"class":104},[91,1485,143],{"class":115},[91,1487,146],{"class":104},[91,1489,149],{"class":115},[91,1491,1492],{"class":93,"line":152},[91,1493,155],{"class":115},[91,1495,1496],{"class":93,"line":158},[91,1497,162],{"emptyLinePlaceholder":161},[91,1499,1500,1502,1504,1506,1508,1510,1512,1514,1516,1518],{"class":93,"line":165},[91,1501,105],{"class":104},[91,1503,170],{"class":108},[91,1505,112],{"class":104},[91,1507,116],{"class":115},[91,1509,38],{"class":119},[91,1511,122],{"class":115},[91,1513,125],{"class":119},[91,1515,128],{"class":115},[91,1517,131],{"class":104},[91,1519,134],{"class":115},[91,1521,1522,1524,1526,1528],{"class":93,"line":189},[91,