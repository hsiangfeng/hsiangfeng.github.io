48,49],{},"Store the data",[12,51,52],{},"Scraping is basically these three steps. We'll start with how to \"get the data\".",[12,54,55],{},"To start implementing, type these commands to set up the first project:",[57,58,63],"pre",{"className":59,"code":60,"language":61,"meta":62,"style":62},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir example-crawler\ncd example-crawler\nnpm init -y\ntouch index.js\n","bash","",[64,65,66,79,88,100],"code",{"__ignoreMap":62},[67,68,71,75],"span",{"class":69,"line":70},"line",1,[67,72,74],{"class":73},"s_sBn","mkdir",[67,76,78],{"class":77},"sTRMh"," example-crawler\n",[67,80,82,86],{"class":69,"line":81},2,[67,83,85],{"class":84},"sCcAr","cd",[67,87,78],{"class":77},[67,89,91,94,97],{"class":69,"line":90},3,[67,92,93],{"class":73},"npm",[67,95,96],{"class":77}," init",[67,98,99],{"class":84}," -y\n",[67,101,103,106],{"class":69,"line":102},4,[67,104,105],{"class":73},"touch",[67,107,108],{"class":77}," index.js\n",[12,110,111],{},"I won't repeat things like package.json — we're going straight to implementation.",[113,114,40],"h3",{"id":115},"analyze-the-source",[12,117,118],{},"Analyzing the source is easy — just know what site you want to scrape and what data you want. We're going straight to implementation, so I'll skip past this quickly.",[113,120,43],{"id":121},"get-the-data",[12,123,124],{},"There are many ways to get data. We can use HTTP Requests. What does that mean? Mimicking opening a browser and typing a URL — the browser sends an HTTP Request and gets data. That's one way.",[12,126,127,128,135],{},"How do we do this? You can use the ",[129,130,134],"a",{"href":131,"rel":132},"https:\u002F\u002Fgithub.com\u002Faxios\u002Faxios",[133],"nofollow","axios"," package. To use axios, install:",[57,137,139],{"className":59,"code":138,"language":61,"meta":62,"style":62},"npm i axios\n",[64,140,141],{"__ignoreMap":62},[67,142,143,145,148],{"class":69,"line":70},[67,144,93],{"class":73},[67,146,147],{"class":77}," i",[67,149,150],{"class":77}," axios\n",[12,152,153,154,156,157,162,163,165],{},"But I'm not using ",[64,155,134],{}," here, because Node.js has had built-in ",[129,158,161],{"href":159,"rel":160},"https:\u002F\u002Fnodejs.org\u002Fdist\u002Flatest-v18.x\u002Fdocs\u002Fapi\u002Fglobals.html#fetch",[133],"fetch"," since around v18. So we can use ",[64,164,161],{}," directly.",[167,168,169],"blockquote",{},[12,170,171,175,176,178,179,165],{},[172,173,174],"strong",{},"Note","\nFetch API was originally a browser-only method, but Node.js v18 added built-in ",[64,177,161],{}," support, so we can use ",[64,180,161],{},[12,182,183],{},"Who's our target? Let's use my blog as the example. My blog URL:",[57,185,187],{"className":59,"code":186,"language":61,"meta":62,"style":62},"https:\u002F\u002Fisraynotarray.com\u002F\n",[64,188,189],{"__ignoreMap":62},[67,190,191],{"class":69,"line":70},[67,192,186],{"class":73},[12,194,195],{},"Now let's write the example code:",[57,197,201],{"className":198,"code":199,"language":200,"meta":62,"style":62},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F index.js\nconst getData = async (url) => {\n  try {\n    const response = await fetch(url);\n    const data = await response.text();\n    console.log(data);\n    return data;\n  } catch (error) {\n    console.log(error);\n  }\n}\n\nconst html = getData('https:\u002F\u002Fisraynotarray.com\u002F');\n","js",[64,202,203,209,241,248,267,288,300,309,321,331,337,343,350],{"__ignoreMap":62},[67,204,205],{"class":69,"line":70},[67,206,208],{"class":207},"sQrFR","\u002F\u002F index.js\n",[67,210,211,215,219,222,225,229,232,235,238],{"class":69,"line":81},[67,212,214],{"class":213},"sWyjQ","const",[67,216,218],{"class":217},"sj_SG"," getData",[67,220,221],{"class":213}," =",[67,223,224],{"class":213}," async",[67,226,228],{"class":227},"sMAXC"," (",[67,230,231],{"class":73},"url",[67,233,234],{"class":227},") ",[67,236,237],{"class":213},"=>",[67,239,240],{"class":227},"