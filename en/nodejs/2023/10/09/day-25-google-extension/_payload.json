[{"data":1,"prerenderedAt":624},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F":599,"related:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F":608},"\u002Fnodejs\u002F20231009\u002F609773828\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":583,"date":584,"description":26,"extension":585,"lang":586,"meta":587,"navigation":588,"path":589,"readingMinutes":201,"seo":590,"standalone":591,"stem":592,"tags":593,"tldr":596,"updated":584,"url":597,"__hash__":598},"content\u002Fen\u002FNodejs\u002Fday-25-google-extension.md","Day 25 - Google Extension","3303082117",{"type":9,"value":10,"toc":576},"minimark",[11,19,24,27,31,34,37,43,46,52,55,58,61,64,68,71,103,106,126,129,155,158,162,165,168,171,319,330,333,484,487,492,495,501,510,513,518,521,526,529,532,545,548,555,559,562,569,572],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Google Extension","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_Google_Extension_e8da17f6-0589-4a56-a23c-69e58c66adb4.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"We're entering a new chapter — this one introduces Google Extension. What is it? Let's quickly get acquainted in this post.",[20,28,30],{"id":29},"chrome-extension","Chrome Extension",[12,32,33],{},"As the most-used browser, Chrome — you've definitely browsed its extension store, right? These extensions are what we call Chrome Extensions. Through them you can make your browser more powerful — ad blockers, translators, video downloaders, etc. — all written in JavaScript.",[12,35,36],{},"(Inner voice: unless you're an outlier like me using Firefox, most developers use Chrome QQ)",[12,38,39],{},[15,40],{"alt":41,"src":42},"Outlier","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1696435415522.png",[12,44,45],{},"Why do we want to learn Chrome Extension? Remember what I mentioned in the very first post?",[47,48,49],"blockquote",{},[12,50,51],{},"V8 is an open-source JavaScript engine developed by Google. It compiles JavaScript code into machine code so the computer can execute it.",[12,53,54],{},"So now the question is:",[12,56,57],{},"\"What's the relationship between Node.js and Chrome Extension?\"",[12,59,60],{},"In reality, the former is server-side JavaScript and the latter is browser-side JavaScript, but both use V8 to execute JavaScript. Still confused? Chrome Extensions run in the browser as JavaScript and use V8 to execute it. So you can think of Chrome Extension as a JavaScript program in the browser.",[12,62,63],{},"Let's get started with Chrome Extension!",[20,65,67],{"id":66},"prep-work","Prep work",[12,69,70],{},"First, set up the project environment:",[72,73,78],"pre",{"className":74,"code":75,"language":76,"meta":77,"style":77},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir example-chrome-extension\ncd example-chrome-extension\n","bash","",[79,80,81,94],"code",{"__ignoreMap":77},[82,83,86,90],"span",{"class":84,"line":85},"line",1,[82,87,89],{"class":88},"s_sBn","mkdir",[82,91,93],{"class":92},"sTRMh"," example-chrome-extension\n",[82,95,97,101],{"class":84,"line":96},2,[82,98,100],{"class":99},"sCcAr","cd",[82,102,93],{"class":92},[12,104,105],{},"Then create some files:",[72,107,109],{"className":74,"code":108,"language":76,"meta":77,"style":77},"touch manifest.json\ntouch popup.html\n",[79,110,111,119],{"__ignoreMap":77},[82,112,113,116],{"class":84,"line":85},[82,114,115],{"class":88},"touch",[82,117,118],{"class":92}," manifest.json\n",[82,120,121,123],{"class":84,"line":96},[82,122,115],{"class":88},[82,124,125],{"class":92}," popup.html\n",[12,127,128],{},"Your project should look like:",[72,130,132],{"className":74,"code":131,"language":76,"meta":77,"style":77},"- example-chrome-extension\n  - manifest.json\n  - popup.html\n",[79,133,134,141,148],{"__ignoreMap":77},[82,135,136,139],{"class":84,"line":85},[82,137,138],{"class":88},"-",[82,140,93],{"class":92},[82,142,143,146],{"class":84,"line":96},[82,144,145],{"class":88},"  -",[82,147,118],{"class":92},[82,149,151,153],{"class":84,"line":150},3,[82,152,145],{"class":88},[82,154,125],{"class":92},[12,156,157],{},"Don't worry about these files yet — we'll cover them later. Get the environment ready first.",[20,159,161],{"id":160},"your-first-chrome-extension","Your first Chrome Extension",[12,163,164],{},"First, let's introduce manifest.json — this file is really important and can be considered the core of the entire Chrome Extension. It tells the browser the extension's info — name, version, description, icon, permissions, etc. It must be in the root directory, not a subdirectory.",[12,166,167],{},"What goes in this file? Paste this:",[12,169,170],{},"(Don't worry, I'll add comments)",[72,172,176],{"className":173,"code":174,"language":175,"meta":77,"style":77},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \u002F\u002F Manifest version — current latest is 3\n  \"manifest_version\": 3,\n  \u002F\u002F Name — change to your liking\n  \"name\": \"Hello Extensions\",\n  \u002F\u002F Description\n  \"description\": \"Base Level Extension\",\n  \u002F\u002F Version\n  \"version\": \"1.0\",\n  \"action\": {\n    \u002F\u002F What HTML file runs when extension is clicked\n    \"default_popup\": \"popup.html\",\n    \u002F\u002F Icon shown in the browser toolbar\n    \"default_icon\": \"hello_extensions.png\"\n  }\n}\n","json",[79,177,178,184,190,205,211,224,230,243,249,262,271,277,290,296,307,313],{"__ignoreMap":77},[82,179,180],{"class":84,"line":85},[82,181,183],{"class":182},"sMAXC","{\n",[82,185,186],{"class":84,"line":96},[82,187,189],{"class":188},"sQrFR","  \u002F\u002F Manifest version — current latest is 3\n",[82,191,192,196,199,202],{"class":84,"line":150},[82,193,195],{"class":194},"sKpQp","  \"manifest_version\"",[82,197,198],{"class":182},": ",[82,200,201],{"class":99},"3",[82,203,204],{"class":182},",\n",[82,206,208],{"class":84,"line":207},4,[82,209,210],{"class":188},"  \u002F\u002F Name — change to your liking\n",[82,212,214,217,219,222],{"class":84,"line":213},5,[82,215,216],{"class":194},"  \"name\"",[82,218,198],{"class":182},[82,220,221],{"class":92},"\"Hello Extensions\"",[82,223,204],{"class":182},[82,225,227],{"class":84,"line":226},6,[82,228,229],{"class":188},"  \u002F\u002F Description\n",[82,231,233,236,238,241],{"class":84,"line":232},7,[82,234,235],{"class":194},"  \"description\"",[82,237,198],{"class":182},[82,239,240],{"class":92},"\"Base Level Extension\"",[82,242,204],{"class":182},[82,244,246],{"class":84,"line":245},8,[82,247,248],{"class":188},"  \u002F\u002F Version\n",[82,250,252,255,257,260],{"class":84,"line":251},9,[82,253,254],{"class":194},"  \"version\"",[82,256,198],{"class":182},[82,258,259],{"class":92},"\"1.0\"",[82,261,204],{"class":182},[82,263,265,268],{"class":84,"line":264},10,[82,266,267],{"class":194},"  \"action\"",[82,269,270],{"class":182},": {\n",[82,272,274],{"class":84,"line":273},11,[82,275,276],{"class":188},"    \u002F\u002F What HTML file runs when extension is clicked\n",[82,278,280,283,285,288],{"class":84,"line":279},12,[82,281,282],{"class":194},"    \"default_popup\"",[82,284,198],{"class":182},[82,286,287],{"class":92},"\"popup.html\"",[82,289,204],{"class":182},[82,291,293],{"class":84,"line":292},13,[82,294,295],{"class":188},"    \u002F\u002F Icon shown in the browser toolbar\n",[82,297,299,302,304],{"class":84,"line":298},14,[82,300,301],{"class":194},"    \"default_icon\"",[82,303,198],{"class":182},[82,305,306],{"class":92},"\"hello_extensions.png\"\n",[82,308,310],{"class":84,"line":309},15,[82,311,312],{"class":182},"  }\n",[82,314,316],{"class":84,"line":315},16,[82,317,318],{"class":182},"}\n",[12,320,321,322,329],{},"What about the icon? You can use the icon Google officially provides — download ",[323,324,328],"a",{"href":325,"rel":326},"https:\u002F\u002Fstorage.googleapis.com\u002Fweb-dev-uploads\u002Fimage\u002FWlD8wC6g8khYWPJUsQceQkhXSlv1\u002FgmKIT88Ha1z8VBMJFOOH.png",[327],"nofollow","Google's official icon"," and put it in the root directory.",[12,331,332],{},"Open popup.html and paste:",[72,334,338],{"className":335,"code":336,"language":337,"meta":77,"style":77},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>Hello Extension\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>Hello Extension\u003C\u002Fh1>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html",[79,339,340,354,372,381,399,423,437,446,455,468,476],{"__ignoreMap":77},[82,341,342,345,348,351],{"class":84,"line":85},[82,343,344],{"class":182},"\u003C!",[82,346,347],{"class":194},"DOCTYPE",[82,349,350],{"class":99}," html",[82,352,353],{"class":182},">\n",[82,355,356,359,361,364,367,370],{"class":84,"line":96},[82,357,358],{"class":182},"\u003C",[82,360,337],{"class":194},[82,362,363],{"class":99}," lang",[82,365,366],{"class":182},"=",[82,368,369],{"class":92},"\"en\"",[82,371,353],{"class":182},[82,373,374,376,379],{"class":84,"line":150},[82,375,358],{"class":182},[82,377,378],{"class":194},"head",[82,380,353],{"class":182},[82,382,383,386,389,392,394,397],{"class":84,"line":207},[82,384,385],{"class":182},"  \u003C",[82,387,388],{"class":194},"meta",[82,390,391],{"class":99}," charset",[82,393,366],{"class":182},[82,395,396],{"class":92},"\"UTF-8\"",[82,398,353],{"class":182},[82,400,401,403,405,408,410,413,416,418,421],{"class":84,"line":213},[82,402,385],{"class":182},[82,404,388],{"class":194},[82,406,407],{"class":99}," name",[82,409,366],{"class":182},[82,411,412],{"class":92},"\"viewport\"",[82,414,415],{"class":99}," content",[82,417,366],{"class":182},[82,419,420],{"class":92},"\"width=device-width, initial-scale=1.0\"",[82,422,353],{"class":182},[82,424,425,427,430,433,435],{"class":84,"line":226},[82,426,385],{"class":182},[82,428,429],{"class":194},"title",[82,431,432],{"class":182},">Hello Extension\u003C\u002F",[82,434,429],{"class":194},[82,436,353],{"class":182},[82,438,439,442,444],{"class":84,"line":232},[82,440,441],{"class":182},"\u003C\u002F",[82,443,378],{"class":194},[82,445,353],{"class":182},[82,447,448,450,453],{"class":84,"line":245},[82,449,358],{"class":182},[82,451,452],{"class":194},"body",[82,454,353],{"class":182},[82,456,457,459,462,464,466],{"class":84,"line":251},[82,458,385],{"class":182},[82,460,461],{"class":194},"h1",[82,463,432],{"class":182},[82,465,461],{"class":194},[82,467,353],{"class":182},[82,469,470,472,474],{"class":84,"line":264},[82,471,441],{"class":182},[82,473,452],{"class":194},[82,475,353],{"class":182},[82,477,478,480,482],{"class":84,"line":273},[82,479,441],{"class":182},[82,481,337],{"class":194},[82,483,353],{"class":182},[12,485,486],{},"Open Chrome, find Extensions, enter the extensions page:",[12,488,489],{},[15,490],{"alt":30,"src":491},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension.png",[12,493,494],{},"Find \"Load unpacked\" at the top and select your project folder:",[12,496,497],{},[15,498],{"alt":499,"src":500},"Load unpacked","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension_2.png",[47,502,503],{},[12,504,505,509],{},[506,507,508],"strong",{},"Note","\nIf you can't find \"Load unpacked\", first confirm you've checked \"Developer mode\". If not, check it.",[12,511,512],{},"You should see your extension appear in the browser toolbar:",[12,514,515],{},[15,516],{"alt":30,"src":517},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension_3.png",[12,519,520],{},"You can see your package in the toolbar — try clicking it. Your popup.html will pop up.",[12,522,523],{},[15,524],{"alt":30,"src":525},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension_hello.png",[12,527,528],{},"Pretty easy right? That's your first Chrome Extension!",[12,530,531],{},"You should notice — Chrome Extensions are basically just HTML, CSS, JavaScript. So really easy for web devs to pick up.",[47,533,534],{},[12,535,536,538,539,544],{},[506,537,508],{},"\nFirefox's extension implementation differs slightly from Chrome Extension since their core engines differ. To develop Firefox extensions, see ",[323,540,543],{"href":541,"rel":542},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FMozilla\u002FAdd-ons\u002FWebExtensions",[327],"Firefox Extension",".",[12,546,547],{},"Basically any browser based on the V8 engine can use these — Edge (Chromium-based), Arc, etc. So you can develop a Chrome Extension and use it in other browsers too.",[47,549,550],{},[12,551,552,554],{},[506,553,508],{},"\nChromium is an open-source browser project also from Google. Chromium's core also uses V8, so they're complementary. Chrome is based on Chromium, and the newer Edge and Arc are also based on Chromium.",[20,556,558],{"id":557},"importing-external-packages","Importing external packages",[12,560,561],{},"If you want to use npm packages in Chrome Extension, you'll need bundling tools — Webpack, Parcel, etc. Chrome Extension itself is just plain CSS, HTML, JavaScript files. So to use npm packages, you bundle them into a single file via a bundler, then import into the Chrome Extension.",[47,563,564],{},[12,565,566,568],{},[506,567,508],{},"\nLooking at it differently — it's like running JavaScript on web pages. We use bundlers to bundle into a single file, then import into the page.",[12,570,571],{},"In the next post we'll cover how to use a bundler to bundle Chrome Extensions.",[573,574,575],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}",{"title":77,"searchDepth":96,"depth":96,"links":577},[578,579,580,581,582],{"id":22,"depth":96,"text":23},{"id":29,"depth":96,"text":30},{"id":66,"depth":96,"text":67},{"id":160,"depth":96,"text":161},{"id":557,"depth":96,"text":558},"Nodejs","2023-10-09 00:00:01","md","en",{},true,"\u002Fen\u002Fnodejs\u002Fday-25-google-extension",{"title":6,"description":26},false,"en\u002FNodejs\u002Fday-25-google-extension",[594,595],"Node.js","Node.js 30 Days Series",null,"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F","JNbAPf-Azr3mqTSTJV2RlvbCd_096tvD3rdF41vRIXU",{"newer":600,"older":604},{"url":601,"title":602,"date":603},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F10\u002Fday-26-google-extension-with-vite\u002F","Day 26 - Google Extension with Vite","2023-10-10 00:00:01",{"url":605,"title":606,"date":607},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F08\u002Fday-24-deploying-to-zeabur\u002F","Day 24 - Deploying to Zeabur","2023-10-08 00:00:01",[609,614,619],{"url":610,"title":611,"date":612,"readingMinutes":613},"\u002Fen\u002Fnodejs\u002F2026\u002F01\u002F13\u002Frun-multiple-commands-with-concurrently\u002F","Tired of Opening Multiple Terminals to Run Commands? Use Concurrently","2026-01-13 09:45:28","2",{"url":615,"title":616,"date":617,"readingMinutes":618},"\u002Fen\u002Fnodejs\u002F2025\u002F03\u002F13\u002Fhexschool-ecommerce-api-complete-tutorial\u002F","Hexschool Capstone Class Study Group: Complete E-commerce API Tutorial","2025-03-13 09:13:26","9",{"url":620,"title":621,"date":622,"readingMinutes":623},"\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F","PM2 Is Process Manager, Not PM2.5","2024-12-25 10:31:33","5",1784011708245]