1017,"meta":102,"style":102},"language-bash shiki shiki-themes github-dark-high-contrast","npm install jsonwebtoken\n","bash",[104,1019,1020],{"__ignoreMap":102},[107,1021,1022,1025,1028],{"class":109,"line":110},[107,1023,1024],{"class":636},"npm",[107,1026,1027],{"class":231}," install",[107,1029,1030],{"class":231}," jsonwebtoken\n",[12,1032,1033],{},"Usage is also simple:",[97,1035,1037],{"className":410,"code":1036,"language":412,"meta":102,"style":102},"const jwt = require('jsonwebtoken');\n\nconst token = jwt.sign({\n  username,\n  email: 'example.com',\n}, 'secret', { expiresIn: 60 });\n\nconsole.log(token); \u002F\u002F Prints JWT Token\n",[104,1038,1039,1058,1062,1080,1085,1095,1112,1116],{"__ignoreMap":102},[107,1040,1041,1043,1046,1048,1051,1053,1056],{"class":109,"line":110},[107,1042,624],{"class":434},[107,1044,1045],{"class":265}," jwt",[107,1047,630],{"class":434},[107,1049,1050],{"class":419}," require",[107,1052,663],{"class":218},[107,1054,1055],{"class":231},"'jsonwebtoken'",[107,1057,693],{"class":218},[107,1059,1060],{"class":109,"line":140},[107,1061,699],{"emptyLinePlaceholder":698},[107,1063,1064,1066,1069,1071,1074,1077],{"class":109,"line":146},[107,1065,624],{"class":434},[107,1067,1068],{"class":265}," token",[107,1070,630],{"class":434},[107,1072,1073],{"class":218}," jwt.",[107,1075,1076],{"class":419},"sign",[107,1078,1079],{"class":218},"({\n",[107,1081,1082],{"class":109,"line":257},[107,1083,1084],{"class":218},"  username,\n",[107,1086,1087,1090,1093],{"class":109,"line":272},[107,1088,1089],{"class":218},"  email: ",[107,1091,1092],{"class":231},"'example.com'",[107,1094,478],{"class":218},[107,1096,1097,1100,1103,1106,1109],{"class":109,"line":707},[107,1098,1099],{"class":218},"}, ",[107,1101,1102],{"class":231},"'secret'",[107,1104,1105],{"class":218},", { expiresIn: ",[107,1107,1108],{"class":265},"60",[107,1110,1111],{"class":218}," });\n",[107,1113,1114],{"class":109,"line":734},[107,1115,699],{"emptyLinePlaceholder":698},