{},"Then add this line before ",[64,260,251],{},":",[116,263,265],{"className":118,"code":264,"language":120,"meta":121,"style":121},"export NVM_AUTO_USE=true\n",[64,266,267],{"__ignoreMap":121},[125,268,269,272,275,277],{"class":127,"line":128},[125,270,271],{"class":169},"export",[125,273,274],{"class":166}," NVM_AUTO_USE",[125,276,170],{"class":169},[125,278,279],{"class":166},"true\n",[12,281,282],{},"So it ends up like:",[116,284,286],{"className":118,"code":285,"language":120,"meta":121,"style":121},"plugins=( \n  git\n  # other plugins...\n  zsh-autosuggestions\n  zsh-syntax-highlighting\n  zsh-nvm  \n)\n\n# Auto-switch nvm version\nexport NVM_AUTO_USE=true\n\nsource $ZSH\u002Foh-my-zsh.sh\n",[64,287,288,296,300,304,308,312,318,322,326,331,341,346],{"__ignoreMap":121},[125,289,290,292,294],{"class":127,"line":128},[125,291,155],{"class":166},[125,293,170],{"class":169},[125,295,173],{"class":166},[125,297,298],{"class":127,"line":176},[125,299,179],{"class":135},[125,301,302],{"class":127,"line":182},[125,303,186],{"class":185},[125,305,306],{"class":127,"line":189},[125,307,192],{"class":135},[125,309,310],{"class":127,"line":195},[125,311,198],{"class":135},[125,313,314,316],{"class":127,"line":201},[125,315,210],{"class":135},[125,317,213],{"class":166},[125,319,320],{"class":127,"line":207},[125,321,219],{"class":166},[125,323,324],{"class":127,"line":216},[125,325,226],{"emptyLinePlaceholder":225},[125,327,328],{"class":127,"line":222},[125,329,330],{"class":185},"# Auto-switch nvm version\n",[125,332,333,335,337,339],{"class":127,"line":229},[125,334,271],{"class":169},[125,336,274],{"class":166},[125,338,170],{"class":169},[125,340,279],{"class":166},[125,342,344],{"class":127,"line":343},11,[125,345,226],{"emptyLinePlaceholder":225},[125,347,349,351,353],{"class":127,"line":348},12,[125,350,233],{"class":232},[125,352,236],{"class":166},[125,354,239],{"class":135},[12,356,357],{},"Close the terminal and reopen.",[20,359,361],{"id":360},"create-a-nvmrc","Create a .nvmrc",[12,363,364],{},"At this point you might excitedly open your project and think...",[12,366,367],{},"\"Why isn't my terminal auto-switching Node.js based on the project?\"",[12,369,370,371,374],{},"Because you're missing one thing — ",[64,372,373],{},".nvmrc",".",[12,376,377],{},[15,378],{"alt":379,"src":380},"nvmrc","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnvm-auto-use\u002F%E6%88%AA%E5%9C%96%202023-10-24%2016.16.46.png",[12,382,383],{},"Create this file in your project root and put the version number you want:",[116,385,387],{"className":118,"code":386,"language":120,"meta":121,"style":121},"20.8.1\n",[64,388,389],{"__ignoreMap":121},[125,390,391],{"class":127,"line":128},[125,392,386],{"class":131},[241,394,395],{},[12,396,397,399,400,374],{},[246,398,248],{},"\nThe version number matches what you'd see with ",[64,401,402],{},"nvm install",[12,404,405],{},"Or via command:",[116,407,409],{"className":118,"code":408,"language":120,"meta":121,"style":121},"echo \"20.8.1\" > .nvmrc\n",[64,410,411],{"__ignoreMap":121},[125,412,413,416,419,422],{"class":127,"line":128},[125,414,415],{"class":232},"echo",[125,417,418],{"class":135}," \"20.8.1\"",[125,420,421],{"class":169}," >",[125,423,424],{"class":135}," .nvmrc\n",[12,426,427,428,374],{},"Now every time you open the terminal in this project, it auto-switches to ",[64,429,430],{},"20.8.1",[12,432,433],{},[15,434],{"alt":435,"src":436},"Auto-switch","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnvm-auto-use\u002F%E6%88%AA%E5%9C%96%202023-10-24%2016.16.39.png",[20,438,440],{"id":439},"powerlevel10k-warning","Powerlevel10k warning?",[12,442,443],{},"If you use Powerlevel10k, you'll see a warning:",[116,445,447],{"className":118,"code":446,"language":120,"meta":121,"style":121},"[WARNING]: Console output during zsh initialization detected.\n\nWhen using Powerlevel10k with instant prompt, console output during zsh\ninitialization may indicate issues.\n\nYou can:\n\n  - Recommended: Change ~\u002F.zshrc so that it does not perform console I\u002FO\n    after the instant prompt preamble. See the link below for details.\n\n    * You will not see this error message again.\n    * Zsh will start quickly and prompt will update smoothly.\n\n  - Suppress this warning either by running p10k configure or by manually\n    defining the following parameter:\n\n      typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet\n\n    * You will not see this error message again.\n    * Zsh will start quickly but prompt will jump down after initialization.\n\n  - Disable instant prompt either by running p10k configure or by manually\n    defining the following parameter:\n\n      typeset -g POWERLEVEL9K_INSTANT_PROMPT=off\n\n    * You will not see this error message again.\n    * Zsh will start slowly.\n\n  - Do nothing.\n\n    * You will see this error message every time you start zsh.\n    * Zsh will start quickly but prompt will jump down after initialization.\n\nFor details, see:\nhttps:\u002F\u002Fgithub.com\u002Fromkatv\u002Fpowerlevel10k\u002Fblob\u002Fmaster\u002FREADME.md#instant-prompt\n\n-- console output produced during zsh initialization follows --\n",[64,448,449,454,458,490,504,508,516,520,557,590,594,622,650,655,691,705,710,727,732,753,785,790,818,829,834,848,853,874,888,893,904,909,940,967,972,984,990,995],{"__ignoreMap":121},[125,450,451],{"class":127,"line":128},[125,452,453],{"class":166},"[WARNING]: Console output during zsh initialization detected.\n",[125,455,456],{"class":127,"line":176},[125,457,226],{"emptyLinePlaceholder":225},[125,459,460,463,466,469,472,475,478,481,484,487],{"class":127,"line":182},[125,461,462],{"class":131},"When",[125,464,465],{"class":135}," using",[125,467,468],{"class":135}," Powerlevel10k",[125,470,471],{"class":135}," with",[125,473,474],{"class":135}," instant",[125,476,477],{"class":135}," prompt,",[125,479,480],{"class":135}," console",[125,482,483],{"class":135}," output",[125,485,486],{