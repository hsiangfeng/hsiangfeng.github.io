\n  ## Declare nvmrc_path variable to store the .nvmrc file path\n  local nvmrc_path\n  ## Use nvm_find_nvmrc to locate the .nvmrc file\n  nvmrc_path=\"$(nvm_find_nvmrc)\"\n\n  ## If .nvmrc found\n  if [ -n \"$nvmrc_path\" ]; then\n    ## Declare nvmrc_node_version variable to store the Node.js version from .nvmrc\n    local nvmrc_node_version\n    ## Use nvm version to get the current Node.js version\n    nvmrc_node_version=$(nvm version \"$(cat \"${nvmrc_path}\")\")\n\n    ## If the .nvmrc version is N\u002FA, install it (nvm doesn't have this version)\n    if [ \"$nvmrc_node_version\" = \"N\u002FA\" ]; then\n      ## Install the specific Node.js version\n      nvm install\n    ## If the .nvmrc version differs from the current one, switch to it\n    elif [ \"$nvmrc_node_version\" != \"$(nvm version)\" ]; then\n      ## Switch to the .nvmrc version, silence output\n      nvm use > \u002Fdev\u002Fnull\n    fi\n  \n  ## If no .nvmrc found, check parent directory; if found and current version isn't default, switch to default\n  elif [ -n \"$(PWD=$OLDPWD nvm_find_nvmrc)\" ] && [ \"$(nvm version)\" != \"$(nvm version default)\" ]; then\n    ## Switch to default, silence output\n    nvm use default > \u002Fdev\u002Fnull\n  fi\n}\n\nadd-zsh-hook chpwd load-nvmrc\nload-nvmrc\n",[64,1508,1509,1513,1517,1521,1525,1530,1538,1542,1547,1553,1558,1564,1569,1581,1585,1590,1608,1613,1619,1624,1648,1652,1657,1677,1682,1688,1693,1717,1722,1733,1737,1741,1746,1786,1791,1804,1808,1812,1816,1825],{"__ignoreMap":121},[125,1510,1511],{"class":127,"line":128},[125,1512,1202],{"class":185},[125,1514,1515],{"class":127,"line":176},[125,1516,226],{"emptyLinePlaceholder":225},[125,1518,1519],{"class":127,"line":182},[125,1520,330],{"class":185},[125,1522,1523],{"class":127,"line":189},[125,1524,226],{"emptyLinePlaceholder":225},[125,1526,1527],{"class":127,"line":195},[125,1528,1529],{"class":185},"## Auto-load Zsh hook library\n",[125,1531,1532,1534,1536],{"class":127,"line":201},[125,1533,1