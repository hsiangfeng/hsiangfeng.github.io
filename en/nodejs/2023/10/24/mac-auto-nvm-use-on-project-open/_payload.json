up zsh and nvm. If you haven't, finish those first or you'll likely hit weird issues:",[35,36,37,47],"ul",{},[38,39,40],"li",{},[41,42,46],"a",{"href":43,"rel":44},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20200123\u002F1105303313\u002F",[45],"nofollow","Mac OS terminal beautification, all in one post (article in Mandarin)",[38,48,49],{},[41,50,52],{"href":51},"\u002Fen\u002Fnodejs\u002F2020\u002F01\u002F24\u002Finstall-nvm-on-mac-os-x\u002F","Installing nvm on Mac OS X",[12,54,55],{},"If you've got nvm installed and zsh (oh-my-zsh) configured, you're good to continue.",[20,57,59],{"id":58},"installing-zsh-nvm","Installing zsh-nvm",[12,61,62,63,67,68,71,72,75,76,79,80,83],{},"As I mentioned, each project uses a different Node.js version, and your ",[64,65,66],"code",{},"nvm"," default might also differ. For example, your project needs ",[64,69,70],{},"18.17.0"," but nvm defaults to ",[64,73,74],{},"16.15.0"," — easy to forget ",[64,77,78],{},"nvm use 18.17.0",". ",[64,81,82],{},"zsh-nvm"," handles the switching for us.",[12,85,86,87,91],{},"The ",[41,88,82],{"href":89,"rel":90},"https:\u002F\u002Fgithub.com\u002Flukechilds\u002Fzsh-nvm",[45]," docs list multiple install methods:",[35,93,94,97,100,103,106],{},[38,95,96],{},"antigen",[38,98,99],{},"zplug",[38,101,102],{},"zgen",[38,104,105],{},"manual",[38,107,108],{},"as an oh-my-zsh custom plugin",[12,110,111],{},"I'll go with \"As an Oh My ZSH! custom plugin\" since I'm using oh-my-zsh.",[12,113,114],{},"In the terminal, install zsh-nvm into oh-my-zsh's custom plugins folder:",[116,117,122],"pre",{"className":118,"code":119,"language":120,"meta":121,"style":121},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","git clone https:\u002F\u002Fgithub.com\u002Flukechilds\u002Fzsh-nvm ~\u002F.oh-my-zsh\u002Fcustom\u002Fplugins\u002Fzsh-nvm\n","bash","",[64,123,124],{"__ignoreMap":121},[125,126,129,133,137,140],"span",{"class":127,"line":128},"line",1,[125,130,132],{"class":131},"smYoP","git",[125,134,136],{"class":135},"sWayO"," clone",[125,138,139],{"class":135}," https:\u002F\u002Fgithub.com\u002Flukechilds\u002Fzsh-nvm",[125,141,142],{"class":135}," ~\u002F.oh-my-zsh\u002Fcustom\u002Fplugins\u002Fzsh-nvm\n",[12,144,145,146,149,150,152,153,156],{},"Open ",[64,147,148],{},"~\u002F.zshrc"," and add ",[64,151,82],{}," to the ",[64,154,155],{},"plugins"," array:",[116,158,160],{"className":118,"code":159,"language":120,"meta":121,"style":121},"plugins=( \n  git\n  # other plugins...\n  zsh-autosuggestions\n  zsh-syntax-highlighting\n  # Add this line\n  zsh-nvm  \n)\n\nsource $ZSH\u002Foh-my-zsh.sh\n",[64,161,162,174,180,187,193,199,205,214,220,227],{"__ignoreMap":121},[125,163,164,167,171],{"class":127,"line":128},[125,165,155],{"class":166},"s8XSl",[125,168,170],{"class":169},"sOudu","=",[125,172,173],{"class":166},"( \n",[125,175,177],{"class":127,"line":176},2,[125,178,179],{"class":135},"  git\n",[125,181,183],{"class":127,"line":182},3,[125,184,186],{"class":185},"sGBqm","  # other plugins...\n",[125,188,190],{"class":127,"line":189},4,[125,191,192],{"class":135},"  zsh-autosuggestions\n",[125,194,196],{"class":127,"line":195},5,[125,197,198],{"class":135},"  zsh-syntax-highlighting\n",[125,200,202],{"class":127,"line":201},6,[125,203,204],{"class":185},"  # Add this line\n",[125,206,208,211],{"class":127,"line":207},7,[125,209,210],{"class":135},"  zsh-nvm",[125,212,213],{"class":166},"  \n",[125,215,217],{"class":127,"line":216},8,[125,218,219],{"class":166},")\n",[125,221,223],{"class":127,"line":222},9,[125,224,226],{"emptyLinePlaceholder":225},true,"\n",[125,228,230,234,237],{"class":127,"line":229},10,[125,231,233],{"class":232},"stw71","source",[125,235,236],{"class":166}," $ZSH",[125,238,239],{"class":135},"\u002Foh-my-zsh.sh\n",[241,242,245],"callout",{"title":243,"type":244},"Note","note",[12,246,247,250,251,253],{},[64,248,249],{},"source $ZSH\u002Foh-my-zsh.sh"," has to come after ",[64,252,155],{},", or things break.",[12,255,256,257,259],{},"Then add this line before ",[64,258,249],{},":",[116,261,263],{"className":118,"code":262,"language":120,"meta":121,"style":121},"export NVM_AUTO_USE=true\n",[64,264,265],{"__ignoreMap":121},[125,266,267,270,273,275],{"class":127,"line":128},[125,268,269],{"class":169},"export",[125,271,272],{"class":166}," NVM_AUTO_USE",[125,274,170],{"class":169},[125,276,277],{"class":166},"true\n",[12,279,280],{},"So it ends up like:",[116,282,284],{"className":118,"code":283,"language":120,"meta":121,"style":121},"plugins=( \n  git\n  # other plugins...\n  zsh-autosuggestions\n  zsh-syntax-highlighting\n  zsh-nvm  \n)\n\n# Auto-switch nvm version\nexport NVM_AUTO_USE=true\n\nsource $ZSH\u002Foh-my-zsh.sh\n",[64,285,286,294,298,302,306,310,316,320,324,329,339,344],{"__ignoreMap":121},[125,287,288,290,292],{"class":127,"line":128},[125,289,155],{"class":166},[125,291,170],{"class":169},[125,293,173],{"class":166},[125,295,296],{"class":127,"line":176},[125,297,179],{"class":135},[125,299,300],{"class":127,"line":182},[125,301,186],{"class":185},[125,303,304],{"class":127,"line":189},[125,305,192],{"class":135},[125,307,308],{"class":127,"line":195},[125,309,198],{"class":135},[125,311,312,314],{"class":127,"line":201},[125,313,210],{"class":135},[125,315,213],{"class":166},[125,317,318],{"class":127,"line":207},[125,319,219],{"class":166},[125,321,322],{"class":127,"line":216},[125,323,226],{"emptyLinePlaceholder":225},[125,325,326],{"class":127,"line":222},[125,327,328],{"class":185},"# Auto-switch nvm version\n",[125,330,331,333,335,337],{"class":127,"line":229},[125,332,269],{"class":169},[125,334,272],{"class":166},[125,336,170],{"class":169},[125,338,277],{"class":166},[125,340,342],{"class":127,"line":341},11,[125,343,226],{"emptyLinePlaceholder":225},[125,345,347,349,351],{"class":127,"line":346},12,[125,348,233],{"class":232},[125,350,236],{"class":166},[125,352,239],{"class":135},[12,354,355],{},"Close the terminal and reopen.",[20,357,359],{"id":358},"create-a-nvmrc","Create a .nvmrc",[12,361,362],{},"At this point you might excitedly open your project and think...",[12,364,365],{},"\"Why isn't my terminal auto-switching Node.js based on the project?\"",[12,367,368,369,372],{},"Because you're missing one thing — ",[64,370,371],{},".nvmrc",".",[12,374,375],{},[15,376],{"alt":377,"src":378},"nvmrc","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnvm-auto-use\u002F%E6%88%AA%E5%9C%96%202023-10-24%2016.16.46.png",[12,380,381],{},"Create this file in your project root and put the version number you want:",[116,383,385],{"className":118,"code":384,"language":120,"meta":121,"style":121},"20.8.1\n",[64,386,387],{"__ignoreMap":121},[125,388,389],{"class":127,"line":128},[125,390,384],{"class":131},[241,392,393],{"title":243,"type":244},[12,394,395,396,372],{},"The version number matches what you'd see with ",[64,397,398],{},"nvm install",[12,400,401],{},"Or via command:",[116,403,405],{"className":118,"code":404,"language":120,"meta":121,"style":121},"echo \"20.8.1\" > .nvmrc\n",[64,406,407],{"__ignoreMap":121},[125,408,409,412,415,418],{"class":127,"line":128},[125,410,411],{"class":232},"echo",[125,413,414],{"class":135}," \"20.8.1\"",[125,416,417],{"class":169}," >",[125,419,420],{"class":135}," .nvmrc\n",[12,422,423,424,372],{},"Now every time you open the terminal in this project, it auto-switches to ",[64,425,426],{},"20.8.1",[12,428,429],{},[15,430],{"alt":431,"src":432},"Auto-switch","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnvm-auto-use\u002F%E6%88%AA%E5%9C%96%202023-10-24%2016.16.39.png",[20,434,436],{"id":435},"powerlevel10k-warning","Powerlevel10k warning?",[12,438,439],{},"If you use Powerlevel10k, you'll see a warning:",[116,441,443],{"className":118,"code":442,"language":120,"meta":121,"style":121},"[WARNING]: Console output during zsh initialization detected.\n\nWhen using Powerlevel10k with instant prompt, console output during zsh\ninitialization may indicate issues.\n\nYou can:\n\n  - Recommended: Change ~\u002F.zshrc so that it does not perform console I\u002FO\n    after the instant prompt preamble. See the link below for details.\n\n    * You will not see this error message again.\n    * Zsh will start quickly and prompt will update smoothly.\n\n  - Suppress this warning either by running p10k configure or by manually\n    defining the following parameter:\n\n      typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet\n\n    * You will not see this error message again.\n    * Zsh will start quickly but prompt will jump down after initialization.\n\n  - Disable instant prompt either by running p10k configure or by manually\n    defining the following parameter:\n\n      typeset -g POWERLEVEL9K_INSTANT_PROMPT=off\n\n    * You will not see this error message again.\n    * Zsh will start slowly.\n\n  - Do nothing.\n\n    * You will see this error message every time you start zsh.\n    * Zsh will start quickly but prompt will jump down after initialization.\n\nFor details, see:\nhttps:\u002F\u002Fgithub.com\u002Fromkatv\u002Fpowerlevel10k\u002Fblob\u002Fmaster\u002FREADME.md#instant-prompt\n\n-- console output produced during zsh initialization follows --\n",[64,444,445,450,454,486,500,504,512,516,553,586,590,618,646,651,687,701,706,723,728,749,781,786,814,825,830,844,849,870,884,889,900,905,936,963,968,980,986,991],{"__ignoreMap":121},[125,446,447],{"class":127,"line":128},[125,448,449],{"class":166},"[WARNING]: Console output during zsh initialization detected.\n",[125,451,452],{"class":127,"line":176},[125,453,226],{"emptyLinePlaceholder":225},[125,455,456,459,462,465,468,471,474,477,480,483],{"class":127,"line":182},[125,457,458],{"class":131},"When",[125,460,461],{"class":135}," using",[125,463,464],{"class":135}," Powerlevel10k",[125,466,467],{"class":135}," with",[125,469,470],{"class":135}," instant",[125,472,473],{"class":135}," prompt,",[125,475,476],{"class":135}," console",[125,478,479],{"class":135}," ou