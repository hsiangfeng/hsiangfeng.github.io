  dangerouslyAllowBrowser: true  \u002F\u002F Allow browser use\n  });\n\n  \u002F\u002F Run OpenAI\n  const completion = await openai.chat.completions.create({\n    \u002F\u002F Input message\n    messages: [{\n      role: 'user', \u002F\u002F User\n      content: 'Say this is a test' \u002F\u002F Input message\n    }],\n    model: 'gpt-3.5-turbo', \u002F\u002F Use gpt-3.5-turbo model\n  });\n\n  \u002F\u002F Output result\n  console.log(completion.choices[0]);\n}\n\n\u002F\u002F Trigger when page loads\nonMounted(main);\n\u003C\u002Fscript>\n",[42,1685,1686,1696,1706,1716,1728,1732,1737,1777,1782,1802,1807,1815,1819,1823,1827,1837,1841,1862,1866,1871,1885,1893,1903,1907,1912,1918,1935,1941,1947,1960,1971,1977,1989,1994,1999,2005,2021,2026,2031,2037,2045],{"__ignoreMap":40},[45,1687,1688,1690,1692,1694],{"class":47,"line":48},[45,1689,641],{"class":225},[45,1691,644],{"class":366},[45,1693,647],{"class":65},[45,1695,650],{"class":225},[45,1697,1698,1700,1702,1704],{"class":47,"line":112},[45,1699,222],{"class":221},[45,1701,657],{"class":225},[45,1703,229],{"class":221},[45,1705,662],{"class":55},[45,1707,1708,1710,1712,1714],{"class":47,"line":130},[45,1709,222],{"class":221},[45,1711,669],{"class":225},[45,1713,229],{"class":221},[45,1715,674],{"class":55},[45,1717,1718,1720,1722,1724,1726],{"class":47,"line":150},[45,1719,222],{"class":221},[45,1721,681],{"class":225},[45,1723,229],{"class":221},[45,1725,686],{"class":55},[45,1727,689],{"class":225},[45,1729,1730],{"class":47,"line":271},[45,1731,275],{"emptyLinePlaceholder":274},[45,1733,1734],{"class":47,"line":278},[45,1735,1736],{"class":286},"\u002F\u002F Wrap as Promise\n",[45,1738,1739,1741,1744,1746,1748,1751,1753,1755,1757,1760,1763,1766,1768,1771,1773,1775],{"class":47,"line":283},[45,1740,698],{"class":221},[45,1742,1743],{"class":299}," getChromeToken",[45,1745,704],{"class":221},[45,1747,1252],{"class":225},[45,1749,1750],{"class":51},"key",[45,1752,1258],{"class":225},[45,1754,850],{"class":221},[4