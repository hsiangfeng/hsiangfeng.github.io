de":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F index.js\nconst { Client, Intents } = require('discord.js');\n\u002F\u002F Instantiate Client\nconst client = new Client({\n  intents: [\n    Intents.FLAGS.GUILDS\n  ]\n});\n\n\u002F\u002F When bot is ready\nclient.once('ready', () => {\n  console.log('Ready!');\n});\n\n\u002F\u002F Login\nclient.login(TOKEN);\n","js","",[45,46,47,56,97,103,123,129,144,150,156,163,169,192,208,213,218,224],"code",{"__ignoreMap":43},[48,49,52],"span",{"class":50,"line":51},"line",1,[48,53,55],{"class":54},"sQrFR","\u002F\u002F index.js\n",[48,57,59,63,67,71,74,77,80,83,87,90,94],{"class":50,"line":58},2,[48,60,62],{"class":61},"sWyjQ","const",[48,64,66],{"class":65},"sMAXC"," { ",[48,68,70],{"class":69},"sCcAr","Client",[48,72,73],{"class":65},", ",[48,75,76],{"class":69},"Intents",[48,78,79],{"class":65}," } ",[48,81,82],{"class":61},"=",[48,84,86],{"class":85},"sj_SG"," require",[48,88,89],{"class":65},"(",[48,91,93],{"class":92},"sTRMh","'discord.js'",[48,95,96],{"class":65},");\n",[48,98,100],{"class":50,"line":99},3,[48,101,102],{"class":54},"\u002F\u002F Instantiate Client\n",[48,104,106,108,111,114,117,120],{"class":50,"line":105},4,[48,107,62],{"class":61},[48,109,110],{"class":69}," client",[48,112,113],{"class":61}," =",[48,115,116],{"class":61}," new",[48,118,119],{"class":85}," Client",[48,121,122],{"class":65},"({\n",[48,124,126],{"class":50,"line":125},5,[48,127,128],{"class":65},"  intents: [\n",[48,130,132,135,138,141],{"class":50,"line":131},6,[48,133,134],{"class":65},"    Intents.",[48,136,137],{"class":69},"FLAGS",[48,139,140],{"class":65},".",[48,142,143],{"class":69},"GUILDS\n",[48,145,147],{"class":50,"line":146},7,[48,148,149],{"class":65},"  ]\n",[48,151,153],{"class":50,"line":152},8,[48,154,155],{"class":65},"});\n",[48,157,159],{"class":50,"line":158},9,[48,160,162],{"emptyLinePlaceholder":161},true,"\n",[48,164,166],{"class":50,"line":165},10,[48,167,168],{"class":54},"\u002F\u002F When bot is ready\n",[48,170,172,175,178,180,183,186,189],{"class":50,"line":171},11,[48,173,174],{"class":65},"client.",[48,176,177],{"class":85},"once",[48,179,89],{"class":65},[48,181,182],{"class":92},"'ready'",[48,184,185],{"class":65},", () ",[48,187,188],{"class":61},"=>",[48,190,191],{"class":65}," {\n",[48,193,195,198,201,203,206],{"class":50,"line":194},12,[48,196,197],{"class":65},"  console.",[48,199,200],{"class":85},"log",[48,202,89],{"class":65},[48,204,205],{"class":92},"'Ready!'",[48,207,96],{"class":65},[48,209,211],{"class":50,"line":210},13,[48,212,155],{"class":65},[48,214,216],{"class":50,"line":215},14,[48,217,162],{"emptyLinePlaceholder":161},[48,219,221],{"class":50,"line":220},15,[48,222,223],{"class":54},"\u002F\u002F Login\n",[48,225,227,229,232,234,237],{"class":50,"line":226},16,[48,228,174],{"class":65},[48,230,231],{"class":85},"login",[48,233,89],{"class":65},[48,235,236],{"class":69},"TOKEN",[48,238,96],{"class":65},[12,240,241,242,245],{},"Let's focus on the object inside ",[45,243,244],{},"const client = new Client({ ... })",":",[38,247,249],{"className":40,"code":248,"language":42,"meta":43,"style":43},"\u002F\u002F ... other code omitted\nconst client = new Client({\n  intents: [\n    Intents.FLAGS.GUILDS\n  ]\n});\n\u002F\u002F ... other code omitted\n",[45,250,251,256,270,274,284,288,292],{"__ignoreMap":43},[48,252,253],{"class":50,"line":51},[48,254,255],{"class":54},"\u002F\u002F ... other code omitted\n",[48,257,258,260,262,264,266,268],{"class":50,"line":58},[48,259,62],{"class":61},[48,261,110],{"class":69},[48,263,113],{"class":61},[48,265,116],{"class":61},[48,267,119],{"class":85},[48,269,122],{"class":65},[48,271,272],{"class":50,"line":99},[48,273,128],{"class":65},[48,275,276,278,280,282],{"class":50,"line":105},[48,277,134],{"class":65},[48,279,137],{"class":69},[48,281,140],{"class":65},[48,283,143],{"class":69},[48,285,286],{"class":50,"line":125},[48,287,149],{"class":65},[48,289,290],{"class":50,"line":131},[48,291,155],{"class":65},[48,293,294],{"class":50,"line":146},[48,295,255],{"class":54},[20,297,76],{"id":298},"intents",[12,300,301,303],{},[45,302,244],{}," creates a new Discord.js object. Think of it as a bridge to the Discord API, letting us operate Discord through code.",[12,305,306,307,309],{},"Inside it takes some parameters. Let's talk about ",[45,308,298],{}," first — this parameter is really important and affects what your bot can do.",[12,311,312,313,315],{},"So what's ",[45,314,298],{}," for? In short, it tells Discord what \"intents\" we have. For example, if our bot needs to receive server messages, we have to tell Discord we need server messages — so Discord knows to send them to our bot.",[12,317,318],{},"Here's example code I've previously written:",[38,320,322],{"className":40,"code":321,"language":42,"meta":43,"style":43},"const { Client, GatewayIntentBits } = require('discord.js');\n\nconst client = new Client({\n  intents: [\n    GatewayIntentBits.Guilds,\n    GatewayIntentBits.GuildMessages,\n    GatewayIntentBits.MessageContent,\n  ],\n});\n",[45,323,324,349,353,367,371,376,381,386,391],{"__ignoreMap":43},[48,325,326,328,330,332,334,337,339,341,343,345,347],{"class":50,"line":51},[48,327,62],{"class":61},[48,329,66],{"class":65},[48,331,70],{"class":69},[48,333,73],{"class":65},[48,335,336],{"class":69},"GatewayIntentBits",[48,338,79],{"class":65},[48,340,82],{"class":61},[48,342,86],{"class":85},[48,344,89],{"class":65},[48,346,93],{"class":92},[48,348,96],{"class":65},[48,350,351],{"class":50,"line":58},[48,352,162],{"emptyLinePlaceholder":161},[48,354,355,357,359,361,363,365],{"class":50,"line":99},[48,356,62],{"class":61},[48,358,110],{"class":69},[48,360,113],{"class":61},[48,362,116],{"class":61},[48,364,119],{"class":85},[48,366,122],{"class":65},[48,368,369],{"class":50,"line":105},[48,370,128],{"class":65},[48,372,373],{"class":50,"line":125},[48,374,375],{"class":65},"    GatewayIntentBits.Guilds,\n",[48,377,378],{"class":50,"line":131},[48,379,380],{"class":65},"    GatewayIntentBits.GuildMessages,\n",[48,382,383],{"class":50,"line":146},[48,384,385],{"class":65},"    GatewayIntentBits.MessageContent,\n",[48,387,388],{"class":50,"line":152},[48,389,390],{"class":65},"  ],\n",[48,392,393],{"class":50,"line":158},[48,394,155],{"class":65},[12,396,397,399],{},[45,398,298],{}," takes an array of three parameters here:",[401,402,403,410,416],"ul",{},[404,405,406,409],"li",{},[45,407,408],{},"GatewayIntentBits.Guilds",": receive server-related events — user joins server, user leaves server, etc.",[404,411,412,415],{},[45,413,414],{},"GatewayIntentBits.GuildMessages",": receive in-server message events — user sends message, user edits message, etc.",[404,417,418,421,422,424],{},[45,419,420],{},"GatewayIntentBits.MessageContent",": a special one — tells the bot we need to receive message content (the actual text of messages). This differs from ",[45,423,414],{},", which only tells us a user sent a message but not the content. So we have to also tell Discord we need the content.",[12,426,427],{},"There are more, like:",[401,429,430,436,442,448],{},[404,431,432,435],{},[45,433,434],{},"GatewayIntentBits.GuildMessageReactions",": receive in-server reaction events — user reacts to a message, user removes reaction, etc.",[404,437,438,441],{},[45,439,440],{},"GatewayIntentBits.DirectMessages",": receive DM events — user sends DM, user edits DM, etc.",[404,443,444,447],{},[45,445,446],{},"GatewayIntentBits.DirectMessageReactions",": receive DM reaction events — user reacts to DM, user removes reaction, etc.",[404,449,450,453],{},[45,451,452],{},"GatewayIntentBits.DirectMessageTyping",": receive DM typing events — user is typing, user stops typing, etc.",[12,455,456,457,140],{},"I'm only listing some — for the rest, see the ",[458,459,463],"a",{"href":460,"rel":461},"https:\u002F\u002Fdiscord.com\u002Fdevelopers\u002Fdocs\u002Ftopics\u002Fgateway#list-of-intents",[462],"nofollow","Discord.js official docs",[20,465,466],{"id":466},"partials",[12,468,469,471,472,245],{},[45,470,466],{}," is special — also passed when creating ",[45,473,474],{},"new Client",[38,476,478],{"className":40,"code":477,"language":42,"meta":43,"style":43},"const { Client, GatewayIntentBits, Partials } = require('discord.js');\nconst client = new Client({\n  intents: [\n    GatewayIntentBits.Guilds,\n    GatewayIntentBits.GuildMessages,\n    GatewayIntentBits.MessageContent,\n  ],\n  partials: [\n    Partials.Channel\n  ],\n});\n",[45,479,480,509,523,527,531,535,539,543,548,553,557],{"__ignoreMap":43},[48,481,482,484,486,488,490,492,494,497,499,501,503,505,507],{"class":50,"line":51},[48,483,62],{"class":61},[48,485,66],{"class":65},[48,487,70],{"class":69},[48,489,73],{"class":65},[48,491,336],{"class":69},[48,493,73],{"class":65},[48,495,496],{"class":69},"Partials",[48,498,79],{"class":65},[48,500,82],{"class":61},[48,502,86],{"class":85},[48,504,89],{"class":65},[48,506,93],{"class":92},[48,508,96],{"class":65},[48,510,511,513,515,517,519,521],{"class":50,"line":58},[48,512,62],{"class":61},[48,514,110],{"class":69},[48,516,113],{"class":61},[48,518,116],{"class":61},[48,520,119],{"class":85},[48,522,122],{"class":65},[48,524,525],{"class":50,"line":99},[48,526,128],{"class":65},[48,528,529],{"class":50,"line":105},[48,530,375],{"class":65},[48,532,533],{"class":50,"line":125},[48,534,380],{"class":65},[48,536,537],{"class":50,"line":131},[48,538,385],{"class":65},[48,540,541],{"class":50,"line":146},[48,542,390],{"class":65},[48,544,545],{"class":50,"line":152},[48,546,547],{"class":65},"  partials: [\n",[48,549,550],{"class":50,"line":158},[48,551,552],{"class":65},"    Partials.Channel\n",[48,554,555],{"class":50,"line":165},[48,556,390],{"class":65},[48,558,559],{"class":50,"line":171},[48,560,155],{"class":65},[12,562,563,565],{},[45,564,466],{}," tells Discord we need certain \"partial\" data — message content, message reactions, etc.",[12,567,568,569,571],{},"Why set this specifically? Because Discord splits some data into two parts — complete data and partial data. For example, message content can be split into complete message content and partial message content. Without setting ",[45,570,466],{},", we can't get the complete content — so we have to tell Discord we need the complete data.",[12,573,574,575,577],{},"OK with general ",[45,576,496],{}," understanding, let's continue. We'll discuss this more if needed.",[20,579,581],{"id":580},"discord-methods-and-events","Discord methods and events",[12,583,584],{},"Now let's talk about Discord methods and events. Let me cover methods first.",[12,586,587,588,590],{},"In our example code, after instantiating ",[45,589,70],{},", we did some things:",[38,592,594],{"className":40,"code":593,"language":42,"meta":43,"style":43},"\u002F\u002F index.js\nconst { Client, Intents } = require('discord.js');\nconst client = new Client({\n  \u002F\u002F ... other code omitted\n});\n\n\u002F\u002F When bot is ready\nclient.once('ready', () => {\n  \u002F\u002F ... other code omitted\n});\n\n\u002F\u002F Log in\nclient.login(TOKEN);\n",[45,595,596,600,624,638,643,647,651,655,671,675,679,683,688],{"__ignoreMap":43},[48,597,598],{"class":50,"line":51},[48,599,55],{"class":54},[48,601,602,604,606,608,610,612,614,616,618,620,622],{"class":50,"line":58},[48,603,62],{"class":61},[48,605,66],{"class":65},[48,607,70],{"class":69},[48,609,73],{"class":65},[48,611,76],{"class":69},[48,613,79],{"class":65},[48,615,82],{"class":61},[48,617,86],{"class":85},[48,619,89],{"class":65},[48,621,93],{"class":92},[48,623,96],{"class":65},[48,625,626,628,630,632,634,636],{"class":50,"line":99},[48,627,62],{"class":61},[48,629,110],{"class":69},[48,631,113],{"class":61},[48,633,116],{"class":61},[48,635,119],{"class":85},[48,637,122],{"class":65},[48,639,640],{"class":50,"line":105},[48,641,642],{"class":54},"  \u002F\u002F ... other code omitted\n",[48,644,645],{"class":50,"line":125},[48,646,155],{"class":65},[48,648,649],{"class":50,"line":131},[48,650,162],{"emptyLinePlaceholder":161},[48,652,653],{"class":50,"line":146},[48,654,168],{"class":54},[48,656,657,659,661,663,665,667,669],{"class":50,"line":152},[48,658,174],{"class":65},[48,660,177],{"class":85},[48,662,89],{"class":65},[48,664,182],{"class":92},[48,666,185],{"class":65},[48,668,188],{"class":61},[48,670,191],{"class":65},[48,672,673],{"class":50,"line":158},[48,674,642],{"class":54},[48,676,677],{"class":50,"line":165},[48,678,155],{"class":65},[48,680,681],{"class":50,"line":171},[48,682,162],{"emptyLinePlaceholder":161},[48,684,685],{"class":50,"line":194},[48,686,687],{"class":54},"\u002F\u002F Log in\n",[48,689,690,692,694,696,698],{"class":50,"line":210},[48,691,174],{"class":65},[48,693,231],{"class":85},[48,695,89],{"class":65},[48,697,236],{"class":69},[48,699,96],{"class":65},[12,701,702],{},"These are:",[401,704,705,710],{},[404,706,707,709],{},[45,708,177],{},": registers an event, but only fires once",[404,711,712,714],{},[45,713,231],{},": logs in the bot",[12,716,717,718,140],{},"There are more methods — see the ",[458,719,463],{"href":720,"rel":721},"https:\u002F\u002Fdiscord.js.org\u002F#\u002Fdocs\u002Fmain\u002Fstable\u002Fclass\u002FClient",[462],[12,723,724,725,728,729,731,732,734,735,737],{},"But the most common are ",[45,726,727],{},"on"," and ",[45,730,177],{},". Both register events, but ",[45,733,727],{}," continuously listens while ",[45,736,177],{}," only listens once.",[12,739,740],{},"Now let's talk about events. Look at the previous code:",[38,742,744],{"className":40,"code":743,"language":42,"meta":43,"style":43},"client.once('ready', () => {\n  \u002F\u002F ... other code omitted\n});\n",[45,745,746,762,766],{"__ignoreMap":43},[48,747,748,750,752,754,756,758,760],{"class":50,"line":51},[48,749,174],{"class":65},[48,751,177],{"class":85},[48,753,89],{"class":65},[48,755,182],{"class":92},[48,757,185],{"class":65},[48,759,188],{"class":61},[48,761,191],{"class":65},[48,763,764],{"class":50,"line":58},[48,765,642],{"class":54},[48,767,768],{"class":50,"line":99},[48,769,155],{"class":65},[12,771,772,774,775,778],{},[45,773,177],{}," listens for an event — ",[45,776,777],{},"ready",". This event fires when the bot is ready. So when the bot is ready, this event fires.",[12,780,781,782,728,785,788,789,792,793,796,797,799,800,802],{},"Where do ",[45,783,784],{},"client.on",[45,786,787],{},"client.once"," come from? If you check the ",[458,790,463],{"href":720,"rel":791},[462],", you'll only find ",[45,794,795],{},"client.login"," — not ",[45,798,784],{}," or ",[45,801,787],{},". Where do these two come from?",[12,804,805,806,809,810,812,813,815,816,728,818,820,821,825],{},"They're from ",[45,807,808],{},"EventEmitter",", a built-in Node.js class. The ",[45,811,70],{}," class inherits from ",[45,814,808],{},", so we can use ",[45,817,784],{},[45,819,787],{},". See ",[458,822,808],{"href":823,"rel":824},"https:\u002F\u002Fnodejs.org\u002Fapi\u002Fevents.html#events_emitter_on_eventname_listener",[462]," for details.",[12,827,828,829,831,832,728,834,836],{},"What events besides ",[45,830,777],{}," are there for ",[45,833,177],{},[45,835,727],{},"? A lot. Plus, the way I wrote it isn't the only way — you can also write:",[38,838,840],{"className":40,"code":839,"language":42,"meta":43,"style":43},"const {\n  Client,\n  GatewayIntentBits,\n  Partials,\n  Events,\n} = require('discord.js');\n\nconst client = new Client({\n  intents: [\n    GatewayIntentBits.Guilds,\n    GatewayIntentBits.GuildMessages,\n    GatewayIntentBits.MessageContent,\n  ],\n  partials: [\n    Partials.Channel,\n  ],\n});\n\nclient.once(Events.ClientReady, () => {\n  console.log('Ready!');\n});\n\nclient.login(TOKEN);\n",[45,841,842,848,856,863,870,877,892,896,910,914,918,922,926,930,934,939,943,948,953,967,980,985,990],{"__ignoreMap":43},[48,843,844,846],{"class":50,"line":51},[48,845,62],{"class":61},[48,847,191],{"class":65},[48,849,850,853],{"class":50,"line":58},[48,851,852],{"class":69},"  Client",[48,854,855],{"class":65},",\n",[48,857,858,861],{"class":50,"line":99},[48,859,860],{"class":69},"  GatewayIntentBits",[48,862,855],{"class":65},[48,864,865,868],{"class":50,"line":105},[48,866,867],{"class":69},"  Partials",[48,869,855],{"class":65},[48,871,872,875],{"class":50,"line":125},[48,873,874],{"class":69},"  Events",[48,876,855],{"class":65},[48,878,879,882,884,886,888,890],{"class":50,"line":131},[48,880,881],{"class":65},"} ",[48,883,82],{"class":61},[48,885,86],{"class":85},[48,887,89],{"class":65},[48,889,93],{"class":92},[48,891,96],{"class":65},[48,893,894],{"class":50,"line":146},[48,895,162],{"emptyLinePlaceholder":161},[48,897,898,900,902,904,906,908],{"class":50,"line":152},[48,899,62],{"class":61},[48,901,110],{"class":69},[48,903,113],{"class":61},[48,905,116],{"class":61},[48,907,119],{"class":85},[48,909,122],{"class":65},[48,911,912],{"class":50,"line":158},[48,913,128],{"class":65},[48,915,916],{"class":50,"line":165},[48,917,375],{"class":65},[48,919,920],{"class":50,"line":171},[48,921,380],{"class":65},[48,923,924],{"class":50,"line":194},[48,925,385],{"class":65},[48,927,928],{"class":50,"line":210},[48,929,390],{"class":65},[48,931,932],{"class":50,"line":215},[48,933,547],{"class":65},[48,935,936],{"class":50,"line":220},[48,937,938],{"class":65},"    Partials.Channel,\n",[48,940,941],{"class":50,"line":226},[48,942,390],{"class":65},[48,944,946],{"class":50,"line":945},17,[48,947,155],{"class":65},[48,949,951],{"class":50,"line":950},18,[48,952,162],{"emptyLinePlaceholder":161},[48,954,956,958,960,963,965],{"class":50,"line":955},19,[48,957,174],{"class":65},[48,959,177],{"class":85},[48,961,962],{"class":65},"(Events.ClientReady, () ",[48,964,188],{"class":61},[48,966,191],{"class":65},[48,968,970,972,974,976,978],{"class":50,"line":969},20,[48,971,197],{"class":65},[48,973,200],{"class":85},[48,975,89],{"class":65},[48,977,205],{"class":92},[48,979,96],{"class":65},[48,981,983],{"class":50,"line":982},21,[48,984,155],{"class":65},[48,986,988],{"class":50,"line":987},22,[48,989,162],{"emptyLinePlaceholder":161},[48,991,993,995,997,999,1001],{"class":50,"line":992},23,[48,994,174],{"class":65},[48,996,231],{"class":85},[48,998,89],{"class":65},[48,1000,236],{"class":69},[48,1002,96],{"class":65},[12,1004,1005,1006,1008,1009,1012,1013,1016,1017,140],{},"Here ",[45,1007,177],{},"'s event becomes ",[45,1010,1011],{},"Events.ClientReady",". The ",[45,1014,1015],{},"Events"," object is provided by Discord.js and contains all events. See ",[458,1018,1015],{"href":1019,"rel":1020},"https:\u002F\u002Fold.discordjs.dev\u002F#\u002Fdocs\u002Fdiscord.js\u002F14.13.0\u002Ftypedef\u002FEvents",[462],[12,1022,1023,1024,1026,1027,1029],{},"What's the difference between writing the string vs using ",[45,1025,1015],{},"? Not much really — the difference is you can use the ",[45,1028,1015],{}," dropdown to see all events without checking docs:",[12,1031,1032],{},[15,1033],{"alt":1034,"src":1035},"Dropdown","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_events.png",[12,1037,1038,1040],{},[45,1039,1015],{}," actually just passes the corresponding string. Here's the source:",[38,1042,1044],{"className":40,"code":1043,"language":42,"meta":43,"style":43},"export enum Events {\n  ClientReady = 'ready',\n  MessageCreate = 'messageCreate',\n  MessageDelete = 'messageDelete',\n  MessageUpdate = 'messageUpdate',\n  \u002F\u002F ... other code omitted\n}\n",[45,1045,1046,1060,1072,1084,1096,1108,1112],{"__ignoreMap":43},[48,1047,1048,1051,1054,1058],{"class":50,"line":51},[48,1049,1050],{"class":61},"export",[48,1052,1053],{"class":61}," enum",[48,1055,1057],{"class":1056},"s_sBn"," Events",[48,1059,191],{"class":65},[48,1061,1062,1065,1067,1070],{"class":50,"line":58},[48,1063,1064],{"class":69},"  ClientReady",[48,1066,113],{"class":61},[48,1068,1069],{"class":92}," 'ready'",[48,1071,855],{"class":65},[48,1073,1074,1077,1079,1082],{"class":50,"line":99},[48,1075,1076],{"class":69},"  MessageCreate",[48,1078,113],{"class":61},[48,1080,1081],{"class":92}," 'messageCreate'",[48,1083,855],{"class":65},[48,1085,1086,1089,1091,1094],{"class":50,"line":105},[48,1087,1088],{"class":69},"  MessageDelete",[48,1090,113],{"class":61},[48,1092,1093],{"class":92}," 'messageDelete'",[48,1095,855],{"class":65},[48,1097,1098,1101,1103,1106],{"class":50,"line":125},[48,1099,1100],{"class":69},"  MessageUpdate",[48,1102,113],{"class":61},[48,1104,1105],{"class":92}," 'messageUpdate'",[48,1107,855],{"class":65},[48,1109,1110],{"class":50,"line":131},[48,1111,642],{"class":54},[48,1113,1114],{"class":50,"line":146},[48,1115,1116],{"class":65},"}\n",[12,1118,1119],{},"So whether you write:",[38,1121,1123],{"className":40,"code":1122,"language":42,"meta":43,"style":43},"client.once('ready', () => {\n  console.log('Ready!');\n});\n",[45,1124,1125,1141,1153],{"__ignoreMap":43},[48,1126,1127,1129,1131,1133,1135,1137,1139],{"class":50,"line":51},[48,1128,174],{"class":65},[48,1130,177],{"class":85},[48,1132,89],{"class":65},[48,1134,182],{"class":92},[48,1136,185],{"class":65},[48,1138,188],{"class":61},[48,1140,191],{"class":65},[48,1142,1143,1145,1147,1149,1151],{"class":50,"line":58},[48,1144,197],{"class":65},[48,1146,200],{"class":85},[48,1148,89],{"class":65},[48,1150,205],{"class":92},[48,1152,96],{"class":65},[48,1154,1155],{"class":50,"line":99},[48,1156,155],{"class":65},[12,1158,1159],{},"Or:",[38,1161,1163],{"className":40,"code":1162,"language":42,"meta":43,"style":43},"client.once(Events.ClientReady, () => {\n  console.log('Ready!');\n});\n",[45,1164,1165,1177,1189],{"__ignoreMap":43},[48,1166,1167,1169,1171,1173,1175],{"class":50,"line":51},[48,1168,174],{"class":65},[48,1170,177],{"class":85},[48,1172,962],{"class":65},[48,1174,188],{"class":61},[48,1176,191],{"class":65},[48,1178,1179,1181,1183,1185,1187],{"class":50,"line":58},[48,1180,197],{"class":65},[48,1182,200],{"class":85},[48,1184,89]