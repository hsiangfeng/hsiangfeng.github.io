was originally in the frontend to Google Apps Script. So we need to:",[35,36,37,41,44,47],"ol",{},[38,39,40],"li",{},"Create a Google Apps Script project",[38,42,43],{},"Write the Google Apps Script code",[38,45,46],{},"Remove the original OpenAI code from the Google Extension",[38,48,49],{},"Integrate with the Google Apps Script API",[12,51,52,53,60],{},"Go to the ",[54,55,59],"a",{"href":56,"rel":57},"https:\u002F\u002Fwww.google.com\u002Fscript\u002Fstart\u002F",[58],"nofollow","Google Apps Script website"," and click \"New Project\":",[12,62,63],{},[15,64],{"alt":65,"src":66},"Google Apps Script","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgoogle_apps_script_dash.png",[68,69,71],"h3",{"id":70},"properties-service","Properties Service",[12,73,74,75,79],{},"Click \"Create script\" on the side. We'll first create environment variables, so name the file ",[76,77,78],"code",{},"env",":",[12,81,82],{},[15,83],{"alt":78,"src":84},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas-env.png",[12,86,87],{},"Add this code:",[89,90,95],"pre",{"className":91,"code":92,"language":93,"meta":94,"style":94},"language-js shiki shiki-themes github-dark-high-contrast","const env = {\n  openai_key: 'OpenAI Key',\n}\n","js","",[76,96,97,117,130],{"__ignoreMap":94},[98,99,102,106,110,113],"span",{"class":100,"line":101},"line",1,[98,103,105],{"class":104},"sWyjQ","const",[98,107,109],{"class":108},"sCcAr"," env",[98,111,112],{"class":104}," =",[98,114,116],{"class":115},"sMAXC"," {\n",[98,118,120,123,127],{"class":100,"line":119},2,[98,121,122],{"class":115},"  openai_key: ",[98,124,126],{"class":125},"sTRMh","'OpenAI Key'",[98,128,129],{"class":115},",\n",[98,131,133],{"class":100,"line":132},3,[98,134,135],{"class":115},"}\n",[12,137,138,139,141,142,145],{},"OK, pause. You're probably confused — earlier when I introduced ",[76,140,78],{},", we needed to install the ",[76,143,144],{},"dotenv"," package. But here we didn't. Why? Because Google Apps Script itself doesn't have an env var concept, and this approach isn't really correct.",[12,147,148,149,151],{},"Although Google Apps Script lacks env var concepts, it has something similar — Properties Service. So we can use this instead of ",[76,150,78],{},".",[12,153,154],{},"Click the gear (Project Settings):",[12,156,157],{},[15,158],{"alt":159,"src":160},"Project Settings","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_setting.png",[12,162,163],{},"Scroll down to find \"Script Properties\", click \"Add script property\", and put your OpenAI Key in:",[12,165,166],{},[15,167],{"alt":168,"src":169},"Script Properties","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_env_key.jpg",[12,171,172],{},"Back in any code, add this and run:",[89,174,176],{"className":91,"code":175,"language":93,"meta":94,"style":94},"Logger.log(PropertiesService.getScriptProperties().getProperty('openai_token'))\n",[76,177,178],{"__ignoreMap":94},[98,179,180,183,187,190,193,196,199,202,205],{"class":100,"line":101},[98,181,182],{"class":115},"Logger.",[98,184,186],{"class":185},"sj_SG","log",[98,188,189],{"class":115},"(PropertiesService.",[98,191,192],{"class":185},"getScriptProperties",[98,194,195],{"class":115},"().",[98,197,198],{"class":185},"getProperty",[98,200,201],{"class":115},"(",[98,203,204],{"class":125},"'openai_token'",[98,206,207],{"class":115},"))\n",[12,209,210],{},"You should see your OpenAI Key in the output. Now back in env.gs, change the code to:",[89,212,214],{"className":91,"code":213,"language":93,"meta":94,"style":94},"const env = {\n  openai_key: PropertiesService.getScriptProperties().getProperty('openai_token'),\n}\n",[76,215,216,226,244],{"__ignoreMap":94},[98,217,218,220,222,224],{"class":100,"line":101},[98,219,105],{"class":104},[98,221,109],{"class":108},[98,223,112],{"class":104},[98,225,116],{"class":115},[98,227,228,231,233,235,237,239,241],{"class":100,"line":119},[98,229,230],{"class":115},"  openai_key: PropertiesService.",[98,232,192],{"class":185},[98,234,195],{"class":115},[98,236,198],{"class":185},[98,238,201],{"class":115},[98,240,204],{"class":125},[98,242,243],{"class":115},"),\n",[98,245,246],{"class":100,"line":132},[98,247,135],{"class":115},[12,249,250,251,254],{},"Now we can use ",[76,252,253],{},"env.openai_key"," anywhere to get the OpenAI Key.",[256,257,258],"blockquote",{},[12,259,260,264,265,267],{},[261,262,263],"strong",{},"Note","\nVariables declared in Google Apps Script are global, so you can use ",[76,266,78],{}," anywhere.",[68,269,271],{"id":270},"integrating-openai","Integrating OpenAI",[12,273,274],{},"Now to integrate OpenAI.",[12,276,277,278,283,284,287,288,151],{},"But Google Apps Script has an inconvenient issue — you can't import packages freely. So we have to use the ",[54,279,282],{"href":280,"rel":281},"https:\u002F\u002Fplatform.openai.com\u002Fdocs\u002Fapi-reference\u002Fchat\u002Fcreate",[58],"OpenAI"," API directly. Conveniently, OpenAI's API is super easy to integrate — just use ",[76,285,286],{},"UrlFetchApp"," to send a request to ",[76,289,290],{},"Post https:\u002F\u002Fapi.openai.com\u002Fv1\u002Fchat\u002Fcompletions",[12,292,293,294,297],{},"Create a new file called ",[76,295,296],{},"openai.gs"," and add:",[12,299,300],{},"(I'll add comments so you can follow)",[89,302,304],{"className":91,"code":303,"language":93,"meta":94,"style":94},"\u002F\u002F Declare doPost method — this is required by Google Apps Script\nconst doPost = (e) => {\n  \u002F\u002F Get e.postData.contents — must use JSON.parse to convert to object\n  const postData = JSON.parse(e.postData.contents);\n  \u002F\u002F Extract text\n  const text = postData.text;\n  \u002F\u002F Declare options object\n  const options = {\n    \u002F\u002F Set request method to post\n    method: 'post',\n    \u002F\u002F Set request headers\n    headers: {\n      \u002F\u002F Default Google Apps Script is application\u002Fx-www-form-urlencoded, but OpenAI needs application\u002Fjson\n      'Content-Type': 'application\u002Fjson',\n      \u002F\u002F Set Authorization to Bearer ${env.openai_key}\n      Authorization: `Bearer ${env.openai_key}`\n    },\n    \u002F\u002F Prepare data to send — must use JSON.stringify to convert object to JSON string\n    payload: JSON.stringify({\n      model: 'gpt-3.5-turbo', \u002F\u002F Use gpt-3.5-turbo model\n      \u002F\u002F Set prompt — using text here\n      messages: [\n        {\n          role: 'user', \u002F\u002F Set role to user\n          content: text \n        }\n      ]\n    })\n  }\n  \u002F\u002F Send request and get response data\n  const response = UrlFetchApp.fetch(env.openai_url, options)\n  \u002F\u002F Convert response to object and extract choices[0].message.content\n  const message = JSON.parse(response.getContentText()).choices[0].message.content\n  \u002F\u002F Return JSON object, set MIME type as JSON via setMimeType\n  return ContentService.createTextOutput(JSON.stringify({\n    content: message\n  })).setMimeType(ContentService.MimeType.JSON)\n}\n",[76,305,306,312,336,341,363,369,382,388,400,406,417,423,429,435,449,455,474,480,486,503,518,524,530,536,550,556,562,568,574,580,586,605,611,642,648,670,676,693],{"__ignoreMap":94},[98,307,308],{"class":100,"line":101},[98,309,311],{"class":310},"sQrFR","\u002F\u002F Declare doPost method — this is required by Google Apps Script\n",[98,313,314,316,319,321,324,328,331,334],{"class":100,"line":119},[98,315,105],{"class":104},[98,317,318],{"class":185}," doPost",[98,320,112],{"class":104},[98,322,323],{"class":115}," (",[98,325,327],{"class":326},"s_sBn","e",[98,329,330],{"class":115},") ",[98,332,333],{"class":104},"=>",[98,335,116],{"class":115},[98,337,338],{"class":100,"line":132},[98,339,340],{"class":310},"  \u002F\u002F Get e.postData.contents — must use JSON.parse to convert to object\n",[98,342,344,3