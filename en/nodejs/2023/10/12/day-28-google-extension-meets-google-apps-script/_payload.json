{},"How do we get the API URL? Click \"Deploy\" — a dropdown appears. Pick \"New deployment\", then find the gear and pick \"Web app\":",[12,715,716],{},[15,717],{"alt":718,"src":719},"Web app","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web.png",[12,721,722],{},"For practice convenience, fill in a description and change \"Who has access\" to \"Anyone\" — so we can use the API without logging in:",[12,724,725],{},[15,726],{"alt":727,"src":728},"API","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web_2.jpg",[12,730,731],{},"If first time deploying, some windows pop up — just follow the prompts to authorize and allow. You should see this screen — the red box is your API URL:",[12,733,734],{},[15,735],{"alt":736,"src":737},"API Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web_3.jpg",[12,739,740],{},"After copying, we're ready to go back to the Google Extension.",[68,742,744],{"id":743},"google-extension","Google Extension",[12,746,747],{},"We won't create a new project — we'll reuse the previous post's example. Open App.vue and replace with:",[89,749,753],{"className":750,"code":751,"language":752,"meta":94,"style":94},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript setup>\nimport { onMounted } from 'vue'\nimport HelloWorld from '.\u002Fcomponents\u002FHelloWorld.vue'\n\nasync function main() {\n  const data = await fetch('API Url', {\n    method: 'POST',\n    body: JSON.stringify({\n      text: 'Hello, world!'\n    })\n  }).then(res => res.json())\n\n  console.log(data)\n}\n\nonMounted(main);\n\u003C\u002Fscript>\n","html",[76,754,755,770,784,796,802,816,839,848,861,869,873,898,902,912,916,920,928],{"__ignoreMap":94},[98,756,757,760,764,767],{"class":100,"line":101},[98,758,759],{"class":115},"\u003C",[98,761,763],{"class":762},"sKpQp","script",[98,765,766],{"c