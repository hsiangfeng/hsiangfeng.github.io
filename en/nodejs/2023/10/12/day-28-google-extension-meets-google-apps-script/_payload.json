.gs",[12,708,709],{},"How do we get the API URL? Click \"Deploy\" — a dropdown appears. Pick \"New deployment\", then find the gear and pick \"Web app\":",[12,711,712],{},[15,713],{"alt":714,"src":715},"Web app","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web.png",[12,717,718],{},"For practice convenience, fill in a description and change \"Who has access\" to \"Anyone\" — so we can use the API without logging in:",[12,720,721],{},[15,722],{"alt":723,"src":724},"API","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web_2.jpg",[12,726,727],{},"If first time deploying, some windows pop up — just follow the prompts to authorize and allow. You should see this screen — the red box is your API URL:",[12,729,730],{},[15,731],{"alt":732,"src":733},"API Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web_3.jpg",[12,735,736],{},"After copying, we're ready to go back to the Google Extension.",[68,738,740],{"id":739},"google-extension","Google Extension",[12,742,743],{},"We won't create a new project — we'll reuse the previous post's example. Open App.vue and replace with:",[89,745,749],{"className":746,"code":747,"language":748,"meta":94,"style":94},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cscript setup>\nimport { onMounted } from 'vue'\nimport HelloWorld from '.\u002Fcomponents\u002FHelloWorld.vue'\n\nasync function main() {\n  const data = await fetch('API Url', {\n    method: 'POST',\n    body: JSON.stringify({\n      text: 'Hello, world!'\n    })\n  }).then(res => res.json())\n\n  console.log(data)\n}\n\nonMounted(main);\n\u003C\u002Fscript>\n","html",[76,750,751,767,781,793,799,813,836,845,858,866,870,895,899,909,913,917,925],{"__ignoreMap":94},[98,752,753,756,760,764],{"class":100,"line":101},[98,754,755],{"class":115},"\u003C",[98,757,759],{"c