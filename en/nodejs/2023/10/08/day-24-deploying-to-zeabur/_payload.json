"class":104},"\"example-discord-crawler\"",[94,1694,335],{"class":212},[94,1696,1697],{"class":96,"line":117},[94,1698,1699],{"class":206},"  \u002F\u002F ... other code omitted\n",[94,1701,1702,1705],{"class":96,"line":129},[94,1703,1704],{"class":1685},"  \"scripts\"",[94,1706,1707],{"class":212},": {\n",[94,1709,1710,1713,1715,1718],{"class":96,"line":138},[94,1711,1712],{"class":1685},"    \"start\"",[94,1714,1689],{"class":212},[94,1716,1717],{"class":104},"\"node index.js\"",[94,1719,335],{"class":212},[94,1721,1722,1725,1727,1730,1733,1736,1738],{"class":96,"line":146},[94,1723,1724],{"class":1685},"    \"test\"",[94,1726,1689],{"class":212},[94,1728,1729],{"class":104},"\"echo ",[94,1731,1732],{"class":221},"\\\"",[94,1734,1735],{"class":104},"Error: no test specified",[94,1737,1732],{"class":221},[94,1739,1740],{"class":104}," && exit 1\"\n",[94,1742,1743],{"class":96,"line":154},[94,1744,1498],{"class":212},[94,1746,1747],{"class":96,"line":162},[94,1748,1699],{"class":206},[94,1750,1751],{"class":96,"line":338},[94,1752,965],{"class":212},[12,1754,1755],{},"Now push this project to GitHub Repositories — Zeabur needs your GitHub repo to deploy. I won't elaborate on the GitHub deployment process. Plus Zeabur uses GitHub for sign-up\u002Flogin, so GitHub is required.",[62,1757,1758],{},[12,1759,1760,1762,1763,1770],{},[43,1761,68],{},"\nIf first-time using GitHub, see my post ",[1764,1765,1769],"a",{"href":1766,"rel":1767},"https:\u002F\u002Fisraynotarray.com\u002Fgit\u002F20210709\u002F1381487661\u002F",[1768],"nofollow","Connecting\u002Fuploading to GitHub via SSH (Ed25519) (article in Mandarin)"," and try pushing the project to GitHub.",[12,1772,1773,1774,1777,1778,1780,1781,651],{},"Reminder — don't push ",[91,1775,1776],{},".env"," to GitHub. It contains your Discord Token. If pushed publicly, your Discord Token gets exposed and your Discord Bot can be controlled by others. Always add ",[91,1779,1776],{}," to ",[91,1782,1783],{},".gitignore",[12,1785,1786],{},"Now go to Zeabur. Since Zeabur uses GitHub for sign-up\u002Flogin:",[12,1788,1789],{},[1764,1790,1791],{"href":1791,"rel":1792},"https:\u002F\u002Fdash.zeabur.com\u002Flogin",[1768],[12,1794,1795],{},"You can directly log in with GitHub:",[12,1797,1798],{},[15,1799],{"alt":1800,"src":1801},"GitHub login","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2014.56.20.png",[12,1803,1804],{},"After logging in, you'll go straight to the Zeabur dashboard. Click \"Create Project\":",[12,1806,1807],{},[15,1808],{"alt":1809,"src":1810},"Create project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2015.00.25.png",[12,1812,1813],{},"Pick the project region — let's pick \"Taiwan\" (FYI: Zeabur servers are in GCP's Taiwan datacenter):",[12,1815,1816],{},[15,1817],{"alt":1818,"src":1819},"Taiwan","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2015.01.11.png",[12,1821,1822],{},"You'll see your newly created project:",[12,1824,1825],{},[15,1826],{"alt":1827,"src":1828},"New Project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fnew%20Project.png",[12,1830,1831],{},"Click it to see project info. Quick overview:",[12,1833,1834],{},[15,1835],{"alt":1836,"src":1837},"Project intro","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002FZeabur_service_dash.jpg",[12,1839,1840],{},"I won't elaborate on project settings — explore on your own.",[12,1842,1843],{},"Let's deploy our service (project). Click \"Create Service\" and you'll see Git and Marketplace options. Pick Git since we're deploying from GitHub:",[12,1845,1846],{},[15,1847],{"alt":1848,"src":1849},"Git Deploy","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fzeabur_deploy_git.png",[12,1851,1852],{},"Pick the project to deploy:",[12,1854,1855],{},[15,1856],{"alt":1857,"src":1858},"Project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fzeabur_deploy_git2.jpg",[12,1860,1861],{},"The whole deploy takes about 1-2 minutes:",[12,1863,1864],{},[15,1865],{"alt":1866,"src":1867},"Deploy","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2016.15.07.png",[12,1869,1870],{},"Click \"Log\" to see the deploy process:",[12,1872,1873],{},[15,1874],{"alt":1875,"src":1876},"Log","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2016.31.52.png",[12,1878,1879],{},[15,1880],{"alt":1875,"src":1881},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002FZeabur_log.jpg",[12,1883,1884],{},"You'll likely find Log shows an error:",[12,1886,1887],{},[15,1888],{"alt":1889,"src":1890},"Error","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2016.39.27.png",[12,1892,1893,1894,1896],{},"Because we didn't set Env vars. Back at the project dashboard, there's an Environment Variables section at the bottom. Click \"Edit Environment Variables\" and you can paste ",[91,1895,1776],{}," contents directly:",[12,1898,1899],{},[15,1900],{"alt":1901,"src":1902},"Env","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002FZeabur_env.jpg",[12,1904,1905],{},"After saving, click ReDeploy and it'll work normally.",[12,1907,1908],{},[15,1909],{"alt":1910,"src":1876},"ReDeploy",[12,1912,1913,1914,1917],{},"Back to Discord, your Discord Bot should be online. Try ",[91,1915,1916],{},"\u002Fblog"," to test — your Discord Bot should reply with an article.",[1919,1920,1922],"h3",{"id":1921},"about-auto-registering-commands","About auto-registering commands",[12,1924,1925,1926,1929],{},"One more thing — about command registration. We added a file called ",[91,1927,1928],{},"register.js"," for registering commands. To make sure commands are always up-to-date, we can register commands via npm scripts so we don't have to manually register every time:",[84,1931,1933],{"className":1671,"code":1932,"language":1673,"meta":89,"style":89},"{\n  \"name\": \"example-discord-crawler\",\n  \u002F\u002F ... other code omitted\n  \"scripts\": {\n    \"postinstall\": \"node register.js\",\n    \"start\": \"node index.js\",\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\",\n    \"register\": \"node register.js\"\n  },\n  \u002F\u002F ... other code omitted\n}\n",[91,1934,1935,1939,1949,1953,1959,1971,1981,2000,2010,2014,2018],{"__ignoreMap":89},[94,1936,1937],{"class":96,"line":97},[94,1938,1680],{"class":212},[94,1940,1941,1943,1945,1947],{"class":96,"line":108},[94,1942,1686],{"class":1685},[94,1944,1689],{"class":212},[94,1946,1692],{"class":104},[94,1948,335],{"class":212},[94,1950,1951],{"class":96,"line":117},[94,1952,1699],{"class":206},[94,1954,1955,1957],{"class":96,"line":129},[94,1956,1704],{"class":1685},[94,1958,1707],{"class":212},[94,1960,1961,1964,1966,1969],{"class":96,"line":138},[94,1962,1963],{"class":1685},"    \"postinstall\"",[94,1965,1689],{"class":212},[94,1967,1968],{"class":104},"\"node register.js\"",[94,1970,335],{"class":212},[94,1972,1973,1975,1977,1979],{"class":96,"line":146},[94,1974,1712],{"class":1685},[94,1976,1689],{"class":212},[94,1978,1717],{"class":104},[94,1980,335],{"class":212},[94,1982,1983,1985,1987,1989,1991,1993,1995,1998],{"class":96,"line":154},[94,1984,1724],{"class":1685},[94,1986,1689],{"class":212},[94,1988,1729],{"class":104},[94,1990,1732],{"class":221},[94,1992,1735],{"class":104},[94,1994,1732],{"class":221},[94,1996,1997],{"class":104}," && exit 1\"",[94,1999,335],{"class":212},[94,2001,2002,2005,2007],{"class":96,"line":162},[94,2003,2004],{"class":1685},"    \"register\"",[94,2006,1689],{"class":212},[94,2008,2009],{"class":104},"\"node register.js\"\n",[94,2011,2012],{"class":96,"line":338},[94,2013,1498],{"class":212},[94,2015,2016],{"class":96,"line":346},[94,2017,1699],{"class":206},[94,2019,2020],{"class":96,"line":354},[94,2021,965],{"class":212},[20,2023,2025],{"id":2024},"other-services","Other services",[12,2027,2028],{},"There are many other services. I've previously covered:",[2030,2031,2032,2040],"ul",{},[2033,2034,2035],"li",{},[1764,2036,2039],{"href":2037,"rel":2038},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20221213\u002F3036227586\u002F",[1768],"Moving from Heroku to Render (article in Mandarin)",[2033,2041,2042],{},[1764,2043,2046],{"href":2044,"rel":2045},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20221216\u002F786812101\u002F",[1768],"Deploying Node.js to fly.io (article in Mandarin)",[12,2048,2049],{},"I've also written about Zeabur:",[2030,2051,2052],{},[2033,2053,2054],{},[1764,2055,2058],{"href":2056,"rel":2057},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20230401\u002F3544735243\u002F",[1768],"Beyond Render and Fly, you can also consider Zeabur (article in Mandarin)",[12,2060,2061],{},"After trying these, I personally recommend Zeabur. Even though it only allows one project at a time, you can deploy lots of services within a project. Plus the free $5 credit is available, the docs are thorough, and the team is responsive in helping resolve issues. So highly recommended.",[12,2063,2064],{},"----- Sponsored content begins -----",[12,2066,2067],{},"If you find the trial usage good, you can fill in my referral code at payment:",[84,2069,2071],{"className":86,"code":2070,"language":88,"meta":89,"style":89},"israynotarray\n",[91,2072,2073],{"__ignoreMap":89},[94,2074,2075],{"class":96,"line":97},[94,2076,2070],{"class":100},[12,2078,2079],{},"You can get a free month of the Developer plan!",[12,2081,2082],{},"For Zeabur's pricing, see their official docs:",[12,2084,2085],{},[1764,2086,2089],{"href":2087,"rel":2088},"https:\u002F\u002Fzeabur.com\u002Fpricing",[1768],"Pricing",[12,2091,2092],{},"----- End of sponsored content -----",[12,2094,2095],{},"That's a wrap, see you in the next one.",[2097,2098,2099],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}",{"title":89,"searchDepth":108,"depth":108,"links":2101},[2102,2103,2104,2107],{"id":22,"depth":108,"text":23},{"id":29,"depth":108,"text":17},{"id":75,"depth":108,"text":76,"children":2105},[2106],{"id":1921,"depth":117,"text":1922},{"id":2024,"depth":108,"text":2025},"Nodejs","2023-10-08 00:00:01","md","en",{},"\u002Fen\u002Fnodejs\u002Fday-24-deploying-to-zeabur","6",{"title":6,"description":26},false,"en\u002FNodejs\u002Fday-24-deploying-to-zeabur",[2119,2120],"Node.js","Node.js 30 Days Series",null,"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F08\u002Fday-24-deploying-to-zeabur\u002F","fbFINbyL9ZBbmA3foybrA0tB5Jc7iRk_U55CCMjHYB8",