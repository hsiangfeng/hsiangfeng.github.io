[{"data":1,"prerenderedAt":1056},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":1031,"related:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":1040},"\u002Fnodejs\u002F20231004\u002F1031795777\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1016,"date":1017,"description":26,"extension":1018,"lang":1019,"meta":1020,"navigation":376,"path":1021,"readingMinutes":785,"seo":1022,"standalone":1023,"stem":1024,"tags":1025,"tldr":1028,"updated":1017,"url":1029,"__hash__":1030},"content\u002Fen\u002FNodejs\u002Fday-20-what-is-a-discord-bot.md","Day 20 - Discord Bot?","5710360983",{"type":9,"value":10,"toc":1007},"minimark",[11,19,24,27,31,34,45,51,54,60,63,69,72,78,84,90,93,111,114,120,123,129,139,145,156,159,165,176,180,183,235,242,257,260,265,268,284,288,297,302,305,654,661,671,674,680,687,809,816,820,823,983,994,1000,1003],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Discord Bot","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_discord_bot_7ffc90d7-a1fd-4705-8a01-7c982263c868.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"Beyond scraping, Node.js can do a lot more. Now we'll introduce another application — Bots.",[20,28,30],{"id":29},"bot","Bot?",[12,32,33],{},"What's a Bot? You've probably heard of Line Bots, Discord Bots, Slack Bots. So what are these Bots? In short, a Bot is an automated program that helps automate things — auto-replying to messages, auto-sending messages, auto-sending Email, etc.",[12,35,36,37,44],{},"What are we demoing this time? A Discord Bot. But first, I'd recommend preparing a Discord server, then going to the ",[38,39,43],"a",{"href":40,"rel":41},"https:\u002F\u002Fdiscord.com\u002Fdevelopers\u002Fdocs\u002Fintro",[42],"nofollow","Developer Portal"," to create a bot. Click Applications:",[12,46,47],{},[15,48],{"alt":49,"src":50},"Applications","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_1.jpg",[12,52,53],{},"Then click \"New Application\" at the top:",[12,55,56],{},[15,57],{"alt":58,"src":59},"New Application","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_2.jpg",[12,61,62],{},"Pick whatever name you want. I'm naming mine \"node-ithelp-2023\":",[12,64,65],{},[15,66],{"alt":67,"src":68},"New Application 2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_3.jpg",[12,70,71],{},"After creating, find the application you just created, click \"Bot\" on the left, and you'll see \"Reset Token\" — click to get the Token:",[12,73,74],{},[15,75],{"alt":76,"src":77},"Get Token","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_4.jpg",[12,79,80],{},[81,82,83],"strong",{},"Don't leak this Token — we'll use it for practice later.",[12,85,86],{},[15,87],{"alt":88,"src":89},"Token is important","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1694789575685.png",[12,91,92],{},"The Token looks something like this (don't worry, I've already changed mine):",[94,95,100],"pre",{"className":96,"code":97,"language":98,"meta":99,"style":99},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","MTE0ODExxxxxxxxxxxxxxxxxx.GJ6bFp.t1h86ISWswdqidu173ydwmawd1213P9mNj9qbXlhI\n","bash","",[101,102,103],"code",{"__ignoreMap":99},[104,105,108],"span",{"class":106,"line":107},"line",1,[104,109,97],{"class":110},"smYoP",[12,112,113],{},"Some operations need permissions, so scroll down to \"Privileged Gateway Intents\". Turn on the permissions below:",[12,115,116],{},[15,117],{"alt":118,"src":119},"Privileged Gateway Intents","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_5.jpg",[12,121,122],{},"Finally, we add this Bot to our server. Click \"OAuth2\" to get the Client ID:",[12,124,125],{},[15,126],{"alt":127,"src":128},"Client ID","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_client_id.jpg",[12,130,131,132,134,135,138],{},"Then click \"Url Generator\" and check ",[101,133,29],{}," and ",[101,136,137],{},"Administrator",":",[12,140,141],{},[15,142],{"alt":143,"src":144},"Discord Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_6.jpg",[146,147,150],"callout",{"title":148,"type":149},"Note","note",[12,151,152,153,155],{},"We pick ",[81,154,137],{}," for practice convenience. In real-world dev, you'd configure permissions based on the Bot's needs.",[12,157,158],{},"Scroll down and you'll see the invite link. Copy and paste it in your browser, then pick the server to add — done.",[12,160,161],{},[15,162],{"alt":163,"src":164},"Discord Url 2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_url.jpg",[146,166,167],{"title":148,"type":149},[12,168,169,170,175],{},"Discord is a gaming community app (many tech communities have moved over too). You can build a server, invite friends, chat, play games, etc. If interested, see my post ",[38,171,174],{"href":172,"rel":173},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20220428\u002F1571298383\u002F",[42],"Discord too hard? Don't worry, I'll teach you (article in Mandarin)",".",[20,177,179],{"id":178},"project-setup","Project setup",[12,181,182],{},"Set up a project:",[94,184,186],{"className":96,"code":185,"language":98,"meta":99,"style":99},"mkdir discord-bot-example\ncd discord-bot-example\nnpm init -y\ntouch index.js\ntouch register.js\n",[101,187,188,197,206,218,227],{"__ignoreMap":99},[104,189,190,193],{"class":106,"line":107},[104,191,192],{"class":110},"mkdir",[104,194,196],{"class":195},"sWayO"," discord-bot-example\n",[104,198,200,204],{"class":106,"line":199},2,[104,201,203],{"class":202},"stw71","cd",[104,205,196],{"class":195},[104,207,209,212,215],{"class":106,"line":208},3,[104,210,211],{"class":110},"npm",[104,213,214],{"class":195}," init",[104,216,217],{"class":202}," -y\n",[104,219,221,224],{"class":106,"line":220},4,[104,222,223],{"class":110},"touch",[104,225,226],{"class":195}," index.js\n",[104,228,230,232],{"class":106,"line":229},5,[104,231,223],{"class":110},[104,233,234],{"class":195}," register.js\n",[12,236,237,238,241],{},"Then install ",[101,239,240],{},"discord.js"," — the package for implementing Discord Bots:",[94,243,245],{"className":96,"code":244,"language":98,"meta":99,"style":99},"npm i discord.js\n",[101,246,247],{"__ignoreMap":99},[104,248,249,251,254],{"class":106,"line":107},[104,250,211],{"class":110},[104,252,253],{"class":195}," i",[104,255,256],{"class":195}," discord.js\n",[12,258,259],{},"This is from Discord officially, so safe to use.",[146,261,262],{"title":148,"type":149},[12,263,264],{},"If you're familiar with other languages, you can also try Python, Go, etc.",[12,266,267],{},"Heads up — for the upcoming implementation we'll use a newer Discord Bot version, so I'd suggest switching to Node.js 18:",[94,269,271],{"className":96,"code":270,"language":98,"meta":99,"style":99},"nvm use 18\n",[101,272,273],{"__ignoreMap":99},[104,274,275,278,281],{"class":106,"line":107},[104,276,277],{"class":110},"nvm",[104,279,280],{"class":195}," use",[104,282,283],{"class":202}," 18\n",[20,285,287],{"id":286},"implementation","Implementation",[12,289,290,291,296],{},"Now we'll implement a simple Discord Bot. Where to start? The ",[38,292,295],{"href":293,"rel":294},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fdiscord.js",[42],"official docs"," provide example code, but it's based on ES6 syntax — let me walk through it.",[298,299,301],"h3",{"id":300},"registering-commands","Registering commands",[12,303,304],{},"First example — registering commands. Don't worry, I'll add line-by-line comments:",[94,306,310],{"className":307,"code":308,"language":309,"meta":99,"style":99},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","\u002F\u002F register.js\nconst {\n  REST, \u002F\u002F Import REST\n  Routes \u002F\u002F Import Routes\n} = require('discord.js'); \u002F\u002F Import discord.js package\n\n\u002F\u002F Command list\nconst list = [\n  {\n    name: 'ping', \u002F\u002F Command name\n    description: 'Replies with Pong!', \u002F\u002F Command description\n  },\n];\n\n\u002F\u002F Instantiate REST, set version and Token\nconst rest = new REST({ version: '10' }).setToken(TOKEN);\n\nconst registerCommands = async (commands) => {\n  try {\n    console.log('Started refreshing application (\u002F) commands.');\n    \u002F\u002F Register commands\n    await rest.put(Routes.applicationCommands(CLIENT_ID), { body: commands });\n\n    console.log('Successfully reloaded application (\u002F) commands.');\n  } catch (error) {\n    console.error(error);\n  }\n}\n\n\u002F\u002F Execute command registration\nregisterCommands(list);\n","js",[101,311,312,318,328,339,347,371,378,384,398,404,418,432,438,444,449,455,491,496,524,532,548,554,580,585,599,611,622,628,634,639,645],{"__ignoreMap":99},[104,313,314],{"class":106,"line":107},[104,315,317],{"class":316},"sGBqm","\u002F\u002F register.js\n",[104,319,320,324],{"class":106,"line":199},[104,321,323],{"class":322},"sOudu","const",[104,325,327],{"class":326},"s8XSl"," {\n",[104,329,330,333,336],{"class":106,"line":208},[104,331,332],{"class":202},"  REST",[104,334,335],{"class":326},", ",[104,337,338],{"class":316},"\u002F\u002