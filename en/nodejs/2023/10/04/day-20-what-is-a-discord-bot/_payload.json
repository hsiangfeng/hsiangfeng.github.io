[{"data":1,"prerenderedAt":1062},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":1037,"related:\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F":1046},"\u002Fnodejs\u002F20231004\u002F1031795777\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1022,"date":1023,"description":26,"extension":1024,"lang":1025,"meta":1026,"navigation":381,"path":1027,"readingMinutes":791,"seo":1028,"standalone":1029,"stem":1030,"tags":1031,"tldr":1034,"updated":1023,"url":1035,"__hash__":1036},"content\u002Fen\u002FNodejs\u002Fday-20-what-is-a-discord-bot.md","Day 20 - Discord Bot?","5710360983",{"type":9,"value":10,"toc":1013},"minimark",[11,19,24,27,31,34,45,51,54,60,63,69,72,78,84,90,93,111,114,120,123,129,139,145,157,160,166,179,183,186,238,245,260,263,270,273,289,293,302,307,310,658,665,677,680,686,693,815,822,826,829,989,1000,1006,1009],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Discord Bot","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_discord_bot_7ffc90d7-a1fd-4705-8a01-7c982263c868.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"Beyond scraping, Node.js can do a lot more. Now we'll introduce another application — Bots.",[20,28,30],{"id":29},"bot","Bot?",[12,32,33],{},"What's a Bot? You've probably heard of Line Bots, Discord Bots, Slack Bots. So what are these Bots? In short, a Bot is an automated program that helps automate things — auto-replying to messages, auto-sending messages, auto-sending Email, etc.",[12,35,36,37,44],{},"What are we demoing this time? A Discord Bot. But first, I'd recommend preparing a Discord server, then going to the ",[38,39,43],"a",{"href":40,"rel":41},"https:\u002F\u002Fdiscord.com\u002Fdevelopers\u002Fdocs\u002Fintro",[42],"nofollow","Developer Portal"," to create a bot. Click Applications:",[12,46,47],{},[15,48],{"alt":49,"src":50},"Applications","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_1.jpg",[12,52,53],{},"Then click \"New Application\" at the top:",[12,55,56],{},[15,57],{"alt":58,"src":59},"New Application","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_2.jpg",[12,61,62],{},"Pick whatever name you want. I'm naming mine \"node-ithelp-2023\":",[12,64,65],{},[15,66],{"alt":67,"src":68},"New Application 2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_3.jpg",[12,70,71],{},"After creating, find the application you just created, click \"Bot\" on the left, and you'll see \"Reset Token\" — click to get the Token:",[12,73,74],{},[15,75],{"alt":76,"src":77},"Get Token","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_4.jpg",[12,79,80],{},[81,82,83],"strong",{},"Don't leak this Token — we'll use it for practice later.",[12,85,86],{},[15,87],{"alt":88,"src":89},"Token is important","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1694789575685.png",[12,91,92],{},"The Token looks something like this (don't worry, I've already changed mine):",[94,95,100],"pre",{"className":96,"code":97,"language":98,"meta":99,"style":99},"language-bash shiki shiki-themes github-dark-high-contrast","MTE0ODExxxxxxxxxxxxxxxxxx.GJ6bFp.t1h86ISWswdqidu173ydwmawd1213P9mNj9qbXlhI\n","bash","",[101,102,103],"code",{"__ignoreMap":99},[104,105,108],"span",{"class":106,"line":107},"line",1,[104,109,97],{"class":110},"s_sBn",[12,112,113],{},"Some operations need permissions, so scroll down to \"Privileged Gateway Intents\". Turn on the permissions below:",[12,115,116],{},[15,117],{"alt":118,"src":119},"Privileged Gateway Intents","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_5.jpg",[12,121,122],{},"Finally, we add this Bot to our server. Click \"OAuth2\" to get the Client ID:",[12,124,125],{},[15,126],{"alt":127,"src":128},"Client ID","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_client_id.jpg",[12,130,131,132,134,135,138],{},"Then click \"Url Generator\" and check ",[101,133,29],{}," and ",[101,136,137],{},"Administrator",":",[12,140,141],{},[15,142],{"alt":143,"src":144},"Discord Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_6.jpg",[146,147,148],"blockquote",{},[12,149,150,153,154,156],{},[81,151,152],{},"Note","\nWe pick ",[81,155,137],{}," for practice convenience. In real-world dev, you'd configure permissions based on the Bot's needs.",[12,158,159],{},"Scroll down and you'll see the invite link. Copy and paste it in your browser, then pick the server to add — done.",[12,161,162],{},[15,163],{"alt":164,"src":165},"Discord Url 2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_url.jpg",[146,167,168],{},[12,169,170,172,173,178],{},[81,171,152],{},"\nDiscord is a gaming community app (many tech communities have moved over too). You can build a server, invite friends, chat, play games, etc. If interested, see my post ",[38,174,177],{"href":175,"rel":176},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20220428\u002F1571298383\u002F",[42],"Discord too hard? Don't worry, I'll teach you (article in Mandarin)",".",[20,180,182],{"id":181},"project-setup","Project setup",[12,184,185],{},"Set up a project:",[94,187,189],{"className":96,"code":188,"language":98,"meta":99,"style":99},"mkdir discord-bot-example\ncd discord-bot-example\nnpm init -y\ntouch index.js\ntouch register.js\n",[101,190,191,200,209,221,230],{"__ignoreMap":99},[104,192,193,196],{"class":106,"line":107},[104,194,195],{"class":110},"mkdir",[104,197,199],{"class":198},"sTRMh"," discord-bot-example\n",[104,201,203,207],{"class":106,"line":202},2,[104,204,206],{"class":205},"sCcAr","cd",[104,208,199],{"class":198},[104,210,212,215,218],{"class":106,"line":211},3,[104,213,214],{"class":110},"npm",[104,216,217],{"class":198}," init",[104,219,220],{"class":205}," -y\n",[104,222,224,227],{"class":106,"line":223},4,[104,225,226],{"class":110},"touch",[104,228,229],{"class":198}," index.js\n",[104,231,233,235],{"class":106,"line":232},5,[104,234,226],{"class":110},[104,236,237],{"class":198}," register.js\n",[12,239,240,241,244],{},"Then install ",[101,242,243],{},"discord.js"," — the package for implementing Discord Bots:",[94,246,248],{"className":96,"code":247,"language":98,"meta":99,"style":99},"npm i discord.js\n",[101,249,250],{"__ignoreMap":99},[104,251,252,254,257],{"class":106,"line":107},[104,253,214],{"class":110},[104,255,256],{"class":198}," i",[104,258,259],{"class":198}," discord.js\n",[12,261,262],{},"This is from Discord officially, so safe to use.",[146,264,265],{},[12,266,267,269],{},[81,268,152],{},"\nIf you're familiar with other languages, you can also try Python, Go, etc.",[12,271,272],{},"Heads up — for the upcoming implementation we'll use a newer Discord Bot version, so I'd suggest switching to Node.js 18:",[94,274,276],{"className":96,"code":275,"language":98,"meta":99,"style":99},"nvm use 18\n",[101,277,278],{"__ignoreMap":99},[104,279,280,283,286],{"class":106,"line":107},[104,281,282],{"class":110},"nvm",[104,284,285],{"class":198}," use",[104,287,288],{"class":205}," 18\n",[20,290,292],{"id":291},"implementation","Implementation",[12,294,295,296,301],{},"Now we'll implement a simple Discord Bot. Where to start? The ",[38,297,300],{"href":298,"rel":299},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fdiscord.js",[42],"official docs"," provide example code, but it's based on ES6 syntax — let me walk through it.",[303,304,306],"h3",{"id":305},"registering-commands","Registering commands",[12,308,309],{},"First example — registering commands. Don't worry, I'll add line-by-line comments:",[94,311,315],{"className":312,"code":313,"language":314,"meta":99,"style":99},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F register.js\nconst {\n  REST, \u002F\u002F Import REST\n  Routes \u002F\u002F Import Routes\n} = require('discord.js'); \u002F\u002F Import discord.js package\n\n\u002F\u002F Command list\nconst list = [\n  {\n    name: 'ping', \u002F\u002F Command name\n    description: 'Replies with Pong!', \u002F\u002F Command description\n  },\n];\n\n\u002F\u002F Instantiate REST, set version and Token\nconst rest = new REST({ version: '10' }).setToken(TOKEN);\n\nconst registerCommands = async (commands) => {\n  try {\n    console.log('Started refreshing application (\u002F) commands.');\n    \u002F\u002F Register commands\n    await rest.put(Routes.applicationCommands(CLIENT_ID), { body: commands });\n\n    console.log('Successfully reloaded application (\u002F) commands.');\n  } catch (error) {\n    console.error(error);\n  }\n}\n\n\u002F\u002F Execute command registration\nregisterCommands(list);\n","js",[101,316,317,323,333,344,352,376,383,389,403,409,423,437,443,449,454,460,496,501,528,536,552,558,584,589,603,615,626,632,638,643,649],{"__ignoreMap":99},[104,318,319],{"class":106,"line":107},[104,320,322],{"class":321},"sQrFR","\u002F\u002F register.js\n",[104,324,325,329],{"class":106,"line":202},[104,326,328],{"class":327},"sWyjQ","const",[104,330,332],{"class":331},"sMAXC"," {\n",[104,334,335,338,341],{"class":106,"line":211},[104,336,337],{"class":205},"  REST",[104,339,340],{"class":331},", ",[104,342,343],{"class":321},"\u002F\u002F Import REST\n",[104,345,346,349],{"class":106,"line":