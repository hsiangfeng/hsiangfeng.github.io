[{"data":1,"prerenderedAt":1749},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2020\u002F12\u002F29\u002Fauto-generate-api-docs-with-swagger\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2020\u002F12\u002F29\u002Fauto-generate-api-docs-with-swagger\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2020\u002F12\u002F29\u002Fauto-generate-api-docs-with-swagger\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2020\u002F12\u002F29\u002Fauto-generate-api-docs-with-swagger\u002F":1724,"related:\u002Fen\u002Fnodejs\u002F2020\u002F12\u002F29\u002Fauto-generate-api-docs-with-swagger\u002F":1733},"\u002Fnodejs\u002F20201229\u002F1974873838\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1707,"date":1708,"description":1709,"extension":1710,"lang":1711,"meta":1712,"navigation":170,"path":1713,"readingMinutes":1714,"seo":1715,"standalone":1716,"stem":1717,"tags":1718,"tldr":1721,"updated":1721,"url":1722,"__hash__":1723},"content\u002Fen\u002FNodejs\u002Fauto-generate-api-docs-with-swagger.md","Auto-Generating API Docs with Swagger","9748738381",{"type":9,"value":10,"toc":1698},"minimark",[11,16,20,24,37,40,44,47,53,64,70,73,90,97,102,105,114,117,120,123,130,231,234,246,249,252,475,478,685,688,720,727,733,744,747,750,822,833,838,842,845,1120,1123,1270,1273,1396,1399,1402,1408,1651,1660,1663,1670,1674,1694],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"When building backends, writing API docs after finishing dev is usually mandatory. This post covers how to auto-generate them.",[12,21,23],{"id":22},"environment","Environment",[25,26,27,31,34],"ul",{},[28,29,30],"li",{},"Node.js 14",[28,32,33],{},"Express",[28,35,36],{},"MacOS Big Sur",[17,38,39],{},"I'll list the environment, but sample code is included later.",[12,41,43],{"id":42},"auto-generating-api-docs","Auto-generating API docs",[17,45,46],{},"We're using Swagger. What's Swagger? Quoting Wikipedia:",[48,49,50],"blockquote",{},[17,51,52],{},"Swagger is a set of open-source software tools used to design, build, document, and consume RESTful web services. Swagger includes automated documentation, code generation, and test-case generation.",[17,54,55,56,63],{},"In short, it gives backend API integration a more intuitive GUI. With ",[57,58,62],"a",{"href":59,"rel":60},"https:\u002F\u002Fswagger.io\u002Ftools\u002Fswagger-ui\u002F",[61],"nofollow","Swagger UI",", you can generate a webpage where you can test APIs and inspect their state.",[17,65,66],{},[67,68],"img",{"alt":62,"src":69},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002Fswagger_ui.png",[17,71,72],{},"Enough preamble. How do we use it in our own project? I'll use Express as the template.",[74,75,80],"pre",{"className":76,"code":77,"language":78,"meta":79,"style":79},"language-cmd shiki shiki-themes github-dark-high-contrast","express --pug --css sass \u002F\u002F After this, cd into the directory and npm install\n","cmd","",[81,82,83],"code",{"__ignoreMap":79},[84,85,88],"span",{"class":86,"line":87},"line",1,[84,89,77],{},[17,91,92,93,96],{},"(I'm using \"Express application generator\" to scaffold. If you don't have it, install with ",[81,94,95],{},"npm install express-generator -g",".)",[17,98,99],{},[67,100],{"alt":33,"src":101},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202020-12-29%2020.41.23.png",[17,103,104],{},"Install the two key packages:",[74,106,108],{"className":76,"code":107,"language":78,"meta":79,"style":79},"npm install --save swagger-autogen swagger-ui-express\n",[81,109,110],{"__ignoreMap":79},[84,111,112],{"class":86,"line":87},[84,113,107],{},[12,115,116],{"id":116},"swagger-autogen",[17,118,119],{},"swagger-ui-express just adds the Swagger UI rendering to Express. The key auto-generation package is swagger-autogen.",[17,121,122],{},"What's swagger-autogen? In short: write comments in your API routers, and when you run swagger-autogen, it auto-generates API docs based on those comments. Pretty nice, right?",[17,124,125,126,129],{},"Create a ",[81,127,128],{},"swagger.js"," file:",[74,131,135],{"className":132,"code":133,"language":134,"meta":79,"style":79},"language-js shiki shiki-themes github-dark-high-contrast","const swaggerAutogen = require('swagger-autogen')();\n\nconst outputFile = '.\u002Fswagger_output.json'; \u002F\u002F Output filename\nconst endpointsFiles = ['.\u002Fapp.js']; \u002F\u002F The API entry point — usually app.js for Express\n\nswaggerAutogen(outputFile, endpointsFiles); \u002F\u002F swaggerAutogen method\n","js",[81,136,137,165,172,192,214,219],{"__ignoreMap":79},[84,138,139,143,147,150,154,158,162],{"class":86,"line":87},[84,140,142],{"class":141},"sWyjQ","const",[84,144,146],{"class":145},"sCcAr"," swaggerAutogen",[84,148,149],{"class":141}," =",[84,151,153],{"class":152},"sj_SG"," require",[84,155,157],{"class":156},"sMAXC","(",[84,159,161],{"class":160},"sTRMh","'swagger-autogen'",[84,163,164],{"class":156},")();\n",[84,166,168],{"class":86,"line":167},2,[84,169,171],{"emptyLinePlaceholder":170},true,"\n",[84,173,175,177,180,182,185,188],{"class":86,"line":174},3,[84,176,142],{"class":141},[84,178,179],{"class":145}," outputFile",[84,181,149],{"class":141},[84,183,184],{"class":160}," '.\u002Fswagger_output.json'",[84,186,187],{"class":156},"; ",[84,189,191],{"class":190},"sQrFR","\u002F\u002F Output filename\n",[84,193,195,197,200,202,205,208,211],{"class":86,"line":194},4,[84,196,142],{"class":141},[84,198,199],{"class":145}," endpointsFiles",[84,201,149],{"class":141},[84,203,204],{"class":156}," [",[84,206,207],{"class":160},"'.\u002Fapp.js'",[84,209,210],{"class":156},"]; ",[84,212,213],{"class":190},"\u002F\u002F The API entry point — usually app.js for Express\n",[84,215,217],{"class":86,"line":216},5,[84,218,171],{"emptyLinePlaceholder":170},[84,220,222,225,228],{"class":86,"line":221},6,[84,223,224],{"class":152},"swaggerAutogen",[84,226,227],{"class":156},"(outputFile, endpointsFiles); ",[84,229,230],{"class":190},"\u002F\u002F swaggerAutogen method\n",[17,232,233],{},"Now update the routers. By default, two routers are generated:",[25,235,236,241],{},[28,237,238],{},[81,239,240],{},"router\u002Findex.js",[28,242,243],{},[81,244,245],{},"router\u002Fusers.js",[17,247,248],{},"Add some more routes. Two writing styles:",[17,250,251],{},"First style:",[74,253,255],{"className":132,"code":254,"language":134,"meta":79,"style":79},"router.get('\u002F', function(req, res, next) {\n  res.send('respond with a resource');\n});\n\nrouter.post('\u002Fpost', function(req, res, next) {\n  res.send('respond with a resource');\n});\n\nrouter.put('\u002Fput', function(req, res, next) {\n  res.send('respond with a resource');\n});\n\nrouter.delete('\u002Fdelete', function(req, res, next) {\n  res.send('respond with a resource');\n});\n",[81,256,257,295,311,316,320,350,362,367,372,403,416,421,426,457,470],{"__ignoreMap":79},[84,258,259,262,265,267,270,273,276,278,282,284,287,289,292],{"class":86,"line":87},[84,260,261],{"class":156},"router.",[84,263,264],{"class":152},"get",[84,266,157],{"class":156},[84,268,269],{"class":160},"'\u002F'",[84,271,272],{"class":156},", ",[84,274,275],{"class":141},"function",[84,277,157],{"class":156},[84,279,281],{"class":280},"s_sBn","req",[84,283,272],{"class":156},[84,285,286],{"class":280},"res",[84,288,272],{"class":156},[84,290,291],{"class":280},"next",[84,293,294],{"class":156},") {\n",[84,296,297,300,303,305,308],{"class":86,"line":167},[84,298,299],{"class":156},"  res.",[84,301,302],{"class":152},"send",[84,304,157],{"class":156},[84,306,307],{"class":160},"'respond with a resource'",[84,309,310],{"class":156},");\n",[84,312,313],{"class":86,"line":174},[84,314,315],{"class":156},"});\n",[84,317,318],{"class":86,"line":194},[84,319,171],{"emptyLinePlaceholder":170},[84,321,322,324,327,329,332,334,336,338,340,342,344,346,348],{"class":86,"line":216},[84,323,261],{"class":156},[84,325,326],{"class":152},"post",[84,328,157],{"class":156},[84,330,331],{"clas