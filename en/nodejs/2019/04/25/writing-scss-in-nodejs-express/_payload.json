[{"data":1,"prerenderedAt":384},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2019\u002F04\u002F25\u002Fwriting-scss-in-nodejs-express\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2019\u002F04\u002F25\u002Fwriting-scss-in-nodejs-express\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2019\u002F04\u002F25\u002Fwriting-scss-in-nodejs-express\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2019\u002F04\u002F25\u002Fwriting-scss-in-nodejs-express\u002F":359,"related:\u002Fen\u002Fnodejs\u002F2019\u002F04\u002F25\u002Fwriting-scss-in-nodejs-express\u002F":368},"\u002Fnodejs\u002F20190425\u002F1258950236\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":342,"date":343,"description":344,"extension":345,"lang":346,"meta":347,"navigation":348,"path":349,"readingMinutes":350,"seo":351,"standalone":352,"stem":353,"tags":354,"tldr":356,"updated":356,"url":357,"__hash__":358},"content\u002Fen\u002FNodejs\u002Fwriting-scss-in-nodejs-express.md","Writing SCSS in Node.js Express","6258950321",{"type":9,"value":10,"toc":337},"minimark",[11,16,20,24,27,44,47,56,59,62,69,78,81,90,93,180,191,201,205,208,211,220,223,251,258,322,333],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"I've been learning Node.js + Express development. Since I learned SCSS as my preprocessor, but couldn't find good resources online for using it here, here's a note...",[12,21,23],{"id":22},"if-you-havent-built-express-yet","If you haven't built Express yet",[17,25,26],{},"First, install Express globally. Open CMD and run:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-cmd shiki shiki-themes github-dark-high-contrast","npm install express -g\n","cmd","",[35,36,37],"code",{"__ignoreMap":33},[38,39,42],"span",{"class":40,"line":41},"line",1,[38,43,31],{},[17,45,46],{},"Once that's done, navigate to your target folder:",[28,48,50],{"className":30,"code":49,"language":32,"meta":33,"style":33},"cd ...folder path\n",[35,51,52],{"__ignoreMap":33},[38,53,54],{"class":40,"line":41},[38,55,49],{},[17,57,58],{},"Then run the Express command to scaffold:",[17,60,61],{},"--view is the template engine (pug, ejs, etc.)\n--css is the CSS preprocessor",[17,63,64,65,68],{},"I use pug for development and want sass for CSS preprocessing.\n※ Don't type ",[35,66,67],{},"--css=scss"," — it doesn't work.",[28,70,72],{"className":30,"code":71,"language":32,"meta":33,"style":33},"express --view=pug --css=sass\n",[35,73,74],{"__ignoreMap":33},[38,75,76],{"class":40,"line":41},[38,77,71],{},[17,79,80],{},"Then install the required dependencies:",[28,82,84],{"className":30,"code":83,"language":32,"meta":33,"style":33},"npm install\n",[35,85,86],{"__ignoreMap":33},[38,87,88],{"class":40,"line":41},[38,89,83],{},[17,91,92],{},"Once installed, open app.js and find this section:",[28,94,98],{"className":95,"code":96,"language":97,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","app.use(sassMiddleware({\n  src: path.join(__dirname, 'public'),\n  dest: path.join(__dirname, 'public'),\n  indentedSyntax: true,\n  sourceMap: true\n}));\n","js",[35,99,100,119,138,152,165,174],{"__ignoreMap":33},[38,101,102,106,110,113,116],{"class":40,"line":41},[38,103,105],{"class":104},"sMAXC","app.",[38,107,109],{"class":108},"sj_SG","use",[38,111,112],{"class":104},"(",[38,114,115],{"class":108},"sassMiddleware",[38,117,118],{"class":104},"({\n",[38,120,122,125,128,131,135],{"class":40,"line":121},2,[38,123,124],{"class":104},"  src: path.",[38,126,127],{"class":108},"join",[38,129,130],{"class":104},"(__dirname, ",[38,132,134],{"class":133},"sTRMh","'public'",[38,136,137],{"class":104},"),\n",[38,139,141,144,146,148,150],{"class":40,"line":140},3,[38,142,143],{"class":104},"  dest: path.",[38,145,127],{"class":108},[38,147,130],{"class":104},[38,149,134],{"class":133},[38,151,137],{"class":104},[38,153,155,158,162],{"class":40,"line":154},4,[38,156,157],{"class":104},"  indentedSyntax: ",[38,159,161],{"class":160},"sCcAr","true",[38,163,164],{"class":104},",\n",[38,166,168,171],{"class":40,"line":167},5,[38,169,170],{"class":104},"  sourceMap: ",[38,172,173],{"class":160},"true\n",[38,175,177],{"class":40,"line":176},6,[38,178,179],{"class":104},"}));\n",[17,181,182,183,186,187,190],{},"Change ",[35,184,185],{},"indentedSyntax"," to ",[35,188,189],{},"false"," to write SCSS:",[192,193,194,198],"ul",{},[195,196,197],"li",{},"false = SCSS",[195,199,200],{},"true = SASS",[12,202,204],{"id":203},"if-you-already-have-an-express-project","If you already have an Express project",[17,206,207],{},"If Express is already built, you'll need to install an extra package.",[17,209,210],{},"First install node-sass-middleware:",[28,212,214],{"className":30,"code":213,"language":32,"meta":33,"style":33},"npm install --save node-sass-middleware\n",[35,215,216],{"__ignoreMap":33},[38,217,218],{"class":40,"line":41},[38,219,213],{},[17,221,222],{},"Then open app.js and paste in:",[28,224,226],{"className":95,"code":225,"language":97,"meta":33,"style":33},"var sassMiddleware = require('node-sass-middleware');\n",[35,227,228],{"__ignoreMap":33},[38,229,230,234,237,240,243,245,248],{"class":40,"line":41},[38,231,233],{"class":232},"sWyjQ","var",[38,235,236],{"class":104}," sassMiddleware ",[38,238,239],{"class":232},"=",[38,241,242],{"class":108}," require",[38,244,112],{"class":104},[38,246,247],{"class":133},"'node-sass-middleware'",[38,249,250],{"class":104},");\n",[17,252,253,254,257],{},"Find ",[35,255,256],{},"app.use(express.static(path.join(__dirname, 'public')));"," and paste the following code right before it:",[28,259,261],{"className":95,"code":260,"language":97,"meta":33,"style":33},"app.use(sassMiddleware({\n  src: path.join(__dirname, 'public'),\n  dest: path.join(__dirname, 'public'),\n  indentedSyntax: false, \u002F\u002F true = .sass and false = .scss\n  sourceMap: true\n}));\n",[35,262,263,275,287,299,312,318],{"__ignoreMap":33},[38,264,265,267,269,271,273],{"class":40,"line":4