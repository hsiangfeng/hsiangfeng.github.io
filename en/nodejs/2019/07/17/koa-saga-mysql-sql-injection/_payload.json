[{"data":1,"prerenderedAt":421},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sql-injection\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sql-injection\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sql-injection\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sql-injection\u002F":397,"related:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sql-injection\u002F":406},"\u002Fnodejs\u002F20190717\u002F3433181406\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":380,"date":381,"description":19,"extension":382,"lang":383,"meta":384,"navigation":385,"path":386,"readingMinutes":387,"seo":388,"standalone":389,"stem":390,"tags":391,"tldr":394,"updated":394,"url":395,"__hash__":396},"content\u002Fen\u002FNodejs\u002Fkoa-saga-mysql-sql-injection.md","Koa Saga: MySQL — SQL Injection","1406343318",{"type":9,"value":10,"toc":374},"minimark",[11,16,20,24,27,30,34,37,89,100,163,170,173,219,222,250,253,256,263,266,271,274,289,293,296,299,358,367,370],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"After basic SQL, let's talk about SQL injection — what it is and why it's dangerous.",[12,21,23],{"id":22},"sql-injection","SQL injection",[17,25,26],{},"SQL injection (also known as SQLi) is a particularly nasty attack class. I'll show an example shortly.",[17,28,29],{},"Where does it happen? Around SQL operations like SELECT, INSERT, UPDATE, DELETE. Attackers typically inject semicolons, comments, etc., into SQL strings to manipulate the query.",[12,31,33],{"id":32},"small-example","Small example",[17,35,36],{},"Suppose your site runs this SQL:",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-sql shiki shiki-themes github-dark-high-contrast","SELECT * FROM testtable WHERE name=\"tom\" AND t_id = 1\n","sql","",[45,46,47],"code",{"__i