a} AND t_id = ${b}`);\n",[45,177,178,189,199],{"__ignoreMap":43},[48,179,180,182,184,186],{"class":50,"line":51},[48,181,111],{"class":54},[48,183,114],{"class":64},[48,185,84],{"class":54},[48,187,188],{"class":74}," \"tom'#\"\n",[48,190,191,193,195,197],{"class":50,"line":122},[48,192,111],{"class":54},[48,194,127],{"class":64},[48,196,84],{"class":54},[48,198,88],{"class":87},[48,200,201,203,205,207,209,211,213,215,217],{"class":50,"line":134},[48,202,137],{"class":64},[48,204,141],{"class":140},[48,206,144],{"class":64},[48,208,147],{"class":74},[48,210,150],{"class":64},[48,212,153],{"class":74},[48,214,156],{"class":64},[48,216,159],{"class":74},[48,218,162],{"class":64},[17,220,221],{},"The result becomes:",[38,223,225],{"className":40,"code":224,"language":42,"meta":43,"style":43},"SELECT * FROM testtable WHERE name='tom'#' AND t_id = 1\n",[45,226,227],{"__ignoreMap":43},[48,228,229,231,233,235,237,239,241,244,247],{"class":50,"line":51},[48,230,55],{"class":54},[48,232,58],{"class":54},[48,234,61],{"class":54},[48,236,65],{"class":64},[48,238,68],{"class":54},[48,240,71],{"class":54},[48,242,243],{"class":74},"'tom'",[48,245,246],{"class":64},"#",[48,248,249],{"class":74},"' AND t_id = 1\n",[17,251,252],{},"What's the impact? Run it in SQL and find out.",[17,254,255],{},"Normally you'd find one tom (lowercase):",[17,257,258],{},[259,260],"img",{"alt":261,"src":262},"lowercase tom","https:\u002F\u002Fi.imgur.com\u002FYIx8yr8.png",[17,264,265],{},"After SQL injection:",[17,267,268],{},[259,269],{"alt":23,"src":270},"https:\u002F\u002Fi.imgur.com\u002FzMIsAX3.png",[17,272,273],{},"All TOMs got pulled. That's SQL injection — just one example.",[17,275,276,277,281,282,288],{},"It's extremely dangerous. An attacker can bypass authentication entirely. SQLi is sometimes called a ",[278,279,280],"strong",{},"fill-in-the-blank game",". See the ",[150,283,287],{"href":284,"rel":285},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002FSQL%E6%B3%A8%E5%85%A5",[286],"nofollow","Wikipedia page"," for more.",[12,290,292],{"id":291},"javascript-prevention","JavaScript prevention",[17,294,295],{},"Since this series is about Koa.js, I'll only cover JS solutions.",[17,297,298],{},"The standard defense is parameterized queries:",[38,300,302],{"className":102,"code":301,"language":104,"meta":43,"style":43},"var a = \"tom'#\"\nvar b = 1\nvar sql = connection.query(`SELECT * FROM testtable WHERE name=? AND t_id=?`, ['tom', 1]);\n",[45,303,304,314,324],{"__ignoreMap":43},[48,305,306,308,310,312],{"class":50,"line":51},[48,307,111],{"class":54},[48,309,114],{"class":64},[48,311,84],{"class":54},[48,313,188],{"class":74},[48,315,316,318,320,322],{"class":50,"line":122},[48,317,111],{"class":54},[48,319,127],{"class":64},[48,321,84],{"class":54},[48,323,88],{"class":87},[48,325,326,328,331,333,336,339,341,344,347,349,352,355],{"class":50,"line":134},[48,327,111],{"class":54},[48,329,330],{"class":64}," sql ",[48,332,84],{"class":54},[48,334,335],{"class":64}," connection.",[48,337,338],{"class":140},"query",[48,340,144],{"class":64},[48,342,343],{"class":74},"`SELECT * FROM testtable WHERE name=? AND t_id=?`",[48,345,346],{"class":64},", [",[48,348,243],{"class":74},[48,350,351],{"class":64},", ",[48,353,354],{"class":87},"1",[48,356,357],{"class":64},"]);\n",[17,359,360,361,366],{},"There are other methods too. See ",[150,362,365],{"href":363,"rel":364},"https:\u002F\u002Fsegmentfault.com\u002Fq\u002F1010000007607956",[286],"this reference (article in Mandarin)",".",[17,368,369],{},"Next, we'll get into the actual implementation.",[371,372,373],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-s