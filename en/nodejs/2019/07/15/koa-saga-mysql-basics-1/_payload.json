[{"data":1,"prerenderedAt":148},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F":123,"related:\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F":132},"\u002Fnodejs\u002F20190715\u002F976970526\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":106,"date":107,"description":19,"extension":108,"lang":109,"meta":110,"navigation":111,"path":112,"readingMinutes":113,"seo":114,"standalone":115,"stem":116,"tags":117,"tldr":120,"updated":120,"url":121,"__hash__":122},"content\u002Fen\u002FNodejs\u002Fkoa-saga-mysql-basics-1.md","Koa Saga: MySQL Basics (1)","5269769700",{"type":9,"value":10,"toc":99},"minimark",[11,16,20,24,35,44,48,51,60,66,69,75,78,81,87,90,96],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Time for something different. In the Express chapters I built a member system with Firebase + Express. Now let me build something with Koa + MySQL — but first some background.",[12,21,23],{"id":22},"what-is-mysql","What is MySQL?",[17,25,26,27,34],{},"In the Express series I introduced Firebase, a NoSQL database. See ",[28,29,33],"a",{"href":30,"rel":31},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20190628\u002F905867989\u002F",[32],"nofollow","my intro post (article in Mandarin)"," if you missed it.",[17,36,37,38,43],{},"MySQL is different — it uses SQL commands to operate on the database, and it's an open-source ",[28,39,42],{"href":40,"rel":41},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002F%E9%97%9C%E8%81%AF%E5%BC%8F%E8%B3%87%E6%96%99%E5%BA%AB%E7%AE%A1%E7%90%86%E7%B3%BB%E7%B5%B1",[32],"relational database (article in Mandarin)",". Tons of big sites use MySQL — Facebook, Google, you name it. (The original MySQL founder has since moved on to MariaDB, but learning MySQL transfers — MariaDB is built on top of MySQL.)",[12,45,47],{"id":46},"mysql-prep","MySQL prep",[17,49,50],{},"Time to set up MySQL. I'll go the simple route with XAMPP. (Use whatever MySQL setup you're comfortable with — XAMPP is just the easiest package.)",[17,52,53,54,59],{},"Open the ",[28,55,58],{"href":56,"rel":57},"https:\u002F\u002Fwww.apachefriends.org\u002Fzh_tw\u002Findex.html",[32],"XAMPP site",":",[17,61,62],{},[63,64],"img",{"alt":58,"src":65},"https:\u002F\u002Fi.imgur.com\u002FotLoGTk.png",[17,67,68],{},"Download the version for your OS and install:",[17,70,71],{},[63,72],{"alt":73,"src":74},"Install","https:\u002F\u002Fi.imgur.com\u002FCkCV4rq.png",[17,76,77],{},"It's mostly Next, Next, Next.",[17,79,80],{},"Open XAMPP. If a port is in use, you'll see a warning at the bottom:",[17,82,83],{},[63,84],{"alt":85,"src":86},"Port conflict","https:\u002F\u002Fi.imgur.com\u002FhB7dfOL.png",[17,88,89],{},"Otherwise, click MySQL Start:",[17,91,92],{},[63,93],{"alt":94,"src":95},"Start","https:\u002F\u002Fi.imgur.com\u002FUH4blKb.png",[17,97,98],{},"When the MySQL field lights up green, you're good.",{"title":100,"searchDepth":101,"depth":101,"links":102},"",2,[103,104,105],{"id":14,"depth":101,"text":15},{"id":22,"depth":101,"text":23},{"id":46,"depth":101,"text":47},"Nodejs","2019-07-15 10:11:32","md","en",{},true,"\u002Fen\u002Fnodejs\u002Fkoa-saga-mysql-basics-1","1",{"title":6,"description":19},false,"en\u002FNodejs\u002Fkoa-saga-mysql-basics-1",[118,119],"Node.js","Koa Saga",null,"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F","q9_5UP6W8tHMrNYyOKEHfqLtXTdGQrXI6cIcTBZg17k",{"newer":124,"older":128},{"url":125,"title":126,"date":127},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-2\u002F","Koa Saga: MySQL Basics (2)","2019-07-15 10:35:15",{"url":129,"title":130,"date":131},"