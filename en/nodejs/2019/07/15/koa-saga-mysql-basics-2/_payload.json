lass":173},[160,275,255],{"class":166},[160,277,278],{"class":166}," default",[160,280,282],{"class":281},"sTRMh"," ''",[160,284,285],{"class":173},",\n",[160,287,288,291,294,296,298,300,302,304,307],{"class":162,"line":196},[160,289,290],{"class":166},"    weight",[160,292,293],{"class":166}," int",[160,295,245],{"class":173},[160,297,271],{"class":248},[160,299,252],{"class":173},[160,301,255],{"class":166},[160,303,278],{"class":166},[160,305,306],{"class":248}," 0",[160,308,285],{"class":173},[160,310,311,314,317,319,321,323,325,327,329],{"class":162,"line":202},[160,312,313],{"class":173},"    height ",[160,315,316],{"class":166},"float",[160,318,245],{"class":173},[160,320,271],{"class":248},[160,322,252],{"class":173},[160,324,255],{"class":166},[160,326,278],{"class":166},[160,328,306],{"class":248},[160,330,285],{"class":173},[160,332,333,336],{"class":162,"line":211},[160,334,335],{"class":166},"    PRIMARY KEY",[160,337,338],{"class":173}," (t_id)\n",[160,340,342,345,348,351],{"class":162,"line":341},7,[160,343,344],{"class":173},"  ) AUTO_INCREMENT",[160,346,347],{"class":166},"=",[160,349,350],{"class":248},"1",[160,352,353],{"class":173},";\n",[17,355,356],{},"Notes:",[358,359,360,364,367,370,373],"ul",{},[361,362,363],"li",{},"NOT NULL — can't be empty",[361,365,366],{},"auto_increment — auto-filled",[361,368,369],{},"default — default value",[361,371,372],{},"PRIMARY KEY — primary key",[361,374,375],{},"AUTO_INCREMENT — auto-increment, starts at 1",[17,377,378],{},"Paste and execute:",[17,380,381],{},[41,382],{"alt":383,"src":384},"Execute SQL","https:\u002F\u002Fi.imgur.com\u002FesqSrwT.png",[17,386,387],{},"Hit F5 to refresh and you'll see the new table:",[17,389,390],{},[41,391],{"alt":392,"src":393},"Table","https:\u002F\u002Fi.imgur.com\u002FXt9o3Ac.png",[17,395,396],{},"The structure matches what we wrote:",[17,398,399],{},[41,400],{"alt":401,"src":402},"Table structure","https:\u002F\u002Fi.imgur.com\u002FnOxa0gL.png",[17,404,405],{},"Right-click the table and choose \"Design Table\" to verify:",[17,407,408],{},[41,409],{"alt":410,"src":411},"Design","https:\u002F\u002Fi.imgur.com\u002FksCjIOo.png",[17,413,414],{},[41,415],{"alt":410,"src":416},"https:\u002F\u002Fi.imgur.com\u002F16sj6RQ.png",[17,418,419],{},"That's how you create a table via SQL.",[12,421,423],{"id":422},"select","SELECT",[17,425,426,427,430],{},"Type ",[61,428,429],{},"SELECT * FROM account;"," and execute:",[17,432,433],{},[41,434],{"alt":423,"src":435},"https:\u002F\u002Fi.imgur.com\u002FBKiKWPn.png",[17,437,438],{},"Empty result is expected since we haven't added data:",[17,440,441],{},[41,442],{"alt":443,"src":444},"Empty result","https:\u002F\u002Fi.imgur.com\u002FIsfa7O8.png",[446,447,449],"h3",{"id":448},"where","WHERE",[17,451,452],{},"Quick syntax tour.",[17,454,455,457,458,461,462,466,467,469,470],{},[61,456,423],{}," is the most common SQL command. ",[61,459,460],{},"SELECT * FROM account"," means ",[463,464,465],"strong",{},"return all rows in the table",". To filter, use ",[61,468,449],{},": ",[61,471,472],{},"SELECT * FROM account WHERE aid = 1;",[17,474,475],{},"This means \"find rows in account where aid equals 1\". (I added some data first.) Result:",[17,477,478],{},[41,479],{"alt":480,"src":481},"Query","https:\u002F\u002Fi.imgur.com\u002FVGGRYNQ.png",[17,483,484,485,488,489,492,493,496],{},"You can use ",[61,486,487],{},"\u003C=",", ",[61,490,491],{},">=",", etc. Let me test against ",[61,494,495],{},"testtabel"," — find anyone with weight under 66:",[151,498,500],{"className":153,"code":499,"language":155,"meta":156,"style":156},"SELECT * FROM testtabel WHERE weight \u003C= 66;\n",[61,501,502],{"__ignoreMap":156},[160,503,504,506,509,512,515,517,520,523,526],{"class":162,"line":163},[160,505,423],{"class":166},[160,507,508],{"class":166}," *",[160,510,511],{"class":166}," FROM",[160,513,514],{"class":173}," testtabel ",[160,516,449],{"class":166},[160,518,519],{"class":166}," weight",[160,521,522],{"class":166}," \u003C=",[160,524,525],{"class":248}," 66",[160,527,353],{"class":173},[17,529,530],{},"You'll find tom and Tom (two people with similar names):",[17,532,533],{},[41,534],{"alt":535,"src":536},"tom","https:\u002F\u002Fi.imgur.com\u002FL1P1HdW.png",[17,538,539,540,117],{},"For sorting (ascending by default), use ",[61,541,542],{},"ORDER BY",[151,544,546],{"className":153,"code":545,"language":155,"meta":156,"style":156},"SELECT * FROM testtabel ORDER BY height\n",[61,547,548],{"__ignoreMap":156},[160,549,550,552,554,556,558,560],{"class":162,"line":163},[160,551,423],{"class":166},[160,553,508],{"class":166},[160,555,511],{"class":166},[160,557,514],{"class":173},[160,559,542],{"class":166},[160,561,562],{"class":173}," height\n",[17,564,565],{},[41,566],{"alt":542,"src":567},"https:\u002F\u002Fi.imgur.com\u002Fcl9hW0o.png",[17,569,570],{},"You can combine WHERE + ORDER BY, but filter first, then sort:",[17,572,573],{},[41,574],{"alt":575,"src":576},"Filter first, then sort","https:\u002F\u002Fi.imgur.com\u002FgbACNN8.png",[17,578,579,580],{},"Correct form: ",[61,581,582],{},"SELECT * FROM testtabel WHERE weight >= 66 ORDER BY height;",[17,584,585],{},[41,586],{"alt":587,"src":588},"Filter then sort","https:\u002F\u002Fi.imgur.com\u002FR4N6oj2.png",[17,590,591,592,117],{},"For descending order, append ",[61,593,594],{},"DESC",[151,596,598],{"className":153,"code":597,"language":155,"meta":156,"style":156},"SELECT * FROM testtabel WHERE weight >= 66 ORDER BY height DESC;\n",[61,599,600],{"__ignoreMap":156},[160,601,602,604,606,608,610,612,614,617,619,622,625,627],{"class":162,"line":163},[160,603,423],{"class":166},[160,605,508],{"class":166},[160,607,511],{"class":166},[160,609,514],{"class":173},[160,611,449],{"class":166},[160,613,519],{"class":166},[160,615,616],{"class":166}," >=",[160,618,525],{"class":248},[160,620,621],{"class":166}," ORDER BY",[160,623,624],{"class":173}," height ",[160,626,594],{"class":166},[160,628,353],{"class":173},[17,630,631],{},[41,632],{"alt":594,"src":633},"https:\u002F\u002Fi.imgur.com\u002FnE5PKNc.png",[12,635,637],{"id":636},"notes","Notes",[17,639,640],{},"Other conditions:",[358,642,643,649,664,670],{},[361,644,645,648],{},[61,646,647],{},"GROUP BY"," — group rows by a column",[361,650,651,654,655,657,658,660,661,663],{},[61,652,653],{},"HAVING"," — must pair with ",[61,656,647],{},"; similar to ",[61,659,449],{}," but applied after grouping (can't replace ",[61,662,449],{},")",[361,665,666,669],{},[61,667,668],{},"DISTINCT"," — unique values",[361,671,672,675],{},[61,673,674],{},"LIMIT"," — limit row count",[17,677,678],{},"I won't cover these in the upcoming examples, but they'll come up if needed.",[680,681,682],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":156,"searchDepth":184,"depth":184,"links":684},[685,686,687,688,689,692],{"id":14,"depth":184,"text":15},{"id":22,"depth":184,"text":23},{"id":129,"depth":184,"text":130},{"id":145,"depth":184,"text":146},{"id":422,"depth":184,"text":423,"children":690},[691],{"id":448,"depth":190,"text":449},{"id":636,"depth":184,"text":637},"Nodejs","2019-07-15 10:35:15","We've got MySQL ready. Now let me use a DB management tool to operate on it.","