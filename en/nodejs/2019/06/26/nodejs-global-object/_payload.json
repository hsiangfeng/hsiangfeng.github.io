terminal, type ",[21,64,65],{},"node",", and then type ",[21,68,46],{},":",[17,71,72],{},[38,73],{"alt":46,"src":74},"https:\u002F\u002Fi.imgur.com\u002Ff8WhLrq.png",[17,76,77],{},"All that stuff underneath is the global object. We can test it like this:",[79,80,85],"pre",{"className":81,"code":82,"language":83,"meta":84,"style":84},"language-js shiki shiki-themes github-dark-high-contrast","var a = 1;\n","js","",[21,86,87],{"__ignoreMap":84},[88,89,92,96,100,103,107],"span",{"class":90,"line":91},"line",1,[88,93,95],{"class":94},"sWyjQ","var",[88,97,99],{"class":98},"sMAXC"," a ",[88,101,102],{"class":94},"=",[88,104,106],{"class":105},"sCcAr"," 1",[88,108,109],{"class":98},";\n",[17,111,112,113,116,117,120],{},"Then type ",[21,114,115],{},"global.a",", and you'll get back ",[21,118,119],{},"1",".",[17,122,123],{},[38,124],{"alt":115,"src":125},"https:\u002F\u002Fi.imgur.com\u002F0fYvZga.png",[17,127,128,129,131,132,135],{},"You can also type ",[21,130,46],{}," again to check whether ",[21,133,134],{},"a"," is in there:",[17,137,138],{},[38,139],{"alt":46,"src":140},"https:\u002F\u002Fi.imgur.com\u002FWcltgfu.png",[17,142,143,144,146,147,120],{},"So basically, Node.js's ",[21,145,46],{}," concept is pretty much the same as ",[21,148,23],{},[17,150,151,152,155,156,159],{},"But here's the interesting part. If you run things with ",[21,153,154],{},"node all.js"," instead, and ",[21,157,158],{},"all.js"," looks like this:",[79,161,163],{"className":81,"code":162,"language":83,"meta":84,"style":84},"var a = 1;\nconsole.log(global);\n",[21,164,165,177],{"__ignoreMap":84},[88,166,167,169,171,173,175],{"class":90,"line":91},[88,168,95],{"class":94},[88,170,99],{"class":98},[88,172,102],{"class":94},[88,174,106],{"class":105},[88,176,109],{"class":98},[88,178,180,183,187],{"class":90,"line":179},2,[88,181,182],{"class":98},"console.",[88,184,186],{"class":185},"sj_SG","log",[88,188,189],{"class":98},"(global);\n",[17,191,192,193,195,196,198],{},"You'll find there's no ",[21,194,134],{}," under ",[21,197,46],{},". Unless you write it like this:",[79,200,202],{"className":81,"code":201,"language":83,"meta":84,"style":84},"global.a = 1;\nconsole.log(global);\n",[21,203,204,215],{"__ignoreMap":84},[88,205,206,209,211,213],{"class":90,"line":91},[88,207,208],{"class":98},"global.a ",[88,210,102],{"class":94},[88,212,106],{"class":105},[88,214,109],{"class":98},[88,216,217,219,221],{"class":90,"line":179},[88,218,182],{"class":98},[88,220,186],{"class":185},[88,222,189],{"class":98},[17,224,225,226,228,229,120],{},"Only then will you see ",[21,227,134],{}," on ",[21,230,46],{},[17,232,233],{},[38,234],{"alt":46,"src":235},"https:\u002F\u002Fi.imgur.com\u002F7GdeQZH.png",[17,237,238,239,242,243,120],{},"So if you want to make a variable or method available to others, you have to create it with ",[21,240,241],{},"global.xxx",", not ",[21,244,95],{},[17,246,247,248,251,252,255],{},"The reason is that Node.js is modular — a ",[21,249,250],{},"var a"," or ",[21,253,254],{},"var b"," written in one file won't interfere with another file. For example:",[17,257,158],{},[79,259,260],{"className":81,"code":82,"language":83,"meta":84,"style":84},[21,261,262],{"__ignoreMap":84},[88,263,264,266,268,270,272],{"class":90,"line":91},[88,265,95],{"class":94},[88,267,99],{"class":98},[88,269,102],{"class":94},[88,271,106],{"class":105},[88,273,109],{"class":98},[17,275,276],{},"all1.js",[79,278,280],{"className":81,"code":279,"language":83,"meta":84,"style":84},"var a = 2;\n",[21,281,282],{"__ignoreMap":84},[88,283,284,286,288,290,293],{"class":90,"line":91},[88,285,95],{"class":94},[88,287,99],{"class":98},[88,289,102],{"class":94},[88,291,292],{"class":105}," 2",[88,294,109],{"class":98},[17,296,297,298,300],{},"These two won't clash. You'd only switch to ",[21,299,115],{}," if you specifically want everyone to share it.",[302,303,304],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html co