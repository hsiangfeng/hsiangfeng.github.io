[{"data":1,"prerenderedAt":258},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnodejs-repl-mode\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnodejs-repl-mode\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnodejs-repl-mode\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnodejs-repl-mode\u002F":233,"related:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnodejs-repl-mode\u002F":242},"\u002Fnodejs\u002F20190626\u002F658065960\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":216,"date":217,"description":218,"extension":219,"lang":220,"meta":221,"navigation":222,"path":223,"readingMinutes":111,"seo":224,"standalone":225,"stem":226,"tags":227,"tldr":230,"updated":230,"url":231,"__hash__":232},"content\u002Fen\u002FNodejs\u002Fnodejs-repl-mode.md","Node.js Basics, Part 2: Writing JavaScript Right in the REPL","5810420198",{"type":9,"value":10,"toc":211},"minimark",[11,16,20,24,40,43,50,66,69,75,78,133,136,141,147,177,180,185,188,194,198,201,207],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This one's going to be pretty short. It's mostly a note that you can use Node's REPL mode to write JavaScript directly.",[12,21,23],{"id":22},"running-code-in-node","Running code in node",[17,25,26,27,31,32,35,36,39],{},"In the previous post we saw that you can create a folder and a file, ",[28,29,30],"code",{},"cd"," into the project directory, and run ",[28,33,34],{},"node all.js"," to print ",[28,37,38],{},"HelloWorld",".",[17,41,42],{},"But if you don't want to bother with all that, you can actually write JavaScript right in the terminal.",[17,44,45,46,49],{},"First, open your terminal and type ",[28,47,48],{},"node",":",[51,52,57],"pre",{"className":53,"code":54,"language":55,"meta":56,"style":56},"language-cmd shiki shiki-themes github-dark-high-contrast","node\n","cmd","",[28,58,59],{"__ignoreMap":56},[60,61,64],"span",{"class":62,"line":63},"line",1,[60,65,54],{},[17,67,68],{},"You'll notice a new prompt arrow appears.",[17,70,71],{},[72,73],"img",{"alt":48,"src":74},"https:\u002F\u002Fi.imgur.com\u002FCeaAHiw.png",[17,76,77],{},"Now try typing this in:",[51,79,83],{"className":80,"code":81,"language":82,"meta":56,"style":56},"language-js shiki shiki-themes github-dark-high-contrast","console.log('HelloWorld');\n1+1;\n10+10;\n","js",[28,84,85,105,121],{"__ignoreMap":56},[60,86,87,91,95,98,102],{"class":62,"line":63},[60,88,90],{"class":89},"sMAXC","console.",[60,92,94],{"class":93},"sj_SG","log",[60,96,97],{"class":89},"(",[60,99,101],{"class":100},"sTRMh","'HelloWorld'",[60,103,104],{"class":89},");\n",[60,106,108,112,116,118],{"class":62,"line":107},2,[60,109,111],{"class":110},"sCcAr","1",[60,113,115],{"class":114},"sWyjQ","+",[60,117,111],{"class":110},[60,119,120],{"class":89},";\n",[60,122,124,127,129,131],{"class":62,"line":123},3,[60,125,126],{"class":110},"10",[60,128,115],{"class":114},[60,130,126],{"class":110},[60,132,120],{"class":89},[17,134,135],{},"And you'll see you can write JavaScript just fine.",[17,137,138],{},[72,139],{"alt":48,"src":140},"https:\u002F\u002Fi.imgur.com\u002FoGclE60.png",[17,142,143,144,146],{},"So we can create a variable and print ",[28,145,38],{}," by passing it through:",[51,148,150],{"className":80,"code":149,"language":82,"meta":56,"style":56},"var sayHi = 'HelloWorld';\nconsole.log(sayHi);\n",[28,151,152,168],{"__ignoreMap":56},[60,153,154,157,160,163,166],{"class":62,"line":63},[60,155,156],{"class":114},"var",[60,158,159],{"class":89}," sayHi ",[60,161,162],{"class":114},"=",[60,164,165],{"class":100}," 'HelloWorld'",[60,167,120],{"class":89},[60,169,170,172,174],{"class":62,"line":107},[60,171,90],{"class":89},[60,173,94],{"class":93},[60,175,176],{"class":89},"(sayHi);\n",[17,178,179],{},"And that's the REPL mode for writing JavaScript.",[17,181,182],{},[72,183],{"alt":48,"src":184},"https:\u002F\u002Fi.imgur.com\u002Fv1evMJd.png",[17,186,187],{},