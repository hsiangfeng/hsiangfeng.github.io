[{"data":1,"prerenderedAt":349},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F":325,"related:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F":334},"\u002Fnodejs\u002F20190626\u002F1317979814\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":309,"date":310,"description":19,"extension":311,"lang":312,"meta":313,"navigation":314,"path":315,"readingMinutes":316,"seo":317,"standalone":318,"stem":319,"tags":320,"tldr":322,"updated":322,"url":323,"__hash__":324},"content\u002Fen\u002FNodejs\u002Fnpm-install-command-variations.md","npm Install Command Variations","1317979821",{"type":9,"value":10,"toc":291},"minimark",[11,16,20,24,27,34,39,65,69,78,82,97,101,104,119,122,126,141,154,157,161,180,186,189,193,202,209,213,222,225,229,238,244,248,262,268,272,275,281,287],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Quick notes on npm install variations so I don't forget — even though I type them all the time.",[12,21,23],{"id":22},"basic-commands","Basic commands",[17,25,26],{},"I've covered most of this in another tutorial series, but pulling out this section for standalone reference.",[17,28,29],{},[30,31],"img",{"alt":32,"src":33},"npm","https:\u002F\u002Fi.imgur.com\u002FT6EsjSb.png",[35,36,38],"h3",{"id":37},"check-the-npm-version","Check the npm version",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","npm -v\n","js","",[47,48,49],"code",{"__ignoreMap":45},[50,51,54,58,62],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sMAXC","npm ",[50,59,61],{"class":60},"sWyjQ","-",[50,63,64],{"class":56},"v\n",[35,66,68],{"id":67},"initialize-npm","Initialize npm",[40,70,72],{"className":42,"code":71,"language":44,"meta":45,"style":45},"npm init\n",[47,73,74],{"__ignoreMap":45},[50,75,76],{"class":52,"line":53},[50,77,71],{"class":56},[35,79,81],{"id":80},"initialize-npm-skip-prompts-use-defaults","Initialize npm (skip prompts, use defaults)",[40,83,85],{"className":42,"code":84,"language":44,"meta":45,"style":45},"npm init -y\n",[47,86,87],{"__ignoreMap":45},[50,88,89,92,94],{"class":52,"line":53},[50,90,91],{"class":56},"npm init ",[50,93,61],{"class":60},[50,95,96],{"class":56},"y\n",[35,98,100],{"id":99},"global-install","Global install",[17,102,103],{},"(using gulp as example)",[40,105,107],{"className":42,"code":106,"language":44,"meta":45,"style":45},"npm install gulp -g\n",[47,108,109],{"__ignoreMap":45},[50,110,111,114,116],{"class":52,"line":53},[50,112,113],{"class":56},"npm install gulp ",[50,115,61],{"class":60},[50,117,118],{"class":56},"g\n",[17,120,121],{},"Global install means installing on your machine, not in the project folder. If the package is only for your own dev workflow (e.g. ESLint), global install is fine — but check the package's docs first.",[35,123,125],{"id":124},"project-install","Project install",[40,127,129],{"className":42,"code":128,"language":44,"meta":45,"style":45},"npm install gulp --save\n",[47,130,131],{"__ignoreMap":45},[50,132,133,135,138],{"class":52,"line":53},[50,134,113],{"class":56},[50,136,137],{"class":60},"--",[50,139,140],{"class":56},"save\n",[17,142,143,146,147,150,151,153],{},[47,144,145],{},"--save"," installs into the project directory. You need to run ",[47,148,149],{},"npm init"," first. With ",[47,152,145],{},", the package info gets recorded in package.json.",[17,155,156],{},"The package info is written into package.json's \"dependencies\" field.",[35,158,160],{"id":159},"project-dev-environment-install","Project dev-environment install",[40,162,164],{"className":42,"code":163,"language":44,"meta":45,"style":45},"npm install gulp --save-dev\n",[47,165,166],{"__ignoreMap":45},[50,167,168,170,172,175,177],{"class":52,"line":53},[50,169,113],{"class":56},[50,171,137],{"class":60},[50,173,174],{"class":56},"save",[50,176,61],{"class":60},[50,178,179],{"class":56},"dev\n",[17,181,182,183,185],{},"This means the package only runs in dev mode, not in production. If you're not sure, just use ",[47,184,145],{},".",[17,187,188],{},"The package info is written into package.json's \"devDependencies\" field.",[35,190,192],{"id":191},"restore-packages","Restore packages",[40,194,196],{"className":42,"code":195,"language":44,"meta":45,"style":45},"npm install\n",[47,197,198],{"__ignoreMap":45},[50,199,200],{"class":52,"line":53},[50,201,195],{"class":56},[17,203,204,205,208],{},"When taking over someone else's project, run ",[47,206,207],{},"npm install"," to restore the dev environment.",[35,210,212],{"id":211},"list-installed-packages","List installed packages",[40,214,216],{"className":42,"code":215,"language":44,"meta":45,"style":45},"npm list\n",[47,217,218],{"__ignoreMap":45},[50,219,220],{"class":52,"line":53},[50,221,215],{"class":56},[17,223,224],{},"Lists the packages currently installed in the project.",[35,226,228],{"id":227},"remove-a-package","Remove a package",[40,230,232],{"className":42,"code":231,"language":44,"meta":45,"style":45},"npm uninstall [package name]\n",[47,233,234],{"__ignoreMap":45},[50,235,236],{"class":52,"line":53},[50,237,231],{"class":56},[17,239,240,241],{},"E.g. to remove gulp: ",[47,242,243],{},"npm uninstall gulp",[35,245,247],{"id":246},"remove-a-global-package","Remove a global package",[40,249,251],{"className":42,"code":250,"language":44,"meta":45,"style":45},"npm uninstall [package name] -g\n",[47,252,253],{"__ignoreMap":45},[50,254,255,258,260],{"class":52,"line":53},[50,256,257],{"class":56},"npm uninstall [package name] ",[50,259,61],{"class":60},[50,261,118],{"cl