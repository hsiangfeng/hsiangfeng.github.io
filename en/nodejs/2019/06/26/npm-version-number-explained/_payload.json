[{"data":1,"prerenderedAt":201},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F":3,"page:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F":4,"alt:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F":3,"prev-next:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F":176,"related:\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F":185},"\u002Fnodejs\u002F20190626\u002F2459037265\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":159,"date":160,"description":161,"extension":162,"lang":163,"meta":164,"navigation":165,"path":166,"readingMinutes":167,"seo":168,"standalone":169,"stem":170,"tags":171,"tldr":173,"updated":173,"url":174,"__hash__":175},"content\u002Fen\u002FNodejs\u002Fnpm-version-number-explained.md","Reading npm Version Numbers","3540627259",{"type":9,"value":10,"toc":154},"minimark",[11,16,20,24,27,34,37,66,69,82,85,99,102,105,121,124,127,134,150],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"A note on how to read npm version numbers — so I don't forget what the symbols mean.",[12,21,23],{"id":22},"example","Example",[17,25,26],{},"The example below uses Hexo's package.json.",[17,28,29],{},[30,31],"img",{"alt":32,"src":33},"package.json","https:\u002F\u002Fi.imgur.com\u002FUbn0HlU.png",[17,35,36],{},"Take this line:",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-themes github-dark-high-contrast","\"hexo\": \"^3.8.0\",\n","js","",[45,46,47],"code",{"__ignoreMap":43},[48,49,52,56,60,63],"span",{"class":50,"line":51},"line",1,[48,53,55],{"class":54},"sTRMh","\"hexo\"",[48,57,59],{"class":58},"sMAXC",": ",[48,61,62],{"class":54},"\"^3.8.0\"",[48,64,65],{"class":58},",\n",[17,67,68],{},"The first number is the major version (3). Between hexo 2.x.x and 3.x.x there are usually significant changes.",[70,71,72,76,79],"ul",{},[73,74,75],"li",{},"First number is the major version → 3",[73,77,78],{},"Second number is the minor version → 8",[73,80,81],{},"Third number is the patch (bug fix) → 0",[17,83,84],{},"What about the caret (^)?",[38,86,87],{"className":40,"code":41,"language":42,"meta":43,"style":43},[45,88,89],{"__ignoreMap":43},[48,90,91,93,95,97],{"class":50,"line":51},[48,92,55],{"class":54},[48,94,59],{"class":58},[48,96,62],{"class":54},[48,98,65],{"class":58},[17,100,101],{},"It means npm will auto-update the second and third digits — e.g. 3.7.2 to 3.8.0. It won't update the major version, since major bumps usually contain breaking changes that can blow things up.",[17,103,104],{},"What about the tilde (~)?",[38,106,108],{"className":40,"code":107,"language":42,"meta":43,"style":43},"\"hexo\": \"~3.8.0\",\n",[45,109,110],{"__ignoreMap":43},[48,111,112,114,116,119],{"class":50,"line":51},[48,113,55],{"class":54},[48,115,59],{"class":58},[48,117,118],{"class":54},"\"~3.8.0\"",[48,120,65],{"class":58},[17,122,123],{},"The tilde means only bug-fix updates — so only the third digit changes.",[17,125,126],{},"If there's no caret or tilde, the version is locked to exactly that one.",[17,128,129,130,133],{},"There's also a special one — ",[45,131,132],{},"latest"," — which always pulls the newest version. Most developers avoid it though, since it tends to introduce weird issues.",[38,135,137],{"className":40,"code":136,"language":42,"meta":43,"style":43},"\"hexo\": \"latest\",\n",[45,138,139],{"__ignoreMap":43},[48,140,141,143,145,148],{"class":50,"line":51},[48,142,55],{"class":54},[48,144,59],{"class":58},[48,146,147],{"class":54},"\"latest\"",[48,149,65],{"class":58},[151,152,153],"style",{},"html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":43,"searchDepth":155,"depth":155,"links":156},2,[157,158],{"id":14,"depth":155,"text":15},{"id":22,"depth":155,"text":23},"Nodejs","2019-06-26 21:19:03","A note on how to read npm version numbers — for when I forget what the symbols mean.","md","en",{},true,"\u002Fen\u002Fnodejs\u002Fnpm-version-number-explained","1",{"title":6,"description":161},false,"en\u002FNodejs\u002Fnpm-version-number-explained",[172],"Node.js",null,"\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F","iVdEAAv3qCfqHDxqCv5S2DGaQEZYxgmx0g-Co82Kt9I",{"newer":177,"older":181},{"url":178,"title":179,"date":180},"\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F","npm Install Command Variations","2019-06-26 22:03:53",{"url":182,"title":183,"date":184},"\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnodejs-create-web-server\u002F","Node.js Basics, Part 5: Spinning Up a Web Server with createServer","2019-06-26 19:33:04",[186,191,196],{"url":187,"title":188,"date":189,"readingMinutes":190},"\u002Fen\u002Fnodejs\u002F2026\u002F01\u002F13\u002Frun-multiple-commands-with-concurrently\u002F","Tired of Opening Multiple Terminals to Run Commands? Use Concurrently","2026-01-13 09:45:28","2",{"url":192,"title":193,"date":194,"readingMinutes":195},"\u002Fen\u002Fnodejs\u002F2025\u002F03\u002F13\u002Fhexschool-ecommerce-api-complete-tutorial\u002F","Hexschool Capstone Class Study Group: Complete E-commerce API Tutorial","2025-03-13 09:13:26","9",{"url":197,"title":198,"date":199,"readingMinutes":200},"\u002Fen\u002Fnodejs\u002F2024\u002F12\u