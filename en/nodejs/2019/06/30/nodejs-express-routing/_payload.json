40],{},"Let me trim it down a bit:",[28,42,45],{"className":43,"code":44,"language":33,"meta":34},[31],"https:\u002F\u002Fwww.google.com\u002Fsearch?q=wiki\n",[36,46,44],{"__ignoreMap":34},[48,49,50,62,65,68,71],"ul",{},[51,52,53,54],"li",{},"https: the transfer protocol. There are usually two, and each runs on a different port\n",[48,55,56,59],{},[51,57,58],{},"HTTP: port 80",[51,60,61],{},"HTTPS: port 443, the secure transfer protocol, also known as SSL",[51,63,64],{},"www: a subdomain, hanging off the main domain — you can adjust it based on the service (e.g., mail.google.com, drive.google.com)",[51,66,67],{},"google.com: the domain, the main domain, which you can buy from a domain registrar",[51,69,70],{},"search: the route, which I touched on earlier",[51,72,73],{},"?q=wiki: the parameter (the URL query parameter)",[12,75,77],{"id":76},"routing-in-nodejs","Routing in Node.js",[17,79,80],{},"With that out of the way, let's head back to Node.js and try designing some routes. I'll tweak the code a little and reuse the example from last time:",[28,82,86],{"className":83,"code":84,"language":85,"meta":34,"style":34},"language-js shiki shiki-themes github-dark-high-contrast","var express = require('express');\nvar router = express();\nvar port = 8080;\n\nrouter.get('\u002F', function(req, res) {\n  \u002F\u002F req → request\n  \u002F\u002F res → response\n  res.send('HelloWorld');\n})\n\nrouter.get('\u002Fadmin', function(req, res) {\n  \u002F\u002F req → request\n  \u002F\u002F res → response\n  res.send('Hello Admin!');\n})\n\nrouter.listen(port, function() {\n  console.log('Server is up on port: ' + port);\n})\n","js",[36,87,88,118,134,151,158,192,199,205,221,227,232,258,263,268,282,287,292,308,328],{"__ignoreMap":34},[89,90,93,97,101,104,108,111,115],"span",{"class":91,"line":92},"line",1,[89,94,96],{"class":95},"sWyjQ","var",[89,98,100],{"class":99},"sMAXC"," express ",[89,102,103],{"class":95},"=",[89,105,107],{"class":106},"sj_SG"," require",[89,109,110],{"cl