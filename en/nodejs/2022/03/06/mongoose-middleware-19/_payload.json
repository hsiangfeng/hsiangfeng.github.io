},10,[45,171,92],{"emptyLinePlaceholder":91},[45,173,175,178,181,184,186],{"class":47,"line":174},11,[45,176,177],{"class":55},"module",[45,179,180],{"class":65},".",[45,182,183],{"class":55},"exports",[45,185,59],{"class":51},[45,187,188],{"class":65}," User;\n",[17,190,191,192,194],{},"The key is the ",[31,193,36],{}," function. The first argument is the event or action you want to listen for, and the second argument is the function you want to call. So now, when you try to write some new data, it'll automatically trigger this Middleware:",[36,196,198],{"className":38,"code":197,"language":40,"meta":41,"style":41},"var judy = new User({\n  account: 'judy',\n  password: 'test1234',\n  nickname: 'judy',\n  age: 48,\n  job: 'construction',\n})\n\njudy.save().then((data) => {\n  console.log(data);\n});\n",[31,199,200,217,228,238,247,257,267,271,275,305,314],{"__ignoreMap":41},[45,201,202,205,208,211,213,215],{"class":47,"line":48},[45,203,204],{"class":51},"var",[45,206,207],{"class":65}," judy ",[45,209,210],{"class":51},"=",[45,212,62],{"class":51},[45,214,151],{"class":69},[45,216,73],{"class":65},[45,218,219,222,225],{"class":47,"line":76},[45,220,221],{"class":65},"  account: ",[45,223,224],{"class":106},"'judy'",[45,226,227],{"class":65},",\n",[45,229,230,233,236],{"class":47,"line":82},[45,231,232],{"class":65},"  password: ",[45,234,235],{"class":106},"'test1234'",[45,237,227],{"class":65},[45,239,240,243,245],{"class":47,"line":88},[45,241,242],{"class":65},"  nickname: ",[45,244,224],{"class":106},[45,246,227],{"class":65},[45,248,249,252,255],{"class":47,"line":95},[45,250,251],{"class":65},"  age: ",[45,253,254],{"class":55},"48",[45,256,227],{"class":65},[45,258,259,262,265],{"class":47,"line":119},[45,260,261],{"class":65},"  job: ",[45,263,264],{"class":106},"'construction'",[45,266,227],{"class":65},[45,268,269],{"class":47,"line":136},[45,270,85],{"class":65},[45,272,273],{"class":47,"line":141},[45,274,92],{"emptyLinePlaceholder":91},[45,276,277,280,