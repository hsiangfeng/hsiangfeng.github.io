yle":42},"const User = require('..\u002Fmodel\u002FUser');\n",[28,169,170],{"__ignoreMap":42},[46,171,172,174,177,179,181,183,186],{"class":48,"line":49},[46,173,53],{"class":52},[46,175,176],{"class":60}," User",[46,178,109],{"class":52},[46,180,88],{"class":87},[46,182,91],{"class":56},[46,184,185],{"class":94},"'..\u002Fmodel\u002FUser'",[46,187,98],{"class":56},[17,189,190],{},"So what's the first thing we want to test? We want to create a user record and then edit the content we just created. The clever you might quickly write something like this:",[37,192,194],{"className":39,"code":193,"language":41,"meta":42,"style":42},"const { describe, it } = require(\"mocha\");\nconst User = require('..\u002Fmodel\u002FUser');\n\ndescribe('Edit user flow test', () => {\n  it('create user', (done) => {\n    const judy = new User({\n      account: 'judy',\n      password: 'test1234',\n      nickname: 'judy',\n      age: 48,\n      job: 'construction',\n    })\n  })\n})\n",[28,195,196,220,236,242,258,283,302,314,325,335,346,357,363,369],{"__ignoreMap":42},[46,197,198,200,202,204,206,208,210,212,214,216,218],{"class":48,"line":49},[46,199,53],{"class":52},[46,201,57],{"class":56},[46,203,61],{"class":60},[46,205,64],{"class":56},[46,207,67],{"class":60},[46,209,81],{"class":56},[46,211,84],{"class":52},[46,213,88],{"class":87},[46,215,91],{"class":56},[46,217,95],{"class":94},[46,219,98],{"class":56},[46,221,222,224,226,228,230,232,234],{"class":48,"line":101},[46,223,53],{"class":52},[46,225,176],{"class":60},[46,227,109],{"class":52},[46,229,88],{"class":87},[46,231,91],{"class":56},[46,233,185],{"class":94},[46,235,98],{"class":56},[46,237,238],{"class":48,"line":158},[46,239,241],{"emptyLinePlaceholder":240},true,"\n",[46,243,245,247,249,252,254,256],{"class":48,"line":244},4,[46,246,61],{"class":87},[46,248,91],{"class":56},[46,250,251],{"class":94},"'Edit user flow test'",[46,253,144],{"class":56},[46,255,147],{"class":52},[46,257,150],{"class":56},[46,259,261,264,266,