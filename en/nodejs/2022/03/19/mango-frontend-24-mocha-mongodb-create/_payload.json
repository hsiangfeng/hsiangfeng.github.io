5],{},"So what is ",[28,640,623],{},"? This property tells you whether the record is new. If it hasn't been saved yet, it's a new record, so ",[28,643,623],{}," is ",[28,646,647],{},"true",". Once it's been saved — meaning ",[28,650,399],{}," has run — it becomes ",[28,653,654],{},"false",[17,656,657,658,660,661,664,665,668,669,671,672,674,675,677],{},"So we can lean on ",[28,659,623],{}," to assert whether the record actually saved. For that we import ",[28,662,663],{},"const assert = require('assert');",". Heads up though: ",[28,666,667],{},"assert"," fails the test if the result is ",[28,670,654],{},". Since ",[28,673,623],{}," becomes ",[28,676,654],{}," on a successful save, we need to flip it when writing the assertion:",[48,679,681],{"className":50,"code":680,"language":52,"meta":53,"style":53},"const { describe, it } = require(\"mocha\");\nconst User = require('..\u002Fmodel\u002FUser');\nconst assert = require('assert');\n\ndescribe('User creation flow test', () => {\n  it('Create a user', (done) => {\n    const judy = new User({\n      account: 'judy',\n      password: 'test1234',\n      nickname: 'judy',\n      age: 48,\n      job: 'construction',\n    });\n\n    judy.save().then((res) => {\n      assert(!judy.isNew);\n      done();\n    })\n  })\n})\n",[28,682,683,707,723,741,745,759,777,791,799,807,815,823,831,835,839,859,872,878,882,886],{"__ignoreMap":53},[57,684,685,687,689,691,693,695,697,699,701,703,705],{"class":59,"line":60},[57,686,64],{"class":63},[57,688,68],{"class":67},[57,690,41],{"class":71},[57,692,74],{"class":67},[57,694,45],{"class":71},[57,696,79],{"class":67},[57,698,82],{"class":63},[57,700,86],{"class":85},[57,702,89],{"class":67},[57,704,93],{"class":92},[57,706,96],{"class":67},[57,708,709,711,713,715,717,719,721],{"class":59,"line":134},[57,710,64],{"class":63},[57,712,184],{"class":71},[57,714,187],{"class":63},[57,716,86],{"class":85},[57,718,89],{"class":67},[57,720,194],{"class":92},[57,722,96],{"class":67},[57,724,725,727,7