},[57,854,285],{"class":67},[57,856,154],{"class":63},[57,858,157],{"class":67},[57,860,861,864,866,869],{"class":59,"line":584},[57,862,863],{"class":85},"      assert",[57,865,89],{"class":67},[57,867,868],{"class":63},"!",[57,870,871],{"class":67},"judy.isNew);\n",[57,873,874,876],{"class":59,"line":593},[57,875,587],{"class":85},[57,877,590],{"class":67},[57,879,880],{"class":59,"line":598},[57,881,369],{"class":67},[57,883,884],{"class":59,"line":603},[57,885,375],{"class":67},[57,887,889],{"class":59,"line":888},20,[57,890,169],{"class":67},[17,892,893,894,897],{},"Now you can run ",[28,895,896],{},"npm run test"," and check the result.",[17,899,900],{},[901,902],"img",{"alt":903,"src":904},"1 passing","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-03-05%2022.42.10.png",[12,906,908],{"id":907},"duplicate-inserts","Duplicate inserts",[17,910,911,912,914],{},"So we successfully created a user. But you'll notice something: every single time you run ",[28,913,896],{}," and then go peek at your MongoDB database, you get this lovely sight:",[17,916,917],{},[901,918],{"alt":919,"src":920},"Duplicate records","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-03-05%2023.21.13.png",[17,922,923,924,926,927,930],{},"That's not really what we want. Usually we'd like our test data to be isolated so it doesn't mess with anyone else. If every ",[28,925,896],{}," adds another user, you end up with a whole crowd of judys. So let's tweak the ",[28,928,929],{},"test_helper.js"," file.",[17,932,933,934,937,938,941],{},"Here we're going to use the ",[28,935,936],{},"beforeEach"," hook, which runs its function before each test. In Mongoose, we can actually grab the collections of the currently connected database through ",[28,939,940],{},"connection.collections",". So we can write it like this:",[48,943,945],{"className":50,"code":944,"language":52,"meta":53,"style":53},"beforeEach((done) => {\n  const { users } = mongoose.connection.collections;\n})\n",[28,946,947,961,978],{"__ignoreMap":53},[57,948,949,951,953,955,957,959],{"class":59,"line":60},[57,950,936],{"class":85},[57,952,560],{"class":67},[57,954,282],{"class":281},[57,956,285],{"class":67},[57,958,154],{"class":63},[57,960,157],{"class":67},[57,962,963,966,968,971,973,975],{"class":59,"line":134},[57,964,965],{"class":63},"  const",[57,967,68],{"class":67},[57,969,970],{"class":71},"users",[57,972,79],{"class":67},[57,974,82],{"class":63},[57,976,977],{"class":67}," mongoose.connection.collections;\n",[57,979,980],{"class":59,"line":141},[57,981,169],{"class":67},[17,983,984,985,988],{},"Each of these collections has a method that empties the table, namely ",[28,986,987],{},"drop",". So here's how it goes:",[48,990,992],{"className":50,"code":991,"language":52,"meta":53,"style":53},"beforeEach((done) => {\n  const { users } = mongoose.connection.collections;\n  users.drop(() => done());\n})\n",[28,993,994,1008,1022,1040],{"__ignoreMap":53},[57,995,996,998,1000,1002,1004,1006],{"class":59,"line":60},[57,997,936],{"class":85},[57,999,560],{"class":67},[57,1001,282],{"class":281},[57,1003,285],{"class":67},[57,1005,154],{"class":63},[57,1007,157],{"class":67},[57,1009,1010,1012,1014,1016,1018,1020],{"class":59,"line":134},[57,1011,965],{"class":63},[57,1013,68],{"class":67},[57,1015,970],{"class":71},[57,1017,79],{"class":67},[57,1019,82],{"class":63},[57,1021,977],{"class":67},[57,1023,1024,1027,1029,1032,1034,1037],{"class":59,"line":141},[57,1025,1026],{"class":67},"  users.",[57,1028,987],{"class":85},[57,1030,1031],{"class":67},"(() ",[57,1033,154],{"class":63},[57,1035,1036],{"class":85}," done",[57,1038,1039],{"class":67},"());\n",[57,1041,1042],{"class":59,"line":160},[57,1043,169],{"class":67},[17,1045,1046],{},"Now no matter how many times you run it, you won't get duplicate inserts anymore, because the data gets wiped first.",[1048,1049,1050],"style",{},"html pre.shiki code