":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","mongoose.connection.once('open', () => console.log('connected to database'));\nmongoose.connection.on('error', (error) => console.error('database error', error));\n","js","",[28,40,41,82],{"__ignoreMap":38},[42,43,46,50,54,57,61,64,68,71,74,76,79],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sMAXC","mongoose.connection.",[42,51,53],{"class":52},"sj_SG","once",[42,55,56],{"class":48},"(",[42,58,60],{"class":59},"sTRMh","'open'",[42,62,63],{"class":48},", () ",[42,65,67],{"class":66},"sWyjQ","=>",[42,69,70],{"class":48}," console.",[42,72,73],{"class":52},"log",[42,75,56],{"class":48},[42,77,78],{"class":59},"'connected to database'",[42,80,81],{"class":48},"));\n",[42,83,85,87,90,92,95,98,102,105,107,109,111,113,116],{"class":44,"line":84},2,[42,86,49],{"class":48},[42,88,89],{"class":52},"on",[42,91,56],{"class":48},[42,93,94],{"class":59},"'error'",[42,96,97],{"class":48},", (",[42,99,101],{"class":100},"s_sBn","error",[42,103,104],{"class":48},") ",[42,106,67],{"class":66},[42,108,70],{"class":48},[42,110,101],{"class":52},[42,112,56],{"class":48},[42,114,115],{"class":59},"'database error'",[42,117,118],{"class":48},", error));\n",[17,120,121,122,125],{},"So how do we write this in Mocha? It's actually really simple. We use the ",[28,123,124],{},"before"," test hook, because we need to connect to the database \"before all the tests start\". So this part is pretty straightforward:",[33,127,129],{"className":35,"code":128,"language":37,"meta":38,"style":38},"const { before } = require('mocha');\nconst mongoose = require('mongoose');\nrequire('dotenv').config();\n\nbefore((done) => {\n  mongoose.connect(process.env.DATABASE_URL);\n  mongoose.connection\n    .once('open', () => done())\n    .on('error', (error) => console.error('database error', error));\n})\n",[28,130,131,159,178,198,205,223,240,246,268,297],{"__ignoreMap":38},[42,132,133,136,139,142,145,148,151,153,156],