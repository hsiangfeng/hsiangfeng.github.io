82],{"class":224,"line":577},[222,1467,405],{"class":345},[222,1469,408],{"class":364},[222,1471,368],{"class":345},[222,1473,834],{"class":232},[222,1475,352],{"class":345},[222,1477,482],{"class":341},[222,1479,841],{"class":228},[222,1481,488],{"class":341},[222,1483,422],{"class":345},[222,1485,1486,1488,1490,1492,1494],{"class":224,"line":862},[222,1487,428],{"class":345},[222,1489,431],{"class":364},[222,1491,368],{"class":345},[222,1493,856],{"class":232},[222,1495,859],{"class":345},[222,1497,1498,1500,1503,1505,1508],{"class":224,"line":867},[222,1499,496],{"class":341},[222,1501,1502],{"class":345}," (message.author.bot) ",[222,1504,514],{"class":341},[222,1506,1507],{"class":345},"; ",[222,1509,1510],{"class":1148},"\u002F\u002F prevent bot-to-bot reply loops\n",[222,1512,1513,1516,1519,1521,1523,1525],{"class":224,"line":872},[222,1514,1515],{"class":341},"  const",[222,1517,1518],{"class":239}," response",[222,1520,384],{"class":341},[222,1522,1070],{"class":341},[222,1524,1039],{"class":364},[222,1526,1527],{"class":345},"(message.content);\n",[222,1529,1530,1533,1535],{"class":224,"line":1133},[222,1531,1532],{"class":345},"  message.",[222,1534,551],{"class":364},[222,1536,1537],{"class":345},"(response);\n",[222,1539,1540],{"class":224,"line":1152},[222,1541,460],{"class":345},[222,1543,1544],{"class":224,"line":1164},[222,1545,399],{"emptyLinePlaceholder":398},[222,1547,1548,1550,1552,1554,1556],{"class":224,"line":1170},[222,1549,405],{"class":345},[222,1551,582],{"class":364},[222,1553,879],{"class":345},[222,1555,882],{"class":239},[222,1557,374],{"class":345},[17,1559,1560,1561,1564],{},"The new piece here is ",[160,1562,1563],{},"message.reply(response);"," — replies to the user's message. Now in Discord, send a message and your bot will reply with what OpenAI returns.",[17,1566,1567],{},[85,1568],{"alt":1569,"src":1570},"JOJO","https:\u002F\u002Fi.imgur.com\u002F3dJOApu.png",[17,1572,1573],{},[85,1574],{"alt":1569,"src":1575},"https:\u002F\u002Fi.imgur.com\u002F2V0pEpu.png",[12,1577,1579],{"id":1578},"making-your-discord-bot-smarter","Making your Discord Bot smarter",[17,1581,1582],{},"So we've built a Discord chatbot integrated with OpenAI. But it has some weaknesses:",[49,1584,1585,1588],{},[52,1586,1587],{},"Feels a bit dumb",[52,1589,1590],{},"No conversation context",[17,1592,1593],{},"To solve this, we'd need to stack previous messages (including bot replies) and send them all to OpenAI with each new user message — so OpenAI can understand context.",[17,1595,1596,1597,1602],{},"But there's a big problem — OpenAI counts tokens per character, so stacking is expensive. See ",[31,1598,1601],{"href":1599,"rel":1600},"https:\u002F\u002Fjcyh.work\u002Fchatgpt-integration-with-linebot\u002F",[35],"this person's writeup"," for details.",[17,1604,1605],{},"If you still want to make the bot smarter, here's an approach — use Discord's Forum.",[17,1607,1608],{},[85,1609],{"alt":1610,"src":1611},"Forum","https:\u002F\u002Fi.imgur.com\u002FjQ4swB2.png",[17,1613,1614],{},"Forum posts let you gather context for a single topic, then send to OpenAI. You can also limit the total character count per post to limit OpenAI's compute cost.",[17,1616,1617],{},"But Discord Forums require Community mode if I remember correctly. Another option: only fetch a limited number of recent messages — e.g. the last 10 — and reset above that. Less elegant, but it works.",[17,1619,1620],{},"Personally I think Forum mode is still better xD.",[12,1622,1624],{"id":1623},"sample-code","Sample code",[17,1626,1627],{},"Sample code for reference — you can use this post to set up Discord, then use my code to build your own chatbot.",[17,1629,1630,1631],{},"GitHub: ",[31,1632,1633],{"href":1633,"rel":1634},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione",[35],[12,1636,1638],{"id":1637},"updates","Updates",[17,1640,1641],{},"OpenAI later released the ChatGPT API. I updated the sample code — see the commits below to learn how to convert from GPT-3 to GPT-3.5:",[49,1643,1644,1651,1658],{},[52,1645,1646],{},[31,1647,1650],{"href":1648,"rel":1649},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002Fccb78b0f5f5b42eb366e5f85f50612a5f31842be",[35],"Switch to createChatCompletion",[52,1652,1653],{},[31,1654,1657],{"href":1655,"rel":1656},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002F2a701f7c4335850b9ace40c1511900c7c80aabb7",[35],"Forum mode adjustment",[52,1659,1660],{},[31,1661,1664],{"href":1662,"rel":1663},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002F3957938f69e548d0a5ecb03534685861d41cbf19",[35],"Text-string mode adjustment",[17,1666,1667],{},"I've also split branches for the two versions, so you can switch branches to compare.",[12,1669,1671],{"id":1670},"important-notes","Important notes",[17,1673,1674],{},"This post does NOT provide a free OpenAI API Key or Discord Token. You need to apply for your own — this is just an integration example. To run it, get both:",[49,1676,1677,1684],{},[52,1678,1679,1680],{},"OpenAI API Key: ",[31,1681,1682],{"href":1682,"rel":1683},"https:\u002F\u002Fplatform.openai.com\u002F",[35],[52,1685,1686,1687],{},"Discord Token: ",[31,1688,78],{"href":78,"rel":1689},[35],[17,1691,1692,1693,37],{},"For OpenAI Key application steps, see the \"Apply for OpenAI API\" section in ",[31,1694,36],{"href":1695,"rel":1696},"https:\u002F\u002Fisraynotarray.com\u002F\u002Fodejs\u002F20221210\u002F1224824056\u002F#%E7%94%B3%E8%AB%8B-OpenAI-API",[35],[17,1698,1699,1700,1703],{},"This sample project uses env variables. If you've applied for the keys but still get \"",[160,1701,1702],{},"RequestAbortedError [AbortError]: Request aborted","\" or \"Sorry, I hit a 401 - Unauthorized error\", your Key or Token is wrong — check your .env. Also, the project uses Node.js, so make sure Node.js is installed first.",[17,1705,1706,1707],{},"Bonus — about Env: ",[31,1708,1711],{"href":1709,"rel":1710},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20230218\u002F3618693250\u002F",[35],"What is Env and when should you use it? (article in Mandarin)",[1713,1714,1715],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":218,"searchDepth":236,"depth":236,"links":1717},[1718,1719,1720,1721,1722,1726,1727,1728,1729],{"id":14,"depth":236,"text":15},{"id":40,"depth":236,"text":41},{"id":71,"depth":236,"text":72},{"id":207,"depth":236,"text":208},{"id":317,"depth":236,"text":318,"children":1723},[1724,1725],{"id":325,"depth":245,"text":326},{"id":906,"depth":245,"text":907},{"id":1578,"depth":236,"text":1579},{"id":1623,"depth":236,"text":1624},{"id":1637,"depth":236,"text":1638},{"id":1670,"depth":236,"text":1671},"Nodejs","2022-12-15 21:15:00","This post walks through building a Discord chatbot using OpenAI GPT-3 — one that can reply to messages. Discord is actually a really good fit for integrating with OpenAI. The post focuses on GPT-3, but the sample code includes GPT-3.5 commits too.","md","en",{},"\u002Fen\u002Fnodejs\u002Fdiscord-bot-with-openai-gpt3","6",{"title":6,"description":1732},false,"en\u002FNodejs\u002Fdiscord-bot-with-openai-gpt3",[1730,1742,1743,899],"GPT-3","OpenAI",null,"2023-03-22 09:48:00","\u002Fen\u002Fnodejs\u002F2022\u002F12\u002F15\u002Fdiscord-bot-with-openai-gpt3\u002F","vy5cry1bxCfHeQHr-H3pgCuJoGoAohcCRje-WK4a3tc",{"newer":1749,"older":1753},{"url":1750,"title":1751,"date":1752},"\u002Fen\u002Fgsap\u002F2022\u002F12\u002F16\u002Fgsap3-fx-09-eases\u002F","(9) Fun Frontend Effects With GSAP3 - Eases","2022-12-16 21:04:00",{"url":1754,"title":1755,"date":1756},"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F13\u002Fmigrating-from-heroku-to-render-deployment-guide\u002F","Migrating From Heroku to Render: A Deployment Guide","2022-12-13 09:59:23",[1758,1763,1768],{"url":1759,"title":1760,"date":1761,"readingMinutes":1762},"\u002Fen\u002Fnodejs\u002F2026\u002F01\u002F13\u002Frun-multiple-commands-with-concurrently\u002F","Tired of Opening Multiple Terminals to Run Commands? Use Concurrently","2026-01-13 09:45:28","2",{"url":1764,"title":1765,"date":1766,"readingMinutes":1767},"\u002Fen\u002Fnodejs\u002F2025\u002F03\u002F13\u002Fhexschool-ecommerce-api-complete-tutorial\u002F","Hexschool Capstone Class Study Group: Complete E-commerce API Tutorial","2025-03-13 09:13:26","9",{"url":1769,"title":1770,"date":1771,"readingMinutes":1772},"\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F","PM2 Is Process Manager, Not PM2.5","2024-12-25 10:31:33","5",1784011707732]