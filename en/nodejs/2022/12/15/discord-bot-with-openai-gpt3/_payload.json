s":224,"line":872},19,[222,874,405],{"class":345},[222,876,582],{"class":364},[222,878,879],{"class":345},"(process.env.",[222,881,882],{"class":239},"DISCORD_TOKEN",[222,884,374],{"class":345},[17,886,887,888,891,892,894],{},"Run ",[160,889,890],{},"node index.js"," in the terminal. When you see ",[160,893,613],{},", the bot's running. Send a message in Discord, and the terminal will print it.",[17,896,897],{},[85,898],{"alt":899,"src":900},"Discord","https:\u002F\u002Fi.imgur.com\u002FWXtW6hO.png",[17,902,903],{},"Discord bot done. Now let's hook up OpenAI.",[323,905,907],{"id":906},"integrating-openais-api","Integrating OpenAI's API",[17,909,910,911,914,915,918],{},"Create a ",[160,912,913],{},"services"," folder in the root, with an ",[160,916,917],{},"openai.js"," file inside. Paste this in (I've wrapped it a bit for clean export):",[213,920,922],{"className":332,"code":921,"language":334,"meta":218,"style":218},"require('dotenv').config()\n\nconst { Configuration, OpenAIApi } = require('openai');\n\nconst configuration = new Configuration({\n  apiKey: process.env.OPENAI_API_KEY,\n});\n\nconst openAI = new OpenAIApi(configuration);\n\nasync function openAiMessage(prompt) {\n  try {\n    const { data } = await openAI.createCompletion({\n      model: 'text-davinci-003',\n      prompt,\n      max_tokens: 100,\n    });\n    const [choices] = data.choices;\n\n    return choices.text.trim(); \u002F\u002F OpenAI responses have leading\u002Ftrailing whitespace, so trim\n  } catch (error) {\n    \u002F\u002F eslint-disable-next-line no-console\n    console.error(error);\n    return `Sorry, I hit a **${error.response.status} - ${error.response.statusText}** error, so I don't know how to reply. QQ`;\n  }\n}\n\nmodule.exports = {\n  openAiMessage,\n};\n",[160,923,924,938,942,969,973,990,1001,1005,1009,1026,1030,1047,1054,1079,1089,1094,1104,1109,1127,1131,1150,1162,1168,1180,1219,1224,1230,1235,1250,1256],{"__ignoreMap":218},[222,925,926,928,930,932,934,936],{"class":224,"