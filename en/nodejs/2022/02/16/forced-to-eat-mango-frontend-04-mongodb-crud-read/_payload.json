s":100,"line":597},50,[98,599,210],{"class":126},[98,601,184],{"class":114},[98,603,260],{"class":201},[98,605,607],{"class":100,"line":606},51,[98,608,221],{"class":114},[98,610,612],{"class":100,"line":611},52,[98,613,614],{"class":114},"])\n",[17,616,617],{},"There are a ton of conditional queries, so I won't list every single one — just the more commonly used ones.",[17,619,620,621,31],{},"So how do we do a conditional search in MongoDB? To add a condition, you write it like this: ",[28,622,623],{},"{ \u003Cfield>: { $operator: \u003Cvalue> } }",[17,625,626],{},"If you're not sure what field and value mean here, take a look at this MongoDB structure diagram:",[17,628,629],{},[40,630],{"alt":631,"src":632},"MongoDB structure","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-22%2023.10.49.png",[17,634,635],{},"So let's get to know some of the common conditional operators.",[637,638,640],"h3",{"id":639},"eq","$eq",[17,642,643,645,646,648,649,31],{},[28,644,640],{}," is actually really similar to the plain condition search. Why do I say that? The ",[28,647,133],{}," we practiced earlier is the same as ",[28,650,651],{},"db.users.find({ age: { $eq: 25 } , name: { $eq: 'Roy' } })",[17,653,654],{},[40,655],{"alt":639,"src":656},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2021.14.19.png",[17,658,659],{},"You can see the two aren't all that different:",[89,661,663],{"className":153,"code":662,"language":155,"meta":94,"style":94},"db.users.find({ age: 25, name: 'Roy' })\n\ndb.users.find({ age: { $eq: 25 } , name: { $eq: 'Roy' } })\n",[28,664,665,685,691],{"__ignoreMap":94},[98,666,667,669,671,674,676,679,682],{"class":100,"line":101},[98,668,162],{"class":114},[98,670,42],{"class":165},[98,672,673],{"class":114},"({ age: ",[98,675,464],{"class":201},[98,677,678],{"class":114},", name: ",[98,680,681],{"class":126},"'Roy'",[98,683,684],{"class":114}," })\n",[98,686,687],{"class":100,"line":172},[98,688,690],{"emptyLinePlaceholder":689},true,"\n",[98,692,693,695,697,700,702,705,707],{"class":100,"line":178},[98,694,162],{"class":114},[98,696,42],{"class":165},[98,698,699],{"class":114},"({ age: { $eq: ",[98,701,464],{"class":201},[98,703,704],{"class":114}," } , name: { $eq: ",[98,706,681],{"class":126},[98,708,709],{"class":114}," } })\n",[17,711,712,713,715],{},"You might be wondering, \"So which style should I pick?\" Personally, I go with the ",[28,714,640],{}," style.",[17,717,718,720],{},[28,719,640],{}," is short for equals — in other words, \"equal to (=)\".",[637,722,724],{"id":723},"gt","$gt",[17,726,727,729],{},[28,728,724],{}," is short for greater — in other words, \"greater than (>)\". Say I want to find users older than 18, you'd write it like this:",[89,731,733],{"className":153,"code":732,"language":155,"meta":94,"style":94},"db.users.find({ age: { $gt: 18 } })\n",[28,734,735],{"__ignoreMap":94},[98,736,737,739,741,744,747],{"class":100,"line":101},[98,738,162],{"class":114},[98,740,42],{"class":165},[98,742,743],{"class":114},"({ age: { $gt: ",[98,745,746],{"class":201},"18",[98,748,709],{"class":114},[17,750,751],{},[40,752],{"alt":753,"src":754},"older than 18","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2021.29.00.png",[637,756,758],{"id":757},"gte","$gte",[17,760,761,762,764],{},"Now if you try to find people who are 25 and over, you'll notice something — ",[28,763,724],{}," only lists people older than 25, and the ones who are exactly 25 get left out.",[89,766,768],{"className":153,"code":767,"language":155,"meta":94,"style":94},"db.users.find({ age: { $gt: 25 } })\n",[28,769,770],{"__ignoreMap":94},[98,771,772,774,776,778,780],{"class":100,"line":101},[98,773,162],{"class":114},[98,775,42],{"class":165},[98,777,743],{"class":114},[98,779,464],{"class":201},[98,781,709],{"class":114},[17,783,784],{},[40,785],{"alt":786,"src":787},"left out","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2021.32.57.png",[17,789,790,791,793,794,796,797,31],{},"The main reason is that ",[28,792,724],{}," is purely \"greater than\". If you want \"greater than or equal to\", you need ",[28,795,758],{},", which is short for ",[28,798,799],{},"greater than or equal",[89,801,803],{"className":153,"code":802,"language":155,"meta":94,"style":94},"db.users.find({ age: { $gte: 25 } })\n",[28,804,805],{"__ignoreMap":94},[98,806,807,809,811,814,816],{"class":100,"line":101},[98,808,162],{"class":114},[98,810,42],{"class":165},[98,812,813],{"class":114},"({ age: { $gte: ",[98,815,464],{"class":201},[98,817,709],{"class":114},[17,819,820],{},[40,821],{"alt":799,"src":822},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2021.43.18.png",[637,824,826],{"id":825},"lt","$lt",[17,828,829,830,832],{},"Where there's greater than, there's also less than. The syntax for less than is ",[28,831,826],{},", which is short for less than.",[17,834,835],{},"So you can try filtering out people younger than 18:",[89,837,839],{"className":153,"code":838,"language":155,"meta":94,"style":94},"db.users.find({ age: { $lt: 18 } })\n",[28,840,841],{"__ignoreMap":94},[98,842,843,845,847,850,852],{"class":100,"line":101},[98,844,162],{"class":114},[98,846,42],{"class":165},[98,848,849],{"class":114},"({ age: { $lt: ",[98,851,746],{"class":201},[98,853,709],{"class":114},[17,855,856],{},[40,857],{"alt":858,"src":859},"younger than 18","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2021.52.27.png",[637,861,863],{"id":862},"lte","$lte",[17,865,866,867,869,870,87],{},"Same deal — ",[28,868,826],{}," only finds people who are strictly less than. If you want \"less than or equal to\", you use ",[28,871,863],{},[89,873,875],{"className":153,"code":874,"language":155,"meta":94,"style":94},"db.users.find({ age: { $lte: 18 } })\n",[28,876,877],{"__ignoreMap":94},[98,878,879,881,883,886,888],{"class":100,"line":101},[98,880,162],{"class":114},[98,882,42],{"class":165},[98,884,885],{"class":114},"({ age: { $lte: ",[98,887,746],{"class":201},[98,889,709],{"class":114},[17,891,892],{},[40,893],{"alt":894,"src":895},"less than or equal","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2021.55.06.png",[17,897,898],{},"(I forgot there's no one aged 18 in the data, but you can try searching with 25 instead.)",[637,900,902],{"id":901},"and","$and",[17,904,905,906,908],{},"Hmm... the way you write ",[28,907,902],{}," is actually pretty close to chaining multiple single conditions. What do I mean? Say we want to filter for people over 25 whose status is enabled — in the normal style you'd write:",[89,910,912],{"className":153,"code":911,"language":155,"meta":94,"style":94},"db.users.find({ age: { $gt: 25 }, status: true })\n",[28,913,914],{"__ignoreMap":94},[98,915,916,918,920,922,924,927,930],{"class":100,"line":101},[98,917,162],{"class":114},[98,919,42],{"class":165},[98,921,743],{"class":114},[98,923,464],{"class":201},[98,925,926],{"class":114}," }, status: ",[98,928,929],{"class":201},"true",[98,931,684],{"class":114},[17,933,934,935,937],{},"If you want to use ",[28,936,902],{},", you'd rewrite it like this:",[89,939,941],{"className":153,"code":940,"language":155,"meta":94,"style":94},"db.users.find({ $and: [{ age: { $gt: 25 } }, { status: true }] })\n",[28,942,943],{"__ignoreMap":94},[98,944,945,947,949,952,954,957,959],{"class":100,"line":101},[98,946,162],{"class":114},[98,948,42],{"class":165},[98,950,951],{"class":114},"({ $and: [{ age: { $gt: ",[98,953,464],{"class":201},[98,955,956],{"class":114}," } }, { status: ",[98,958,929],{"class":201},[98,960,961],{"class":114}," }] })\n",[17,963,964],{},[40,965],{"alt":902,"src":966},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2022.54.48.png",[637,968,970],{"id":969},"or","$or",[17,972,973,975],{},[28,974,970],{}," is one you'll genuinely use a lot. Say I want to find people who are 18 or older, or whose status is enabled — you'd write it like this:",[89,977,979],{"className":153,"code":978,"language":155,"meta":94,"style":94},"db.users.find({or: [{ age: { $gte: 18 } }, { status: true }]})\n",[28,980,981],{"__ignoreMap":94},[98,982,983,985,987,990,992,994,996],{"class":100,"line":101},[98,984,162],{"class":114},[98,986,42],{"class":165},[98,988,989],{"class":114},"({or: [{ age: { $gte: ",[98,991,746],{"class":201},[98,993,956],{"class":114},[98,995,929],{"class":201},[98,997,998],{"class":114}," }]})\n",[17,1000,1001],{},[40,1002],{"alt":970,"src":1003},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2022.53.52.png",[1005,1006,1007],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":94,"searchDepth":172,"depth":172,"links":1009},[1010,1011,1012],{"id":14,"depth":172,"text":15},{"id":22,"depth":172,"text":23},{"id":146,"depth":172,"text":147,"children":1013},[1014,1015,1016,1017,1018,1019,1020],{"id":639,"