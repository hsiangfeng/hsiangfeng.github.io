90,491],{},[35,492,493],{},"uppercase",[200,495,496],{},[35,497,498],{},"lowercase",[200,500,501],{},[35,502,503],{},"enum",[200,505,506],{},[35,507,508],{},"minLength",[200,510,511],{},[35,512,513],{},"maxLength",[17,515,516,517,519,520,522],{},"Honestly ",[35,518,493],{}," and ",[35,521,498],{}," are pretty rare in practice — they just transform the data to all uppercase or all lowercase, so I won't go into those.",[524,525,503],"h3",{"id":503},[17,527,528,530],{},[35,529,503],{}," is basically about defining a \"range\" of allowed values. Think of it like an HTML Select dropdown. Say a user's job category can be one of these:",[197,532,533,536,539,542],{},[200,534,535],{},"Tech",[200,537,538],{},"Electronics",[200,540,541],{},"Food Processing",[200,543,544],{},"Construction",[17,546,547],{},"Then you can write it like this:",[28,549,551],{"className":30,"code":550,"language":32,"meta":33,"style":33},"const UserSchema = new mongoose.Schema({\n  account: {\n    type: String,\n    required: true,\n  }\n  password: {\n    type: String,\n    required: true,\n  },\n  nickname: {\n    type: String,\n    required: [true, 'nickname is required.'],\n  },\n  job: {\n    type: String,\n    enum: [\n      '科技類',\n      '電子類',\n      '食品加工類',\n      '營造業',\n    ],\n  },\n  createTime: {\n    type: Date,\n    default: Date.now,\n  }\n});\n",[35,552,553,569,573,577,585,589,593,597,605,609,613,617,629,633,638,642,647,654,661,669,677,683,688,693,698,703,708],{"__ignoreMap":33},[38,554,555,557,559,561,563,565,567],{"class":40,"line":41},[38,556,45],{"class":44},[38,558,49],{"class":48},[38,560,52],{"class":44},[38,562,55],{"class":44},[38,564,59],{"class":58},[38,566,63],{"class":62},[38,568,66],{"class":58},[38,570,571],{"class":40,"line":69},[38,572,119],{"class":58},[38,574,575],{"class":40,"line":75},[38,576,124],{"class":58},[38,578,579,581,583],{"class":40,"line":81},[38,580,289],{"class":58},[38,582,292],{"class":48},[38,584,295],{"class":58},[38,586,587],{"class":40,"line":