,129],{"class":58},[38,162,164],{"class":40,"line":163},11,[38,165,166],{"class":58},"  createTime: {\n",[38,168,170],{"class":40,"line":169},12,[38,171,172],{"class":58},"    type: Date,\n",[38,174,176],{"class":40,"line":175},13,[38,177,178],{"class":58},"    default: Date.now,\n",[38,180,182],{"class":40,"line":181},14,[38,183,184],{"class":58},"  }\n",[38,186,188],{"class":40,"line":187},15,[38,189,90],{"class":58},[17,191,192,195],{},[35,193,194],{},"type"," supports a lot of formats. Here are just the more common SchemaTypes:",[197,198,199,203,206,209,212,215,218],"ul",{},[200,201,202],"li",{},"String",[200,204,205],{},"Number",[200,207,208],{},"Boolean",[200,210,211],{},"Date",[200,213,214],{},"Object",[200,216,217],{},"ObjectID",[200,219,220],{},"Array",[17,222,223],{},"And of course the official ones also include:",[197,225,226,229],{},[200,227,228],{},"Buffer",[200,230,231],{},"Map",[17,233,234],{},"...and so on.",[12,236,238],{"id":237},"schema-validators","Schema Validators",[17,240,241],{},"So why use the second style? It mostly comes down to Schema Validators — the \"validators\" part being the validation rules you attach to a field.",[17,243,244,245,248],{},"There are a bunch of validators, and I'll walk through them one by one, so the ",[35,246,247],{},"UserSchema"," will get tweaked a little along the way.",[17,250,251,252,255],{},"The most basic validator is ",[35,253,254],{},"required",". For example, password and account should both be required. Adding it is dead simple:",[28,257,259],{"className":30,"code":258,"language":32,"meta":33,"style":33},"const UserSchema = new mongoose.Schema({\n  account: {\n    type: String,\n    required: true,\n  }\n  password: {\n    type: String,\n    required: true,\n  },\n  nickname: {\n    type: String,\n  },\n  createTime: {\n    type: Date,\n    default: Date.now,\n  }\n});\n",[35,260,261,277,281,285,296,300,304,308,316,320,324,328,332,336,340,344,349],{"__ignoreMap":33},[38,262,263,265,267,269,271,273,275],{