nstall --save passport passport-google-oauth20\n",[110,312,313],{"__ignoreMap":275},[279,314,315],{"class":281,"line":282},[279,316,310],{},[17,318,319,320,323],{},"After install, run ",[110,321,322],{},"npm start"," to confirm everything works, then we're ready to start.",[12,325,327],{"id":326},"writing-the-routes","Writing the routes",[17,329,330,331,307],{},"Create ",[110,332,333],{},"router\u002Fauth.js",[270,335,339],{"className":336,"code":337,"language":338,"meta":275,"style":275},"language-js shiki shiki-themes github-dark-high-contrast","var express = require('express');\nvar router = express.Router();\n\n\u002F* GET home page. *\u002F\nrouter.get('\u002F', function(req, res, next) {\n  res.render('index', { title: 'Express' });\n});\n\nmodule.exports = router;\n","js",[110,340,341,368,386,392,399,438,461,467,472],{"__ignoreMap":275},[279,342,343,347,351,354,358,361,365],{"class":281,"line":282},[279,344,346],{"class":345},"sWyjQ","var",[279,348,350],{"class":349},"sMAXC"," express ",[279,352,353],{"class":345},"=",[279,355,357],{"class":356},"sj_SG"," require",[279,359,360],{"class":349},"(",[279,362,364],{"class":363},"sTRMh","'express'",[279,366,367],{"class":349},");\n",[279,369,370,372,375,377,380,383],{"class":281,"line":288},[279,371,346],{"class":345},[279,373,374],{"class":349}," router ",[279,376,353],{"class":345},[279,378,379],{"class":349}," express.",[279,381,382],{"class":356},"Router",[279,384,385],{"class":349},"();\n",[279,387,388],{"class":281,"line":294},[279,389,391],{"emptyLinePlaceholder":390},true,"\n",[279,393,395],{"class":281,"line":394},4,[279,396,398],{"class":397},"sQrFR","\u002F* GET home page. *\u002F\n",[279,400,402,405,408,410,413,416,419,421,425,427,430,432,435],{"class":281,"line":401},5,[279,403,404],{"class":349},"router.",[279,406,407],{"class":356},"get",[279,409,360],{"class":349},[279,411,412],{"class":363},"'\u002F'",[279,414,415],{"class":349},", ",[279,417,418],{"class":345},"function",[279,420,360],{"class":349},[279,422,424],{"class":423},"s_sBn","req",[279,426,415],{"class":349},[279,428,429],{"class":423},"res",[279,431,415],{"class":349},[279,433,434],{"class":423},"next",[279,436,437],{"class":349},") {\n",[279,439,441,444,447,449,452,455,458],{"class":281,"line":440},6,[279,442,443],{"class":349},"  res.",[279,445,446],{"class":356},"render",[279,448,360],{"class":349},[279,450,451],{"class":363},"'index'",[279,453,454],{"class":349},", { title: ",[279,456,457],{"class":363},"'Express'",[279,459,460],{"class":349}," });\n",[279,462,464],{"class":281,"line":463},7,[279,465,466],{"class":349},"});\n",[279,468,470],{"class":281,"line":469},8,[279,471,391],{"emptyLinePlaceholder":390},[279,473,475,479,482,485,488],{"class":281,"line":474},9,[279,476,478],{"class":477},"sCcAr","module",[279,480,481],{"class":349},".",[279,483,484],{"class":477},"exports",[279,486,487],{"class":345}," =",[279,489,490],{"class":349}," router;\n",[17,492,493,494,303,497,481],{},"We need two routes: ",[110,495,496],{},"\u002Fgoogle",[110,498,499],{},"\u002Fgoogle\u002Fcallback",[17,501,502,503,506],{},"The first route uses passport's ",[110,504,505],{},"authenticate"," method, which takes two arguments — auth type and data scope. For this demo we need the user's profile and email:",[270,508,510],{"className":336,"code":509,"language":338,"meta":275,"style":275},"router.get('\u002Fgoogle', passport.authenticate('google', {\n  scope: [ 'email', 'profile' ],\n}));\n",[110,511,512,536,552],{"__ignoreMap":275},[279,513,514,516,518,520,523,526,528,530,533],{"class":281,"line":282},[279,515,404],{"class":349},[279,517,407],{"class":356},[279,519,360],{"class":349},[279,521,522],{"class":363},"'\u002Fgoogle'",[279,524,525],{"class":349},", passport.",[279,527,505],{"class":356},[279,529,360],{"class":349},[279,531,532],{"class":363},"'google'",[279,534,535],{"class":349},", {\n",[279,537,538,541,544,546,549],{"class":281,"line":288},[279,539,540],{"class":349},"  scope: [ ",[279,542,543],{"class":363},"'email'",[279,545,415],{"class":349},[279,547,548],{"class":363},"'profile'",[279,550,551],{"class":349}," ],\n",[279,553,554],{"class":281,"line":294},[279,555,556],{"class":349},"}));\n",[17,558,559,560,563,564,569],{},"(For ",[110,561,562],{},"scope"," options, see ",[28,565,568],{"href":566,"rel":567},"https:\u002F\u002Fwww.passportjs.org\u002Fpackages\u002Fpassport-google-oauth2\u002F",[32],"this link"," for what user data you can access.)",[17,571,572,573,575,576,578],{},"The second route, ",[110,574,499],{},". When the user hits ",[110,577,496],{},", they're redirected to Google's login page:",[17,580,581],{},[46,582],{"alt":583,"src":584},"Login page","https:\u002F\u002Fi.imgur.com\u002FxMGKH5q.png",[17,586,587,588,591,592,594,595,598,599,307],{},"After successful login, Google redirects based on the ",[110,589,590],{},"passport.use"," config (we'll set this up in a moment). So ",[110,593,499],{}," looks like this. Note since we're assuming decoupled frontend\u002Fbackend, we don't need ",[110,596,597],{},"session",", so pass ",[110,600,601],{},"session: false",[270,603,605],{"className":336,"code":604,"language":338,"meta":275,"style":275},"router.get('\u002Fgoogle\u002Fcallback', passport.authenticate('google', { session: false }), (req, res) => {\n  res.send({\n    status: true,\n    data: {\n      id: req.user.id,\n      name: req.user.displayName\n    }\n  });\n})\n",[110,606,607,650,660,671,676,681,686,691,696],{"__ignoreMap":275},[279,608,609,611,613,615,618,620,622,624,626,629,632,635,637,639,641,644,647],{"class":281,"line":282},[279,610,404],{"class":349},[279,612,407],{"class":356},[279,614,360],{"class":349},[279,616,617],{"class":363},"'\u002Fgoogle\u002Fcallback'",[279,619,525],{"class":349},[279,621,505],{"class":356},[279,623,360],{"class":349},[279,625,532],{"class":363},[279,627,628],{"class":349},", { session: ",[279,630,631],{"class":477},"false",[279,633,634],{"class":349}," }), (",[279,636,424],{"class":423},[279,638,415],{"class":3