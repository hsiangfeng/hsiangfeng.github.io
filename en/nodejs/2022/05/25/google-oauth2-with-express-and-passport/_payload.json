,{},"Once you have a project, click \"",[39,40,41],"strong",{},"APIs & Services","\" on the screen.",[17,44,45],{},[46,47],"img",{"alt":41,"src":48},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002FExpress-Passport-Google-OAuth-2-0\u002F202205241701.png",[17,50,51],{},"Or find it in the sidebar.",[17,53,54],{},[46,55],{"alt":41,"src":56},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002FExpress-Passport-Google-OAuth-2-0\u002F202205241702.png",[58,59,61],"h3",{"id":60},"step-1-oauth-consent-screen","Step 1: OAuth consent screen",[17,63,64,65,67,68,71,72,75,76,79],{},"In the \"",[39,66,41],{},"\" sidebar, click \"",[39,69,70],{},"OAuth consent screen","\", then choose \"",[39,73,74],{},"External","\" on the left and click \"",[39,77,78],{},"Submit","\".",[17,81,82],{},[46,83],{"alt":70,"src":84},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002FExpress-Passport-Google-OAuth-2-0\u002F202205241712.png",[17,86,64,87,90],{},[39,88,89],{},"Edit app registration","\" screen, fill in only the required fields:",[92,93,94,98,101,114],"ul",{},[95,96,97],"li",{},"App name",[95,99,100],{},"User support email",[95,102,103,104],{},"App home page\n",[92,105,106],{},[95,107,108,109,113],{},"Use Express's default port: \"",[110,111,112],"code",{},"http:\u002F\u002Flocalhost:3000","\"",[95,115,116],{},"Developer contact info => Email address",[17,118,119,120,79],{},"Click \"",[39,121,122],{},"Save and continue",[17,124,125],{},[46,126],{"alt":89,"src":127},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002FExpress-Passport-Google-OAuth-2-0\u002F202205241720.png",[17,129,130,131,79],{},"Second page — ignore it, just click \"",[39,132,122],{},[17,134,135],{},[46,136],{"alt":137,"src":138},"Scopes","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002FExpress-Passport-Google-OAuth-2-0\u002F%E6%88%AA%E5%9C%96_2022-05-24_17_23_52.png",[17,140,141,142,79],{},"Third page is test