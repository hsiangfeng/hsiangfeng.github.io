syntax:",[27,154,156],{"className":73,"code":155,"language":75,"meta":32,"style":32},"import 'dotenv\u002Fconfig';\nconsole.log('DATABASE：', process.env.DATABASE); \u002F\u002F DATABASE：Database Url\nconsole.log('DATABASE_PASSWORD：', process.env.DATABASE_PASSWORD); \u002F\u002FDATABASE_PASSWORD： Database Password\n",[34,157,158,170,188],{"__ignoreMap":32},[37,159,160,164,167],{"class":39,"line":40},[37,161,163],{"class":162},"sWyjQ","import",[37,165,166],{"class":90}," 'dotenv\u002Fconfig'",[37,168,169],{"class":86},";\n",[37,171,172,174,176,178,180,182,184,186],{"class":39,"line":64},[37,173,105],{"class":86},[37,175,108],{"class":82},[37,177,87],{"class":86},[37,179,113],{"class":90},[37,181,116],{"class":86},[37,183,120],{"class":119},[37,185,123],{"class":86},[37,187,127],{"class":126},[37,189,190,192,194,196,198,200,202,204],{"class":39,"line":130},[37,191,105],{"class":86},[37,193,108],{"class":82},[37,195,87],{"class":86},[37,197,139],{"class":90},[37,199,116],{"class":86},[37,201,144],{"class":119},[37,203,123],{"class":86},[37,205,149],{"class":126},[17,207,208],{},"You can also customize which file gets loaded, but that's not what this post's about.",[17,210,211,212,214,215,217],{},"Anyway, ",[34,213,48],{}," usually holds sensitive info. In a team there are always multiple people sharing one ",[34,216,48],{},", so we end up encrypting and zipping it, then passing it around through Email or Slack.",[17,219,220],{},"But... that still has security concerns. So the dotenv team built a service called Dotenv Vault. Let me walk through it.",[12,222,224],{"id":223},"dotenv-vault","Dotenv Vault",[17,226,227],{},"Dotenv Vault is dotenv's official service — a relatively new one. This post was written on 2022\u002F06\u002F23.",[17,229,230,231,233,234,236],{},"The service is simple — centralized management of your ",[34,232,48],{}," files, set up as an organization so team members can pull directly. No more emailing or Slacking encrypted ",[34,235,48],{}," zips.",[17,238,239],{},"Let's actually try it out.",[241,242,244],"h3",{"id":243},"sign-up-for-dotenv-vault","Sign up for Dotenv Vault",[17,246,247,248,255],{},"Go to ",[249,250,254],"a",{"href":251,"rel":252},"https:\u002F\u002Fwww.dotenv.org\u002F",[253],"nofollow","Dotenv Vault's site"," and click \"Log in\" at the top.",[17,257,258],{},[259,260],"img",{"alt":261,"src":262},"Log in","https:\u002F\u002Fi.imgur.com\u002FUEvKOJ2.png",[17,264,265],{},"Then click \"Create a new account\" below.",[17,267,268],{},[259,269],{"alt":270,"src":271},"Create a new account","https:\u002F\u002Fi.imgur.com\u002F387U9AQ.png",[17,273,274],{},"Three steps follow — enter your Email and organization name. Once you're good, click \"Next: Create project\".",[17,276,277],{},[259,278],{"alt":279,"src":280},"Next:Create project","https:\u002F\u002Fi.imgur.com\u002FqN3GNZo.png",[17,282,283],{},"Then it asks you to verify your email.",[17,285,286],{},[259,287],{"alt":288,"src":289},"Verify email","https:\u002F\u002Fi.imgur.com\u002FMomPHuL.png",[241,291,293],{"id":292},"create-an-env-project","Create an env project",[17,295,296],{},"After verification, you're ready to create a project.",[17,298,299],{},[259,300],{"alt":279,"src":301},"https:\u002F\u002Fi.imgur.com\u002FE9jaKuv.png",[17,303,304],{},"Name the first project \"test-env\" — this is just a demo.",[17,306,307],{},[259,308],{"alt":309,"src":310},"test-env","https:\u002F\u002Fi.imgur.com\u002FmoKLe9B.png",[17,312,313,314,317],{},"(You'll notice there's also a hint at the bottom that you can use ",[34,315,316],{},"npx dotenv-vault new",".)",[17,319,320],{},"After creation, you'll see this Setup screen.",[17,322,323],{},[259,324],{"alt":325,"src":326},"Setup","https:\u002F\u002Fi.imgur.com\u002FW0SlfwC.png",[17,328,329,330,333,334,317],{},"(Step three should be ",[34,331,332],{},"npx dotenv-vault@latest pull",", not sure why the official docs say ",[34,335,336],{},"npx dotenv-vault@latest push",[17,338,339],{},"Now let's create a project.",[241,341,343],{"id":342},"test-with-express","Test with Express",[17,345,346],{},"I'll cheat and scaffold a project with the Express generator. I'm on Mac, so here are the commands:",[27,348,350],{"className":29,"code":349,"language":31,"meta":32,"style":32},"mkdir test-express\ncd test-express\nexpress --no-view\nnpm install\n",[34,351,352,357,362,367],{"__ignoreMap":32},[37,353,354],{"class":39,"line":40},[37,355,356],{},"mkdir test-express\n",[37,358,359],{"class":39,"line":64},[37,360,361],{},"cd test-express\n",[37,363,364],{"class":39,"line":130},[37,365,366],{},"express --no-view\n",[37,368,370],{"class":39,"line":369},4,[37,371,372],{},"npm install\n",[17,374,375],{},"Now just copy the Setup screen commands one by one. It'll ask whether to install \"dotenv-vault\" — just say Y.",[17,377,378],{},[259,379],{"alt":223,"src":380},"https:\u002F\u002Fi.imgur.com\u002FGEgFrCc.png",[17,382,383,384,387,388,391],{},"It creates a ",[34,385,386],{},".env.vault"," file. Step two: ",[34,389,390],{},"npx dotenv-vault@latest login"," opens a browser — click \"Log in\".",[17,393,394],{},[259,395],{"alt":261,"src":396},"https:\u002F\u002Fi.imgur.com\u002FolKuyOq.png",[17,398,399,400,403],{},"The screen will ask you to run ",[34,401,402],{},"npx dotenv-vault@latest open"," in the terminal — that opens the env project dashboard.",[17,405,406],{},[259,407],{"alt":408,"src":409},"env dashboard","https:\u002F\u002Fi.imgur.com\u002FXaYaggs.png",[17,411,412],{},"Here I add an env entry: name TEST, value Hello.",[17,414,415],{},[259,416],{"alt":417,"src":418},"Add","https:\u002F\u002Fi.imgur.com\u002FpIRT9JI.png",[17,420,421,422,424],{},"After adding, go back to the terminal and run ",[34,423,332],{}," to fetch the remote env.",[17,426,427],{},[259,428],{"alt":429,"src":430},"pull","https:\u002F\u002Fi.imgur.com\u002F22WveiN.png",[17,432,433,434,436],{},"Now if you want to add anything else, just edit ",[34,435,48],{}," directly. For example:",[27,438,440],{"className":52,"code":439,"language":54,"meta":32,"style":32},"# development\nTEST=\"Hello\"\nDATEBASE=\"URLQQ\"\nDATEBASE_PASSWORD=\"URLQQ\"\n",[34,441,442,447,452,457],{"__ignoreMap":32},[37,443,444],{"class":39,"line":40},[37,445,446],{},"# development\n",[37,448,449],{"class":39,"line":64},[37,450,451],{},"TEST=\"Hello\"\n",[37,453,454],{"class":39,"line":130},[37,455,456],{},"DATEBASE=\"URLQQ\"\n",[37,458,459],{"class":39,"line":369},[37,460,461],{},"DATEBASE_PASSWORD=\"URLQQ\"\n",[17,463,464],{},[259,465],{"alt":466,"src":467},"push","https:\u002F\u002Fi.imgur.com\u002FdVIDo4Q.png",[17,469,470,471,473],{},"To push to remote, just run ",[34,472,336],{},":",[17,475,476],{},[259,477],{"alt":466,"src":478},"https:\u002F\u002Fi.imgur.com\u002F6IrShOd.png",[17,480,481],{},"The remote now reflects what we updated locally.",[17,483,484],{},[259,485],{"alt":54,"src":486},"https:\u002F\u002Fi.imgur.com\u002FtMtzWy9.png",[241,488,490],{"id":489},"adding-env-project-members","Adding env project members",[17,492,493],{},"Adding members is also dead simple — there's a People tab at the top. Switch over and add a member's email.",[17,495,496],{},[259,497],{"alt":498,"src":499},"Add member","https:\u002F\u002Fi.imgur.com\u002FfFl6eVh.png",[17,501,502],{},"They'll see the env project in their own dashboard.",[17,504,505],{},[259,506],{"alt":54,"src":507},"https:\u002F\u002Fi.imgur.com\u002FmfJAC1n.png",[17,509,510],{},"To pull a project env, just click Setup next to it.",[17,512,513],{},[259,514],{"alt":54,"src":515},"https:\u002F\u002Fi.imgur.com\u002F3iw6k2t.png",[17,517,518,519,521],{},"Follow steps to step two, then run ",[34,520,332],{}," to get the env locally.",[17,523,524],{},"So the only commands you really need to know are:",[526,527,528,535,540,545],"ul",{},[529,530,531,532],"li",{},"Add a credential to a project: ",[34,533,534],{},"npx dotenv-vault@latest new 'key'",[529,536,537,538],{},"Login: ",[34,539,390],{},[529,541,542,543],{},"Pull env: ",[34,544,332],{},[529,546,547,548],{},"Push env to 