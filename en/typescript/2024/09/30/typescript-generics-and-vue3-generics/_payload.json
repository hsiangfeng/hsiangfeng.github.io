and keep TypeScript's type checking.",[36,264,266],{"className":38,"code":265,"language":40,"meta":41,"style":41},"function sayHello\u003CT>(name: T): T {\n  return `Hello, ${name}`;\n}\n",[43,267,268,298,310],{"__ignoreMap":41},[46,269,270,272,274,277,280,283,285,287,290,292,294,296],{"class":48,"line":49},[46,271,127],{"class":52},[46,273,131],{"class":130},[46,275,276],{"class":73},"\u003C",[46,278,279],{"class":137},"T",[46,281,282],{"class":73},">(",[46,284,138],{"class":137},[46,286,60],{"class":52},[46,288,289],{"class":137}," T",[46,291,145],{"class":73},[46,293,60],{"class":52},[46,295,289],{"class":137},[46,297,152],{"class":73},[46,299,300,302,304,306,308],{"class":48,"line":155},[46,301,158],{"class":52},[46,303,161],{"class":69},[46,305,138],{"class":73},[46,307,166],{"class":69},[46,309,74],{"class":73},[46,311,312],{"class":48,"line":171},[46,313,174],{"class":73},[13,315,316,317,320,321,323,324,326,327,203],{},"The syntax is simple — add ",[43,318,319],{},"\u003CT>"," after the function name to mark it as a generic function. ",[43,322,279],{}," is the type parameter. When you call ",[43,325,180],{},", TypeScript will infer the type of ",[43,328,138],{},[36,330,332],{"className":38,"code":331,"language":40,"meta":41,"style":41},"const result = sayHello('Ray');\n",[43,333,334],{"__ignoreMap":41},[46,335,336,338,341,343,345,347,350],{"class":48,"line":49},[46,337,53],{"class":52},[46,339,340],{"class":56}," result",[46,342,66],{"class":52},[46,344,131],{"class":130},[46,346,134],{"class":73},[46,348,349],{"class":69},"'Ray'",[46,351,352],{"class":73},");\n",[13,354,355,356,358,359,361,362,364,365,367,368,371,372,203],{},"Above, we called ",[43,357,180],{}," with the string ",[43,360,349],{},", so TypeScript infers ",[43,363,138],{}," as ",[43,366,84],{},", and ",[43,369,370],{},"result"," also as ",[43,373,84],{},[90,375,376],{},[13,377,378,380,382,383,193,386,193,389,193,392,395],{},[95,379,97],{},[43,381,319],{}," is just a type parameter name — there's no special meaning to it. You can use any name: ",[43,384,385],{},"\u003CType>",[43,387,388],{},"\u003CU>",[43,390,391],{},"\u003CV>",[43,393,394],{},"\u003CG>",", etc.",[13,397,398,399,401],{},"A little confusing? No worries — let's use diagrams. When you write ",[43,400,319],{},", the type passed in at call time gets forwarded through:",[13,403,404],{},[16,405],{"alt":18,"src":406},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.35.33.png",[13,408,409,410,413,414,364,416,60],{},"In ",[43,411,412],{},"const result = sayHello('Ray');",", we passed in a string, so TypeScript infers ",[43,415,279],{},[43,417,84],{},[13,419,420],{},[16,421],{"alt":18,"src":422},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.37.44.png",[13,424,425,426,428,429,431,432,434,435,437],{},"In the diagram, ",[43,427,319],{}," gets replaced with ",[43,430,84],{},", and that ",[43,433,84],{}," flows into both the ",[43,436,138],{}," parameter and the return value. That's how TypeScript infers the types automatically:",[13,439,440],{},[16,441],{"alt":18,"src":442},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Ftypescript\u002Ftypescript-generics\u002F%E6%88%AA%E5%9C%96%202024-10-02%2013.41.37.png",[13,444,445,446,449],{},"When you call ",[43,447,448],{},"sayHello('Ray')"," and pass a string directly, that's called \"explicit type\" — TypeScript can infer the type so you keep type-checking.",[13,451,452],{},"If you want to specify the type manually, you can do that too — just provide the type when calling:",[36,454,456],{"className":38,"code":455,"language":40,"meta":41,"style":41},"const result = sayHello\u003Cnumber>('Ray');\n",[43,457,458],{"__ignoreMap":41},[46,459,460,462,464,466,468,470,473,475,477],{"class":48,"line":49},[46,461,53],{"class":52},[46,463,340],{"class":56},[46,465,66],{"class":52},[46,