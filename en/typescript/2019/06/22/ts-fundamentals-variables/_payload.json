[{"data":1,"prerenderedAt":486},["ShallowReactive",2],{"header-locale:\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-variables\u002F":3,"page:\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-variables\u002F":4,"alt:\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-variables\u002F":3,"prev-next:\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-variables\u002F":461,"related:\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-variables\u002F":470},"\u002FTypeScript\u002F20190622\u002F3955309115\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":8,"body":9,"category":444,"date":445,"description":446,"extension":447,"lang":448,"meta":449,"navigation":278,"path":450,"readingMinutes":451,"seo":452,"standalone":453,"stem":454,"tags":455,"tldr":458,"updated":445,"url":459,"__hash__":460},"content\u002Fen\u002FTypeScript\u002Fts-fundamentals-variables.md","TypeScript Fundamentals — Variables","9841933878","\u002Ftypescript\u002F20190622\u002F3955309115\u002F",{"type":10,"value":11,"toc":437},"minimark",[12,17,21,25,28,31,38,49,53,56,63,70,73,76,82,86,89,138,141,183,186,192,203,241,244,250,253,412,415,421,425,433],[13,14,16],"h2",{"id":15},"intro","Intro",[18,19,20],"p",{},"A lot of frontend devs around me end up touching TypeScript at some point, so let me write a basic intro to it.",[13,22,24],{"id":23},"what-is-typescript","What is TypeScript?",[18,26,27],{},"Before learning anything new, the basics first. What's TypeScript?",[18,29,30],{},"TypeScript is a strict superset of JavaScript. What's a \"strict superset\"? Basically it's stricter than JS but still includes everything in JS \u002F ES.",[18,32,33],{},[34,35],"img",{"alt":36,"src":37},"Hand-drawn diagram (ugly)","https:\u002F\u002Fi.imgur.com\u002FhQBV3ej.png",[18,39,40,41,48],{},"For more details, check ",[42,43,47],"a",{"href":44,"rel":45},"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FTypeScript",[46],"nofollow","Wikipedia",".",[13,50,52],{"id":51},"getting-started","Getting started",[18,54,55],{},"TypeScript needs to be transpiled (like CoffeeScript), so we can use Gulp to handle it. Gulp has a plugin for this:",[18,57,58],{},[42,59,62],{"href":60,"rel":61},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fgulp-typescript",[46],"gulp-typescript",[18,64,65,66,48],{},"Without rambling too much, I'll get to writing TypeScript. If you're not familiar with Gulp, check out my earlier Gulp series ",[42,67,69],{"href":68},"\u002Fcategories\u002Fgulp\u002F","Talking About Gulp the Task Runner, Not the Drink (article in Mandarin)",[18,71,72],{},"I'll fast-forward past the install \u002F Gulp setup.",[18,74,75],{},"Note: Gulp environment must be Gulp 4.",[18,77,78],{},[34,79],{"alt":80,"src":81},"Setup","https:\u002F\u002Fi.imgur.com\u002FsJTtXLB.png",[13,83,85],{"id":84},"writing-variables","Writing variables",[18,87,88],{},"TypeScript declares variables a bit differently. In JavaScript:",[90,91,96],"pre",{"className":92,"code":93,"language":94,"meta":95,"style":95},"language-js shiki shiki-themes github-dark-high-contrast","const isA = 10;\nconst isB = '小明';\n","js","",[97,98,99,122],"code",{"__ignoreMap":95},[100,101,104,108,112,115,118],"span",{"class":102,"line":103},"line",1,[100,105,107],{"class":106},"sWyjQ","const",[100,109,111],{"class":110},"sCcAr"," isA",[100,113,114],{"class":106}," =",[100,116,117],{"class":110}," 10",[100,119,121],{"class":120},"sMAXC",";\n",[100,123,125,127,130,132,136],{"class":102,"line":124},2,[100,126,107],{"class":106},[100,128,129],{"class":110}," isB",[100,131,114],{"class":106},[100,133,135],{"class":134},"sTRMh"," '小明'",[100,137,121],{"class":120},[18,139,140],{},"In TypeScript you need to declare the type:",[90,142,146],{"className":143,"code":144,"language":145,"meta":95,"style":95},"language-ts shiki shiki-themes github-dark-high-contrast","const isA: number = 10;\nconst isB: string = '小明';\n","ts",[97,147,148,166],{"__ignoreMap":95},[100,149,150,152,154,157,160,162,164],{"class":102,"line":103},[100,151,107],{"class":106},[100,153,111],{"class":110},[100,155,156],{"class":106},":",[100,158,159],{"class":110}," number",[100,161,114],{"class":106},[100,163,117],{"class":110},[100,165,121],{"class":120},[100,167,168,170,172,174,177,179,181],{"class":102,"line":124},[100,169,107],{"class":106},[100,171,129],{"class":110},[100,173,156],{"class":106},[100,175,176],{"class":110}," string",[100,178,114],{"class":106},[100,180,135],{"class":134},[100,182,121],{"class":120},[18,184,185],{},"After compilation you get the same JS:",[18,187,188],{},[34,189],{"alt":190,"src":191},"TypeScript output","https:\u002F\u002Fi.imgur.com\u002FZRWGumI.png",[18,193,194,195,198,199,202],{},"But what if you don't declare a type? It still compiles, but you lose the whole point of TypeScript. If you say ",[97,196,197],{},"isA"," is ",[97,200,201],{},"number"," but accidentally assign a string:",[90,204,206],{"className":143,"code":205,"language":145,"meta":95,"style":95},"const isA: number = '123';\nconst isB: string = '小明';\n",[97,207,208,225],{"__ignoreMap":95},[100,209,210,212,214,216,218,220,223],{"class":102,"line":103},[100,211,107],{"class":106},[100,213,111],{"class":110},[100,215,156],{"class":106},[100,217,159],{"class":110},[100,219,114],{"class":106},[100,221,222],{"class":134}," '123'",[100,224,121],{"class":120},[100,226,227,229,231,233,235,237,239],{"class":102,"line":124},[100,228,107],{"class":106},[100,230,129],{"class":110},[100,232,156],{"class":106},[100,234,176],{"class":110},[100,236,114],{"class":106},[100,238,135],{"class":134},[100,240,121],{"class":120},[18,242,243],{},"You get an error — TypeScript is telling you the value you assigned isn't the right type.",[18,245,246],{},[34,247],{"alt":248,"src":249},"Wrong type","https:\u002F\u002Fi.imgur.com\u002Fp2v3goE.png",[18,251,252],{},"The main TS types:",[90,254,256],{"className":143,"code":255,"language":145,"meta":95,"style":95},"const isA: number = '123';\n\nconst isB: string = '小明';\n\n\u002F\u002F Don't use `new Boolean` — that creates an object via constructor, not a boolean\nconst isC: boolean = false;\n\n\u002F\u002F JavaScript has no concept of \"no value\", so TypeScript uses `void`, but declaring void on a variable is basically useless\nconst isD: void = undefined; \u002F\u002F void only accepts undefined and null\n\n\u002F\u002F You can also declare undefined and null as types\nconst isE: undefined = undefined;\nconst isF: null = null;\n",[97,257,258,274,280,297,302,309,329,334,340,364,369,375,393],{"__ignoreMap":95},[100,259,260,262,264,266,268,270,272],{"class":102,"line":103},[100,261,107],{"class":106},[100,263,111],{"class":110},[100,265,156],{"class":106},[100,267,159],{"class":110},[100,269,114],{"class":106},[100,271,222],{"class":134},[100,273,121],{"class":120},[100,275,276],{"class":102,"line":124},[100,277,279],{"emptyLinePlaceholder":278},true,"\n",[100,281,283,285,287,289,291,293,295],{"class":102,"line":282},3,[100,284,107],{"class":106},[100,286,129],{"class":110},[100,288,156],{"class":106},[100,290,176],{"class":110},[100,292,114],{"class":106},[100,294,135],{"class":134},[100,296,121],{"class":120},[100,298,300],{"class":102,"line":299},4,[100,301,279],{"emptyLinePlaceholder":278},[100,303,305],{"class":102,"line":304},5,[100,306,308],{"class":307},"sQrFR","\u002F\u002F Don't use `new Boolean` — that creates an object via constructor, not a boolean\n",[100,310,312,314,317,319,322,324,327],{"class":102,"line":311},6,[100,313,107],{"class":106},[100,315,316],{"class":110}," isC",[100,318,156],{"class":106},[100,320,321],{"class":110}," boolean",[100,323,114],{"class":106},[100,325,326],{"class":110}," false",[100,328,121],{"class":120},[100,330,332],{"class":102,"line":331},7,[100,333,279],{"emptyLinePlaceholder":278},[100,335,337],{"class":102,"line":336},8,[100,338,339],{"class":307},"\u002F\u002F JavaScript has no concept of \"no value\", so TypeScript uses `void`, but declaring void on a variable is basically useless\n",[100,341,343,345,348,350,353,355,358,361],{"class":102,"line":342},9,[100,344,107],{"class":106},[100,346,347],{"class":110}," isD",[100,349,156],{"class":106},[100,351,352],{"class":110}," void",[100,354,114],{"class":106},[100,356,357],{"class":110}," undefined",[100,359,360],{"class":120},"; ",[100,362,363],{"class":307},"\u002F\u002F void only accepts undefined and null\n",[100,365,367],{"class":102,"line":366},10,[100,368,279],{"emptyLinePlaceholder":278},[100,370,372],{"class":102,"line":371},11,[100,373,374],{"class":307},"\u002F\u002F You can also declare undefined and null as types\n",[100,376,378,380,383,385,387,389,391],{"class":102,"line":377},12,[100,379,107],{"class":106},[100,381,382],{"class":110}," isE",[100,384,156],{"class":106},[100,386,357],{"class":110},[100,388,114],{"class":106},[100,390,357],{"class":110},[100,392,121],{"class":120},[100,394,396,398,401,403,406,408,410],{"class":102,"line":395},13,[100,397,107],{"class":106},[100,399,400],{"class":110}," isF",[100,402,156],{"class":106},[100,404,405],{"class":110}," null",[100,407,114],{"class":106},[100,409,405],{"class":110},[100,411,121],{"class":120},[18,413,414],{},"Compiled output:",[18,416,417],{},[34,418],{"alt":419,"src":420},"Main types","https:\u002F\u002Fi.imgur.com\u002F8dWV7Wj.png",[13,422,424],{"id":423},"wrapping-up","Wrapping up",[18,426,427,428,432],{},"You can already see what TypeScript gives you — JavaScript is weakly typed and dynamic, so you only find out the runtime type at runtime. TypeScript lets you declare types upfront, which avoids a lot of weird bugs. Another benefit — ",[429,430,431],"strong",{},"you don't have to worry about browser compatibility",", because TypeScript already does what Babel does, so you can freely write ES5–ES6+ in TS.",[434,435,436],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":95,"searchDepth":124,"depth":124,"links":438},[439,440,441,442,443],{"id":15,"depth":124,"text":16},{"id":23,"depth":124,"text":24},{"id":51,"depth":124,"text":52},{"id":84,"depth":124,"text":85},{"id":423,"depth":124,"text":424},"TypeScript","2019-06-22 15:06:22","A lot of frontend devs around me run into TypeScript sooner or later, so here's a basic intro — starting with variables.","md","en",{},"\u002Fen\u002Ftypescript\u002Fts-fundamentals-variables","2",{"title":6,"description":446},false,"en\u002FTypeScript\u002Fts-fundamentals-variables",[456,457,444],"TypeScript Fundamentals","JavaScript",null,"\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-variables\u002F","dtq8-Pw2pOqjtpKDv2C9fgplLJdseRH_CvuUtADPR74",{"newer":462,"older":466},{"url":463,"title":464,"date":465},"\u002Fen\u002Ftypescript\u002F2019\u002F06\u002F22\u002Fts-fundamentals-type-inference\u002F","TypeScript Fundamentals — Type Inference","2019-06-22 15:49:05",{"url":467,"title":468,"date":469},"\u002Fen\u002Fgit\u002F2019\u002F06\u002F21\u002Fhow-to-resolve-github-conflicts\u002F","How to Resolve GitHub Conflicts","2019-06-21 16:35:09",[471,476,481],{"url":472,"title":473,"date":474,"readingMinutes":475},"\u002Fen\u002Ftypescript\u002F2024\u002F09\u002F30\u002Ftypescript-generics-and-v