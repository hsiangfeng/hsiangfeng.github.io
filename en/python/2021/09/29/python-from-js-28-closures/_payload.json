},"600",[41,858,629],{"class":155},[41,860,862],{"class":43,"line":861},35,[41,863,864],{"class":260},"\u002F\u002F check Mei's current balance\n",[41,866,868,870,872,874],{"class":43,"line":867},36,[41,869,816],{"class":151},[41,871,747],{"class":155},[41,873,802],{"class":151},[41,875,242],{"class":155},[41,877,879],{"class":43,"line":878},37,[41,880,881],{"class":260},"\u002F\u002F Wang only spends 300\n",[41,883,885,888,890,892,894,896],{"class":43,"line":884},38,[41,886,887],{"class":151},"wang",[41,889,747],{"class":155},[41,891,286],{"class":151},[41,893,251],{"class":155},[41,895,784],{"class":170},[41,897,629],{"class":155},[41,899,901],{"class":43,"line":900},39,[41,902,903],{"class":260},"\u002F\u002F check Wang's current balance\n",[41,905,907,909,911,913],{"class":43,"line":906},40,[41,908,887],{"class":151},[41,910,747],{"class":155},[41,912,802],{"class":151},[41,914,242],{"class":155},[17,916,917],{},"So here's the question — can Python pull off the same thing? The answer is yes, you just have to tweak how you write it:",[31,919,921],{"className":33,"code":920,"language":35,"meta":36,"style":36},"def myMoney(storage):\n  icash = storage\n\n  def nowMoney():\n    return print('Current balance:', icash)\n\n  def count(price):\n    nonlocal icash\n    icash = icash - price\n    return print('Remaining after deduction:', icash)\n\n  return {\n    'nowMoney': nowMoney,\n    'count': count,\n  }\n\n# Ming is broke and only tops up 500$\nming = myMoney(500)\n# Mei just struck it rich and tops up 5000$\nmei = myMoney(5000)\n# Wang somehow has money and tops up 30000$\nwang = myMoney(30000)\n\n# Ming spends 500$ three days in a row\nming['count'](100)\nming['count'](100)\nming['count'](300)\n# check Ming's current balance\nming['nowMoney']()\n# Mei spends 2300\nmei['count'](1600)\nmei['count'](100)\nmei['count'](600)\n# check Mei's current balance\nmei['nowMoney']()\n# Wang only spends 300\nwang['count'](300)\n# check Wang's current balance\nwang['nowMoney']()\n",[38,922,923,928,933,937,942,947,951,956,960,964,969,973,978,983,988,992,996,1001,1006,1011,1016,1021,1026,1030,1035,1040,1044,1049,1054,1059,1064,1069,1074,1079,1084,1089,1094,1099,1104],{"__ignoreMap":36},[41,924,925],{"class":43,"line":44},[41,926,927],{},"def myMoney(storage):\n",[41,929,930],{"class":43,"line":50},[41,931,932],{},"  icash = storage\n",[41,934,935],{"class":43,"line":57},[41,936,54],{"emptyLinePlaceholder":53},[41,938,939],{"class":43,"line":63},[41,940,941],{},"  def nowMoney():\n",[41,943,944],{"class":43,"line":69},[41,945,946],{},"    return print('Current balance:', icash)\n",[41,948,949],{"class":43,"line":74},[41,950,54],{"emptyLinePlaceholder":53},[41,952,953],{"class":43,"line":223},[41,954,955],{},"  def count(price):\n",[41,957,958],{"class":43,"line":229},[41,959,321],{},[41,961,962],{"class":43,"line":245},[41,963,326],{},[41,965,966],{"class":43,"line":264},[41,967,968],{},"    return print('Remaining after deduction:', icash)\n",[41,970,971],{"class":43,"line":585},[41,972,54],{"emptyLinePlaceholder":53},[41,974,975],{"class":43,"line":601},[41,976,977],{},"  return {\n",[41,979,980],{"class":43,"line":607},[41,981,982],{},"    'nowMoney': nowMoney,\n",[41,984,985],{"class":43,"line":632},[41,986,987],{},"    'count': count,\n",[41,989,990],{"class":43,"line":638},[41,991,647],{},[41,993,994],{"class":43,"line":644},[41,995,54],{"emptyLinePlaceholder":53},[41,997,998],{"class":43,"line":650},[41,999,1000],{},"# Ming is broke and only tops up 500$\n",[41,1002,1003],{"class":43,"line":655},[41,1004,1005],{},"ming = myMoney(500)\n",[41,1007,1008],{"class":43,"line":661},[41,1009,1010],{},"# Mei just struck it rich and tops up 5000$\n",[41,1012,1013],{"class":43,"line":680},[41,1014,1015],{},"mei = myMoney(5000)\n",[41,1017,1018],{"class":43,"line":686},[41,1019,1020],{},"# Wang somehow has money and tops up 30000$\n",[41,1022,1023],{"class":43,"line":705},[41,1024,1025],{},"wang = myMoney(30000)\n",[41,1027,1028],{"class":43,"lin