[{"data":1,"prerenderedAt":1246},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fpython\u002F2021\u002F09\u002F29\u002Fpython-from-js-28-closures\u002F":3,"page:\u002Fen\u002Fpython\u002F2021\u002F09\u002F29\u002Fpython-from-js-28-closures\u002F":4,"alt:\u002Fen\u002Fpython\u002F2021\u002F09\u002F29\u002Fpython-from-js-28-closures\u002F":3,"prev-next:\u002Fen\u002Fpython\u002F2021\u002F09\u002F29\u002Fpython-from-js-28-closures\u002F":1226,"related:\u002Fen\u002Fpython\u002F2021\u002F09\u002F29\u002Fpython-from-js-28-closures\u002F":1235},"\u002Fpython\u002F20210929\u002F585008686\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1208,"date":1209,"description":1210,"extension":1211,"lang":1212,"meta":1213,"navigation":53,"path":1214,"readingMinutes":1215,"seo":1216,"standalone":1217,"stem":1218,"tags":1219,"tldr":1223,"updated":1209,"url":1224,"__hash__":1225},"content\u002Fen\u002FPython\u002Fpython-from-js-28-closures.md","Learning Python From a JavaScript Angle (28) - Closures","1002549921",{"type":9,"value":10,"toc":1199},"minimark",[11,16,20,24,27,30,78,85,116,119,126,129,133,136,277,294,297,351,354,396,403,406,410,413,915,918,1109,1112,1115,1121,1125,1142,1146,1149,1152,1156,1189,1195],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"JavaScript has this thing called a closure. Does Python have it too? In this chapter we'll have a relaxed chat about how to write a closure in Python if you actually want one.",[12,21,23],{"id":22},"variable-scope","Variable scope",[17,25,26],{},"First, a quick recap of the earlier \"Learning Python From a JavaScript Angle (6) - Variable Scope\" chapter. We already know every variable has its own scope — global variables, local variables, and so on.",[17,28,29],{},"Take a global variable. As long as you put it at the outermost level of your code, you can always find it by looking upward, kind of like JavaScript's scope chain:",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-py shiki shiki-themes github-dark-high-contrast","money = 1\n\ndef fn():\n  print(money) # 1\n\nfn()\n","py","",[38,39,40,48,55,61,67,72],"code",{"__ignoreMap":36},[41,42,45],"span",{"class":43,"line":44},"line",1,[41,46,47],{},"money = 1\n",[41,49,51],{"class":43,"line":50},2,[41,52,54],{"emptyLinePlaceholder":53},true,"\n",[41,56,58],{"class":43,"line":57},3,[41,59,60],{},"def fn():\n",[41,62,64],{"class":43,"line":63},4,[41,65,66],{},"  print(money) # 1\n",[41,68,70],{"class":43,"line":69},5,[41,71,54],{"emptyLinePlaceholder":53},[41,73,75],{"class":43,"line":74},6,[41,76,77],{},"fn()\n",[17,79,80,81,84],{},"What about local variables? I mentioned before that Python variables behave a lot like JavaScript's ",[38,82,83],{},"var"," — they're function-scoped. So a variable declared inside a function can't be reached from outside that function:",[31,86,88],{"className":33,"code":87,"language":35,"meta":36,"style":36},"def fn():\n  money = 1\n  print(money) # 1\n\nfn()\nprint(money) # NameError: name 'money' is not defined\n",[38,89,90,94,99,103,107,111],{"__ignoreMap":36},[41,91,92],{"class":43,"line":44},[41,93,60],{},[41,95,96],{"class":43,"line":50},[41,97,98],{},"  money = 1\n",[41,100,101],{"class":43,"line":57},[41,102,66],{},[41,104,105],{"class":43,"line":63},[41,106,54],{"emptyLinePlaceholder":53},[41,108,109],{"class":43,"line":69},[41,110,77],{},[41,112,113],{"class":43,"line":74},[41,114,115],{},"print(money) # NameError: name 'money' is not defined\n",[17,117,118],{},"Alright, that's enough recap. That's pretty much it for today...",[17,120,121],{},[122,123],"img",{"alt":124,"src":125},"You're messing with me again!","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632558615063.png",[17,127,128],{},"Don't worry, we were just doing a quick refresher on variable scope. Now let's get into how to write a closure in Python.",[12,130,132],{"id":131},"closures","Closures",[17,134,135],{},"Before we get into writing a Python closure, let me pull up the JavaScript closure example I wrote earlier:",[31,137,141],{"className":138,"code":139,"language":140,"meta":36,"style":36},"language-js shiki shiki-themes github-dark-high-contrast","function count() {\n let icash = 1000;\n return function (price){\n  icash = icash - price;\n  return icash;\n }\n}\nlet ray = count();\nray(100); \u002F\u002F 900\nray(200); \u002F\u002F 700\n","js",[38,142,143,157,175,193,208,216,221,227,243,262],{"__ignoreMap":36},[41,144,145,149,153],{"class":43,"line":44},[41,146,148],{"class":147},"sWyjQ","function",[41,150,152],{"class":151},"sj_SG"," count",[41,154,156],{"class":155},"sMAXC","() {\n",[41,158,159,162,165,168,172],{"class":43,"line":50},[41,160,161],{"class":147}," let",[41,163,164],{"class":155}," icash ",[41,166,167],{"class":147},"=",[41,169,171],{"class":170},"sCcAr"," 1000",[41,173,174],{"class":155},";\n",[41,176,177,180,183,186,190],{"class":43,"line":57},[41,178,179],{"class":147}," return",[41,181,182],{"class":147}," function",[41,184,185],{"class":155}," (",[41,187,189],{"class":188},"s_sBn","price",[41,191,192],{"class":155},"){\n",[41,194,195,198,200,202,205],{"class":43,"line":63},[41,196,197],{"class":155},"  icash ",[41,199,167],{"class":147},[41,201,164],{"class":155},[41,203,204],{"class":147},"-",[41,206,207],{"class":155}," price;\n",[41,209,210,213],{"class":43,"line":69},[41,211,212],{"class":147},"  return",[41,214,215],{"class":155}," icash;\n",[41,217,218],{"class":43,"line":74},[41,219,220],{"class":155}," }\n",[41,222,224],{"class":43,"line":223},7,[41,225,226],{"class":155},"}\n",[41,228,230,233,236,238,240],{"class":43,"line":229},8,[41,231,232],{"class":147},"let",[41,234,235],{"class":155}," ray ",[41,237,167],{"class":147},[41,239,152],{"class":151},[41,241,242],{"class":155},"();\n",[41,244,246,249,252,255,258],{"class":43,"line":245},9,[41,247,248],{"class":151},"ray",[41,250,251],{"class":155},"(",[41,253,254],{"class":170},"100",[41,256,257],{"class":155},"); ",[41,259,261],{"class":260},"sQrFR","\u002F\u002F 900\n",[41,263,265,267,269,272,274],{"class":43,"line":264},10,[41,266,248],{"class":151},[41,268,251],{"class":155},[41,270,271],{"class":170},"200",[41,273,257],{"class":155},[41,275,276],{"class":260},"\u002F\u002F 700\n",[17,278,279,280,283,284,287,288,293],{},"That's a super simple JavaScript closure. Under normal circumstances, the ",[38,281,282],{},"icash"," variable inside ",[38,285,286],{},"count"," won't have its memory freed, because the inner anonymous function still references it. That lets us reuse that variable's memory. If you're not comfortable with closures in JavaScript, I'd suggest reading my article \"",[289,290,292],"a",{"href":291},"\u002Fjavascript\u002F20201220\u002F3559993634\u002F","JavaScript Core Concepts (38) - How Functions and This Work - Closures","\" first (article in Mandarin).",[17,295,296],{},"Now back to Python. If we want to write the same closure as the JavaScript one above, how do we do it? Here's what that code looks like rewritten in Python:",[31,298,300],{"className":33,"code":299,"language":35,"meta":36,"style":36},"def count():\n  icash = 1000\n  def reduce(price):\n    nonlocal icash\n    icash = icash - price\n  return reduce\n\nray = count()\nray(100) # 900\nray(200) # 700\n",[38,301,302,307,312,317,322,327,332,336,341,346],{"__ignoreMap":36},[41,303,304],{"class":43,"line":44},[41,305,306],{},"def count():\n",[41,308,309],{"class":43,"line":50},[41,310,311],{},"  icash = 1000\n",[41,313,314],{"class":43,"line":57},[41,315,316],{},"  def reduce(price):\n",[41,318,319],{"class":43,"line":63},[41,320,321],{},"    nonlocal icash\n",[41,323,324],{"class":43,"line":69},[41,325,326],{},"    icash = icash - price\n",[41,328,329],{"class":43,"line":74},[41,330,331],{},"  return reduce\n",[41,333,334],{"class":43,"line":223},[41,335,54],{"emptyLinePlaceholder":53},[41,337,338],{"class":43,"line":229},[41,339,340],{},"ray = count()\n",[41,342,343],{"class":43,"line":245},[41,344,345],{},"ray(100) # 900\n",[41,347,348],{"class":43,"line":264},[41,349,350],{},"ray(200) # 700\n",[17,352,353],{},"Oh, and one thing — whatever you do, don't write it like this:",[31,355,357],{"className":33,"code":356,"language":35,"meta":36,"style":36},"def count():\n  icash = 1000\n  return def (price):\n    nonlocal icash\n    icash = icash - price\n\nray = count()\nray(100) # 900\nray(200) # 700\n",[38,358,359,363,367,372,376,380,384,388,392],{"__ignoreMap":36},[41,360,361],{"class":43,"line":44},[41,362,306],{},[41,364,365],{"class":43,"line":50},[41,366,311],{},[41,368,369],{"class":43,"line":57},[41,370,371],{},"  return def (price):\n",[41,373,374],{"class":43,"line":63},[41,375,321],{},[41,377,378],{"class":43,"line":69},[41,379,326],{},[41,381,382],{"class":43,"line":74},[41,383,54],{"emptyLinePlaceholder":53},[41,385,386],{"class":43,"line":223},[41,387,340],{},[41,389,390],{"class":43,"line":229},[41,391,345],{},[41,393,394],{"class":43,"line":245},[41,395,350],{},[17,397,398,399,402],{},"If you try to make it look like JavaScript, all you'll get is a ",[38,400,401],{},"SyntaxError: invalid syntax",".",[17,404,405],{},"So from the examples above, you can see closures basically come hand in hand with nested functions.",[12,407,409],{"id":408},"factory-pattern","Factory pattern",[17,411,412],{},"We know JavaScript closures have a more advanced use too — the factory pattern. With it, we can expose a few operations, like showing the current balance. So here's the JavaScript factory-pattern closure example I wrote before:",[31,414,416],{"className":138,"code":415,"language":140,"meta":36,"style":36},"function myMoney(storage) {\n  var money = storage;\n  return function(price) {\n    return { \u002F\u002F use an object of functions to query and deduct the balance\n      nowMoney: function () {\n        return console.log(money);\n      },\n      count: function (price) {\n        if(money \u003C price) return console.log('Insufficient balance, current balance: ' + money + ' $'); \u002F\u002F when price is greater than the current balance, return an error.\n        if (!money \u003C= 0) { \u002F\u002F when money is 0 or less, skip the calculation.\n          return money = money - price;\n        }\n        return console.log('Deduction failed, current balance: ' + money + ' $');\n      }\n    }\n  }\n}\n\u002F\u002F Ming is broke and only tops up 500$\nvar ming = myMoney(500);\n\u002F\u002F Mei just struck it rich and tops up 5000$\nvar mei = myMoney(5000);\n\u002F\u002F Wang somehow has money and tops up 30000$\nvar wang = myMoney(30000);\n\n\u002F\u002F Ming spends 500$ three days in a row\nming().count(100);\nming().count(100);\nming().count(300);\n\u002F\u002F check Ming's current balance\nming().nowMoney();\n\u002F\u002F Mei spends 2300\nmei().count(1600);\nmei().count(100);\nmei().count(600);\n\u002F\u002F check Mei's current balance\nmei().nowMoney();\n\u002F\u002F Wang only spends 300\nwang().count(300);\n\u002F\u002F check Wang's current balance\nwang().nowMoney();\n",[38,417,418,433,446,458,469,482,496,501,516,559,583,599,605,630,636,642,648,653,659,678,684,703,709,728,733,739,756,771,787,793,805,811,828,843,859,865,876,882,898,904],{"__ignoreMap":36},[41,419,420,422,425,427,430],{"class":43,"line":44},[41,421,148],{"class":147},[41,423,424],{"class":151}," myMoney",[41,426,251],{"class":155},[41,428,429],{"class":188},"storage",[41,431,432],{"class":155},") {\n",[41,434,435,438,441,443],{"class":43,"line":50},[41,436,437],{"class":147},"  var",[41,439,440],{"class":155}," money ",[41,442,167],{"class":147},[41,444,445],{"class":155}," storage;\n",[41,447,448,450,452,454,456],{"class":43,"line":57},[41,449,212],{"class":147},[41,451,182],{"class":147},[41,453,251],{"class":155},[41,455,189],{"class":188},[41,457,432],{"class":155},[41,459,460,463,466],{"class":43,"line":63},[41,461,462],{"class":147},"    return",[41,464,465],{"class":155},