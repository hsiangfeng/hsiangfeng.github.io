[{"data":1,"prerenderedAt":1624},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fpython\u002F2021\u002F09\u002F16\u002Flearn-python-from-javascript-15-modules\u002F":3,"page:\u002Fen\u002Fpython\u002F2021\u002F09\u002F16\u002Flearn-python-from-javascript-15-modules\u002F":4,"alt:\u002Fen\u002Fpython\u002F2021\u002F09\u002F16\u002Flearn-python-from-javascript-15-modules\u002F":3,"prev-next:\u002Fen\u002Fpython\u002F2021\u002F09\u002F16\u002Flearn-python-from-javascript-15-modules\u002F":1600,"related:\u002Fen\u002Fpython\u002F2021\u002F09\u002F16\u002Flearn-python-from-javascript-15-modules\u002F":1609},"\u002Fpython\u002F20210916\u002F2101329033\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1582,"date":1583,"description":1584,"extension":1585,"lang":1586,"meta":1587,"navigation":213,"path":1588,"readingMinutes":1589,"seo":1590,"standalone":1591,"stem":1592,"tags":1593,"tldr":1597,"updated":1583,"url":1598,"__hash__":1599},"content\u002Fen\u002FPython\u002Flearn-python-from-javascript-15-modules.md","Learn Python From a JavaScript Angle (15): Modules","1002439055",{"type":9,"value":10,"toc":1572},"minimark",[11,16,20,24,32,175,182,257,266,269,280,283,389,392,399,402,405,409,412,504,511,621,630,633,638,704,707,713,719,729,732,738,823,826,830,834,840,849,877,918,924,931,954,957,974,983,990,993,1000,1060,1070,1136,1142,1145,1164,1174,1177,1183,1192,1199,1328,1331,1397,1402,1409,1504,1516,1520,1523,1527,1562,1568],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Next up, let's talk about modules in Python. JavaScript has its own concept of modules too, so this is a nice place to compare the two.",[12,21,23],{"id":22},"modules","Modules",[17,25,26,27,31],{},"If you've ever used tools like Webpack or Vue CLI, you've probably already got a decent feel for what a module is. And even if you haven't touched Webpack yet, you've likely run into a bit of code like ",[28,29,30],"code",{},"export default",", for example:",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","\u002F* app.js *\u002F\nexport default {\n  sayHello() {\n    console.log('Hello Ray');\n  },\n  myName: 'Ray',\n  obj: {\n    myName: 'Ray',\n  },\n  arr: [1, 2, 3],\n};\n","js","",[28,40,41,50,64,78,97,106,117,123,133,140,166],{"__ignoreMap":38},[42,43,46],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sQrFR","\u002F* app.js *\u002F\n",[42,51,53,57,60],{"class":44,"line":52},2,[42,54,56],{"class":55},"sWyjQ","export",[42,58,59],{"class":55}," default",[42,61,63],{"class":62},"s_sBn"," {\n",[42,65,67,71,74],{"class":44,"line":66},3,[42,68,70],{"class":69},"sj_SG","  sayHello",[42,72,73],{"class":62},"() ",[42,75,77],{"class":76},"sMAXC","{\n",[42,79,81,84,87,90,94],{"class":44,"line":80},4,[42,82,83],{"class":76},"    console.",[42,85,86],{"class":69},"log",[42,88,89],{"class":76},"(",[42,91,93],{"class":92},"sTRMh","'Hello Ray'",[42,95,96],{"class":76},");\n",[42,98,100,103],{"class":44,"line":99},5,[42,101,102],{"class":76},"  }",[42,104,105],{"class":62},",\n",[42,107,109,112,115],{"class":44,"line":108},6,[42,110,111],{"class":76},"  myName: ",[42,113,114],{"class":92},"'Ray'",[42,116,105],{"class":62},[42,118,120],{"class":44,"line":119},7,[42,121,122],{"class":76},"  obj: {\n",[42,124,126,129,131],{"class":44,"line":125},8,[42,127,128],{"class":76},"    myName: ",[42,130,114],{"class":92},[42,132,105],{"class":76},[42,134,136,138],{"class":44,"line":135},9,[42,137,102],{"class":76},[42,139,105],{"class":62},[42,141,143,146,150,153,156,158,161,164],{"class":44,"line":142},10,[42,144,145],{"class":76},"  arr: [",[42,147,149],{"class":148},"sCcAr","1",[42,151,152],{"class":76},", ",[42,154,155],{"class":148},"2",[42,157,152],{"class":76},[42,159,160],{"class":148},"3",[42,162,163],{"class":76},"]",[42,165,105],{"class":62},[42,167,169,172],{"class":44,"line":168},11,[42,170,171],{"class":62},"}",[42,173,174],{"class":76},";\n",[17,176,177,178,181],{},"Or the ",[28,179,180],{},"module.exports"," syntax that Node.js developers reach for all the time:",[33,183,185],{"className":35,"code":184,"language":37,"meta":38,"style":38},"\u002F* exports.js *\u002F\nmodule.exports = 'Hello World'\n\n\u002F* main.js *\u002F\nconst hello = require('exports');\n\nconsole.log(hello); \u002F\u002F Hello World\n",[28,186,187,192,209,215,220,240,244],{"__ignoreMap":38},[42,188,189],{"class":44,"line":45},[42,190,191],{"class":48},"\u002F* exports.js *\u002F\n",[42,193,194,197,200,203,206],{"class":44,"line":52},[42,195,196],{"class":148},"module",[42,198,199],{"class":76},".",[42,201,202],{"class":148},"exports",[42,204,205],{"class":55}," =",[42,207,208],{"class":92}," 'Hello World'\n",[42,210,211],{"class":44,"line":66},[42,212,214],{"emptyLinePlaceholder":213},true,"\n",[42,216,217],{"class":44,"line":80},[42,218,219],{"class":48},"\u002F* main.js *\u002F\n",[42,221,222,225,228,230,233,235,238],{"class":44,"line":99},[42,223,224],{"class":55},"const",[42,226,227],{"class":148}," hello",[42,229,205],{"class":55},[42,231,232],{"class":69}," require",[42,234,89],{"class":76},[42,236,237],{"class":92},"'exports'",[42,239,96],{"class":76},[42,241,242],{"class":44,"line":108},[42,243,214],{"emptyLinePlaceholder":213},[42,245,246,249,251,254],{"class":44,"line":119},[42,247,248],{"class":76},"console.",[42,250,86],{"class":69},[42,252,253],{"class":76},"(hello); ",[42,255,256],{"class":48},"\u002F\u002F Hello World\n",[17,258,259,260,265],{},"These days the more famous one is probably ESM (ES6 Modules, a.k.a. JavaScript Modules). If you're not familiar with ESM, you might want to check out an earlier post of mine, ",[261,262,264],"a",{"href":263},"\u002Fjavascript\u002F20210424\u002F616364031\u002F","What is ESM (ES6 Modules or JavaScript Modules)? (article in Mandarin)"," — it goes into a lot more detail.",[17,267,268],{},"So here's my quick summary of what a module is:",[270,271,272],"blockquote",{},[17,273,274,275,279],{},"Basically, ",[276,277,278],"strong",{},"one module equals one file",", and that file usually holds a bunch of functions — or features, if you like — that we can use. The point is we can import that file and use it from other files.",[17,281,282],{},"For example, say we have five Python files, and all of them need to do addition and say hello:",[33,284,288],{"className":285,"code":286,"language":287,"meta":38,"style":38},"language-py shiki shiki-themes github-dark-high-contrast","# ch1.py\nprint(1 + 2)\nprint(f'Hello Ray!')\n\n# ch2.py\nprint(10 + 23)\nprint(f'Hello Mike!')\n\n# ch3.py\nprint(12 + 6)\nprint(f'Hello Ming!')\n\n# ch4.py\nprint(105+ 9)\nprint(f'Hello Jack!')\n\n# ch5.py\nprint(189 + 256)\nprint(f'Hello Charles!')\n","py",[28,289,290,295,300,305,309,314,319,324,328,333,338,343,348,354,360,366,371,377,383],{"__ignoreMap":38},[42,291,292],{"class":44,"line":45},[42,293,294],{},"# ch1.py\n",[42,296,297],{"class":44,"line":52},[42,298,299],{},"print(1 + 2)\n",[42,301,302],{"class":44,"line":66},[42,303,304],{},"print(f'Hello Ray!')\n",[42,306,307],{"class":44,"line":80},[42,308,214],{"emptyLinePlaceholder":213},[42,310,311],{"class":44,"line":99},[42,312,313],{},"# ch2.py\n",[42,315,316],{"class":44,"line":108},[42,317,318],{},"print(10 + 23)\n",[42,320,321],{"class":44,"line":119},[42,322,323],{},"print(f'Hello Mike!')\n",[42,325,326],{"class":44,"line":125},[42,327,214],{"emptyLinePlaceholder":213},[42,329,330],{"class":44,"line":135},[42,331,332],{},"# ch3.py\n",[42,334,335],{"class":44,"line":142},[42,336,337],{},"print(12 + 6)\n",[42,339,340],{"class":44,"line":168},[42,341,342],{},"print(f'Hello Ming!')\n",[42,344,346],{"class":44,"line":345},12,[42,347,214],{"emptyLinePlaceholder":213},[42,349,351],{"class":44,"line":350},13,[42,352,353],{},"# ch4.py\n",[42,355,357],{"class":44,"line":356},14,[42,358,359],{},"print(105+ 9)\n",[42,361,363],{"class":44,"line":362},15,[42,364,365],{},"print(f'Hello Jack!')\n",[42,367,369],{"class":44,"line":368},16,[42,370,214],{"emptyLinePlaceholder":213},[42,372,374],{"class":44,"line":373},17,[42,375,376],{},"# ch5.py\n",[42,378,380],{"class":44,"line":379},18,[42,381,382],{},"print(189 + 256)\n",[42,384,386],{"class":44,"line":385},19,[42,387,388],{},"print(f'Hello Charles!')\n",[17,390,391],{},"Doesn't look like a big deal, right? But picture this: what if we had 100 pages that needed this? You'd be writing the same code 100 times. Sure, you might think \"eh, it's fine, I'll just copy-paste.\" Okay, say you've finished pasting all 100 pages. Then the next day your boss tells you to change \"Hello\" into Chinese — now you're editing it 100 times again. Maybe you're thinking \"hah, I'll just use find-and-replace!\" Wow, good for you!",[17,393,394],{},[395,396],"img",{"alt":397,"src":398},"Good for you","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631196405626.png",[17,400,401],{},"Just kidding — the meme above is just a joke.",[17,403,404],{},"But if you make good use of modularization, you only have to edit that one module file. So let's figure out how to modularize the example code above!",[12,406,408],{"id":407},"exporting-a-module","Exporting a Module",[17,410,411],{},"Same as always, let's start with how JavaScript exports a module. Here's an ESM export:",[33,413,414],{"className":35,"code":36,"language":37,"meta":38,"style":38},[28,415,416,420,428,436,448,454,462,466,474,480,498],{"__ignoreMap":38},[42,417,418],{"class":44,"line":45},[42,419,49],{"class":48},[42,421,422,424,426],{"class":44,"line":52},[42,423,56],{"class":55},[42,425,59],{"class":55},[42,427,63],{"class":62},[42,429,430,432,434],{"class":44,"line":66},[42,431,70],{"class":69},[42,433,73],{"class":62},[42,435,77],{"class":76},[42,437,438,440,442,444,446],{"class":44,"line":80},[42,439,83],{"class":76},[42,441,86],{"class":69},[42,443,89],{"class":76},[42,445,93],{"class":92},[42,447,96],{"class":76},[42,449,450,452],{"class":44,"line":99},[42,451,102],{"class":76},[42,453,105],{"class":62},[42,455,456,458,460],{"class":44,"line":108},[42,457,111],{"class":76},[42,459,114],{"class":92},[42,461,105],{"class":62},[42,463,464],{"class":44,"line":119},[42,465,122],{"class":76},[42,467,468,470,472],{"class":44,"line":125},[42,469,128],{"class":76},[42,471,114],{"class":92},[42,473,105],{"class":76},[42,475,476,478],{"class":44,"line":135},[42,477,102],{"class":76},[42,479,105],{"class":62},[42,481,482,484,486,488,490,492,494,496],{"class":44,"line":142},[42,483,145],{"class":76},[42,485,149],{"class":148},[42,487,152],{"class":76},[42,489,155],{"class":148},[42,491,152],{"class":76},[42,493,160],{"class":148},[42,495,163],{"class":76},[42,497,105],{"class":62},[42,499,500,502],{"class":44,"line":168},[42,501,171],{"class":62},[42,503,174],{"class":76},[17,505,506,507,510],{},"To bring it in, you have to use ",[28,508,509],{},"import",":",[33,512,516],{"className":513,"code":514,"language":515,"meta":38,"style":38},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript type=\"module\">\n  import app from '.\u002Fapp.js';\n  console.log(app.myName); \u002F\u002F 'Ray'\n  app.sayHello(); \u002F\u002F Hello Ray\n  console.log(app.obj.myName); \u002F\u002F Ray\n  console.log(app.arr[0]); \u002F\u002F 0\n\u003C\u002Fscript>\n","html",[28,517,518,539,555,568,582,594,612],{"__ignoreMap":38},[42,519,520,523,527,530,533,536],{"class":44,"line":45},[42,521,522],{"class":76},"\u003C",[42,524,526],{"class":525},"sKpQp","script",[42,528,529],{"class":148}," type",[42,531,532],{"class":76},"=",[42,534,535],{"class":92},"\"module\"",[42,537,538],{"class":76},">\n",[42,540,541,544,547,550,553],{"class":44,"line":52},[42,542,543],{"class":55},"  import",[42,545,546],{"class":76}," app ",[42,548,549],{"class":55},"from",[42,551,552],{"class":92}," '.\u002Fapp.js'",[42,554,174],{"class":76},[42,556,557,560,562,565],{"class":44,"line":66},[42,558,559],{"class":76},"  console.",[42,561,86],{"class":69},[42,563,564],{"class":76},"(app.myName); ",[42,566,567],{"class":48},"\u002F\u002F 'Ray'\n",[42,569,570,573,576,579],{"class":44,"line":80},[42,571,572],{"class":76},"  app.",[42,574,575],{"class":69},"sayHello",[42,577,578],{"class":76},"(); ",[42,580,581],{"class":48},"\u002F\u002F Hello Ray\n",[42,583,584,586,588,591],{"class":44,"line":99},[42,585,559],{"class":76},[42,587,86],{"class":69},[42,589,590],{"class":76},"(app.obj.myName); ",[42,592,593],{"class":48},"\u002F\u002F Ray\n",[42,595,596,598,600,603,606,609],{"class":44,"line":108},[42,597,559],{"class":76},[42,599,86],{"class":69},[42,601,602],{"class":76},"(app.arr[",[42,604,605],{"class":148},"0",[42,607,608],{"class":76},"]); ",[42,610,611],{"class":48},"\u002F\u002F 0\n",[42,613,614,617,619],{"class":44,"line":119},[42,615,616],{"class":76},"\u003C\u002F",[42,618,526],{"class":525},[42,620,538],{"class":76},[17,622,623,624,627,628,199],{},"Oh, one thing about ESM — each module has its own isolated scope, meaning one ",[28,625,626],{},"script module"," can't grab variables from another ",[28,629,626],{},[17,631,632],{},"Now let's swing the camera back to Python.",[17,634,635,636,510],{},"So how do you write a module in Python? Honestly it's ridiculously simple — you just split the relevant functions into a separate file and pull them in with ",[28,637,509],{},[33,639,641],{"className":285,"code":640,"language":287,"meta":38,"style":38},"# module.py\ndef add(a, b):\n  return int(a + b)\n\ndef sayHi(name):\n  return f'Hello {name}!'\n\n# example.py\nimport module\n\nprint(module.add(100, 25)) # 125\n\nprint(module.sayHi('Ray')) # Hello Ray!\n",[28,642,643,648,653,658,662,667,672,676,681,686,690,695,699],{"__ignoreMap":38},[42,644,645],{"class":44,"line":45},[42,646,647],{},"# module.py\n",[42,649,650],{"class":44,"line":52},[42,651,652],{},"def add(a, b):\n",[42,654,655],{"class":44,"line":66},[42,656,657],{},"  return int(a + b)\n",[42,659,660],{"class":44,"line":80},[42,661,214],{"emptyLinePlaceholder":213},[42,663,664],{"class":44,"line":99},[42,665,666],{},"def sayHi(name):\n",[42,668,669],{"class":44,"line":108},[42,670,671],{},"  return f'Hello {name}!'\n",[42,673,674],{"class":44,"line":119},[42,675,214],{"emptyLinePlaceholder":213},[42,677,678],{"class":44,"line":125},[42,679,680],{},"# example.py\n",[42,682,683],{"class":44,"line":135},[42,684,685],{},"import module\n",[42,687,688],{"class":44,"line":142},[42,689,214],{"emptyLinePlaceholder":213},[42,691,692],{"class":44,"line":168},[42,693,694],{},"print(module.add(100, 25)) # 125\n",[42,696,697],{"class":44,"line":345},[42,698,214],{"emptyLinePlaceholder":213},[42,700,701],{"class":44,"line":350},[42,702,703],{},"print(module.sayHi('Ray')) # Hello Ray!\n",[17,705,706],{},"Pretty easy, right?",[17,708,709],{},[395,710],{"alt":711,"src":712},"Super easy","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631199687551.png",[17,714,715,716,718],{},"We'll get to the ",[28,717,509],{}," part in a moment.",[17,720,721,722,725,726,728],{},"From the example above you can see that Python makes modularization really convenient — you just create a file, declare your functions, and ",[28,723,724],{},"return"," the results. Compare that with JavaScript, where you also have to use the ",[28,727,56],{}," syntax to send things out.",[17,730,731],{},"Of course, a module might not only contain functions — it could hold a dictionary too. Does that change anything in Python?",[17,733,734,735,737],{},"Nope. You just declare a dictionary as usual, and you don't even need ",[28,736,724],{}," to use it:",[33,739,741],{"className":285,"code":740,"language":287,"meta":38,"style":38},"# module.py\ndef add(a, b):\n  return int(a + b)\n\ndef sayHi(name):\n  return f'Hello {name}!'\n\ndic = {\n  'myName': 'Ray',\n}\n\n# example.py\nimport module\n\nprint(module.add(100, 25)) # 125\n\nprint(module.sayHi('Ray')) # Hello Ray!\n\nprint(module.dic['myName']) # Ray\n",[28,742,743,747,751,755,759,763,767,771,776,781,786,790,794,798,802,806,810,814,818],{"__ignoreMap":38},[42,744,745],{"class":44,"line":45},[42,746,647],{},[42,748,749],{"class":44,"line":52},[42,750,652],{},[42,752,753],{"class":44,"line":66},[42,754,657],{},[42,756,757],{"class":44,"line":80},[42,758,214],{"emptyLinePlaceholder":213},[42,760,761],{"class":44,"line":99},[42,762,666],{},[42,764,765],{"class":44,"line":108},[42,766,671],{},[42,768,769],{"class":44,"line":119},[42,770,214],{"emptyLinePlaceholder":213},[42,772,773],{"class":44,"line":125},[42,774,775],{},"dic = {\n",[42,777,778],{"class":44,"line":135},[42,779,780],{},"  'myName': 'Ray',\n",[42,782,783],{"class":44,"line":142},[42,784,785],{},"}\n",[42,787,788],{"class":44,"line":168},[42,789,214],{"emptyLinePlaceholder":213},[42,791,792],{"class":44,"line":345},[42,793,680],{},[42,795,796],{"class":44,"line":350},[42,797,685],{},[42,799,800],{"class":44,"line":356},[42,801,214],{"emptyLinePlaceholder":213},[42,803,804],{"class":44,"line":362},[42,805,694],{},[42,807,808],{"class":44,"line":368},[42,809,214],{"emptyLinePlaceholder":213},[42,811,812],{"class":44,"line":373},[42,813,703],{},[42,815,816],{"class":44,"line":379},[42,817,214],{"emptyLinePlaceholder":213},[42,819,820],{"class":44,"line":385},[42,821,822],{},"print(module.dic['myName']) # Ray\n",[17,824,825],{},"Super convenient. Here's SpongeBob one more time.",[17,827,828],{},[395,829],{"alt":711,"src":712},[12,831,833],{"id":832},"importing-a-module","Importing a Module",[17,835,836,837,839],{},"Now for something a bit simpler — the ",[28,838,509],{}," syntax itself.",[17,841,842,843,845,846,199],{},"We've already been using ",[28,844,509],{}," in the examples above. And just plainly importing a specific file like that is actually one way of importing everything, so you can directly use all the functions and dictionaries inside ",[28,847,848],{},"module.py",[17,850,851,852,854,855,858,859,862,863,866,867,869,870,873,874,876],{},"But ",[28,853,509],{}," has other tricks too. Take the earlier ",[28,856,857],{},"import module"," — every time you want to use a function from the module, you have to write ",[28,860,861],{},"module.add"," or ",[28,864,865],{},"module.dic"," and so on. At that point ",[28,868,196],{}," starts to feel long and annoying. So you can use ",[28,871,872],{},"as"," with ",[28,875,509],{}," to rename what you're bringing in, and then call it by the new name:",[33,878,880],{"className":285,"code":879,"language":287,"meta":38,"style":38},"# example.py\nimport module as mu\n\nprint(mu.add(100, 25)) # 125\n\nprint(mu.sayHi('Ray')) # Hello Ray!\n\nprint(mu.dic['myName']) # Ray\n",[28,881,882,886,891,895,900,904,909,913],{"__ignoreMap":38},[42,883,884],{"class":44,"line":45},[42,885,680],{},[42,887,888],{"class":44,"line":52},[42,889,890],{},"import module as mu\n",[42,892,893],{"class":44,"line":66},[42,894,214],{"emptyLinePlaceholder":213},[42,896,897],{"class":44,"line":80},[42,898,899],{},"print(mu.add(100, 25)) # 125\n",[42,901,902],{"class":44,"line":99},[42,903,214],{"emptyLinePlaceholder":213},[42,905,906],{"class":44,"line":108},[42,907,908],{},"print(mu.sayHi('Ray')) # Hello Ray!\n",[42,910,911],{"class":44,"line":119},[42,912,214],{"emptyLinePlaceholder":213},[42,914,915],{"class":44,"line":125},[42,916,917],{},"print(mu.dic['myName']) # Ray\n",[17,919,920,921,923],{},"As I mentioned, plainly importing a module means you're pulling the whole package into your file. But sometimes you only want one specific thing from it, and that's where ",[28,922,549],{}," comes in.",[17,925,926,927,930],{},"For example, if I only want to import the ",[28,928,929],{},"dic"," dictionary, I just write:",[33,932,934],{"className":285,"code":933,"language":287,"meta":38,"style":38},"# example.py\nfrom module import dic\n\nprint(dic['myName']) # Ray\n",[28,935,936,940,945,949],{"__ignoreMap":38},[42,937,938],{"class":44,"line":45},[42,939,680],{},[42,941,942],{"class":44,"line":52},[42,943,944],{},"from module import dic\n",[42,946,947],{"class":44,"line":66},[42,948,214],{"emptyLinePlaceholder":213},[42,950,951],{"class":44,"line":80},[42,952,953],{},"print(dic['myName']) # Ray\n",[17,955,956],{},"That basically reads \"from xxx import xxx method.\" Compare that with the JavaScript import:",[33,958,960],{"className":35,"code":959,"language":37,"meta":38,"style":38},"import app from '.\u002Fapp.js';\n",[28,961,962],{"__ignoreMap":38},[42,963,964,966,968,970,972],{"class":44,"line":45},[42,965,509],{"class":55},[42,967,546],{"class":76},[42,969,549],{"class":55},[42,971,552],{"class":92},[42,973,174],{"class":76},[17,975,976,977,979,980,982],{},"You can see the two are written differently — one starts with ",[28,978,549],{},", the other starts with ",[28,981,509],{},". From a JavaScript angle, the gist is \"import xxx, whose source is xxx.\"",[17,984,985,986,989],{},"I'll definitely not admit that I kept writing the long ",[28,987,988],{},"import ... from ..."," while doing Python.",[12,991,992],{"id":992},"dir",[17,994,995,996,999],{},"Lastly, I want to throw in one extra thing I find pretty useful — ",[28,997,998],{},"dir()",". What does it do? In short, it lists out which variables and methods exist in the current scope:",[33,1001,1003],{"className":285,"code":1002,"language":287,"meta":38,"style":38},"# dir.py\ndef add(a, b):\n  print(a, b)\n  return int(a + b)\n\ndef sayHi(name):\n  return f'Hello {name}!'\n\ndic = {\n  'myName': 'Ray',\n}\n\nprint(dir()) # ['__annotations__', '__builtins__', '__cached__', '__doc__', '__file__', '__loader__', '__name__', '__package__', '__spec__', 'add', 'dic', 'sayHi']\n",[28,1004,1005,1010,1014,1019,1023,1027,1031,1035,1039,1043,1047,1051,1055],{"__ignoreMap":38},[42,1006,1007],{"class":44,"line":45},[42,1008,1009],{},"# dir.py\n",[42,1011,1012],{"class":44,"line":52},[42,1013,652],{},[42,1015,1016],{"class":44,"line":66},[42,1017,1018],{},"  print(a, b)\n",[42,1020,1021],{"class":44,"line":80},[42,1022,657],{},[42,1024,1025],{"class":44,"line":99},[42,1026,214],{"emptyLinePlaceholder":213},[42,1028,1029],{"class":44,"line":108},[42,1030,666],{},[42,1032,1033],{"class":44,"line":119},[42,1034,671],{},[42,1036,1037],{"class":44,"line":125},[42,1038,214],{"emptyLinePlaceholder":213},[42,1040,1041],{"class":44,"line":135},[42,1042,775],{},[42,1044,1045],{"class":44,"line":142},[42,1046,780],{},[42,1048,1049],{"class":44,"line":168},[42,1050,785],{},[42,1052,1053],{"class":44,"line":345},[42,1054,214],{"emptyLinePlaceholder":213},[42,1056,1057],{"class":44,"line":350},[42,1058,1059],{},"print(dir()) # ['__annotations__', '__builtins__', '__cached__', '__doc__', '__file__', '__loader__', '__name__', '__package__', '__spec__', 'add', 'dic', 'sayHi']\n",[17,1061,1062,1063,1066,1067,1069],{},"Ignore the ",[28,1064,1065],{},"__xxx__"," ones for now and just look at the entries without double underscores. You can see the methods and dictionary declared on this page all get listed. And besides showing the variables and scope of the current run, you can also use ",[28,1068,992],{}," to inspect a module:",[33,1071,1073],{"className":285,"code":1072,"language":287,"meta":38,"style":38},"# module.py\ndef add(a, b):\n  return int(a + b)\n\ndef sayHi(name):\n  return f'Hello {name}!'\n\ndic = {\n  'myName': 'Ray',\n}\n\n# example.py\nimport module\n\nprint(module) # ['__builtins__', '__cached__', '__doc__', '__file__', '__loader__', '__name__', '__package__', '__spec__', 'add', 'dic', 'sayHi']\n",[28,1074,1075,1079,1083,1087,1091,1095,1099,1103,1107,1111,1115,1119,1123,1127,1131],{"__ignoreMap":38},[42,1076,1077],{"class":44,"line":45},[42,1078,647],{},[42,1080,1081],{"class":44,"line":52},[42,1082,652],{},[42,1084,1085],{"class":44,"line":66},[42,1086,657],{},[42,1088,1089],{"class":44,"line":80},[42,1090,214],{"emptyLinePlaceholder":213},[42,1092,1093],{"class":44,"line":99},[42,1094,666],{},[42,1096,1097],{"class":44,"line":108},[42,1098,671],{},[42,1100,1101],{"class":44,"line":119},[42,1102,214],{"emptyLinePlaceholder":213},[42,1104,1105],{"class":44,"line":125},[42,1106,775],{},[42,1108,1109],{"class":44,"line":135},[42,1110,780],{},[42,1112,1113],{"class":44,"line":142},[42,1114,785],{},[42,1116,1117],{"class":44,"line":168},[42,1118,214],{"emptyLinePlaceholder":213},[42,1120,1121],{"class":44,"line":345},[42,1122,680],{},[42,1124,1125],{"class":44,"line":350},[42,1126,685],{},[42,1128,1129],{"class":44,"line":356},[42,1130,214],{"emptyLinePlaceholder":213},[42,1132,1133],{"class":44,"line":362},[42,1134,1135],{},"print(module) # ['__builtins__', '__cached__', '__doc__', '__file__', '__loader__', '__name__', '__package__', '__spec__', 'add', 'dic', 'sayHi']\n",[17,1137,1138,1139,1141],{},"On top of that, ",[28,1140,992],{}," can show you which methods are available on lists and dictionaries:",[17,1143,1144],{},"(I've cleaned up the output below a little.)",[33,1146,1148],{"className":285,"code":1147,"language":287,"meta":38,"style":38},"print(dir([])) # ['append', 'clear', 'copy', 'count', 'extend', 'index', 'insert', 'pop', 'remove', 'reverse', 'sort']\n\nprint(dir({})) # ['clear', 'copy', 'fromkeys', 'get', 'items', 'keys', 'pop', 'popitem', 'setdefault', 'update', 'values']\n",[28,1149,1150,1155,1159],{"__ignoreMap":38},[42,1151,1152],{"class":44,"line":45},[42,1153,1154],{},"print(dir([])) # ['append', 'clear', 'copy', 'count', 'extend', 'index', 'insert', 'pop', 'remove', 'reverse', 'sort']\n",[42,1156,1157],{"class":44,"line":52},[42,1158,214],{"emptyLinePlaceholder":213},[42,1160,1161],{"class":44,"line":66},[42,1162,1163],{},"print(dir({})) # ['clear', 'copy', 'fromkeys', 'get', 'items', 'keys', 'pop', 'popitem', 'setdefault', 'update', 'values']\n",[17,1165,1166,1167,1169,1170,1173],{},"Doesn't Python's ",[28,1168,992],{}," feel a lot like JavaScript's ",[28,1171,1172],{},"console.dir","?",[12,1175,1176],{"id":1176},"help",[17,1178,1179,1180,1182],{},"Finally, let's talk about ",[28,1181,1176],{},". Most of you probably already know what it does just from the name — it lets you look up detailed documentation for modules and functions:",[33,1184,1186],{"className":285,"code":1185,"language":287,"meta":38,"style":38},"help('def')\n",[28,1187,1188],{"__ignoreMap":38},[42,1189,1190],{"class":44,"line":45},[42,1191,1185],{},[17,1193,1194,1195,1198],{},"I'll warn you upfront: if you look up ",[28,1196,1197],{},"def",", the output is insanely detailed and insanely long, so I'm only grabbing part of it:",[33,1200,1204],{"className":1201,"code":1202,"language":1203,"meta":38,"style":38},"language-txt shiki shiki-themes github-dark-high-contrast","Function definitions\n********************\n\nA function definition defines a user-defined function object (see\nsection The standard type hierarchy):\n\n   funcdef                   ::= [decorators] \"def\" funcname \"(\" [parameter_list] \")\"\n               [\"->\" expression] \":\" suite\n   decorators                ::= decorator+\n   decorator                 ::= \"@\" assignment_expression NEWLINE\n   parameter_list            ::= defparameter (\",\" defparameter)* \",\" \"\u002F\" [\",\" [parameter_list_no_posonly]]\n                        | parameter_list_no_posonly\n   parameter_list_no_posonly ::= defparameter (\",\" defparameter)* [\",\" [parameter_list_starargs]]\n                                 | parameter_list_starargs\n   parameter_list_starargs   ::= \"*\" [parameter] (\",\" defparameter)* [\",\" [\"**\" parameter [\",\"]]]\n                               | \"**\" parameter [\",\"]\n   parameter                 ::= identifier [\":\" expression]\n   defparameter              ::= parameter [\"=\" expression]\n   funcname                  ::= identifier\n\nA function definition is an executable statement.  Its execution binds\nthe function name in the current local namespace to a function object\n(a wrapper around the executable code for the function).  This\nfunction object contains a reference to the current global namespace\n","txt",[28,1205,1206,1211,1216,1220,1225,1230,1234,1239,1244,1249,1254,1259,1264,1269,1274,1279,1284,1289,1294,1299,1304,1310,1316,1322],{"__ignoreMap":38},[42,1207,1208],{"class":44,"line":45},[42,1209,1210],{},"Function definitions\n",[42,1212,1213],{"class":44,"line":52},[42,1214,1215],{},"********************\n",[42,1217,1218],{"class":44,"line":66},[42,1219,214],{"emptyLinePlaceholder":213},[42,1221,1222],{"class":44,"line":80},[42,1223,1224],{},"A function definition defines a user-defined function object (see\n",[42,1226,1227],{"class":44,"line":99},[42,1228,1229],{},"section The standard type hierarchy):\n",[42,1231,1232],{"class":44,"line":108},[42,1233,214],{"emptyLinePlaceholder":213},[42,1235,1236],{"class":44,"line":119},[42,1237,1238],{},"   funcdef                   ::= [decorators] \"def\" funcname \"(\" [parameter_list] \")\"\n",[42,1240,1241],{"class":44,"line":125},[42,1242,1243],{},"               [\"->\" expression] \":\" suite\n",[42,1245,1246],{"class":44,"line":135},[42,1247,1248],{},"   decorators                ::= decorator+\n",[42,1250,1251],{"class":44,"line":142},[42,1252,1253],{},"   decorator                 ::= \"@\" assignment_expression NEWLINE\n",[42,1255,1256],{"class":44,"line":168},[42,1257,1258],{},"   parameter_list            ::= defparameter (\",\" defparameter)* \",\" \"\u002F\" [\",\" [parameter_list_no_posonly]]\n",[42,1260,1261],{"class":44,"line":345},[42,1262,1263],{},"                        | parameter_list_no_posonly\n",[42,1265,1266],{"class":44,"line":350},[42,1267,1268],{},"   parameter_list_no_posonly ::= defparameter (\",\" defparameter)* [\",\" [parameter_list_starargs]]\n",[42,1270,1271],{"class":44,"line":356},[42,1272,1273],{},"                                 | parameter_list_starargs\n",[42,1275,1276],{"class":44,"line":362},[42,1277,1278],{},"   parameter_list_starargs   ::= \"*\" [parameter] (\",\" defparameter)* [\",\" [\"**\" parameter [\",\"]]]\n",[42,1280,1281],{"class":44,"line":368},[42,1282,1283],{},"                               | \"**\" parameter [\",\"]\n",[42,1285,1286],{"class":44,"line":373},[42,1287,1288],{},"   parameter                 ::= identifier [\":\" expression]\n",[42,1290,1291],{"class":44,"line":379},[42,1292,1293],{},"   defparameter              ::= parameter [\"=\" expression]\n",[42,1295,1296],{"class":44,"line":385},[42,1297,1298],{},"   funcname                  ::= identifier\n",[42,1300,1302],{"class":44,"line":1301},20,[42,1303,214],{"emptyLinePlaceholder":213},[42,1305,1307],{"class":44,"line":1306},21,[42,1308,1309],{},"A function definition is an executable statement.  Its execution binds\n",[42,1311,1313],{"class":44,"line":1312},22,[42,1314,1315],{},"the function name in the current local namespace to a function object\n",[42,1317,1319],{"class":44,"line":1318},23,[42,1320,1321],{},"(a wrapper around the executable code for the function).  This\n",[42,1323,1325],{"class":44,"line":1324},24,[42,1326,1327],{},"function object contains a reference to the current global namespace\n",[17,1329,1330],{},"You can get a similar effect on your own module, though the description won't be nearly as detailed:",[33,1332,1334],{"className":285,"code":1333,"language":287,"meta":38,"style":38},"# module.py\ndef add(a, b):\n  return int(a + b)\n\ndef sayHi(name):\n  return f'Hello {name}!'\n\ndic = {\n  'myName': 'Ray',\n}\n\n# example.py\nimport module\n\nprint(help(module))\n",[28,1335,1336,1340,1344,1348,1352,1356,1360,1364,1368,1372,1376,1380,1384,1388,1392],{"__ignoreMap":38},[42,1337,1338],{"class":44,"line":45},[42,1339,647],{},[42,1341,1342],{"class":44,"line":52},[42,1343,652],{},[42,1345,1346],{"class":44,"line":66},[42,1347,657],{},[42,1349,1350],{"class":44,"line":80},[42,1351,214],{"emptyLinePlaceholder":213},[42,1353,1354],{"class":44,"line":99},[42,1355,666],{},[42,1357,1358],{"class":44,"line":108},[42,1359,671],{},[42,1361,1362],{"class":44,"line":119},[42,1363,214],{"emptyLinePlaceholder":213},[42,1365,1366],{"class":44,"line":125},[42,1367,775],{},[42,1369,1370],{"class":44,"line":135},[42,1371,780],{},[42,1373,1374],{"class":44,"line":142},[42,1375,785],{},[42,1377,1378],{"class":44,"line":168},[42,1379,214],{"emptyLinePlaceholder":213},[42,1381,1382],{"class":44,"line":345},[42,1383,680],{},[42,1385,1386],{"class":44,"line":350},[42,1387,685],{},[42,1389,1390],{"class":44,"line":356},[42,1391,214],{"emptyLinePlaceholder":213},[42,1393,1394],{"class":44,"line":362},[42,1395,1396],{},"print(help(module))\n",[17,1398,1399],{},[395,1400],{"alt":1176,"src":1401},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-03%2021.34.50.png",[17,1403,1404,1405,1408],{},"At this point someone might ask how to get a description to show up like ",[28,1406,1407],{},"help('def')"," does. It's really simple — just use comments:",[33,1410,1412],{"className":285,"code":1411,"language":287,"meta":38,"style":38},"# NAME: this line becomes the module's description\n\n# FUNCTIONS: very simple math, but it returns an integer\ndef add(a, b):\n  return int(a + b)\n\n# FUNCTIONS: this is a method that greets someone\ndef sayHi(name):\n  # the explanatory comment has to go before def — putting it inside def won't show up\n  return f'Hello {name}!'\n\n# DATA entries don't show a comment description\ndic = {\n  # writing it here doesn't help either\n  'myName': 'Ray',\n}\n\n# example.py\nimport module\n\nprint(help(module))\n",[28,1413,1414,1419,1423,1428,1432,1436,1440,1445,1449,1454,1458,1462,1467,1471,1476,1480,1484,1488,1492,1496,1500],{"__ignoreMap":38},[42,1415,1416],{"class":44,"line":45},[42,1417,1418],{},"# NAME: this line becomes the module's description\n",[42,1420,1421],{"class":44,"line":52},[42,1422,214],{"emptyLinePlaceholder":213},[42,1424,1425],{"class":44,"line":66},[42,1426,1427],{},"# FUNCTIONS: very simple math, but it returns an integer\n",[42,1429,