],{"class":109},"() {\n",[103,855,856,859,861,863,865],{"class":105,"line":127},[103,857,858],{"class":109},"  console.",[103,860,114],{"class":113},[103,862,117],{"class":109},[103,864,136],{"class":120},[103,866,124],{"class":109},[103,868,869,871,873,875,877],{"class":105,"line":141},[103,870,858],{"class":109},[103,872,114],{"class":113},[103,874,117],{"class":109},[103,876,150],{"class":120},[103,878,124],{"class":109},[103,880,881,883,885,887,889],{"class":105,"line":155},[103,882,858],{"class":109},[103,884,114],{"class":113},[103,886,117],{"class":109},[103,888,164],{"class":120},[103,890,124],{"class":109},[103,892,893,895,897,899,901],{"class":105,"line":169},[103,894,858],{"class":109},[103,896,114],{"class":113},[103,898,117],{"class":109},[103,900,178],{"class":120},[103,902,124],{"class":109},[103,904,905,907,909,911,913],{"class":105,"line":183},[103,906,858],{"class":109},[103,908,114],{"class":113},[103,910,117],{"class":109},[103,912,192],{"class":120},[103,914,124],{"class":109},[103,916,917,919,921,923,925],{"class":105,"line":197},[103,918,858],{"class":109},[103,920,114],{"class":113},[103,922,117],{"class":109},[103,924,206],{"class":120},[103,926,124],{"class":109},[103,928,929,931,933,935,937],{"class":105,"line":211},[103,930,858],{"class":109},[103,932,114],{"class":113},[103,934,117],{"class":109},[103,936,220],{"class":120},[103,938,124],{"class":109},[103,940,941,943,945,947,949],{"class":105,"line":225},[103,942,858],{"class":109},[103,944,114],{"class":113},[103,946,117],{"class":109},[103,948,234],{"class":120},[103,950,124],{"class":109},[103,952,953,955,957,959,961],{"class":105,"line":239},[103,954,858],{"class":109},[103,956,114],{"class":113},[103,958,117],{"class":109},[103,960,248],{"class":120},[103,962,124],{"class":109},[103,964,965,967,969,971,973],{"class":105,"line":253},[103,966,858],{"class":109},[103,968,114],{"class":113},[103,970,117],{"class":109},[103,972,262],{"class":120},[103,974,124],{"class":109},[103,976,977],{"class":105,"line":267},[103,978,979],{"class":109},"}\n",[103,981,982,984,986,988,990],{"class":105,"line":281},[103,983,110],{"class":109},[103,985,114],{"class":113},[103,987,117],{"class":109},[103,989,121],{"class":120},[103,991,124],{"class":109},[103,993,994,997],{"class":105,"line":294},[103,995,996],{"class":113},"fn",[103,998,999],{"class":109},"();\n",[103,1001,1002,1004,1006,1008,1010],{"class":105,"line":307},[103,1003,110],{"class":109},[103,1005,114],{"class":113},[103,1007,117],{"class":109},[103,1009,276],{"class":120},[103,1011,124],{"class":109},[103,1013,1014,1016],{"class":105,"line":320},[103,1015,996],{"class":113},[103,1017,999],{"class":109},[103,1019,1020,1022,1024,1026,1028],{"class":105,"line":333},[103,1021,110],{"class":109},[103,1023,114],{"class":113},[103,1025,117],{"class":109},[103,1027,420],{"class":120},[103,1029,124],{"class":109},[103,1031,1032,1034],{"class":105,"line":346},[103,1033,996],{"class":113},[103,1035,999],{"class":109},[103,1037,1038,1040,1042,1044,1046],{"class":105,"line":359},[103,1039,110],{"class":109},[103,1041,114],{"class":113},[103,1043,117],{"class":109},[103,1045,564],{"class":120},[103,1047,124],{"class":109},[103,1049,1050,1052],{"class":105,"line":372},[103,1051,996],{"class":113},[103,1053,1054],{"class":109},"()\n",[103,1056,1057,1059,1061,1063,1065],{"class":105,"line":385},[103,1058,110],{"class":109},[103,1060,114],{"class":113},[103,1062,117],{"class":109},[103,1064,708],{"class":120},[103,1066,124],{"class":109},[103,1068,1069,1071],{"class":105,"line":398},[103,1070,996],{"class":113},[103,1072,999],{"class":109},[17,1074,1075,1076,1079,1080,1083,1084,1087],{},"In the example above, you can see I only need to call ",[100,1077,1078],{},"fn()"," to get the exact same behaviour. And what if I told you this repeated routine now needs to run from day 1 to day 100? Or even 365 days? You'd be copy-pasting until you die. There's another upside too: when you need to maintain or change something, you can fix it all in one place. Say one day I change my routine and ",[100,1081,1082],{},"console.log('Afternoon nap');"," becomes ",[100,1085,1086],{},"console.log('Study');"," — now you don't have to find-and-replace until your fingers fall off.",[17,1089,1090],{},[45,1091],{"alt":1092,"src":1093},"Functions are great!","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630808846740.png",[17,1095,1096,1097,1100,1101,1104],{},"Of course, with the code above we could also add a loop to wrap up the ",[100,1098,1099],{},"Day 1",", ",[100,1102,1103],{},"Day 2"," part too, so you can run it for however many days you want:",[93,1106,1108],{"className":95,"code":1107,"language":97,"meta":98,"style":98},"function fn(day) {\n  console.log('Day ' + day);\n  console.log('Wake up');\n  console.log('Brush teeth');\n  console.log('Exercise');\n  console.log('Lunch');\n  console.log('Afternoon nap');\n  console.log('Afternoon exercise');\n  console.log('Dinner');\n  console.log('Evening shower');\n  console.log('Sleep');\n  console.log('---------');\n}\n\nvar day = 5;\n\nfor(var i = 0; i \u003C day; i+=1) {\n  fn(i + 1);\n}\n",[100,1109,1110,1125,1142,1154,1166,1178,1190,1202,1214,1226,1238,1250,1262,1266,1272,1290,1294,1328,1344],{"__ignoreMap":98},[103,1111,1112,1114,1116,1118,1122],{"class":105,"line":106},[103,1113,847],{"class":846},[103,1115,850],{"class":113},[103,1117,117],{"class":109},[103,1119,1121],{"class":1120},"s_sBn","day",[103,1123,1124],{"class":109},") {\n",[103,1126,1127,1129,1131,1133,1136,1139],{"class":105,"line":127},[103,1128,858],{"class":109},[103,1130,114],{"class":113},[103,1132,117],{"class":109},[103,1134,1135],{"class":120},"'Day '",[103,1137,1138],{"class":846}," +",[103,1140,1141],{"class":109}," day);\n",[103,1143,1144,1146,1148,1150,1152],{"class":105,"line":141},[103,1145,858],{"class":109},[103,1147,114],{"class":113},[103,1149,117],{"class":109},[103,115