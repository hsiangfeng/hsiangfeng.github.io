05,"line":294},[103,1269,1271],{"emptyLinePlaceholder":1270},true,"\n",[103,1273,1274,1277,1280,1283,1287],{"class":105,"line":307},[103,1275,1276],{"class":846},"var",[103,1278,1279],{"class":109}," day ",[103,1281,1282],{"class":846},"=",[103,1284,1286],{"class":1285},"sCcAr"," 5",[103,1288,1289],{"class":109},";\n",[103,1291,1292],{"class":105,"line":320},[103,1293,1271],{"emptyLinePlaceholder":1270},[103,1295,1296,1299,1301,1303,1306,1308,1311,1314,1317,1320,1323,1326],{"class":105,"line":333},[103,1297,1298],{"class":846},"for",[103,1300,117],{"class":109},[103,1302,1276],{"class":846},[103,1304,1305],{"class":109}," i ",[103,1307,1282],{"class":846},[103,1309,1310],{"class":1285}," 0",[103,1312,1313],{"class":109},"; i ",[103,1315,1316],{"class":846},"\u003C",[103,1318,1319],{"class":109}," day; i",[103,1321,1322],{"class":846},"+=",[103,1324,1325],{"class":1285},"1",[103,1327,1124],{"class":109},[103,1329,1330,1333,1336,1339,1342],{"class":105,"line":346},[103,1331,1332],{"class":113},"  fn",[103,1334,1335],{"class":109},"(i ",[103,1337,1338],{"class":846},"+",[103,1340,1341],{"class":1285}," 1",[103,1343,124],{"class":109},[103,1345,1346],{"class":105,"line":359},[103,1347,979],{"class":109},[17,1349,1350],{},"I won't show the output of these, but if you're still not totally clear on when to use a function, try listing out the repeated behaviours in your own daily life, then try turning them into code and thinking about how to wrap them into a function.",[12,1352,1354,1355,1358],{"id":1353},"pythons-def-definition","Python's ",[100,1356,1357],{},"def"," definition",[17,1360,1361,1362,1364,1365,1367],{},"Let's get back to Python. Earlier we learned that JavaScript declares a function with the ",[100,1363,847],{}," keyword. So what about Python? Python uses ",[100,1366,1357],{},", which is short for \"define\" — you're defining something. So let me just rewrite the JavaScript function above into Python and give it a go:",[93,1369,1373],{"className":1370,"code":1371,"language":1372,"meta":98,"style":98},"language-py shiki shiki-themes github-dark-high-contrast","def fn(day):\n  print('Day ' + day)\n  print('Wake up')\n  print('Brush teeth')\n  print('Exercise')\n  print('Lunch')\n  print('Afternoon nap')\n  print('Afternoon exercise')\n  print('Dinner')\n  print('Evening shower')\n  print('Sleep')\n  print('---------')\n\nfn(1)\n","py",[100,1374,1375,1380,1385,1390,1395,1400,1405,1410,1415,1420,1425,1430,1435,1439],{"__ignoreMap":98},[103,1376,1377],{"class":105,"line":106},[103,1378,1379],{},"def fn(day):\n",[103,1381,1382],{"class":105,"line":127},[103,1383,1384],{},"  print('Day ' + day)\n",[103,1386,1387],{"class":105,"line":141},[103,1388,1389],{},"  print('Wake up')\n",[103,1391,1392],{"class":105,"line":155},[103,1393,1394],{},"  print('Brush teeth')\n",[103,1396,1397],{"class":105,"line":169},[103,1398,1399],{},"  print('Exercise')\n",[103,1401,1402],{"class":105,"line":183},[103,1403,1404],{},"  print('Lunch')\n",[103,1406,1407],{"class":105,"line":197},[103,1408,1409],{},"  print('Afternoon nap')\n",[103,1411,1412],{"class":105,"line":211},[103,1413,1414],{},"  print('Afternoon exercise')\n",[103,1416,1417],{"class":105,"line":225},[103,1418,1419],{},"  print('Dinner')\n",[103,1421,1422],{"class":105,"line":239},[103,1423,1424],{},"  print('Evening shower')\n",[103,1426,1427],{"class":105,"line":253},[103,1428,1429],{},"  print('Sleep')\n",[103,1431,1432],{"class":105,"line":267},[103,1433,1434],{},"  print('---------')\n",[103,1436,1437],{"class":105,"line":281},[103,1438,1271],{"emptyLinePlaceholder":1270},[103,1440,1441],{"class":105,"line":294},[103,1442,1443],{},"fn(1)\n",[17,1445,1446,1447,1449,1450,1453,1454,1456,1457,1460],{},"When you declare a ",[100,1448,1357],{},", make sure you add a \"",[100,1451,1452],{},":","\" after the ",[100,1455,1357],{}," name, otherwise you'll get an error. The main reason is that Python's curly braces ",[100,1458,1459],{},"{}"," only get used for dictionaries (I'll explain what a dictionary is in a later chapter — for now just know that's a thing).",[17,1462,1463,1464,1467,1468,1471],{},"Also, the code above will actually throw an error, and the message is mainly ",[100,1465,1466],{},"TypeError: can only concatenate str (not \"int\") to str",". What does that mean? In short, the bit of code where we're trying to combine strings is being passed the wrong type (",[100,1469,1470],{},"print('Day ' + day)","). Right about now your face is probably the first sticker in your reaction-image pack:",[17,1473,1474],{},[45,1475],{"alt":1476,"src":1477},"WT...","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1627709736178.png",[17,1479,1480,1481,1484],{},"After all, when we do string concatenation in JavaScript, we usually just glue it together like ",[100,1482,1483],{},"console.log('Day ' + day);"," (or with template literals, of course).",[17,1486,1487,1488,1491,1492,1495],{},"But doing that in Python throws a type error. What the message basically means is that an integer type (",[100,1489,1490],{},"int",") can't be added to a string type (",[100,1493,1494],{},"string","). So we learn something here: when JavaScript does string concatenation, it does an implicit type conversion for us:",[93,1497,1499],{"className":95,"code":1498,"language":97,"meta":98,"style":98},"var a = 1;\nconsole.log('Day ' + a);\n",[100,1500,1501,1514],{"__ignoreMap":98},[103,1502,1503,1505,1508,1510,1512],{"class":105,"line":106},[103,1504,1276],{"class":846},[103,1506,1507],{"class":109}," a ",[103,1509,1282],{"class":846},[103,1511,1341],{"class":1285},[103,1513,1289],{"class":109},[103,1515,1516,1518,1520,1522,1524,1526],{"class":105,"line":127},[103,1517,110],{"class":109},[103,1519,114],{"class":113},[103,1521,117],{"class":109},[103,1523,1135],{"class":120},[103,1525,1138],{"class":846},[103,1527,1528],{"class":109}," a);\n",[17,1530,1531],{},"Surprising, right? I didn't expect it either — I only found out while writing an example for this post.",[17,1533,1534,1535,1537,1538,1540,1541,1543,1544,1546],{},"So in Python, the reason you get ",[100,1536,1466],{}," is mainly because we're trying to add a string type (",[100,1539,1494],{},") to an integer type (",[100,1542,1490],{},") (",[100,1545,1470],{},"). Normally a string can only be added to another string. To fix this, you have to do a type conversion first:",[93,1548,1550],{"className":1370,"code":1549,"language":1372,"meta":98,"style":98},"def fn(day):\n  print('Day ' + str(day))\n  print('Wake up')\n  print('Brush teeth')\n  print('Exercise')\n  print('Lunch')\n  print('Afternoon nap')\n  print('Afternoon exercise')\n  print('Dinner')\n  print('Evening shower')\n  print('Sleep')\n  print('---------')\n\nfn(1)\n",[100,1551,1552,1556,1561,1565,1569,1573,1577,1581,1585,1589,1593,1597,1601,1605],{"__ignoreMap":98},[103,1553,1554],{"class":105,"line":106},[103,1555,1379],{},[103,1557,1558],{"class":105,"line":127},[103,1559,1560],{},"  print('Day ' + str(day))\n",[103,1562,1563],{"class":105,"line":141},[103,1564,1389],{},[103,1566,1567],{"class":105,"line":155},[103,1568,1394],{},[103,1570,1571],{"class":105,"line":169},[103,1572,1399],{},[103,1574,1575],{"class":105,"line":183},[103,1576,1404],{},[103,1578,1579],{"class":105,"line":197},[103,1580,1409],{},[103,1582,1583],{"class":105,"line":211},[103,1584,1414],{},[103,1586,1587],{"class":105,"line":225},[103,1588,1419],{},[103,1590,1591],{"class":105,"line":239},[103,1592,1424],{},[103,1594,1595],{"class":105,"line":253},[103,1596,1429],{},[103,1598,1599],{"class":105,"line":267},[103,1600,1434],{},[103,1602,1603],{"class":105,"line":281},[103,1604,1271],{"emptyLinePlaceholder":1270},[103,1606,1607],{"class":105,"line":294},[103,1608,1443],{},[17,1610,1611],{},"As for how to write the loop — I'll hold off on that and save it for next time (otherwise this post gets way too long).",[17,1613,1614],{},"One more thing to note: Python's type conversions are all lowercase. Here's a list for you:",[56,1616,1617,1622,1627,1632],{},[59,1618,1619],{},[100,1620,1621],{},"str()",[59,1623,1624],{},[100,1625,1626],{},"int()",[59,1628,1629],{},[100,1630,1631],{},"bool()",[59,1633,1634],{},[100,1635,1636],{},"float()",[17,1638,1639],{},"Which is different from JavaScript's type conversions, where the first letter is capitalized:",[56,1641,1642,1647,1652],{},[59,1643,1644],{},[100,1645,1646],{},"String()",[59,1648,1649],{},[100,1650,1651],{},"Number()",[59,1653,1654],{},[100,1655,1656],{},"Boolean()",[12,1658,1660],{"id":1659},"differences-between-python-and-javascript-functions","Differences between Python and JavaScript functions",[17,1662,1663],{},"Let's talk about how Python functions differ from JavaScript functions. JavaScript functions have a few common traits:",[56,1665,1666,1669,1672],{},[59,1667,1668],{},"You can store a function in a variable (anonymous expression)",[59,1670,1671],{},"You can call a function before the function statement is created (Hoisting and named function statements)",[59,1673,1674],{},"IIFE (Immediately Invoked Function Expression)",[17,1676,1677],{},"Here are some common ways to write JavaScript function statements, function expressions, and IIFEs:",[93,1679,1681],{"className":95,"code":1680,"language":97,"meta":98,"style":98},"\u002F\u002F First way\nfn1();\nfunction fn1() {\n  console.log('Hello Ray');\n}\n\n\u002F\u002F Second way\nconst fn2 = function() {\n  console.log('Hello Ray');\n}\nfn2();\n\n\u002F\u002F Third way\n(function() {\n  console.log('Hello Ray');\n})();\n",[100,1682,1683,1689,1696,1705,1718,1722,1726,1731,1747,1759,1763,1770,1774,1779,1787,1799],{"__ignoreMap":98},[103,1684,1685],{"class":105,"line":106},[103,1686,1688],{"class":1687},"sQrFR","\u002F\u002F First way\n",[103,1690,1691,1694],{"class":105,"line":127},[103,1692,1693],{"class":113},"fn1",[103,1695,999],{"class":109},[103,1697,1698,1700,1703],{"class":105,"line":141},[103,1699,847],{"class":846},[103,1701,1702],{"class":113}," fn1",[103,1704,853],{"class":109},[103,1706,1707,1709,1711,1713,1716],{"class":105,"line":155},[103,1708,858],{"class":109},[103,1710,114],{"class":113},[103,1712,117],{"class":109},[103,1714,1715],{"class":120},"'Hello Ray'",[103,1717,124],{"class":109},[103,1719,1720],{"class":105,"line":169},[103,1721,979],{"class":109},[103,1723,1724],{"class":105,"line":183},[103,1725,1271],{"emptyLinePlaceholder":1270},[103,1727,1728],{"class":105,"line":197},[103,1729,1730],{"class":1687},"\u002F\u002F Second way\n",[103,1732,1733,1736,1739,1742,1745],{"class":105,"line":211},[103,1734,1735],{"class":846},"const",[103,1737,1738],{"class":113}," fn2",[103,1740,1741],{"class":846}," =",[103,1743,1744],{"class":846}," function",[103,1746,853],{"class":109},[103,1748,1749,1751,1753,1755,1757],{"class":105,"line":225},[103,1750,858],{"class":109},[103,1752,114],{"class":113},[103,1754,117],{"class":109},[103,1756,1715],{"class":120},[103,1758,124],{"class":109},[103,1760,1761],{"class":105,"line":239},[103,1762,979],{"class":109},[103,1764,1765,1768],{"class":105,"line":253},[103,1766,1767],{"class":113},"fn2",[103,1769,999],{"class":109},[103,1771,1772],{"class":105,"line":267},[103,1773,1271],{"emptyLinePlaceholder":1270},[103,1775,1776],{"class":105,"line":281},[103,1777,1778],{"class":1687},"\u002F\u002F Third way\n",[103,1780,1781,1783,1785],{"class":105,"line":294},[103,1782,117],{"class":109},[103,1784,847],{"class":846},[103,1786,853],{"class":109},[103,1788,1789,1791,1793,1795,1797],{"class":105,"line":307},[103,1790,858],{"class":109},[103,1792,114],{"class":113},[103,1794,117],{"class":109},[103,1796,1715],{"class":120},[103,1798,124],{"class":109},[103,1800,1801],{"class":105,"line":320},[103,1802,1803],{"class":109},"})();\n",[17,1805,1806],{},"Let's start with the first way — calling a function before it's created. Basically, JavaScript lets you call a function before it's declared (usually not recommended). So... what about Python? Can Python do the same thing? The answer is no:",[93,1808,1810],{"className":1370,"code":1809,"language":1372,"meta":98,"style":98},"fn1()\n\ndef fn1():\n  print('Hello Ray')\n",[100,1811,1812,1817,1821,1826],{"__ignoreMap":98},[103,1813,1814],{"class":105,"line":106},[103,1815,1816],{},"fn1()\n",[103,1818,1819],{"class":105,"line":127},[103,1820,1271],{"emptyLinePlaceholder":1270},[103,1822,1823],{"class":105,"line":141},[103,1824,1825],{},"def fn1():\n",[103,1827,1828],{"class":105,"line":155},[103,1829,1830],{},"  print('Hello Ray')\n",[17,1832,1833,1834,1837],{},"This Python code throws a ",[100,1835,1836],{},"NameError: name 'fn1' is not defined"," error. So once again we get to appreciate the beauty of JavaScript's hoisting (or not).",[17,1839,1840],{},"Next we'd jump to the second way — anonymous expressions — and IIFE. But Python handles this a bit differently, so let me jump straight to the next section.",[12,1842,1843],{"id":1843},"lambda",[17,1845,1846,1847,1849],{},"Now let's talk about storing a function directly inside a variable. To do this in Python, you have to use an operator called ",[100,1848,1843],{},", which is what's known as an anonymous function. As the name suggests, its traits are:",[56,1851,1852,1855],{},[59,1853,1854],{},"No need to declare a name",[59,1856,1857],{},"But it can only be one line of code — break it onto a new line and it errors out",[17,1859,1860],{},"So how do you use lambda? Let's look at a code example:",[93,1862,1864],{"className":1370,"code":1863,"language":1372,"meta":98,"style":98},"myName = lambda name: print('Hello ' + name)\nmyName('Ray') # Hello Ray\n",[100,1865,1866,1871],{"__ignoreMap":98},[103,1867,1868],{"class":105,"line":106},[103,1869,1870],{},"myName = lambda name: print('Hello ' + name)\n",[103,1872,1873],{"class":105,"line":127},[103,1874,1875],{},"myName('Ray') # Hello Ray\n",[17,1877,1878],{},"Ridiculously short, right? If you like things concise, this should make you happy.",[17,1880,1881],{},[45,1882],{"alt":1883,"src":1884},"A man who likes things concise","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630809970300.png",[17,1886,1887,1888,1892],{},"So let's talk a bit about the lambda function. Since a lambda function ",[1889,1890,1891],"strong",{},"can only be written on one line"," (meaning a line break throws an error), there are some small limitations, but it's incredibly compact and powerful. A lambda has three key parts:",[56,1894,1895,1898,1901],{},[59,1896,1897],{},"Lambda — the keyword",[59,1899,1900],{},"Parameter list — parameter",[59,1902,1903],{},"Expression — expression",[93,1905,1907],{"className":1370,"code":1906,"language":1372,"meta":98,"style":98},"lambda parameter1, parameter2,...: expression\n",[100,1908,1909],{"__ignoreMap":98},[103,1910,1911],{"class":105,"line":106},[103,1912,1906],{},[17,1914,1915,1916,1920],{},"(If you're not familiar with expressions versus statements, check out ",[28,1917,1919],{"href":1918},"\u002Fjavascript\u002F20200607\u002F196651152\u002F","this post"," (article in Mandarin).)",[17,1922,1923,1924,1926],{},"If you insist on making ",[100,1925,1843],{}," multi-line, you'll get an error:",[93,1928,1930],{"className":1370,"code":1929,"language":1372,"meta":98,"style":98},"# SyntaxError: invalid syntax\nmyName = lambda name:\n  print('Hello ' + name)\n",[100,1931,1932,1937,1942],{"__ignoreMap":98},[103,1933,1934],{"class":105,"line":106},[103,1935,1936],{},"# SyntaxError: invalid syntax\n",[103,1938,1939],{"class":105,"line":127},[103,1940,1941],{},"myName = lambda name:\n",[103,1943,1944],{"class":105,"line":141},[103,1945,1946],{},"  print('Hello ' + name)\n",[17,1948,1949],{},"What about JavaScript's IIFE then? The third one, the IIFE (Immediately Invoked Function Expression), is also related to lambda. Enough talk — let's look at the code:",[93,1951,1953],{"className":1370,"code":1952,"language":1372,"meta":98,"style":98},"(lambda name: print('Hello ' + name))('Ray') # Hello Ray\n",[100,1954,1955],{"__ignoreMap":98},[103,1956,1957],{"class":105,"line":106},[103,1958,1952],{},[17,1960,1961],{},"Looking at it now, doesn't it give you a bit of déjà vu with JavaScript's IIFE?",[17,1963,1964],{},[45,1965],{"alt":1966,"src":1967},"Is this JavaScript?","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1624117447047.png",[17,1969,1970,1971,1973],{},"One last reminder: even though ",[100,1972,1843],{}," is powerful and handy, use it carefully. Because it's so compact and forced onto a single line, it can hurt your code's readability.",[12,1975,1977],{"id":1976},"references","References",[56,1979,1980],{},[59,1981,1982],{},[28,1983,1987],{"href":1984,"rel":1985},"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FAnonymous_function#Python",[1986],"nofollow","Anonymous function",[12,1989,1991],{"id":1990},"a-note-from-the-author","A note from the author",[17,1993,1994],{},"I bought a giant bottle of huadiao wine, so lately I've been madly making huadiao drunken chicken (I get the plain chicken from Costco). I tried a basic version of huadiao drunken chicken, and my first attempt was a total disaster — a bit too salty, way too much huadiao wine.",[12,1996,1998],{"id":1997},"about-the-bunnies","About the bunnies",[56,2000,2001,2008,2016,2024],{},[59,2002,2003],{},[28,2004,2007],{"href":2005,"rel":2006},"https:\u002F\u002Ftailwindcss.tw",[1986],"Tailwind CSS Taiwan official site",[59,2009,2010,2015],{},[28,2011,2014],{"href":2012,"rel":2013},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[1986],"Tailwind CSS Taiwan"," (Facebook fan page)",[59,2017,2018,2023],{},[28,2019,2022],{"href":2020,"rel":2021},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[1986],"Bunny School × Tailwind CSS Taiwan"," (Facebook community)",[59,2025,2026],{},[28,2027,2030],{"href":2028,"rel":202