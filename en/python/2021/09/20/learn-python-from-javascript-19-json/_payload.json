,577,578,581,585,588,591,593,595,597,600,603],{"class":64,"line":279},[62,579,580],{"class":68},"localStorage.",[62,582,584],{"class":583},"sj_SG","setItem",[62,586,587],{"class":68},"(",[62,589,590],{"class":112},"'test'",[62,592,401],{"class":68},[62,594,23],{"class":82},[62,596,369],{"class":68},[62,598,599],{"class":583},"stringify",[62,601,602],{"class":68},"(a)); ",[62,604,605],{"class":445},"\u002F\u002F save\n",[62,607,608],{"class":64,"line":353},[62,609,276],{"emptyLinePlaceholder":275},[62,611,612,614,616,619,622,625,627,629,632],{"class":64,"line":359},[62,613,23],{"class":82},[62,615,369],{"class":68},[62,617,618],{"class":583},"parse",[62,620,621],{"class":68},"(localStorage.",[62,623,624],{"class":583},"getItem",[62,626,587],{"class":68},[62,628,590],{"class":112},[62,630,631],{"class":68},"))",[62,633,634],{"class":445},"\u002F\u002F retrieve\n",[17,636,637],{},"If Python wants to deal with JSON, you have to import Python's JSON module:",[53,639,641],{"className":187,"code":640,"language":189,"meta":57,"style":57},"import json\n",[59,642,643],{"__ignoreMap":57},[62,644,645],{"class":64,"line":65},[62,646,640],{},[17,648,649,650,653,654,657],{},"The JSON module has a ",[59,651,652],{},"dumps"," method that converts a Python ",[59,655,656],{},"dict"," into JSON format. The syntax and usage are pretty simple, so let's take a look:",[53,659,661],{"className":187,"code":660,"language":189,"meta":57,"style":57},"import json\n\ndic = {\n  \"keyID\": 0,\n  \"blogList\": [\n    {\n      \"title\": \"PixiJS V5 Tutorial (0)\",\n      \"url\": \"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20200203\u002F3949702627\u002F\"\n    },\n  ],\n  \"updateTime\": \"2020\u002F2\u002F18 PM 7:49:36\",\n  \"blogUrl\": \"https:\u002F\u002Fisraynotarray.com\u002F\",\n  \"name\": \"Ray\"\n}\n\n\n\nf = open('example.json', 'w')\nf.write(json.dumps(dic))\nf.close()\n",[59,662,663,667,671,675,679,683,687,691,695,699,703,707,711,715,719,723,727,732,737,743],{"__ignoreMap":57},[62,664,665],{"class":64,"line":65},[62,666,640],{},[62,668,669],{"class":64,"line":72},[62,670,276],{"emptyLinePlaceholder":275},[62,672,673],{"class":64,"line":89},[62,674,196],{},[62,676,677],{"class":64,"line":98},[62,678,223],{},[62,680,681],{"class":64,"line":104},[62,682,228],{},[62,684,685],{"class":64,"line":118},[62,686,101],{},[62,688,689],{"class":64,"line":129},[62,690,237],{},[62,692,693],{"class":64,"line":135},[62,694,242],{},[62,696,697],{"class":64,"line":141},[62,698,132],{},[62,700,701],{"class":64,"line":154},[62,702,138],{},[62,704,705],{"class":64,"line":167},[62,706,255],{},[62,708,709],{"class":64,"line":178},[62,710,260],{},[62,712,713],{"class":64,"line":272},[62,714,265],{},[62,716,717],{"class":64,"line":279},[62,718,181],{},[62,720,721],{"class":64,"line":353},[62,722,276],{"emptyLinePlaceholder":275},[62,724,725],{"class":64,"line":359},[62,726,276],{"emptyLinePlaceholder":275},[62,728,730],{"class":64,"line":729},17,[62,731,276],{"emptyLinePlaceholder":275},[62,733,735],{"class":64,"line":734},18,[62,736,350],{},[62,738,740],{"class":64,"line":739},19,[62,741,742],{},"f.write(json.dumps(dic))\n",[62,744,746],{"class":64,"line":745},20,[62,747,362],{},[17,749,750],{},"See that? Now you can write out proper JSON — and no errors at all!",[17,752,753],{},[39,754],{"alt":755,"src":756},"Successfully wrote JSON!","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631542638770.png",[17,758,759],{},"So what about reading it back? Sure, you can read the JSON file directly like this:",[53,761,763],{"className":187,"code":762,"language":189,"meta":57,"style":57},"f = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(read)\n",[59,764,765,770,775,779],{"__ignoreMap":57},[62,766,767],{"class":64,"line":65},[62,768,769],{},"f = open('example.json', 'r')\n",[62,771,772],{"class":64,"line":72},[62,773,774],{},"read = f.read()\n",[62,776,777],{"class":64,"line":89},[62,778,362],{},[62,780,781],{"class":64,"line":98},[62,782,783],{},"print(read)\n",[17,785,786,787,790],{},"But if you want to actually do something with that JSON data, you have to run it through the JSON module to convert it into a type Python can read. Otherwise the file you get back from ",[59,788,789],{},"f.read()"," is just a str (string):",[53,792,794],{"className":187,"code":793,"language":189,"meta":57,"style":57},"f = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(type(read)) # str\n",[59,795,796,800,804,808],{"__ignoreMap":57},[62,797,798],{"class":64,"line":65},[62,799,769],{},[62,801,802],{"class":64,"line":72},[62,803,774],{},[62,805,806],{"class":64,"line":89},[62,807,362],{},[62,809,810],{"class":64,"line":98},[62,811,812],{},"print(type(read)) # str\n",[17,814,815],{},"You might wonder what's wrong with that. Well, usually after reading JSON we need to grab one of its fields. And if you don't process it through the JSON module, you can't access any specific property — because the whole thing is just one big str:",[53,817,819],{"className":187,"code":818,"language":189,"meta":57,"style":57},"f = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(type(read))\nprint(read['name']) # TypeError: string indices must be integers\n",[59,820,821,825,829,833,838],{"__ignoreMap":57},[62,822,823],{"class":64,"line":65},[62,824,769],{},[62,826,827],{"class":64,"line":72},[62,828,774],{},[62,830,831],{"class":64,"line":89},[62,832,362],{},[62,834,835],{"class":64,"line":98},[62,836,837],{},"print(type(read))\n",[62,839,840],{"class":64,"line":104},[62,841,842],{},"print(read['name']) # TypeError: string indices must be integers\n",[17,844,845],{},"So once you've read in the JSON, remember to use the JSON module to convert it into something Python can understand:",[53,847,849],{"className":187,"code":848,"language":189,"meta":57,"style":57},"import json\n\nf = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(type(read))\ndata = json.loads(read)\nprint(data['name']) # Ray\n",[59,850,851,855,859,863,867,871,875,880],{"__ignoreMap":57},[62,852,853],{"class":64,"line":65},[62,854,640],{},[62,856,857],{"class":64,"line":72},[62,858,276],{"emptyLinePlaceholder":275},[62,860,861],{"class":64,"line":89},[62,862,769],{},[62,864,865],{"class":64,"line":98},[62,866,774],{},[62,868,869],{"class":64,"line":104},[62,870,362],{},[62,872,873],{"class":64,"line":118},[62,874,837],{},[62,876,877],{"class":64,"line":129},[62,878,879],{},"data = json.loads(read)\n",[62,881,882],{"class":64,"line":135},[62,883,884],{},"print(data['name']) # Ray\n",[17,886,887],{},"So you can see that JSON data needs a bit of extra handling in both JavaScript and Python.",[12,889,891],{"id":890},"a-note-from-the-author","A Note From the Author",[17,893,894],{},"My family said they liked the drunken chicken in rice wine I made... so I went and bought new wine again. This time I'm planning to try making it with Shaoxing wine instead. Maybe it'll taste good too?!",[12,896,898],{"id":897},"about-the-bunnies","About the Bunnies",[900,901,902,911,919,927],"ul",{},[903,904,905],"li",{},[28,906,910],{"href":907,"rel":908},"https:\u002F\u002Ftailwindcss.tw",[909],"nofollow","Tailwind CSS Taiwan Official Site",[903,912,913,918],{},[28,914,917],{"href":915,"rel":916},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[909],"Tailwind CSS Taiwan"," (Facebook fan page)",[903,920,921,926],{},[28,922,925],{"href":923,"rel":924},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[909],"Bunny Cult × Tailwind CSS Taiwan"," (Facebook community)",[903,928,929],{},[28,930,933],{"href":931,"rel":932},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[909],"Bunny Cult HQ",[17,935,936],{},[39,937],{"alt":938,"src":939},"The bunny way is boundless","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[941,942,943],"style",{},"htm