[{"data":1,"prerenderedAt":992},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fpython\u002F2021\u002F09\u002F20\u002Flearn-python-from-javascript-19-json\u002F":3,"page:\u002Fen\u002Fpython\u002F2021\u002F09\u002F20\u002Flearn-python-from-javascript-19-json\u002F":4,"alt:\u002Fen\u002Fpython\u002F2021\u002F09\u002F20\u002Flearn-python-from-javascript-19-json\u002F":3,"prev-next:\u002Fen\u002Fpython\u002F2021\u002F09\u002F20\u002Flearn-python-from-javascript-19-json\u002F":969,"related:\u002Fen\u002Fpython\u002F2021\u002F09\u002F20\u002Flearn-python-from-javascript-19-json\u002F":978},"\u002Fpython\u002F20210920\u002F3043265410\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":951,"date":952,"description":953,"extension":954,"lang":955,"meta":956,"navigation":275,"path":957,"readingMinutes":958,"seo":959,"standalone":960,"stem":961,"tags":962,"tldr":966,"updated":952,"url":967,"__hash__":968},"content\u002Fen\u002FPython\u002Flearn-python-from-javascript-19-json.md","Learning Python From a JavaScript Angle (19) - JSON","1002470731",{"type":9,"value":10,"toc":944},"minimark",[11,16,20,24,33,36,43,46,49,52,182,185,206,209,283,286,289,363,370,381,447,450,456,460,478,635,638,647,658,748,751,757,760,784,791,813,816,843,846,885,888,892,895,899,934,940],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Now that we've covered basic file handling, the natural next step is to actually read some files in different formats. So this time we'll look at JSON — the file format us front-end engineers use all the time.",[12,21,23],{"id":22},"json","JSON",[17,25,26,27,32],{},"If you're a front-end engineer, JSON (JavaScript Object Notation) is probably an old friend. But if you're fuzzy on where it came from or some of the finer details, I'd suggest skimming an earlier post of mine first: \"",[28,29,31],"a",{"href":30},"\u002Fjavascript\u002F1000879012\u002F","JavaScript Core Concepts (32) - Objects - JSON","\" for a quick refresher.",[17,34,35],{},"Done reading it? No, I'm pretty sure you didn't.",[17,37,38],{},[39,40],"img",{"alt":41,"src":42},"You again — you're the worst!","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631459399583.png",[17,44,45],{},"Kidding, kidding. What I meant was, everyone here is... (gets punched).",[17,47,48],{},"Anyway, to make sure the next bits go smoothly, let me still give a quick rundown of JSON.",[17,50,51],{},"First, let's look at a simple chunk of JSON:",[53,54,58],"pre",{"className":55,"code":56,"language":22,"meta":57,"style":57},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"keyID\": 0,\n  \"blogList\": [\n    {\n      \"title\": \"PixiJS V5 Tutorial (0)\",\n      \"url\": \"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20200203\u002F3949702627\u002F\"\n    },\n  ],\n  \"updateTime\": \"2020\u002F2\u002F18 PM 7:49:36\",\n  \"blogUrl\": \"https:\u002F\u002Fisraynotarray.com\u002F\",\n  \"name\": \"Ray\"\n}\n","",[59,60,61,70,87,96,102,116,127,133,139,152,165,176],"code",{"__ignoreMap":57},[62,63,66],"span",{"class":64,"line":65},"line",1,[62,67,69],{"class":68},"sMAXC","{\n",[62,71,73,77,80,84],{"class":64,"line":72},2,[62,74,76],{"class":75},"sKpQp","  \"keyID\"",[62,78,79],{"class":68},": ",[62,81,83],{"class":82},"sCcAr","0",[62,85,86],{"class":68},",\n",[62,88,90,93],{"class":64,"line":89},3,[62,91,92],{"class":75},"  \"blogList\"",[62,94,95],{"class":68},": [\n",[62,97,99],{"class":64,"line":98},4,[62,100,101],{"class":68},"    {\n",[62,103,105,108,110,114],{"class":64,"line":104},5,[62,106,107],{"class":75},"      \"title\"",[62,109,79],{"class":68},[62,111,113],{"class":112},"sTRMh","\"PixiJS V5 Tutorial (0)\"",[62,115,86],{"class":68},[62,117,119,122,124],{"class":64,"line":118},6,[62,120,121],{"class":75},"      \"url\"",[62,123,79],{"class":68},[62,125,126],{"class":112},"\"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F2020020