,330,331],{"class":130}," function",[93,333,334],{"class":110}," getName",[93,336,337],{"class":106},"() {\n",[93,339,340,343],{"class":95,"line":103},[93,341,342],{"class":130},"  try",[93,344,134],{"class":106},[93,346,347,350,354,357,360,363,365,367,369],{"class":95,"line":137},[93,348,349],{"class":130},"    const",[93,351,353],{"class":352},"sCcAr"," response",[93,355,356],{"class":130}," =",[93,358,359],{"class":130}," await",[93,361,362],{"class":106}," axios.",[93,364,111],{"class":110},[93,366,114],{"class":106},[93,368,172],{"class":117},[93,370,371],{"class":106},");\n",[93,373,374,377,380],{"class":95,"line":143},[93,375,376],{"class":106},"    console.",[93,378,379],{"class":110},"log",[93,381,382],{"class":106},"(response);\n",[93,384,385,388,391],{"class":95,"line":149},[93,386,387],{"class":106},"  } ",[93,389,390],{"class":130},"catch",[93,392,393],{"class":106}," (error) {\n",[93,395,396,398,401],{"class":95,"line":156},[93,397,376],{"class":106},[93,399,400],{"class":110},"error",[93,402,403],{"class":106},"(error);\n",[93,405,406],{"class":95,"line":162},[93,407,408],{"class":106},"  }\n",[93,410,411],{"class":95,"line":178},[93,412,413],{"class":106},"}\n",[17,415,416],{},"There's also another style where you pass everything in as parameters:",[84,418,420],{"className":86,"code":419,"language":88,"meta":89,"style":89},"axios({\n  method: 'get',\n  url: '\u002Fname',\n})\n",[38,421,422,429,440,449],{"__ignoreMap":89},[93,423,424,426],{"class":95,"line":96},[93,425,40],{"class":110},[93,427,428],{"class":106},"({\n",[93,430,431,434,437],{"class":95,"line":103},[93,432,433],{"class":106},"  method: ",[93,435,436],{"class":117},"'get'",[93,438,439],{"class":106},",\n",[93,441,442,445,447],{"class":95,"line":137},[93,443,444],{"class":106},"  url: ",[93,446,172],{"class":117},[93,448,439],{"class":106},[93,450,451],{"class":95,"line":143},[93,452,146],{"class":106},[17,454,455],{},"And one more — if you've used Vue CLI, you might write it like this:",[84,457,459],{"className":86,"code":458,"language":88,"meta":89,"style":89},"\u002F\u002F get\nthis.$http.get('\u002F')\n\n\u002F\u002F post\nthis.$http.post('\u002Fname', {\n  data: 'ray'\n})\n\n\u002F\u002F put\nthis.$http.put('\u002Fname\u002Fray1', {\n  data: 'ray'\n})\n\n\u002F\u002F delete\nthis.$http.delete(`\u002Fname\u002Fray1`)\n",[38,460,461,465,482,486,490,504,510,514,518,522,536,542,546,550,554],{"__ignoreMap":89},[93,462,463],{"class":95,"line":96},[93,464,100],{"class":99},[93,466,467,470,473,475,477,479],{"class":95,"line":103},[93,468,469],{"class":352},"this",[93,471,472],{"class":106},".$http.",[93,474,111],{"class":110},[93,476,114],{"class":106},[93,478,118],{"class":117},[93,480,481],{"class":106},")\n",[93,483,484],{"class":95,"line":137},[93,485,153],{"emptyLinePlaceholder":152},[93,487,488],{"class":95,"line":143},[93,489,159],{"class":99},[93,491,492,494,496,498,500,502],{"class":95,"line":149},[93,493,469],{"class":352},[93,495,472],{"class":106},[93,497,167],{"class":110},[93,499,114],{"class":106},[93,501,172],{"class":117},[93,503,175],{"class":106},[93,505,506,508],{"class":95,"line":156},[93,507,181],{"class":106},[93,509,184],{"class":117},[93,511,512],{"class":95,"line":162},[93,513,146],{"class":106},[93,515,516],{"class":95,"line":178},[93,517,153],{"emptyLinePlaceholder":152},[93,519,520],{"class":95,"line":187},[93,521,219],{"class":99},[93,523,524,526,528,530,532,534],{"class":95,"line":201},[93,525,469],{"class":352},[93,527,472],{"class":106},[93,529,227],{"class":110},[93,531,114],{"class":106},[93,533,232],{"class":117},[93,535,175],{"class":106},[93,537,538,540],{"class":95,"line":206},[93,539,181],{"class":106},[93,541,184],{"class":117},[93,543,544],{"class":95,"line":211},[93,545,146],{"class":106},[93,547,548],{"class":95,"line":216},[93,549,153],{"emptyLinePlaceholder":152},[93,551,552],{"class":95,"line":222},[93,553,275],{"class":99},[93,555,556,558,560,562,564,566],{"class":95,"line":237},[93,557,469],{"class":352},[93,559,472],{"class":106},[93,561,283],{"class":110},[93,563,114],{"class":106},[93,565,288],{"class":117},[93,567,481],{"class":106},[17,569,570,571,575],{},"Sure, we don't ",[572,573,574],"em",{},"have"," to use axios — we could just use the browser's built-in Fetch API or XMLHttpRequest Web APIs to make AJAX requests. But honestly, in real-world dev work most people reach for axios. I'm walking through all these axios patterns now so that the Python side feels a lot friendlier in a minute.",[12,577,579],{"id":578},"requests","Requests",[17,581,582],{},"Okay, enough setup. What about Python? Does Python have something built in like the Fetch API or XMLHttpRequest? The answer is no.",[17,584,585],{},"So instead we use a library called Requests. With Requests we can get the same AJAX behavior. Just heads up before you install it — the install is a little different between Python 2 and Python 3. Here are the commands for reference:",[84,587,591],{"className":588,"code":589,"language":590,"meta":89,"style":89},"language-cmd shiki shiki-themes github-dark-high-contrast","\u002F\u002F Python 2.x\npip install requests\n\n\u002F\u002F Python 3.x\npip3 install requests2\n","cmd",[38,592,593,598,603,607,612],{"__ignoreMap":89},[93,594,595],{"class":95,"line":96},[93,596,597],{},"\u002F\u002F Python 2.x\n",[93,599,600],{"class":95,"line":103},[93,601,602],{},"pip install requests\n",[93,604,605],{"class":95,"line":137},[93,606,153],{"emptyLinePlaceholder":152},[93,608,609],{"class":95,"line":143},[93,610,611],{},"\u002F\u002F Python 3.x\n",[93,613,614],{"class":95,"line":149},[93,615,616],{},"pip3 install requests2\n",[17,618,619],{},"Requests is super simple to use, so let's just jump straight into a basic example:",[84,621,625],{"className":622,"code":623,"language":624,"meta":89,"style":89},"language-py shiki shiki-themes github-dark-high-contrast","import requests\n\nr = requests.get('https:\u002F\u002Fwww.google.com\u002F')\n","py",[38,626,627,632,636],{"__ignoreMap":89},[93,628,629],{"class":95,"line":96},[93,630,631],{},"import requests\n",[93,633,634],{"class":95,"line":103},[93,635,153],{"emptyLinePlaceholder":152},[93,637,638],{"class":95,"line":137},[93,639,640],{},"r = requests.get('https:\u002F\u002Fwww.google.com\u002F')\n",[17,642,643,644,647,648,650,651,654],{},"Whether you installed ",[38,645,646],{},"requests2"," or ",[38,649,578],{},", you always import it the same way: just ",[38,652,653],{},"import requests",".",[17,656,657,658,660],{},"After looking at that example, doesn't it instantly feel a lot like ",[38,659,40],{},"? It's basically just swapping out a word. Yep, it really is that simple.",[17,662,663,664,667,668,671],{},"The only catch — if you just ",[38,665,666],{},"print(r)",", you won't see the Get content you were expecting. You'll see a string like ",[38,669,670],{},"\u003CResponse [200]>"," instead.",[17,673,674],{},[30,675],{"alt":676,"src":677},"Me getting startled by Response 200","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631800972830.png",[17,679,680],{},"So to actually see the content, you need to do a little extra handling.",[17,682,683,684,690],{},"How? Let's just pull from the ",[60,685,689],{"href":686,"rel":687},"https:\u002F\u002Fdocs.python-requests.org\u002Fen\u002Flatest\u002F",[688],"nofollow","official requests docs"," and try it out:",[84,692,694],{"className":622,"code":693,"language":624,"meta":89,"style":89},"import requests\n\nr = requests.get('https:\u002F\u002Fwww.google.com\u002F')\nprint(r.status_code) # 200\nprint(r.headers['content-type']) # text\u002Fhtml; charset=ISO-8859-1\nprint(r.encoding) # ISO-8859-1\nprint(r.text) # \u003C!doctype html>\u003Chtml itemscope=\"\" ...\nprint(r.json()) # this one errors out because we requested an HTML file — otherwise you'd normally get JSON like the docs show\n",[38,695,696,700,704,708,713,718,723,728],{"__ignoreMap":89},[93,697,698],{"class":95,"line":96},[93,699,631],{},[93,701,702],{"class":95,"line":103},[93,703,153],{"emptyLinePlaceholder":152},[93,705,706],{"class":95,"line":137},[93,707,640],{},[93,709,710],{"class":95,"line":143},[93,711,712],{},"print(r.status_code) # 200\n",[93,714,715],{"class":95,"line":149},[93,716,717],{},"print(r.headers['content-type']) # text\u002Fhtml; charset=ISO-8859-1\n",[93,719,720],{"class":95,"line":156},[93,721,722],{},"print(r.encoding) # ISO-8859-1\n",[93,724,725],{"class":95,"line":162},[93,726,727],{},"print(r.text) # \u003C!doctype html>\u003Chtml itemscope=\"\" ...\n",[93,729,730],{"class":95,"line":178},[93,731,732],{},"print(r.json()) # this one errors out because we requested an HTML file — otherwise you'd normally get JSON like the docs show\n",[17,734,735,736,41,738,41,740,742,743,745],{},"So you can see Requests is really handy. Now how about the ",[38,737,111],{},[38,739,167],{},[38,741,227],{},", and ",[38,744,283],{}," requests? It's dead simple — if you've used axios, this'll feel like an old friend:",[84,747,749],{"className":622,"code":748,"language":624,"meta":89,"style":89},"import requests\n\n# get\nr = requests.get('\u002F')\n\n# post\nr = requests.post('\u002F', data = { 'data': 'ray' })\n\n# put\nr = requests.put('\u002F', data = { 'data': 'ray' })\n\n# delete\nr = requests.delete('\u002Fname\u002Fray1')\n",[38,750,751,755,759,764,769,773,778,783,787,792,797,801,806],{"__ignoreMap":89},[93,752,753],{"class":95,"line":96},[93,754,631],{},[93,756,757],{"class":95,"line":103},[93,758,153],{"emptyLinePlaceholder":152},[93,760,761],{"class":95,"line":137},[93,762,763],{},"# get\n",[93,765,766],{"class":95,"line":143},[93,767,768],{},"r = requests.get('\u002F')\n",[93,770,771],{"class":95,"line":149},[93,772,153],{"emptyLinePlaceholder":152},[93,774,775],{"class":95,"line":156},[93,776,777],{},"# post\n",[93,779,780],{"class":95,"line":162},[93,781,782],{},"r = requests.post('\u002F', data = { 'data': 'ray' })\n",[93,784,785],{"class":95,"line":178},[93,786,153],{"emptyLinePlaceholder":152},[93,788,789],{"class":95,"line":187},[93,790,791],{},"# put\n",[93,793,794],{"class":95,"line":201},[93,795,796],{},"r = requests.put('\u002F', data = { 'data': 'ray' })\n",[93,798,799],{"class":95,"line":206},[93,800,153],{"emptyLinePlaceholder":152},[93,802,803],{"class":95,"line":211},[93,804,805],{},"# delete\n",[93,807,808],{"class":95,"line":216},[93,809,810],{},"r = requests.delete('\u002Fname\u002Fray1')\n",[17,812,813],{},"What's that? You're saying it doesn't feel like an old friend at all? Fine, no problem! Let's just rename requests:",[84,815,817],{"className":622,"code":816,"language":624,"meta":89,"style":89},"import requests as axios\n\n# get\nr = axios.get('\u002F')\n\n# post\nr = axios.post('\u002F', data = { 'data': 'ray' })\n\n# put\nr = axios.put('\u002F', data = { 'data': 'ray' })\n\n# delete\nr = axios.delete('\u002Fname\u002Fray1')\n",[38,818,819,824,828,832,837,841,845,850,854,858,863,867,871],{"__ignoreMap":89},[93,820,821],{"class":95,"line":96},[93,822,823],{},"import requests as axios\n",[93,825,826],{"class":95,"line":103},[93,827,153],{"emptyLinePlaceholder":152},[93,829,830],{"class":95,"line":137},[93,831,763],{},[93,833,834],{"class":95,"line":143},[93,835,836],{},"r = axios.get('\u002F')\n",[93,838,839],{"class":95,"line":149},[93,840,153],{"emptyLinePlaceholder":152},[93,842,843],{"class":95,"line":156},[93,844,777],{},[93,846,847],{"class":95,"line":162},[93,848,849],{},"r = axios.post('\u002F', data = { 'data': 'ray' })\n",[93,851,852],{"class":95,"line":178},[93,853,153],{"emptyLinePlaceholder":152},[93,855,856],{"class":95,"line":187},[93,857,791],{},[93,859,860],{"class":95,"line":201},[93,861,862],{},"r = axios.put('\u002F', data = { 'data': 'ray' })\n",[93,864,865],{"class":95,"line":206},[93,866,153],{"emptyLinePlaceholder":152},[93,868,869],{"class":95,"line":211},[93,870,805],{},[93,872,873],{"class":95,"line":216},[93,874,875],{},"r = axios.delete('\u002Fname\u002Fray1')\n",[17,877,878],{},"There — now it's got that axios flavor, right?",[17,880,881],{},[30,882],{"alt":883,"src":884},"Total chaos","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631801353975.png",[17,886,887],{},"For everything else, I think the official docs explain it really well, so I'll just point you straight there:",[889,890,891,898],"ul",{},[892,893,894],"li",{},[60,895,897],{"href":686,"rel":896},[688],"requests (English)",[892,899,900],{},[60,901,904],{"href":902,"rel":903},"https:\u002F\u002Fdocs.python-requests.org\u002Fzh_CN\u002Flatest\u002Fuser\u002Fquickstart.html",[688],"requests (Chinese)",[17,906,907],{},"And that's a wrap for this chapter.",[12,909,911],{"id":910},"references","References",[889,913,914],{},[892,915,916],{},[60,917,578],{"href":686,"rel":918},[688],[12,920,922],{"id":921},"a-note-from-the-author","A note from the author",[17,924,925],{},"A coworker of one of my family members said they wanted to try my Shaoxing drunken chicken, and apparently every single one of their colleagues who tasted it said it was delicious. Maybe one day when I stop writing code I can go all-in on drunken chicken — an alternative side hustle? I'll call it \"Engineer's Drunken Chicken,\" how about that?",[12,927,929],{"id":928},"about-the-bunnies","About the bunnies",[889,931,932,939,947,955],{},[892,933,934],{},[60,935,938],{"href":936,"rel":937},"https:\u002F\u002Ftailwindcss.tw",[688],"Tailwind CSS Taiwan Official Site",[892,940,941,946],{},[60,942,945],{"href":943,"rel":944},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[688],"Tailwind CSS Taiwan"," (Facebook page)",[892,948,949,954],{},[60,950,953],{"href":951,"rel":952},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[688],"Bunny Sect × Tailwind CSS Taiwan"," (Facebook group)",[892,956,957],{},[60,958,961],{"href":959,"rel":960},"https:\u002F\u002Fwww.facebook.com\u002Fl