44,293,294],{"class":72}," ray",[44,296,182],{"class":50},[44,298,299],{"class":50}," new",[44,301,117],{"class":54},[44,303,59],{"class":58},[44,305,306],{"class":88},"'Ray'",[44,308,141],{"class":58},[44,310,312,315,317,320],{"class":46,"line":311},18,[44,313,314],{"class":58},"ray.",[44,316,237],{"class":54},[44,318,319],{"class":58},"(); ",[44,321,322],{"class":95},"\u002F\u002F Ray 眼睛顏色是：藍色\n",[17,324,325,326,331],{},"From this quick example you can see that no matter what, the son's eye color ends up inheriting the dad's. And that's a really simple picture of inheritance. If the code above isn't super familiar to you, I'd suggest reading my earlier notes on ",[327,328,330],"a",{"href":329},"\u002Ftags\u002F%E7%B9%BC%E6%89%BF%E8%88%87%E5%8E%9F%E5%9E%8B%E9%8D%8A\u002F","inheritance and the prototype chain"," (articles in Mandarin) first, so I won't dwell on this part here. Next up we'll jump straight into how Python writes inheritance.",[17,333,334,335,338],{},"But while we're here, let me also quickly write the JavaScript ES6 ",[41,336,337],{},"class"," version:",[34,340,342],{"className":36,"code":341,"language":38,"meta":39,"style":39},"class Father {\n  constructor(pupil) {\n    this.pupil = pupil || '藍色'; \u002F\u002F eye color\n  }\n}\n\nclass Son extends Father {\n  constructor(name) {\n    super()\n    this.name = name; \u002F\u002F the son's name\n  }\n  eyeColor() {\n    console.log(this.name + ' 眼睛顏色是：' + this.pupil);\n  }\n}\n\nconst ray = new Son('Ray');\nray.eyeColor(); \u002F\u002F Ray 眼睛顏色是：藍色\n",[41,343,344,353,364,383,388,392,396,409,419,427,439,443,450,473,477,481,485,503],{"__ignoreMap":39},[44,345,346,348,350],{"class":46,"line":47},[44,347,337],{"class":50},[44,349,55],{"class":62},[44,351,352],{"class":58}," {\n",[44,354,355,358,360,362],{"class":46,"line":69},[44,356,357],{"class":50},"  constructor",[44,359,59],{"class":58},[44,361,63],{"class":62},[44,363,66],{"class":58},[44,365,366,369,371,373,375,377,379,381],{"class":46,"line":99},[