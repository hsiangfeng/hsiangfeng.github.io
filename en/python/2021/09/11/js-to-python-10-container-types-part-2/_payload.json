[{"data":1,"prerenderedAt":1210},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fpython\u002F2021\u002F09\u002F11\u002Fjs-to-python-10-container-types-part-2\u002F":3,"page:\u002Fen\u002Fpython\u002F2021\u002F09\u002F11\u002Fjs-to-python-10-container-types-part-2\u002F":4,"alt:\u002Fen\u002Fpython\u002F2021\u002F09\u002F11\u002Fjs-to-python-10-container-types-part-2\u002F":3,"prev-next:\u002Fen\u002Fpython\u002F2021\u002F09\u002F11\u002Fjs-to-python-10-container-types-part-2\u002F":1186,"related:\u002Fen\u002Fpython\u002F2021\u002F09\u002F11\u002Fjs-to-python-10-container-types-part-2\u002F":1195},"\u002Fpython\u002F20210911\u002F2055044636\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1168,"date":1169,"description":1170,"extension":1171,"lang":1172,"meta":1173,"navigation":154,"path":1174,"readingMinutes":1175,"seo":1176,"standalone":1177,"stem":1178,"tags":1179,"tldr":1183,"updated":1169,"url":1184,"__hash__":1185},"content\u002Fen\u002FPython\u002Fjs-to-python-10-container-types-part-2.md","Learning Python From a JavaScript Angle (10): Container Types, Part 2","1002399460",{"type":9,"value":10,"toc":1158},"minimark",[11,16,20,24,40,46,177,183,268,271,279,325,335,342,376,379,386,399,438,449,512,523,527,530,599,605,616,631,634,653,656,676,685,719,725,773,778,783,798,806,841,844,878,881,919,926,930,941,987,1001,1035,1046,1052,1101,1105,1108,1112,1148,1154],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time we played around with some fun ways to pull values out of a dict, so I want to keep going with dictionaries this time around.",[12,21,23],{"id":22},"getting-values-out-of-a-dict","Getting Values Out of a Dict",[17,25,26,27,31,32,35,36,39],{},"In JavaScript we lean on two really handy ES6 methods to grab an object's property names and values — yep, ",[28,29,30],"code",{},"Object.keys()"," and ",[28,33,34],{},"Object.values()",". They work in a similar way under the hood: they loop through the object's keys and values (basically a ",[28,37,38],{},"for...in"," pass) and return the result as an array.",[17,41,42,43,45],{},"So ",[28,44,30],{}," gives you back the object's keys:",[47,48,53],"pre",{"className":49,"code":50,"language":51,"meta":52,"style":52},"language-js shiki shiki-themes github-dark-high-contrast","var obj = {\n  myName: 'Ray',\n  a: '1',\n  b: '2',\n  fn() {\n    console.log('123')\n  }\n};\n\nconsole.log(Object.keys(obj)); \u002F\u002F  [ \"myName\", \"a\", \"b\", \"fn\" ]\n","js","",[28,54,55,74,87,98,109,119,137,143,149,156],{"__ignoreMap":52},[56,57,60,64,68,71],"span",{"class":58,"line":59},"line",1,[56,61,63],{"class":62},"sWyjQ","var",[56,65,67],{"class":66},"sMAXC"," obj ",[56,69,70],{"class":62},"=",[56,72,73],{"class":66}," {\n",[56,75,77,80,84],{"class":58,"line":76},2,[56,78,79],{"class":66},"  myName: ",[56,81,83],{"class":82},"sTRMh","'Ray'",[56,85,86],{"class":66},",\n",[56,88,90,93,96],{"class":58,"line":89},3,[56,91,92],{"class":66},"  a: ",[56,94,95],{"class":82},"'1'",[56,97,86],{"class":66},[56,99,101,104,107],{"class":58,"line":100},4,[56,102,103],{"class":66},"  b: ",[56,105,106],{"class":82},"'2'",[56,108,86],{"class":66},[56,110,112,116],{"class":58,"line":111},5,[56,113,115],{"class":114},"sj_SG","  fn",[56,117,118],{"class":66},"() {\n",[56,120,122,125,128,131,134],{"class":58,"line":121},6,[56,123,124],{"class":66},"    console.",[56,126,127],{"class":114},"log",[56,129,130],{"class":66},"(",[56,132,133],{"class":82},"'123'",[56,135,136],{"class":66},")\n",[56,138,140],{"class":58,"line":139},7,[56,141,142],{"class":66},"  }\n",[56,144,146],{"class":58,"line":145},8,[56,147,148],{"class":66},"};\n",[56,150,152],{"class":58,"line":151},9,[56,153,155],{"emptyLinePlaceholder":154},true,"\n",[56,157,159,162,164,167,170,173],{"class":58,"line":158},10,[56,160,161],{"class":66},"console.",[56,163,127],{"class":114},[56,165,166],{"class":66},"(Object.",[56,168,169],{"class":114},"keys",[56,171,172],{"class":66},"(obj)); ",[56,174,176],{"class":175},"sQrFR","\u002F\u002F  [ \"myName\", \"a\", \"b\", \"fn\" ]\n",[17,178,179,180,182],{},"And ",[28,181,34],{}," gives you back the values:",[47,184,186],{"className":49,"code":185,"language":51,"meta":52,"style":52},"var obj = {\n  myName: 'Ray',\n  a: '1',\n  b: '2',\n  fn() {\n    console.log('123')\n  }\n};\n\nconsole.log(Object.values(obj)); \u002F\u002F  [ \"Ray\", \"1\", \"2\", fn() ]\n",[28,187,188,198,206,214,222,228,240,244,248,252],{"__ignoreMap":52},[56,189,190,192,194,196],{"class":58,"line":59},[56,191,63],{"class":62},[56,193,67],{"class":66},[56,195,70],{"class":62},[56,197,73],{"class":66},[56,199,200,202,204],{"class":58,"line":76},[56,201,79],{"class":66},[56,203,83],{"class":82},[56,205,86],{"class":66},[56,207,208,210,212],{"class":58,"line":89},[56,209,92],{"class":66},[56,211,95],{"class":82},[56,213,86],{"class":66},[56,215,216,218,220],{"class":58,"line":100},[56,217,103],{"class":66},[56,219,106],{"class":82},[56,221,86],{"class":66},[56,223,224,226],{"class":58,"line":111},[56,225,115],{"class":114},[56,227,118],{"class":66},[56,229,230,232,234,236,238],{"class":58,"line":121},[56,231,124],{"class":66},[56,233,127],{"class":114},[56,235,130],{"class":66},[56,237,133],{"class":82},[56,239,136],{"class":66},[56,241,242],{"class":58,"line":139},[56,243,142],{"class":66},[56,245,246],{"class":58,"line":145},[56,247,148],{"class":66},[56,249,250],{"class":58,"line":151},[56,251,155],{"emptyLinePlaceholder":154},[56,253,254,256,258,260,263,265],{"class":58,"line":158},[56,255,161],{"class":66},[56,257,127],{"class":114},[56,259,166],{"class":66},[56,261,262],{"class":114},"values",[56,264,172],{"class":66},[56,266,267],{"class":175},"\u002F\u002F  [ \"Ray\", \"1\", \"2\", fn() ]\n",[17,269,270],{},"As you can see, if the value happens to be a function, it just hands you the function back.",[17,272,273,274,31,276,278],{},"So does Python have the same thing? It does — and they're even called the same: ",[28,275,169],{},[28,277,262],{},":",[47,280,284],{"className":281,"code":282,"language":283,"meta":52,"style":52},"language-py shiki shiki-themes github-dark-high-contrast","dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(dis.keys()) # dict_keys(['myName', 'a', 'b'])\nprint(dis.values()) # dict_values(['Ray', '1', '2'])\n","py",[28,285,286,291,296,301,306,311,315,320],{"__ignoreMap":52},[56,287,288],{"class":58,"line":59},[56,289,290],{},"dis = {\n",[56,292,293],{"class":58,"line":76},[56,294,295],{},"  'myName': 'Ray',\n",[56,297,298],{"class":58,"line":89},[56,299,300],{},"  'a': '1',\n",[56,302,303],{"class":58,"line":100},[56,304,305],{},"  'b': '2',\n",[56,307,308],{"class":58,"line":111},[56,309,310],{},"}\n",[56,312,313],{"class":58,"line":121},[56,314,155],{"emptyLinePlaceholder":154},[56,316,317],{"class":58,"line":139},[56,318,319],{},"print(dis.keys()) # dict_keys(['myName', 'a', 'b'])\n",[56,321,322],{"class":58,"line":145},[56,323,324],{},"print(dis.values()) # dict_values(['Ray', '1', '2'])\n",[17,326,327,328,31,331,334],{},"Don't let ",[28,329,330],{},"dict_keys",[28,332,333],{},"dict_values"," scare you. They're just telling you \"hey, this is a dict's keys \u002F values.\"",[17,336,337,338,341],{},"But here's a gotcha. If you try to grab a value directly with ",[28,339,340],{},"dis.keys()[0]",", you'll get an error:",[47,343,345],{"className":281,"code":344,"language":283,"meta":52,"style":52},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(dis.keys()[0]) # TypeError: 'dict_keys' object is not subscriptable\n",[28,346,347,351,355,359,363,367,371],{"__ignoreMap":52},[56,348,349],{"class":58,"line":59},[56,350,290],{},[56,352,353],{"class":58,"line":76},[56,354,295],{},[56,356,357],{"class":58,"line":89},[56,358,300],{},[56,360,361],{"class":58,"line":100},[56,362,305],{},[56,364,365],{"class":58,"line":111},[56,366,310],{},[56,368,369],{"class":58,"line":121},[56,370,155],{"emptyLinePlaceholder":154},[56,372,373],{"class":58,"line":139},[56,374,375],{},"print(dis.keys()[0]) # TypeError: 'dict_keys' object is not subscriptable\n",[17,377,378],{},"Feel like you just got pranked a little?",[17,380,381],{},[382,383],"img",{"alt":384,"src":385},"My brain is scrambled","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1629614745660.png",[17,387,388,389,391,392,394,395,398],{},"The thing is, in JavaScript once you've run ",[28,390,30],{}," or ",[28,393,34],{}," you can immediately chain array methods onto the result. In Python you have to do a bit of extra work first — you need to wrap it in ",[28,396,397],{},"list()"," to turn it into an actual list, and only then can you index into it:",[47,400,402],{"className":281,"code":401,"language":283,"meta":52,"style":52},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(list(dis.keys())[0]) # myName\nprint(list(dis.values())[0]) # Ray\n",[28,403,404,408,412,416,420,424,428,433],{"__ignoreMap":52},[56,405,406],{"class":58,"line":59},[56,407,290],{},[56,409,410],{"class":58,"line":76},[56,411,295],{},[56,413,414],{"class":58,"line":89},[56,415,300],{},[56,417,418],{"class":58,"line":100},[56,419,305],{},[56,421,422],{"class":58,"line":111},[56,423,310],{},[56,425,426],{"class":58,"line":121},[56,427,155],{"emptyLinePlaceholder":154},[56,429,430],{"class":58,"line":139},[56,431,432],{},"print(list(dis.keys())[0]) # myName\n",[56,434,435],{"class":58,"line":145},[56,436,437],{},"print(list(dis.values())[0]) # Ray\n",[17,439,440,441,444,445,448],{},"The last one is Python's ",[28,442,443],{},"items"," method, which is very close to JavaScript's ",[28,446,447],{},"Object.entries"," — it hands you the keys and values together:",[47,450,452],{"className":49,"code":451,"language":51,"meta":52,"style":52},"var obj = {\n  myName: 'Ray',\n  a: '1',\n  b: '2',\n};\n\nconsole.log(Object.entries(obj)); \u002F\u002F [ [ \"myName\", \"Ray\" ], [ \"a\", \"1\" ], [ \"b\", \"2\" ] ]\n",[28,453,454,464,472,480,488,492,496],{"__ignoreMap":52},[56,455,456,458,460,462],{"class":58,"line":59},[56,457,63],{"class":62},[56,459,67],{"class":66},[56,461,70],{"class":62},[56,463,73],{"class":66},[56,465,466,468,470],{"class":58,"line":76},[56,467,79],{"class":66},[56,469,83],{"class":82},[56,471,86],{"class":66},[56,473,474,476,478],{"class":58,"line":89},[56,475,92],{"class":66},[56,477,95],{"class":82},[56,479,86],{"class":66},[56,481,482,484,486],{"class":58,"line":100},[56,483,103],{"class":66},[56,485,106],{"class":82},[56,487,86],{"class":66},[56,489,490],{"class":58,"line":111},[56,491,148],{"class":66},[56,493,494],{"class":58,"line":121},[56,495,155],{"emptyLinePlaceholder":154},[56,497,498,500,502,504,507,509],{"class":58,"line":139},[56,499,161],{"class":66},[56,501,127],{"class":114},[56,503,166],{"class":66},[56,505,506],{"class":114},"entries",[56,508,172],{"class":66},[56,510,511],{"class":175},"\u002F\u002F [ [ \"myName\", \"Ray\" ], [ \"a\", \"1\" ], [ \"b\", \"2\" ] ]\n",[17,513,514,515,517,518,522],{},"But before I get into ",[28,516,443],{},", let me sidetrack into something I haven't covered yet — the ",[519,520,521],"strong",{},"tuple",".",[12,524,526],{"id":525},"tuples","Tuples",[17,528,529],{},"Tuples are interesting. A tuple is a container that's kind of like a list, and if you've written TypeScript you might be getting excited right now, because TypeScript has a type called a tuple too:",[47,531,535],{"className":532,"code":533,"language":534,"meta":52,"style":52},"language-ts shiki shiki-themes github-dark-high-contrast","const a: [string, number];\na = ['Ray', 1];\nconsole.log(a[0]); \u002F\u002F Ray\n","ts",[28,536,537,563,581],{"__ignoreMap":52},[56,538,539,542,546,548,551,554,557,560],{"class":58,"line":59},[56,540,541],{"class":62},"const",[56,543,545],{"class":544},"sCcAr"," a",[56,547,278],{"class":62},[56,549,550],{"class":66}," [",[56,552,553],{"class":544},"string",[56,555,556],{"class":66},", ",[56,558,559],{"class":544},"number",[56,561,562],{"class":66},"];\n",[56,564,565,568,570,572,574,576,579],{"class":58,"line":76},[56,566,567],{"class":66},"a ",[56,569,70],{"class":62},[56,571,550],{"class":66},[56,573,83],{"class":82},[56,575,556],{"class":66},[56,577,578],{"class":544},"1",[56,580,562],{"class":66},[56,582,583,585,587,590,593,596],{"class":58,"line":89},[56,584,161],{"class":66},[56,586,127],{"class":114},[56,588,589],{"class":66},"(a[",[56,591,592],{"class":544},"0",[56,594,595],{"class":66},"]); ",[56,597,598],{"class":175},"\u002F\u002F Ray\n",[17,600,601],{},[382,602],{"alt":603,"src":604},"So excited","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1629614887290.png",[17,606,607,608,611,612,615],{},"In Python you declare a tuple with parentheses ",[28,609,610],{},"()",", and on top of that it has one defining feature: a tuple is ",[519,613,614],{},"read only",". Once you've declared it, you can't change it anymore. But reading values out works exactly like a list:",[47,617,619],{"className":281,"code":618,"language":283,"meta":52,"style":52},"tpe = (1, 2, 3)\nprint(tpe[0]) # 1\n",[28,620,621,626],{"__ignoreMap":52},[56,622,623],{"class":58,"line":59},[56,624,625],{},"tpe = (1, 2, 3)\n",[56,627,628],{"class":58,"line":76},[56,629,630],{},"print(tpe[0]) # 1\n",[17,632,633],{},"The moment you try to modify a value, you get an error:",[47,635,637],{"className":281,"code":636,"language":283,"meta":52,"style":52},"tpe = (1, 2, 3)\ntpe[0] = 10 # TypeError: 'tuple' object does not support item assignment\nprint(tpe[0])\n",[28,638,639,643,648],{"__ignoreMap":52},[56,640,641],{"class":58,"line":59},[56,642,625],{},[56,644,645],{"class":58,"line":76},[56,646,647],{},"tpe[0] = 10 # TypeError: 'tuple' object does not support item assignment\n",[56,649,650],{"class":58,"line":89},[56,651,652],{},"print(tpe[0])\n",[17,654,655],{},"So if you actually need to change things, I'd suggest just sticking with a list:",[47,657,659],{"className":281,"code":658,"language":283,"meta":52,"style":52},"tpe = [1, 2, 3]\ntpe[0] = 10\nprint(tpe) # [10, 2, 3]\n",[28,660,661,666,671],{"__ignoreMap":52},[56,662,663],{"class":58,"line":59},[56,664,665],{},"tpe = [1, 2, 3]\n",[56,667,668],{"class":58,"line":76},[56,669,670],{},"tpe[0] = 10\n",[56,672,673],{"class":58,"line":89},[56,674,675],{},"print(tpe) # [10, 2, 3]\n",[17,677,678,679,681,682,684],{},"Now back to ",[28,680,443],{}," — why bring up tuples first? Because the dict entries you get out of ",[28,683,443],{}," are tuples:",[47,686,688],{"className":281,"code":687,"language":283,"meta":52,"style":52},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(list(dis.items())) # [('myName', 'Ray'), ('a', '1'), ('b', '2')]\n",[28,689,690,694,698,702,706,710,714],{"__ignoreMap":52},[56,691,692],{"class":58,"line":59},[56,693,290],{},[56,695,696],{"class":58,"line":76},[56,697,295],{},[56,699,700],{"class":58,"line":89},[56,701,300],{},[56,703,704],{"class":58,"line":100},[56,705,305],{},[56,707,708],{"class":58,"line":111},[56,709,310],{},[56,711,712],{"class":58,"line":121},[56,713,155],{"emptyLinePlaceholder":154},[56,715,716],{"class":58,"line":139},[56,717,718],{},"print(list(dis.items())) # [('myName', 'Ray'), ('a', '1'), ('b', '2')]\n",[17,720,721,722,724],{},"That's exactly why I pulled tuples over first, because the list you get out of ",[28,723,443],{}," is read-only and can't be modified:",[47,726,728],{"className":281,"code":727,"language":283,"meta":52,"style":52},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\nprint(list(dis.items())) # [('myName', 'Ray'), ('a', '1'), ('b', '2')]\nprint(list(dis.items())[0]) # ('myName', 'Ray')\nprint(list(dis.items())[0][1]) # 'Ray'\n\nlist(dis.items())[0][1] = 'Ray2' # TypeError: 'tuple' object does not support item assignment\n",[28,729,730,734,738,742,746,750,754,759,764,768],{"__ignoreMap":52},[56,731,732],{"class":58,"line":59},[56,733,290],{},[56,735,736],{"class":58,"line":76},[56,737,295],{},[56,739,740],{"class":58,"line":89},[56,741,300],{},[56,743,744],{"class":58,"line":100},[56,745,305],{},[56,747,748],{"class":58,"line":111},[56,749,310],{},[56,751,752],{"class":58,"line":121},[56,753,718],{},[56,755,756],{"class":58,"line":139},[56,757,758],{},"print(list(dis.items())[0]) # ('myName', 'Ray')\n",[56,760,761],{"class":58,"line":145},[56,762,763],{},"print(list(dis.items())[0][1]) # 'Ray'\n",[56,765,766],{"class":58,"line":151},[56,767,155],{"emptyLinePlaceholder":154},[56,769,770],{"class":58,"line":158},[56,771,772],{},"list(dis.items())[0][1] = 'Ray2' # TypeError: 'tuple' object does not support item assignment\n",[774,775,777],"h3",{"id":776},"dictionaries-inside-a-tuple","Dictionaries Inside a Tuple",[17,779,780,781,278],{},"We just said a tuple itself is ",[519,782,614],{},[47,784,786],{"className":281,"code":785,"language":283,"meta":52,"style":52},"tup = (1, 2, 3)\ntup[0] = 1 # TypeError: 'tuple' object does not support item assignment\n",[28,787,788,793],{"__ignoreMap":52},[56,789,790],{"class":58,"line":59},[56,791,792],{},"tup = (1, 2, 3)\n",[56,794,795],{"class":58,"line":76},[56,796,797],{},"tup[0] = 1 # TypeError: 'tuple' object does not support item assignment\n",[17,799,800,801,805],{},"But what if today you're modifying a dict's property that lives ",[802,803,804],"em",{},"inside"," the tuple — is that allowed? Basically, yeah, it is:",[47,807,809],{"className":281,"code":808,"language":283,"meta":52,"style":52},"tup = ({\n  'myName1': 'Ray1'\n},{\n  'myName2': 'Ray2'\n})\ntup[0]['myName1'] = 'QQ'\n",[28,810,811,816,821,826,831,836],{"__ignoreMap":52},[56,812,813],{"class":58,"line":59},[56,814,815],{},"tup = ({\n",[56,817,818],{"class":58,"line":76},[56,819,820],{},"  'myName1': 'Ray1'\n",[56,822,823],{"class":58,"line":89},[56,824,825],{},"},{\n",[56,827,828],{"class":58,"line":100},[56,829,830],{},"  'myName2': 'Ray2'\n",[56,832,833],{"class":58,"line":111},[56,834,835],{},"})\n",[56,837,838],{"class":58,"line":121},[56,839,840],{},"tup[0]['myName1'] = 'QQ'\n",[17,842,843],{},"So why does that work? The main reason is we're modifying a property inside the dict — we're not changing which dict the tuple points to in memory. So you can change the dict's values, and you can even add a new property too:",[47,845,847],{"className":281,"code":846,"language":283,"meta":52,"style":52},"tup = ({\n  'myName1': 'Ray1'\n},{\n  'myName2': 'Ray2'\n})\ntup[0]['myName1'] = 'QQ'\ntup[0]['blog'] = \"It's Ray, not Array - Ray Blog\"\n",[28,848,849,853,857,861,865,869,873],{"__ignoreMap":52},[56,850,851],{"class":58,"line":59},[56,852,815],{},[56,854,855],{"class":58,"line":76},[56,856,820],{},[56,858,859],{"class":58,"line":89},[56,860,825],{},[56,862,863],{"class":58,"line":100},[56,864,830],{},[56,866,867],{"class":58,"line":111},[56,868,835],{},[56,870,871],{"class":58,"line":121},[56,872,840],{},[56,874,875],{"class":58,"line":139},[56,876,877],{},"tup[0]['blog'] = \"It's Ray, not Array - Ray Blog\"\n",[17,879,880],{},"The only time you'll hit an error is if you try to point that slot at a brand-new dict:",[47,882,884],{"className":281,"code":883,"language":283,"meta":52,"style":52},"tup = ({\n  'myName1': 'Ray1'\n},{\n  'myName2': 'Ray2'\n})\ntup[0]['myName1'] = 'QQ'\ntup[0]['blog'] = \"It's Ray, not Array - Ray Blog\"\ntup[0] = {} # TypeError: 'tuple' object does not support item assignment\n",[28,885,886,890,894,898,902,906,910,914],{"__ignoreMap":52},[56,887,888],{"class":58,"line":59},[56,889,815],{},[56,891,892],{"class":58,"line":76},[56,893,820],{},[56,895,896],{"class":58,"line":89},[56,897,825],{},[56,899,900],{"class":58,"line":100},[56,901,830],{},[56,903,904],{"class":58,"line":111},[56,905,835],{},[56,907,908],{"class":58,"line":121},[56,909,840],{},[56,911,912],{"class":58,"line":139},[56,913,877],{},[56,915,916],{"class":58,"line":145},[56,917,918],{},"tup[0] = {} # TypeError: 'tuple' object does not support item assignment\n",[17,920,921,922,925],{},"This is really similar to the idea behind ",[28,923,924],{},"const obj = {};"," in JavaScript — you can mutate the object's contents, you just can't reassign the binding.",[12,927,929],{"id":928},"the-in-operator","The in Operator",[17,931,932,933,936,937,940],{},"To wrap up, let me throw in a quick note about the ",[28,934,935],{},"in"," operator. The idea here is basically the same as JavaScript's ",[28,938,939],{},"Object.hasOwnProperty"," method, which checks whether a given property exists on an object:",[47,942,944],{"className":49,"code":943,"language":51,"meta":52,"style":52},"var obj = {\n  myName: 'Ray',\n}\nobj.hasOwnProperty('myName'); \u002F\u002F true\n",[28,945,946,956,964,968],{"__ignoreMap":52},[56,947,948,950,952,954],{"class":58,"line":59},[56,949,63],{"class":62},[56,951,67],{"class":66},[56,953,70],{"class":62},[56,955,73],{"class":66},[56,957,958,960,962],{"class":58,"line":76},[56,959,79],{"class":66},[56,961,83],{"class":82},[56,963,86],{"class":66},[56,965,966],{"class":58,"line":89},[56,967,310],{"class":66},[56,969,970,973,976,978,981,984],{"class":58,"line":100},[56,971,972],{"class":66},"obj.",[56,974,975],{"class":114},"hasOwnProperty",[56,977,130],{"class":66},[56,979,980],{"class":82},"'myName'",[56,982,983],{"class":66},"); ",[56,985,986],{"class":175},"\u002F\u002F true\n",[17,988,989,990,992,993,996,997,1000],{},"Python's ",[28,991,935],{}," operator does the same job — if the property exists it returns ",[28,994,995],{},"True",", and if it doesn't it returns ",[28,998,999],{},"False",". The one thing to watch is the word order: the property comes first, the dict comes second:",[47,1002,1004],{"className":281,"code":1003,"language":283,"meta":52,"style":52},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint('myName' in dis) # True\n",[28,1005,1006,1010,1014,1018,1022,1026,1030],{"__ignoreMap":52},[56,1007,1008],{"class":58,"line":59},[56,1009,290],{},[56,1011,1012],{"class":58,"line":76},[56,1013,295],{},[56,1015,1016],{"class":58,"line":89},[56,1017,300],{},[56,1019,1020],{"class":58,"line":100},[56,1021,305],{},[56,1023,1024],{"class":58,"line":111},[56,1025,310],{},[56,1027,1028],{"class":58,"line":121},[56,1029,155],{"emptyLinePlaceholder":154},[56,1031,1032],{"class":58,"line":139},[56,1033,1034],{},"print('myName' in dis) # True\n",[17,1036,1037,1038,1041,1042,1045],{},"Just by reading the code you can clearly tell what it's saying: \"is the string ",[28,1039,1040],{},"myName"," in the ",[28,1043,1044],{},"dis"," dict?\"",[17,1047,1048,1049,1051],{},"As an aside, JavaScript actually has an ",[28,1050,935],{}," operator too — I just rarely use it:",[47,1053,1055],{"className":49,"code":1054,"language":51,"meta":52,"style":52},"var obj = {\n  myName: 'Ray',\n}\n\nconsole.log('myName' in obj); \u002F\u002F true\n",[28,1056,1057,1067,1075,1079,1083],{"__ignoreMap":52},[56,1058,1059,1061,1063,1065],{"class":58,"line":59},[56,1060,63],{"class":62},[56,1062,67],{"class":66},[56,1064,70],{"class":62},[56,1066,73],{"class":66},[56,1068,1069,1071,1073],{"class":58,"line":76},[56,1070,79],{"class":66},[56,1072,83],{"class":82},[56,1074,86],{"class":66},[56,1076,1077],{"class":58,"line":89},[56,1078,310],{"class":66},[56,1080,1081],{"class":58,"line":100},[56,1082,155],{"emptyLinePlaceholder":154},[56,1084,1085,1087,1089,1091,1093,1096,1099],{"class":58,"line":111},[56,1086,161],{"class":66},[56,1088,127],{"class":114},[56,1090,130],{"class":66},[56,1092,980],{"class":82},[56,1094,1095],{"class":62}," in",[56,1097,1098],{"class":66}," obj); ",[56,1100,986],{"class":175},[12,1102,1104],{"id":1103},"a-note-from-the-author","A Note From the Author",[17,1106,1107],{},"These past few days I pretty much finished off my bottle of huadiao wine, but then I had a brain-dead moment wandering around the supermarket and accidentally grabbed a bottle of shaoxing wine on the way out... looks like it's time to start down the drunken chicken road again.",[12,1109,1111],{"id":1110},"about-the-bunnies","About the Bunnies",[1113,1114,1115,1125,1133,1141],"ul",{},[1116,1117,1118],"li",{},[1119,1120,1124],"a",{"href":1121,"rel":1122},"https:\u002F\u002Ftailwindcss.tw",[1123],"nofollow","Tailwind CSS Taiwan Official Site",[1116,1126,1127,1132],{},[1119,1128,1131],{"href":1129,"rel":1130},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[1123],"Tailwind CSS Taiwan"," (Facebook page)",[1116,1134,1135,1140],{},[1119,1136,1139],{"href":1137,"rel":1138},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[1123],"Bunny Cult × Tailwind CSS Taiwan"," (Facebook group)",[1116,1142,1143],{},[1119,1144,1147],{"href":1145,"rel":1146},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[1123],"Bunny Cult HQ",[17,1149,1150],{},[382,1151],{"alt":1152,"src":1153},"Bunny power knows no bounds","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[1155,1156,1157],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":52,"searchDepth":76,"depth":76,"links":1159},[1160,1161,1162,1165,1166,1167],{"id":14,"depth":7