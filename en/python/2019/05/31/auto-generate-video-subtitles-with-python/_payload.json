[{"data":1,"prerenderedAt":387},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fpython\u002F2019\u002F05\u002F31\u002Fauto-generate-video-subtitles-with-python\u002F":3,"page:\u002Fen\u002Fpython\u002F2019\u002F05\u002F31\u002Fauto-generate-video-subtitles-with-python\u002F":4,"alt:\u002Fen\u002Fpython\u002F2019\u002F05\u002F31\u002Fauto-generate-video-subtitles-with-python\u002F":3,"prev-next:\u002Fen\u002Fpython\u002F2019\u002F05\u002F31\u002Fauto-generate-video-subtitles-with-python\u002F":363,"related:\u002Fen\u002Fpython\u002F2019\u002F05\u002F31\u002Fauto-generate-video-subtitles-with-python\u002F":372},"\u002Fpython\u002F20190531\u002F4077454772\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":73,"date":346,"description":347,"extension":348,"lang":349,"meta":350,"navigation":351,"path":352,"readingMinutes":353,"seo":354,"standalone":355,"stem":356,"tags":357,"tldr":360,"updated":346,"url":361,"__hash__":362},"content\u002Fen\u002FPython\u002Fauto-generate-video-subtitles-with-python.md","Auto-Generating Video Subtitles (.srt) With Python","5102020306",{"type":9,"value":10,"toc":338},"minimark",[11,16,20,23,27,30,58,62,68,75,81,98,101,107,110,119,125,128,137,143,146,155,161,172,181,188,194,197,202,206,212,222,228,231,237,241,244,253,259,266,271,274,283,286,295,298,307,310,316,320,327,334],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Subtitling a video is painful — you have to keep replaying to catch the timing. If a tool can auto-generate 50% of the subtitle blocks for you, the rest is easy cleanup. Notes on how to set it up.",[17,21,22],{},"Note: this uses Google Translate for speech recognition, so the translation can come out a bit funny. Quality depends on how clearly the speaker enunciates.",[12,24,26],{"id":25},"tools","Tools",[17,28,29],{},"This is a bit involved on Windows. You'll need:",[31,32,33,44,51],"ul",{},[34,35,36,37],"li",{},"Python 2.7.12 ",[38,39,43],"a",{"href":40,"rel":41},"https:\u002F\u002Fwww.python.org\u002Fftp\u002Fpython\u002F2.7.12\u002Fpython-2.7.12.msi",[42],"nofollow","Download",[34,45,46,47],{},"ffmpeg ",[38,48,43],{"href":49,"rel":50},"https:\u002F\u002Fsourceforge.net\u002Fprojects\u002Fffmpegwindowsbi\u002Ffiles\u002F?source=navbar",[42],[34,52,53,54],{},"autosub ",[38,55,43],{"href":56,"rel":57},"https:\u002F\u002Fgithub.com\u002Fagermanidis\u002Fautosub\u002Ffiles\u002F1177869\u002Fautosub_app.0.3.12.zip",[42],[12,59,61],{"id":60},"steps","Steps",[63,64,65],"ol",{},[34,66,67],{},"Install Python 2.7.12 (I already have it, skipping).",[17,69,70],{},[71,72],"img",{"alt":73,"src":74},"Python","https:\u002F\u002Fi.imgur.com\u002FmmcIY0m.png",[63,76,78],{"start":77},2,[34,79,80],{},"Open CMD (or PowerShell, which I use) and run:",[82,83,88],"pre",{"className":84,"code":85,"language":86,"meta":87,"style":87},"language-cmd shiki shiki-themes github-dark-high-contrast","C:\\Python27\\Scripts\\pip.exe install autosub\n","cmd","",[89,90,91],"code",{"__ignoreMap":87},[92,93,96],"span",{"class":94,"line":95},"line",1,[92,97,85],{},[17,99,100],{},"This takes a while — go make tea.",[17,102,103],{},[71,104],{"alt":105,"src":106},"Installing","https:\u002F\u002Fi.imgur.com\u002F2ElD6PH.png",[17,108,109],{},"If you don't want the above, you can install directly from the tarball:",[82,111,113],{"className":84,"code":112,"language":86,"meta":87,"style":87},"C:\\Python27\\Scripts\\pip.exe install https:\u002F\u002Fpypi.python.org\u002Fpackages\u002F35\u002F7b\u002F9d5361c0f7abfcc6d826a5279b1c4501f7616505629f6c54857587ec6e37\u002Fautosub-0.3.9.tar.gz\n",[89,114,115],{"__ignoreMap":87},[92,116,117],{"class":94,"line":95},[92,118,112],{},[63,120,122],{"start":121},3,[34,123,124],{},"After installing, rename the installed package (important!):",[17,126,127],{},"CMD:",[82,129,131],{"className":84,"code":130,"language":86,"meta":87,"style":87},"Rename C:\\Python27\\Scripts\\autosub autosub_app.py\n",[89,132,133],{"__ignoreMap":87},[92,134,135],{"class":94,"line":95},[92,136,130],{},[17,138,139],{},[71,140],{"alt":141,"src":142},"CMD rename","https:\u002F\u002Fi.imgur.com\u002FdSLs4J5.png",[17,144,145],{},"PowerShell:",[82,147,149],{"className":84,"code":148,"language":86,"meta":87,"style":87},"Rename-Item C:\\Python27\\Scripts\\autosub.py autosub_app.py\n",[89,150,151],{"__ignoreMap":87},[92,152,153],{"class":94,"line":95},[92,154,148],{},[17,156,157],{},[71,158],{"alt":159,"src":160},"PowerShell rename","https:\u002F\u002Fi.imgur.com\u002FSc2Y8ab.png",[17,162,163,164,167,168,171],{},"If you're not sure it worked, check ",[89,165,166],{},"C:\\Python27\\Scripts"," for ",[89,169,170],{},"autosub_app.py",".",[63,173,175],{"start":174},4,[34,176,177,178,171],{},"Extract the ffmpeg zip and copy ",[89,179,180],{},"ffmpeg.exe",[17,182,183,184,187],{},"(Path: ",[89,185,186],{},"ffmpeg-4.1.3-win64-static\\bin",")",[17,189,190],{},[71,191],{"alt":192,"src":193},"ffmpeg","https:\u002F\u002Fi.imgur.com\u002FeycQA95.png",[17,195,196],{},"Paste into your Python folder.",[17,198,199],{},[71,200],{"alt":192,"src":201},"https:\u002F\u002Fi.imgur.com\u002FiYFAa4V.png",[12,203,205],{"id":204},"patching-autosub-source","Patching autosub source",[17,207,208,209,211],{},"You need to patch ",[89,210,170],{}," or it won't run.",[17,213,214,215,218,219,171],{},"Around line 48, change ",[89,216,217],{},"temp = tempfile.NamedTemporaryFile(suffix='.flac')"," to ",[89,220,221],{},"temp = tempfile.NamedTemporaryFile(suffix='.flac', delete=False)",[17,223,224],{},[71,225],{"alt":226,"src":227},"autosub_app patch","https:\u002F\u002Fi.imgur.com\u002FtA8Wkgo.png",[17,229,230],{},"Also — this one's critical — comment out lines 138–140 or it won't compile.",[17,232,233],{},[71,234],{"alt":235,"src":236},"Important patch","https:\u002F\u002Fi.imgur.com\u002F8GYdlLE.png",[12,238,240],{"id":239},"ai-auto-subtitling","AI auto-subtitling",[17,242,243],{},"Final step — try this in your terminal:",[82,245,247],{"className":84,"code":246,"language":86,"meta":87,"style":87},