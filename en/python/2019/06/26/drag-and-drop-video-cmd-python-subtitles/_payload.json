ntrast","@echo off \u002F\u002F turn on output\necho Without extension: %~n1\necho With extension: %~nx1\necho Absolute path: %1\necho Short-name absolute path: %~s1\necho Drive and path: %~dp1\necho Drive: %~d1\necho Path: %~p1\necho File attributes: %~a1\necho Date\u002FTime: %~t1\necho File size: %~z1\npause \u002F\u002F press any key to close the window\n","cmd","",[27,52,53,61,67,73,79,85,91,97,103,109,115,121],{"__ignoreMap":50},[54,55,58],"span",{"class":56,"line":57},"line",1,[54,59,60],{},"@echo off \u002F\u002F turn on output\n",[54,62,64],{"class":56,"line":63},2,[54,65,66],{},"echo Without extension: %~n1\n",[54,68,70],{"class":56,"line":69},3,[54,71,72],{},"echo With extension: %~nx1\n",[54,74,76],{"class":56,"line":75},4,[54,77,78],{},"echo Absolute path: %1\n",[54,80,82],{"class":56,"line":81},5,[54,83,84],{},"echo Short-name absolute path: %~s1\n",[54,86,88],{"class":56,"line":87},6,[54,89,90],{},"echo Drive and path: %~dp1\n",[54,92,94],{"class":56,"line":93},7,[54,95,96],{},"echo Drive: %~d1\n",[54,98,100],{"class":56,"line":99},8,[54,101,102],{},"echo Path: %~p1\n",[54,104,106],{"class":56,"line":105},9,[54,107,108],{},"echo File attributes: %~a1\n",[54,110,112],{"class":56,"line":111},10,[54,113,114],{},"echo Date\u002FTime: %~t1\n",[54,116,118],{"class":56,"line":117},11,[54,119,120],{},"echo File size: %~z1\n",[54,122,124],{"class":56,"line":123},12,[54,125,126],{},"pause \u002F\u002F press any key to close the window\n",[17,128,129],{},[130,131],"img",{"alt":132,"src":133},"CMD basics","https:\u002F\u002Fi.imgur.com\u002FEfL2iO4.png",[17,135,136,137],{},"Source: ",[21,138,142],{"href":139,"rel":140},"https:\u002F\u002Fcodertw.com\u002F%E5%89%8D%E7%AB%AF%E9%96%8B%E7%99%BC\u002F388796\u002F",[141],"nofollow","Getting file info via drag and drop bat code (in Chinese)",[12,144,146],{"id":145},"python-autosub-command","Python autosub command",[17,148,149],{},"The original command was:",[45,151,153],{"className":47,"code":152,"language":49,"meta":50,"style":50},"C:\\Python27\\python.exe C:\\Python27\\scripts\\autosub_app.py -S zh-TW -D zh-TW [video-path]\n",[27,154,155],{"__ignoreMap":50},[54,156,157],{"class":56,"line":57},[54,158,152],{},[17,160,161,162,165],{},"Create a file called ",[27,163,164],{},"autosub.bat",".",[17,167,168,169,172,173,176],{},"At the end, replace the video path with ",[27,170,171],{},"%1",".\n(Don't use ",[27,174,175],{},"%~s1"," — that'll error.)",[17,178,179],{},[130,180],{"alt":181,"src":182},"Python autosub","https:\u002F\u002Fi.imgur.com\u002FLpbbax6.png",[17,184,185,186,188],{},"Now you can drag a video onto ",[27,187,164],{}," and it'll auto-generate subtitles.",[17,190,191],{},[130,192],{"alt":164,"src":193},"https:\u002F\u002Fi.imgur.com\u002FaqAY1fj.png",[17,195,196,197,199],{},"Here's a slightly nicer version of the ",[27,198,29],{},":",[45,201,203],{"className":47,"code":202,"language":49,"meta":50,"style":50},"@echo off\necho Preparing to generate subtitles...\necho Video file: %~nx1\nC:\\Python27\\python.exe C:\\Python27\\scripts\\autosub_app.py -S zh-TW -D zh-TW %1\necho Output path: %~p1\npause\n",[27,204,205,210,215,220,225,230],{"__ignoreMap":50},[54,206,207],{"class":56,"line":57},[54,208,209],{},"@echo off\n",[54,211,212],{"class":56,"line":63},[54,213,214],{},"echo Preparing to generate subtitles...\n",[54,216,217],{"class":56,"line":69},[54,218,219],{},"echo Video file: %~nx1\n",[54,221,222],{"class":56,"line":75},[54,223,224],{},"C:\\Python27\\python.exe C:\\Python27\\scripts\\autosub_app.py -S zh-TW -D zh-TW %1\n",[54,226,227],{"class":56,"line":81},[54,228,229],{},"echo Output path: %~p1\n",[54,231,232],{"class":56,"line":87},[54,233,234],{},"pause\n",[17,236,237],{},"Result looks like this — more informative:",[17,239,240],{},[130,241],{"alt":242,"src":243},"CMD output","https:\u002F\u002Fi.imgur.com\u002FlM41Cn2.png",[17,245,246,247,165],{},"To auto-close the window after generation, remove ",[27,248,249],{},"pause",[251,252,253],"style",{},"html .default .s