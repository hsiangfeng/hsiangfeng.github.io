unch_runtime=\"nodejs\"\n\nCOPY --from=builder \u002Froot\u002F.volta \u002Froot\u002F.volta\nCOPY --from=builder \u002Fapp \u002Fapp\n\nWORKDIR \u002Fapp\nENV NODE_ENV production\nENV PATH \u002Froot\u002F.volta\u002Fbin:$PATH\n\nCMD [ \"npm\", \"run\", \"start\" ]\n","dockerfile","",[35,36,37,45,52,58,63,69,75,81,87,93,98,104,110,115,121,126,132,137,143,149,154,160,165,171,177,182,187,192,197,202],"code",{"__ignoreMap":33},[38,39,42],"span",{"class":40,"line":41},"line",1,[38,43,44],{},"FROM debian:bullseye as builder\n",[38,46,48],{"class":40,"line":47},2,[38,49,51],{"emptyLinePlaceholder":50},true,"\n",[38,53,55],{"class":40,"line":54},3,[38,56,57],{},"ARG NODE_VERSION=16.15.0\n",[38,59,61],{"class":40,"line":60},4,[38,62,51],{"emptyLinePlaceholder":50},[38,64,66],{"class":40,"line":65},5,[38,67,68],{},"RUN apt-get update; apt install -y curl\n",[38,70,72],{"class":40,"line":71},6,[38,73,74],{},"RUN curl https:\u002F\u002Fget.volta.sh | bash\n",[38,76,78],{"class":40,"line":77},7,[38,79,80],{},"ENV VOLTA_HOME \u002Froot\u002F.volta\n",[38,82,84],{"class":40,"line":83},8,[38,85,86],{},"ENV PATH \u002Froot\u002F.volta\u002Fbin:$PATH\n",[38,88,90],{"class":40,"line":89},9,[38,91,92],{},"RUN volta install node@${NODE_VERSION}\n",[38,94,96],{"class":40,"line":95},10,[38,97,51],{"emptyLinePlaceholder":50},[38,99,101],{"class":40,"line":100},11,[38,102,103],{},"RUN mkdir \u002Fapp\n",[38,105,107],{"class":40,"line":106},12,[38,108,109],{},"WORKDIR \u002Fapp\n",[38,111,113],{"class":40,"line":112},13,[38,114,51],{"emptyLinePlaceholder":50},[38,116,118],{"class":40,"line":117},14,[38,119,120],{},"ENV NODE_ENV production\n",[38,122,124],{"class":40,"line":123},15,[38,125,51],{"emptyLinePlaceholder":50},[38,127,129],{"class":40,"line":128},16,[38,130,131],{},"COPY . .\n",[38,133,135],{"class":40,"line":134},17,[38,136,51],{"emptyLinePlaceholder":50},[38,138,140],{"class":40,"line":139},18,[38,141,142],{},"RUN npm install\n",[38,144,146],{"class":40,"line":145},19,[38,147,148],{},"FROM debian:bullseye\n",[38,150,152],{"class":40,"line":151},20,[38,153,51],{"emptyLinePlaceholder":50},[38,155,157],{"class":40,"line":156},21,[38,158,159],{},"LABEL fly_launch_runtime=\"nodejs\"\n",[38,161,163],{"class":40,"line":162},22,[38,164,51],{"emptyLinePlaceholder":50},[38,166,168],{"class":40,"line":167},23,[38,169,170],{},"COPY --from=builder \u002Froot\u002F.volta \u002Froot\u002F.volta\n",[38,172,174],{"class":40,"line":173},24,[38,175,176],{},"COPY --from=builder \u002Fapp \u002Fapp\n",[38,178,180],{"class":40,"line":179},25,[38,181,51],{"emptyLinePlaceholder":50},[38,183,185],{"class":40,"line":184},26,[38,186,109],{},[38,188,190],{"class":40,"line":189},27,[38,191,120],{},[38,193,195],{"class":40,"line":194},28,[38,196,86],{},[38,198,200],{"class":40,"line":199},29,[38,201,51],{"emptyLinePlaceholder":50},[38,203,205],{"class":40,"line":204},30,[38,206,207],{},"CMD [ \"npm\", \"run\", \"start\" ]\n",[17,209,210,211,218,219,223],{},"This is taken from an open-source project of mine, ",[212,213,217],"a",{"href":214,"rel":215},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione",[216],"nofollow","Hermione",". If you're curious about the project, check out ",[212,220,222],{"href":221},"\u002Fnodejs\u002F20221215\u002F2411869749\u002F","Building a Discord bot with OpenAI GPT-3 (article in Mandarin)",".",[17,225,226,227,231],{},"Anyway, back to the exercise. Your task is to add comments to each instruction describing what it does. The full answer is below — try it yourself first. Some of the commands here weren't covered in the previous post, and this Dockerfile was auto-generated by ",[212,228,230],{"href":229},"\u002Fother\u002F20221216\u002F786812101\u002F","fly.io (article in Mandarin)",", so don't sweat the parts you don't recognise.",[17,233,234],{},"Ready? Have a crack at it.",[17,236,237],{},"The answer key is below.",[12,239,241],{"id":240},"answer-key","Answer key",[28,243,245],{"className":30,"code":244,"language":32,"meta":33,"style":33},"# Use Debian Bullseye as the base, naming this stage \"builder\"\nFROM debian:bullseye as builder\n\n# Define a Docker variable NODE_VERSION set to 16.15.0\nARG NODE_VERSION=16.15.0\n\n# Update packages and install CURL\nRUN apt-get update; apt install -y curl\n\n# Download the Volta install script via CURL\nRUN curl https:\u002F\u002Fget.volta.sh | bash\n\n# Set env var VOLTA_HOME to \u002Froot\u002F.volta\nENV VOLTA_HOME \u002Froot\u002F.volta\n\n# Set env var PATH to \u002Froot\u002F.volta\u002Fbin:$PATH\nENV PATH \u002Froot\u002F.volta\u002Fbin:$PATH\n\n# Install Node.js 16.15.0 via Volta\nRUN volta install node@${NODE_VERSION}\n\n# Create a \u002Fapp directory\nRUN mkdir \u002Fapp\n\n# Set working directory to \u002Fapp\nWORKDIR \u002Fapp\n\n# Set env var NODE_ENV to production\nENV NODE_ENV production\n\n# Copy all files in the current directory into \u002Fapp\nCOPY . .\n\n# Run npm install\nRUN npm install\n\n# Use Debian Bullseye as the base (new stage)\nFROM debian:bullseye\n\n# Add a LABEL fly_launch_runtime set to \"nodejs\"\nLABEL fly_launch_runtime=\"nodejs\"\n\n# Copy \u002Froot\u002F.volta from the builder stage\nCOPY --from=builder \u002Froot\u002F.volta \u002Froot\u002F.volta\n\n# Copy \u002Fapp from the builder stage\nCOPY --from=builder \u002Fapp \u002Fapp\n\n# Set working directory to \u002Fapp\nWORKDIR \u002Fapp\n\n# Set env var NODE_ENV to production\nENV NODE_ENV production\n\n# Set env var PATH to \u002Froot\u002F.volta\u002Fbin:$PATH\nENV PATH \u002Froot\u002F.volta\u002Fbin:$PATH\n\n# Run npm run start\nCMD [ \"npm\", \"run\", \"start\" ]\n",[35,246,247,252,256,260,265,269,273,278,282,286,291,295,299,304,308,312,317,321,325,330,334,338,343,347,351,356,360,364,369,373,377,383,388,393,399,404,409,415,420,425,431,436,441,447,452,457,463,468,473,478,483,488,493,498,503,508,513,518,524],{"__ignoreMap":33},[38,248,249],{"class":40,"line":41},[38,250,251],{},"# Use Debian Bullseye as the base, naming this stage \"builder\"\n",[38,253,25