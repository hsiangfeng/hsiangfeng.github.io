],{"class":157}," tag",[147,298,204],{"class":161},[147,300,301],{"class":157},"ID]",[147,303,304],{"class":161}," [TAG]\n",[17,306,307,308,310,311,214],{},"To tag the Image ",[44,309,213],{}," as ",[44,312,313],{},"v1.0.0",[138,315,317],{"className":140,"code":316,"language":142,"meta":143,"style":143},"docker tag 58bfbd37b174 docker-express-example:v1.0.0\n",[44,318,319],{"__ignoreMap":143},[147,320,321,323,325,328],{"class":149,"line":150},[147,322,154],{"class":153},[147,324,296],{"class":157},[147,326,327],{"class":157}," 58bfbd37b174",[147,329,330],{"class":157}," docker-express-example:v1.0.0\n",[12,332,334],{"id":333},"docker-save","docker save",[17,336,337],{},"Saves an Image to a file. Signature:",[138,339,341],{"className":140,"code":340,"language":142,"meta":143,"style":143},"docker save [IMAGE ID] > [FILE NAME]\n",[44,342,343],{"__ignoreMap":143},[147,344,345,347,350,352,354,357,360],{"class":149,"line":150},[147,346,154],{"class":153},[147,348,349],{"class":157}," save",[147,351,204],{"class":161},[147,353,301],{"class":157},[147,355,356],{"class":165}," >",[147,358,359],{"class":161}," [FILE ",[147,361,362],{"class":157},"NAME]\n",[17,364,365,366,368,369,214],{},"To save Image ",[44,367,213],{}," to ",[44,370,371],{},"docker-express-example.tar",[138,373,375],{"className":140,"code":374,"language":142,"meta":143,"style":143},"docker save 58bfbd37b174 > docker-express-example.tar\n",[44,376,377],{"__ignoreMap":143},[147,378,379,381,383,385,387],{"class":149,"line":150},[147,380,154],{"class":153},[147,382,349],{"class":157},[147,384,327],{"class":157},[147,386,356],{"class":165},[147,388,389],{"class":157}," docker-express-example.tar\n",[17,391,392],{},"The output file ends up in your current directory.",[12,394,396],{"id":395},"docker-load","docker load",[17,398,399],{},"Restores an Image from a file. Signature:",[138,401,403],{"className":140,"code":402,"language":142,"meta":143,"style":143},"docker load \u003C [FILE NAME]\n",[44,404,405],{"__ignore