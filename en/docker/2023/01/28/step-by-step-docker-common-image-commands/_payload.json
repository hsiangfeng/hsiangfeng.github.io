{},"Log in to Docker Hub",[33,53,55,42,57,60],{"className":54},[36],[38,56],{"checked":40,"disabled":40,"type":41},[44,58,59],{},"docker logout",[28,61,62],{},[33,63,64],{},"Log out of Docker Hub",[33,66,68,42,70,73],{"className":67},[36],[38,69],{"checked":40,"disabled":40,"type":41},[44,71,72],{},"docker search",[28,74,75],{},[33,76,77],{},"Search for Images on Docker Hub",[33,79,81,42,83,86],{"className":80},[36],[38,82],{"checked":40,"disabled":40,"type":41},[44,84,85],{},"docker pull",[28,87,88],{},[33,89,90],{},"Pull an Image from Docker Hub",[33,92,94,42,96,99],{"className":93},[36],[38,95],{"checked":40,"disabled":40,"type":41},[44,97,98],{},"docker push",[28,100,101],{},[33,102,103],{},"Push an Image to Docker Hub",[17,105,106,107,109,110,112,113,115,116,118,119,121],{},"Of these, ",[44,108,72],{},", ",[44,111,85],{},", and ",[44,114,98],{}," are Image-related. ",[44,117,46],{}," and ",[44,120,59],{}," are Docker Hub-related.",[17,123,124,125,128],{},"Last post also used ",[44,126,127],{},"docker build"," to package an Image, which is also an Image command.",[12,130,127],{"id":131},"docker-build",[17,133,134,136],{},[44,135,127],{}," builds a Docker Image. Signature:",[138,139,144],"pre",{"className":140,"code":141,"language":142,"meta":143,"style":143},"language-bash shiki shiki-themes github-dark-high-contrast","docker build [OPTIONS] PATH | URL | -\n","bash","",[44,145,146],{"__ignoreMap":143},[147,148,151,155,159,163,167,170,173],"span",{"class":149,"line":150},"line",1,[147,152,154],{"class":153},"s_sBn","docker",[147,156,158],{"class":157},"sTRMh"," build",[147,160,162],{"class":161},"sMAXC"," [OPTIONS] PATH ",[147,164,166],{"class":165},"sWyjQ","|",[147,168,169],{"class":153}," URL",[147,171,172],{"class":165}," |",[147,174,175],{"class":153}," -\n",[17,177,178],{},"We already used this last post, so I'll skip the deep dive.",[12,180,182],{"id":181},"docker-rmi","docker rmi",[17,184,185,186,189],{},"Similar to ",[44,187,188],{},"docker rm",", but for