{},"Log in to Docker Hub",[33,53,55,42,57,60],{"className":54},[36],[38,56],{"checked":40,"disabled":40,"type":41},[44,58,59],{},"docker logout",[28,61,62],{},[33,63,64],{},"Log out of Docker Hub",[33,66,68,42,70,73],{"className":67},[36],[38,69],{"checked":40,"disabled":40,"type":41},[44,71,72],{},"docker search",[28,74,75],{},[33,76,77],{},"Search for Images on Docker Hub",[33,79,81,42,83,86],{"className":80},[36],[38,82],{"checked":40,"disabled":40,"type":41},[44,84,85],{},"docker pull",[28,87,88],{},[33,89,90],{},"Pull an Image from Docker Hub",[33,92,94,42,96,99],{"className":93},[36],[38,95],{"checked":40,"disabled":40,"type":41},[44,97,98],{},"docker push",[28,100,101],{},[33,102,103],{},"Push an Image to Docker Hub",[17,105,106,107,109,110,112,113,115,116,118,119,121],{},"Of these, ",[44,108,72],{},", ",[44,111,85],{},", and ",[44,114,98],{}," are Image-related. ",[44,117,46],{}," and ",[44,120,59],{}," are Docker Hub-related.",[17,123,124,125,128],{},"Last post also used ",[44,126,127],{},"docker build"," to package an Image, which is also an Image command.",[12,130,127],{"id":131},"docker-build",[17,133,134,136],{},[44,135,127],{}," builds a Docker Image. Signature:",[138,139,144],"pre",{"className":140,"code":141,"language":142,"meta":143,"style":143},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","docker build [OPTIONS] PATH | URL | -\n","bash","",[44,145,146],{"__ignoreMap":143},[147,148,151,155,159,163,167,170,173],"span",{"class":149,"line":150},"line",1,[147,152,154],{"class":153},"smYoP","docker",[147,156,158],{"class":157},"sWayO"," build",[147,160,162],{"class":161},"s8XSl"," [OPTIONS] PATH ",[147,164,166],{"class":165},"sOudu","|",[147,168,169],{"class":153}," URL",[147,171,172],{"class":165}," |",[147,174,175],{"class":153}," -\n",[17,177,178],{},"We already used this last post, so I'll skip the deep dive.",[12,180,182],{"id":181},"docker-rmi","docker rmi",[17,184,185,186,189],{},"Similar to ",[44,187,188],{},"docker rm",", but for Images. Signature:",[138,191,193],{"className":140,"code":192,"language":142,"meta":143,"style":143},"docker rmi [IMAGE ID]\n",[44,194,195],{"__ignoreMap":143},[147,196,197,199,202,205],{"class":149,"line":150},[147,198,154],{"class":153},[147,200,201],{"class":157}," rmi",[147,203,204],{"class":161}," [IMAGE ",[147,206,207],{"class":157},"ID]\n",[17,209,210,211,214],{},"To delete the Image with ID ",[44,212,213],{},"58bfbd37b174",":",[138,216,218],{"className":140,"code":217,"language":142,"meta":143,"style":143},"docker rmi 58bfbd37b174\n",[44,219,220],{"__ignoreMap":143},[147,221,222,224,226],{"class":149,"line":150},[147,223,154],{"class":153},[147,225,201],{"class":157},[147,227,228],{"class":157}," 58bfbd37b174\n",[230,231,234],"callout",{"title":232,"type":233},"Warning","warning",[17,235,236],{},"If the Image is in use by a Container, the delete fails.",[17,238,239],{},"You can also delete by Image name:",[138,241,243],{"className":140,"code":242,"language":142,"meta":143,"style":143},"docker rmi docker-express-example\n",[44,244,245],{"__ignoreMap":143},[147,246,247,249,251],{"class":149,"line":150},[147,248,154],{"class":153},[147,250,201],{"class":157},[147,252,253],{"class":157}," docker-express-example\n",[12,255,257],{"id":256},"docker-images","docker images",[17,259,260],{},"Lists Images on your machine. Signature:",[138,262,264],{"className":140,"code":263,"language":142,"meta":143,"style":143},"docker images\n",[44,265,266],{"__ignoreMap":143},[147,267,268,270],{"class":149,"line":150},[147,269,154],{"class":153},[147,271,272],{"class":157}," images\n",[17,274,275],{},"That's it — prints all Images on your machine.",[12,277,279],{"id":278},"docker-tag","docker tag",[17,281,282],{},"Tags an Image. Signature:",[138,284,286],{"className":140,"code":285,"language":142,"meta":143,"style":143},"docker tag [IMAGE ID] [TAG]\n",[44,287,288],{"__ignoreMap":143},[147,289,290,292,295,297,300],{"class":149,"line":150},[147,291,154],{"c