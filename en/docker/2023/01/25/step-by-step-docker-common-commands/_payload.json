[{"data":1,"prerenderedAt":756},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fdocker\u002F2023\u002F01\u002F25\u002Fstep-by-step-docker-common-commands\u002F":3,"page:\u002Fen\u002Fdocker\u002F2023\u002F01\u002F25\u002Fstep-by-step-docker-common-commands\u002F":4,"alt:\u002Fen\u002Fdocker\u002F2023\u002F01\u002F25\u002Fstep-by-step-docker-common-commands\u002F":3,"prev-next:\u002Fen\u002Fdocker\u002F2023\u002F01\u002F25\u002Fstep-by-step-docker-common-commands\u002F":732,"related:\u002Fen\u002Fdocker\u002F2023\u002F01\u002F25\u002Fstep-by-step-docker-common-commands\u002F":741},"\u002Fdocker\u002F20230125\u002F2499755737\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":713,"date":714,"description":715,"extension":716,"lang":717,"meta":718,"navigation":719,"path":720,"readingMinutes":721,"seo":722,"standalone":723,"stem":724,"tags":725,"tldr":728,"updated":729,"url":730,"__hash__":731},"content\u002Fen\u002FDocker\u002Fstep-by-step-docker-common-commands.md","(5) Step-by-Step Docker — Common Container Commands","9513622352",{"type":9,"value":10,"toc":705},"minimark",[11,16,20,24,27,80,83,86,91,124,135,147,154,172,183,190,193,198,219,225,228,233,248,269,278,284,299,302,336,353,369,372,393,403,417,420,432,435,445,450,461,475,480,500,503,512,523,528,534,537,542,560,563,576,579,584,600,606,619,622,625,691,698,701],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We covered some Docker and Docker Hub commands earlier. Now let's go through the most common Docker container commands.",[12,21,23],{"id":22},"common-docker-container-commands","Common Docker container commands",[17,25,26],{},"Last post covered Docker Hub commands. This post is about Docker itself — the core container commands. Here they are:",[28,29,30,38,44,50,56,62,68,74],"ul",{},[31,32,33,37],"li",{},[34,35,36],"code",{},"docker run"," — create \u002F run a Docker container",[31,39,40,43],{},[34,41,42],{},"docker start"," — start a Docker container",[31,45,46,49],{},[34,47,48],{},"docker stop"," — stop a Docker container",[31,51,52,55],{},[34,53,54],{},"docker rm"," — remove a Docker container",[31,57,58,61],{},[34,59,60],{},"docker restart"," — restart a Docker container",[31,63,64,67],{},[34,65,66],{},"docker ps"," — list Docker containers",[31,69,70,73],{},[34,71,72],{},"docker exec"," — exec into a Docker container",[31,75,76,79],{},[34,77,78],{},"docker logs"," — view a Docker container's logs",[17,81,82],{},"These are the ones you'll hit most. Let's walk through how to use them.",[12,84,36],{"id":85},"docker-run",[17,87,88,90],{},[34,89,36],{}," creates and runs a Docker container. The signature:",[92,93,98],"pre",{"className":94,"code":95,"language":96,"meta":97,"style":97},"language-bash shiki shiki-themes github-dark-high-contrast","docker run [OPTIONS] IMAGE[:TAG|@DIGEST] [COMMAND] [ARG...]\n","bash","",[34,99,100],{"__ignoreMap":97},[101,102,105,109,113,117,121],"span",{"class":103,"line":104},"line",1,[101,106,108],{"class":107},"s_sBn","docker",[101,110,112],{"class":111},"sTRMh"," run",[101,114,116],{"class":115},"sMAXC"," [OPTIONS] IMAGE[:TAG",[101,118,120],{"class":119},"sWyjQ","|",[101,122,123],{"class":115},"@DIGEST] [COMMAND] [ARG...]\n",[17,125,126,127,130,131,134],{},"This looks scary at first, but you really only need to focus on two things — ",[34,128,129],{},"[OPTIONS]"," and ",[34,132,133],{},"IMAGE[:TAG|@DIGEST]",":",[28,136,137,142],{},[31,138,139,141],{},[34,140,129],{}," — flags to customise the command",[31,143,144,146],{},[34,145,133],{}," — the Docker Image to use",[17,148,149,150,153],{},"Let's try it. Earlier we did ",[34,151,152],{},"docker pull node"," to download the Node.js Image. Now run:",[92,155,157],{"className":94,"code":156,"language":96,"meta":97,"style":97},"docker run -it node\n",[34,158,159],{"__ignoreMap":97},[101,160,161,163,165,169],{"class":103,"line":104},[101,162,108],{"class":107},[101,164,112],{"class":111},[101,166,168],{"class":167},"sCcAr"," -it",[101,170,171],{"class":111}," node\n",[17,173,174,175,178,179,182],{},"What's ",[34,176,177],{},"-it","? It means \"enter the container's interactive mode\". ",[34,180,181],{},"node"," is the Image. So this means \"run the Node.js container in interactive mode\". You'll see:",[17,184,185],{},[186,187],"img",{"alt":188,"src":189},"Node REPL","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002Fd7QmS1O.png",[17,191,192],{},"That's the familiar Node.js REPL.",[17,194,195,197],{},[34,196,177],{}," is actually two flags:",[28,199,200,210],{},[31,201,202,205,206,209],{},[34,203,204],{},"-i"," — ",[34,207,208],{},"interactive",", attach an interactive STDIN",[31,211,212,205,215,218],{},[34,213,214],{},"-t",[34,216,217],{},"tty",", allocate a pseudo-TTY",[17,220,221,222,224],{},"Usually you'll see ",[34,223,177],{}," written together.",[12,226,42],{"id":227},"docker-start",[17,229,230,232],{},[34,231,42],{}," starts an existing container. Signature:",[92,234,236],{"className":94,"code":235,"language":96,"meta":97,"style":97},"docker start [OPTIONS] CONTAINER [CONTAINER...]\n",[34,237,238],{"__ignoreMap":97},[101,239,240,242,245],{"class":103,"line":104},[101,241,108],{"class":107},[101,243,244],{"class":111}," start",[101,246,247],{"class":115}," [OPTIONS] CONTAINER [CONTAINER...]\n",[17,249,250,251,253,254,256,257,261,262,264,265,268],{},"Similar feel to ",[34,252,36],{},", but with a critical difference. ",[34,255,36],{}," ",[258,259,260],"strong",{},"creates and starts"," a container — so the right use for ",[34,263,42],{}," is ",[258,266,267],{},"starting a container that was previously stopped",".",[17,270,271,272,274,275,277],{},"What does that mean? When you ",[34,273,36],{},", Docker creates a new container based on the Image. If you keep using ",[34,276,36],{}," as your \"start\" command, you'll end up with a mess of containers that's hard to manage. So please distinguish between the two.",[17,279,280,281,283],{},"If you excitedly type the ",[34,282,36],{},"-style command:",[92,285,287],{"className":94,"code":286,"language":96,"meta":97,"style":97},"docker start -it node\n",[34,288,289],{"__ignoreMap":97},[101,290,291,293,295,297],{"class":103,"line":104},[101,292,108],{"class":107},[101,294,244],{"class":111},[101,296,168],{"class":167},[101,298,171],{"class":111},[17,300,301],{},"You get this error:",[92,303,305],{"className":94,"code":304,"language":96,"meta":97,"style":97},"unknown shorthand flag: 't' in -t\nSee 'docker start --help'.\n",[34,306,307,327],{"__ignoreMap":97},[101,308,309,312,315,318,321,324],{"class":103,"line":104},[101,310,311],{"class":107},"unknown",[101,313,314],{"class":111}," shorthand",[101,316,317],{"class":111}," flag:",[101,319,320],{"class":111}," 't'",[101,322,323],{"class":111}," in",[101,325,326],{"class":167}," -t\n",[101,328,330,333],{"class":103,"line":329},2,[101,331,332],{"class":107},"See",[101,334,335],{"class":111}," 'docker start --help'.\n",[17,337,338,339,341,342,205,344,346,347,349,350,352],{},"That's because ",[34,340,42],{}," doesn't support ",[34,343,214],{},[34,345,214],{}," is for ",[34,348,36],{},". So drop ",[34,351,214],{},". If you try:",[92,354,356],{"className":94,"code":355,"language":96,"meta":97,"style":97},"docker start -i node\n",[34,357,358],{"__ignoreMap":97},[101,359,360,362,364,367],{"class":103,"line":104},[101,361,108],{"class":107},[101,363,244],{"class":111},[101,365,366],{"class":167}," -i",[101,368,171],{"class":111},[17,370,371],{},"You'll get:",[92,373,375],{"className":94,"code":374,"language":96,"meta":97,"style":97},"Error: No such container: node\n",[34,376,377],{"__ignoreMap":97},[101,378,379,382,385,388,391],{"class":103,"line":104},[101,380,381],{"class":107},"Error:",[101,383,384],{"class":111}," No",[101,386,387],{"class":111}," such",[101,389,390],{"class":111}," container:",[101,392,171],{"class":111},[17,394,395,396,399,400,402],{},"You might be thinking — wait, didn't we just ",[34,397,398],{},"docker pull"," Node, and didn't we just run it? Why can't it find the ",[34,401,181],{}," container?",[17,404,405,406,409,410,412,413,416],{},"Because when you did ",[34,407,408],{},"docker run -it node",", Docker created a brand new container and dropped you into the Node REPL. That container's name is auto-generated and random. ",[34,411,42],{}," needs a container ",[258,414,415],{},"ID",", not an Image name.",[17,418,419],{},"So the principle:",[28,421,422,427],{},[31,423,424,426],{},[34,425,36],{}," — creates and starts. The argument is the Image name.",[31,428,429,431],{},[34,430,42],{}," — starts. The argument is the Container ID.",[17,433,434],{},"One is \"create a container\", one is \"start a container\". Don't mix them up.",[17,436,437,438,440,441,444],{},"How do you actually use ",[34,439,42],{},"? First, run ",[34,442,443],{},"docker ps -a"," to list all containers and find the ID you want to start.",[17,446,447],{},[186,448],{"alt":443,"src":449},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002F7MC8f5g.png",[17,451,452,453,456,457,460],{},"The ",[34,454,455],{},"CONTAINER ID"," column is what you want. Now start the container — note: the Node container will exit immediately after you ",[34,458,459],{},"docker start 00c86b3fe0ca"," because we're not in interactive mode. The correct command is:",[92,462,464],{"className":94,"code":463,"language":96,"meta":97,"style":97},"docker start 00c86b3fe0ca\n",[34,465,466],{"__ignoreMap":97},[101,467,468,470,472],{"class":103,"line":104},[101,469,108],{"class":107},[101,471,244],{"class":111},[101,473,474],{"class":111}," 00c86b3fe0ca\n",[17,476,477,478,134],{},"How do you enter the interactive mode? You need a command we haven't covered yet — ",[34,479,72],{},[92,481,483],{"className":94,"code":482,"language":96,"meta":97,"style":97},"docker exec -it 00c86b3fe0ca \u002Fbin\u002Fbash\n",[34,484,485],{"__ignoreMap":97},[101,486,487,489,492,494,497],{"class":103,"line":104},[101,488,108],{"class":107},[101,490,491],{"class":111}," exec",[101,493,168],{"class":167},[101,495,496],{"class":111}," 00c86b3fe0ca",[101,498,499],{"class":111}," \u002Fbin\u002Fbash\n",[17,501,502],{},"This drops you into an odd-looking prompt:",[92,504,506],{"className":94,"code":505,"language":96,"meta":97,"style":97},"root@00c86b3fe0ca:\u002F#\n",[34,507,508],{"__ignoreMap":97},[101,509,510],{"class":103,"line":104},[101,511,505],{"class":107},[17,513,514,515,518,519,522],{},"That's because you're inside the container, as root. You can run ",[34,516,517],{},"ls"," to see files, or ",[34,520,521],{},"exit"," to leave interactive mode.",[17,524,525,526,268],{},"Since we want to get back into the Node REPL, type ",[34,527,181],{},[17,529,530,531,533],{},"Don't worry about ",[34,532,72],{}," — we'll cover it in detail in a later post.",[12,535,48],{"id":536},"docker-stop",[17,538,539,541],{},[34,540,48],{}," stops a Docker container. Usage:",[92,543,545],{"className":94,"code":544,"language":96,"meta":97,"style":97},"docker stop [CONTAINER ID]\n",[34,546,547],{"__ignoreMap":97},[101,548,549,551,554,557],{"class":103,"line":104},[101,550,108],{"class":107},[101,552,553],{"class":111}," stop",[101,555,556],{"class":115}," [CONTAINER ",[101,558,559],{"class":111},"ID]\n",[17,561,562],{},"For the Node example:",[92,564,566],{"className":94,"code":565,"language":96,"meta":97,"style":97},"docker stop 00c86b3fe0ca\n",[34,567,568],{"__ignoreMap":97},[101,569,570,572,574],{"class":103,"line":104},[101,571,108],{"class":107},[101,573,553],{"class":111},[101,575,474],{"class":111},[12,577,54],{"id":578},"docker-rm",[17,580,581,583],{},[34,582,54],{}," deletes a Docker container. Usage:",[92,585,587],{"className":94,"code":586,"language":96,"meta":97,"style":97},"docker rm [CONTAINER ID]\n",[34,588,589],{"__ignoreMap":97},[101,590,591,593,596,598],{"class":103,"line":104},[101,592,108],{"class":107},[101,594,595],{"class":111}," rm",[101,597,556],{"class":115},[101,599,559],{"class":111},[17,601,602,603,605],{},"It removes containers created by ",[34,604,36],{},". For our Node example:",[92,607,609],{"className":94,"code":608,"language":96,"meta":97,"style":97},"docker rm 00c86b3fe0ca\n",[34,610,611],{"__ignoreMap":97},[101,612,613,615,617],{"class":103,"line":104},[101,614,108],{"class":107},[101,616,595],{"class":111},[101,618,474],{"class":111},[17,620,621],{},"Easy.",[17,623,624],{},"Heads up — if the container is running, you'll get this error:",[92,626,628],{"className":94,"code":627,"language":96,"meta":97,"style":97},"Error response from daemon: You cannot remove a running container 00c86b3fe0ca. Stop the container before attempting removal or force remove\n",[34,629,630],{"__ignoreMap":97},[101,631,632,635,638,641,644,647,650,653,656,659,662,665,668,671,673,676,679,682,685,688],{"class":103,"line":104},[101,633,634],{"class":107},"Error",[101,636,637],{"class":111}," response",[101,639,640],{"class":111}," from",[101,642,643],{"class":111}," daemon:",[101,645,646],{"class":111}," You",[101,648,649],{"class":111}," cannot",[101,651,652],{"class":111}," remove",[101,654,655],{"class":111}," a",[101,657,658],{"class":111}," running",[101,660,661],{"class":111}," container",[101,663,664],{"class":111}," 00c86b3fe0ca.",[101,666,667],{"class":111}," Stop",[101,669,670],{"class":111}," the",[101,672,661],{"class":111},[101,674,675],{"class":111}," before",[101,677,678],{"class":111}," attempting",[101,680,681],{"class":111}," removal",[101,683,684],{"class":111}," or",[101,686,687],{"class":111}," force",[101,689,690],{"class":111}," remove\n",[17,692,693,694,697],{},"So if the container is running, stop it first (",[34,695,696],{},"docker stop 00c86b3fe0ca","), then remove it.",[17,699,700],{},"That's it for this post. Next post continues with more Docker commands.",[702,703,704],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":97,"searchDepth":329,"depth":329,"links":706},[707,708,709,710,711,712],{"id":14,"depth":329,"text":15},{"id":22,"depth":329,"text":23},{"id":85,"depth":329,"text":36},{"id":227,"depth":329,"text":42},{"id":536,"depth":329,"text":48},{"id":578,"depth":329,"text":54},"Docker","2023-01-25 20:20:00","We covered Docker and Docker Hub commands. Now let's go through the Docker commands you'll actually use day-to-day with containers.","md","en",{},true,"\u002Fen\u002Fdocker\u002Fstep-by-step-docker-common-commands","4",{"title":6,"description":715},false,"en\u002FDocker\u002Fstep-by-step-docker-common-commands",[713,726,727],"Docker Container","Step-by-Step Docker",null,"2023-02-13 15:30:00","\u002Fen\u002Fdocker\u002F2023\u002F01\u002F25\u002Fstep-by-step-docker-common-commands\u002F","VV9em3dyjD4FSKmln6NErHJ0dLEOPeLZ75_ooXHjNqo",{"newer":733,"older":737},{"url":734,"title":735,"date":736},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F26\u002Fstep-by-step-docker-container-commands-part-2\u002F","(6) Step-by-Step Docker — Common Container Commands (Part 2)","2023-01-26 20:51:00",{"url":738,"title":739,"date":740},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F24\u002Fstep-by-step-docker-docker-hub\u002F","(4) Step-by-Step Docker — Docker Hub","2023-01-24 14:36:00",[742,747,752],{"url":743,"title":744,"date":745,"readingMinutes":746},"\u002Fen\u002Fdocker\u002F2024\u002F12\u002F19\u002Fdockerize-vite-vue-project\u002F","How to Dockerize a Vite + Vue Project","2024-12-19 16:36:18","2",{"url":748,"title":749,"date":750,"readingMinutes":751},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F29\u002Fstep-by-step-docker-table-of-contents\u002F","(11) Step-by-Step Docker — Table of Contents","2023-01-29 15:22:19","1",{"url":753,"title":754,"date":755,"readingMinutes":746},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F29\u002Fstep-by-step-docker-gui\u002F","(10) Step-by-Step Docker — Docker GUI","2023-01-29 15:20:19",1784020350799]