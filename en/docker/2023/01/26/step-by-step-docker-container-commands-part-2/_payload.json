docker start"," — start a Docker container",[33,58,60,42,62,65],{"className":59},[36],[38,61],{"checked":40,"disabled":40,"type":41},[44,63,64],{},"docker stop"," — stop a Docker container",[33,67,69,42,71,74],{"className":68},[36],[38,70],{"checked":40,"disabled":40,"type":41},[44,72,73],{},"docker rm"," — remove a Docker container",[33,76,78,42,80,83],{"className":77},[36],[38,79],{"disabled":40,"type":41},[44,81,82],{},"docker restart"," — restart a Docker container",[33,85,87,42,89,92],{"className":86},[36],[38,88],{"disabled":40,"type":41},[44,90,91],{},"docker ps"," — list Docker containers",[33,94,96,42,98,101],{"className":95},[36],[38,97],{"disabled":40,"type":41},[44,99,100],{},"docker exec"," — exec into a Docker container",[33,103,105,42,107,110],{"className":104},[36],[38,106],{"disabled":40,"type":41},[44,108,109],{},"docker logs"," — view a Docker container's logs",[17,112,113],{},"(Checked = covered, unchecked = still to cover.)",[17,115,116],{},"Let's go through the rest.",[12,118,82],{"id":119},"docker-restart",[17,121,122],{},"Pretty simple — restarts a Docker container.",[124,125,130],"pre",{"className":126,"code":127,"language":128,"meta":129,"style":129},"language-bash shiki shiki-themes github-dark-high-contrast","docker restart [container name]\n","bash","",[44,131,132],{"__ignoreMap":129},[133,134,137,141,145,149],"span",{"class":135,"line":136},"line",1,[133,138,140],{"class":139},"s_sBn","docker",[133,142,144],{"class":143},"sTRMh"," restart",[133,146,148],{"class":147},"sMAXC"," [container ",[133,150,151],{"class":143},"name]\n",[17,153,154,155,158],{},"Say your container ID is ",[44,156,157],{},"00c86b3fe0ca",":",[124,160,162],{"className":126,"code":161,"language":128,"meta":129,"style":129},"docker restart 00c86b3fe0ca\n",[44,163,164],{"__ignoreMap":129},[133,165,166,168,170],{"class":135,"line":136},[133,167,140],{"class":139},[133,169,144],{"class":143},[133,171,172],{"class":143}," 00c86b3fe0ca\n",[17,174,175],{},"Container restarted.",[12,177,91],{"id":178},"docker-ps",[17,180,181],{},"We touched on this earlier — lists Docker containers.",[124,183,185],{"className":126,"code":184,"language":128,"meta":129,"style":129},"docker ps [options]\n",[44,186,187],{"__ignoreMap":129},[133,188,189,191,194],{"class":135,"line":136},[133,190,140],{"class":139},[133,192,193],{"class":143}," ps",[133,195,196],{"class":147}," [options]\n",[17,198,199,200,202,203,207,208,158],{},"Heads up: ",[44,201,91],{}," on its own only shows ",[204,205,206],"strong",{},"running"," containers. To see all containers (including stopped ones), add ",[44,209,210],{},"-a",[124,212,214],{"className":126,"code":213,"language":128,"meta":129,"style":129},"docker ps -a\n",[44,215,216],{"__ignoreMap":129},[133,217,218,220,222],{"class":135,"line":136},[133,219,140],{"class":139},[133,221,193],{"class":143},[133,223,225],{"class":224},"sCcAr"," -a\n",[17,227,228,229,231],{},"This shows both running and stopped containers. Without ",[44,230,210],{}," you only see running.",[17,233,234,236,237,239,240,247],{},[44,235,91],{}," supports many more flags than just ",[44,238,210],{},". For everything else, see the ",[241,242,246],"a",{"href":243,"rel":244},"https:\u002F\u002Fdocs.docker.com\u002Fengine\u002Freference\u002Fcommandline\u002Fps\u002F",[245],"nofollow","Docker official docs",".",[12,249,100],{"id":250},"docker-exec",[17,252,253],{},"Lets you exec into a running container.",[124,255,257],{"className":126,"code":256,"language":128,"meta":129,"style":129},"docker exec [options] [container name] [command]\n",[44,258,259],{"__ignoreMap":129},[133,260,261,263,266],{"class":135,"line":136},[133,262,140],{"class":139},[133,264,265],{"class":143}," exec",[133,267,268],{"class":147}," [options] [container name] [command]\n",[17,270,271,272,158],{},"For container ID ",[44,273,157],{},[124,275,277],{"className":126,"code":276,"language":128,"meta":129,"style":129},"docker exec -it 962636806cb9 \u002Fbin\u002Fbash\n",[44,278,279],{"__igno