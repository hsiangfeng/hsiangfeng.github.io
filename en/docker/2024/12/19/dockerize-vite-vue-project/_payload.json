igh-contrast","npm init vite@latest\n","bash","",[41,42,43],"code",{"__ignoreMap":39},[44,45,48,52,56],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"smYoP","npm",[44,53,55],{"class":54},"sWayO"," init",[44,57,58],{"class":54}," vite@latest\n",[12,60,61],{},"Pick the options that fit you. Here's what I used:",[34,63,65],{"className":36,"code":64,"language":38,"meta":39,"style":39},"✔ Project name: … vue-project-docker\n✔ Use TypeScript? … No \u002F Yes\n✔ Add JSX support? … No \u002F Yes\n✔ Add Vue Router for SPA? … No \u002F Yes\n✔ Add Pinia for state management? … No \u002F Yes\n✔ Add Vitest for unit testing? … No \u002F Yes\n✔ Add an E2E testing tool? › No\n✔ Add ESLint for code quality? › No\n",[41,66,67,84,106,128,155,181,207,232],{"__ignoreMap":39},[44,68,69,72,75,78,81],{"class":46,"line":47},[44,70,71],{"class":50},"✔",[44,73,74],{"class":54}," Project",[44,76,77],{"class":54}," name:",[44,79,80],{"class":54}," …",[44,82,83],{"class":54}," vue-project-docker\n",[44,85,87,89,92,95,97,100,103],{"class":46,"line":86},2,[44,88,71],{"class":50},[44,90,91],{"class":54}," Use",[44,93,94],{"class":54}," TypeScript?",[44,96,80],{"class":54},[44,98,99],{"class":54}," No",[44,101,102],{"class":54}," \u002F",[44,104,105],{"class":54}," Yes\n",[44,107,109,111,114,117,120,122,124,126],{"class":46,"line":108},3,[44,110,71],{"class":50},[44,112,113],{"class":54}," Add",[44,115,116],{"class":54}," JSX",[44,118,119],{"class":54}," support?",[44,121,80],{"class":54},[44,123,99],{"class":54},[44,125,102],{"class":54},[44,127,105],{"class":54},[44,129,131,133,135,138,141,144,147,149,151,153],{"class":46,"line":130},4,[44,132,71],{"class":50},[44,134,113],{"class":54},[44,136,137],{"class":54}," Vue",[44,139,140],{"class":54}," Router",[44,142,143],{"class":54}," for",[44,145,146],{"class":54}," SPA?",[44,148,80],{"class":54},[44,150,99],{"class":54},[44,152,102],{"class":54},[44,154,105],{"class":54},[44,156,158,160,162,165,167,170,173,175,177,179],{"class":46,"line":157},5,[44,159,71],{"class":50},[44,161,113],{"class":54},[44,163,164],{"class":54}," Pinia",[44,166,143],{"class":54},[44,168,169],{"class":54}," state",[44,171,172],{"class":54}," management?",[44,174,80],{"class":54},[44,176,99],{"class":54},[44,178,102],{"class":54},[44,180,105],{"class":54},[44,182,184,186,188,191,193,196,199,201,203,205],{"class":46,"line":183},6,[44,185,71],{"class":50},[44,187,113],{"class":54},[44,189,190],{"class":54}," Vitest",[44,192,143],{"class":54},[44,194,195],{"class":54}," unit",[44,197,198],{"class":54}," testing?",[44,200,80],{"class":54},[44,202,99],{"class":54},[44,204,102],{"class":54},[44,206,105],{"class":54},[44,208,210,212,214,217,220,223,226,229],{"class":46,"line":209},7,[44,211,71],{"class":50},[44,213,113],{"class":54},[44,215,216],{"class":54}," an",[44,218,219],{"class":54}," E2E",[44,221,222],{"class":54}," testing",[44,224,225],{"class":54}," tool?",[44,227,228],{"class":54}," ›",[44,230,231],{"class":54}," No\n",[44,233,235,237,239,242,244,247,250,252],{"class":46,"line":234},8,[44,236,71],{"class":50},[44,238,113],{"class":54},[44,240,241],{"class":54}," ESLint",[44,243,143],{"class":54},[44,245,246],{"class":54}," code",[44,248,249],{"class":54}," quality?",[44,251,228],{"class":54},[44,253,231],{"class":54},[19,255,257],{"id":256},"dockerfile","Dockerfile",[12,259,260],{},"Next, create a Dockerfile in the project root:",[34,262,264],{"className":36,"code":263,"language":38,"meta":39,"style":39},"touch Dockerfile\n",[41,265,266],{"__ignoreMap":39},[44,267,268,271],{"class":46,"line":47},[44,269,270],{"class":50},"touch",[44,272,273],{"class":54}," Dockerfile\n",[12,275,276],{},"The Dockerfile tells Docker how to build the environment. Here's mine:",[34,278,281],{"className":279,"code":280,"language":256,"meta":39,"style":39},"language-dockerfile shiki shiki-themes github-light github-light github-dark-high-contrast","FROM node:20 AS builder\nWORKDIR \u002Fapp\nCOPY package*.json .\u002F\nRUN npm install\nCOPY . .\nRUN npm run build\n\nFROM nginx:alpine\nCOPY --from=builder \u002Fapp\u002Fdist \u002Fusr\u002Fshare\u002Fnginx\u002Fhtml\nEXPOSE 80\nCMD [\"nginx\", \"-g\", \"daemon off;\"]\n",[41,282,283,288,293,298,303,308,313,319,324,330,336],{"__ignoreMap":39},[44,284,285],{"class":46,"line":47},[44,286,287],{},"FROM node:20 AS builder\n",[44,289,290],{"class":46,"line":86},[44,291,292],{},"WORKDIR \u002Fapp\n",[44,294,295],{"class":46,"line":108},[44,296,297],{},"COPY package*.json .\u002F\n",[44,299,300],{"class":46,"line":130},[44,301,302],{},"RUN npm install\n",[44,304,305],{"class":46,"line":157},[44,306,307],{},"COPY . .\n",[44,309,310],{"class":46,"line":183},[44,311,312],{},"RUN npm run build\n",[44,314,315],{"class":46,"line":209},[44,316,318],{"emptyLinePlaceholder":317},true,"\n",[44,320,321],{"class":46,"line":234},[44,322,323],{},"FROM nginx:alpine\n",[44,325,327],{"class":46,"line":326},9,[44,328,329],{},"COPY --from=builder \u002Fapp\u002Fdist \u002Fusr\u002Fshare\u002Fnginx\u002Fhtml\n",[44,331,333],{"class":46,"line":332},10,[44,334,335],{},"EXPOSE 80\n",[44,337,339],{"class":46,"line":338},11,[44,340,341],{},"CMD [\"nginx\", \"-g\", \"daemon off;\"]\n",[12,343,344],{},"Quick line-by-line:",[346,347,348,359,373,390,403,411],"ol",{},[349,350,351,354,355,358],"li",{},[41,352,353],{},"FROM node:20 AS builder"," — use Node.js 20 as the base, named ",[41,356,357],{},"builder",". We're splitting the build into two stages; this is the build stage.",[349,360,361,364,365,368,369,372],{},[41,362,363],{},"WORKDIR \u002Fapp"," — set the working directory to ",[41,366,367],{},"\u002Fapp",". Think of it as creating a folder called ",[41,370,371],{},"app"," where all subsequent commands run.",[349,374,375,378,379,382,383,386,387,389],{},[41,376,377],{},"COPY package*.json .\u002F"," — copy ",[41,380,381],{},"package.json"," and ",[41,384,385],{},"package-lock.json"," into ",[41,388,367],{},".",[349,391,392,395,396,399,400,402],{},[41,393,394],{},"RUN npm install"," — install dependencies. ",[41,397,398],{},"node_modules"," ends up in ",[41,401,367],{}," after this.",[349,404,405,408,409,389],{},[41,406,407],{},"COPY . ."," — copy the whole project into ",[41,410,367],{},[349,412,413,416],{},[41,414,415],{},"RUN npm run build"," — build the project into static files.",[12,418,419,420,422],{},"That's the ",[41,421,357],{}," stage done. Now we move to the runtime stage.",[346,424,425,431,444,450],{},[349,426,427,430],{},[41,428,429],{},"FROM nginx:alpine"," — use the Nginx Alpine base. Alpine is the lightweight version.",[349,432,433,436,437,440,441,443],{},[41,434,435],{},"COPY --from=builder \u002Fapp\u002Fdist \u002Fusr\u002Fshare\u002Fnginx\u002Fhtml"," — copy the ",[41,438,439],{},"dist"," folder from the ",[41,442,357],{}," stage into Nginx's default serving folder.",[349,445,446,449],{},[41,447,448],{},"EXPOSE 80"," — declare port 80 so external traffic can hit our site.",[349,451,452,455,456,459],{},[41,453,454],{},"CMD [\"nginx\", \"-g\", \"daemon off;\"]"," — start Nginx in foreground when the container launches. Without ",[41,457,458],{},"daemon off",", Docker would shut down right after launching since Nginx would daemonize and exit.",[19,461,463],{"id":462},"building-the-docker-image","Building the Docker Image",[12,465,466],{},"Now build the image. In the project root run:",[34,468,470],{"className":36,"code":469,"language":38,"meta":39,"style":39},"docker build -t vue-project-docker:v1 .\n",[41,471,472],{"__ignoreMap":39},[44,473,474,477,480,484,487],{"class":46,"line":47},[44,475,476],{"class":50},"docker",[44,478,479],{"class":54}," build",[44,481,483],{"class":482},"stw71"," -t",[44,485,486],{"class":54}," vue-project-docker:v1",[44,488,489],{"class":54}," .\n",[12,491,492],{},"This takes a moment.",[12,494,495],{},[15,496],{"alt":497,"src":498},"Building","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202024-12-19%2016.53.40.png",[12,500,501],{},"Once done, check it:",[34,503,505],{"className":36,"code":504,"language":38,"meta":39,"style":39},"docker images\n",[41,506,507],{"__ignoreMap":39},[44,508,509,511],{"class":46,"line":47},[44,510,476],{"class":50},[44,512,513],{"class":54}," images\n",[12,515,516],{},"If you see your image in the list, you're good.",[19,518,520],{"id":519},"running-the-container","Running the container",[12,522,523,524,527],{},"Now spin up a container with ",[41,525,526],{},"docker run",":",[34,529,531],{"className":36,"code":530,"language":38,"meta":39,"style":39},"docker run -d -p 8080:80 vue-project-docker:v1\n",[41,532,533],{"__ignoreMap":39},[44,534,535,537,540,543,546,549],{"class":46,"line":47},[44,536,476],{"class":50},[44,538,539],{"class":54}," run",[44,541,542],{"class":482}," -d",[44,544,545],{"class":482}," -p",[44,547,548],{"class":54}," 8080:80",[44,550,551],{"class":54}," vue-project-docker:v1\n",[12,553,554],{},"If you see this output, your container is running.",[12,556,557],{},[15,558],{"alt":559,"src":560},"Container running","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202024-12-19%2016.57.00.png",[12,562,563,564,567],{},"Now hit ",[41,565,566],{},"http:\u002F\u002Flocalhost:8080"," in your browser.",[569,570,573],"callout",{"title":571,"type":572},"Note","note",[12,574,575,578,579,581,582,585,586,588],{},[41,576,577],{},"8080"," is the host port you set in ",[41,580,526],{},". Change it if you used a different one. ",[41,583,584],{},"80"," is Nginx's port — if you want to change that, update ",[41,587,448],{}," in the Dockerfile.",[19,590,592],{"id":591},"stopping-the-container","Stopping the container",[12,594,595],{},"To stop the container:",[34,597,599],{"className":36,"code":598,"language":38,"meta":39,"style":39},"docker stop containerId\n",[41,600,601],{"__ignoreMap":39},[44,602,603,605,608],{"class":46,"line":47},[44,604,476],{"class":50},[44,606,607],{"class":54}," stop",[44,609,610],{"class":54}," containerId\n",[569,612,613],{"t