[{"data":1,"prerenderedAt":443},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fwebpack\u002F2019\u002F06\u002F05\u002Fwebpack-learning-ep-1-intro\u002F":3,"page:\u002Fen\u002Fwebpack\u002F2019\u002F06\u002F05\u002Fwebpack-learning-ep-1-intro\u002F":4,"alt:\u002Fen\u002Fwebpack\u002F2019\u002F06\u002F05\u002Fwebpack-learning-ep-1-intro\u002F":3,"prev-next:\u002Fen\u002Fwebpack\u002F2019\u002F06\u002F05\u002Fwebpack-learning-ep-1-intro\u002F":419,"related:\u002Fen\u002Fwebpack\u002F2019\u002F06\u002F05\u002Fwebpack-learning-ep-1-intro\u002F":428},"\u002Fwebpack\u002F20190605\u002F2833498596\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":404,"date":405,"description":19,"extension":406,"lang":407,"meta":408,"navigation":193,"path":409,"readingMinutes":410,"seo":411,"standalone":412,"stem":413,"tags":414,"tldr":416,"updated":416,"url":417,"__hash__":418},"content\u002Fen\u002FWebpack\u002Fwebpack-learning-ep-1-intro.md","EP 1 - Learning Webpack the Hard Way","8596283349",{"type":9,"value":10,"toc":399},"minimark",[11,16,20,24,27,34,37,68,75,80,83,92,98,105,108,134,137,146,150,157,269,272,290,301,308,313,319,339,342,357,368,373,380,385,390,395],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Webpack is a pretty common web technology — it bundles up everything your site needs and packages it for delivery. So let me start logging my Webpack learning notes here.",[12,21,23],{"id":22},"setup","Setup",[17,25,26],{},"Why do we need Webpack? Web development has exploded — now we write Sass, SCSS, LESS, PUG, all kinds of things. Webpack helps bundle these assets and integrate them into what the browser actually needs. The official site has a diagram:",[17,28,29],{},[30,31],"img",{"alt":32,"src":33},"Webpack official site","https:\u002F\u002Fi.imgur.com\u002Fcw6fL2W.png",[17,35,36],{},"Before writing Webpack, install it. Open a terminal:",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-