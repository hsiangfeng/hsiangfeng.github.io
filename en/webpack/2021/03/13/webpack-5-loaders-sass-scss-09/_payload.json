":45,"style":45},"language-cmd shiki shiki-themes github-light github-light github-dark-high-contrast","npm install --save-dev style-loader css-loader sass-loader node-sass\n","cmd","",[47,48,49],"code",{"__ignoreMap":45},[50,51,54],"span",{"class":52,"line":53},"line",1,[50,55,43],{},[57,58,59,66,72,78],"ul",{},[60,61,62,65],"li",{},[47,63,64],{},"node-sass"," is the CSS preprocessor. The alternative is Dart-sass, but as of writing most projects pick node-sass.",[60,67,68,71],{},[47,69,70],{},"sass-loader"," depends on the above. It compiles Sass\u002FSCSS into CSS.",[60,73,74,77],{},[47,75,76],{},"css-loader"," works with style-loader. It reads CSS styles.",[60,79,80,83,84,87],{},[47,81,82],{},"style-loader"," injects the CSS that css-loader read into a ",[47,85,86],{},"\u003Cstyle>"," tag.",[17,89,90,91,94,95,98],{},"Easier to see than to read about, so let's do it. With those installed, add to ",[47,92,93],{},"webpack.config.js","'s ",[47,96,97],{},"rules",":",[40,100,104],{"className":101,"code":102,"language":103,"meta":45,"style":45},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  test: \u002F\\.s[ac]ss$\u002Fi,\n  use: ['style-loader', 'css-loader', 'sass-loader'],\n},\n","js",[47,105,106,112,152,178],{"__ignoreMap":45},[50,107,108],{"class":52,"line":53},[50,109,111],{"class":110},"s8XSl","{\n",[50,113,115,119,121,125,129,132,136,139,143,146,149],{"class":52,"line":114},2,[50,116,118],{"class":117},"smYoP","  test",[50,120,98],{"class":110},[50,122,124],{"class":123},"sWayO"," \u002F",[50,126,128],{"class":127},"sIdya","\\.",[50,130,131],{"class":123},"s",[50,133,135],{"class":134},"stw71","[ac]",[50,137,138],{"class":123},"ss",[50,140,142],{"class":141},"sOudu","$",[50,144,145],{"class":123},"\u002F",[50,147,148],{"class":141},"i",[50,150,151],{"class":110},",\n",[50,153,155,158,161,164,167,170,172,175],{"class":52,"line":154},3,[50,156,157],{"class":117},"  use",[50,159,160],{"class":110},": [",[50,162,163],{"cla