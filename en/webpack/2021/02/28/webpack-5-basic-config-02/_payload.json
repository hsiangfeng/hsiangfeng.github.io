"meta":74,"style":74},"language-js shiki shiki-themes github-dark-high-contrast","const path = require('path');\n\nmodule.exports = {\n  mode: 'development',\n  entry: path.resolve(__dirname, '.\u002Fsrc\u002Fmain.js'),\n  output: {\n    path: path.resolve(__dirname, '.\u002Fdist'),\n    filename: '[name].[contenthash].bundle.js',\n  },\n};\n","js","",[47,76,77,108,115,131,143,161,167,182,193,199],{"__ignoreMap":74},[78,79,82,86,90,93,97,101,105],"span",{"class":80,"line":81},"line",1,[78,83,85],{"class":84},"sWyjQ","const",[78,87,89],{"class":88},"sCcAr"," path",[78,91,92],{"class":84}," =",[78,94,96],{"class":95},"sj_SG"," require",[78,98,100],{"class":99},"sMAXC","(",[78,102,104],{"class":103},"sTRMh","'path'",[78,106,107],{"class":99},");\n",[78,109,111],{"class":80,"line":110},2,[78,112,114],{"emptyLinePlaceholder":113},true,"\n",[78,116,118,121,123,126,128],{"class":80,"line":117},3,[78,119,120],{"class":88},"module",[78,122,53],{"class":99},[78,124,125],{"class":88},"exports",[78,127,92],{"class":84},[78,129,130],{"class":99}," {\n",[78,132,134,137,140],{"class":80,"line":133},4,[78,135,136],{"class":99},"  mode: ",[78,138,139],{"class":103},"'development'",[78,141,142],{"class":99},",\n",[78,144,146,149,152,155,158],{"class":80,"line":145},5,[78,147,148],{"class":99},"  entry: path.",[78,150,151],{"class":95},"resolve",[78,153,154],{"class":99},"(__dirname, ",[78,156,157],{"class":103},"'.\u002Fsrc\u002Fmain.js'",[78,159,160],{"class":99},"),\n",[78,162,164],{"class":80,"line":163},6,[78,165,166],{"class":99},"  output: {\n",[78,168,170,173,175,177,180],{"class":80,"line":169},7,[78,171,172],{"class":99},"    path: path.",[78,174,151],{"class":95},[78,176,154],{"class":99},[78,178,179],{"class":103},"'.\u002Fdist'",[78,181,160],{"class":99},[78,183,185,188,191],{"class":80,"line":184},8,[78,186,187],{"class":99},"    filename: ",[78,189,190],{"class":103},"'[name].[contenthash].bundle.js'",[78,192,142],{"class":99},[78,194,196],{"class":80,"line":195},9,[78,197,198],{"class":99},"  },\n",[78,200,202],{"class":80,"line":201},10,[78,203,204],{"class":99},"};\n",[17,206,207,208,211,212,219],{},"Walking through line by line — first, ",[47,209,210],{},"const path = require('path');"," is Node.js syntax used for ",[213,214,218],"a",{"href":215,"rel":216},"https:\u002F\u002Fnodejs.org\u002Fapi\u002Fpath.html",[217],"nofollow","path manipulation",". Why use this? Let me explain.",[17,221,222,225,226,229,230,233,234,236,237,240,241,244],{},[47,223,224],{},"path.resolve"," joins paths together. ",[47,227,228],{},"__dirname"," is the current execution directory. For example, mine prints ",[47,231,232],{},"\u002FUsers\u002Frayxu\u002FGitHub\u002Fwebpack5sample",", and after ",[47,235,224],{}," it becomes ",[47,238,239],{},"\u002FUsers\u002Frayxu\u002FGitHub\u002Fwebpack5sample\u002Fsrc\u002Fmain.js",". We do this because on some operating systems, writing ",[47,242,243],{},".\u002Fsrc\u002Fmain.js"," directly can hit path-related issues.",[17,246,247,248,251],{},"Next is the line most frontend devs already know — ",[47,249,250],{},"module.exports",". As mentioned earlier, Webpack requires Node.js, so Webpack's module system uses Node.js's CommonJS spec. If you're not familiar with CommonJS, look it up — there are plenty of in-depth explainers out there.",[17,253,254,255,258,259,262],{},"When developing, we usually have a dev mode and a production mode. Webpack also has both, controlled via the ",[47,256,257],{},"mode"," property. If you don't set it, Webpack defaults to ",[47,260,261],{},"production",". The official docs confirm this:",[264,265,266],"blockquote",{},[17,267,268],{},"By setting the mode parameter to either development, production or none, you can enable webpack's built-in optimizations that correspond to each environment. The default value is production.",[17,270,271,274,275,277,278,280],{},[47,272,273],{},"entry"," is one of Webpack's core properties — you've probably heard the term \"entry point\". The entry point is exactly that — where Webpack starts parsing your modules. ",[47,276,273],{}," is required; without it Webpack errors out. Typically it points to ",[47,279,243],{},". Create that file too.",[17,282,283,286,287,290,291,294,295,297,298,301,302,304,305,308,309,312,313,316],{},[47,284,285],{},"output"," tells Webpack where to write the output and what to name it. It has two properties: ",[47,288,289],{},"path"," (output directory) and ",[47,292,293],{},"filename"," (output file name). For ",[47,296,293],{},", you'll usually want ",[47,299,300],{},"[name]"," — when you use ",[47,303,300],{},", the output is named after the entry file. If you hard-code ",[47,306,307],{},"filename: 'index.bundle.js',",", no matter what your entry is, the output is always called ",[47,310,311],{},"index.bundle.js",". ",[47,314,315],{},"[contenthash]"," generates a hash based on the file content. There are other naming options too:",[28,318,319,324,329],{},[31,320,321],{},[47,322,323],{},"[name].[hash].bundle.js",[31,325,326],{},[47,327,328],{},"[name].[chunkhash].bundle.js",[31,330,331],{},[47,332,333],{},"[name].[contenthash].bundle.js",[17,335,336,337,340],{},"All three see real-world use. Side note — if you find the hash too long, you can cap its length: ",[47,338,339],{},"[name].[hash:6].bundle.js",". Why use hashes? Mainly to bust browser caches. During dev we hit reload constantly, which can lead to confusion when caches kick in and you can't tell whether your changes apply. With hashes, every save produces a new filename, so the browser doesn't serve stale content.",[17,342,343,344,347],{},"That's Webpack's most basic and most core config. Let's create the entry file (",[47,345,346],{},"\u002Fsrc\u002Fmain.js","):",[17,349,350],{},"Content:",[69,352,354],{"className":71,"code":353,"language":73,"meta":74,"style":74},"console.log('Hello Ray!');\n",[47,355,356],{"__ignoreMap":74},[78,357,358,361,364,366,369],{"class":80,"line":81},[78,359,360],{"class":99},"console.",[78,362,363],{"