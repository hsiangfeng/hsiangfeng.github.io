[{"data":1,"prerenderedAt":525},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2022\u002F04\u002F17\u002Fjavascript-core-74-promise-basics\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2022\u002F04\u002F17\u002Fjavascript-core-74-promise-basics\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2022\u002F04\u002F17\u002Fjavascript-core-74-promise-basics\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2022\u002F04\u002F17\u002Fjavascript-core-74-promise-basics\u002F":500,"related:\u002Fen\u002Fjavascript\u002F2022\u002F04\u002F17\u002Fjavascript-core-74-promise-basics\u002F":509},"\u002Fjavascript\u002F20220417\u002F2521435150\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":485,"date":486,"description":487,"extension":488,"lang":489,"meta":490,"navigation":149,"path":491,"readingMinutes":376,"seo":492,"standalone":493,"stem":494,"tags":495,"tldr":497,"updated":486,"url":498,"__hash__":499},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-74-promise-basics.md","JavaScript Core (74) - Promise - The Basics of Promise","1000641442",{"type":9,"value":10,"toc":480},"minimark",[11,16,20,24,30,33,39,42,163,169,186,201,217,222,227,238,262,265,453,456,459,463,476],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time we figured out why we even need Promise and how the older ways of writing async code differed. Starting with this post, we'll get hands-on with the actual Promise syntax and build up a basic understanding of it.",[12,21,23],{"id":22},"promise","Promise",[17,25,26],{},[27,28],"img",{"alt":23,"src":29},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202022-04-16%2022.20.53.png",[17,31,32],{},"The course happened to have a really nice diagram showing the states of a Promise.",[17,34,35],{},[27,36],{"alt":37,"src":38},"Promise states","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u0