02FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202022-04-16%2022.49.31.png",[17,170,171,172,174,175,178,179,181,182,185],{},"You'll notice that when you log the ",[50,173,22],{}," right away, JavaScript shows it as unsettled. That's because JavaScript is an asynchronous language — at the moment ",[50,176,177],{},"console.log"," runs, the ",[50,180,22],{}," hasn't returned anything yet, so it outputs ",[50,183,184],{},"Promise { \u003Cstate>: \"pending\" }"," to tell you the Promise is still pending (it hasn't finished).",[17,187,188,189,192,193,196,197,200],{},"Once the Promise's work is done, its ",[50,190,191],{},"state"," flips to ",[50,194,195],{},"fulfilled"," (resolved\u002Fsucceeded), or to ",[50,198,199],{},"rejected"," if it failed.",[17,202,203,204,206,207,209,210,213,214,216],{},"For the code above, if you wait five seconds and then expand the logged object, you'll see ",[50,205,191],{}," has become ",[50,208,195],{},", and the returned value is exactly the ",[50,211,212],{},"true"," we passed to ",[50,215,81],{},".",[17,218,219],{},[27,220],{"alt":195,"src":221},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202022-04-16%2022.51.03.png",[17,223,119,224,226],{},[50,225,177],{}," is itself asynchronous, so what you see logged versus what you see when you expand it will always be different.)",[17,228,229,230,234,235,216],{},"So no matter what, if you want to make sure something only runs ",[231,232,233],"em",{},"after"," the Promise has finished, you have to add a ",[50,236,237],{},".then",[17,239,240,241,243,244,246,247,249,250,246,253,256,257,259,260,216],{},"When you declare a ",[50,242,23],{},", you pass in two parameters: ",[50,245,81],{}," and ",[50,248,87],{},". Those two map to ",[50,251,252],{},"then",[50,254,255],{},"catch",". So when the Promise succeeds, the result gets sent into ",[50,258,252],{},"; when it fails, it goes into ",[50,261,255],{},[17,263,264],{},"Here's a snippet that randomly succeeds or fails:",[43,266,268],{"className":45,"code":267,"language":47,"meta":48,"style":48},"const promise = (random) => new Promise((resolve, reject) => {\n  if(random) {\n    resolve(random);\n  } else {\n    reject(random)\n  }\n});\n\npromise(Math.floor(Math.random()*2))\n  .then((resolve) => {\n    console.log('resolve', resolve);\n  }).catch((reject) => {\n    console.log('reject', reject);\n  })\n",[50,269,270,306,314,321,331,339,344,348,353,380,398,414,432,447],{"__ignoreMap":48},[53,271,272,274,276,278,281,284,286,288,290,292,294,296,298,300,302,304],{"class":55,"line":56},[53,273,60],{"class":59},[53,275,64],{"class":102},[53,277,67],{"class":59},[53,279,280],{"class":76}," (",[53,282,283],{"class":80},"random",[53,285,90],{"class":76},[53,287,93],{"class":59},[53,289,70],{"class":59},[53,291,73],{"class":63},[53,293,77],{"class":76},[53,295,81],{"class":80},[53,297,84],{"class":76},[53,299,87],{"class":80},[53,301,90],{"class":76},[53,303,93],{"class":59},[53,305,96],{"class":76},[53,307,308,311],{"class":55,"line":99},[53,309,310],{"class":59},"  if",[53,312,313],{"class":76},"(random) {\n",[53,315,316,318],{"class":55,"line":113},[53,317,116],{"class":102},[53,319,320],{"class":76},"(random);\n",[53,322,323,326,329],{"class":55,"line":129},[53,324,325],{"class":76},"  } ",[53,327,328],{"class":59},"else",[53,330,96],{"class":76},[53,332,333,336],{"class":55,"line":140},[53,334,335],{"class":102},"    reject",[53,337,338],{"class":76},"(random)\n",[53,340,341],{"class":55,"line":146},[53,342,343],{"class":76},"  }\n",[53,345,346],{"class":55,"line":153},[53,347,143],{"class":76},[53,349,351],{"class":55,"line":350},8,[53,352,150],{"emptyLinePlaceholder":149},[53,354,356,358,361,364,366,368,371,374,377],{"class":55,"line":355},9,[53,357,22],{"class":102},[53,359,360],{"class":76},"(Math.",[53,362,363],{"class":102},"floor",[53,365,360],{"class":76},[53,36