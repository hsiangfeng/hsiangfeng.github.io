unction fn() {\n  ...\n}\n\nconst fn = async function() {\n  ...\n}\n\nconst fn = async () => {\n  ...\n}\n",[38,297,298,311,316,320,326,343,347,351,355,372,376],{"__ignoreMap":36},[41,299,300,302,305,308],{"class":43,"line":44},[41,301,291],{"class":47},[41,303,304],{"class":47}," function",[41,306,307],{"class":51}," fn",[41,309,310],{"class":55},"() {\n",[41,312,313],{"class":43,"line":66},[41,314,315],{"class":47},"  ...\n",[41,317,318],{"class":43,"line":100},[41,319,189],{"class":55},[41,321,322],{"class":43,"line":113},[41,323,325],{"emptyLinePlaceholder":324},true,"\n",[41,327,328,331,333,336,339,341],{"class":43,"line":122},[41,329,330],{"class":47},"const",[41,332,307],{"class":51},[41,334,335],{"class":47}," =",[41,337,338],{"class":47}," async",[41,340,304],{"class":47},[41,342,310],{"class":55},[41,344,345],{"class":43,"line":138},[41,346,315],{"class":47},[41,348,349],{"class":43,"line":149},[41,350,189],{"class":55},[41,352,353],{"class":43,"line":163},[41,354,325],{"emptyLinePlaceholder":324},[41,356,357,359,361,363,365,368,370],{"class":43,"line":169},[41,358,330],{"class":47},[41,360,307],{"class":51},[41,362,335],{"class":47},[41,364,338],{"class":47},[41,366,367],{"class":55}," () ",[41,369,94],{"class":47},[41,371,97],{"class":55},[41,373,374],{"class":43,"line":180},[41,375,315],{"class":47},[41,377,378],{"class":43,"line":186},[41,379,189],{"class":55},[17,381,382,383,385],{},"So how do we rewrite that ",[38,384,195],{}," call from above? We just rewrite it using Async:",[31,387,389],{"className":33,"code":388,"language":35,"meta":36,"style":36},"async function asyncFn() {\n  const res = await promiseFn(true);\n  console.log(res); \u002F\u002F resolve\n}\n\nasyncFn();\n",[38,390,391,402,423,437,441,445],{"__ignoreMap":36},[41,392,393,395,397,400],{"class":43,"line":44},[41,394,291],{"class":47},[41,396,304],{"class":47},[41,398,399],{"class":51}," asyncFn",[41,401,310],{"class":55},[41,403,404,407,410,412,415,417,419,421],{"class":43,"line":66},[41,405,406],{"class":47},"  const",[41,408,409],{"class":75}," res",[41,411,335],{"class":47},[41,413,414],{"class":47}," await",[41,416,52],{"class":51},[41,418,128],{"class":55},[41,420,210],{"class":75},[41,422,135],{"class":55},[41,424,425,428,430,433],{"class":43,"line":100},[41,426,427],{"class":55},"  console.",[41,429,239],{"class":51},[41,431,432],{"class":55},"(res); ",[41,434,436],{"class":435},"sQrFR","\u002F\u002F resolve\n",[41,438,439],{"class":43,"line":113},[41,440,189],{"class":55},[41,442,443],{"class":43,"line":122},[41,444,325],{"emptyLinePlaceholder":324},[41,446,447,450],{"class":43,"line":138},[41,448,449],{"class":51},"asyncFn",[41,451,452],{"class":55},"();\n",[17,454,455,456,459,460,462],{},"One thing to watch out for here: ",[38,457,458],{},"await"," is only used to receive the result of a Promise expression. And once you use ",[38,461,458],{},", the code is forced to block and wait until that line finishes. So it ends up behaving kind of like line-by-line execution — you don't get the event-queue (async) behavior you'd otherwise see.",[31,464,466],{"className":33,"code":465,"language":35,"meta":36,"style":36},"async function asyncFn() {\n  console.log('1'); \u002F\u002F 1\n  const res = await promiseFn(true);\n  console.log('2', res); \u002F\u002F 2 resolve\n}\n\nasyncFn();\n",[38,467,468,478,495,513,530,534,538],{"__ignoreMap":36},[41,469,470,472,474,476],{"class":43,"line":44},[41,471,291],{"class":47},[41,473,304],{"class":47},[41,475,399],{"class":51},[41,477,310],{"class":55},[41,479,480,482,484,486,489,492],{"class":43,"line":66},[41,481,427],{"class":55},[41,483,239],{"class":51},[41,485,128],{"class":55},[41,487,488],{"class":131},"'1'",[41,490,491],{"class":55},"); ",[41,493,494],{"class":435},"\u002F\u002F 1\n",[41,496,497,499,501,503,505,507,509,511],{"class":43,"line":100},[41,498,406],{"class":47},[41,500,409],{"class":75},[41,502,335],{"class":47},[41,504,414],{"class":47},[41,506,52],{"class":51},[41,508,128],{"class":5