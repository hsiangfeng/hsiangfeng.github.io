\n      } else {\n        reject('reject')\n      }\n    }, 1000)\n  })\n}\n\nconst asyncFn = async () => {\n  try {\n    const res = await promiseFn(true);\n    console.log(res);\n  } catch(error) {\n    console.log('error', error);\n  }\n}\n","js","",[35,36,37,61,95,108,117,133,144,158,164,175,181,187,194,216,224,247,259,271,286,292],"code",{"__ignoreMap":33},[38,39,42,46,50,54,58],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sOudu","function",[38,47,49],{"class":48},"scAaK"," promiseFn",[38,51,53],{"class":52},"s8XSl"," (",[38,55,57],{"class":56},"syBk-","boolean",[38,59,60],{"class":52},") {\n",[38,62,64,67,70,74,77,80,83,86,89,92],{"class":40,"line":63},2,[38,65,66],{"class":44},"  return",[38,68,69],{"class":44}," new",[38,71,73],{"class":72},"stw71"," Promise",[38,75,76],{"class":52},"((",[38,78,79],{"class":56},"resolve",[38,81,82],{"class":52},", ",[38,84,85],{"class":56},"reject",[38,87,88],{"class":52},") ",[38,90,91],{"class":44},"=>",[38,93,94],{"class":52}," {\n",[38,96,98,101,104,106],{"class":40,"line":97},3,[38,99,100],{"class":48},"    setTimeout",[38,102,103],{"class":52},"(() ",[38,105,91],{"class":44},[38,107,94],{"class":52},[38,109,111,114],{"class":40,"line":110},4,[38,112,113],{"class":44},"      if",[38,115,116],{"class":52},"(boolean) {\n",[38,118,120,123,126,130],{"class":40,"line":119},5,[38,121,122],{"class":48},"        resolve",[38,124,125],{"class":52},"(",[38,127,129],{"class":128},"sWayO","'resolve'",[38,131,132],{"class":52},");\n",[38,134,136,139,142],{"class":40,"line":135},6,[38,137,138],{"class":52},"      } ",[38,140,141],{"class":44},"else",[38,143,94],{"class":52},[38,145,147,150,152,155],{"class":40,"line":146},7,[38,148,149],{"class":48},"        reject",[38,151,125],{"class":52},[38,153,154],{"class":128},"'reject'",[38,156,157],{"class":52},")\n",[38,159,161],{"class":40,"line":160},8,[38,162,163],{"class":52},"      }\n",[38,165,167,170,173],{"class":40,"line":166},9,[38,168,169],{"class":52},"    }, ",[38,171,172],{"class":72},"1000",[38,174,157],{"class":52},[38,176,178],{"class":40,"line":177},10,[38,179,180],{"class":52},"  })\n",[38,182,184],{"class":40,"line":183},11,[38,185,186],{"class":52},"}\n",[38,188,190],{"class":40,"line":189},12,[38,191,193],{"emptyLinePlaceholder":192},true,"\n",[38,195,197,200,203,206,209,212,214],{"class":40,"line":196},13,[38,198,199],{"class":44},"const",[38,201,202],{"class":48}," asyncFn",[38,204,205],{"class":44}," =",[38,207,208],{"class":44}," async",[38,210,211],{"class":52}," () ",[38,213,91],{"class":44},[38,215,94],{"class":52},[38,217,219,222],{"class":40,"line":218},14,[38,220,221],{"class":44},"  try",[38,223,94],{"class":52},[38,225,227,230,233,235,238,240,242,245],{"class":40,"line":226},15,[38,228,229],{"class":44},"    const",[38,231,232],{"class":72}," res",[38,234,205],{"class":44},[38,236,237],{"class":44}," await",[38,239,49],{"class":48},[38,241,125],{"class":52},[38,243,244],{"class":72},"true",[38,246,132],{"class":52},[38,248,250,253,256],{"class":40,"line":249},16,[38,251,252],{"class":52},"    console.",[38,254,255],{"class":48},"log",[38,257,258],{"class":52},"(res);\n",[38,260,262,265,268],{"class":40,"line":261},17,[38,263,264],{"class":52},"  } ",[38,266,267],{"class":44},"catch",[38,269,270],{"class":52},"(error) {\n",[38,272,274,276,278,280,283],{"class":40,"line":273},18,[38,275,252],{"class":52},[38,277,255],{"class":48},[38,279,125],{"class":52},[38,281,282],{"class":128},"'error'",[38,284,285],{"class":52},", error);\n",[38,287,289],{"class":40,"line":288},19,[38,290,291],{"class":52},"  }\n",[38,293,295],{"class":40,"line":294},20,[38,296,186],{"class":52},[17,298,299,300,303,304,307,308,311],{},"You can see from the code above that whenever you use ",[35,301,302],{},"async"," and ",[35,305,306],{},"await",", the recommendation is to wrap things in a ",[35,309,310],{},"try...catch...",". Otherwise you can't catch errors properly.",[17,313,314,315,303,317,319,320,322,323,325,326,328,329,331,332,334,335,338],{},"But honestly, this isn't the prettiest pattern, because now every single time you use ",[35,316,302],{},[35,318,306],{}," you have to write a bunch of ",[35,321,310],{}," blocks. The good news is the ",[35,324,310],{}," structure can be factored out. One thing to watch though is the ",[35,327,267],{}," part. The main reason we use ",[35,330,310],{}," is to catch the error and surface it, so the ",[35,333,267],{}," part should be consistent (meaning a unified behavior, like ",[35,336,337],{},"window.alert(error);"," and so on).",[17,340,341,342,345,346,349,350,352],{},"So first, let's look at how to rewrite this. We start by declaring a ",[35,343,344],{},"catchError"," function that takes an ",[35,347,348],{},"async function",", and from here we handle the ",[35,351,267],{}," in one place:",[28,354,356],{"className":30,"code":355,"language":32,"meta":33,"style":33},"const catchError = (asFn) => {\n  return asFn.catch((error) => {\n    console.log('error', error);\n  })\n}\n",[35,357,358,378,398,410,414],{"__ignoreMap":33},[38,359,360,362,365,367,369,372,374,376],{"class":40,"line":41},[38,361,199],{"class":44},[38,363,364],{"class":48}," catchError",[38,366,205],{"class":44},[38,368,53],{"class":52},[38,370,371],{"class":56},"asFn",[38,373,88],{"class":52},[38,375,91],{"class":44},[38,377,94],{"class":52},[38,379,380,382,385,387,389,392,394,396],{"class":40,"line":63},[38,381,66],{"class":44},[38,383,384],{"class":52}," asFn.",[38,386,267],{"class":48},[38,388,76],{"class":52},[38,390,391],{"class":56},"error",[38,393,88],{"class":52},[38,395,91],{"class":44},[38,397,94],{"class":52},[38,399,400,402,404,406,408],{"class":40,"line":97},[38,401,252],{"class":52},[38,403,255],{"class":48},[38,405,125],{"class":52},[38,407,282],{"class":128},[38,409,285],{"class":52},[38,411,412],{"class":40,"line":110},[38,413,180],{"class":52},[38,415,416],{"class":40,"line":119},[38,417,186],{"class":52},[17,419,420],{},"So now we can call it like this:",[28,422,424],{"className":30,"code":423,"language":32,"meta":33,"style":33},"catchError(asyncFn(1));\n",[35,425,426],{"__ignoreMap":33},[38,427,428,430,432,435,437,440],{"class":40,"line":41},[38,429,344],{"class":48},[38,431,125],{"class":52},[38,433,434],{"class":48},"asyncFn",[38,436,125],{"class":52},[38,438,439],{"class":72},"1",[38,441,442],{"class":52},"));\n",[17,444,445],{},[446,447],"img",{"alt":448,"src":449},"catchError result in the console","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202022-05-15%2012.19.33.png",[17,451,452],{},"But this version isn't great either. Say you need to pass in an argument, and it just so happens you're inside a loop hitting an API:",[28,454,456],{"className":30,"code":455,"language":32,"meta":33,"style":33},"[1, 2].forEach(catchError(async (n) => {\n  await axios.get(`https:\u002F\u002Fjsonplaceholder.typicode.com\u002Ftodos\u002F${n}`)\n}))\n",[35,457,458,495,518],{"__ignoreMap":33},[38,459,460,463,465,467,470,473,476,478,480,482,484,486,489,491,493],{"class":40,"line":41},[38,461,462],{"class":52},"[",[38,464,439],{"class":72},[38,466,82],{"class":52},[38,468,469],{"class":72},"2",[38,471,472],{"class":52},"].",[38,474,475],{"class":48},"forEach",[38,477,125],{"class":52},[38,479,344],{"class":48},[38,481,125],{"class":52},[38,483,302],{"class":44},[38,485,53],{"class":52},[38,487,488],{"class":56},"n",[38,490,88],{"class":52},[38,492,91],{"class":44},[38,494,94],{"class":52},[38,496,497,500,503,506,508,511,513,516],{"class":40,"line":63},[38,498,499],{"class":44},"  await",[38,501,502],{"class":52}," axios.",[38,504,505],{"class":48},"get",[38,507,125],{"class":52},[38,509,510],{"class":128},"`https:\u002F\u002Fjsonplaceholder.typicode.com\u002Ftodos\u002F${",[38,512,488],{"class":52},[38,514,515],{"class":128},"}`",[38,517,157],{"class":52},[38,519,520],{"class":40,"line":97},[38,521,522],{"class":52},"}))\n",[17,524,525,526,528],{},"You'll notice there's no way to pass the loop value through. That's the first common pattern. To fix this, we need to tweak ",[35,527,344],{}," — we have to wrap another function around the outside:",[28,530,532],{"className":30,"code":531,"language":32,"meta":33,"style":33},"const catchError = (asFn) => {\n  return (n) => {\n    return asFn(n).catch((error) => {\n      console.log('error', error);\n    })\n  }\n}\n",[35,533,534,552,566,589,602,607,611],{"__ignoreMap":33},[38,535,536,538,540,542,544,546,548,550],{"class":40,"line":41},[38,537,199],{"class":44},[38,539,364],{"class":48},[38,541,205],{"class":44},[38,543,53],{"class":52},[38,545,371],{"class":56},[38,547,88],{"class":52},[38,549,91],{"class":44},[38,551,94],{"class":52},[38,553,554,556,558,560,562,564],{"class":40,"line":63},[38,555,66],{"class":44},[38,557,53],{"class":52},[38,559,488],{"class":56},[38,561,88],{"class":52},[38,563,91],{"class":44},[38,565,94],{"class":52},[38,567,568,571,574,577,579,581,583,585,587],{"class":40,"line":97},[38,569,570],{"class":44},"    return",[38,572,573],{"class":48}," asFn",[38,575,576],{"class":52},"(n).",[38,578,267],{"class":48},[38,580,76],{"class":52},[38,582,391],{"class":56},[38,584,88],{"class":52},[38,586,91],{"class":44},[38,588,94],{"class":52},[38,590,591,594,596,598,600],{"class":40,"line":110},[38,592,593],{"class":52},"      console.",[38,595,255],{"class":48},[38,597,125],{"class":52},[38,599,282],{"class":128},[38,601,285],{"class":52},[38,603,604],{"class":40,"line":119},[38,605,606],{"class":52},"    })\n",[38,608,609],{"class":40,"line":135},[38,610,291],{"class":52},[38,612,613],{"class":40,"line":146},[38,614,186],{"class":52},[17,616,617],{},"If you look closely, you'll spot that this is basically a closure. With this version, when you run the loop the value can actually get passed in correctly.",[17,619,620],{},"This is actually a design pattern — it falls under Functional Programming, using the idea of first-class functions to pull it off. I wrote about this a while back too, so here's a reference if you want to dig deeper:",[17,622,623],{},[624,625,627],"a",{"href":626},"\u002Fother\u002F20211219\u002F3830068067\u002F","A casual chat about Functional Programming in JavaScript (article in Mandarin)",[12,629,631],{"id":630},"references","References",[633,634,635],"ul",{},[636,637,638],"li",{},[624,639,643],{"href":640,"rel":641},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[642],"nofollow","JavaScript 核心篇",[645,646,647],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syBk-, html code.shiki .syBk-{--shiki-light:#E36209;--shiki-default:#E36209;--shiki-dark:#FFB757}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki