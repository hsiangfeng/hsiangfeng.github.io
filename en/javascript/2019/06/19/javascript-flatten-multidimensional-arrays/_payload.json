,"https:\u002F\u002Fi.imgur.com\u002FKM8dXLI.png",[17,899,900,901,904,905,911],{},"For ",[38,902,903],{},"flat()",", you can ",[336,906,910],{"href":907,"rel":908},"https:\u002F\u002Fv8.dev\u002Ffeatures\u002Farray-flat-flatmap?fbclid=IwAR0Mml_jRnoagn1FRykdjjjHJtXL0f5mp_sK9Anwp8jLS9iwW0Z1OkgGOA0",[909],"nofollow","check out this article",".",[12,913,915],{"id":914},"references","References",[917,918,919,927],"ul",{},[920,921,922],"li",{},[336,923,926],{"href":924,"rel":925},"http:\u002F\u002Fwww.jstips.co\u002Fen\u002Fjavascript\u002Fflattening-multidimensional-arrays-in-javascript\u002F",[909],"Flattening multidimensional arrays in JavaScript",[920,928,929],{},[336,930,932],{"href":907,"rel":931},[909],"Array.prototype.flat and Array.prototype.flatMap",[12,934,936],{"id":935},"bonus","Bonus",[17,938,939],{},"Here's a recursive example and solution that a fellow blogger, Yuxuan, shared with me:",[31,941,943],{"className":33,"code":942,"language":35,"meta":36,"style":36},"\u002F\u002F Exercise 2: Flatten an array\n\u002F\u002F Write a function flatten that takes a multidimensional array and returns the \"flattened\" array.\n\u002F\u002F flatten([1, 2, 3]) expected return: [1, 2, 3]\n\u002F\u002F flatten([1, 2, [1, 2], [1, 3], 6]) expected return: [1, 2, 1, 2, 1, 3, 6]\n\u002F\u002F flatten([1, [2, [3, [4]], 5], 6]) expected return: [1, 2, 3, 4, 5, 6]\n\u002F\u002F recursion\nfunction flatten(array) {\n  let tempArray = [];\n  for (let i = 0; i \u003C array.length; i++) {\n    if (Array.isArray(array[i])) {\n      \u002F\u002F flatten the array by calling itself\n      let flat = flatten(array[i]); \u002F\u002F ex [1, 2, 3]\n      \u002F\u002F push into the array\n      for (let j = 0; j \u003C flat.length; j++) {\n        tempArray.push(flat[j]);\n      }\n    } else {\n      tempArray.push(array[i]);\n    }\n  }\n  return tempArray;\n}\n",[38,944,945,951,956,961,966,971,976,992,1005,1045,1060,1066,1085,1091,1125,1136,1142,1153,1164,1170,1176,1184],{"__ignoreMap":36}