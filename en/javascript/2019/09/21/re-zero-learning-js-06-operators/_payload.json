[{"data":1,"prerenderedAt":754},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F":729,"related:\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F":738},"\u002Fjavascript\u002F20190921\u002F1280863990\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":712,"date":713,"description":714,"extension":715,"lang":716,"meta":717,"navigation":193,"path":718,"readingMinutes":719,"seo":720,"standalone":721,"stem":722,"tags":723,"tldr":726,"updated":713,"url":727,"__hash__":728},"content\u002Fen\u002FJavaScript\u002Fre-zero-learning-js-06-operators.md","RE:Zero — Learning JS From Scratch, Day 6: Operators (and Why 1 + '1' Is '11')","1002233161",{"type":9,"value":10,"toc":704},"minimark",[11,16,20,24,68,90,96,103,107,110,283,287,298,359,362,385,421,427,430,438,448,498,510,514,520,551,554,584,595,601,629,636,643,687,693,697,700],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Day 6 of my reincarnated JS life. This time we're going to talk about operators. We've already run into a few of them in earlier posts, but here I want to go through the common ones a bit more properly.",[12,21,23],{"id":22},"operators","Operators",[17,25,26,27,31,32,35,36,39,40,43,44,47,48,51,52,55,56,59,60,63,64,34],{},"In everyday dev work, the two operators you see the most are the assignment operator (",[28,29,30],"code",{},"=",") and the dot operator (",[28,33,34],{},".","). But there are plenty of others — the plus operator (",[28,37,38],{},"+","), minus operator (",[28,41,42],{},"-","), multiply operator (",[28,45,46],{},"*","), divide operator (",[28,49,50],{},"\u002F","), increment operator (",[28,53,54],{},"++","), decrement operator (",[28,57,58],{},"--","), modulo operator (",[28,61,62],{},"%","), and so on. That bunch is collectively called ",[65,66,67],"strong",{},"arithmetic operators",[17,69,70,71,74,75,78,79,82,83,86,87,34],{},"There's another group too: greater-than (",[28,72,73],{},">","), less-than (",[28,76,77],{},"\u003C","), greater-than-or-equal (",[28,80,81],{},">=","), less-than-or-equal (",[28,84,85],{},"\u003C=","), and friends. These are called ",[65,88,89],{},"comparison operators",[17,91,92],{},[93,94],"img",{"alt":23,"src":95},"https:\u002F\u002Fi.imgur.com\u002FRTjQZm3.png",[17,97,98,99,102],{},"And there's one more group called ",[65,100,101],{},"logical operators",", but on Day 6 we're going to skip those for now.",[12,104,106],{"id":105},"arithmetic-operators","Arithmetic Operators",[17,108,109],{},"We've touched on arithmetic operators already. Like the name says, they do calculations — so honestly the fastest way to explain is to just look at an example:",[111,112,117],"pre",{"className":113,"code":114,"language":115,"meta":116,"style":116},"language-js shiki shiki-themes github-dark-high-contrast","10 + 10; \u002F\u002F 20\n10 - 2; \u002F\u002F 8\n10 * 2; \u002F\u002F 20\n10 \u002F 2; \u002F\u002F 5\n\n\u002F\u002F The increment operator has to work through a variable\nvar a = 10;\na++; \u002F\u002F 11 — ++ means +1\n\nvar b = 10;\nb--; \u002F\u002F 9 — -- means -1\n\n10 % 4; \u002F\u002F 2\n","js","",[28,118,119,143,159,173,188,195,201,217,230,235,249,262,267],{"__ignoreMap":116},[120,121,124,128,132,135,139],"span",{"class":122,"line":123},"line",1,[120,125,127],{"class":126},"sCcAr","10",[120,129,131],{"class":130},"sWyjQ"," +",[120,133,134],{"class":126}," 10",[120,136,138],{"class":137},"sMAXC","; ",[120,140,142],{"class":141},"sQrFR","\u002F\u002F 20\n",[120,144,146,148,151,154,156],{"class":122,"line":145},2,[120,147,127],{"class":126},[120,149,150],{"class":130}," -",[120,152,153],{"class":126}," 2",[120,155,138],{"class":137},[120,157,158],{"class":141},"\u002F\u002F 8\n",[120,160,162,164,167,169,171],{"class":122,"line":161},3,[120,163,127],{"class":126},[120,165,166],{"class":130}," *",[120,168,153],{"class":126},[120,170,138],{"class":137},[120,172,142],{"class":141},[120,174,176,178,181,183,185],{"class":122,"line":175},4,[120,177,127],{"class":126},[120,179,180],{"class":130}," \u002F",[120,182,153],{"class":126},[120,184,138],{"class":137},[120,186,187],{"class":141},"\u002F\u002F 5\n",[120,189,191],{"class":122,"line":190},5,[120,192,194],{"emptyLinePlaceholder":193},true,"\n",[120,196,198],{"class":122,"line":197},6,[120,199,200],{"class":141},"\u002F\u002F The increment operator has to work through a variable\n",[120,202,204,207,210,212,214],{"class":122,"line":203},7,[120,205,206],{"class":130},"var",[120,208,209],{"class":137}," a ",[120,211,30],{"class":130},[120,213,134],{"class":126},[120,215,216],{"class":137},";\n",[120,218,220,223,225,227],{"class":122,"line":219},8,[120,221,222],{"class":137},"a",[120,224,54],{"class":130},[120,226,138],{"class":137},[120,228,229],{"class":141},"\u002F\u002F 11 — ++ means +1\n",[120,231,233],{"class":122,"line":232},9,[120,234,194],{"emptyLinePlaceholder":193},[120,236,238,240,243,245,247],{"class":122,"line":237},10,[120,239,206],{"class":130},[120,241,242],{"class":137}," b ",[120,244,30],{"class":130},[120,246,134],{"class":126},[120,248,216],{"class":137},[120,250,252,255,257,259],{"class":122,"line":251},11,[120,253,254],{"class":137},"b",[120,256,58],{"class":130},[120,258,138],{"class":137},[120,260,261],{"class":141},"\u002F\u002F 9 — -- means -1\n",[120,263,265],{"class":122,"line":264},12,[120,266,194],{"emptyLinePlaceholder":193},[120,268,270,272,275,278,280],{"class":122,"line":269},13,[120,271,127],{"class":126},[120,273,274],{"class":130}," %",[120,276,277],{"class":126}," 4",[120,279,138],{"class":137},[120,281,282],{"class":141},"\u002F\u002F 2\n",[12,284,286],{"id":285},"comparison-operators","Comparison Operators",[17,288,289,290,293,294,297],{},"Comparison operators compare two (or more) things and return a boolean — ",[28,291,292],{},"true"," or ",[28,295,296],{},"false",". So again, let's just look at an example:",[111,299,301],{"className":113,"code":300,"language":115,"meta":116,"style":116},"10 > 5; \u002F\u002F true\n10 \u003C 5; \u002F\u002F false\n10 >= 10; \u002F\u002F true — but 10 > 10; would be false\n10 \u003C= 5; \u002F\u002F false\n",[28,302,303,318,332,346],{"__ignoreMap":116},[120,304,305,307,310,313,315],{"class":122,"line":123},[120,306,127],{"class":126},[120,308,309],{"class":130}," >",[120,311,312],{"class":126}," 5",[120,314,138],{"class":137},[120,316,317],{"class":141},"\u002F\u002F true\n",[120,319,320,322,325,327,329],{"class":122,"line":145},[120,321,127],{"class":126},[120,323,324],{"class":130}," \u003C",[120,326,312],{"class":126},[120,328,138],{"class":137},[120,330,331],{"class":141},"\u002F\u002F false\n",[120,333,334,336,339,341,343],{"class":122,"line":161},[120,335,127],{"class":126},[120,337,338],{"class":130}," >=",[120,340,134],{"class":126},[120,342,138],{"class":137},[120,344,345],{"class":141},"\u002F\u002F true — but 10 > 10; would be false\n",[120,347,348,350,353,355,357],{"class":122,"line":175},[120,349,127],{"class":126},[120,351,352],{"class":130}," \u003C=",[120,354,312],{"class":126},[120,356,138],{"class":137},[120,358,331],{"class":141},[17,360,361],{},"There are also a couple of common comparison operators worth calling out:",[363,364,365,376],"ul",{},[366,367,368,371,372,375],"li",{},[28,369,370],{},"=="," & ",[28,373,374],{},"==="," — equality operators",[366,377,378,371,381,384],{},[28,379,380],{},"!=",[28,382,383],{},"!=="," — inequality operators",[17,386,387,388,371,390,392,393,371,395,397,398,371,400,402,403,406,407,409,410,371,412,414,415,418,419,34],{},"You might be wondering what the difference is between ",[28,389,370],{},[28,391,380],{}," and ",[28,394,374],{},[28,396,383],{},". In short: ",[28,399,370],{},[28,401,380],{}," do loose comparison. When you type ",[28,404,405],{},"1 == '1';",", you get ",[28,408,292],{},". Meanwhile ",[28,411,374],{},[28,413,383],{}," do strict comparison — they check the type too — so ",[28,416,417],{},"1 === '1';"," gives you ",[28,420,296],{},[17,422,423],{},[93,424],{"alt":425,"src":426},"Strict vs loose comparison","https:\u002F\u002Fi.imgur.com\u002FCxx3LDa.png",[17,428,429],{},"For real-world dev work, I'd recommend using strict comparison over loose comparison. So we can sum it up like this:",[363,431,432,435],{},[366,433,434],{},"regular equal or not-equal (loose comparison)",[366,436,437],{},"strict equal or not-equal (strict comparison)",[17,439,440,441,444,445,447],{},"There's also another special bit of syntax: ",[28,442,443],{},"Object.is",". It was added in ES6, and ",[28,446,443],{}," falls under strict comparison:",[111,449,451],{"className":113,"code":450,"language":115,"meta":116,"style":116},"Object.is(1, '1'); \u002F\u002F false\nObject.is('1', '1'); \u002F\u002F true\n",[28,452,453,480],{"__ignoreMap":116},[120,454,455,458,462,465,468,471,475,478],{"class":122,"line":123},[120,456,457],{"class":137},"Object.",[120,459,461],{"class":460},"sj_SG","is",[120,463,464],{"class":137},"(",[120,466,467],{"class":126},"1",[120,469,470],{"class":137},", ",[120,472,474],{"class":473},"sTRMh","'1'",[120,476,477],{"class":137},"); ",[120,479,331],{"class":141},[120,481,482,484,486,488,490,492,494,496],{"class":122,"line":145},[120,483,457],{"class":137},[120,485,461],{"class":460},[120,487,464],{"class":137},[120,489,474],{"class":473},[120,491,470],{"class":137},[120,493,474],{"class":473},[120,495,477],{"class":137},[120,497,317],{"class":141},[17,499,500,501,503,504,34],{},"If you want to dig into ",[28,502,443],{},", check out the ",[222,505,509],{"href":506,"rel":507},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FGlobal_Objects\u002FObject\u002Fis",[508],"nofollow","docs from MDN",[12,511,513],{"id":512},"the-string-concatenation-operator","The String Concatenation Operator",[17,515,516,517,519],{},"Last one — let's talk about a special operator, the plus operator (",[28,518,38],{},"). The plus operator is actually pretty interesting. On top of working as an arithmetic operator, it can also act as a string concatenation operator, joining two strings together:",[111,521,523],{"className":113,"code":522,"language":115,"meta":116,"style":116},"var a = 'Hello' + ' World';\na; \u002F\u002F Hello World\n",[28,524,525,543],{"__ignoreMap":116},[120,526,527,529,531,533,536,538,541],{"class":122,"line":123},[120,528,206],{"class":130},[120,530,209],{"class":137},[120,532,30],{"class":130},[120,534,535],{"class":473}," 'Hello'",[120,537,131],{"class":130},[120,539,540],{"class":473}," ' World'",[120,542,216],{"class":137},[120,544,545,548],{"class":122,"line":145},[120,546,547],{"class":137},"a; ",[120,549,550],{"class":141},"\u002F\u002F Hello World\n",[17,552,553],{},"But there's a situation where one side is a number type and the other is a string type. We already know the plus operator can add numbers, so what happens with something like this?",[111,555,557],{"className":113,"code":556,"language":115,"meta":116,"style":116},"var a = 1 + '1';\na; \u002F\u002F 11\n",[28,558,559,577],{"__ignoreMap":116},[120,560,561,563,565,567,570,572,575],{"class":122,"line":123},[120,562,206],{"class":130},[120,564,209],{"class":137},[120,566,30],{"class":130},[120,568,569],{"class":126}," 1",[120,571,131],{"class":130},[120,573,574],{"class":473}," '1'",[120,576,216],{"class":137},[120,578,579,581],{"class":122,"line":145},[120,580,547],{"class":137},[120,582,583],{"class":141},"\u002F\u002F 11\n",[17,585,586,587,590,591,594],{},"You actually get ",[28,588,589],{},"11",", not ",[28,592,593],{},"2",". The way to understand it is simple: as long as there's a string in there (meaning something wrapped in single or double quotes), it's always going to be string concatenation.",[17,596,597,598,600],{},"But here's a pretty interesting twist — if you switch it to the minus operator (",[28,599,42],{},"), things get weird:",[111,602,604],{"className":113,"code":603,"language":115,"meta":116,"style":116},"var a = 1 - '1';\na; \u002F\u002F 0\n",[28,605,606,622],{"__ignoreMap":116},[120,607,608,610,612,614,616,618,620],{"class":122,"line":123},[120,609,206],{"class":130},[120,611,209],{"class":137},[120,613,30],{"class":130},[120,615,569],{"class":126},[120,617,150],{"class":130},[120,619,574],{"class":473},[120,621,216],{"class":137},[120,623,624,626],{"class":122,"line":145},[120,625,547],{"class":137},[120,627,628],{"class":141},"\u002F\u002F 0\n",[17,630,631,632,635],{},"You'll find you somehow get ",[28,633,634],{},"0",". That has to do with JavaScript's automatic type coercion, which I'll cover later.",[17,637,638,639,642],{},"And finally, if you try to multiply a string by a string, all you get is an error — well, ",[28,640,641],{},"NaN",", which stands for \"not a number,\" basically telling you this isn't a number:",[111,644,646],{"className":113,"code":645,"language":115,"meta":116,"style":116},"var a = 'qq';\nvar b = 'aa';\na * b; \u002F\u002F NaN\n",[28,647,648,661,674],{"__ignoreMap":116},[120,649,650,652,654,656,659],{"class":122,"line":123},[120,651,206],{"class":130},[120,653,209],{"class":137},[120,655,30],{"class":130},[120,657,658],{"class":473}," 'qq'",[120,660,216],{"class":137},[120,662,663,665,667,669,672],{"class":122,"line":145},[120,664,206],{"class":130},[120,666,242],{"class":137},[120,668,30],{"class":130},[120,670,671],{"class":473}," 'aa'",[120,673,216],{"class":137},[120,675,676,679,681,684],{"class":122,"line":161},[120,677,678],{"class":137},"a ",[120,680,46],{"class":130},[120,682,683],{"class":137}," b; ",[120,685,686],{"class":141},"\u002F\u002F NaN\n",[17,688,689],{},[93,690],{"alt":691,"src":692},"not a number","https:\u002F\u002Fi.imgur.com\u002Fonyaybn.png",[12,694,696],{"id":695},"wrapping-up","Wrapping Up",[17,698,699],{},"The next RE:Zero — Learning JS From Scratch, Day 6 post will introduce functions.",[701,702,703],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":116,"searchDepth":145,"depth":145,"links":705},[706,707,708,709,710,711],{"id":14,"depth":145,"text":15},{"id":22,"depth":145,"text":23},{"id":105,"depth":145,"text":106},{"id":285,"depth":145,"text":286},{"id":512,"depth":145,"text":513},{"id":695,"depth":145,"text":696},"JavaScript","2019-09-21 00:01:15","Day 6 of my reincarnated JS life. This time we cover operators. We've already bumped into a few of them, but here I want to walk through the common ones properly — arithmetic operators, comparison operators, loose vs strict equality, and that weird thing where 1 + '1' gives you '11' instead of 2.","md","en",{},"\u002Fen\u002Fjavascript\u002Fre-zero-learning-js-06-operators","3",{"title":6,"description":714},false,"en\u002FJavaScript\u002Fre-zero-learning-js-06-operators",[712,724,725],"RE:Zero — Learning JS From Scratch","11th iThome Ironman Contest",null,"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F","KmuvE5UjWNHu4gqWeGZ7TdBEkOIEHOZRyx5RHWVeOTo",{"newer":730,"older":734},{"url":731,"title":732,"date":733},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F22\u002Fre-learning-js-from-zero-07-functions\u002F","Re:Learning JS From Zero — Day 7: Functions, Your Reusable Code Wrappers","2019-09-22 00:01:10",{"url":735,"title":736,"date":737},"\u002Fen\u002Fphp\u002F2019\u002F09\u002F21\u002Fthinkphp-day-20-import-bootstrap\u002F","Learning ThinkPHP from Scratch Day 20 - Pulling Bootstrap into Your Layout","2019-09-21 00:01:05",[739,744,749],{"url":740,"title":741,"date":742,"readingMinutes":743},"\u002Fen\u002Fjavascript\u002F2026\u002F03\u002F10\u002Fweb-crypto-api-encryption-guide\u002F","No crypto Package, No Node.js — The Web Crypto API Does It All in the Browser","2026-03-10 09:45:08","9",{"url":745,"title":746,"date":747,"readingMinutes":748},"\u002Fen\u002Fjavascript\u002F2025\u002F12\u002F08\u002Fjquery-why-it-declined\u002F","jQuery Was Once King — So Why Did It Fall Off?","2025-12-08 21:35:24","7",{"url":750,"title":751,"date":752,"readingMinutes":753},"\u002Fen\u002Fjavascript\u002F2025\u002F12\u002F05\u002Fjavascript-generator-functions\u002F","What Are JavaScript Generator Functions (function*)? The Function You Can Pause and Resume","2025-12-05 13:40:31","5",1784013059969]