 reject) => {\n    if(status) {\n      console.log(`${name} 起跑了!`)\n      return setTimeout(() => {\n        resolve(`${name} 衝了 ${time \u002F 1000}秒`)\n      },time);\n    } else {\n     reject(new Error(`${name} 出現錯誤`));\n    };\n  });\n};\n\u002F\u002F If runner fails, return an error message\n\nlet asyncPromise = async function() {\n  let min = await runPromiss('小明', 3000, true);\n  let wei = await runPromiss('小王', 1000, true);\n  return `${min},${wei}`;\n}\nasyncPromise().then((res)=>{\n  console.log(res)\n}).catch((error) => {\n  console.log(error);\n});\n\nconsole.log('我偷偷執行了');\n","js","",[21,56,57,101,131,140,164,180,208,214,225,251,257,263,269,276,283,302,337,367,390,396,421,432,452,462,468,473],{"__ignoreMap":54},[58,59,62,66,70,73,77,81,84,87,89,92,95,98],"span",{"class":60,"line":61},"line",1,[58,63,65],{"class":64},"sWyjQ","let",[58,67,69],{"class":68},"sj_SG"," runPromiss",[58,71,72],{"class":64}," =",[58,74,76],{"class":75},"sMAXC"," (",[58,78,80],{"class":79},"s_sBn","name",[58,82,83],{"class":75},", ",[58,85,86],{"class":79},"time",[58,88,83],{"class":75},[58,90,91],{"class":79},"status",[58,93,94],{"class":75},") ",[58,96,97],{"class":64},"=>",[58,99,100],{"class":75}," {\n",[58,102,104,107,110,114,117,120,122,125,127,129],{"class":60,"line":103},2,[58,105,106],{"class":64},"  return",[58,108,109],{"class":64}," new",[58,111,113],{"class":112},"sCcAr"," Promise",[58,115,116],{"class":75},"((",[58,118,119],{"class":79},"resolve",[58,121,83],{"class":75},[58,123,124],{"class":79},"reject",[58,126,94],{"class":75},[58,128,97],{"class":64},[58,130,100],{"class":75},[58,132,134,137],{"class":60,"line":133},3,[58,135,136],{"class":64},"    if",[58,138,139],{"class":75},"(status) {\n",[58,141,143,146,149,152,156,158,161],{"class":60,"line":142},4,[58,144,145],{"class":75},"      console.",[58,147,148],{"class":68},"log",[58,150,151],{"class":75},"(",[58,153,155],{"class":154},"sTRMh","`${",[58,157,80],{"class":75},[58,159,160],{"class":154},"} 起跑了!`",[58