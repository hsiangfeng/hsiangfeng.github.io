[104,313,315,318,321],{"class":106,"line":314},8,[104,316,317],{"class":114},"    } ",[104,319,320],{"class":110},"else",[104,322,147],{"class":114},[104,324,326,329,331,334,337,339,341,343,346],{"class":106,"line":325},9,[104,327,328],{"class":181},"     reject",[104,330,249],{"class":114},[104,332,333],{"class":110},"new",[104,335,336],{"class":181}," Error",[104,338,249],{"class":114},[104,340,253],{"class":252},[104,342,191],{"class":114},[104,344,345],{"class":252},"} hit an error`",[104,347,348],{"class":114},"));\n",[104,350,352],{"class":106,"line":351},10,[104,353,354],{"class":114},"    };\n",[104,356,358],{"class":106,"line":357},11,[104,359,360],{"class":114},"  });\n",[104,362,364],{"class":106,"line":363},12,[104,365,366],{"class":114},"};\n",[104,368,370],{"class":106,"line":369},13,[104,371,372],{"class":153},"\u002F\u002F Ming fails, so it returns an error message\n",[104,374,376,379,381,384,386,389,391,394,397,400,402,405,407,409],{"class":106,"line":375},14,[104,377,378],{"class":181},"runPromiss",[104,380,249],{"class":114},[104,382,383],{"class":252},"'Ming'",[104,385,135],{"class":114},[104,387,388],{"class":124},"3000",[104,390,135],{"class":114},[104,392,393],{"class":124},"false",[104,395,396],{"class":114},").",[104,398,399],{"class":181},"then",[104,401,128],{"class":114},[104,403,404],{"class":131},"res",[104,406,141],{"class":114},[104,408,144],{"class":110},[104,410,147],{"class":114},[104,412,414,417,419],{"class":106,"line":413},15,[104,415,416],{"class":114},"  console.",[104,418,246],{"class":181},[104,420,421],{"class":114},"(res);\n",[104,423,425,427,429,431,434,436,439,441,444],{"class":106,"line":424},16,[104,426,212],{"class":110},[104,428,182],{"class":181},[104,430,249],{"class":114},[104,432,433],{"class":252},"'Wang'",[104,435,135],{"class":114},[104,437,438],{"class":124},"1000",[104,440,135],{"class":114},[104,442,443],{"class":124},"true",[104,445,261],{"class":114},[104,447,449,452,454,456,458,460,462],{"class":106,"line":448},17,[104,450,451],{"class":114},"}).",[104,453,399],{"class":181},[104,455,128],{"class":114},[104,457,404],{"class":131},[104,459,141],{"class":114},[104,461,144],{"class":110},[104,463,147],{"class":114},[104,465,467,469,471],{"class":106,"line":466},18,[104,468,416],{"class":114},[104,470,246],{"class":181},[104,472,421],{"class":114},[104,474,476,478,481,483,486,488,490],{"class":106,"line":475},19,[104,477,451],{"class":114},[104,479,480],{"class":181},"catch",[104,482,128],{"class":114},[104,484,485],{"class":131},"error",[104,487,141],{"class":114},[104,489,144],{"class":110},[104,491,147],{"class":114},[104,493,495,497,499],{"class":106,"line":494},20,[104,496,416],{"class":114},[104,498,246],{"class":181},[104,500,501],{"class":114},"(error);\n",[104,503,505],{"class":106,"line":504},21,[104,506,166],{"class":114},[17,508,509],{},"From the case above, you can see that once Ming fails, it returns the error message right away.",[17,511,512],{},[59,513],{"alt":514,"src":515},"Ming failed","https:\u002F\u002Fi.imgur.com\u002FVjYjgAH.png",[17,517,518],{},"But if Ming finishes the run successfully, then next we'll see Wang start running too.",[17,520,521],{},[59,522],{"alt":523,"src":524},"Wang takes off!","https:\u002F\u002Fi.imgur.com\u002FulBXMm1.png",[526,527,532],"iframe",{"height":528,"style":529,"scrolling":530,"title":76,"src":531,"frameBorder":530,"allowTransparency":443,"allowFullScreen":443},265,"width: 100%;","no","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FgJBWQL\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FgJBWQL\u002F'>Promise\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[87,534,536],{"id":535},"one-thing-to-watch-out-for","One thing to watch out for",[17,538,539,540,542,543,546],{},"So this is how we handle async events. There's one thing you absolutely need to know though: if a Promise doesn't return ",[20,541,132],{},", then the next ",[20,544,545],{},".then"," won't run. Like this ↓",[95,548,550],{"className":97,"code":549,"language":99,"meta":100,"style":100},"let runPromiss = (name, time, status) => {\n  return new Promise((resolve, reject) => {\n    if(status) {\n      console.log(`${name} is off!`)\n      return setTimeout(() => {\n        console.log(`${name} ran for ${time \u002F 1000} s`)\n      },time);\n    } else {\n     reject(new Error(`${name} hit an error`));\n    };\n  });\n};\n\u002F\u002F Ming fails, so it returns an error message\nrunPromiss('Ming', 3000, true).then((res) => {\n  console.log(res);\n  return runPromiss('Wang', 1000, true)\n}).then((res) => {\n  console.log(res);\n}).catch((error) => {\n  console.log(error);\n})\n",[20,551,552,578,600,606,622,634,660,664,672,692,696,700,704,708,738,746,766,782,790,806,814],{"__ignoreMap":100},[104,553,554,556,558,560,562,564,566,568,570,572,574,576],{"class":106,"line":107},[104,555,111],{"class":110},[104,557,182],{"class":181},[104,559,185],{"class":110},[104,561,188],{"class":114},[104,563,191],{"class":131},[104,565,135],{"class":114},[104,567,196],{"class":131},[104,569,135],{"class":114},[104,571,201],{"class":131},[104,573,141],{"class":114},[104,575,144],{"class":110},[104,577,147],{"class":114},[104,579,580,582,584,586,588,590,592,594,596,598],{"class":106,"line":150},[104,581,212],{"class":110},[104,583,121],{"class":110},[104,585,125],{"class":124},[104,587,128],{"class":114},[104,589,132],{"class":131},[104,591,135],{"class":114},[104,593,138],{"class":131},[104,595,141],{"class":114},[104,597,144],{"class":110},[104,599,147],{"class":114},[104,601,602,604],{"class":106,"line":157},[104,603,235],{"class":110},[104,605,238],{"class":114},[104,607,608,610,612,614,616,618,620],{"class":106,"line":163},[104,609,243],{"class":114},[104,611,246],{"class":181},[104,613,249],{"class":11