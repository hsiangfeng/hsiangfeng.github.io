[{"data":1,"prerenderedAt":706},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F14\u002Fjs-from-zero-ep29-template-string\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F14\u002Fjs-from-zero-ep29-template-string\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F14\u002Fjs-from-zero-ep29-template-string\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F14\u002Fjs-from-zero-ep29-template-string\u002F":681,"related:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F14\u002Fjs-from-zero-ep29-template-string\u002F":690},"\u002Fjavascript\u002F20191014\u002F321662173\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":663,"date":664,"description":665,"extension":666,"lang":667,"meta":668,"navigation":669,"path":670,"readingMinutes":671,"seo":672,"standalone":673,"stem":674,"tags":675,"tldr":678,"updated":664,"url":679,"__hash__":680},"content\u002Fen\u002FJavaScript\u002Fjs-from-zero-ep29-template-string.md","JS From Zero, Day 29: Template Strings Will Spoil You Forever","1002193566",{"type":9,"value":10,"toc":658},"minimark",[11,16,20,24,32,39,42,99,105,119,155,161,180,183,439,442,640,643,647,654],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Day 29 of the reincarnation. This time we're covering ES6's Template Strings.",[12,21,23],{"id":22},"template-string","Template String",[17,25,26,27,31],{},"Template Strings are one of my personal favorite ES6 features. Back in the early days of writing JS, whenever we wanted to build a string we had to use single or double quotes glued together with a ",[28,29,30],"code",{},"+"," sign, like this:",[17,33,34],{},[35,36],"img",{"alt":37,"src":38},"the plus operator","https:\u002F\u002Fi.imgur.com\u002Fs41WCev.png",[17,40,41],{},"And when the string you're building gets long, it turns into a real pain. Something like this:",[43,44,49],"pre",{"className":45,"code":46,"language":47,"meta":48,"style":48},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Ray';\nvar hello = 'Hello' + a + '，你好';\n","js","",[28,50,51,74],{"__ignoreMap":48},[52,53,56,60,64,67,71],"span",{"class":54,"line":55},"line",1,[52,57,59],{"class":58},"sWyjQ","var",[52,61,63],{"class":62},"sMAXC"," a ",[52,65,66],{"class":58},"=",[52,68,70],{"class":69},"sTRMh"," 'Ray'",[52,72,73],{"class":62},";\n",[52,75,77,79,82,84,87,90,92,94,97],{"class":54,"line":76},2,[52,78,59],{"class":58},[52,80,81],{"class":62}," hello ",[52,83,66],{"class":58},[52,85,86],{"class":69}," 'Hello'",[52,88,89],{"class":58}," +",[52,91,63],{"class":62},[52,93,30],{"class":58},[52,95,96],{"class":69}," '，你好'",[52,98,73],{"class":62},[17,100,101,102,104],{},"You end up with more and more quotes, more and more ",[28,103,30],{}," operators. The more you write, the harder it is to read, and there's a pretty good chance you'll accidentally delete a quote or a plus along the way. On top of that, if the string is too long you have to drop in a backslash to break the line.",[17,106,107,108,111,112,115,116,118],{},"ES6's Template String exists specifically to solve this string-building headache. Basically you use two backticks ",[28,109,110],{},"`"," plus ",[28,113,114],{},"${}",", where ",[28,117,114],{}," is where you drop a variable in. So we can rewrite the example above like this:",[43,120,122],{"className":45,"code":121,"language":47,"meta":48,"style":48},"var a = 'Ray';\nvar hello = `Hello ${a}，你好`;\n",[28,123,124,136],{"__ignoreMap":48},[52,125,126,128,130,132,134],{"class":54,"line":55},[52,127,59],{"class":58},[52,129,63],{"class":62},[52,131,66],{"class":58},[52,133,70],{"class":69},[52,135,73],{"class":62},[52,137,138,140,142,144,147,150,153],{"class":54,"line":76},[52,139,59],{"class":58},[52,141,81],{"class":62},[52,143,66],{"class":58},[52,145,146],{"class":69}," `Hello ${",[52,148,149],{"class":62},"a",[52,151,152],{"class":69},"}，你好`",[52,154,73],{"class":62},[17,156,157,158,160],{},"Way nicer to write, right? And if the ",[28,159,114],{}," looks a little like Ruby to you — yeah, ES6 borrowed good ideas from other languages. The upsides of Template Strings come down to a few things:",[162,163,164,168,174,177],"ul",{},[165,166,167],"li",{},"Fewer quotes",[165,169,170,171,173],{},"No more ",[28,172,30],{}," operator for gluing strings together",[165,175,176],{},"No backslash needed for line breaks",[165,178,179],{},"You can even put expressions inside a Template String",[17,181,182],{},"Let's look at a real-world example to really feel the difference. Here's a snippet from one of my little practice exercises:",[43,184,186],{"className":45,"code":185,"language":47,"meta":48,"style":48},"function updataList(data) {\n    str = '';\n    var len = data.length;\n    for (var i = 0; i \u003C len; i++) {\n        str += '\u003Cli class=text-center ' + 123 + '>';\n        str += '\u003Cspan>' + data[i].status + '\u003C\u002Fspan>';\n        str += '\u003Cspan>\u003Cspan>BMI\u003C\u002Fspan> ' + data[i].bmi + '\u003C\u002Fspan>';\n        str += '\u003Cspan>\u003Cspan>height\u003C\u002Fspan> ' + data[i].weight + ' kg \u003C\u002Fspan>';\n        str += '\u003Cspan>\u003Cspan>weight\u003C\u002Fspan> ' + data[i].height + ' cm \u003C\u002Fspan>';\n        str += '\u003Ca href=\"#\" data-index=' + i + ' \u002F>刪除\u003C\u002Fa>';\n        str += '\u003C\u002Fli>';\n    }\n    bmiList.innerHTML = str;\n}\n",[28,187,188,207,219,239,272,296,318,339,361,383,404,416,422,433],{"__ignoreMap":48},[52,189,190,193,197,200,204],{"class":54,"line":55},[52,191,192],{"class":58},"function",[52,194,196],{"class":195},"sj_SG"," updataList",[52,198,199],{"class":62},"(",[52,201,203],{"class":202},"s_sBn","data",[52,205,206],{"class":62},") {\n",[52,208,209,212,214,217],{"class":54,"line":76},[52,210,211],{"class":62},"    str ",[52,213,66],{"class":58},[52,215,216],{"class":69}," ''",[52,218,73],{"class":62},[52,220,222,225,228,230,233,237],{"class":54,"line":221},3,[52,223,224],{"class":58},"    var",[52,226,227],{