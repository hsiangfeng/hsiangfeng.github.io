,"line":363},9,[52,365,277],{"class":62},[52,367,280],{"class":58},[52,369,370],{"class":69}," '\u003Cspan>\u003Cspan>weight\u003C\u002Fspan> '",[52,372,89],{"class":58},[52,374,375],{"class":62}," data[i].height ",[52,377,30],{"class":58},[52,379,380],{"class":69}," ' cm \u003C\u002Fspan>'",[52,382,73],{"class":62},[52,384,386,388,390,393,395,397,399,402],{"class":54,"line":385},10,[52,387,277],{"class":62},[52,389,280],{"class":58},[52,391,392],{"class":69}," '\u003Ca href=\"#\" data-index='",[52,394,89],{"class":58},[52,396,252],{"class":62},[52,398,30],{"class":58},[52,400,401],{"class":69}," ' \u002F>刪除\u003C\u002Fa>'",[52,403,73],{"class":62},[52,405,407,409,411,414],{"class":54,"line":406},11,[52,408,277],{"class":62},[52,410,280],{"class":58},[52,412,413],{"class":69}," '\u003C\u002Fli>'",[52,415,73],{"class":62},[52,417,419],{"class":54,"line":418},12,[52,420,421],{"class":62},"    }\n",[52,423,425,428,430],{"class":54,"line":424},13,[52,426,427],{"class":62},"    bmiList.innerHTML ",[52,429,66],{"class":58},[52,431,432],{"class":62}," str;\n",[52,434,436],{"class":54,"line":435},14,[52,437,438],{"class":62},"}\n",[17,440,441],{},"Later I rewrote it with ES6 Template Strings, and it became this:",[43,443,445],{"className":45,"code":444,"language":47,"meta":48,"style":48},"function updataList(data) {\n    str = '';\n    var len = data.length;\n    for (var i = 0; i \u003C len; i++) {\n        str += `\n        \u003Cli class=text-center>\n          \u003Cspan>${data[i].status}\u003C\u002Fspan>\n          \u003Cspan>\u003Cspan>BMI\u003C\u002Fspan> ${data[i].bmi} \u003C\u002Fspan>\n          \u003Cspan>\u003Cspan>height\u003C\u002Fspan> ${data[i].weight} kg \u003C\u002Fspan>\n          \u003Cspan>\u003Cspan>weight\u003C\u002Fspan> ${data[i].height} cm \u003C\u002Fspan>\n          \u003Ca href=\"#\" data-index=\"${i}\"\u002F>刪除\u003C\u002Fa>\n        \u003C\u002Fli>\n        `;\n    }\n    bmiList.innerHTML = str;\n}\n",[28,446,447,459,469,483,507,516,521,543,5