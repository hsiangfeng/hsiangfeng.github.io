[{"data":1,"prerenderedAt":965},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F06\u002Fjs-from-zero-21-date-time\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F06\u002Fjs-from-zero-21-date-time\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F06\u002Fjs-from-zero-21-date-time\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F06\u002Fjs-from-zero-21-date-time\u002F":940,"related:\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F06\u002Fjs-from-zero-21-date-time\u002F":949},"\u002Fjavascript\u002F20191006\u002F2165491615\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":923,"date":924,"description":925,"extension":926,"lang":927,"meta":928,"navigation":507,"path":929,"readingMinutes":930,"seo":931,"standalone":932,"stem":933,"tags":934,"tldr":937,"updated":924,"url":938,"__hash__":939},"content\u002Fen\u002FJavaScript\u002Fjs-from-zero-21-date-time.md","JS From Zero — Day 21: Working With Dates and Time","1002130214",{"type":9,"value":10,"toc":907},"minimark",[11,16,20,24,27,39,46,53,59,63,70,76,79,110,116,119,126,132,136,142,148,158,198,202,208,214,223,246,250,256,262,266,272,278,282,288,294,298,304,310,313,317,323,329,332,336,339,580,586,590,604,889,896,900,903],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Day 21 of the reincarnation. This time we're looking at dates and time.",[12,21,23],{"id":22},"time","Time",[17,25,26],{},"Time is one of the most common things you'll deal with when building any kind of system, and of course JavaScript gives us syntax for it. So how do we use it? Let's do a quick intro on grabbing the current time.",[17,28,29,30,34,35,38],{},"To get the time in JavaScript you use ",[31,32,33],"code",{},"Date()",", but you also need the ",[31,36,37],{},"new"," constructor to build the date object. So it looks like this:",[17,40,41],{},[42,43],"img",{"alt":44,"src":45},"Building a Date object","https:\u002F\u002Fi.imgur.com\u002F4g0ktp1.png",[17,47,48,49,52],{},"Once you've got ",[31,50,51],{},"date",", you can pull all sorts of values out of it. The pattern is mostly the same across the board — here's getting the current year as an example:",[17,54,55],{},[42,56],{"alt":57,"src":58},"Getting the year","https:\u002F\u002Fi.imgur.com\u002Ft8SfJF1.png",[12,60,62],{"id":61},"gmt","GMT",[17,64,65,66,69],{},"GMT stands for Greenwich Mean Time. So if you just ",[31,67,68],{},"console.log(date)"," directly, you'll see the GMT version of the date:",[17,71,72],{},[42,73],{"alt":74,"src":75},"Greenwich Mean Time","https:\u002F\u002Fi.imgur.com\u002FYU2e59n.png",[17,77,78],{},"There's also another way to get the GMT string:",[80,81,86],"pre",{"className":82,"code":83,"language":84,"meta":85,"style":85},"language-js shiki shiki-themes github-dark-high-contrast","new Date().toGMTString()\n","js","",[31,87,88],{"__ignoreMap":85},[89,90,93,96,100,104,107],"span",{"class":91,"line":92},"line",1,[89,94,37],{"class":95},"sWyjQ",[89,97,99],{"class":98},"sj_SG"," Date",[89,101,103],{"class":102},"sMAXC","().",[89,105,106],{"class":98},"toGMTString",[89,108,109],{"class":102},"()\n",[17,111,112],{},[42,113],{"alt":114,"src":115},"Another way to get GMT","https:\u002F\u002Fi.imgur.com\u002FAlP0m8X.png",[12,117,57],{"id":118},"getting-the-year",[17,120,121,122,125],{},"To get the year you use ",[31,123,124],{},"getFullYear()",":",[17,127,128],{},[42,129],{"alt":130,"src":131},"Year","https:\u002F\u002Fi.imgur.com\u002FUpHJ2hp.png",[12,133,135],{"id":134},"getting-the-month","Getting the month",[17,137,138,139,125],{},"To get the month you use ",[31,140,141],{},"getMonth()",[17,143,144],{},[42,145],{"alt":146,"src":147},"Month","https:\u002F\u002Fi.imgur.com\u002FdmUXrRT.png",[17,149,150,151,153,154,157],{},"But here's something to watch out for: ",[31,152,141],{}," counts from 0, so in real usage remember to ",[31,155,156],{},"+1",".",[159,160,161,165,168,171,174,177,180,183,186,189,192,195],"ul",{},[162,163,164],"li",{},"January = 0",[162,166,167],{},"February = 1",[162,169,170],{},"March = 2",[162,172,173],{},"April = 3",[162,175,176],{},"May = 4",[162,178,179],{},"June = 5",[162,181,182],{},"July = 6",[162,184,185],{},"August = 7",[162,187,188],{},"September = 8",[162,190,191],{},"October = 9",[162,193,194],{},"November = 10",[162,196,197],{},"December = 11",[12,199,201],{"id":200},"getting-the-day","Getting the day",[17,203,204,205,125],{},"To get the day you use ",[31,206,207],{},"getDay()",[17,209,210],{},[42,211],{"alt":212,"src":213},"Day","https:\u002F\u002Fi.imgur.com\u002FSTs0U0H.png",[17,215,216,217,219,220,222],{},"Same deal here — ",[31,218,207],{}," also counts from 0, so remember to ",[31,221,156],{}," in real usage.",[159,224,225,228,231,234,237,240,243],{},[162,226,227],{},"Sunday = 0",[162,229,230],{},"Monday = 1",[162,232,233],{},"Tuesday = 2",[162,235,236],{},"Wednesday = 3",[162,238,239],{},"Thursday = 4",[162,241,242],{},"Friday = 5",[162,244,245],{},"Saturday = 6",[12,247,249],{"id":248},"getting-the-hours","Getting the hours",[17,251,252,253,125],{},"To get the hours you use ",[31,254,255],{},"getHours()",[17,257,258],{},[42,259],{"alt":260,"src":261},"Hours","https:\u002F\u002Fi.imgur.com\u002FtVyhZlJ.png",[12,263,265],{"id":264},"getting-the-minutes","Getting the minutes",[17,267,268,269,125],{},"To get the minutes you use ",[31,270,271],{},"getMinutes()",[17,273,274],{},[42,275],{"alt":276,"src":277},"Minutes","https:\u002F\u002Fi.imgur.com\u002FjyVyKr3.png",[12,279,281],{"id":280},"getting-the-seconds","Getting the seconds",[17,283,284,285,125],{},"To get the seconds you use ",[31,286,287],{},"getSeconds()",[17,289,290],{},[42,291],{"alt":292,"src":293},"Seconds","https:\u002F\u002Fi.imgur.com\u002FS78mdqu.png",[12,295,297],{"id":296},"getting-the-milliseconds","Getting the milliseconds",[17,299,300,301,125],{},"To get the milliseconds you use ",[31,302,303],{},"getMilliseconds()",[17,305,306],{},[42,307],{"alt":308,"src":309},"Milliseconds","https:\u002F\u002Fi.imgur.com\u002FVJBXiP5.png",[17,311,312],{},"The unit here is milliseconds, where 1000 milliseconds = 1 second.",[12,314,316],{"id":315},"getting-the-timestamp","Getting the timestamp",[17,318,319,320,125],{},"For the timestamp you use ",[31,321,322],{},"getTime()",[17,324,325],{},[42,326],{"alt":327,"src":328},"Timestamp","https:\u002F\u002Fi.imgur.com\u002FUemmK7S.png",[17,330,331],{},"In practice, you'll often see timestamps used to track when data was created or modified.",[12,333,335],{"id":334},"combining-it-into-yearmonthday-hoursminutesseconds","Combining it into year\u002Fmonth\u002Fday hours:minutes:seconds",[17,337,338],{},"If you want to combine all of the above into a single date, just store each piece in its own variable and then stitch them together:",[80,340,342],{"className":82,"code":341,"language":84,"meta":85,"style":85},"var time = new Date();\nvar year = time.getFullYear();\nvar month = time.getMonth() + 1;\nvar day = time.getDay() +1 ;\nvar hours = time.getHours();\nvar minutes = time.getMinutes();\nvar sec = time.getSeconds();\nvar millSec = time.getMilliseconds();\n\nvar fullTime = 'Current date and time: ' + year + '\u002F' + month + '\u002F' + day + ' ' + hours + ':' + minutes + ':' + sec + ':' + millSec;\n",[31,343,344,363,381,409,434,451,468,485,502,509],{"__ignoreMap":85},[89,345,346,349,352,355,358,360],{"class":91,"line":92},[89,347,348],{"class":95},"var",[89,350,351],{"class":102}," time ",[89,353,354],{"class":95},"=",[89,356,357],{"class":95}," new",[89,359,99],{"class":98},[89,361,362],{"class":102},"();\n",[89,364,366,368,371,373,376,379],{"class":91,"line":365},2,[89,367,348],{"class":95},[89,369,370],{"class":102}," year ",[89,372,354],{"class":95},[89,374,375],{"class":102}," time.",[89,377,378],{"class":98},"getFullYear",[89,380,362],{"class":102},[89,382,384,386,389,391,393,396,399,402,406],{"class":91,"line":383},3,[89,385,348],{"class":95},[89,387,388],{"class":102}," month ",[89,390,354],{"class":95},[89,