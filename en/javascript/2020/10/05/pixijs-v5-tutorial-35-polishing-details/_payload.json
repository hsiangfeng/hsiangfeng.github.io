\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[17,35,36],{},"At this point Treasure Hunter is pretty much in an OK state, but a game can always be improved a bit more. Here's a rough list of things we could polish:",[38,39,40,49,52],"ul",{},[41,42,43,44],"li",{},"Randomize the speed on restart.\n",[38,45,46],{},[41,47,48],{},"Right now the speed is fixed — it only grabs the speed from the first load.",[41,50,51],{},"Make the player's body go semi-transparent when it touches a slime.",[41,53,54,55],{},"Random collision damage.\n",[38,56,57],{},[41,58,59],{},"Right now every collision drains the exact same amount of HP.",[17,61,62],{},"Most of this reuses loading patterns we've already covered, so I won't walk through everything in detail — just a few spots worth pointing out.",[12,64,66],{"id":65},"random-speed","Random Speed",[17,68,69],{},"Right now the speed is set like this:",[71,72,77],"pre",{"className":73,"code":74,"language":75,"meta":76,"style":76},"language-js shiki shiki-themes github-dark-high-contrast","blob.vy = blobOptions.speeds + randomInt(0, 3);\n","js","",[78,79,80],"code",{"__ignoreMap":76},[81,82,85,89,93,96,99,103,106,110,113,116],"span",{"class":83,"line":84},"line",1,[81,86,88],{"class":87},"sMAXC","blob.vy ",[81,90,92],{"class":91},"sWyjQ","=",[81,94,95],{"class":87}," blobOptions.speeds ",[81,97,98],{"class":91},"+",[81,100,102],{"class":101},"sj_SG"," randomInt",[81,104,105],{"class":87},"(",[81,107,109],{"class":108},"sCcAr","0",[81,111,112],{"class":87},", ",[81,114,115],{"class":108},"3",[81,117,118],{"class":87},");\n",[17,120,121],{},"The thing is, when we restart the game we want to re-roll the speed. The monsters are all generated from an array, so we should change it like this:",[71,123,125],{"className":73,"code":124,"language":75,"meta":76,"style":76},"function gameReset() {\n  ...\n  \u002F\u002F re-roll the monster speeds\n  blobs.forEach((it