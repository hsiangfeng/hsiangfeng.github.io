",1,[38,43,45],{"class":44},"sWyjQ","if",[38,47,49],{"class":48},"sMAXC","(",[38,51,53],{"class":52},"sj_SG","boxesIntersect",[38,55,56],{"class":48},"(explorer, treasure)) {\n",[38,58,60,63,66,69,72,76],{"class":40,"line":59},2,[38,61,62],{"class":48},"  treasure.x ",[38,64,65],{"class":44},"=",[38,67,68],{"class":48}," explorer.x ",[38,70,71],{"class":44},"+",[38,73,75],{"class":74},"sCcAr"," 8",[38,77,78],{"class":48},";\n",[38,80,82,85,87,90,92,94],{"class":40,"line":81},3,[38,83,84],{"class":48},"  treasure.y ",[38,86,65],{"class":44},[38,88,89],{"class":48}," explorer.y ",[38,91,71],{"class":44},[38,93,75],{"class":74},[38,95,78],{"class":48},[38,97,99],{"class":40,"line":98},4,[38,100,101],{"class":48},"}\n",[17,103,104],{},"Now when you touch the chest, it follows you around.",[17,106,107],{},[108,109],"img",{"alt":110,"src":111},"The chest follows the player","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F2020-01-17_15-33-40.png",[12,113,115],{"id":114},"escaping","Escaping",[17,117,118,119,121],{},"Now, when we touch the door, the game should end. That's also pretty easy — we just add a variable and pair it with an ",[35,120,45],{}," check:",[28,123,125],{"className":30,"code":124,"language":32,"meta":33,"style":33},"let getTreasure = false;\n\nif(boxesIntersect(explorer, treasure)) {\n  treasure.x = explorer.x + 8;\n  treasure.y = explorer.y + 8;\n  getTreasure = true;\n}\n",[35,126,127,142,148,158,172,187,200],{"__ignoreMap":33},[38,128,129,132,135,137,140],{"class":40,"line":41},[38,130,131],{"class":44},"let",[38,133,134],{"class":48}," getTreasure ",[38,136,65],{"class":44},[38,138,139],{"class":74}," false",[38,141,78],{"class":48},[38,143,144],{"class":40,"line":59},[38,145,147],{"emptyLinePlaceholder":146},true,"\n",[38,149,150,152,154,156],{"class":40,"line":81},[38,151,45],{"class":44},[38,153,49],{"class":48},[38,155,53],{"class":52},[38,157,56],{"class":48},[38,159,160,162,164,166,168,170],{"class":40,"line":98},[