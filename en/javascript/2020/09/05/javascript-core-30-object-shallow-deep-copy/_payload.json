44},[38,566,55],{"class":48},[38,568,569,571,573],{"class":40,"line":58},[38,570,61],{"class":48},[38,572,65],{"class":64},[38,574,68],{"class":48},[38,576,577],{"class":40,"line":71},[38,578,356],{"class":48},[38,580,581,583],{"class":40,"line":77},[38,582,361],{"class":48},[38,584,364],{"class":64},[38,586,587],{"class":40,"line":84},[38,588,369],{"class":48},[38,590,591],{"class":40,"line":97},[38,592,74],{"class":48},[38,594,595],{"class":40,"line":102},[38,596,81],{"emptyLinePlaceholder":80},[38,598,599,601,603,605,609,612,615,618,621,623,626],{"class":40,"line":116},[38,600,45],{"class":44},[38,602,89],{"class":48},[38,604,52],{"class":44},[38,606,608],{"class":607},"sCcAr"," JSON",[38,610,611],{"class":48},".",[38,613,614],{"class":122},"parse",[38,616,617],{"class":48},"(",[38,619,620],{"class":607},"JSON",[38,622,611],{"class":48},[38,624,625],{"class":122},"stringify",[38,627,628],{"class":48},"(b));\n",[38,630,631],{"class":40,"line":223},[38,632,81],{"emptyLinePlaceholder":80},[38,634,635,637,639,641],{"class":40,"line":398},[38,636,401],{"class":48},[38,638,52],{"class":44},[38,640,406],{"class":64},[38,642,113],{"class":48},[38,644,645,647,649,651],{"class":40,"line":411},[38,646,119],{"class":48},[38,648,123],{"class":122},[38,650,418],{"class":48},[38,652,653],{"class":129},"\u002F\u002F Two\n",[38,655,656,658,660,662],{"class":40,"line":424},[38,657,119],{"class":48},[38,659,123],{"class":122},[38,661,431],{"class":48},[38,663,421],{"class":129},[17,665,666],{},"This is the simplest way to get past the shallow-copy problem, and it's called a deep copy. The way it works is that it turns the object into a primitive value — a string — and then turns it back into an object. At that point the object lives in a fresh chunk of memory.",[17,668,669,670,672,673,675,676,679,680,683,684,687],{},"But using ",[35,671,546],{}," plus ",[35,674,550],{}," for a deep copy has one big problem: if your object contains ",[35,677,678],{},"undefined",", ",[35,681,682],{},