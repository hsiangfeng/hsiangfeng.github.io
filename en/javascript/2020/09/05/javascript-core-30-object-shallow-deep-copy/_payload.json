,{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var b = {\n  name: 'Ray',\n};\n\nvar e = b;\n\ne.name = 'QQ';\nconsole.log(b.name); \u002F\u002F QQ\n","js","",[35,36,37,56,69,75,82,95,100,114],"code",{"__ignoreMap":33},[38,39,42,46,50,53],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," b ",[38,51,52],{"class":44},"=",[38,54,55],{"class":48}," {\n",[38,57,59,62,66],{"class":40,"line":58},2,[38,60,61],{"class":48},"  name: ",[38,63,65],{"class":64},"sTRMh","'Ray'",[38,67,68],{"class":48},",\n",[38,70,72],{"class":40,"line":71},3,[38,73,74],{"class":48},"};\n",[38,76,78],{"class":40,"line":77},4,[38,79,81],{"emptyLinePlaceholder":80},true,"\n",[38,83,85,87,90,92],{"class":40,"line":84},5,[38,86,45],{"class":44},[38,88,89],{"class":48}," e ",[38,91,52],{"class":44},[38,93,94],{"class":48}," b;\n",[38,96,98],{"class":40,"line":97},6,[38,99,81],{"emptyLinePlaceholder":80},[38,101,103,106,108,111],{"class":40,"line":102},7,[38,104,105],{"class":48},"e.name ",[38,107,52],{"class":44},[38,109,110],{"class":64}," 'QQ'",[38,112,113],{"class":48},";\n",[38,115,117,120,124,127],{"class":40,"line":116},8,[38,118,119],{"class":48},"console.",[38,121,123],{"class":122},"sj_SG","log",[38,125,126],{"class":48},"(b.name); ",[38,128,130],{"class":129},"sQrFR","\u002F\u002F QQ\n",[17,132,133],{},"How this works lets me paste a diagram from before:",[17,135,136],{},[137,138],"img",{"alt":139,"src":140},"Memory pointer animation","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E7%89%A9%E4%BB%B6%E8%A8%98%E6%86%B6%E9%AB%94%E6%8C%87%E5%90%91.gif",[17,142,143,144,147],{},"So how do we fix this? There are actually quite a few ways. For example, you can use ",[35,145,146],{},"Object.assign"," to copy a brand-new object:",[28,149,151],{"className":30,"code":150,"language":32,