[{"data":1,"prerenderedAt":646},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F13\u002Fjavascript-core-12-asi-automatic-semicolon-insertion\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F13\u002Fjavascript-core-12-asi-automatic-semicolon-insertion\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F13\u002Fjavascript-core-12-asi-automatic-semicolon-insertion\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F13\u002Fjavascript-core-12-asi-automatic-semicolon-insertion\u002F":621,"related:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F13\u002Fjavascript-core-12-asi-automatic-semicolon-insertion\u002F":630},"\u002Fjavascript\u002F20200613\u002F3587770435\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":604,"date":605,"description":606,"extension":607,"lang":608,"meta":609,"navigation":151,"path":610,"readingMinutes":611,"seo":612,"standalone":613,"stem":614,"tags":615,"tldr":618,"updated":605,"url":619,"__hash__":620},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-12-asi-automatic-semicolon-insertion.md","JavaScript Core (12): How Can Semicolons Be Optional? Meet ASI","1000720632",{"type":9,"value":10,"toc":599},"minimark",[11,16,25,29,35,38,41,105,108,111,169,190,195,198,250,256,259,323,328,331,466,469,511,514,552,561,570,574,595],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"How come JavaScript sometimes needs a ",[21,22,23],"code",{},";"," and sometimes doesn't? That's thanks to a mechanism in JavaScript called ASI.",[12,26,28],{"id":27},"asi","ASI",[17,30,31],{},[32,33],"img",{"alt":28,"src":34},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-13%2022.28.43.png",[17,36,37],{},"ASI stands for \"Automatic Semicolon Insertion.\"",[17,39,40],{},"When you write JavaScript, you're actually allowed to skip semicolons, because the engine inserts them for you automatically.",[42,43,48],"pre",{"className":44,"code":45,"language":46,"meta":47,"style":47},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","var a = {\n  qq: '123',\n}\nconsole.log(a.qq); \u002F\u002F 123\n","js","",[21,49,50,69,82,88],{"__ignoreMap":47},[51,52,55,59,63,66],"span",{"class":53,"line":54},"line",1,[51,56,58],{"class":57},"sOudu","var",[51,60,62],{"class":61},"s8XSl"," a ",[51,64,65],{"class":57},"=",[51,67,68],{"class":61}," {\n",[51,70,72,75,79],{"class":53,"line":71},2,[51,73,74],{"class":61},"  qq: ",[51,76,78],{"class":77},"sWayO","'123'",[51,80,81],{"class":61},",\n",[51,83,85],{"class":53,"line":84},3,[51,86,87],{"class":61},"}\n",[51,89,91,94,98,101],{"class":53,"line":90},4,[51,92,93],{"class":61},"console.",[51,95,97],{"class":96},"scAaK","log",[51,99,100],{"class":61},"(a.qq); ",[51,102,104],{"class":103},"sGBqm","\u002F\u002F 123\n",[17,106,107],{},"ASI is pretty convenient. In fact, the Standard style in ESLint (one of JavaScript's style managers) goes with this no-semicolon approach.",[17,109,110],{},"But as a developer, \"automatic\" anything is kind of dangerous. Here's an example.",[42,112,114],{"className":44,"code":113,"language":46,"meta":47,"style":47},"var a = function() {\n  return\n  'ASI is Good!'\n}\n\nconsole.log(a())\n",[21,115,116,132,137,142,146,153],{"__ignoreMap":47},[51,117,118,120,123,126,129],{"class":53,"line":54},[51,119,58],{"class":57},[51,121,122],{"class":96}," a",[51,124,125],{"class":57}," =",[51,127,128],{"class":57}," function",[51,130,131],{"class":61},"() {\n",[51,133,134],{"class":53,"line":71},[51,135,136],{"class":57},"  return\n",[51,138,139],{"class":53,"line":84},[51,140,141],{"class":77},"  'ASI is Good!'\n",[51,143,144],{"class":53,"line":90},[51,145,87],{"class":61},[51,147,149],{"class":53,"line":148},5,[51,150,152],{"emptyLinePlaceholder":151},true,"\n",[51,154,156,158,160,163,166],{"class":53,"line":155},6,[51,157,93],{"class":61},[51,159,97],{"class":96},[51,161,162],{"class":61},"(",[51,164,165],{"class":96},"a",[51,167,168],{"class":61},"())\n",[17,170,171,172,174,175,178,179,182,183,185,186,189],{},"In the code above we store a function in the variable ",[21,173,165],{}," and use ",[21,176,177],{},"console.log()"," to display the returned ",[21,180,181],{},"ASI is Good!",". But if you actually run this, you'll notice something weird — it doesn't return ",[21,184,181],{}," at all, it returns ",[21,187,188],{},"undefined",".",[17,191,192],{},[32,193],{"alt":188,"src":194},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-14%2020.47.34.png",[17,196,197],{},"The culprit is ASI. Because ASI adds a semicolon at the end of the line, the code above actually runs like this:",[42,199,201],{"className":44,"code":200,"language":46,"meta":47,"style":47},"var a = function() {\n  return; 'ASI is Good!';\n}\n\nconsole.log(a());\n",[21,202,203,215,229,233,237],{"__ignoreMap":47},[51,204,205,207,209,211,213],{"class":53,"line":54},[51,206,58],{"class":57},[51,208,122],{"class":96},[51,210,125],{"class":57},[51,212,128],{"class":57},[51,214,131],{"class":61},[51,216,217,220,223,226],{"class":53,"line":71},[51,218,219],{"class":57},"  return",[51,221,222],{"class":61},"; ",[51,224,225],{"class":77},"'ASI is Good!'",[51,227,228],{"class":61},";\n",[51,230,231],{"class":53,"line":84},[51,232,87],{"class":61},[51,234,235],{"class":53,"line":90},[51,236,152],{"emptyLinePlaceholder":151},[51,238,239,241,243,245,247],{"class":53,"line":148},[51,240,93],{"class":61},[51,242,97],{"class":96},[51,244,162],{"class":61},[51,246,165],{"class":96},[51,248,249],{"class":61},"());\n",[17,251,252,253,255],{},"So it returns ",[21,254,188],{},", because it isn't returning anything at all.",[17,257,258],{},"ASI has another classic gotcha too — immediately invoked function expressions (IIFEs).",[42,260,262],{"class