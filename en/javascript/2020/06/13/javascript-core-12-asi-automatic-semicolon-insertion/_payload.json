51,348,131],{"class":61},[51,350,351,353,355,357,359],{"class":53,"line":84},[51,352,277],{"class":61},[51,354,97],{"class":96},[51,356,162],{"class":61},[51,358,284],{"class":77},[51,360,287],{"class":61},[51,362,363],{"class":53,"line":90},[51,364,365],{"class":61},"})();\n",[51,367,368],{"class":53,"line":148},[51,369,152],{"emptyLinePlaceholder":151},[51,371,372,374,376],{"class":53,"line":155},[51,373,162],{"class":61},[51,375,270],{"class":57},[51,377,131],{"class":61},[51,379,380,382,384,386,388],{"class":53,"line":320},[51,381,277],{"class":61},[51,383,97],{"class":96},[51,385,162],{"class":61},[51,387,315],{"class":77},[51,389,287],{"class":61},[51,391,393],{"class":53,"line":392},8,[51,394,365],{"class":61},[51,396,398],{"class":53,"line":397},9,[51,399,152],{"emptyLinePlaceholder":151},[51,401,403],{"class":53,"line":402},10,[51,404,405],{"class":103},"\u002F\u002F Option 2\n",[51,407,409,412,414],{"class":53,"line":408},11,[51,410,411],{"class":61},";(",[51,413,270],{"class":57},[51,415,131],{"class":61},[51,417,419,421,423,425,427],{"class":53,"line":418},12,[51,420,277],{"class":61},[51,422,97],{"class":96},[51,424,162],{"class":61},[51,426,284],{"class":77},[51,428,287],{"class":61},[51,430,432],{"class":53,"line":431},13,[51,433,292],{"class":61},[51,435,437],{"class":53,"line":436},14,[51,438,152],{"emptyLinePlaceholder":151},[51,440,442,444,446],{"class":53,"line":441},15,[51,443,411],{"class":61},[51,445,270],{"class":57},[51,447,131],{"class":61},[51,449,451,453,455,457,459],{"class":53,"line":450},16,[51,452,277],{"class":61},[51,454,97],{"class":96},[51,456,162],{"class":61},[51,458,315],{"class":77},[51,460,287],{"class":61},[51,462,464],{"class":53,"line":463},17,[51,465,292],{"class":61},[17,467,468],{},"Basically, ASI tends to cause trouble when a new line starts with one of these:",[470,471,472,484,500,505],"ul",{},[473,474,475,477,478,477,481],"li",{},[21,476,162],{},", ",[21,479,480],{},"[",[21,482,483],{},"\u002F",[473,485,486,487,477,4