[{"data":1,"prerenderedAt":514},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F":489,"related:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F":498},"\u002Fjavascript\u002F20200621\u002F3160672433\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":473,"date":474,"description":475,"extension":476,"lang":477,"meta":478,"navigation":184,"path":479,"readingMinutes":369,"seo":480,"standalone":481,"stem":482,"tags":483,"tldr":486,"updated":474,"url":487,"__hash__":488},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-13-dynamic-typing.md","JavaScript Core Concepts (13): Dynamic Typing — Why You Never Declare Types","1000728551",{"type":9,"value":10,"toc":468},"minimark",[11,16,20,24,32,55,62,71,74,131,138,242,245,305,308,323,326,364,387,442,445,448,452,464],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"When you write JavaScript, you never have to declare what type a variable is. The reason is pretty simple — JavaScript is a dynamically typed language.",[12,21,23],{"id":22},"dynamic-typing","Dynamic typing",[17,25,26,27,31],{},"So what does dynamic typing actually mean? Let me use C as a comparison. In C, if you want to declare an ",[28,29,30],"code",{},"int"," (a number), you have to spell it out like this:",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-c shiki shiki-themes github-dark-high-contrast","int a = 4;\nint b = 3;\n","c","",[28,40,41,49],{"__ignoreMap":38},[42,43,46],"span",{"class":44,"line":45},"line",1,[42,47,48],{},"int a = 4;\n",[42,50,52],{"class":44,"line":51},2,[42,53,54],{},"int b = 3;\n",[17,56,57,58,61],{},"And a string? In C, strings are declared with ",[28,59,60],{},"char"," (a string in C is basically an array of characters):",[33,63,65],{"className":35,"code":64,"language":37,"meta":38,"style":38},"char str[6] = \"hello\";\n",[28,66,67],{"__ignoreMap":38},[42,68,69],{"class":44,"line":45},[42,70,64],{},[17,72,73],{},"Now what about JavaScript? In the examples above, JavaScript figures out the correct type for you at runtime and assigns it automatically:",[33,75,79],{"className":76,"code":77,"language":78,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","var a = 4;\nvar b = 3;\nvar str = 'hello';\n","js",[28,80,81,101,115],{"__ignoreMap":38},[42,82,83,87,91,94,98],{"class":44,"line":45},[42,84,86],{"class":85},"sWyjQ","var",[42,88,90],{"class":89},"sMAXC"," a ",[42,92,93],{"class":85},"=",[42,95,97],{"class":96},"sCcAr"," 4",[42,99,100],{"class":89},";\n",[42,102,103,105,108,110,113],{"class":44,"line":51},[42,104,86],{"class":85},[42,106,107],{"class":89}," b ",[42,109,93],{"class":85},[42,111,112],{"class":96}," 3",[42,114,100],{"class":89},[42,116,118,120,123,125,129],{"class":44,"line":117},3,[42,119,86],{"class":85},[42,121,122],{"class":89}," str ",[42,124,93],{"class":85},[42,126,128],{"class":127},"sTRMh"," 'hello'",[42,130,100],{"class":89},[17,132,133,134,137],{},"We can use ",[28,135,136],{},"typeof"," to check the type:",[33,139,141],{"className":76,"code":140,"language":78,"meta":38,"style":38},"var a = 4;\nvar b = 3;\nvar str = 'hello';\n\nconsole.log(typeof(a)); \u002F\u002F number — covers both int and float\nconsole.log(typeof(b)); \u002F\u002F number\nconsole.log(typeof(str)); \u002F\u002F string\n",[28,142,143,155,167,179,186,208,225],{"__ignoreMap":38},[42,144,145,147,149,151,153],{"class":44,"line":45},[42,146,86],{"class":85},[42,148,90],{"class":89},[42,150,93],{"class":85},[42,152,97],{"class":96},[42,154,100],{"class":89},[42,156,157,159,161,163,165],{"class":44,"line":51},[42,158,86],{"class":85},[42,160,107],{"class":89},[42,162,93],{"class":85},[42,164,112],{"class":96},[42,166,100],{"class":89},[42,168,169,171,173,175,177],{"class":44,"line":117},[42,170,86],{"class":85},[42,172,122],{"class":89},[42,174,93],{"class":85},[42,176,128],{"class":127},[42,178,100],{"class":89},[42,180,182],{"class":44,"line":181},4,[42,183,185],{"emptyLinePlaceholder":184},true,"\n",[42,187,189,192,196,199,201,204],{"class":44,"line":188},5,[42,190,191],{"class":89},"console.",[42,193,195],{"class":194},"sj_SG","log",[42,197,198],{"class":89},"(",[42,200,136],{"class":85},[42,202,203],{"class":89},"(a)); ",[42,205,207],{"class":206},"sQrFR","\u002F\u002F number — covers both int and float\n",[42,209,211,213,215,217,219,222],{"class":44,"line":210},6,[42,212,191],{"class":89},[42,214,195],{"class":194},[42,216,198],{"class":89},[42,218,136],{"class":85},[42,220,221],{"class":89},"(b)); ",[42,223,224],{"class":206},"\u002F\u002F number\n",[42,226,228,230,232,234,236,239],{"class":44,"line":227},7,[42,229,191],{"class":89},[42,231,195],{"class":194},[42,233,198],{"class":89},[42,235,136],{"class":85},[42,237,238],{"class":89},"(str)); ",[42,240,241],{"class":206},"\u002F\u002F string\n",[17,243,244],{},"JavaScript also has type conversion — for example, a value that starts as a string can turn into a number, or the other way around:",[33,246,248],{"className":76,"code":247,"language":78,"meta":38,"style":38},"var a = 4;\nconsole.log(typeof(a)); \u002F\u002F number\n\na = 'hello';\nconsole.log(typeof(a)); \u002F\u002F string\n",[28,249,250,262,276,280,291],{"__ignoreMap":38},[42,251,252,254,256,258,260],{"class":44,"line":45},[42,253,86],{"class":85},[42,255,90],{"class":89},[42,257,93],{"class":85},[42,259,97],{"class":96},[42,261,100],{"class":89},[42,263,264,266,268,270,272,274],{"class":44,"line":51},[42,265,191],{"class":89},[42,267,195],{"class":194},[42,269,198],{"class":89},[42,271,136],{"class":85},[42,273,203],{"class":89},[42,275,224],{"class":206},[42,277,278],{"class":44,"line":117},[42,279,185],{"emptyLinePlaceholder":184},[42,281,282,285,287,289],{"class":44,"line":181},[42,283,284],{"class":89},"a ",[42,286,93],{"class":85},[42,288,128],{"class":127},[42,290,100],{"class":89},[42,292,293,295,297,299,301,303],{"class":44,"line":188},[42,294,191],{"class":89},[42,296,195],{"class":194},[42,298,198],{"class":89},[42,300,136],{"class":85},[42,302,203],{"class":89},[42,304,241],{"class":206},[17,306,307],{},"This is where JavaScript hides two dangerous traps: explicit conversion and implicit conversion.",[17,309,310,311,314,315,318,319,322],{},"When you can't be sure of a variable's type, you've got a real problem on your hands during development — bugs. Explicit conversion is basically the conversion you can see. In the example above, you can tell from the code that ",[28,312,313],{},"a"," became a ",[28,316,317],{},"number",", and then got reassigned to a ",[28,320,321],{},"string",". That's explicit conversion.",[17,324,325],{},"So what's implicit conversion? In short, it tends to happen when you're not sure about JavaScript's rules. Here's the classic example:",[33,327,329],{"className":76,"code":328,"language":78,"meta":38,"style":38},"var a = 1;\n\na = a + '1';\n",[28,330,331,344,348],{"__ignoreMap":38},[42,332,333,335,337,339,342],{"class":44,"line":45},[42,334,86],{"class":85},[42,336,90],{"class":89},[42,338,93],{"class":85},[42,340,341],{"class":96}," 1",[42,343,100],{"class":89},[42,345,346],{"class":44,"line":51},[42,347,185],{"emptyLinePlaceholder":184},[42,349,350,352,354,356,359,362],{"class":44,"line":117},[42,351,284],{"class":89},[42,353,93],{"class":85},[42,355,90],{"class":89},[42,357,358],{"class":85},"+",[42,360,361],{"class":127}," '1'",[42,363,100],{"class":89},[17,365,366,367,370,371,375,376,378,379,382,383,386],{},"You might assume the answer is ",[28,368,369],{},"2",". But since you're reading this post, you're probably already wondering — how does a number even add to a string? Here's the thing: JavaScript steps in and ",[372,373,374],"strong",{},"helpfully"," converts the types for you based on a set of rules. The rule for the ",[28,377,358],{}," operator is that when a number meets a string, the number gets converted to a string. So ",[28,380,381],{},"a + '1'"," becomes ",[28,384,385],{},"'11'"," — and it's a string.",[33,388,390],{"className":76,"code":389,"language":78,"meta":38,"style":38},"var a = 1;\n\na = a + '1';\n\nconsole.log(a, typeof(a)); \u002F\u002F 11, string\n",[28,391,392,404,408,422,426],{"__ignoreMap":38},[42,393,394,396,398,400,402],{"class":44,"line":45},[42,395,86],{"class":85},[42,397,90],{"class":89},[42,399,93],{"class":85},[42,401,341],{"class":96},[42,403,100],{"class":89},[42,405,406],{"class":44,"line":51},[42,407,185],{"emptyLinePlaceholder":184},[42,409,410,412,414,416,418,420],{"class":44,"line":117},[42,411,284],{"class":89},[42,413,93],{"class":85},[42,415,90],{"class":89},[42,417,358],{"class":85},[42,419,361],{"class":127},[42,421,100],{"class":89},[42,423,424],{"class":44,"line":181},[42,425,185],{"emptyLinePlaceholder":184},[42,427,428,430,432,435,437,439],{"class":44,"line":188},[42,429,191],{"class":89},[42,431,195],{"class":194},[42,433,434],{"class":89},"(a, ",[42,436,136],{"class":85},[42,438,203],{"class":89},[42,440,441],{"class":206},"\u002F\u002F 11, string\n",[17,443,444],{},"And that's implicit conversion.",[17,446,447],{},"Once you understand these rules, you can dodge a whole class of bugs in your day-to-day coding.",[12,449,451],{"id":450},"references","References",[453,454,455],"ul",{},[456,457,458],"li",{},[313,459,463],{"href":460,"rel":461},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[462],"nofollow","JavaScript Core (course in Mandarin)",[465,466,467],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(-