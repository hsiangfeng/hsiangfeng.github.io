[{"data":1,"prerenderedAt":746},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-14-primitive-and-object-types\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-14-primitive-and-object-types\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-14-primitive-and-object-types\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-14-primitive-and-object-types\u002F":721,"related:\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-14-primitive-and-object-types\u002F":730},"\u002Fjavascript\u002F20200621\u002F3684249269\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":704,"date":705,"description":706,"extension":707,"lang":708,"meta":709,"navigation":133,"path":710,"readingMinutes":711,"seo":712,"standalone":713,"stem":714,"tags":715,"tldr":718,"updated":705,"url":719,"__hash__":720},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-14-primitive-and-object-types.md","JavaScript Core Concepts (14): Primitive Types vs. Object Types","1000736470",{"type":9,"value":10,"toc":698},"minimark",[11,16,20,24,31,34,53,56,64,67,73,323,342,390,393,421,428,450,459,463,466,502,505,531,534,579,585,592,598,631,637,640,679,683,694],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"The clearer you are on how types work in JavaScript, the more it helps you when you're actually building things. So let's talk types.",[12,21,23],{"id":22},"primitive-types","Primitive Types",[17,25,26],{},[27,28],"img",{"alt":29,"src":30},"Primitive types","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-21%2021.09.23.png",[17,32,33],{},"JavaScript has these primitive types:",[35,36,37,41,44,47,50],"ul",{},[38,39,40],"li",{},"String",[38,42,43],{},"Boolean",[38,45,46],{},"Number",[38,48,49],{},"Undefined",[38,51,52],{},"Null",[17,54,55],{},"Plus the two that got added later:",[35,57,58,61],{},[38,59,60],{},"Bigint",[38,62,63],{},"Symbol",[17,65,66],{},"So seven in total. Anything outside of these is called an \"object type\" — we'll get to that in a bit.",[17,68,69],{},[27,70],{"alt":71,"src":72},"List of primitive types","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-21%2021.12.35.png",[74,75,80],"pre",{"className":76,"code":77,"language":78,"meta":79,"style":79},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F String — single or double quotes, doesn't change the result\nvar a = 'String';\nvar a1 = \"String\";\n\n\u002F\u002F Boolean\nvar b = true;\nvar b1 = false;\n\n\u002F\u002F Number\n\u002F\u002F In other languages decimals are a separate float type, but in JavaScript it's all just Number\nvar c = 10;\nvar c1 = 11.1;\n\n\u002F\u002F Undefined\nvar d = undefined;\n\n\u002F\u002F Null\nvar e = null;\n\n\u002F\u002F Bigint\n\u002F\u002F This mainly exists to solve the problem that JavaScript's Number type can't go above 2^53\nvar theBiggestInt = 9007199254740991n;\n\n\u002F\u002F Symbol\n\u002F\u002F Symbol is a bit special — it has to be created with Symbol(), so I won't demo it here.\n","js","",[81,82,83,92,113,128,135,141,157,172,177,183,189,204,219,224,230,245,250,256,271,276,282,288,306,311,317],"code",{"__ignoreMap":79},[84,85,88],"span",{"class":86,"line":87},"line",1,[84,89,91],{"class":90},"sQrFR","\u002F\u002F String — single or double quotes, doesn't change the result\n",[84,93,95,99,103,106,110],{"class":86,"line":94},2,[84,96,98],{"class":97},"sWyjQ","var",[84,100,102],{"class":101},"sMAXC"," a ",[84,104,105],{"class":97},"=",[84,107,109],{"class":108},"sTRMh"," 'String'",[84,111,112],{"class":101},";\n",[84,114,116,118,121,123,126],{"class":86,"line":115},3,[84,117,98],{"class":97},[84,119,120],{"class":101}," a1 ",[84,122,105],{"class":97},[84,124,125],{"class":108}," \"String\"",[84,127,112],{"class":101},[84,129,131],{"class":86,"line":130},4,[84,132,134],{"emptyLinePlaceholder":133},true,"\n",[84,136,138],{"class":86,"line":137},5,[84,139,140],{"class":90},"\u002F\u002F Boolean\n",[84,142,144,146,149,151,155],{"class":86,"line":143},6,[84,145,98],{"class":97},[84,147,148],{"class":101}," b ",[84,150,105],{"class":97},[84,152,154],{"class":153},"sCcAr"," true",[84,156,112],{"class":101},[84,158,160,162,165,167,170],{"class":86,"line":159},7,[84,161,98],{"class":97},[84,163,164],{"class":101}," b1 ",[84,166,105],{"class":97},[84,168,169],{"class":153}," false",[84,171,112],{"class":101},[84,173,175],{"class":86,"line":174},8,[84,176,134],{"emptyLinePlaceholder":133},[84,178,180],{"class":86,"line":179},9,[84,181,182],{"class":90},"\u002F\u002F Number\n",[84,184,186],{"class":86,"line":185},10,[84,187,188],{"class":90},"\u002F\u002F In other languages decimals are a separate float type, but in JavaScript it's all just Number\n",[84,190,192,194,197,199,202],{"class":86,"line":191},11,[84,193,98],{"class":97},[84,195,196],{"class":101}," c ",[84,198,105],{"class":97},[84,200,201],{"class":153}," 10",[84,203,112],{"class":101},[84,205,207,209,212,214,217],{"class":86,"line":206},12,[84,208,98],{"class":97},[84,210,211],{"class":101}," c1 ",[84,213,105],{"class":97},[84,215,216],{"class":153}," 11.1",[84,218,112],{"class":101},[84,220,222],{"class":86,"line":221},13,[84,223,134],{"emptyLinePlaceholder":133},[84,225,227],{"class":86,"line":226},14,[84,228,229],{"class":90},"\u002F\u002F Undefined\n",[84,231,233,235,238,240,243],{"class":86,"line":232},15,[84,234,98],{"class":97},[84,236,237],{"class":101}," d ",[84,239,105],{"class":97},[84,241,242],{"class":153}," undefined",[84,244,112],{"class":101},[84,246,248],{"class":86,"line":247},16,[84,249,134],{"emptyLinePlaceholder":133},[84,251,253],{"class":86,"line":252},17,[84,254,255],{"class":90},"\u002F\u002F Null\n",[84,257,259,261,264,266,269],{"class":86,"line":258},18,[84,260,98],{"class":97},[84,262,263],{"class":101}," e ",[84,265,105],{"class":97},[84,267,268],{"class":153}," null",[84,270,112],{"class":101},[84,272,274],{"class":86,"line":273},19,[84,275,134],{"emptyLinePlaceholder":133},[84,277,279],{"class":86,"line":278},20,[84,280,281],{"class":90},"\u002F\u002F Bigint\n",[84,283,285],{"class":86,"line":284},21,[84,286,287],{"class":90},"\u002F\u002F This mainly exists to solve the problem that JavaScript's Number type can't go above 2^53\n",[84,289,291,293,296,298,301,304],{"class":86,"line":290},22,[84,292,98],{"class":97},[84,294,295],{"class":101}," theBiggestInt ",[84,297,105],{"class":97},[84,299,300],{"class":153}," 9007199254740991",[84,302,303],{"class":97},"n",[84,305,112],{"class":101},[84,307,309],{"class":86,"line":308},23,[84,310,134],{"emptyLinePlaceholder":133},[84,312,314],{"class":86,"line":313},24,[84,315,316],{"class":90},"\u002F\u002F Symbol\n",[84,318,320],{"class":86,"line":319},25,[84,321,322],{"class":90},"\u002F\u002F Symbol is a bit special — it has to be created with Symbol(), so I won't demo it here.\n",[17,324,325,326,329,330,333,334,337,338,341],{},"These types also come with what we call wrapper objects, like ",[81,327,328],{},"new Boolean()",", ",[81,331,332],{},"new String()",", and so on. The only two without a wrapper object are ",[81,335,336],{},"undefined"," and ",[81,339,340],{},"null",".",[74,343,345],{"className":76,"code":344,"language":78,"meta":79,"style":79},"new Boolean();\nnew String();\nnew Number();\nBigInt();\nSymbol();\n",[81,346,347,359,368,377,384],{"__ignoreMap":79},[84,348,349,352,356],{"class":86,"line":87},[84,350,351],{"class":97},"new",[84,353,355],{"class":354},"sj_SG"," Boolean",[84,357,358],{"class":101},"();\n",[84,360,361,363,366],{"class":86,"line":94},[84,362,351],{"class":97},[84,364,365],{"class":354}," String",[84,367,358],{"class":101},[84,369,370,372,375],{"class":86,"line":115},[84,371,351],{"class":97},[84,373,374],{"class":354}," Number",[84,376,358],{"class":101},[84,378,379,382],{"class":86,"line":130},[84,380,381],{"class":354},"BigInt",[84,383,358],{"class":101},[84,385,386,388],{"class":86,"line":137},[84,387,63],{"class":354},[84,389,358],{"class":101},[17,391,392],{},"Because these types have wrapper objects, they also come with methods — things like capitalizing the first letter and so on.",[17,394,395,396,398,399,402,403,406,407,409,410,412,413,415,416,420],{},"One thing that's really worth mentioning here is the ",[81,397,340],{}," primitive. If you run ",[81,400,401],{},"typeof(null)",", you'll see it return ",[81,404,405],{},"object",". That's a long-standing JavaScript bug, and it's not getting fixed any time soon — a ton of websites rely on this exact quirk to run, so if ",[81,408,340],{}," suddenly reported as ",[81,411,340],{}," instead of ",[81,414,405],{},", a whole lot of sites out there would break (",[417,418,419],"del",{},"just rolling with the mistake",").",[17,422,423,424,427],{},"On top of that, if you reference a variable or function in your code that was never declared, you'll get a ",[81,425,426],{},"XXX is not defined",". But if you do this:",[74,429,431],{"className":76,"code":430,"language":78,"meta":79,"style":79},"console.log(typeof(e));\n",[81,432,433],{"__ignoreMap":79},[84,434,435,438,441,444,447],{"class":86,"line":87},[84,436,437],{"class":101},"console.",[84,439,440],{"class":354},"log",[84,442,443],{"class":101},"(",[84,445,446],{"class":97},"typeof",[84,448,449],{"class":101},"(e));\n",[17,451,452,453,455,456,458],{},"you'll notice the code runs just fine and outputs ",[81,454,336],{},". That's one of JavaScript's weird bits — it's a safety measure built in to keep your code from blowing up. So whenever you see ",[81,457,336],{},", it means your variable or function probably hasn't been assigned a value, declared, or anything like that yet.",[12,460,462],{"id":461},"object-types","Object Types",[17,464,465],{},"I mentioned wrapper objects earlier. Because each primitive type has its own wrapper object, there are methods sitting underneath, which means we can run things like this:",[74,467,469],{"className":76,"code":468,"language":78,"meta":79,"style":79},"var a = 'hello';\nconsole.log(a.length); \u002F\u002F 5\n",[81,470,471,484],{"__ignoreMap":79},[84,472,473,475,477,479,482],{"class":86,"line":87},[84,474,98],{"class":97},[84,476,102],{"class":101},[84,478,105],{"class":97},[84,480,481],{"class":108}," 'hello'",[84,483,112],{"class":101},[84,485,486,488,490,493,496,499],{"class":86,"line":94},[84,487,437],{"class":101},[84,489,440],{"class":354},[84,491,492],{"class":101},"(a.",[84,494,495],{"class":153},"length",[84,497,498],{"class":101},"); ",[84,500,501],{"class":90},"\u002F\u002F 5\n",[17,503,504],{},"Now, each primitive type has quite a lot of methods you can use. When you want to look them up, one way is to just Google it. The other way is through the wrapper object, which you declare like this:",[74,506,508],{"className":76,"code":507,"language":78,"meta":79,"style":79},"var a = new String('Hello');\n",[81,509,510],{"__ignoreMap":79},[84,511,512,514,516,518,521,523,525,528],{"class":86,"line":87},[84,513,98],{"class":97},[84,515,102],{"class":101},[84,517,105],{"class":97},[84,519,520],{"class":97}," new",[84,522,365],{"class":354},[84,524,443],{"class":101},[84,526,527],{"class":108},"'Hello'",[84,529,530],{"class":101},");\n",[17,532,533],{},"But heads up: \"a variable declared via a wrapper object is a different type and gets represented differently.\"",[74,535,537],{"className":76,"code":536,"language":78,"meta":79,"style":79},"var a = new String('Hello');\nvar b = 'Hello';\nconsole.log(a, b);\n",[81,538,539,557,570],{"__ignoreMap":79},[84,540,541,543,545,547,549,551,553,555],{"class":86,"line":87},[84,542,98],{"class":97},[84,544,102],{"class":101},[84,546,105],{"class":97},[84,548,520],{"class":97},[84,550,365],{"class":354},[84,552,443],{"class":101},[84,554,527],{"class":108},[84,556,530],{"class":101},[84,558,559,561,563,565,568],{"class":86,"line":94},[84,560,98],{"class":97},[84,562,148],{"class":101},[84,564,105],{"class":97},[84,566,567],{"class":108}," 'Hello'",[84,569,112],{"class":101},[84,571,572,574,576],{"class":86,"line":115},[84,573,437],{"class":101},[84,575,440],{"class":354},[84,577,578],{"class":101},"(a, b);\n",[17,580,581],{},[27,582],{"alt":583,"src":584},"Declaring a wrapper object","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-21%2021.37.41.png",[17,586,587,588,591],{},"Once we've declared the wrapper object, we can look at ",[81,589,590],{},"_proto_"," underneath it — that's the wrapper object's prototype — to see which methods are available on it.",[17,593,594],{},[27,595],{"alt":596,"src":597},"proto","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-21%2021.39.33.png",[74,599,601],{"className":76,"code":600,"language":78,"meta":79,"style":79},"a.anchor();\na.big();\na.blink();\n",[81,602,603,613,622],{"__ignoreMap":79},[84,604,605,608,611],{"class":86,"line":87},[84,606,607],{"class":101},"a.",[84,609,610],{"class":354},"anchor",[84,612,358],{"class":101},[84,614,615,617,620],{"class":86,"line":94},[84,616,607],{"class":101},[84,618,619],{"class":354},"big",[84,621,358],{"class":101},[84,623,624,626,629],{"class":86,"line":115},[84,625,607],{"class":101},[84,627,628],{"class":354},"blink",[84,630,358],{"class":101},[17,632,633],{},[27,634],{"alt":635,"src":636},"Wrapper object methods","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-21%2021.40.56.png",[17,638,639],{},"Last thing, and it's an important one: when you declare a primitive variable, try not to use the wrapper object. This style is called a constructor, and the reason to avoid it is that it declares the value as an object — so it ends up different from your original primitive type.",[74,641,643],{"className":76,"code":642,"language":78,"meta":79,"style":79},"var a = new String('Hello');\nconsole.log(typeof(a)); \u002F\u002F Object\n",[81,644,645,663],{"__ignoreMap":79},[84,646,647,649,651,653,655,657,659,661],{"class":86,"line":87},[84,648,98],{"class":97},[84,650,102],{"class":101},[84,652,105],{"class":97},[84,654,520],{"class":97},[84,656,365],{"class":354},[84,658,443],{"class":101},[84,660,527],{"class":108},[84,662,530],{"class":101},[84,664,665,667,669,671,673,676],{"class":86,"line":94},[84,666,437],{"class":101},[84,668,440],{"class":354},[84,670,443],{"class":101},[84,672,446],{"class":97},[84,674,675],{"class":101},"(a)); ",[84,677,678],{"class":90},"\u002F\u002F Object\n",[12,680,682],{"id":681},"references","References",[35,684,685],{},[38,686,687],{},[688,689,693],"a",{"href":690,"rel":691},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[692],"nofollow","JavaScript Core (course in Mandarin)",[695,696,697],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}",{"title":79,"searchDepth":94,"depth":94,"links":699},[700,701,702,703],{"id":14,"depth":94,"text":15},{"id":22,"depth":94,"text":23},{"id":461,"depth":94,"text":462},{"id":681,"depth":94,"text":682},"JavaScript","2020-06-21 20:41:52","The clearer you are on how types work in JavaScript, the easier real-world development gets. This post walks through the seven primitive types, the wrapper objects behind them, the famous typeof null bug, and why you should avoid declaring primitives with wrapper objects like new String().","md","en",{},"\u002Fen\u002Fjavascript\u002Fjavascript-core-14-primitive-and-object-types","3",{"title":6,"description":706},false,"en\u002FJavaScript\u002Fjavascript-core-14-primitive-and-object-types",[704,716,717],"JavaScript Core","Operators, Types, and Grammar",null,"\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-14-primitive-and-object-types\u002F","a9_NBf7y2JKEXspxk9Xlu9dmIDIHWsX3riBEAg76N7Y",{"newer":722,"older":726},{"url":723,"title":724,"date":725},"\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F22\u002Fpixijs-v5-tutorial-20-collision-boundary-02\u002F","PixiJS V5 Tutorial (20): Pop a Damage Number When You Hit the Wall","2020-06-22 08:25:39",{"url":727,"title":728,"date":729},"\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F","JavaScript Core Concepts (13): Dynamic Typing — Why You Never Declare Types","2020-06-21 16:41:54",[731,736,741],{"url":732,"title":733,"date":734,"readingMinutes":735},"\u002Fen\u002Fjavascript\u002F2026\u002F03\u002F10\u002Fweb-crypto-api-encryption-guide\u002F","No crypto Package, No Node.js — The Web Crypto API Does It All in the Browser","2026-03-10 09:45:08","9",{"url":737,"title":738,"date":739,"readingMinutes":740},"\u002Fen\u002Fjavascript\u002F2025\u002F12\u002F08\u002Fjquery-why-it-declined\u002F","jQuery Was Once King — So Why Did It Fall Off?","2025-12-08 21:35:24","7",{"url":742,"title":743,"date":744,"readingMinutes":745},"\u002Fen\u002Fjavascript\u002F2025\u002F12\u002F05\u002Fjavascript-generator-functions\u002F","What Are JavaScript Generator Functions (function*)? The Function You Can Pause and Resume","2025-12-05 13:40:31","5",1784012775876]