if",[38,47,49],{"class":48},"sMAXC","(",[38,51,53],{"class":52},"sCcAr","10",[38,55,56],{"class":48},") {\n",[38,58,60,63,67,69,73,76],{"class":40,"line":59},2,[38,61,62],{"class":48},"  console.",[38,64,66],{"class":65},"sj_SG","log",[38,68,49],{"class":48},[38,70,72],{"class":71},"sTRMh","'執行程式'",[38,74,75],{"class":48},"); ",[38,77,79],{"class":78},"sQrFR","\u002F\u002F this line prints\n",[38,81,83],{"class":40,"line":82},3,[38,84,85],{"class":48},"}\n",[17,87,88],{},"But if you check it with an equality comparison:",[28,90,92],{"className":30,"code":91,"language":32,"meta":33,"style":33},"10 == true; \u002F\u002F false\n",[35,93,94],{"__ignoreMap":33},[38,95,96,98,101,104,107],{"class":40,"line":41},[38,97,53],{"class":52},[38,99,100],{"class":44}," ==",[38,102,103],{"class":52}," true",[38,105,106],{"class":48},"; ",[38,108,109],{"class":78},"\u002F\u002F false\n",[17,111,112,113,116,117,124],{},"You'll notice you get ",[35,114,115],{},"false"," back. So Truthy and Falsy aren't really tied to implicit coercion. Usually you can figure things out by looking at a ",[118,119,123],"a",{"href":120,"rel":121},"https:\u002F\u002Fdorey.github.io\u002FJavaScript-Equality-Table\u002F",[122],"nofollow","truth table",".",[17,126,127],{},[128,129],"img",{"alt":130,"src":131},"if truthy\u002Ffalsy table","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-28%2022.08.49.png",[17,133,134,135,137],{},"Basically this ",[35,136,45],{}," truthy\u002Ffalsy idea is something you'll use a ton in real-world dev. For example:",[28,139,141],{"className":30,"code":140,"language":32,"meta":33,"style":33},"var a = ''; \u002F\u002F runs the false branch\n\u002F\u002F var a = '1234' \u002F\u002F runs the true branch\n\nif (a) {\n console.log(true)\n} else {\n console.log(false);\n}\n",[35,142,143,162,170,176,184,200,212,226],{"__ignoreMap":33},[38,144,145,148,151,154,157,159],{"class