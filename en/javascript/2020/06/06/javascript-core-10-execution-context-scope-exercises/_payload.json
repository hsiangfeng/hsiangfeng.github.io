,542,543],{},[32,544,545],{},"Hello Casper",[93,547,548],{},"None of the above",[122,550,551,553,558],{},[125,552,127],{},[17,554,555,556,208],{},"The answer is \"3. ",[32,557,545],{},[17,559,560,561,98,563,565,566,569,570,573,574,576,577,579,580,582],{},"This one's about lexical scope. The scope is decided the moment the code is written. Inside ",[32,562,494],{},[32,564,84],{}," is re-declared with ",[32,567,568],{},"var a = 'Mary';",", so ",[32,571,572],{},"a = 'Tom';"," only affects that local ",[32,575,84],{}," — it doesn't touch the global ",[32,578,84],{},". That's why the answer is ",[32,581,545],{},".",[12,584,586],{"id":585},"question-4","Question 4",[25,588,590],{"className":27,"code":589,"language":29,"meta":30,"style":30},"function a() {\n  console.log('1');\n  function c() {\n    console.log('b');\n    function b() {\n      console.log('b')\n    }\n    b();\n  }\n  c();\n}\na();\n",[32,591,592,601,616,626,640,650,664,669,677,683,691,696],{"__ignoreMap":30},[35,593,594,596,599],{"class":37,"line":38},[35,595,437],{"class":55},[35,597,598],{"class":45}," a",[35,600,443],{"class":41},[35,602,603,606,608,610,613],{"class":37,"line":52},[35,604,605],{"class":41},"  console.",[35,607,46],{"class":45},[35,609,507],{"class":41},[35,611,612],{"class":65},"'1'",[35,614,615],{"class":41},");\n",[35,617,618,621,624],{"class":37,"line":72},[35,619,620],{"class":55},"  function",[35,622,623],{"class":45}," c",[35,625,443],{"class":41},[35,627,628,631,633,635,638],{"class":37,"line":369},[35,629,630],{"class":41},"    console.",[35,632,46],{"class":45},[35,634,507],{"class":41},[35,636,637],{"class":65},"'b'",[35,639,615],{"class":41},[35,641,642,645,648],{"class":37,"line":477},[35,643,644],{"class":55},"    function",[35,646,647],{"class":45}," b",[35,649,443],{"class":41},[35,651,652,655,657,659,661],{"class":37,"line":491},[35,653,654],{"class":41},"      console.",[35,656,46],{"class":45},[35,658,507],{"class":41},[35,660,637],{"class":65},[35,662,663],{"class":4