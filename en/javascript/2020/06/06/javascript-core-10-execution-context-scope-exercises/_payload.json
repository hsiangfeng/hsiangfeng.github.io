],{},"String",[93,297,298],{},"BigInt",[93,300,301],{},"Symbol",[17,303,304,305,308,309,311,312,315,316,318],{},"So in ",[32,306,307],{},"1 = true;",", the ",[32,310,223],{}," is a number, and you can't assign to it — that throws an LHS error. Then ",[32,313,314],{},"console.log(a);"," references ",[32,317,84],{},", which was never declared, so calling it throws an RHS error.",[17,320,321,322,324],{},"So the answer is \"1. LHS, ",[32,323,112],{}," (RHS)\".",[17,326,327],{},"You can also try playing with this code to see whether it runs:",[25,329,331],{"className":27,"code":330,"language":29,"meta":30,"style":30},"'' = true;\ntrue = '';\nnull = '';\n123 = true;\n",[32,332,333,344,356,367],{"__ignoreMap":30},[35,334,335,338,340,342],{"class":37,"line":38},[35,336,337],{"class":65},"''",[35,339,226],{"class":55},[35,341,229],{"class":222},[35,343,69],{"class":41},[35,345,346,349,351,354],{"class":37,"line":52},[35,347,348],{"class":222},"true",[35,350,226],{"class":55},[35,352,353],{"class":65}," ''",[35,355,69],{"class":41},[35,357,358,361,363,365],{"class":37,"line":72},[35,359,360],{"class":222},"null",[35,362,226],{"class":55},[35,364,353],{"class":65},[35,366,69],{"class":41},[35,368,370,373,375,377],{"class":37,"line":369},4,[35,371,372],{"class":222},"123",[35,374,226],{"class":55},[35,376,229],{"class":222},[35,378,69],{"class":41},[17,380,381,382,384],{},"But ",[32,383,101],{}," among the primitives is a weird one. If you type any of the following, you'll find they all just return fine:",[25,386,388],{"className":27,"code":387,"language":29,"meta":30,"style":30},"undefined = 1;\nundefined = '';\nundefined = true;\n",[32,389,390,401,411],{"__ignoreMap":30},[35,391,392,394,396,399],{"class":37,"line":38},[35,393,101],{"class":222},[35,395,226],{"class":55},[35,397,398],{"class":222}," 1",[35,400,69],{"class":41},[35,402,403,405,407,409],{"class":37,"line":52},[35,404,101],{"class":222},[35,406,226],{"class":55},[35,408,353],{"class":65},[35,410,69],{"class":41},