alName, arguments, this);\n  }\n}\n\nobj.fn(globalName, 'qq 先生', '2');\n","js","",[35,36,37,60,67,80,103,119,144,150,156,161],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," globalName ",[38,51,52],{"class":44},"=",[38,54,56],{"class":55},"sTRMh"," 'Ray'",[38,58,59],{"class":48},";\n",[38,61,63],{"class":40,"line":62},2,[38,64,66],{"emptyLinePlaceholder":65},true,"\n",[38,68,70,72,75,77],{"class":40,"line":69},3,[38,71,45],{"class":44},[38,73,74],{"class":48}," obj ",[38,76,52],{"class":44},[38,78,79],{"class":48}," {\n",[38,81,83,87,90,93,96,100],{"class":40,"line":82},4,[38,84,86],{"class":85},"sj_SG","  fn",[38,88,89],{"class":48},": ",[38,91,92],{"class":44},"function",[38,94,95],{"class":48},"(",[38,97,99],{"class":98},"s_sBn","name",[38,101,102],{"class":48},") {\n",[38,104,106,109,112,114,117],{"class":40,"line":105},5,[38,107,108],{"class":44},"    var",[38,110,111],{"class":48}," localName ",[38,113,52],{"class":44},[38,115,116],{"class":55}," 'Ray is Good!'",[38,118,59],{"class":48},[38,120,122,125,128,131,135,138,141],{"class":40,"line":121},6,[38,123,124],{"class":48},"    console.",[38,126,127],{"class":85},"log",[38,129,130],{"class":48},"(name, localName, globalName, ",[38,132,134],{"class":133},"sCcAr","arguments",[38,136,137],{"class":48},", ",[38,139,140],{"class":133},"this",[38,142,143],{"class":48},");\n",[38,145,147],{"class":40,"line":146},7,[38,148,149],{"class":48},"  }\n",[38,151,153],{"class":40,"line":152},8,[38,154,155],{"class":48},"}\n",[38,157,159],{"class":40,"line":158},9,[38,160,66],{"emptyLinePlaceholder":65},[38,162,164,167,170,173,176,178,181],{"class":40,"line":163},10,[38,165,166],{"class":48},"obj.",[38,168,169],{"class":85},"fn",[38,171,172],{"class":48},"(globalName, ",[38,174,175],{"class":55},"'qq 先生'",[38,177,137],{"class":48},[38,179,180],{"class":55},"'2'",[38,182,143],{"class":48},[17,184,185,186,189,190,193],{},"There's a lot packed into that ",[35,187,188],{},"console.log"," inside ",[35,191,192],{},"obj.fn",", so let's unpack it.",[17,195,196,197,200,201,203,204,206,207,209,210,212,213,216],{},"Notice that ",[35,198,199],{},"obj.fn(globalName, 'qq 先生', '2');"," passes in three arguments, but ",[35,202,169],{}," only accepts one parameter — ",[35,205,99],{},". So which of the three does ",[35,208,99],{}," end up holding? The answer is the first one. Arguments get loaded in order, first to last, so ",[35,211,99],{}," ends up as ",[35,214,215],{},"Ray",".",[17,218,219,220,222,223,226],{},"The second thing in that ",[35,221,188],{}," is ",[35,224,225],{},"localName",", but that's not something we passed in — it's a local variable declared inside the function. And the third one is just the global variable.",[17,228,229,230,216],{},"Now let's get into something a bit more special: ",[35,231,134],{},[12,233,134],{"id":134},[17,235,236,238,239,241,242,244,245,249],{},[35,237,134],{}," is a pretty special thing. Basically, no matter how many arguments you pass in, ",[35,240,134],{}," grabs all of them. But here's the catch — ",[35,243,134],{}," is an ",[246,247,248],"strong",{},"array-like"," object.",[17,251,252,253,256],{},"What's an array-like object? In short, it's something that looks like an array but isn't actually one. The big difference between an array-like and a real array is the ",[246,254,255],{},"methods and features you can use"," on it — they're nowhere near the same. Let me show you.",[28,258,260],{"className":30,"code":259,"language":32,"meta":33,"style":33},"var a = ['1', '2', '3'];\nconsole.dir(a);\n",[35,261,262,289],{"__ignoreMap":33},[38,263,264,266,269,271,274,277,279,281,283,286],{"class":40,"line":41},[38,265,45],{"class":44},[38,267,268],{"class":48}," a ",[38,270,52],{"class":44},[38,272,273],{"class":48}," [",[38,275,276],{"class":55},"'1'",[38,278,137],{"class":48},[38,280,180],{"class":55},[38,282,137],{"class":48},[38,284,285],{"class":55},"'3'",[38,287,288],{"class":48},"];\n",[38,290,291,294,297],{"class":40,"line":62},[38,292,293],{"class":48},"console.",[38,295,296],{"class":85},"dir",[38,298,299],{"class":48},"(a);\n",[17,301,302,303,306],{},"Here we've created an array literal. If you run this in the browser and expand the array's ",[35,304,305],{},"__proto__",", you'll see a whole pile of methods and features available to you.",[17,308,309],{},[310,311],"img",{"alt":312,"src":313},"Array methods","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-29%2020.42.03.png",[17,315,316,317,319],{},"Now what about the ",[35,318,134],{}," we keep talking about? (I trimmed this down a little so it's not too much to take in.)",[28,321,323],{"className":30,"code":322,"language":32,"meta":33,"style":33},"var globalName = 'Ray';\nvar obj = {\n  fn: function(name) {\n    console.log(arguments);\n  }\n}\n\nobj.fn(globalName, 'qq 先生', '2');\n",[35,324,325,337,347,361,373,377,381,385],{"__ignoreMap":33},[38,326,327,329,331,333,335],{"class":40,"line":41},[38,328,45],{"class":44},[38,330,49],{"class":48},[38,332,52],{"class":44},[38,334,56],{"class":55},[38,336,59],{"class":48},[38,338,339,341,343,345],{"class":40,"line":62},[38,340,45],{"class":44},[38,342,74],{"class":48},[38,344,52],{"class":44},[38,346,79],{"class":48},[38,348,349,351,353,355,357,359],{"class":40,"line":69},[38,350,86],{"class":85},[38,352,89],{"class":48},[38,354,92],{"class":44},[38,356,95],{"class":48},[38,358,99],{"class":98},[38,360,102],{"class":48},[38,362,363,365,367,369,371],{"class":40,"line":82},[38,364,124],{"class":48},[38,366,127],{"class":85},[38,368,95],{"class":48},[38,370,134],{"class":133},[38,372,143],{"class":48},[38,374,375],{"class":40,"line":105},[38,376,149],{"class":48},[38,378,379],{"class":40,"line":121},[38,380,155],{"class":48},[38,382,383],{"class":40,"line":146},[38,384,66],{"emptyLinePlaceholder":65},[38,386,387,389,391,393,395,397,399],{"class":40,"line":152},[38,388,166],{"class":48},[38,390,169],{"class":85},[38,392,172],{"class":48},[38,394,175],{"class":55},[38,396,137],{"class":48},[38,398,180],{"class":55},[38,400,143],{"class":48},[17,402,403],{},[310,404],{"alt":405,"src":406},"Array-like object","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-29%2020.44.58.png",[17,408,409],{},"So you can see that even though it looks like an array, it's actually very different from a real one — just look at how few methods it has. That's why we call it an array-like object.",[17,411,412,413,415,416,418],{},"And the nice thing is, you don't have to declare or build ",[35,414,134],{}," yourself. When a function runs, ",[35,417,134],{}," gets automatically created for you.",[12,420,422],{"id":421},"parameter-declarations-inside-a-function","Parameter declarations inside a function",[17,424,425],{},"Next, let's talk about what happens when a variable declared inside a function has the same name as one of the function's parameters.",[28,427,429],{"className":30,"code":428,"language":32,"meta":33,"style":33},"var qq = 'jack';\n\nfunction fn(qq) {\n  console.log(qq); \u002F\u002F jack\n  var qq;\n  console.log(qq); \u002F\u002F jack\n}\n\nfn(qq);\n",[35,430,431,445,449,463,477,485,495,499,503],{"__ignoreMap":33},[38,432,433,435,438,440,443],{"class":40,"line":41},[38,434,45],{"class":44},[38,436,437],{"class":48}," qq ",[38,439,52],{"class":44},[38,441,442],{"class":55}," 'jack'",[38,444,59],{"class":48},[38,446,447],{"class":40,"line":62},[38,448,66],{"emptyLinePlaceholder":65},[38,450,451,453,456,458,461],{"class":40,"line":69},[38,452,92],{"class":44},[38,454,455],{"class":85}," fn",[38,457,95],{"class":48},[38,459,460],{"class":98},"qq",[38,462,102],{"class":48},[38,464,465,468,470,473],{"class":40,"line":82},[38,466,467],{"class":48},"  console.",[38,469,127],{"class":85},[38,471,472],{"class":48},"(qq); ",[38,474,476],{"class":475},"sQrFR","\u002F\u002F jack\n",[38,478,479,482],{"class":40,"line":105},[38,480,481],{"class":44},"  var",[38,483,484],{"class":48}," qq;\n",[38,486,487,489,491,493],{"class":40,"line":121},[38,488,467],{"class":48},[38,490,127],{"class":85},[38,492,472],{"class":48},[38,494,476],{"class":475},[38,496,497],{"class":40,"line":146},[38,498,155],{"class":48},[38,500,501],{"class":40,"line":152},[38,502,66],{"emptyLinePlaceholder":65},[38,504,505,507],{"class":40,"line":158},[38,506,169],{"class":85},[38,508,509],{"class":48},"(qq);\n",[17,511,512,513,516],{},"When a variable name inside the function matches the function's own parameter, redeclaring it doesn't overwrite the original parameter value. So that ",[35,514,515],{},"var qq"," declaration is basically a no-op.",[17,518,519,520,522],{},"But reassigning ",[35,521,460],{}," a new value is allowed:",[28,524,526],{"className":30,"code":525,"language":32,"meta":33,"style":33},"var qq = 'jack';\n\nfunction fn(qq) {\n  console.log(qq); \u002F\u002F jack\n  var qq;\n  console.log(qq); \u002F\u002F jack\n  qq = 'Ray';\n  console.log(qq); \u002F\u002F Ray\n}\n\nfn(qq);\n",[35,527,528,540,544,556,566,572,582,593,604,608,612],{"__ignoreMap":33},[38,529,530,532,534,536,538],{"class":40,"line":41},[38,531,45],{"class":44},[38,533,437],{"class":48},[38,535,52],{"class":44},[38,537,442],{"class":55},[38,539,59],{"class":48},[38,541,542],{"class":40,"line":62},[38,543,66],{"emptyLinePlaceholder":65},[38,545,546,548,550,552,554],{"class":40,"line":69},[38,547,92],{"class":44},[38,549,455],{"class":85},[38,551,95],{"class":48},[38,553,460],{"class":98},[38,555,102],{"class":48},[38,557,558,560,562,564],{"class":40,"line":82},[38,559,467],{"class":48},[38,561,127],{"class":85},[38,563,472],{"class":48},[38,565,476],{"class":475},[38,567,568,570],{"class":40,"line":105},[38,569,481],{"class":44},[38,571,484],{"class":48},[38,573,574,576,578,580],{"class":40,"line":121},[38,575,467],{"class":48},[38,577,127],{"class":85},[38,579,472],{"class":48},[38,581,476],{"class":475},[38,583,584,587,589,591],{"class":40,"line":146},[38,585,586],{"class":48},"  qq ",[38,588,52],{"class":44},[38,590,56],{"class":55},[38,592,59],{"class":48},[38,594,595,597,599,601],{"class":40,"line":152},[38,596,467],{"class":48},[38,598,127],{"class":85},[38,600,472],{"class":48},[38,602,603],{"class":475},"\u002F\u002F Ray\n",[38,605,606],{"class":40,"line":158},[38,607,155],{"class":48},[38,609,610],{"class":40,"line":163},[38,611,66],{"emptyLinePlaceholder":65},[38,613,615,617],{"class":40,"line":614},11,[38,616,169],{"class":85},[38,618,509],{"class":48},[17,620,621],{},"So we can see that a function's parameter is really just another kind of variable. If you want to change a parameter's value, the only way is to reassign it. Which raises a question — do function parameters get affected by hoisting? Yep, they do.",[28,623,625],{"className":30,"code":624,"language":32,"meta":33,"style":33},"var qq = 'jack';\n\nfunction fn(qq) {\n  console.log(qq); \u002F\u002F qq function\n  function qq() {}\n  var qq; \u002F\u002F note: functions have higher priority than variables, so redeclaring here is a no-op\n  console.log(qq); \u002F\u002F qq function\n  qq = 'Ray';\n  console.log(qq); \u002F\u002F Ray\n}\n\nfn(qq);\n",[35,626,627,639,643,655,666,677,687,697,707,717,721,725],{"__ignoreMap":33},[38,628,629,631,633,635,637],{"class":40,"line":41},[38,630,45],{"class":44},[38,632,437],{"class":48},[38,634,52],{"class":44},[38,636,442],{"class":55},[38,638,59],{"class":48},[38,640,641],{"class":40,"line":62},[38,642,66],{"emptyLinePlaceholder":65},[38,644,645,647,649,651,653],{"class":40,"line":69},[38,646,92],{"class":44},[38,648,455],{"class":85},[38,650,95],{"class":48},[38,652,460],{"class":98},[38,654,102],{"class":48},[38,656,657,659,661,663],{"class":40,"line":82},[38,658,467],{"class":48},[38,660,127],{"class":85},[38,662,472],{"class":48},[38,664,665],{"class":475},"\u002F\u002F qq function\n",[38,667,668,671,674],{"class":40,"line":105},[38,669,670],{"class":44},"  function",[38,672,673],{"class":85}," qq",[38,675,676],{"class":48},"() {}\n",[38,678,679,681,684],{"class":40,"line":121},[38,680,481],{"class":44},[38,682,683],{"class":48}," qq; ",[38,685,686],{"class":475},"\u002F\u002F note: functions have higher priority than variables, so redeclaring here is a no-op\n",[38,688,689,691,693,695],{"class":40,"line":146},[38,690,467],{"class":48},[38,692,127],{"class":85},[38,694,472],{"class":48},[38,696,665],{"class":475},[38,698,699,701,703,705],{"class":40,"line":152},[38,700,586],{"class":48},[38,702,52],{"class":44},[38,704,56],{"class":55},[38,706,59],{"class":48},[38,708,709,711,713,715],{"class":40,"line":158},[38,710,467],{"class":48},[38,712,127],{"class":85},[38,714,472],{"class":48},[38,716,603],{"class":475},[38,718,719],{"class":40,"line":163},[38,720,155],{"class":48},[38,722,723],{"class":40,"line":614},[38,724,66],{"emptyLinePlaceholder":65},[38,726,728,730],{"class":40,"line":727},12,[38,729,169],{"class":85},[38,731,509],{"class":48},[17,733,734],{},"One thing to keep in mind here: no matter what, hoisting inside the function never affects how the argument gets passed in — it only ever gets reassigned.",[12,736,738],{"id":737},"passing-arguments","Passing arguments",[17,740,741,742,745],{},"On a related note, when the number of arguments you pass in doesn't match the number of parameters, the missing ones get filled with ",[35,743,744],{},"undefined",". It's the same idea as declaring a variable without giving it a value.",[28,747,749],{"className":30,"code":748,"language":32,"meta":33,"style":33},"function fn(qq, bb, cc) {\n  console.log(qq, bb, cc); \u002F\u002F Ray, undefined, undefined\n}\n\nfn('Ray');\n",[35,750,751,773,785,789,793],{"__ignoreMap":33},[38,752,753,755,757,759,761,763,766,768,771],{"class":40,"line":41},[38,754,92],{"class":44},[38,756,455],{"class":85},[38,758,95],{"class":48},[38,760,460],{"class":98},[38,762,137],{"class":48},[38,764,765],{"class":98},"bb",[38,767,137],{"class":48},[38,769,770],{"class":98},"cc",[38,772,102],{"class":48},[38,774,775,777,779,782],{"class":40,"line":62},[38,776,467],{"class":48},[38,778,127],{"class":85},[38,780,781],{"class":48},"(qq, bb, cc); ",[38,783,784],{"class":475},"\u002F\u002F Ray, undefined, undefined\n",[38,786,787],{"class":40,"line":69},[38,788,155],{"class":48},[38,790,791],{"class":40,"line":82},[38,792,66],{"emptyLinePlaceholder":65},[38,794,795,797,799,802],{"class":40,"line":105},[38,796,169],{"class":85},[38,798,95],{"class":48},[38,800,801],{"class":55},"'Ray'",[38,803,143],{"class":48},[17,805,806],{},"You also have to be careful about pass-by-reference when passing in objects. If you pass in a whole object, it keeps the original object's pass-by-reference behavior.",[28,808,810],{"className":30,"code":809,"language":32,"meta":33,"style":33},"var obj = {\n  name: 'Ray',\n};\n\nfunction fn(a) {\n  a.name = 'QQ';\n}\n\nfn(obj);\n\nconsole.log(obj.name); \u002F\u002F QQ\n",[35,811,812,822,832,837,841,854,866,870,874,881,885],{"__ignoreMap":33},[38,813,814,816,818,820],{"class":40,"line":41},[38,815,45],{"class":44},[38,817,74],{"class":48},[38,819,52],{"class":44},[38,821,79],{"class":48},[38,823,824,827,829],{"class":40,"line":62},[38,825,826],{"class":48},"  name: ",[38,828,801],{"class":55},[38,830,831],{"class":48},",\n",[38,833,834],{"class":40,"line":69},[38,835,836],{"class":48},"};\n",[38,838,839],{"class":40,"line":82},[38,840,66],{"emptyLinePlaceholder":65},[38,842,843,845,847,849,852],{"class":40,"line":105},[38,844,92],{"class":44},[38,846,455],{"class":85},[38,848,95],{"class":48},[38,850,851],{"class":98},"a",[38,853,102],{"class":48},[38,855,856,859,861,864],{"class":40,"line":121},[38,857,858],{"class":48},"  a.name ",[38,860,52],{"class":44},[38,862,863],{"class":55}," 'QQ'",[38,865,59],{"class":48},[38,867,868],{"class":40,"line":146},[38,869,155],{"class":48},[38,871,872],{"class":40,"line":152},[38,873,66],{"emptyLinePlaceholder":65},[38,875,876,878],{"class":40,"line":158},[38,877,169],{"class":85},[38,879,880],{"class":48},"(obj);\n",[38,882,883],{"class":40,"line":163},[38,884,66],{"emptyLinePlaceholder":65},[38,886,887,889,891,894],{"class":40,"line":614},[38,888,293],{"class":48},[38,890,127],{"class":85},[38,892,893],{"class":48},"(obj.name); ",[38,895,896],{"class":475},"\u002F\u002F QQ\n",[17,898,899],{},"But if you only pass in a single property of the object, you won't run into the pass-by-reference problem.",[28,901,903],{"className":30,"code":902,"language":32,"meta":33,"style":33},"var obj = {\n  name: 'Ray',\n};\n\nfunction fn(a) {\n  a.name = 'QQ';\n}\n\nfn(obj.name);\n\nconsole.log(obj.name); \u002F\u002F Ray\n",[35,904,905,915,923,927,931,943,953,957,961,968,972],{"__ignoreMap":33},[38,906,907,909,911,913],{"class":40,"line":41},[38,908,45],{"class":44},[38,910,74],{"class":48},[38,912,52],{"class":44},[38,914,79],{"class":48},[38,916,917,919,921],{"class":40,"line":62},[38,918,826],{"class":48},[38,920,801],{"class":55},[38,922,831],{"class":48},[38,924,925],{"class":40,"line":69},[38,926,836],{"class":48},[38,928,929],{"class":40,"line":82},[38,930,66],{"emptyLinePlaceholder":65},[38,932,933,935,937,939,941],{"class":40,"line":105},[38,934,92],{"class":44},[38,936,455],{"class":85},[38,938,95],{"class":48},[38,940,851],{"class":98},[38,942,102],{"class":48},[38,944,945,947,949,951],{"class":40,"line":121},[38,946,858],{"class":48},[38,948,52],{"class":44},[38,950,863],{"class":55},[38,952,59],{"class":48},[38,954,955],{"class":40,"line":146},[38,956,155],{"class":48},[38,958,959],{"class":40,"line":152},[38,960,66],{"emptyLinePlaceholder":65},[38,962,963,965],{"class":40,"line":158},[38,964,169],{"class":85},[38,966,967],{"class":48},"(obj.name);\n",[38,969,970],{"class":40,"line":163},[38,971,66],{"emptyLinePlaceholder":65},[38,973,974,976,978,980],{"class":40,"line":614},[38,975,293],{"class":48},[38,977,127],{"class":85},[38,979,893],{"class":48},[38,981,603],{"class":475},[17,983,984],{},"This is why a lot of ESLint rules suggest you don't mutate the object you've been passed — it stops you from accidentally changing something you didn't mean to touch.",[12,986,988],{"id":987},"callback-functions","Callback Functions",[17,990,991],{},"Besides objects and plain values, functions can also be passed in as arguments — and that function can be an anonymous function.",[28,993,995],{"className":30,"code":994,"language":32,"meta":33,"style":33},"function functionA(fn) {\n  fn();\n}\n\nfunctionA(function() {\n  console.log('Ray');\n})\n",[35,996,997,1010,1017,1021,1025,1037,1049],{"__ignoreMap":33},[38,998,999,1001,1004,1006,1008],{"class":40,"line":41},[38,1000,92],{"class":44},[38,1002,1003],{"class":85}," functionA",[38,1005,95],{"class":48},[38,1007,169],{"class":98},[38,1009,102],{"class":48},[38,1011,1012,1014],{"class":40,"line":62},[38,1013,86],{"class":85},[38,1015,1016],{"class":48},"();\n",[38,1018,1019],{"class":40,"line":69},[38,1020,155],{"class":48},[38,1022,1023],{"class":40,"line":82},[38,1024,66],{"emptyLinePlaceholder":65},[38,1026,1027,1030,1032,1034],{"class":40,"line":105},[38,1028,1029],{"class":85},"functionA",[38,1031,95],{"class":48},[38,1033,92],{"class":44},[38,1035,1036],{"class":48},"() {\n",[38,1038,1039,1041,1043,1045,1047],{"class":40,"line":121},[38,1040,467],{"class":48},[38,1042,127],{"class":85},[38,1044,95],{"class":48},[38,1046,801],{"class":55},[38,1048,143],{"class":48},[38,1050,1051],{"class":40,"line":146},[38,1052,1053],{"class":48},"})\n",[17,1055,1056],{},"This pattern is called a callback function. As long as what you pass in is a function expression, it can be called like this:",[28,1058,1060],{"className":30,"code":1059,"language":32,"meta":33,"style":33},"function functionB(fn) {\n  console.log('Ray');\n}\n\nfunction functionA(fn) {\n  fn();\n}\n\nfunctionA(functionB);\n",[35,1061,1062,1075,1087,1091,1095,1107,1113,1117,1121