[{"data":1,"prerenderedAt":741},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F12\u002Fjavascript-core-32-object-json\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F12\u002Fjavascript-core-32-object-json\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F12\u002Fjavascript-core-32-object-json\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F12\u002Fjavascript-core-32-object-json\u002F":717,"related:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F12\u002Fjavascript-core-32-object-json\u002F":726},"\u002Fjavascript\u002F20201112\u002F8535\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":701,"date":702,"description":703,"extension":704,"lang":705,"meta":706,"navigation":306,"path":707,"readingMinutes":336,"seo":708,"standalone":709,"stem":710,"tags":711,"tldr":714,"updated":702,"url":715,"__hash__":716},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-32-object-json.md","JavaScript Core Concepts (32) - Objects - JSON: It Looks Like an Object, But It Isn't","1000879012",{"type":9,"value":10,"toc":696},"minimark",[11,16,20,24,27,79,90,96,99,104,107,146,176,179,187,194,201,204,217,220,242,254,493,508,517,525,618,624,676,679,683,692],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This chapter is all about JSON.",[12,21,23],{"id":22},"json","JSON",[17,25,26],{},"JSON is kind of special — on the surface it looks a lot like a JavaScript object.",[28,29,33],"pre",{"className":30,"code":31,"language":22,"meta":32,"style":32},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"name\":\"Ray\",\n  \"fn\":\"SayHello\"\n}\n","",[34,35,36,45,62,73],"code",{"__ignoreMap":32},[37,38,41],"span",{"class":39,"line":40},"line",1,[37,42,44],{"class":43},"sMAXC","{\n",[37,46,48,52,55,59],{"class":39,"line":47},2,[37,49,51],{"class":50},"sKpQp","  \"name\"",[37,53,54],{"class":43},":",[37,56,58],{"class":57},"sTRMh","\"Ray\"",[37,60,61],{"class":43},",\n",[37,63,65,68,70],{"class":39,"line":64},3,[37,66,67],{"class":50},"  \"fn\"",[37,69,54],{"class":43},[37,71,72],{"class":57},"\"SayHello\"\n",[37,74,76],{"class":39,"line":75},4,[37,77,78],{"class":43},"}\n",[17,80,81,82,89],{},"To understand how JSON relates to JavaScript, the ",[83,84,88],"a",{"href":85,"rel":86},"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FJSON",[87],"nofollow","Wikipedia"," description is a good starting point:",[91,92,93],"blockquote",{},[17,94,95],{},"JSON (JavaScript Object Notation, pronounced \u002Fˈdʒeɪsən\u002F) is a lightweight data-interchange language designed by Douglas Crockford. It's based on human-readable text and is used to transmit data objects made up of attribute-value pairs or sequences of values. Although JSON is a subset of JavaScript, it's a language-independent text format that borrows some conventions from the C family of languages.",[17,97,98],{},"But here's the line that really matters:",[91,100,101],{},[17,102,103],{},"The JSON data format is language-independent. Even though it came from JavaScript, plenty of programming languages today can generate and parse JSON data.",[17,105,106],{},"So in short, JSON is just a data format — it has no real connection to JavaScript. Which means if you try to write JSON using JavaScript object syntax, you'll run into errors pretty easily.",[28,108,110],{"className":30,"code":109,"language":22,"meta":32,"style":32},"{\n  name: 'Ray',\n  fn: 'SayHello',\n}\n",[34,111,112,116,130,142],{"__ignoreMap":32},[37,113,114],{"class":39,"line":40},[37,115,44],{"class":43},[37,117,118,122,125,128],{"class":39,"line":47},[37,119,121],{"class":120},"szH_Z","  name",[37,123,124],{"class":43},": ",[37,126,127],{"class":120},"'Ray'",[37,129,61],{"class":43},[37,131,132,135,137,140],{"class":39,"line":64},[37,133,134],{"class":120},"  fn",[37,136,124],{"class":43},[37,138,139],{"class":120},"'SayHello'",[37,141,61],{"class":43},[37,143,144],{"class":39,"line":75},[37,145,78],{"class":43},[28,147,148],{"className":30,"code":31,"language":22,"meta":32,"style":32},[34,149,150,154,164,172],{"__ignoreMap":32},[37,151,152],{"class":39,"line":40},[37,153,44],{"class":43},[37,155,156,158,160,162],{"class":39,"line":47},[37,157,51],{"class":50},[37,159,54],{"class":43},[37,161,58],{"class":57},[37,163,61],{"class":43},[37,165,166,168,170],{"class":39,"line":64},[37,167,67],{"class":50},[37,169,54],{"class":43},[37,171,72],{"class":57},[37,173,174],{"class":39,"line":75},[37,175,78],{"class":43},[17,177,178],{},"The first one is a bad example — if you actually paste it into an editor, you'll see it flagged in red. VSCode does exactly this.",[17,180,181,182,186],{},"From that we learn JSON keys and values must be ",[183,184,185],"strong",{},"double-quoted strings"," (the red is the error hint).",[17,188,189],{},[190,191],"img",{"alt":192,"src":193},"JSON comparison","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-08%2017.04.35.png",[17,195,196,197,200],{},"One more thing to watch out for: the last item in JSON can't have a trailing ",[34,198,199],{},",",".",[17,202,203],{},"So the biggest differences between JSON and a JavaScript object are:",[205,206,207,211,214],"ul",{},[208,209,210],"li",{},"Everything has to be a string format",[208,212,213],{},"No trailing comma on the last item",[208,215,216],{},"Always double quotes, never single quotes",[17,218,219],{},"Given all that, how do we actually use JSON inside JavaScript? Well, JavaScript gives us two methods specifically for converting to and from JSON:",[205,221,222,232],{},[208,223,224,227],{},[34,225,226],{},"JSON.stringify()",[205,228,229],{},[208,230,231],{},"Converts an object into JSON format",[208,233,234,237],{},[34,235,236],{},"JSON.parse()",[205,238,239],{},[208,240,241],{},"Converts JSON into an object",[17,243,244,245,247,248,253],{},"Let's start with ",[34,246,226],{},". MDN has a whole set of ",[83,249,252],{"href":250,"rel":251},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FGlobal_Objects\u002FJSON\u002Fstringify",[87],"reference examples",", so I'll just paste the MDN samples here for reference:",[28,255,259],{"className":256,"code":257,"language":258,"meta":32,"style":32},"language-js shiki shiki-themes github-dark-high-contrast","console.log(JSON.stringify({ x: 5, y: 6 }));\n\u002F\u002F expected output: \"{\"x\":5,\"y\":6}\"\n\nconsole.log(JSON.stringify([new Number(3), new String('false'), new Boolean(false)]));\n\u002F\u002F expected output: \"[3,\"false\",false]\"\n\nconsole.log(JSON.stringify({ x: [10, undefined, function(){}, Symbol('')] }));\n\u002F\u002F expected output: \"{\"x\":[10,null,null,null]}\"\n\nconsole.log(JSON.stringify(new Date(2006, 0, 2, 15, 4, 5)));\n\u002F\u002F expected output: \"\"2006-01-02T15:04:05.000Z\"\"\n","js",[34,260,261,296,302,308,365,371,376,422,428,433,487],{"__ignoreMap":32},[37,262,263,266,270,273,276,278,281,284,287,290,293],{"class":39,"line":40},[37,264,265],{"class":43},"console.",[37,267,269],{"class":268},"sj_SG","log",[37,271,272],{"class":43},"(",[37,274,23],{"class":275},"sCcAr",[37,277,200],{"class":43},[37,279,280],{"class":268},"stringify",[37,282,283],{"class":43},"({ x: ",[37,285,286],{"class":275},"5",[37,288,289],{"class":43},", y: ",[37,291,292],{"class":275},"6",[37,294,295],{"class":43}," }));\n",[37,297,298],{"class":39,"line":47},[37,299,301],{"class":300},"sQrFR","\u002F\u002F expected output: \"{\"x\":5,\"y\":6}\"\n",[37,303,304],{"class":39,"line":64},[37,305,307],{"emptyLinePlaceholder":306},true,"\n",[37,309,310,312,314,316,318,320,322,325,329,332,334,337,340,342,345,347,350,352,354,357,359,362],{"class":39,"line":75},[37,311,265],{"class":43},[37,313,269],{"class":268},[37,315,272],{"class":43},[37,317,23],{"class":275},[37,319,200],{"class":43},[37,321,280],{"class":268},[37,323,324],{"class":43},"([",[37,326,328],{"class":327},"sWyjQ","new",[37,330,331],{"class":268}," Number",[37,333,272],{"class":43},[37,335,336],{"class":275},"3",[37,338,339],{"class":43},"), ",[37,341,328],{"class":327},[37,343,344],{"class":268}," String",[37,346,272],{"class":43},[37,348,349],{"class":57},"'false'",[37,351,339],{"class":43},[37,353,328],{"class":327},[37,355,356],{"class":268}," Boolean",[37,358,272],{"class":43},[37,360,361],{"class":275},"false",[37,363,364],{"class":43},")]));\n",[37,366,368],{"class":39,"line":367},5,[37,369,370],{"class":300},"\u002F\u002F expected output: \"[3,\"false\",false]\"\n",[37,372,374],{"class":39,"line":373},6,[37,375,307],{"emptyLinePlaceholder":306},[37,377,379,381,383,385,387,389,391,394,397,400,403,405,408,411,414,416,419],{"class":39,"line":378},7,[37,380,265],{"class":43},[37,382,269],{"class":268},[37,384,272],{"class":43},[37,386,23],{"class":275},[37,388,200],{"class":43},[37,390,280],{"class":268},[37,392,393],{"class":43},"({ x: [",[37,395,396],{"class":275},"10",[37,398,399],{"class":43},", ",[37,401,402],{"class":275},"undefined",[37,404,399],{"class":43},[37,406,407],{"class":327},"function",[37,409,410],{"class":43},"(){}, ",[37,412,413],{"class":268},"Symbol",[37,415,272],{"class":43},[37,417,418],{"class":57},"''",[37,420,421],{"class":43},")] }));\n",[37,423,425],{"class":39,"line":424},8,[37,426,427],{"class":300},"\u002F\u002F expected output: \"{\"x\":[10,null,null,null]}\"\n",[37,429,431],{"class":39,"line":430},9,[37,432,307],{"emptyLinePlaceholder":306},[37,434,436,438,440,442,444,446,448,450,452,455,457,460,462,465,467,470,472,475,477,480,482,484],{"class":39,"line":435},10,[37,437,265],{"class":43},[37,439,269],{"class":268},[37,441,272],{"class":43},[37,443,23],{"class":275},[37,445,200],{"class":43},[37,447,280],{"class":268},[37,449,272],{"class":43},[37,451,328],{"class":327},[37,453,454],{"class":268}," Date",[37,456,272],{"class":43},[37,458,459],{"class":275},"2006",[37,461,399],{"class":43},[37,463,464],{"class":275},"0",[37,466,399],{"class":43},[37,468,469],{"class":275},"2",[37,471,399],{"class":43},[37,473,474],{"class":275},"15",[37,476,399],{"class":43},[37,478,479],{"class":275},"4",[37,481,399],{"class":43},[37,483,286],{"class":275},[37,485,486],{"class":43},")));\n",[37,488,490],{"class":39,"line":489},11,[37,491,492],{"class":300},"\u002F\u002F expected output: \"\"2006-01-02T15:04:05.000Z\"\"\n",[17,494,495,496,399,498,501,502,504,505,200],{},"As you can see, the contents get turned into strings and numbers. The thing to be careful about is values like ",[34,497,402],{},[34,499,500],{},"NaN",", or ",[34,503,407],{}," — those don't convert cleanly and just become ",[34,506,507],{},"null",[17,509,510,511,513,514,516],{},"What about ",[34,512,236],{},"? Usually we only pass it a single argument, but ",[34,515,236],{}," can actually take more than that.",[17,518,519,520,54],{},"The example below is from ",[83,521,524],{"href":522,"rel":523},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FGlobal_Objects\u002FJSON\u002Fparse",[87],"MDN",[28,526,528],{"className":256,"code":527,"language":258,"meta":32,"style":32},"JSON.parse('{\"p\": 5}', function(k, v) {\n  if (typeof v === 'number') {\n    return v * 2;\n  }\n  return v;\n});\n",[34,529,530,562,584,600,605,613],{"__ignoreMap":32},[37,531,532,534,536,539,541,544,546,548,550,554,556,559],{"class":39,"line":40},[37,533,23],{"class":275},[37,535,200],{"class":43},[37,537,538],{"class":268},"parse",[37,540,272],{"class":43},[37,542,543],{"class":57},"'{\"p\": 5}'",[37,545,399],{"class":43},[37,547,407],{"class":327},[37,549,272],{"class":43},[37,551,553],{"class":552},"s_sBn","k",[37,555,399],{"class":43},[37,557,558],{"class":552},"v",[37,560,561],{"class":43},") {\n",[37,563,564,567,570,573,576,579,582],{"class":39,"line":47},[37,565,566],{"class":327},"  if",[37,568,569],{"class":43}," (",[37,571,572],{"class":327},"typeof",[37,574,575],{"class":43}," v ",[37,577,578],{"class":327},"===",[37,580,581],{"class":57}," 'number'",[37,583,561],{"class":43},[37,585,586,589,591,594,597],{"class":39,"line":64},[37,587,588],{"class":327},"    return",[37,590,575],{"class":43},[37,592,593],{"class":327},"*",[37,595,596],{"class":275}," 2",[37,598,599],{"class":43},";\n",[37,601,602],{"class":39,"line":75},[37,603,604],{"class":43},"  }\n",[37,606,607,610],{"class":39,"line":367},[37,608,609],{"class":327},"  return",[37,611,612],{"class":43}," v;\n",[37,614,615],{"class":39,"line":373},[37,616,617],{"class":43},"});\n",[17,619,620,621,623],{},"So ",[34,622,236],{}," doesn't just convert a string into an object — it can also walk through and surface every value along the way:",[28,625,627],{"className":256,"code":626,"language":258,"meta":32,"style":32},"JSON.parse('{\"1\": 1, \"2\": 2, \"3\": {\"4\": 4, \"5\": {\"6\": 6}}}', function(k, v) {\n  console.log(v);\n  return v;\n});\n",[34,628,629,656,666,672],{"__ignoreMap":32},[37,630,631,633,635,637,639,642,644,646,648,650,652,654],{"class":39,"line":40},[37,632,23],{"class":275},[37,634,200],{"class":43},[37,636,538],{"class":268},[37,638,272],{"class":43},[37,640,641],{"class":57},"'{\"1\": 1, \"2\": 2, \"3\": {\"4\": 4, \"5\": {\"6\": 6}}}'",[37,643,399],{"class":43},[37,645,407],{"class":327},[37,647,272],{"class":43},[37,649,553],{"class":552},[37,651,399],{"class":43},[37,653,558],{"class":552},[37,655,561],{"class":43},[37,657,658,661,663],{"class":39,"line":47},[37,659,660],{"class":43},"  console.",[37,662,269],{"class":268},[37,664,665],{"class":43},"(v);\n",[37,667,668,670],{"class":39,"line":64},[37,669,609],{"class":327},[37,671,612],{"class":43},[37,673,674],{"class":39,"line":75},[37,675,617],{"class":43},[17,677,678],{},"Pretty neat trick, honestly.",[12,680,682],{"id":681},"references","References",[205,684,685],{},[208,686,687],{},[83,688,691],{"href":689,"rel":690},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[87],"JavaScript Core (course in Mandar