so the real point here is how you read values out of it. The key idea is that every property on an object is a string. Because of that, you can read any value using either bracket notation or the dot operator — except for a few special properties that ",[210,211,212],"em",{},"have"," to use brackets.",[25,215,217],{"className":27,"code":216,"language":29,"meta":30,"style":30},"person['Hello']();\nperson['interests'];\n",[32,218,219,229],{"__ignoreMap":30},[35,220,221,224,226],{"class":37,"line":38},[35,222,223],{"class":45},"person[",[35,225,158],{"class":61},[35,227,228],{"class":45},"]();\n",[35,230,231,233,236],{"class":37,"line":55},[35,232,223],{"class":45},[35,234,235],{"class":61},"'interests'",[35,237,238],{"class":45},"];\n",[17,240,241],{},"Basically the rule of thumb with brackets is: if the key is a string (with special characters) or a number, you have to use brackets.",[17,243,244],{},"On top of that, brackets let you pass the key in as a variable:",[25,246,248],{"className":27,"code":247,"language":29,"meta":30,"style":30},"var item = 'interests';\nperson[item];\n",[32,249,250,265],{"__ignoreMap":30},[35,251,252,254,257,259,262],{"class":37,"line":38},[35,253,42],{"class":41},[35,255,256],{"class":45}," item ",[35,258,49],{"class":41},[35,260,261],{"class":61}," 'interests'",[35,263,264],{"class":45},";\n",[35,266,267],{"class":37,"line":55},[35,268,269],{"class":45},"person[item];\n",[17,271,272],{},"So a slightly more advanced move is pairing that with a loop to read everything in one go:",[25,274,276],{"className":27,"code":275,"language":29,"meta":30,"style":30},"var arr = ['name', 'age', '1', 'gender', 'interests', 'greeting', 'Hello'];\nfor (var i = 0 ; i \u003C arr.length; i++) {\n  console.log(person[arr[i]]);\n}\n",[32,277,278,322,361,371],{"__ignoreMap":30},[35,279,280,282,285,287,290,293,295,298,300,302,304,307,309,311,313,316,318,320],{"class":37,"line":38},[35,281,42],{"class":41},[35,283,284],{"class":45}," arr ",[35,286,49],{"class":41}