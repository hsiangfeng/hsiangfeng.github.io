[{"data":1,"prerenderedAt":879},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F08\u002Fjavascript-core-31-object-array\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F08\u002Fjavascript-core-31-object-array\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F08\u002Fjavascript-core-31-object-array\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F08\u002Fjavascript-core-31-object-array\u002F":855,"related:\u002Fen\u002Fjavascript\u002F2020\u002F11\u002F08\u002Fjavascript-core-31-object-array\u002F":864},"\u002Fjavascript\u002F20201108\u002F33884\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":838,"date":839,"description":840,"extension":841,"lang":842,"meta":843,"navigation":213,"path":844,"readingMinutes":845,"seo":846,"standalone":847,"stem":848,"tags":849,"tldr":852,"updated":839,"url":853,"__hash__":854},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-31-object-array.md","JavaScript Core Concepts (31) - Objects - Arrays","1000871093",{"type":9,"value":10,"toc":830},"minimark",[11,16,20,24,27,37,40,116,119,126,132,142,147,151,161,230,234,241,309,318,322,325,385,388,393,396,466,473,536,539,545,555,616,626,631,634,645,812,816,826],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This time around, let's talk about arrays.",[12,21,23],{"id":22},"arrays","Arrays",[17,25,26],{},"First off, we covered earlier that in JavaScript there are really only two kinds of things:",[28,29,30,34],"ul",{},[31,32,33],"li",{},"Primitive types",[31,35,36],{},"Object types",[17,38,39],{},"So where do arrays fit in? An array in JavaScript is actually a kind of object type. But arrays are pretty special to work with. For one thing, you can stuff all sorts of types into an array. In some languages you can't just throw whatever you want in there — for example, if the array holds strings, the whole array has to be strings. JavaScript doesn't care:",[41,42,47],"pre",{"className":43,"code":44,"language":45,"meta":46,"style":46},"language-js shiki shiki-themes github-dark-high-contrast","var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\n","js","",[48,49,50,69,79,88,96,104,110],"code",{"__ignoreMap":46},[51,52,55,59,63,66],"span",{"class":53,"line":54},"line",1,[51,56,58],{"class":57},"sWyjQ","var",[51,60,62],{"class":61},"sMAXC"," arr ",[51,64,65],{"class":57},"=",[51,67,68],{"class":61}," [\n",[51,70,72,76],{"class":53,"line":71},2,[51,73,75],{"class":74},"sCcAr","  1",[51,77,78],{"class":61},",\n",[51,80,82,86],{"class":53,"line":81},3,[51,83,85],{"class":84},"sTRMh","  '1'",[51,87,78],{"class":61},[51,89,91,94],{"class":53,"line":90},4,[51,92,93],{"class":74},"  true",[51,95,78],{"class":61},[51,97,99,102],{"class":53,"line":98},5,[51,100,101],{"class":74},"  undefined",[51,103,78],{"class":61},[51,105,107],{"class":53,"line":106},6,[51,108,109],{"class":61},"  {},\n",[51,111,113],{"class":53,"line":112},7,[51,114,115],{"class":61},"];\n",[17,117,118],{},"So you can see an array is basically a superset of all the different types.",[17,120,121,122,125],{},"Even though if you throw it into the browser it shows up as ",[48,123,124],{},"Array",":",[17,127,128],{},[129,130],"img",{"alt":124,"src":131},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-08%2016.35.57.png",[17,133,134,135,138,139,125],{},"If you run ",[48,136,137],{},"typeof arr",", you'll actually get ",[48,140,141],{},"object",[17,143,144],{},[129,145],{"alt":141,"src":146},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-08%2016.37.35.png",[12,148,150],{"id":149},"reading-values-from-an-array","Reading values from an array",[17,152,153,154,157,158,125],{},"To read a value out of an array, you use square brackets. One thing to remember: arrays count from 0, so the position of ",[48,155,156],{},"true"," is ",[48,159,160],{},"2",[41,162,164],{"className":43,"code":163,"language":45,"meta":46,"style":46},"var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\n\narr[2]; \u002F\u002F true\n",[48,165,166,176,182,188,194,200,204,208,215],{"__ignoreMap":46},[51,167,168,170,172,174],{"class":53,"line":54},[51,169,58],{"class":57},[51,171,62],{"class":61},[51,173,65],{"class":57},[51,175,68],{"class":61},[51,177,178,180],{"class":53,"line":71},[51,179,75],{"class":74},[51,181,78],{"class":61},[51,183,184,186],{"class":53,"line":81},[51,185,85],{"class":84},[51,187,78],{"class":61},[51,189,190,192],{"class":53,"line":90},[51,191,93],{"class":74},[51,193,78],{"class":61},[51,195,196,198],{"class":53,"line":98},[51,197,101],{"class":74},[51,199,78],{"class":61},[51,201,202],{"class":53,"line":106},[51,203,109],{"class":61},[51,205,206],{"class":53,"line":112},[51,207,115],{"class":61},[51,209,211],{"class":53,"line":210},8,[51,212,214],{"emptyLinePlaceholder":213},true,"\n",[51,216,218,221,223,226],{"class":53,"line":217},9,[51,219,220],{"class":61},"arr[",[51,222,160],{"class":74},[51,224,225],{"class":61},"]; ",[51,227,229],{"class":228},"sQrFR","\u002F\u002F true\n",[12,231,233],{"id":232},"adding-to-an-array","Adding to an array",[17,235,236,237,240],{},"If you want to add data to an array, the most common way is ",[48,238,239],{},"push",", which tacks the value onto the end:",[41,242,244],{"className":43,"code":243,"language":45,"meta":46,"style":46},"var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\n\narr.push('Hello');\n",[48,245,246,256,262,268,274,280,284,288,292],{"__ignoreMap":46},[51,247,248,250,252,254],{"class":53,"line":54},[51,249,58],{"class":57},[51,251,62],{"class":61},[51,253,65],{"class":57},[51,255,68],{"class":61},[51,257,258,260],{"class":53,"line":71},[51,259,75],{"class":74},[51,261,78],{"class":61},[51,263,264,266],{"class":53,"line":81},[51,265,85],{"class":84},[51,267,78],{"class":61},[51,269,270,272],{"class":53,"line":90},[51,271,93],{"class":74},[51,273,78],{"class":61},[51,275,276,278],{"class":53,"line":98},[51,277,101],{"class":74},[51,279,78],{"class":61},[51,281,282],{"class":53,"line":106},[51,283,109],{"class":61},[51,285,286],{"class":53,"line":112},[51,287,115],{"class":61},[51,289,290],{"class":53,"line":210},[51,291,214],{"emptyLinePlaceholder":213},[51,293,294,297,300,303,306],{"class":53,"line":217},[51,295,296],{"class":61},"arr.",[51,298,239],{"class":299},"sj_SG",[51,301,302],{"class":61},"(",[51,304,305],{"class":84},"'Hello'",[51,307,308],{"class":61},");\n",[17,310,311,312,317],{},"I won't go through all the array methods here one by one — you can check out my earlier post for that: ",[313,314,316],"a",{"href":315},"\u002Fjavascript\u002F20190421\u002F1216566123\u002F","20 ways to work with JavaScript arrays (article in Mandarin)",".",[12,319,321],{"id":320},"adding-properties-to-an-array","Adding properties to an array",[17,323,324],{},"Here's something really special about arrays — they let you add properties. What does that mean? Basically it's the same idea as adding a property to an object:",[41,326,328],{"className":43,"code":327,"language":45,"meta":46,"style":46},"var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\narr.hello = 'Ray';\n",[48,329,330,340,346,352,358,364,368,372],{"__ignoreMap":46},[51,331,332,334,336,338],{"class":53,"line":54},[51,333,58],{"class":57},[51,335,62],{"class":61},[51,337,65],{"class":57},[51,339,68],{"class":61},[51,341,342,344],{"class":53,"line":71},[51,343,75],{"class":74},[51,345,78],{"class":61},[51,347,348,350],{"class":53,"line":81},[51,349,85],{"class":84},[51,351,78],{"class":61},[51,353,354,356],{"class":53,"line":90},[51,355,93],{"class":74},[51,357,78],{"class":61},[51,359,360,362],{"class":53,"line":98},[51,361,101],{"class":74},[51,363,78],{"class":61},[51,365,366],{"class":53,"line":106},[51,367,109],{"class":61},[51,369,370],{"class":53,"line":112},[51,371,115],{"class":61},[51,373,374,377,379,382],{"class":53,"line":210},[51,375,376],{"class":61},"arr.hello ",[51,378,65],{"class":57},[51,380,381],{"class":84}," 'Ray'",[51,383,384],{"class":61},";\n",[17,386,387],{},"But here's the weird part: the array length doesn't change. Right now the array has five items total, and the property we just added doesn't actually get counted as part of the array:",[17,389,390],{},[129,391],{"alt":233,"src":392},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-08%2016.45.41.png",[17,394,395],{},"Of course, you can still grab that value back using the object-style property access:",[41,397,399],{"className":43,"code":398,"language":45,"meta":46,"style":46},"var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\narr.hello = 'Ray';\n\narr.hello; \u002F\u002F Ray;\n",[48,400,401,411,417,423,429,435,439,443,453,457],{"__ignoreMap":46},[51,402,403,405,407,409],{"class":53,"line":54},[51,404,58],{"class":57},[51,406,62],{"class":61},[51,408,65],{"class":57},[51,410,68],{"class":61},[51,412,413,415],{"class":53,"line":71},[51,414,75],{"class":74},[51,416,78],{"class":61},[51,418,419,421],{"class":53,"line":81},[51,420,85],{"class":84},[51,422,78],{"class":61},[51,424,425,427],{"class":53,"line":90},[51,426,93],{"class":74},[51,428,78],{"class":61},[51,430,431,433],{"class":53,"line":98},[51,432,101],{"class":74},[51,434,78],{"class":61},[51,436,437],{"class":53,"line":106},[51,438,109],{"class":61},[51,440,441],{"class":53,"line":112},[51,442,115],{"class":61},[51,444,445,447,449,451],{"class":53,"line":210},[51,446,376],{"class":61},[51,448,65],{"class":57},[51,450,381],{"class":84},[51,452,384],{"class":61},[51,454,455],{"class":53,"line":217},[51,456,214],{"emptyLinePlaceholder":213},[51,458,460,463],{"class":53,"line":459},10,[51,461,462],{"class":61},"arr.hello; ",[51,464,465],{"class":228},"\u002F\u002F Ray;\n",[17,467,468,469,472],{},"So besides using array methods to insert data, you can also insert with square brackets. For example, the length is currently ",[48,470,471],{},"4",", and if I want to add a new item at the fifth position, I can just write this:",[41,474,476],{"className":43,"code":475,"language":45,"meta":46,"style":46},"var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\narr[5] = 'Ray';\n",[48,477,478,488,494,500,506,512,516,520],{"__ignoreMap":46},[51,479,480,482,484,486],{"class":53,"line":54},[51,481,58],{"class":57},[51,483,62],{"class":61},[51,485,65],{"class":57},[51,487,68],{"class":61},[51,489,490,492],{"class":53,"line":71},[51,491,75],{"class":74},[51,493,78],{"class":61},[51,495,496,498],{"class":53,"line":81},[51,497,85],{"class":84},[51,499,78],{"class":61},[51,501,502,504],{"class":53,"line":90},[51,503,93],{"class":74},[51,505,78],{"class":61},[51,507,508,510],{"class":53,"line":98},[51,509,101],{"class":74},[51,511,78],{"class":61},[51,513,514],{"class":53,"line":106},[51,515,109],{"class":61},[51,517,518],{"class":53,"line":112},[51,519,115],{"class":61},[51,521,522,524,527,530,532,534],{"class":53,"line":210},[51,523,220],{"class":61},[51,525,526],{"class":74},"5",[51,528,529],{"class":61},"] ",[51,531,65],{"class":57},[51,533,381],{"class":84},[51,535,384],{"class":61},[17,537,538],{},"That adds the value at the fifth position:",[17,540,541],{},[129,542],{"alt":543,"src":544},"Array insert","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-11-08%2016.49.47.png",[17,546,547,548,550,551,554],{},"But what if we skip index ",[48,549,526],{}," and insert straight into position ",[48,552,553],{},"99","?",[41,556,558],{"className":43,"code":557,"language":45,"meta":46,"style":46},"var arr = [\n  1,\n  '1',\n  true,\n  undefined,\n  {},\n];\narr[99] = 'Ray';\n",[48,559,560,570,576,582,588,594,598,602],{"__ignoreMap":46},[51,561,5