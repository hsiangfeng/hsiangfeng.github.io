[{"data":1,"prerenderedAt":800},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F08\u002Fjavascript-core-26-object-reference-semantics\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F08\u002Fjavascript-core-26-object-reference-semantics\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F08\u002Fjavascript-core-26-object-reference-semantics\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F08\u002Fjavascript-core-26-object-reference-semantics\u002F":775,"related:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F08\u002Fjavascript-core-26-object-reference-semantics\u002F":784},"\u002Fjavascript\u002F20200808\u002F2652400322\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":759,"date":760,"description":761,"extension":762,"lang":763,"meta":764,"navigation":214,"path":765,"readingMinutes":680,"seo":766,"standalone":767,"stem":768,"tags":769,"tldr":772,"updated":760,"url":773,"__hash__":774},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-26-object-reference-semantics.md","JavaScript Core Concepts (26): Objects — Why Changing One Object Changes Another","1000831498",{"type":9,"value":10,"toc":754},"minimark",[11,16,20,24,27,90,111,175,178,226,243,319,334,341,344,354,357,363,366,369,409,415,418,504,507,572,579,736,740,750],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Time to talk about passing objects by reference. The thing is, if you don't have a clear picture of how reference semantics work, it's really easy to step on a landmine.",[12,21,23],{"id":22},"passing-objects-by-reference","Passing objects by reference",[17,25,26],{},"First, let's look at the usual pass-by-value case:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Ray';\nvar b = a;\nconsole.log(a, b); \u002F\u002F Ray, Ray\n","js","",[35,36,37,60,73],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," a ",[38,51,52],{"class":44},"=",[38,54,56],{"class":55},"sTRMh"," 'Ray'",[38,58,59],{"class":48},";\n",[38,61,63,65,68,70],{"class":40,"line":62},2,[38,64,45],{"class":44},[38,66,67],{"class":48}," b ",[38,69,52],{"class":44},[38,71,72],{"class":48}," a;\n",[38,74,76,79,83,86],{"class":40,"line":75},3,[38,77,78],{"class":48},"console.",[38,80,82],{"class":81},"sj_SG","log",[38,84,85],{"class":48},"(a, b); ",[38,87,89],{"class":88},"sQrFR","\u002F\u002F Ray, Ray\n",[17,91,92,93,96,97,100,101,103,104,106,107,110],{},"You can see ",[35,94,95],{},"b"," received the value of ",[35,98,99],{},"a",", so ",[35,102,95],{}," comes out as Ray. Now what if we change ",[35,105,95],{},"? What does the second ",[35,108,109],{},"console.log(a, b)"," print?",[28,112,114],{"className":30,"code":113,"language":32,"meta":33,"style":33},"var a = 'Ray';\nvar b = a;\nconsole.log(b); \u002F\u002F Ray;\nb = 'qq123';\nconsole.log(a, b); \u002F\u002F Ray, qq123\n",[35,115,116,128,138,150,163],{"__ignoreMap":33},[38,117,118,120,122,124,126],{"class":40,"line":41},[38,119,45],{"class":44},[38,121,49],{"class":48},[38,123,52],{"class":44},[38,125,56],{"class":55},[38,127,59],{"class":48},[38,129,130,132,134,136],{"class":40,"line":62},[38,131,45],{"class":44},[38,133,67],{"class":48},[38,135,52],{"class":44},[38,137,72],{"class":48},[38,139,140,142,144,147],{"class":40,"line":75},[38,141,78],{"class":48},[38,143,82],{"class":81},[38,145,146],{"class":48},"(b); ",[38,148,149],{"class":88},"\u002F\u002F Ray;\n",[38,151,153,156,158,161],{"class":40,"line":152},4,[38,154,155],{"class":48},"b ",[38,157,52],{"class":44},[38,159,160],{"class":55}," 'qq123'",[38,162,59],{"class":48},[38,164,166,168,170,172],{"class":40,"line":165},5,[38,167,78],{"class":48},[38,169,82],{"class":81},[38,171,85],{"class":48},[38,173,174],{"class":88},"\u002F\u002F Ray, qq123\n",[17,176,177],{},"Nothing surprising here. But with objects it gets a little special. Let's start with an object example:",[28,179,181],{"className":30,"code":180,"language":32,"meta":33,"style":33},"var a = {\n  name: 'Ray',\n}\n\nvar b = a;\n",[35,182,183,194,205,210,216],{"__ignoreMap":33},[38,184,185,187,189,191],{"class":40,"line":41},[38,186,45],{"class":44},[38,188,49],{"class":48},[38,190,52],{"class":44},[38,192,193],{"class":48}," {\n",[38,195,196,199,202],{"class":40,"line":62},[38,197,198],{"class":48},"  name: ",[38,200,201],{"class":55},"'Ray'",[38,203,204],{"class":48},",\n",[38,206,207],{"class":40,"line":75},[38,208,209],{"class":48},"}\n",[38,211,212],{"class":40,"line":152},[38,213,215],{"emptyLinePlaceholder":214},true,"\n",[38,217,218,220,222,224],{"class":40,"line":165},[38,219,45],{"class":44},[38,221,67],{"class":48},[38,223,52],{"class":44},[38,225,72],{"class":48},[17,227,228,229,231,232,234,235,238,239,242],{},"Here you can see the object ",[35,230,99],{}," is assigned to ",[35,233,95],{},". Now if we change ",[35,236,237],{},"b.name"," and then look at ",[35,240,241],{},"console.log(a.name, b.name);",", what happens?",[28,244,246],{"className":30,"code":245,"language":32,"meta":33,"style":33},"var a = {\n  name: 'Ray',\n}\n\nvar b = a;\n\nb.name = 'qq123';\n\nconsole.log(a.name, b.name); \u002F\u002F qq123, qq123\n",[35,247,248,258,266,270,274,284,289,301,306],{"__ignoreMap":33},[38,249,250,252,254,256],{"class":40,"line":41},[38,251,45],{"class":44},[38,253,49],{"class":48},[38,255,52],{"class":44},[38,257,193],{"class":48},[38,259,260,262,264],{"class":40,"line":62},[38,261,198],{"class":48},[38,263,201],{"class":55},[38,265,204],{"class":48},[38,267,268],{"class":40,"line":75},[38,269,209],{"class":48},[38,271,272],{"class":40,"line":152},[38,273,215],{"emptyLinePlaceholder":214},[38,275,276,278,280,282],{"class":40,"line":165},[38,277,45],{"class":44},[38,279,67],{"class":48},[38,281,52],{"class":44},[38,283,72],{"class":48},[38,285,287],{"class":40,"line":286},6,[38,288,215],{"emptyLinePlaceholder":214},[38,290,292,295,297,299],{"class":40,"line":291},7,[38,293,294],{"class":48},"b.name ",[38,296,52],{"class":44},[38,298,160],{"class":55},[38,300,59],{"class":48},[38,302,304],{"class":40,"line":303},8,[38,305,215],{"emptyLinePlaceholder":214},[38,307,309,311,313,316],{"class":40,"line":308},9,[38,310,78],{"class":48},[38,312,82],{"class":81},[38,314,315],{"class":48},"(a.name, b.name); ",[38,317,318],{"class":88},"\u002F\u002F qq123, qq123\n",[17,320,321,322,325,326,329,330,333],{},"Something weird just happened — ",[35,323,324],{},"a.name"," got changed too. And if you then run ",[35,327,328],{},"console.log(a === b);",", you'll get ",[35,331,332],{},"true",". In the very first example we were assigning a primitive value, but in this one we're dealing with an object.",[17,335,336],{},[337,338],"img",{"alt":339,"src":340},"value vs reference","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-09%2017.35.25.png",[17,342,343],{},"Basically, when JavaScript assigns values, it works in two different ways:",[345,346,347,351],"ul",{},[348,349,350],"li",{},"Call by value",[348,352,353],{},"Call by reference",[17,355,356],{},"(JavaScript is actually Call by Sharing — I'll explain that in a later chapter. For now, just keep it simple.)",[17,358,359],{},[337,360],{"alt":361,"src":362},"pass by value vs pass by reference","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-09%2017.38.37.png",[17,364,365],{},"In short, pass-by-value just hands the data over, while pass-by-reference means you're referencing the whole original chunk of data. Think of a school exam where you just copy whatever the person across from you writes — same idea.",[17,367,368],{},"An object itself is conceptually a piece of memory. So if what you're passing is an object, you're actually passing the whole object to the other variable — exactly like the example just now:",[28,370,371],{"className":30,"code":180,"language":32,"meta":33,"style":33},[35,372,373,383,391,395,399],{"__ignoreMap":33},[38,374,375,377,379,381],{"class":40,"line":41},[38,376,45],{"class":44},[38,378,49],{"class":48},[38,380,52],{"class":44},[38,382,193],{"class":48},[38,384,385,387,389],{"class":40,"line":62},[38,386,198],{"class":48},[38,388,201],{"class":55},[38,390,204],{"class":48},[38,392,393],{"class":40,"line":75},[38,394,209],{"class":48},[38,396,397],{"class":40,"line":152},[38,398,215],{"emptyLinePlaceholder":214},[38,400,401,403,405,407],{"class":40,"line":165},[38,402,45],{"class":44},[38,404,67],{"class":48},[38,406,52],{"class":44},[38,408,72],{"class":48},[17,410,411],{},[337,412],{"alt":413,"src":414},"object pass by reference","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-09%2017.42.57.png",[17,416,417],{},"But if you assign a brand new object instead, you get a different situation:",[28,419,421],{"className":30,"code":420,"language":32,"meta":33,"style":33},"var a = {\n  name: 'Ray',\n}\n\nvar b = a;\n\nb = {\n  name: 'Ray',\n}\n\nconsole.log(a === b);\n",[35,422,423,433,441,445,449,459,463,471,479,483,488],{"__ignoreMap":33},[38,424,425,427,429,431],{"class":40,"line":41},[38,426,45],{"class":44},[38,428,49],{"class":48},[38,430,52],{"class":44},[38,432,193],{"class":48},[38,434,435,437,439],{"class":40,"line":62},[38,436,198],{"class":48},[38,438,201],{"class":55},[38,440,204],{"class":48},[38,442,443],{"class":40,"line":75},[38,444,209],{"class":48},[38,446,447],{"class":40,"line":152},[38,448,215],{"emptyLinePlaceholder":214},[38,450,451,453,455,457],{"class":40,"line":165},[38,452,45],{"class":44},[38,454,67],{"class":48},[38,456,52],{"class":44},[38,458,72],{"class":48},[38,460,461],{"class":40,"line":286},[38,462,215],{"emptyLinePlaceholder":214},[38,464,465,467,469],{"class":40,"line":291},[38,466,155],{"class":48},[38,468,52],{"class":44},[38,470,193],{"class":48},[38,472,473,475,477],{"class":40,"line":303},[38,474,198],{"class":48},[38,476,201],{"class":55},[38,478,204],{"class":48},[38,480,481],{"class":40,"line":308},[38,482,209],{"class":48},[38,484,486],{"class":40,"line":485},10,[38,487,215],{"emptyLinePlaceholder":214},[38,489,491,493,495,498,501],{"class":40,"line":490},11,[38,492,78],{"class":48},[38,494,82],{"class":81},[38,496,497],{"class":48},"(a ",[38,499,500],{"class":44},"===",[38,502,503],{"class":48}," b);\n",[17,505,506],{},"Even though the contents are the same, the two objects live at different memory locations. And if you pass a value from inside the object instead, nothing gets affected — because that's pass-by-value:",[28,508,510],{"className":30,"code":509,"language":32,"meta":33,"style":33},"var a = {\n  name: 'Ray',\n}\n\nvar b = a.name;\nb = 'qq';\nconsole.log(a.name, b); \u002F\u002F Ray, qq\n",[35,511,512,522,530,534,538,549,560],{"__ignoreMap":33},[38,513,514,516,518,520],{"class":40,"line":41},[38,515,45],{"class":44},[38,517,49],{"class":48},[38,519,52],{"class":44},[38,521,193],{"class":48},[38,523,524,526,528],{"class":40,"line":62},[38,525,198],{"class":48},[38,527,201],{"class":55},[38,529,204],{"class":48},[38,531,532],{"class":40,"line":75},[38,533,209],{"class":48},[38,535,536],{"class":40,"line":152},[38,537,215],{"emptyLinePlaceholder":214},[38,539,540,542,544,546],{"class":40,"line":165},[38,541,45],{"class":44},[38,543,67],{"class":48},[38,545,52],{"class":44},[38,547,548],{"class":48}," a.name;\n",[38,550,551,553,555,558],{"class":40,"line":286},[38,552,155],{"class":48},[38,554,52],{"class":44},[38,556,557],{"class":55}," 'qq'",[38,559,59],{"class":48},[38,561,562,564,566,569],{"class":40,"line":291},[38,563,78],{"class":48},[38,565,82],{"class":81},[38,567,568],{"class":48},"(a.name, b); ",[38,570,571],{"cl