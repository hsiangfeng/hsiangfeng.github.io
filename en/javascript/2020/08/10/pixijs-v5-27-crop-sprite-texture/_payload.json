s, Pixi gives you some handy ways to deal with this. A sprite sheet is basically a single file that contains all the assets your game needs — in this case, an image packed with game objects and characters.",[17,48,49],{},"You'll run into this approach a lot in real-world dev too.",[17,51,52,53,57],{},"Normally you'd need some software to generate the Sprite JSON, but since that's not the point of this post, I'm just going to use the ",[54,55,56],"code",{},"animals.json"," from LearningPixi. At the start we just pull in the sprite image directly:",[59,60,65],"pre",{"className":61,"code":62,"language":63,"meta":64,"style":64},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","loader\n  .add('fakeimg','https:\u002F\u002Fi.imgur.com\u002FT2vjvYl.png')\n  .load((loader, resource)=> {\n    console.log('Done');\n    init(resource);\n  })\n","js","",[54,66,67,76,102,133,150,159],{"__ignoreMap":64},[68,69,72],"span",{"class":70,"line":71},"line",1,[68,73,75],{"class":74},"s8XSl","loader\n",[68,77,79,82,86,89,93,96,99],{"class":70,"line":78},2,[68,80,81],{"class":74},"  .",[68,83,85],{"class":84},"scAaK","add",[68,87,88],{"class":74},"(",[68,90,92],{"class":91},"sWayO","'fakeimg'",[68,94,95],{"class":74},",",[68,97,98],{"class":91},"'https:\u002F\u002Fi.imgur.com\u002FT2vjvYl.png'",[68,100,101],{"class":74},")\n",[68,103,105,107,110,113,117,120,123,126,130],{"class":70,"line":104},3,[68,106,81],{"class":74},[68,108,109],{"class":84},"load",[68,111,112],{"class":74},"((",[68,114,116],{"class":115},"syBk-","loader",[68,118,119],{"class":74},", ",[68,121,122],{"class":115},"resource",[68,124,125],{"class":74},")",[68,127,129],{"class":128},"sOudu","=>",[68,131,132],{"class":74}," {\n",[68,134,136,139,142,144,147],{"class":70,"line":135},4,[68,137,138],{"class":74},"    console.",[68,140,141],{"class":84},"log",[68,143,88],{"class":74},[68,145,146],{"class":91},"'Done'",[68,148,149],{"class":74},");\n",[68,151,153,156],{"class":70,"line":152},5,