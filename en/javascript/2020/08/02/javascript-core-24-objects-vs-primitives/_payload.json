2,46,50,53],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," family ",[38,51,52],{"class":44},"=",[38,54,55],{"class":48}," {};\n",[38,57,59,62,64,68],{"class":40,"line":58},2,[38,60,61],{"class":48},"family.name ",[38,63,52],{"class":44},[38,65,67],{"class":66},"sTRMh"," 'Ray'",[38,69,70],{"class":48},";\n",[38,72,74,77,81,84],{"class":40,"line":73},3,[38,75,76],{"class":48},"console.",[38,78,80],{"class":79},"sj_SG","log",[38,82,83],{"class":48},"(family); ",[38,85,87],{"class":86},"sQrFR","\u002F\u002F object\n",[17,89,90],{},"Other primitive values look like this:",[28,92,94],{"className":30,"code":93,"language":32,"meta":33,"style":33},"var num = 10;\nconsole.log(num); \u002F\u002F 10\n",[35,95,96,111],{"__ignoreMap":33},[38,97,98,100,103,105,109],{"class":40,"line":41},[38,99,45],{"class":44},[38,101,102],{"class":48}," num ",[38,104,52],{"class":44},[38,106,108],{"class":107},"sCcAr"," 10",[38,110,70],{"class":48},[38,112,113,115,117,120],{"class":40,"line":58},[38,114,76],{"class":48},[38,116,80],{"class":79},[38,118,119],{"class":48},"(num); ",[38,121,122],{"class":86},"\u002F\u002F 10\n",[17,124,125],{},"Now let's try adding a property to that primitive:",[28,127,129],{"className":30,"code":128,"language":32,"meta":33,"style":33},"var num = 10;\nconsole.log(num); \u002F\u002F 10\nnum.name = 'Ray';\n",[35,130,131,143,153],{"__ignoreMap":33},[38,132,133,135,137,139,141],{"class":40,"line":41},[38,134,45],{"class":44},[38,136,102],{"class":48},[38,138,52],{"class":44},[38,140,108],{"class":107},[38,142,70],{"class":48},[38,144,145,147,149,151],{"class":40,"line":58},[38,146,76],{"class":48},[38,148,80],{"class":79},[38,150,119],{"class":48},[38,152,122],{"class":86},[38,154,155,158,160,162],{"class":40,"line":73},[38,156,157],{"class":48},"num.name ",[38,159,52],{"class":44},[38,161,67],{"class":66},[38,163,70],{"class":48},[17,165,166,167,170],{},"So here's the question — when I run ",[35,168,169],{},"console.log(num.name)",", what do you think shows up?",[28,172,174],{"className":30,"code":173,"language":32,"meta":33,"style":33},"var num = 10;\nconsole.log(num); \u002F\u002F 10\nnum.name = 'Ray';\nconsole.log(num.name); \u002F\u002F undefined\n",[35,175,176,188,198,208],{"__ignoreMap":33},[38,177,178,180,182,184,186],{"class":40,"line":41},[38,179,45],{"class":44},[38,181,102],{"class":48},[38,183,52],{"class":44},[38,185,108],{"class":107},[38,187,70],{"class":48},[38,189,190,192,194,196],{"class":40,"line":58},[38,191,76],{"class":48},[38,193,80],{"class":79},[38,195,119],{"class":48},[38,197,122],{"class":86},[38,199,200,202,204,206],{"class":40,"line":73},[38,201,157],{"class":48},[38,203,52],{"class":44},[38,205,67],{"class":66},[38,207,70],{"class":48},[38,209,211,213,215,218],{"class":40,"line":210},4,[38,212,76],{"class":48},[38,214,80],{"class":79},[38,216,217],{"class":48},"(num.name); ",[38,219,220],{"class":86},"\u002F\u002F undefined\n",[17,222,223],{},"And here's the key takeaway: primitives don't let you add properties.",[17,225,226],{},"But that probably raises a question — if primitives can't take new properties, then where do all those built-in methods come from?",[17,228,229],{},[230,231],"img",{"alt":232,"src":233},"property methods","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-02%2016.18.30.png",[17,235,236,237,241,242,245,246,249,250,253,254,257,258,261],{},"Those methods are all ",[238,239,240],"strong",{},"inherited"," from the original object type. What do I mean by that? Say I add a ",[35,243,244],{},"prototype"," property called ",[35,247,248],{},"qq123"," directly onto ",[35,251,252],{},"Number"," and give it the value ",[35,255,256],{},"Ray",". What happens when I then call ",[35,259,260],{},"num.qq123","?",[28,263,265],{"className":30,"code":264,"language":32,"meta":33,"style":33},"var num = 10;\nconsole.log(num); \u002F\u002F 10\nnum.name = 'Ray';\nconsole.log(num.name); \u002F\u002F undefined\n\nNumber.prototype.qq123 = 'Ray';\nconsole.log(num.qq123); \u002F\u002F Ray\n",[35,266,267,279,289,299,309,316,335],{"__ignoreMap":33},[38,268,269,271,273,275,277],{"class":40,"line":41},[38,270,45],{"class":44},[38,272,102],{"class":48},[38,274,52],{"class":44},[38,276,108],{"class":107},[38,278,70],{"class":48},[38,280,281,283,285,287],{"class":40,"line":58},[38,282,76],{"class":48},[38,284,80],{"class":79},[38,286,119],{"class":48},[38,288,122],{"class":86},[38,290,291,293,295,297],{"class":40,"line":73},[38,292,157],{"class":48},[38,294,52],{"class":44},[38,296,67],{"class":66},[38,298,70],{"class":48},[38,300,301,303,305,307],{"class":40,"line":210},[38,302,76],{"class":48},[38,304,80],{"class":79},[38,306,217],{"class":48},[38,308,220],{"class":86},[38,310,312],{"class":40,"line":311},5,[38,313,315],{"emptyLinePlaceholder":314},true,"\n",[38,317,319,321,324,326,329,331,333],{"class":40,"line":318},6,[38,320,252],{"class":107},[38,322,323],{"class":48},".",[38,325,244],{"class":107},[38,327,328],{"class":48},".qq123 ",[38,330,52],{"class":44},[38,332,67],{"class":66},[38,334,70],{"class":48},[38,336,338,340,342,345],{"class":40,"line":337},7,[38,339,76],{"class":48},[38,341,80],{"class":79},[38,343,344],{"class":48},"(num.qq123); ",[38,346,347],{"class":86},"\u002F\u002F Ray\n",[17,349,350],{},"But remember the key point — primitives don't allow adding properties. So even if you try to change the value of that property, it won't stick, because it's inherited:",[28,352,354],{"className":30,"code":353,"language":32,"meta":33,"style":33},"var num = 10;\nconsole.log(num); \u002F\u002F 10\nnum.name = 'Ray';\nconsole.log(num.name); \u002F\u002F undefined\n\nNumber.prototype.qq123 = 'Ray';\nconsole.log(num.qq123); \u002F\u002F Ray\nnum.qq123 = 'Hello';\nconsole.log(num.qq123); \u002F\u002F Ray\n",[35,355,356,368,378,388,398,402,418,428,441],{"__ignoreMap":33},[38,357,358,360,362,364,366],{"class":40,"line":41},[38,359,45],{"class":44},[38,361,102],{"class":48},[38,363,52],{"class":44},[38,365,108],{"class":107},[38,367,70],{"class":48},[38,369,370,372,374,376],{"class":40,"line":58},[38,371,76],{"class":48},[38,373,80],{"class":79},[38,375,119],{"class":48},[38,377,122],{"class":86},[38,379,380,382,384,386],{"class":40,"line":73},[38,381,157],{"class":48},[38,383,52],{"class":44},[38,385,67],{"class":66},[38,387,70],{"class":48},[38,389,390,392,394,396],{"class":40,"line":210},[38,391,76],{"class":48},[38,393,80],{"class":79},[38,395,217],{"class":48},[38,397,220],{"class":86},[38,399,400],{"class":40,"line":311},[38,401,315],{"emptyLinePlaceholder":314},[38,403,404,406,408,410,412,414,416],{"class":40,"line":318},[38,405,252],{"class":107},[38,407,323],{"class":48},[38,409,244],{"class":107},[38,411,328],{"class":48},[38,413,52],{"class":44},[38,415,67],{"class":66},[38,417,70],{"class":48},[38,419,420,422,424,426],{"class":40,"line":337},[38,421,76],{"class":48},[38,423,80],{"class":79},[38,425,344],{"class":48},[38,427,347],{"class":86},[38,429,431,434,436,439],{"class":40,"line":430},8,[38,432,433],{"class":48},"num.qq123 ",[38,435,52],{"class":44},[38,437,438],{"class":66}," 'Hello'",[38,440,70],{"class":48},[38,442,444,446,448,450],{"class":40,"line":443},9,[38,445,76],{"class":48},[38,447,80],{"class":79},[38,449,344],{"class":48},[38,451,347],{"class":86},[17,453,454],{},"Basically, you inherit your dad's DNA, but you can't go rewriting his genes.",[17,456,457,458,461,462,465],{},"On top of that, anything you declare with the ",[35,459,460],{},"new"," constructor ",[238,463,464],{},"is an object",":",[28,467,469],{"className":30,"code":468,"language":32,"meta":33,"style":33},"var a = new Number('123');\nconsole.log(typeof a); \u002F\u002F Object\n",[35,470,471,495],{"__ignoreMap":33},[38,472,473,475,478,480,483,486,489,492],{"class":40,"line":41},[38,474,45],{"class":44},[38,476,477],{"class":48}," a ",[38,479,52],{"class":44},[38,481,482],{"class":44}," new",[38,484,485],{"class":79}," Number",[38,487,488],{"class":48},"(",[38,490,491],{"class":66},"'123'",[38,493,494],{"class":48},");\n",[38,496,497,499,501,503,506,509],{"class":40,"line":58},[38,498,76],{"class":48},[38,500,80],{"class":79},[38,502,488],{"class":48},[38,504,505],{"class":44},"typeof",[38,507,508],{"class":48}," a); ",[38,510,511],{"class":86},"\u002F\u002F Object\n",[17,513,514],{},"And since something built with a constructor is an object, it does have the ability to take new properties — because it literally is an object:",[28,516,518],{"className":30,"code":517,"language":32,"meta":33,"style":33},"var a = new Number('123');\nconsole.log(typeof a); \u002F\u002F Object\na.name = 'Ray';\nconsole.log(a.name); \u002F\u002F Ray\n",[35,519,520,538,552,563],{"__ignoreMap":33},[38,521,522,524,526,528,530,532,534,536],{"class":40,"line":41},[38,523,45],{"class":44},[38,525,477],{"class":48},[38,527,52],{"class":44},[38,529,482],{"class":44},[38,531,485],{"class":79},[38,533,488],{"class":48},[38,535,491],{"class":66},[38,537,494],{"class":48},[38,539,540,542,544,546,548,550],{"class":40,"line":58},[38,541,76],{"class":48},[38,543,80],{"class":79},[38,545,488],{"class":48},[38,547,505],{"class":44},[38,549,508],{"class":48},[38,551,511],{"class":86},[38,553,554,557,559,561],{"class":40,"line":73},[38,555,556],{"class":48},"a.name ",[38,558,52],{"class":44},[38,560,67],{"class":66},[38,562,70],{"class":48},[38,564,565,567,569,572],{"class":40,"line":210},[38,566,76],{"class":48},[38,568,80],{"class":79},[38,570,571],{"class":48},"(a.name); ",[38,573,347],{"class":86},[12,575,577],{"id":576},"javascript-only-has-two-kinds-of-types","JavaScript only has two kinds of types",[17,579,580],{},"JavaScript really only has two kinds of types: objects and primitives. In other words, anything that isn't one of the types below is an object:",[582,583,584,588,591,593,596],"ul",{},[585,586,587],"li",{},"String",[585,589,590],{},"Boolean",[585,592,252],{},[585,594,595],{},"Undefined",[585,597,598],{},"Null",[17,600,601],{},"Plus the ones added later:",[582,603,604,607],{},[585,605,606],{},"Bigint — currently only implemented in some browsers.",[585,608,609],{},"Symbol",[17,611,612,613,615],{},"At this point you might be wondering about Array and Function. Well, with ",[35,614,505],{}," we can see that an Array is an object:",[28,617,619],{"className":30,"code":618,"language":32,"meta":33,"style":33},"var arr = [1,2];\nconsole.log(typeof arr); \u002F\u002F Object\n",[35,620,621,645],{"__ignoreMap":33},[38,622,623,625,628,630,633,636,639,642],{"class":40,"line":41},[38,624,45],{"class":44},[38,626,627],{"class":48}," arr ",[38,629,52],{"class":44},[38,631,632],{"class":48}," [",[38,634,635],{"class":107},"1",[38,637,638],{"class":48},",",[38,640,641],{"class":107},"2",[38,643,644],{"class":48},"];\n",[38,646,647,649,651,653,655,658],{"class":40,"line":58},[38,648,76],{"class":48},[38,650,80],{"class":79},[38,652,488],{"class":48},[38,654,505],{"class":44},[38,656,657],{"class":48}," arr); ",[38,659,511],{"class":86},[17,661,662],{},"This isn't a JavaScript bug. JavaScript arrays are actually fake arrays, so you can add properties to them:",[28,664,666],{"className":30,"code":665,"language":32,"meta":33,"style":33},"var arr = [1,2];\nconsole.log(typeof arr); \u002F\u002F Object\narr.name = \"Ray\"; \u002F\u002F [1, 2, name: \"Ray\"]\n",[35,667,668,686,700],{"__ignoreMap":33},[38,669,670,672,674,676,678,680,682,684],{"class":40,"line":41},[38,671,45],{"class":44},[38,673,627],{"class":48},[38,675,52],{"class":44},[38,677,632],{"class":48},[38,679,635],{"class":107},[38,681,638],{"class":48},[38,683,641],{"class":107},[38,685,644],{"class":48},[38,687,688,690,692,694,696,698],{"class":40,"line":58},[38,689,76],{"class":48},[38,691,80],{"class":79},[38,693,488],{"class":48},[38,695,505],{"class":44},[38,697,657],{"class":48},[38,699,511],{"class":86},[38,701,702,705,707,710,713],{"class":40,"line":73},[38,703,704],{"class":48},"arr.name ",[38,706,52],{"class":44},[38,708,709],{"class":66}," \"Ray\"",[38,711,712],{"class":48},"; ",[38,714,715],{"class":86},"\u002F\u002F [1, 2, name: \"Ray\"]\n",[17,717,718,719,721],{},"Now you might push back — a function can't possibly be an object, since ",[35,720,505],{}," shows it as a function:",[28,723,725],{"className":30,"code":724,"language":32,"meta":33,"style":33},"function fn() {}\nconsole.log(typeof fn); \u002F\u002F function\n",[35,726,727,738],{"__ignoreMap":33},[38,728,729,732,735],{"class":40,"line":41},[38,730,731],{"class":44},"function",[38,733,734],{"class":79}," fn",[38,736,737],{"class":48},"() {}\n",[38,739,740,742,744,746,748,751],{"class":40,"line":58},[38,741,76],{"class":48},[38,743,80],{"class":79},[38,745,488],{"class":48},[38,747,505],{"class":44},[38,749,750],{"class":48}," fn); ",[38,752,753],{"class":86},"\u002F\u002F function\n",[17,755,756],{},"So how do we prove that a function is actually an object too? We can add a property to it with the dot operator:",[28,758,760],{"className":30,"code":759,"language":32,"meta":33,"style":33},"function fn() {}\nconsole.log(typeof fn); \u002F\u002F function\nfn.a = 'Ray';\nconsole.log(fn.a); \u002F\u002F Ray\n",[35,761,762,770,784,795],{"__ignoreMap":33},[38,763,764,766,768],{"class":40,"line":41},[38,765,731],{"class":44},[38,767,734],{"class":79},[38,769,737],{"class":48},[38,771,772,774,776,778,780,782],{"class":40,"line":58},[38,773,76],{"class":48},[38,775,80],{"class":79},[38,777,488],{"class":48},[38,779,505],{"class":44},[38,781,750],{"class":48},[38,783,753],{"class":86},[38,785,786,789,791,793],{"class":40,"line":73},[38,787,788],{"class":48},"fn.a ",[38,790,52],{"class":44},[38,792,67],{"class":66},[38,794,70],{"class":48},[38,796,797,799,801,804],{"class":40,"line":210},[38,798,76],{"class":48},[38,800,80],{"class":79},[38,802,803],{"class":48},"(fn.a); ",[38,805,347],{"class":86},[17,807,808,809,812,813,815],{},"One extra thing to watch out for here: a function has its own ",[35,810,811],{},"name"," property, and that ",[35,814,811],{}," maps to the function's name — so you can't change it. A function just gains the extra ability to be called and to hold a chunk of code, but at heart it's still an object.",[12,817,819],{"id":818},"references","References",[582,821,822],{},[585,823,824],{},[825,826,830],"a",{"href":827,"rel":828},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[829],"nofollow","Hexschool - JavaScript Core (course in Mandarin)",[832,833,834],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":33,"searchDepth":58,"depth":58,"links":836},[837,838,839,840],{"id":14,"depth":58,"text":15},{"id":22,"depth":58,"text":23},{"id":576,"depth":58,"text":577},{"id":818,"depth":58,"text":819},"JavaScript","2020-08-02 15:32:34","Ever tried adding a property to a plain number and watched it quietly disappear? In this post we dig into the relationship between objects and primitives in JavaScript — why primitives can't take new properties, where those built-in methods actually come from, and why JavaScript really only has two kinds of typ