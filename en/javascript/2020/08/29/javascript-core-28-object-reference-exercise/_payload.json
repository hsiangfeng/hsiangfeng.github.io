[{"data":1,"prerenderedAt":562},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F29\u002Fjavascript-core-28-object-reference-exercise\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F29\u002Fjavascript-core-28-object-reference-exercise\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F29\u002Fjavascript-core-28-object-reference-exercise\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F29\u002Fjavascript-core-28-object-reference-exercise\u002F":537,"related:\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F29\u002Fjavascript-core-28-object-reference-exercise\u002F":546},"\u002Fjavascript\u002F20200829\u002F48073682\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":520,"date":521,"description":522,"extension":523,"lang":524,"meta":525,"navigation":448,"path":526,"readingMinutes":527,"seo":528,"standalone":529,"stem":530,"tags":531,"tldr":534,"updated":521,"url":535,"__hash__":536},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-28-object-reference-exercise.md","JavaScript Core (28) - Objects - The Object Reference Exercise","1000847336",{"type":9,"value":10,"toc":512},"minimark",[11,16,20,24,27,139,143,158,165,176,218,221,227,231,240,267,273,276,282,286,311,356,359,365,368,374,380,387,473,489,492,496,508],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This chapter is the exercise for object references. The whole point here is just to make sure the \"objects are passed by reference\" idea actually stuck in your head.",[12,21,23],{"id":22},"the-exercise-code","The exercise code",[17,25,26],{},"Here's the snippet for this chapter's exercise. You have to work out the result by tracing where each thing points in memory.",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var a = { x: 1};\nvar b = a;\na.x = { x: 2};\na.y = a = { y: 1};\nconsole.log(a); \u002F\u002F result?\nconsole.log(b); \u002F\u002F result?\n","js","",[35,36,37,63,76,91,110,127],"code",{"__ignoreMap":33},[38,39,42,46,50,53,56,60],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," a ",[38,51,52],{"class":44},"=",[38,54,55],{"class":48}," { x: ",[38,57,59],{"class":58},"sCcAr","1",[38,61,62],{"class":48},"};\n",[38,64,66,68,71,73],{"class":40,"line":65},2,[38,67,45],{"class":44},[38,69,70],{"class":48}," b ",[38,72,52],{"class":44},[38,74,75],{"class":48}," a;\n",[38,77,79,82,84,86,89],{"class":40,"line":78},3,[38,80,81],{"class":48},"a.x ",[38,83,52],{"class":44},[38,85,55],{"class":48},[38,87,88],{"class":58},"2",[38,90,62],{"class":48},[38,92,94,97,99,101,103,106,108],{"class":40,"line":93},4,[38,95,96],{"class":48},"a.y ",[38,98,52],{"class":44},[38,100,49],{"class":48},[38,102,52],{"class":44},[38,104,105],{"class":48}," { y: ",[38,107,59],{"class":58},[38,109,62],{"class":48},[38,111,113,116,120,123],{"class":40,"line":112},5,[38,114,115],{"class":48},"console.",[38,117,119],{"class":118},"sj_SG","log",[38,121,122],{"class":48},"(a); ",[38,124,126],{"class":125},"sQrFR","\u002F\u002F result?\n",[38,128,130,132,134,137],{"class":40,"line":129},6,[38,131,115],{"class":48},[38,133,119],{"class":118},[38,135,136],{"class":48},"(b); ",[38,138,126],{"class":125},[12,140,142],{"id":141},"stage-one","Stage one",[17,144,145,146,149,150,153,154,157],{},"First off, we declare the variables ",[35,147,148],{},"a"," and ",[35,151,152],{},"b",". At the very start there's hoisting going on, and hoisting points both of them at ",[35,155,156],{},"undefined"," by default — the same memory location.",[17,159,160],{},[161,162],"img",{"alt":163,"src":164},"Hoisting","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-30%2000.04.59.png",[17,166,167,168,170,171,149,173,175],{},"At this point you might ask — do the ",[35,169,156],{}," values of ",[35,172,148],{},[35,174,152],{}," really point to the same spot in memory? Yep, they do. You can verify it with this:",[28,177,179],{"className":30,"code":178,"language":32,"meta":33,"style":33},"var a; \u002F\u002F undefined\nvar b; \u002F\u002F undefined\nconsole.log(a === b); \u002F\u002F true\n",[35,180,181,191,200],{"__ignoreMap":33},[38,182,183,185,188],{"class":40,"line":41},[38,184,45],{"class":44},[38,186,187],{"class":48}," a; ",[38,189,190],{"class":125},"\u002F\u002F undefined\n",[38,192,193,195,198],{"class":40,"line":65},[38,194,45],{"class":44},[38,196,197],{"class":48}," b; ",[38,199,190],{"class":125},[38,201,202,204,206,209,212,215],{"class":40,"line":78},[38,203,115],{"class":48},[38,205,119],{"class":118},[38,207,208],{"class":48},"(a ",[38,210,211],{"class":44},"===",[38,213,214],{"class":48}," b); ",[38,216,217],{"class":125},"\u002F\u002F true\n",[17,219,220],{},"Here's the animation for it too:",[17,222,223],{},[161,224],{"alt":225,"src":226},"Animation","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%8F%90%E5%8D%87%E8%A8%98%E6%86%B6%E9%AB%94.gif",[12,228,230],{"id":229},"stage-two","Stage two",[17,232,233,234,236,237,239],{},"Next is the execution phase, where memory actually gets assigned. The object gets a memory location created for it, and ",[35,235,148],{},"'s memory location gets handed over to ",[35,238,152],{},".",[28,241,243],{"className":30,"code":242,"language":32,"meta":33,"style":33},"a = { x: 1};\nb = a;\n",[35,244,245,258],{"__ignoreMap":33},[38,246,247,250,252,254,256],{"class":40,"line":41},[38,248,249],{"class":48},"a ",[38,251,52],{"class":44},[38,253,55],{"class":48},[38,255,59],{"class":58},[38,257,62],{"class":48},[38,259,260,263,265],{"class":40,"line":65},[38,261,262],{"class":48},"b ",[38,264,52],{"class":44},[38,266,75],{"class":48},[17,268,269],{},[161,270],{"alt":271,"src":272},"Memory created and assigned","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-30%2000.29.12.png",[17,274,275],{},"If this part isn't clear, go back and check the previous chapter.",[17,277,278],{},[161,279],{"alt":280,"src":281},"Animation walkthrough","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E8%AE%8A%E6%95%B8%E8%B3%A6%E4%BA%88%E9%81%8E%E7%A8%8B.gif",[12,283,285],{"id":284},"stage-three","Stage three",[17,287,288,289,292,293,296,297,300,301,303,304,307,308,310],{},"This part gets a little hairier. ",[35,290,291],{},"a.x"," gets assigned to a brand-new object memory space, then we add an extra property called ",[35,294,295],{},"a.y",", and finally ",[35,298,299],{},"a.y = a = { y: 1};"," runs all at once with its own new memory space. Saying \"all at once\" can get confusing though, so let's look at it through dependency order instead. The ",[35,302,52],{}," operator resolves from the right, so ",[35,305,306],{},"a = { y: 1};"," runs first, and since an expression returns a result, ",[35,309,295],{}," is actually receiving the result of that expression. So you can read it like this:",[28,312,314],{"className":30,"code":313,"language":32,"meta":33,"style":33},"a.x = { x: 2};\na.y = { y: 1}; \u002F\u002F note: this line and the one below run at the same time\na = { y: 1};\n",[35,315,316,328,344],{"__ignoreMap":33},[38,317,318,320,322,324,326],{"class":40,"line":41},[38,319,81],{"class":48},[38,321,52],{"class":44},[38,323,55],{"class":48},[38,325,88],{"class":58},[38,327,62],{"class":48},[38,329,330,332,334,336,338,341],{"class":40,"line":65},[38,331,96],{"class":48},[38,333,52],{"class":44},[38,335,105],{"class":48},[38,337,59],{"class":58},[38,339,340],{"class":48},"}; ",[38,342,343],{"class":125},"\u002F\u002F note: this line and the one below run at the same time\n",[38,345,346,348,350,352,354],{"class":40,"line":78},[38,347,249],{"class":48},[38,349,52],{"class":44},[38,351,105],{"class":48},[38,353,59],{"class":58},[38,355,62],{"class":48},[17,357,358],{},"Now let's look at the diagram:",[17,360,361],{},[161,362],{"alt":363,"src":364},"Object assigned to a new object","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-30%2000.53.27.png",[17,366,367],{},"The memory pointers are probably pretty tangled by now, so as usual the animated version is easier to follow:",[17,369,370],{},[161,371],{"alt":372,"src":373},"Memory pointers","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E7%AB%A0%E7%AF%80%E4%BD%9C%E6%A5%AD%E7%89%A9%E4%BB%B6%E8%A8%98%E6%86%B6%E9%AB%94%E6%8C%87%E5%90%91.gif",[17,375,376,377,379],{},"One thing to watch in that animation: ",[35,378,299],{}," happens all at once — it's only drawn one step at a time because that's the only way to animate it.",[17,381,382,383,386],{},"So the answers for the final ",[35,384,385],{},"console.log"," calls are:",[28,388,390],{"className":30,"code":389,"language":32,"meta":33,"style":33},"var a = { x: 1};\nvar b = a;\na.x = { x: 2};\na.y = a = { y: 1};\n\nconsole.log(a); \u002F\u002F { y: 1}\nconsole.log(b); \u002F\u002F {x: { x: 2}, y: { y: 1}}\n",[35,391,392,406,416,428,444,450,461],{"__ignoreMap":33},[38,393,394,396,398,400,402,404],{"class":40,"line":41},[38,395,45],{"class":44},[38,397,49],{"class":48},[38,399,52],{"class":44},[38,401,55],{"class":48},[38,403,59],{"class":58},[38,405,62],{"class":48},[38,407,408,410,412,414],{"class":40,"line":65},[38,409,45],{"class":44},[38,411,70],{"class":48},[38,413,52],{"class":44},[38,415,75],{"class":48},[38,417,418,420,422,424,426],{"class":40,"line":78},[38,419,81],{"class":48},[38,421,52],{"class":44},[38,423,55],{"class":48},[38,425,88],{"class":58},[38,427,62],{"class":48},[38,429,430,432,434,436,438,440,442],{"class":40,"line":93},[38,431,96],{"class":48},[38,433,52],{"class":44},[38,435,49],{"class":48},[38,437,52],{"class":44},[38,439,105],{"class":48},[38,441,59],{"class":58},[38,443,62],{"class":48},[38,445,446],{"class":40,"line":112},[38,447,449],{"emptyLinePlaceholder":448},true,"\n",[38,451,452,454,456,458],{"class":40,"line":129},[38,453,115],{"class":48},[38,455,119],{"class":118},[38,457,122],{"class":48},[38,459,460],{"class":125},"\u002F\u002F { y: 1}\n",[38,462,464,466,468,470],{"class":40,"line":463},7,[38,465,115],{"class":48},[38,467,119],{"class":118},[38,469,136],{"class":48},[38,471,472],{"class":125},"\u002F\u002F {x: { x: 2}, y: { y: 1}}\n",[17,474,475,476,478,479,482,483,485,486,488],{},"The memory pointers here are on the trickier side, but with the diagrams you can see that ",[35,477,152],{}," points at the original memory location the whole way through. Everything we did was operating on the original ",[35,480,481],{},"0x01"," memory. Later ",[35,484,148],{}," got reassigned to a new memory location, but because objects are passed by reference and use memory pointers, ",[35,487,152],{}," keeps pointing at that original spot.",[17,490,491],{},"This chapter is more involved than usual, so you might need to revisit the earlier chapters' concepts a few times to make it click.",[12,493,495],{"id":494},"references","References",[497,498,499],"ul",{},[500,501,502],"li",{},[148,503,507],{"href":504,"rel":505},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[506],"nofollow","JavaScript Core (Mandarin course)",[509,510,511],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":33,"searchDepth":65,"depth":65,"links":513},[514,515,516,517,518,519],{"id":14,"depth":65,"text":15},{"id":22,"depth":65,"text":23},{"id":141,"depth":65,"text":142},{"id":229,"depth":65,"text":230},{"id":284,"depth":65,"text":285},{"id":494,"depth":65,"text":495},"JavaScript","2020-08-29 23:52:38","This chapter is the exercise for object references. The whole point is to make sure the \"objects are passed by reference\" idea actually stuck. We walk through a tricky little snippet step by step, tracing memory pointers and drawing out exactly why a and b end up the way they do.","md","en",{},"\u002Fen\u002Fjavascript\u002Fjavascript-core-28-object-reference-exercise","3",{"title":6,"description":522},false,"en\u002FJavaScript\u002Fjavascript-core-28-object-reference-exercise",[520,532,533],"JavaScript Core","Object",null,"\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F29\u002Fjavascript-core-28-object-reference-exercise\u002F","pfuRaVnLFswd7o7-ra8JzTSE0SvPuy2d7k8C9RBnaS0",{"newer":538,"older":542},{"url":539,"title":540,"date":541},"\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F31\u002Fpixijs-v5-tutorial-30-game-loop\u002F","PixiJS V5 Tutorial (30) - The Game Loop","2020-08-31 13:45:57",{"url":543,"title":544,"date":545},"\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F24\u002Fpixijs-v5-29-treasure-hunter-setup\u002F","PixiJS V5 Tutorial (29) - Building treasureHunter (the Treasure Hunter)","2020-08-24 17:41:22",[547,552,557],{"url":548,"title":549,"date":550,"readingMinutes":551},"\u002Fen\u002Fjavascript\u002F2026\u002F03\u002F10\u002Fweb-crypto-api-encryption-guide\u002F","No crypto Package, No Node.js — The Web Crypto API Does It All in the Browser","2026-03-10 09:45:08","9",{"url":553,"title":554,"date":555,"readingMinutes":556},"\u002Fen\u002Fjavascript\u002F2025\u002F12\u002F08\u002Fjquery-why-it-declined\u002F","jQuery Was Once King — So Why Did It Fall Off?","2025-12-08 21:35:24","7",{"url":558,"title":559,"date":560,"readingMinutes":561},"\u002Fen\u002Fjavascript\u002F2025\u002F12\u002F05\u002Fjavascript-generator-functions\u002F","What Are JavaScript Generator Functions (function*)? The Function You Can Pause and Resume","2025-12-05 13:40:31","5",1784012776284]