[{"data":1,"prerenderedAt":368},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F01\u002Fpixijs-v5-21-collision-boundary-03\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F01\u002Fpixijs-v5-21-collision-boundary-03\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F01\u002Fpixijs-v5-21-collision-boundary-03\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F01\u002Fpixijs-v5-21-collision-boundary-03\u002F":343,"related:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F01\u002Fpixijs-v5-21-collision-boundary-03\u002F":352},"\u002Fjavascript\u002F20200701\u002F237553233\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":313,"date":324,"description":325,"extension":326,"lang":327,"meta":328,"navigation":329,"path":330,"readingMinutes":331,"seo":332,"standalone":333,"stem":334,"tags":335,"tldr":340,"updated":324,"url":341,"__hash__":342},"content\u002Fen\u002FJavaScript\u002Fpixijs-v5-21-collision-boundary-03.md","PixiJS V5 Tutorial (21) - Collision Boundaries (3): Random Positions and Centering Text","1001797616",{"type":9,"value":10,"toc":319},"minimark",[11,16,20,24,40,115,118,156,159,208,215,218,287,297,301,315],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This one picks up where the last post left off and patches a few small things, so most of the code carries over from before. That means this post is going to be a bit shorter.",[12,21,23],{"id":22},"picking-up-from-last-time","Picking up from last time",[17,25,26,27,31,32,39],{},"Last time we got the basic damage-number effect working. But there's a problem — what if you want the position to be random instead of always landing in the same spot? For that we reach for ",[28,29,30],"code",{},"random",". Someone over on the iThome forums already ",[33,34,38],"a",{"href":35,"rel":36},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10197904",[37],"nofollow","wrote it up",", so I'm just going to borrow their helper:",[41,42,47],"pre",{"className":43,"code":44,"language":45,"meta":46,"style":46},"language-js shiki shiki-themes github-dark-high-contrast","function getRandom(x){\n  return Math.floor(Math.random()*x)+1;\n};\n","js","",[28,48,49,73,109],{"__ignoreMap":46},[50,51,54,58,62,66,70],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sWyjQ","function",[50,59,61],{"class":60},"sj_SG"," getRandom",[50,63,65],{"class":64},"sMAXC","(",[50,67,69],{"class":68},"s_sBn","x",[50,71,72],{"class":64},"){\n",[50,74,76,79,82,85,88,90,93,96,99,102,106],{"class":52,"line":75},2,[50,77,78],{"class":56},"  return",[50,80,81],{"class":64}," Math.",[50,83,84],{"class":60},"floor",[50,86,87],{"class":64},"(Math.",[50,89,30],{"class":60},[50,91,92],{"class":64},"()",[50,94,95],{"class":56},"*",[50,97,98],{"class":64},"x)",[50,100,101],{"class":56},"+",[50,103,105],{"class":104},"sCcAr","1",[50,107,108],{"class":64},";\n",[50,110,112],{"class":52,"line":111},3,[50,113,114],{"class":64},"};\n",[17,116,117],{},"With that, we can give the effect a random position whenever it hits the top boundary:",[41,119,121],{"className":43,"code":120,"language":45,"meta":46,"style":46},"graphics.x = getRandom(150);\ngraphics.y = getRandom(150);\n",[28,122,123,141],{"__ignoreMap":46},[50,124,125,128,131,133,135,138],{"class":52,"line":53},[50,126,127],{"class":64},"graphics.x ",[50,129,130],{"class":56},"=",[50,132,61],{"class":60},[50,134,65],{"class":64},[50,136,137],{"class":104},"150",[50,139,140],{"class":64},");\n",[50,142,143,146,148,150,152,154],{"class":52,"line":75},[50,144,145],{"class":64},"graphics.y ",[50,147,130],{"class":56},[50,149,61],{"class":60},[50,151,65],{"class":64},[50,153,137],{"class":104},[50,155,140],{"class":64},[17,157,158],{},"Now you'll see the effect spawning all over the place. But there's a catch — the text. The text doesn't sit vertically and horizontally centered inside the star shape. The fix is this little formula:",[41,160,162],{"className":43,"code":161,"language":45,"meta":46,"style":46},"startText.x = graphics.x - startText.width \u002F 2;\nstartText.y = graphics.y - startText.width \u002F 2;\n",[28,163,164,188],{"__ignoreMap":46},[50,165,166,169,171,174,177,180,183,186],{"class":52,"line":53},[50,167,168],{"class":64},"startText.x ",[50,170,130],{"class":56},[50,172,173],{"class":64}," graphics.x ",[50,175,176],{"class":56},"-",[50,178,179],{"class":64}," startText.width ",[50,181,182],{"class":56},"\u002F",[50,184,185],{"class":104}," 2",[50,187,108],{"class":64},[50,189,190,193,195,198,200,202,204,206],{"class":52,"line":75},[50,191,192],{"class":64},"startText.y ",[50,194,130],{"class":56},[50,196,197],{"class":64}," graphics.y ",[50,199,176],{"class":56},[50,201,179],{"class":64},[50,203,182],{"class":56},[50,205,185],{"class":104},[50,207,108],{"class":64},[17,209,210,211,214],{},"If you just write ",[28,212,213],{},"startText.x = graphics.x",", you'll notice the text gets shoved off to one side. That's because PIXI renders text anchored to the first character, so you have to subtract half the text's width and height to pull it back into place. Do that and the text ends up dead-center in the star effect.",[17,216,217],{},"Finally I tweaked things a little so the star looks more like an actual crit hit:",[41,219,221],{"className":43,"code":220,"language":45,"meta":46,"style":46},"graphics.beginFill(0x9D482E);\nconst startText = new PIXI.Text('1000',{\n  fill: 0xDDD00D,\n});\n",[28,222,223,238,270,281],{"__ignoreMap":46},[50,224,225,228,231,233,236],{"class":52,"line":53},[50,226,227],{"class":64},"graphics.",[50,229,230],{"class":60},"beginFill",[50,232,65],{"class":64},[50,234,235],{"class":104},"0x9D482E",[50,237,140],{"class":64},[50,239,240,243,246,249,252,255,258,261,263,267],{"class":52,"line":75},[50,241,242],{"class":56},"const",[50,244,245],{"class":104}," startText",[50,247,248],{"class":56}," =",[50,250,251],{"class":56}," new",[50,253,254],{"class":104}," PIXI",[50,256,257],{"class":64},".",[50,259,260],{"class":60},"Text",[50,262,65],{"class":64},[50,264,266],{"class":265},"sTRMh","'1000'",[50,268,269],{"class":64},",{\n",[50,271,272,275,278],{"class":52,"line":111},[50,273,274],{"class":64},"  fill: ",[50,276,277],{"class":104},"0xDDD00D",[50,279,280],{"class":64},",\n",[50,282,284],{"class":52,"line":283},4,[50,285,286],{"class":64},"});\n",[288,289,296],"iframe",{"height":290,"style":291,"scrolling":292,"title":293,"src":294,"frameBorder":292,"allowTransparency":295,"allowFullScreen":295},265,"width: 100%;","no","PIXI effect(2)","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FWNbXYME?height=265&theme-id=default&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNbXYME'>PIXI effect(2)\u003C\u002Fa> by Ray\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,298,300],{"id":299},"references","References",[302,303,304],"ul",{},[305,306,307],"li",{},[33,308,310,311,314],{"href":35,"rel":309},[37],"[Note]",[50,312,313],{},"JavaScript"," Getting random numbers with Math.random() (article in Mandarin)",[316,317,318],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);