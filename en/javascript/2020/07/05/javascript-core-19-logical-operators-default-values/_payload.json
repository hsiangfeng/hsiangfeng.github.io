[{"data":1,"prerenderedAt":740},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F05\u002Fjavascript-core-19-logical-operators-default-values\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F05\u002Fjavascript-core-19-logical-operators-default-values\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F05\u002Fjavascript-core-19-logical-operators-default-values\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F05\u002Fjavascript-core-19-logical-operators-default-values\u002F":715,"related:\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F05\u002Fjavascript-core-19-logical-operators-default-values\u002F":724},"\u002Fjavascript\u002F20200705\u002F3382481626\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":698,"date":699,"description":700,"extension":701,"lang":702,"meta":703,"navigation":340,"path":704,"readingMinutes":705,"seo":706,"standalone":707,"stem":708,"tags":709,"tldr":712,"updated":699,"url":713,"__hash__":714},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-19-logical-operators-default-values.md","JavaScript Core Concepts (19): Logical Operators and Faking Default Values Before ES6","1000776065",{"type":9,"value":10,"toc":693},"minimark",[11,16,20,24,27,30,62,65,99,111,186,198,247,263,266,399,402,426,429,472,477,491,536,539,597,604,667,674,678,689],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This time we're talking about logical operators. They look simple, but if you use them carelessly the result might not be what you expect.",[12,21,23],{"id":22},"logical-operators","Logical Operators",[17,25,26],{},"In the last post we covered truthy and falsy values. That whole idea carries straight over into logical operators here.",[17,28,29],{},"Per the MDN docs, there are three of them:",[31,32,33,44,53],"ul",{},[34,35,36,40,41],"li",{},[37,38,39],"code",{},"&&"," (AND operator), used as ",[37,42,43],{},"expr1 && expr2",[34,45,46,49,50],{},[37,47,48],{},"||"," (OR operator), used as ",[37,51,52],{},"expr1 || expr2",[34,54,55,58,59],{},[37,56,57],{},"!"," (NOT operator), used as ",[37,60,61],{},"!expr",[17,63,64],{},"MDN already explains how these work, so let me just quote it:",[66,67,68],"blockquote",{},[17,69,70,71,74,75,78,79,81,82,85,86,88,89,92,93,95,96,98],{},"If ",[37,72,73],{},"expr1"," can be converted to ",[37,76,77],{},"false",", returns ",[37,80,73],{},"; else, returns ",[37,83,84],{},"expr2",". Thus, when used with Boolean values, ",[37,87,39],{}," returns ",[37,90,91],{},"true"," if both operands are ",[37,94,91],{},"; otherwise, returns ",[37,97,77],{},".",[17,100,101,102,74,104,78,106,81,108,110],{},"Let me break down that first part: \"If ",[37,103,73],{},[37,105,77],{},[37,107,73],{},[37,109,84],{},".\" Easiest to just look at the code:",[112,113,118],"pre",{"className":114,"code":115,"language":116,"meta":117,"style":117},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","var a = 0; \u002F\u002F false\nvar b = 1; \u002F\u002F true\nconsole.log(a && b); \u002F\u002F 0\n","js","",[37,119,120,147,165],{"__ignoreMap":117},[121,122,125,129,133,136,140,143],"span",{"class":123,"line":124},"line",1,[121,126,128],{"class":127},"sOudu","var",[121,130,132],{"class":131},"s8XSl"," a ",[121,134,135],{"class":127},"=",[121,137,139],{"class":138},"stw71"," 0",[121,141,142],{"class":131},"; ",[121,144,146],{"class":145},"sGBqm","\u002F\u002F false\n",[121,148,150,152,155,157,160,162],{"class":123,"line":149},2,[121,151,128],{"class":127},[121,153,154],{"class":131}," b ",[121,156,135],{"class":127},[121,158,159],{"class":138}," 1",[121,161,142],{"class":131},[121,163,164],{"class":145},"\u002F\u002F true\n",[121,166,168,171,175,178,180,183],{"class":123,"line":167},3,[121,169,170],{"class":131},"console.",[121,172,174],{"class":173},"scAaK","log",[121,176,177],{"class":131},"(a ",[121,179,39],{"class":127},[121,181,182],{"class":131}," b); ",[121,184,185],{"class":145},"\u002F\u002F 0\n",[17,187,188,189,191,192,194,195,197],{},"So as long as the first operand ",[37,190,73],{}," converts to ",[37,193,77],{},", it returns the value of ",[37,196,73],{}," directly. What if we flip the order?",[112,199,201],{"className":114,"code":200,"language":116,"meta":117,"style":117},"var a = 0; \u002F\u002F false\nvar b = 1; \u002F\u002F true\nconsole.log(b && a); \u002F\u002F 0\n",[37,202,203,217,231],{"__ignoreMap":117},[121,204,205,207,209,211,213,215],{"class":123,"line":124},[121,206,128],{"class":127},[121,208,132],{"class":131},[121,210,135],{"class":127},[121,212,139],{"class":138},[121,214,142],{"class":131},[121,216,146],{"class":145},[121,218,219,221,223,225,227,229],{"class":123,"line":149},[121,220,128],{"class":127},[121,222,154],{"class":131},[121,224,135],{"class":127},[121,226,159],{"class":138},[121,228,142],{"class":131},[121,230,164],{"class":145},[121,232,233,235,237,240,242,245],{"class":123,"line":167},[121,234,170],{"class":131},[121,236,174],{"class":173},[121,238,239],{"class":131},"(b ",[121,241,39],{"class":127},[121,243,244],{"class":131}," a); ",[121,246,185],{"class":145},[17,248,249,250,253,254,74,256,78,258,81,260,262],{},"Still returns ",[37,251,252],{},"0",". That confirms the rule: \"If ",[37,255,73],{},[37,257,77],{},[37,259,73],{},[37,261,84],{},".\"",[17,264,265],{},"Basically, AND keys off whether the first value is truthy. If the first value is truthy, you always get the second value back. If the first value is falsy, you get the first value back.",[112,267,269],{"className":114,"code":268,"language":116,"meta":117,"style":117},"console.log(1 && 10); \u002F\u002F 10\nconsole.log(1 && 15); \u002F\u002F 15\nconsole.log(1 && 2); \u002F\u002F 2\n\nconsole.log(0 && 10); \u002F\u002F 0\nconsole.log(0 && 15); \u002F\u002F 0\nconsole.log(0 && 2); \u002F\u002F 0\n",[37,270,271,295,315,335,342,361,380],{"__ignoreMap":117},[121,272,273,275,277,280,283,286,289,292],{"class":123,"line":124},[121,274,170],{"class":131},[121,276,174],{"class":173},[121,278,279],{"class":131},"(",[121,281,282],{"class":138},"1",[121,284,285],{"class":127}," &&",[121,287,288],{"class":138}," 10",[121,290,291],{"class":131},"); ",[121,293,294],{"class":145},"\u002F\u002F 10\n",[121,296,297,299,301,303,305,307,310,312],{"class":123,"line":149},[121,298,170],{"class":131},[121,300,174],{"class":173},[121,302,279],{"class":131},[121,304,282],{"class":138},[121,306,285],{"class":127},[121,308,309],{"class":138}," 15",[121,311,291],{"class":131},[121,313,314],{"class":145},"\u002F\u002F 15\n",[121,316,317,319,321,323,325,327,330,332],{"class":123,"line":167},[121,318,170],{"class":131},[121,320,174],{"class":173},[121,322,279],{"class":131},[121,324,282],{"class":138},[121,326,285],{"class":127},[121,328,329],{"class":138}," 2",[121,331,291],{"class":131},[121,333,334],{"class":145},"\u002F\u002F 2\n",[121,336,338],{"class":123,"line":337},4,[121,339,341],{"emptyLinePlaceholder":340},true,"\n",[121,343,345,347,349,351,353,355,357,359],{"class":123,"line":344},5,[121,346,170],{"class":131},[121,348,174],{"class":173},[121,350,279],{"class":131},[121,352,252],{"class":138},[121,354,285],{"class":127},[121,356,288],{"class":138},[121,358,291],{"class":131},[121,360,185],{"class":145},[121,362,364,366,368,370,372,374,376,378],{"class":123,"line":363},6,[121,365,170],{"class":131},[121,367,174],{"class":173},[121,369,279],{"class":131},[121,371,252],{"class":138},[121,373,285],{"class":127},[121,375,309],{"class":138},[121,377,291],{"class":131},[121,379,185],{"class":145},[121,381,383,385,387,389,391,393,395,397],{"class":123,"line":382},7,[121,384,170],{"class":131},[121,386,174],{"class":173},[121,388,279],{"class":131},[121,390,252],{"class":138},[121,392,285],{"class":127},[121,394,329],{"class":138},[121,396,291],{"class":131},[121,398,185],{"class":145},[17,400,401],{},"Now let's look at the MDN explanation for the OR operator:",[66,403,404],{},[17,405,70,406,74,408,78,410,81,412,85,414,88,416,418,419,421,422,78,424,98],{},[37,407,73],{},[37,409,91],{},[37,411,73],{},[37,413,84],{},[37,415,48],{},[37,417,91],{}," if either operand is ",[37,420,91],{},"; if both are ",[37,423,77],{},[37,425,77],{},[17,427,428],{},"So as long as the first value is truthy, you get the first value back; otherwise you get the second.",[112,430,432],{"className":114,"code":431,"language":116,"meta":117,"style":117},"console.log(1 || 0); \u002F\u002F 1\nconsole.log(0 || 1); \u002F\u002F 1\n",[37,433,434,454],{"__ignoreMap":117},[121,435,436,438,440,442,444,447,449,451],{"class":123,"line":124},[121,437,170],{"class":131},[121,439,174],{"class":173},[121,441,279],{"class":131},[121,443,282],{"class":138},[121,445,446],{"class":127}," ||",[121,448,139],{"class":138},[121,450,291],{"class":131},[121,452,453],{"class":145},"\u002F\u002F 1\n",[121,455,456,458,460,462,464,466,468,470],{"class":123,"line":149},[121,457,170],{"class":131},[121,459,174],{"class":173},[121,461,279],{"class":131},[121,463,252],{"class":138},[121,465,446],{"class":127},[121,467,159],{"class":138},[121,469,291],{"class":131},[121,471,453],{"class":145},[17,473,474,475,98],{},"Pretty similar idea to ",[37,476,39],{},[17,478,479,480,482,483,485,486,482,488,490],{},"The last one is the one people mix up most — the NOT operator. I usually think of it as the \"flip the result\" operator. In short, it turns ",[37,481,91],{}," into ",[37,484,77],{}," and ",[37,487,77],{},[37,489,91],{},". It also always returns an actual boolean.",[112,492,494],{"className":114,"code":493,"language":116,"meta":117,"style":117},"!true; \u002F\u002F false\n!false; \u002F\u002F true\n!1; \u002F\u002F false\n!0; \u002F\u002F true\n",[37,495,496,506,516,526],{"__ignoreMap":117},[121,497,498,500,502,504],{"class":123,"line":124},[121,499,57],{"class":127},[121,501,91],{"class":138},[121,503,142],{"class":131},[121,505,146],{"class":145},[121,507,508,510,512,514],{"class":123,"line":149},[121,509,57],{"class":127},[121,511,77],{"class":138},[121,513,142],{"class":131},[121,515,164],{"class":145},[121,517,518,520,522,524],{"class":123,"line":167},[121,519,57],{"class":127},[121,521,282],{"class":138},[121,523,142],{"class":131},[121,525,146],{"class":145},[121,527,528,530,532,534],{"class":123,"line":337},[121,529,57],{"class":127},[121,531,252],{"class":138},[121,533,142],{"class":131},[121,535,164],{"class":145},[17,537,538],{},"This little trick comes in handy in a few places — for example, giving a function a default value. Back in the early days, before ES6 default parameters existed, a function with no value passed in could blow up. So you'd write something like this:",[112,540,542],{"className":114,"code":541,"language":116,"meta":117,"style":117},"function fn(name) {\n  console.log('I am ' + name);\n}\n\nfn()\n",[37,543,544,561,580,585,589],{"__ignoreMap":117},[121,545,546,549,552,554,558],{"class":123,"line":124},[121,547,548],{"class":127},"function",[121,550,551],{"class":173}," fn",[121,553,279],{"class":131},[121,555,557],{"class":556},"syBk-","name",[121,559,560],{"class":131},") {\n",[121,562,563,566,568,570,574,577],{"class":123,"line":149},[121,564,565],{"class":131},"  console.",[121,567,174],{"class":173},[121,569,279],{"class":131},[121,571,573],{"class":572},"sWayO","'I am '",[121,575,576],{"class":127}," +",[121,578,579],{"class":131}," name);\n",[121,581,582],{"class":123,"line":167},[121,583,584],{"class":131},"}\n",[121,586,587],{"class":123,"line":337},[121,588,341],{"emptyLinePlaceholder":340},[121,590,591,594],{"class":123,"line":344},[121,592,593],{"class":173},"fn",[121,595,596],{"class":131},"()\n",[17,598,599,600,603],{},"Without ES6 defaults, that code outputs \"",[37,601,602],{},"I am undefined","\". But we don't actually want that — we want a fallback value. And we can get one using one of the tricks we just learned, the OR operator:",[112,605,607],{"className":114,"code":606,"language":116,"meta":117,"style":117},"function fn(name) {\n  name = name || 'Ray';\n  console.log('I am ' + name);\n}\n\nfn()\n",[37,608,609,621,639,653,657,661],{"__ignoreMap":117},[121,610,611,613,615,617,619],{"class":123,"line":124},[121,612,548],{"class":127},[121,614,551],{"class":173},[121,616,279],{"class":131},[121,618,557],{"class":556},[121,620,560],{"class":131},[121,622,623,626,628,631,633,636],{"class":123,"line":149},[121,624,625],{"class":131},"  name ",[121,627,135],{"class":127},[121,629,630],{"class":131}," name ",[121,632,48],{"class":127},[121,634,635],{"class":572}," 'Ray'",[121,637,638],{"class":131},";\n",[121,640,641,643,645,647,649,651],{"class":123,"line":167},[121,642,565],{"class":131},[121,644,174],{"class":173},[121,646,279],{"class":131},[121,648,573],{"class":572},[121,650,576],{"class":127},[121,652,579],{"class":131},[121,654,655],{"class":123,"line":337},[121,656,584],{"class":131},[121,658,659],{"class":123,"line":344},[121,660,341],{"emptyLinePlaceholder":340},[121,662,663,665],{"class":123,"line":363},[121,664,593],{"class":173},[121,666,596],{"class":131},[17,668,669,670,673],{},"With the OR operator trick, the ",[37,671,672],{},"undefined"," problem goes away.",[12,675,677],{"id":676},"references","References",[31,679,680],{},[34,681,682],{},[683,684,688],"a",{"href":685,"rel":686},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[687],"nofollow","JavaScript Core (course in Mandarin)",[690,691,692],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html pre.shiki code .sGBqm, html code.shiki .sGBqm{--shiki-light:#6A737D;--shiki-default:#6A737D;--shiki-dark:#BDC4CC}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html .light .sh