ion-9","Question 9",[17,945,946],{},"Earlier in the course we learned that JavaScript has this thing called ASI (Automatic Semicolon Insertion). So does the code below throw an error?",[47,948,950],{"className":49,"code":949,"language":51,"meta":52,"style":52},"var a = 10\n(a + 10).toString();\n",[28,951,952,963],{"__ignoreMap":52},[56,953,954,956,958,960],{"class":58,"line":59},[56,955,63],{"class":62},[56,957,67],{"class":66},[56,959,70],{"class":62},[56,961,962],{"class":73}," 10\n",[56,964,965,967,970,972,975,978],{"class":58,"line":80},[56,966,497],{"class":66},[56,968,969],{"class":62},"+",[56,971,748],{"class":73},[56,973,974],{"class":66},").",[56,976,977],{"class":154},"toString",[56,979,473],{"class":66},[225,981,982,985],{},[228,983,984],{},"throws an error",[228,986,987],{},"no error",[241,989,990,992,995],{},[244,991,246],{},[17,993,994],{},"The answer is \"throws an error\".",[17,996,997,998,1001],{},"What actually happens is the code gets read as ",[28,999,1000],{},"var a = 10(a + 10).toString();",". The whole point here is testing the ASI auto-semicolon-insertion mechanism.",[12,1003,1005],{"id":1004},"question-10","Question 10",[17,1007,1008,1009,1012],{},"ASI cuts both ways — and one of the classic gotchas involves ",[28,1010,1011],{},"return",". So is the code below correct?",[47,1014,1016],{"className":49,"code":1015,"language":51,"meta":52,"style":52},"var a = 1\n(function() {\n console.log(a);\n})()\n",[28,1017,1018,1029,1039,1049],{"__ignoreMap":52},[56,1019,1020,1022,1024,1026],{"class":58,"line":59},[56,1021,63],{"class":62},[56,1023,67],{"class":66},[56,1025,70],{"class":62},[56,1027,1028],{"class":73}," 1\n",[56,1030,1031,1033,1036],{"class":58,"line":80},[56,1032,158],{"class":66},[56,1034,1035],{"class":62},"function",[56,1037,1038],{"class":66},"() {\n",[56,1040,1041,1044,1046],{"class":58,"line":96},[56,1042,1043],{"class":66}," console.",[56,1045,155],{"class":154},[56,1047,1048],{"class":66},"(a);\n",[56,1050,1051],{"class":58,"line"