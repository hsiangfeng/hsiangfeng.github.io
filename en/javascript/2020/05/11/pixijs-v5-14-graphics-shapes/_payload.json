[{"data":1,"prerenderedAt":862},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F05\u002F11\u002Fpixijs-v5-14-graphics-shapes\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F05\u002F11\u002Fpixijs-v5-14-graphics-shapes\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F05\u002F11\u002Fpixijs-v5-14-graphics-shapes\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F05\u002F11\u002Fpixijs-v5-14-graphics-shapes\u002F":839,"related:\u002Fen\u002Fjavascript\u002F2020\u002F05\u002F11\u002Fpixijs-v5-14-graphics-shapes\u002F":848},"\u002Fjavascript\u002F20200511\u002F1897499725\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":819,"date":820,"description":821,"extension":822,"lang":823,"meta":824,"navigation":825,"path":826,"readingMinutes":827,"seo":828,"standalone":829,"stem":830,"tags":831,"tldr":836,"updated":820,"url":837,"__hash__":838},"content\u002Fen\u002FJavaScript\u002Fpixijs-v5-14-graphics-shapes.md","PixiJS V5 Tutorial (14) - Graphics (2): Circles, Polygons, Lines and Stars","1001734264",{"type":9,"value":10,"toc":807},"minimark",[11,16,20,24,32,37,59,162,172,176,194,270,275,279,299,380,385,389,399,502,507,511,525,528,641,646,650,672,774,779,783,803],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Last time we covered basic geometry drawing, but I only showed you the rectangle. PIXI actually has a bunch of other shapes you can draw, so in this post let's go through the rest of them.",[12,21,23],{"id":22},"geometry","Geometry",[17,25,26,27,31],{},"Like I mentioned before, the opening move for any shape is always to instantiate one with ",[28,29,30],"code",{},"new PIXI.Graphics();",". Everything else is the same here.",[33,34,36],"h3",{"id":35},"circle-drawcircle","Circle — drawCircle",[17,38,39,40,43,44,47,48,51,52,55,56,58],{},"You draw a circle with ",[28,41,42],{},"drawCircle()",", and it takes three parameters: ",[28,45,46],{},"x",", ",[28,49,50],{},"y",", and ",[28,53,54],{},"radius",". Basically you control the size of the circle with that third one, ",[28,57,54],{},".",[60,61,66],"pre",{"className":62,"code":63,"language":64,"meta":65,"style":65},"language-js shiki shiki-themes github-dark-high-contrast","let graphics = new PIXI.Graphics();\ngraphics.lineStyle(5, 0x000000, 1);\ngraphics.drawCircle(0, 0, 50);\ngraphics.endFill();\n","js","",[28,67,68,100,128,152],{"__ignoreMap":65},[69,70,73,77,81,84,87,91,93,97],"span",{"class":71,"line":72},"line",1,[69,74,76],{"class":75},"sWyjQ","let",[69,78,80],{"class":79},"sMAXC"," graphics ",[69,82,83],{"class":75},"=",[69,85,86],{"class":75}," new",[69,88,90],{"class":89},"sCcAr"," PIXI",[69,92,58],{"class":79},[69,94,96],{"class":95},"sj_SG","Graphics",[69,98,99],{"class":79},"();\n",[69,101,103,106,109,112,115,117,120,122,125],{"class":71,"line":102},2,[69,104,105],{"class":79},"graphics.",[69,107,108],{"class":95},"lineStyle",[69,110,111],{"class":79},"(",[69,113,114],{"class":89},"5",[69,116,47],{"class":79},[69,118,119],{"class":89},"0x000000",[69,121,47],{"class":79},[69,123,124],{"class":89},"1",[69,126,127],{"class":79},");\n",[69,129,131,133,136,138,141,143,145,147,150],{"class":71,"line":130},3,[69,132,105],{"class":79},[69,134,135],{"class":95},"drawCircle",[69,137,111],{"class":79},[69,139,140],{"class":89},"0",[69,142,47],{"class":79},[69,144,140],{"class":89},[69,146,47],{"class":79},[69,148,149],{"class":89},"50",[69,151,127],{"class":79},[69,153,155,157,160],{"class":71,"line":154},4,[69,156,105],{"class":79},[69,158,159],{"class":95},"endFill",[69,161,99],{"class":79},[163,164,171],"iframe",{"height":165,"style":166,"scrolling":167,"title":168,"src":169,"frameBorder":167,"allowTransparency":170,"allowFullScreen":170},265,"width: 100%;","no","PIXI Graphics(3)","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FjOEGGem?height=265&theme-id=default&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FjOEGGem