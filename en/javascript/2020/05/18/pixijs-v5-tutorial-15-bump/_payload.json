,359,360],{"class":86},"(vx) ",[72,362,363],{"class":78},"\u003C",[72,365,366],{"class":86}," combinedHalfWidths) {\n",[72,368,370,373,375,377,380,382],{"class":74,"line":369},17,[72,371,372],{"class":78},"        if",[72,374,354],{"class":86},[72,376,357],{"class":82},[72,378,379],{"class":86},"(vy) ",[72,381,363],{"class":78},[72,383,384],{"class":86}," combinedHalfHeights) {\n",[72,386,388,391,393,396],{"class":74,"line":387},18,[72,389,390],{"class":86},"        hit ",[72,392,118],{"class":78},[72,394,395],{"class":121}," true",[72,397,125],{"class":86},[72,399,401,404,407],{"class":74,"line":400},19,[72,402,403],{"class":86},"        } ",[72,405,406],{"class":78},"else",[72,408,409],{"class":86}," {\n",[72,411,413,415,417,419],{"class":74,"line":412},20,[72,414,390],{"class":86},[72,416,118],{"class":78},[72,418,122],{"class":121},[72,420,125],{"class":86},[72,422,424],{"class":74,"line":423},21,[72,425,426],{"class":86},"        }\n",[72,428,430,433,435],{"class":74,"line":429},22,[72,431,432],{"class":86},"    } ",[72,434,406],{"class":78},[72,436,409],{"class":86},[72,438,440,442,444,446],{"class":74,"line":439},23,[72,441,390],{"class":86},[72,443,118],{"class":78},[72,445,122],{"class":121},[72,447,125],{"class":86},[72,449,451],{"class":74,"line":450},24,[72,452,453],{"class":86},"    }\n",[72,455,457,460],{"class":74,"line":456},25,[72,458,459],{"class":78},"    return",[72,461,462],{"class":86}," hit;\n",[72,464,466],{"class":74,"line":465},26,[72,467,468],{"class":86},"};\n",[17,470,471,472,475,476,479],{},"Using it is dead simple — just call it and pass in two objects, ",[28,473,474],{},"hitTestRectangle(a, b)",". If they're colliding, it returns ",[28,477,478],{},"true",". That alone lets you do a ton of things.",[17,481,482,483,485],{},"There's also a similar ",[28,484,474],{}," that someone shared on the PIXI forums, and honestly it feels a bit cleaner:",[63,487,489],{"className":65,"code":488,"language":67,"meta":68,"style":68},"function boxesIntersect(a, b)\n{\n  var ab = a.getBounds();\n  var bb = b.getBounds();\n  return ab.x + ab.width > bb.x && ab.x \u003C bb.x + bb.width && ab.y + ab.height > bb.y && ab.y \u003C bb.y + bb.height;\n}\n",[28,490,491,510,515,534,550,611],{"__ignoreMap":68},[72,492,493,495,498,500,502,504,507],{"class":74,"line":75},[72,494,79],{"class":78},[72,496,497],{"class":82}," boxesIntersect",[72,499,87],{"class":86},[72,501,43],{"class":90},[72,503,94],{"class":86},[72,505,506],{"class":90},"b",[72,508,509],{"class":86},")\n",[72,511,512],{"class":74,"line":103},[72,513,514],{"class":86},"{\n",[72,516,517,520,523,525,528,531],{"class":74,"line":112},[72,518,519],{"class":78},"  var",[72,521,522],{"class":86}," ab ",[72,524,118],{"class":78},[72,526,527],{"class":86}," a.",[72,529,530],{"class":82},"getBounds",[72,532,533],{"class":86},"();\n",[72,535,536,538,541,543,546,548],{"class":74,"line":128},[72,537,519],{"class":78},[72,539,540],{"class":86}," bb ",[72,542,118],{"class":78},[72,544,545],{"class":86}," b.",[72,547,530],{"class":82},[72,549,533],{"class":86},[72,551,552,555,558,560,563,566,569,572,574,576,578,580,583,585,588,590,593,595,598,600,602,604,606,608],{"class":74,"line":153},[72,553,554],{"class":78},"  return",[72,556,557],{"class":86}," ab.x ",[72,559,139],{"class":78},[72,561,562],{"class":86}," ab.width ",[72,564,565],{"class":78},">",[72,567,568],{"class":86}," bb.x ",[72,570,571],{"class":78},"&&",[72,573,557],{"class":86},[72,575,363],{"class":78},[72,577,568],{"class":86},[72,579,139],{"class":78},[72,581,582],{"class":86}," bb.width ",[72,584,571],{"class":78},[72,586,587],{"class":86}," ab.y ",[72,589,139],{"class":78},[72,591,592],{"class":86}," ab.height ",[72,594,565],{"class":78},[72,596,597],{"class":86}," bb.y ",[72,599,571],{"class":78},[72,601,587],{"class":86},[72,603,363],{"class":78},[72,605,597],{"class":86},[72,607,139],{"class":78},[72,609,610],{"class":86}," bb.height;\n",[72,612,613],{"class":74,"line":175},[72,614,615],{"class":86},"}\n",[17,617,618,619,622],{},"Now, every frame we need to re-check whether a collision is happening, so we pair this with ",[28,620,621],{},"app.ticker.add((delta) => {...}"," from earlier. The result looks like this:",[63,624,626],{"className":65,"code":625,"language":67,"meta":68,"style":68},"app.ticker.add((delta) => {\n  if (boxesIntersect(container, container2)) {\n    container.y -= 20; \u002F\u002F nudge it back so the alert doesn't trap us\n    container.x -= 20;\n    alert('You hit me!');\n  }\n})\n",[28,627,628,650,664,682,693,707,712],{"__ignoreMap":68},[72,629,630,633,636,639,642,645,648],{"class":74,"line":75},[72,631,632],{"class":86},"app.ticker.",[72,634,635],{"class":82},"add",[72,637,638],{"class":86},"((",[72,640,641],{"class":90},"delta",[72,643,644],{"class":86},") ",[72,646,647],{"class":78},"=>",[72,649,409],{"class":86},[72,651,652,655,658,661],{"class":74,"line":103},[72,653,654],{"class":78},"  if",[72,656,657],{"class":86}," (",[72,659,660],{"class":82},"boxesIntersect",[72,662,663],{"class":86},"(container, container2)) {\n",[72,665,666,669,672,675,678],{"class":74,"line":112},[72,667,668],{"class":86},"    container.y ",[72,670,671],{"class":78},"-=",[72,673,674],{"class":121}," 20",[72,676,677],{"class":86},"; ",[72,679,681],{"class":680},"sQrFR","\u002F\u002F nudge it back so the alert doesn't trap us\n",[72,683,684,687,689,691],{"class":74,"line":128},[72,685,686],{"class":86},"    container.x ",[72,688,671],{"class":78},[72,690,674],{"class":121},[72,692,125],{"class":86},[72,694,695,698,700,704],{"class":74,"line":153},[72,696,697],{"class":82},"    alert",[72,699,87],{"class":86},[72,701,703],{"class":702},"sTRMh","'You hit me!'",[72,705,706],{"class":86},");\n",[72,708,709],{"class":74,"line":175},[72,710,711],{"class":86},"  }\n",[72,713,714],{"class":74,"line":197},[72,715,716],{"class":86},"})\n",[718,719,725],"iframe",{"height":720,"style":721,"scrolling":722,"title":723,"src":724,"frameBorder":722,"allowTransparency":478,"allowFul