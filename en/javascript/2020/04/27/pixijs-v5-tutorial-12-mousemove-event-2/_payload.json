-js shiki shiki-themes github-dark-high-contrast","container.click = () => {\n  alert('you click me!');\n};\n","js","",[28,57,58,83,99],{"__ignoreMap":55},[59,60,63,67,70,74,77,80],"span",{"class":61,"line":62},"line",1,[59,64,66],{"class":65},"sMAXC","container.",[59,68,34],{"class":69},"sj_SG",[59,71,73],{"class":72},"sWyjQ"," =",[59,75,76],{"class":65}," () ",[59,78,79],{"class":72},"=>",[59,81,82],{"class":65}," {\n",[59,84,86,89,92,96],{"class":61,"line":85},2,[59,87,88],{"class":69},"  alert",[59,90,91],{"class":65},"(",[59,93,95],{"class":94},"sTRMh","'you click me!'",[59,97,98],{"class":65},");\n",[59,100,102],{"class":61,"line":101},3,[59,103,104],{"class":65},"};\n",[17,106,107],{},"But if you only write it like that, you'll notice nothing happens. That's because you still have to tell PIXI \"I want interaction turned on\":",[50,109,111],{"className":52,"code":110,"language":54,"meta":55,"style":55},"container.interactive = true;\ncontainer.click = () => {\n  alert('you click me!');\n};\n",[28,112,113,128,142,152],{"__ignoreMap":55},[59,114,115,118,121,125],{"class":61,"line":62},[59,116,117],{"class":65},"container.interactive ",[59,119,120],{"class":72},"=",[59,122,124],{"class":123},"sCcAr"," true",[59,126,127],{"class":65},";\n",[59,129,130,132,134,136,138,140],{"class":61,"line":85},[59,131,66],{"class":65},[59,133,34],{"class":69},[59,135,73],{"class":72},[59,137,76],{"class":65},[59,139,79],{"class":72},[59,141,82],{"class":65},[59,143,144,146,148,150],{"class":61,"line":101},[59,145,88],{"class":69},[59,147,91],{"class":65},[59,149,95],{"class":94},[59,151,98],{"class":65},[59,153,155],{"class":61,"line":154},4,[59,156,104],{"class":65},[17,158,159,160,163],{},"Also, if you don't set ",[28,161,162],{},"buttonMode",", the cursor won't turn into a pointer when you hover over the image:",[50,165,167],{"className":52,"code":166,"language":54,"meta":55,"style":55},"container.interactive = true;\ncontainer.buttonMode = true;\ncontainer.click = () => {\n  alert('you click me!');\n};\n",[28,168,169,179,190,204,214],{"__ignoreMap":55},[59,170,171,173,175,177],{"class":61,"line":62},[59,172,117],{"class":65},[59,174,120],{"class":72},[59,176,124],{"class":123},[59,178,127],{"class":65},[59,180,181,184,186,188],{"class":61,"line":85},[59,182,183],{"class":65},"container.buttonMode ",[59,185,120],{"class":72},[59,187,124],{"class":123},[59,189,127],{"class":65},[59,191,192,194,196,198,200,202],{"class":61,"line":101},[59,193,66],{"class":65},[59,195,34],{"class":69},[59,197,73],{"class":72},[59,199,76],{"class":65},[59,201,79],{"class":72},[59,203,82],{"class":65},[59,205,206,208,210,212],{"class":61,"line":154},[59,207,88],{"class":69},[59,209,91],{"class":65},[59,211,95],{"class":94},[59,213,98],{"class":65},[59,215,217],{"class":61,"line":216},5,[59,218,104],{"class":65},[17,220,221],{},"Now when you click the sad face, a window pops up:",[17,223,224],{},[225,226],"img",{"alt":227,"src":228},"Pop-up window","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F2019-12-27_10-58-10.png",[17,230,231,232,235],{},"We can use this to do something a little different too — like shrinking the image a bit on every click (in PIXI you resize an image with ",[28,233,234],{},"scale","):",[50,237,239],{"className":52,"code":238,"language":54,"meta":55,"style":55},"container.click = () => {\n  container.scale.x -= 0.1;\n  container.scale.y -= 0.1;\n};\n",[28,240,241,255,268,279],{"__ignoreMap":55},[59,242,243,245,247,249,251,253],{"class":61,"line":62},[59,244,66],{"class":65},[59,246,34],{"class":69},[59,248,73],{"class":72},[59,250,76],{"class":65},[59,252,79],{"class":72},[59,254,82],{"class":65},[59,256,257,260,263,266],{"class":61,"line":85},[59,258,259],{"class":65},"  container.scale.x ",[59,261,262],{"class":72},"-=",[59,264,265],{"class":123}," 0.1",[59,267,127],{"class":65},[59,269,270,273,275,277],{"class":61,"line":101},[59,271,272],{"class":65},"  container.scale.y ",[59,274,262],{"class":72},[59,