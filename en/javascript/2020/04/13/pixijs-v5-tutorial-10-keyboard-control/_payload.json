46},"language-js shiki shiki-themes github-dark-high-contrast","const body = document.querySelector('body');\n\nbody.addEventListener('keydown',(e) => {\n  console.log(e.keyCode);\n})\n","js","",[36,48,49,83,90,120,132],{"__ignoreMap":46},[50,51,54,58,62,65,69,73,76,80],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sWyjQ","const",[50,59,61],{"class":60},"sCcAr"," body",[50,63,64],{"class":56}," =",[50,66,68],{"class":67},"sMAXC"," document.",[50,70,72],{"class":71},"sj_SG","querySelector",[50,74,75],{"class":67},"(",[50,77,79],{"class":78},"sTRMh","'body'",[50,81,82],{"class":67},");\n",[50,84,86],{"class":52,"line":85},2,[50,87,89],{"emptyLinePlaceholder":88},true,"\n",[50,91,93,96,99,101,104,107,111,114,117],{"class":52,"line":92},3,[50,94,95],{"class":67},"body.",[50,97,98],{"class":71},"addEventListener",[50,100,75],{"class":67},[50,102,103],{"class":78},"'keydown'",[50,105,106],{"class":67},",(",[50,108,110],{"class":109},"s_sBn","e",[50,112,113],{"class":67},") ",[50,115,116],{"class":56},"=>",[50,118,119],{"class":67}," {\n",[50,121,123,126,129],{"class":52,"line":122},4,[50,124,125],{"class":67},"  console.",[50,127,128],{"class":71},"log",[50,130,131],{"class":67},"(e.keyCode);\n",[50,133,135],{"class":52,"line":134},5,[50,136,137],{"class":67},"})\n",[17,139,140],{},"So here are the key codes we end up with:",[142,143,144,148,151,154,157,160,163,166],"ul",{},[145,146,147],"li",{},"Up - 38",[145,149,150],{},"Down - 40",[145,152,153],{},"Left - 37",[145,155,156],{},"Right - 39",[145,158,159],{},"W (up) - 87",[145,161,162],{},"S (down) - 83",[145,164,165],{},"A (left) - 65",[145,167,168],{},"D (right) - 68",[17,170,171,172,177],{},"If you're shaky on the JavaScript basics, I'd recommend checking out the ",[173,174,176],"a",{"href":175},"\u002Ftags\u002FRE%EF%BC%9A%E5%BE%9E%E9%9B%B6%E9%96%8B%E5%A7%8B%E7%9A%84%E5%AD%B8%E7%BF%92-JS-%E7%94%9F%E6%B4%BB\u002F","RE: Learning JS Life From Zero (article in Mandarin)"," series I wrote during a past Ironman challenge.",[12,179,181],{"id":180},"moving-with-the-keyboard","Moving with the keyboard",[17,183,184],{},"Now that we know the key codes, let's actually wire up the movement. I'm reusing the earlier example and tweaking it:",[186,187,194],"iframe",{"height":188,"style":189,"scrolling":190,"title":191,"src":192,"frameBorder":190,"allowTransparency":193,"allowFullScreen":193},265,"width: 100%;","no","PIXI ticker speed","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FWNbpder?height=265&theme-id=default&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNbpder'>PIXI ticker speed\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[41,196,198],{"className":43,"code":197,"language":45,"meta":46,"style":46},"const body = document.querySelector('body');\n\nbody.addEventListener('keydown',(e) => {\n  switch(e.keyCode) {\n    case 38:\n    case 87:\n      container.y -= 5;\n      break;\n    case 40:\n    case 83:\n      container.y += 5;\n      break;\n    case 37:\n    case 65:\n      container.x -= 5;\n      break;\n    case 39:\n    case 68:\n      container.x += 5;\n      break;\n    default:\n      break;\n  }\n})\n",[36,199,200,218,222,242,250,261,271,286,294,304,314,326,333,343,353,365,372,382,392,403,410,418,425,431],{"__ignoreMap":46},[50,201,202,204,206,208,210,212,214,216],{"class":52,"line":53},[50,203,57],{"class":56},[50,205,61],{"class":60},[50,207,64],{"class":56},[50,209,68],{"class":67},[50,211,72],{"class":71},[50,213,75],{"class":67},[50,215,79],{"class":78},[50,217,82],{"class":67},[50,219,220],{"class":52,"line":85},[50,221,89],{"emptyLinePlaceholder":88},[50,223,224,226,228,230,232,234,236,238,240],{"class":52,"line":92},[50,225,95],{"class":67},[50,227,98],{"class":71},[50,229,75],{"class":67},[50,231,103],{"class":78},[50,233,106],