ge loads at a different speed.",[17,435,436],{},[144,437],{"alt":438,"src":439},"Images loading out of order","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202020-12-22%2022.55.50.png",[17,441,442,443,446,447,450,451,453],{},"So once we pull out the image URL with JavaScript and write it into the ",[28,444,445],{},"src"," of the image created by ",[28,448,449],{},"new Image();",", we can listen for the image's load event. Through ",[28,452,389],{}," we get to know whether each image has loaded.",[17,455,456,457,461],{},"From there you just need a little bit of logic to only show things once ",[458,459,460],"em",{},"all"," the images are loaded. Something like this:",[46,463,465],{"className":48,"code":464,"language":50,"meta":51,"style":51},"const imgID = document.querySelectorAll('.img');\n\nlet i = 0;\nimgID.forEach((item, index) => {\n  const img = new Image();\n  img.src = item.src;\n  \n  img.addEventListener(\"load\", () => {\n    i += 1; \u002F\u002F +1 each time one finishes loading\n    if(imgID.length === i) { \u002F\u002F once all images are loaded, show \"done\" — pair this with a loading state to switch the UI\n      console.log('All images loaded');\n    }\n  });\n})\n",[28,466,467,485,489,504,524,538,546,551,568,587,608,623,629,635],{"__ignoreMap":51},[55,468,469,471,473,475,477,479,481,483],{"class":57,"line":58},[55,470,300],{"class":61},[55,472,303],{"class":82},[55,474,306],{"class":61},[55,476,309],{"class":65},[55,478,312],{"class":75},[55,480,79],{"class":65},[55,482,317],{"class":103},[55,484,92],{"class":65},[55,486,487],{"class":57,"line":95},[55,488,325],{"emptyLinePlaceholder":324},[55,490,491,494,497,499,502],{"class":57,"line":110},[55,492,493],{"class":61},"let",[55,495,496],{"class":65}," i ",[55,498,69],{"class":61},[55,500,501],{"class":82}," 0",[55,503,107],{"class":65},[55,505,506,508,510,512,514,516,518,520,522],{"class":57,"line":206},[55,507,330],{"class":65},[55,509,333],{"clas