5%A0%86%E7%96%8A.gif",[17,38,39],{},"And when a function finishes its job, its memory gets released:",[17,41,42],{},[33,43],{"alt":44,"src":45},"Memory being released","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E9%87%8B%E6%94%BE%E5%9F%B7%E8%A1%8C%E5%A0%86%E7%96%8A.gif",[17,47,48],{},"This behavior is called \"Garbage collection\", or GC for short.",[17,50,51],{},"So why does a closure have anything to do with this?",[17,53,54,55,59,60,63,64,67],{},"Let me show you an example first. The code below is pretty simple: ",[56,57,58],"code",{},"randomString"," is a function that generates a random string, and when you run ",[56,61,62],{},"getData"," it spits out a bunch of random strings and stores them in the ",[56,65,66],{},"demoData"," array.",[69,70,75],"pre",{"className":71,"code":72,"language":73,"meta":74,"style":74},"language-js shiki shiki-themes github-dark-high-contrast","function randomString(length) {\n  var result = '';\n  var characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\n  var charactersLength = characters.length;\n  for (var i = 0; i \u003C length; i++) {\n    result += characters.charAt(Math.floor(Math.random() * charactersLength));\n  }\n  return result;\n}\n\nfunction getData() {\n  var demoData = [];\n  for (let i = 0; i \u003C 1000; i++) {\n    demoData.push(randomString(1000))\n  }\n}\ngetData();\n","js","",[56,76,77,101,120,135,153,187,221,227,236,242,249,260,273,303,324,329,334],{"__ignoreMap":74},[78,79,82,86,90,94,98],"span",{"class":80,"line":81},"line",1,[78,83,85],{"class":84},"sWyjQ","function",[78,87,89],{"class":88},"sj_SG"," randomString",[78,91,93],{"class":92},"sMAXC","(",[78,95,97],{"class":96},"s_sBn","length",[78,99,100],{"class":92},") {\n",[78,102,104,107,110,113,117],{"class":80,"line":103},2,[78,105,106],{"class":84},"  var",[78,108,109],{"class":92}," result ",[78,111,112],{"class":84},"=",[78,114,116],{"cla