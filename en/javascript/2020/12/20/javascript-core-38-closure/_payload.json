],{"class":84},"    return",[78,1098,1099],{"class":92}," money;\n",[78,1101,1102],{"class":80,"line":189},[78,1103,226],{"class":92},[78,1105,1106],{"class":80,"line":223},[78,1107,241],{"class":92},[78,1109,1110],{"class":80,"line":229},[78,1111,248],{"emptyLinePlaceholder":247},[78,1113,1114,1116,1119,1121,1123],{"class":80,"line":238},[78,1115,164],{"class":84},[78,1117,1118],{"class":92}," a ",[78,1120,112],{"class":84},[78,1122,1046],{"class":88},[78,1124,341],{"class":92},[17,1126,1127,1128,1131,1132,1135,1136,1139,1140,1142,1143,1145],{},"That right there is a textbook closure. I mentioned closures are mainly about memory — so what does that mean here? First we create an ",[56,1129,1130],{},"fn"," function that declares a variable and returns a function. Then we run ",[56,1133,1134],{},"fn()"," and store the result in the variable ",[56,1137,1138],{},"a",". At this point, if we try running ",[56,1141,1138],{},", you'll see it returns the inner ",[56,1144,85],{},":",[17,1147,1148],{},[33,1149],{"alt":1150,"src":1151},"Function","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-12-20%2020.18.18.png",[17,1153,1154,1155,1157],{},"So this function takes a parameter, namely ",[56,1156,1074],{},". And when we write it like this, you'll notice something interesting — the amount keeps adding up:",[69,1159,1161],{"className":71,"code":1160,"language":73,"meta":74,"style":74},"function fn() {\n  var money = 100;\n  return function(num) {\n    money = money + num;\n    return money;\n  }\n}\n\nvar a = fn();\n\nconsole.log(a(100)); \u002F\u002F 200\nconsole.log(a(100)); \u002F\u002F 300\nconsole.log(a(100)); \u002F\u002F 400\nconsole.log(a(100)); \u002F\u002F 500\n",[56,1162,1163,1171,1183,1195,1207,1213,1217,1221,1225,1237,1241,1265,1284,1303],{"__ignoreMap":74},[78,1164,1165,1167,1169],{"class":80,"line":81},[78,1166,85],{"class":84},[78,1168,1046],{"class":88},