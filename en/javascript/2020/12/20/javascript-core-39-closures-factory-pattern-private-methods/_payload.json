[{"data":1,"prerenderedAt":896},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2020\u002F12\u002F20\u002Fjavascript-core-39-closures-factory-pattern-private-methods\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2020\u002F12\u002F20\u002Fjavascript-core-39-closures-factory-pattern-private-methods\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2020\u002F12\u002F20\u002Fjavascript-core-39-closures-factory-pattern-private-methods\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2020\u002F12\u002F20\u002Fjavascript-core-39-closures-factory-pattern-private-methods\u002F":871,"related:\u002Fen\u002Fjavascript\u002F2020\u002F12\u002F20\u002Fjavascript-core-39-closures-factory-pattern-private-methods\u002F":880},"\u002Fjavascript\u002F20201220\u002F423870936\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":854,"date":855,"description":856,"extension":857,"lang":858,"meta":859,"navigation":234,"path":860,"readingMinutes":861,"seo":862,"standalone":863,"stem":864,"tags":865,"tldr":868,"updated":855,"url":869,"__hash__":870},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-39-closures-factory-pattern-private-methods.md","JavaScript Core Concepts (39) - Functions and This: Leveling Up Closures with the Factory Pattern and Private Methods","1000934445",{"type":9,"value":10,"toc":849},"minimark",[11,16,20,24,27,30,33,149,156,313,316,823,829,833,845],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Next up is a slightly more advanced way to use closures.",[12,21,23],{"id":22},"closures-leveled-up","Closures, leveled up",[17,25,26],{},"In the last chapter we got the main idea behind closures down — it all comes down to memory references and when that memory gets released. So with the example from last time, we can actually take it a step further and turn it into a factory pattern. But what is a factory pattern?",[17,28,29],{},"A factory is an abstract concept. The main idea is that it gives you an interface to work with. So in a factory pattern you'll usually pass in some arguments, run some repeatable action, and get a result back.",[17,31,32],{},"Going back to last chapter's example, we can tweak it so the amount is decided by whatever the user passes in:",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-js shiki shiki-themes github-dark-high-contrast","function fn(value) {\n  var money = value || 0; \u002F\u002F if the user passes nothing, default to 0\n  return function(num) {\n    money = money + num;\n    return money;\n  }\n}\n","js","",[41,42,43,67,96,112,128,137,143],"code",{"__ignoreMap":39},[44,45,48,52,56,60,64],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sWyjQ","function",[44,53,55],{"class":54},"sj_SG"," fn",[44,57,59],{"class":58},"sMAXC","(",[44,61,63],{"class":62},"s_sBn","value",[44,65,66],{"class":58},") {\n",[44,68,70,73,76,79,82,85,89,92],{"class":46,"line":69},2,[44,71,72],{"class":50},"  var",[44,74,75],{"class":58}," money ",[44,77,78],{"class":50},"=",[44,80,81],{"class":58}," value ",[44,83,84],{"class":50},"||",[44,86,88],{"class":87},"sCcAr"," 0",[44,90,91],{"class":58},"; ",[44,93,95],{"class":94},"sQrFR","\u002F\u002F if the user passes nothing, default to 0\n",[44,97,99,102,105,107,110],{"class":46,"line":98},3,[44,100,101],{"class":50},"  return",[44,103,104],{"class":50}," function",[44,106,59],{"class":58},[44,108,109],{"class":62},"num",[44,111,66],{"class":58},[44,113,115,118,120,122,125],{"class":46,"line":114},4,[44,116,117],{"class":58},"    money ",[44,119,78],{"class":50},[44,121,75],{"class":58},[44,123,124],{"class":50},"+",[44,126,127],{"class":58}," num;\n",[44,129,131,134],{"class":46,"line":130},5,[44,132,133],{"class":50},"    return",[44,135,136],{"class":58}," money;\n",[44,138,140],{"class":46,"line":139},6,[44,141,142],{"class":58},"  }\n",[44,144,146],{"class":46,"line":145},7,[44,147,148],{"class":58},"}\n",[17,150,151,152,155],{},"Because of this, we can keep using ",[41,153,154],{},"fn"," to create new closures over and over, each one generated from the argument the user hands in. And that's basically what we call the factory pattern:",[34,157,159],{"className":36,"code":158,"language":38,"meta":39,"style":39},"function fn(value) {\n  var money = value || 0; \u002F\u002F if the user passes nothing, default to 0\n  return function(num) {\n    money = money + num;\n    return money;\n  }\n}\n\nvar a = fn(100);\na(100); \u002F\u002F 200\n\nvar b = fn(1000);\nb(2000); \u002F\u002F 3000;\n",[41,160,161,173,191,203,215,221,225,229,236,257,273,278,297],{"__ignoreMap":39},[44,162,163,165,167,169,171],{"class":46,"line":47},[44,164,51],{"class":50},[44,166,55],{"class":54},[44,168,59],{"class":58},[44,170,63],{"class":62},[44,172,66],{"class":58},[44,174,175,177,179,181,183,185,187,189],{"class":46,"line":69},[44,176,72],{"class":50},[44,178,75],{"class":58},[44,180,78],{"class":50},[44,182,81],{"class":58},[44,184,84],{"class":50},[44,186,88],{"class":87},[44,188,91],{"class":58},[44,190,95],{"class":94},[44,192,193,195,197,199,201],{"class":46,"line":98},[44,194,101],{"class":50},[44,196,104],{"class":50},[44,198,59],{"class":58},[44,200,109],{"class":62},[44,202,66],{"class":58},[44,204,205,207,209,211,213],{"class":46,"line":114},[44,206,117],{"class":58},[44,208,78],{"class":50},[44,210,75],{"class":58},[44,212,124],{"class":50},[44,214,127],{"class":58},[44,216,217,219],{"class":46,"line":130},[44,218,133],{"class":50},[44,220,136],{"class":58},[44,222,223],{"class":46,"line":139},[44,224,142],{"class":58},[44,226,227],{"class":46,"line":145},[44,228,148],{"class":58},[44,230,232],{"class":46,"line":231},8,[44,233,235],{"emptyLinePlaceholder":234},true,"\n",[44,237,239,242,245,247,249,251,254],{"class":46,"line":238},9,[44,240,241],{"class":50},"var",[44,243,244],{"class":58}," a ",[44,246,78],{"class":50},[44,248,55],{"class":54},[44,250,59],{"class":58},[44,252,253],{"class":87},"100",[44,255,256],{"class":58},");\n",[44,258,260,263,265,267,270],{"class":46,"line":259},10,[44,261,262],{"class":54},"a",[44,264,59],{"class":58},[44,266,253],{"class":87},[44,268,269],{"class":58},"); ",[44,271,272],{"class":94},"\u002F\u002F 200\n",[44,274,276],{"class":46,"line":275},11,[44,277,235],{"emptyLinePlaceholder":234},[44,279,281,283,286,288,290,292,295],{"class":46,"line":280},12,[44,282,241],{"class":50},[44,284,285],{"class":58}," b ",[44,287,78],{"class":50},[44,289,55],{"class":54},[44,291,59],{"class":58},[44,293,294],{"class":87},"1000",[44,296,256],{"class":58},[44,298,300,303,305,308,310],{"class":46,"line":299},13,[44,301,302],{"class":54},"b",[44,304,59],{"class":58},[44,306,307],{"class":87},"2000",[44,309,269],{"class":58},[44,311,312],{"class":94},"\u002F\u002F 3000;\n",[17,314,315],{},"Closures have another trick up their sleeve too, and it's called private methods. A private method isn't limited to returning a single function — it can return all kinds of things, like an object. Here's a closure example I wrote a while back:",[34,317,319],{"className":36,"code":318,"language":38,"meta":39,"style":39},"function myMoney(storage) {\n  var money = storage;\n  console.log(money);\n  return function(price) {\n    return { \u002F\u002F use an object of functions to check and deduct the balance\n      nowMoney: function () {\n        return console.log(money);\n      },\n      count: function (price) {\n        if(money \u003C price) return console.log('Not enough balance, current balance: ' + money + ' $'); \u002F\u002F if price is bigger than the current money, return an error\n        if (!money \u003C= 0) { \u002F\u002F skip the calculation when money equals 0 or is less than money\n          return money = money - price;\n        }\n        return console.log('Failed to deduct balance, current balance: ' + money + ' $');\n      }\n    }\n  }\n}\n\u002F\u002F Ming is a bit broke, only tops up 500$\nvar ming = myMoney(500);\n\u002F\u002F Mei is loaded and tops up 5000$\nvar mei = myMoney(5000);\n\u002F\u002F Wang got money from who-knows-where and tops up 30000$\nvar wang = myMoney(30000);\n\n\u002F\u002F Ming spends 500$ over three days\nming().count(100);\nming().count(100);\nming().count(300);\n\u002F\u002F check Ming's current balance\nming().nowMoney();\n\u002F\u002F Mei spends 2300\nmei().count(1600);\nmei().count(100);\nmei().count(600);\n\u002F\u002F check Mei's current balance\nmei().nowMoney();\n\u002F\u002F Wang only spends 300\nwang().count(300);\n\u002F\u002F check Wang's current balance\nwang().nowMoney();\n",[41,320,321,335,346,357,370,380,393,405,410,426,468,491,508,513,537,543,549,554,559,565,584,590,609,615,634,639,645,663,678,694,700,713,719,736,751,767,773,784,790,806,812],{"__ignoreMap":39},[44,322,323,325,328,330,333],{"class":46,"line":47},[44,324,51],{"class":50},[44,326,327],{"class":54}," myMoney",[44,329,59],{"class":58},[44,331,332],{"class":62},"storage",[44,334,66],{"class":58},[44,336,337,339,341,343],{"class":46,"line":69},[44,338,72],{"class":50},[44,340,75],{"class":58},[44,342,78],{"class":50},[44,344,345],{"class":58}," storage;\n",[44,347,348,351,354],{"class":46,"line":98},[44,349,350],{"class":58},"  console.",[44,352,353],{"class":54},"log",[44,355,356],{"class":58},"(money);\n",[44,358,359,361,363,365,368],{"class":46,"line":114},[44,360,101],{"class":50},[44,362,104],{"class":50},[44,364,59],{"class":58},[44,366,367],{"class":62},"price",[44,369,66],{"class":58},[44,371,372,374,377],{"class":46,"line":130},[44,373,133],{"class":50},[44,375,376],{"class":58}," { ",[44,378,379],{"class":94},"\u002F\u002F use an object of functions to check and deduct the balance\n",[44,381,382,385,388,390],{"class":46,"line":139},[44,383,384],{"class":54},"      nowMoney",[44,386,387],{"class":58},": ",[44,389,51],{"class":50},[44,391,392],{"class":58}," () {\n",[44,394,395,398,401,403],{"class":46,"line":145},[44,396,397],{"class":50},"        return",[44,399,400],{"class":58}," console.",[44,402,353],{"class":54},[44,404,356],{"class