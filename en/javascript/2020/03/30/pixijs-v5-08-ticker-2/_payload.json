u stop it.",[77,78,83],"pre",{"className":79,"code":80,"language":81,"meta":82,"style":82},"language-js shiki shiki-themes github-dark-high-contrast","app.ticker.add((delta) => {\n  ...\n})\n","js","",[21,84,85,114,120],{"__ignoreMap":82},[86,87,90,94,97,100,104,107,111],"span",{"class":88,"line":89},"line",1,[86,91,93],{"class":92},"sMAXC","app.ticker.",[86,95,41],{"class":96},"sj_SG",[86,98,99],{"class":92},"((",[86,101,103],{"class":102},"s_sBn","delta",[86,105,106],{"class":92},") ",[86,108,110],{"class":109},"sWyjQ","=>",[86,112,113],{"class":92}," {\n",[86,115,117],{"class":88,"line":116},2,[86,118,119],{"class":109},"  ...\n",[86,121,123],{"class":88,"line":122},3,[86,124,125],{"class":92},"})\n",[12,127,46],{"id":128},"addonce",[17,130,131,132,135,136,138],{},"What about ",[21,133,134],{},"addOnce()","? It's the opposite of ",[21,137,74],{}," — it only runs once.",[77,140,142],{"className":79,"code":141,"language":81,"meta":82,"style":82},"app.ticker.addOnce((delta) => {\n  ...\n})\n",[21,143,144,160,164],{"__ignoreMap":82},[86,145,146,148,150,152,154,156,158],{"class":88,"line":89},[86,147,93],{"class":92},[86,149,46],{"class":96},[86,151,99],{"class":92},[86,153,103],{"class":102},[86,155,106],{"class":92},[86,157,110],{"class":109},[86,159,113],{"class":92},[86,161,162],{"class":88,"line":116},[86,163,119],{"class":109},[86,165,166],{"class":88,"line":122},[86,167,125],{"class":92},[12,169,51],{"id":51},[17,171,172,174,175,177],{},[21,173,51],{}," means destroying the game loop (the thing ",[21,176,74],{}," set up). One thing to watch out for: this method instantly kills all animation behavior, and once it's destroyed you can't run it again. Honestly though, I wouldn't really recommend using it.",[77,179,181],{"className":79,"code":180,"language":81,"meta":82,"style":82},"app.ticker.destroy();\n",[21,182,183],{"__ignoreMap":82},[86,184,185,187,189],{"class":88,"line":89},[86,186,93],{"class":92},[86,188,51],{"class":96},[86,190,191],{"class":92},"();\n",[