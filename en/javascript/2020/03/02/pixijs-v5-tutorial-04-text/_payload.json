},"  strokeThickness: ",[45,489,490],{"class":55},"8",[45,492,302],{"class":68},[45,494,495],{"class":305},"\u002F\u002F stroke thickness\n",[45,497,498],{"class":47,"line":152},[45,499,311],{"class":68},[12,501,503],{"id":502},"text-shadow","Text Shadow",[17,505,506],{},"And if you want the text to have a drop shadow, PIXI has settings for that as well:",[36,508,510],{"className":38,"code":509,"language":40,"meta":41,"style":41},"const text = new PIXI.Text('這是一段話', {\n  fontFamily: 'Microsoft JhengHei',\n  fontSize: 24,\n  fill: 0xEEEE00,\n  align: 'center',\n  stroke: '#000000',\n  strokeThickness: 8,\n  dropShadow: true, \u002F\u002F must be true to enable the shadow\n  dropShadowColor: '#ffffff', \u002F\u002F shadow color\n  dropShadowBlur: 4, \u002F\u002F shadow blur (softness)\n  dropShadowAngle: 5, \u002F\u002F shadow angle\n  dropShadowDistance: 10 \u002F\u002F shadow distance\n})\n",[21,511,512,534,542,550,558,566,574,582,594,607,620,633,644],{"__ignoreMap":41},[45,513,514,516,518,520,522,524,526,528,530,532],{"class":47,"line":48},[45,515,52],{"class":51},[45,517,274],{"class":55},[45,519,59],{"class":51},[45,521,62],{"class":51},[45,523,65],{"class":55},[45,525,24],{"class":68},[45,527,28],{"class":71},[45,529,87],{"class":68},[45,531,224],{"class":90},[45,533,291],{"class":68},[45,535,536,538,540],{"class":47,"line":78},[45,537,296],{"class":68},[45,539,299],{"class":90},[45,541,106],{"class":68},[45,543,544,546,548],{"class":47,"line":97},[45,545,354],{"class":68},[45,547,357],{"class":55},[45,549,106],{"class":68},[45,551,552,554,556],{"class":47,"line":109},[45,553,457],{"class":68},[45,555,370],{"class":55},[45,557,106],{"class":68},[45,559,560,562,564],{"class":47,"line":119},[45,561,386],{"class":68},[45,563,389],{"class":90},[45,565,106],{"class":68},[45,567,568,570,572],{"class":47,"line":130},[45,569,474],{"class":68},[45,571,477],{"class":90},[45,573,106],{"class":68},[45,575,576,578,580],{"class":47,"line":141},[45,577,487],{"class":68},[45,57