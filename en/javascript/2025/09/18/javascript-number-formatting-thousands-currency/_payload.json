[{"data":1,"prerenderedAt":1777},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2025\u002F09\u002F18\u002Fjavascript-number-formatting-thousands-currency\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2025\u002F09\u002F18\u002Fjavascript-number-formatting-thousands-currency\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2025\u002F09\u002F18\u002Fjavascript-number-formatting-thousands-currency\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2025\u002F09\u002F18\u002Fjavascript-number-formatting-thousands-currency\u002F":1754,"related:\u002Fen\u002Fjavascript\u002F2025\u002F09\u002F18\u002Fjavascript-number-formatting-thousands-currency\u002F":1763},"\u002Fjavascript\u002F20250918\u002F1019906872\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1738,"date":1739,"description":1740,"extension":1741,"lang":1742,"meta":1743,"navigation":211,"path":1744,"readingMinutes":1387,"seo":1745,"standalone":1746,"stem":1747,"tags":1748,"tldr":1751,"updated":1739,"url":1752,"__hash__":1753},"content\u002Fen\u002FJavaScript\u002Fjavascript-number-formatting-thousands-currency.md","JavaScript Number Formatting: The Easiest Way (Thousands Separators and Currency)","1001251205",{"type":9,"value":10,"toc":1730},"minimark",[11,18,23,26,30,33,111,117,120,254,261,264,393,396,407,411,416,422,459,497,502,594,597,603,689,692,695,700,830,834,837,840,843,977,979,986,1105,1109,1112,1312,1321,1325,1328,1404,1407,1410,1485,1489,1492,1567,1571,1574,1646,1650,1653,1727],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Fjavascript-number-format\u002FChatGPT%20Image%202025%E5%B9%B49%E6%9C%8818%E6%97%A5%20%E4%B8%8A%E5%8D%8810_49_23.png",[19,20,22],"h2",{"id":21},"intro","Intro",[12,24,25],{},"I recently had a task where I needed to format some numbers into a thousands separator or currency format. So I figured I'd write up how I went about it.",[19,27,29],{"id":28},"thousands-separator-formatting","Thousands Separator Formatting",[12,31,32],{},"When you're working on anything involving money or reports, you'll usually need to format numbers with thousands separators. And there are quite a few ways to do it:",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-js shiki shiki-themes github-dark-high-contrast","const number = 1234567.89;\nconst formattedNumber = number.toLocaleString('en-US'); \u002F\u002F \"1,234,567.89\"\nconsole.log(formattedNumber); \u002F\u002F \"1,234,567.89\"\n","js","",[41,42,43,66,97],"code",{"__ignoreMap":39},[44,45,48,52,56,59,62],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sWyjQ","const",[44,53,55],{"class":54},"sCcAr"," number",[44,57,58],{"class":50}," =",[44,60,61],{"class":54}," 1234567.89",[44,63,65],{"class":64},"sMAXC",";\n",[44,67,69,71,74,76,79,83,86,90,93],{"class":46,"line":68},2,[44,70,51],{"class":50},[44,72,73],{"class":54}," formattedNumber",[44,75,58],{"class":50},[44,77,78],{"class":64}," number.",[44,80,82],{"class":81},"sj_SG","toLocaleString",[44,84,85],{"class":64},"(",[44,87,89],{"class":88},"sTRMh","'en-US'",[44,91,92],{"class":64},"); ",[44,94,96],{"class":95},"sQrFR","\u002F\u002F \"1,234,567.89\"\n",[44,98,100,103,106,109],{"class":46,"line":99},3,[44,101,102],{"class":64},"console.",[44,104,105],{"class":81},"log",[44,107,108],{"class":64},"(formattedNumber); ",[44,110,96],{"class":95},[12,112,113,114,116],{},"This method formats the number based on the locale you pass in. ",[41,115,89],{}," means US formatting, which uses a comma as the thousands separator.",[12,118,119],{},"But if you want a custom separator, you can use a regular expression:",[34,121,123],{"className":36,"code":122,"language":38,"meta":39,"style":39},"function formatNumberWithCommas(number) {\n  return number.toString().replace(\u002F\\B(?=(\\d{3})+(?!\\d))\u002Fg, \".\");\n}\n\nconst number = 1234567.89;\nconst formattedNumber = formatNumberWithCommas(number); \u002F\u002F \"1.234.567.89\"\nconsole.log(formattedNumber); \u002F\u002F \"1.234.567.89\"\n",[41,124,125,142,201,206,213,226,243],{"__ignoreMap":39},[44,126,127,130,133,135,139],{"class":46,"line":47},[44,128,129],{"class":50},"function",[44,131,132],{"class":81}," formatNumberWithCommas",[44,134,85],{"class":64},[44,136,138],{"class":137},"s_sBn","number",[44,140,141],{"class":64},") {\n",[44,143,144,147,149,152,155,158,160,163,166,169,172,175,178,181,184,186,189,192,195,198],{"class":46,"line":68},[44,145,146],{"class":50},"  return",[44,148,78],{"class":64},[44,150,151],{"class":81},"toString",[44,153,154],{"class":64},"().",[44,156,157],{"class":81},"replace",[44,159,85],{"class":64},[44,161,162],{"class":88},"\u002F",[44,164,165],{"class":50},"\\B",[44,167,168],{"class":88},"(?=(",[44,170,171],{"class":54},"\\d",[44,173,174],{"class":50},"{3}",[44,176,177],{"class":88},")",[44,179,180],{"class":50},"+",[44,182,183],{"class":88},"(?!",[44,185,171],{"class":54},[44,187,188],{"class":88},"))\u002F",[44,190,191],{"class":50},"g",[44,193,194],{"class":64},", ",[44,196,197],{"class":88},"\".\"",[44,199,200],{"class":64},");\n",[44,202,203],{"class":46,"line":99},[44,204,205],{"class":64},"}\n",[44,207,209],{"class":46,"line":208},4,[44,210,212],{"emptyLinePlaceholder":211},true,"\n",[44,214,216,218,220,222,224],{"class":46,"line":215},5,[44,217,51],{"class":50},[44,219,55],{"class":54},[44,221,58],{"class":50},[44,223,61],{"class":54},[44,225,65],{"class":64},[44,227,229,231,233,235,237,240],{"class":46,"line":228},6,[44,230,51],{"class":50},[44,232,73],{"class":54},[44,234,58],{"class":50},[44,236,132],{"class":81},[44,238,239],{"class":64},"(number); ",[44,241,242],{"class":95},"\u002F\u002F \"1.234.567.89\"\n",[44,244,246,248,250,252],{"class":46,"line":245},7,[44,247,102],{"class":64},[44,249,105],{"class":81},[44,251,108],{"class":64},[44,253,242],{"class":95},[12,255,256,257,260],{},"This function turns the number into a string, then uses a regex to insert your separator (here it's ",[41,258,259],{},".",") before every group of three digits.",[12,262,263],{},"And if you want to slap a currency symbol on the front, you can do this:",[34,265,267],{"className":36,"code":266,"language":38,"meta":39,"style":39},"function formatCurrency(number, currencySymbol = '$') {\n  return currencySymbol + number.toString().replace(\u002F\\B(?=(\\d{3})+(?!\\d))\u002Fg, \",\");\n}\n\nconst number = 1234567.89;\nconst formattedCurrency = formatCurrency(number, 'NT$'); \u002F\u002F \"NT$1,234,567.89\"\nconsole.log(formattedCurrency); \u002F\u002F \"NT$1,234,567.89\"\n",[41,268,269,292,340,344,348,360,382],{"__ignoreMap":39},[44,270,271,273,276,278,280,282,285,287,290],{"class":46,"line":47},[44,272,129],{"class":50},[44,274,275],{"class":81}," formatCurrency",[44,277,85],{"class":64},[44,279,138],{"class":137},[44,281,194],{"class":64},[44,283,284],{"class":137},"currencySymbol",[44,286,58],{"class":50},[44,288,289],{"class":88}," '$'",[44,291,141],{"class":64},[44,293,294,296,299,301,303,305,307,309,311,313,315,317,319,321,323,325,327,329,331,333,335,338],{"class":46,"line":68},[44,295,146],{"class":50},[44,297,298],{"class":64}," currencySymbol ",[44,300,180],{"class":50},[44,302,78],{"class":64},[44,304,151],{"class":81},[44,306,154],{"class":64},[44,308,157],{"class":81},[44,310,85],{"class":64},[44,312,162],{"class":88},[44,314,165],{"class":50},[44,316,168],{"class":88},[44,318,171],{"class":54},[44,320,174],{"class":50},[44,322,177],{"class":88},[44,324,180],{"class":50},[44,326,183],{"class":88},[44,328,171],{"class":54},[44,330,188],{"class":88},[44,332,191],{"class":50},[44,334,194],{"class":64},[44,336,337],{"class":88},"\",\"",[44,339,200],{"class":64},[44,341,342],{"class":46,"line":99},[44,343,205],{"class":64},[44,345,346],{"class":46,"line":208},[44,347,212],{"emptyLinePlaceholder":211},[44,349,350,352,354,356,358],{"class":46,"line":215},[44,351,51],{"class":50},[44,353,55],{"class":54},[44,355,58],{"class":50},[44,357,61],{"class":54},[44,359,65],{"class":64},[44,361,362,364,367,369,371,374,377,379],{"class":46,"line":228},[44,363,51],{"class":50},[44,365,366],{"class":54}," formattedCurrency",[44,368,58],{"class":50},[44,370,275],{"class":81},[44,372,373],{"class":64},"(number, ",[44,375,376],{"class":88},"'NT$'",[44,378,92],{"class":64},[44,380,381],{"class":95},"\u002F\u002F \"NT$1,234,567.89\"\n",[44,383,384,386,388,391],{"class":46,"line":245},[44,385,102],{"class":64},[44,387,105],{"class":81},[44,389,390],{"class":64},"(formattedCurrency); ",[44,392,381],{"class":95},[12,394,395],{},"You can probably already tell that whether it's thousands separators or currency formatting, both are basically pulled off with a regular expression.",[12,397,398,399,406],{},"If you'd rather not roll your own like this, you might reach for a package like ",[400,401,405],"a",{"href":402,"rel":403},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fnumeral",[404],"nofollow","numeral",". But... that package isn't maintained anymore and it's pretty old, so a lot of people just end up writing their own.",[19,408,410],{"id":409},"intlnumberformat","Intl.NumberFormat",[12,412,413,414,259],{},"The old-school methods work, but they're not exactly intuitive or easy to maintain. So... is there a more modern, JavaScript-native way to do this? Yep, there is — it's ",[41,415,410],{},[12,417,418,419,421],{},"For modern development I'd recommend the built-in ",[41,420,410],{},". It performs well and there's nothing to install. Here's the basic shape of it:",[34,423,425],{"className":36,"code":424,"language":38,"meta":39,"style":39},"const formatter = new Intl.NumberFormat(locales, options);\nformatter.format(number);\n",[41,426,427,448],{"__ignoreMap":39},[44,428,429,431,434,436,439,442,445],{"class":46,"line":47},[44,430,51],{"class":50},[44,432,433],{"class":54}," formatter",[44,435,58],{"class":50},[44,437,438],{"class":50}," new",[44,440,441],{"class":64}," Intl.",[44,443,444],{"class":81},"NumberFormat",[44,446,447],{"class":64},"(locales, options);\n",[44,449,450,453,456],{"class":46,"line":68},[44,451,452],{"class":64},"formatter.",[44,454,455],{"class":81},"format",[44,457,458],{"class":64},"(number);\n",[460,461,462,479],"ul",{},[463,464,465,472,473,194,475,478],"li",{},[466,467,468,471],"strong",{},[41,469,470],{},"locales",":"," the locale to use, e.g. ",[41,474,89],{},[41,476,477],{},"'zh-TW'",", and so on.",[463,480,481,486,487,194,490,194,493,496],{},[466,482,483,471],{},[41,484,485],{},"options"," the formatting options, e.g. ",[41,488,489],{},"style",[41,491,492],{},"currency",[41,494,495],{},"minimumFractionDigits",", etc.",[12,498,499,501],{},[41,500,410],{}," is a built-in JavaScript object made specifically for formatting numbers, and it handles all kinds of formatting needs really conveniently. Here's an example:",[34,503,505],{"className":36,"code":504,"language":38,"meta":39,"style":39},"const number = 1234567.89;\nconst formatter = new Intl.NumberFormat('en-US', {\n  style: 'currency',\n  currency: 'USD',\n});\nconst formattedCurrency = formatter.format(number); \u002F\u002F \"$1,234,567.89\"\nconsole.log(formattedCurrency); \u002F\u002F \"$1,234,567.89\"\n",[41,506,507,519,540,551,561,566,584],{"__ignoreMap":39},[44,508,509,511,513,515,517],{"class":46,"line":47},[44,510,51],{"class":50},[44,512,55],{"class":54},[44,514,58],{"class":50},[44,516,61],{"class":54},[44,518,65],{"class":64},[44,520,521,523,525,527,529,531,533,535,537],{"class":46,"line":68},[44,522,51],{"class":50},[44,524,433],{"class":54},[44,526,58],{"class":50},[44,528,438],{"class":50},[44,530,441],{"class":64},[44,532,444],{"class":81},[44,534,85],{"class":64},[44,536,89],{"class":88},[44,538,539],{"class":64},", {\n",[44,541,542,545,548],{"class":46,"line":99},[44,543,544],{"class":64},"  style: ",[44,546,547],{"class":88},"'currency'",[44,549,550],{"class":64},",\n",[44,552,553,556,559],{"class":46,"line":208},[44,554,555],{"class":64},"  currency: ",[44,557,558],{"class":88},"'USD'",[44,560,550],{"class":64},[44,562,563],{"class":46,"line":215},[44,564,565],{"class":64},"});\n",[44,567,568,570,572,574,577,579,581],{"class":46,"line":228},[44,569,51],{"class":50},[44,571,366],{"class":54},[44,573,58],{"class":50},[44,575,576],{"class":64}," formatter.",[44,578,455],{"class":81},[44,580,239],{"class":64},[44,582,583],{"class":95},"\u002F\u002F \"$1,234,567.89\"\n",[44,585,586,588,590,592],{"class":46,"line":245},[44,587,102],{"class":64},[44,589,105],{"class":81},[44,591,390],{"class":64},[44,593,583],{"class":95},[12,595,596],{},"As you can see, this not only handles the thousands separators but also adds the currency symbol directly — no need to hand-write a regex anymore. And it automatically adjusts the format based on the locale, which is super handy.",[12,598,599,600,602],{},"If you want to format into a different currency, you just change the ",[41,601,492],{}," value. For example:",[34,604,606],{"className":36,"code":605,"language":38,"meta":39,"style":39},"const number = 1234567.89;\nconst formatter = new Intl.NumberFormat('ja-JP', {\n  style: 'currency',\n  currency: 'JPY',\n});\nconst formattedCurrency = formatter.format(number); \u002F\u002F \"￥1,234,568\"\nconsole.log(formattedCurrency); \u002F\u002F \"￥1,234,568\"\n",[41,607,608,620,641,649,658,662,679],{"__ignoreMap":39},[44,609,610,612,614,616,618],{"class":46,"line":47},[44,611,51],{"class":50},[44,613,55],{"class":54},[44,615,58],{"class":50},[44,617,61],{"class":54},[44,619,65],{"class":64},[44,621,622,624,626,628,630,632,634,636,639],{"class":46,"line":68},[44,623,51],{"class":50},[44,625,433],{"class":54},[44,627,58],{"class":50},[44,629,438],{"class":50},[44,631,441],{"class":64},[44,633,444],{"class":81},[44,635,85],{"class":64},[44,637,638],{"class":88},"'ja-JP'",[44,640,539],{"class":64},[44,642,643,645,647],{"class":46,"line":99},[44,644,544],{"class":64},[44,646,547],{"class":88},[44,648,550],{"class":64},[44,650,651,653,656],{"class":46,"line":208},[44,652,555],{"class":64},[4