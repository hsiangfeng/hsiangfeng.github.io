8},"\u002F\u002F I'm Array\n",[307,308,309],"blockquote",{},[17,310,311,315,316,319,320,323,324,327],{},[312,313,314],"strong",{},"Note","\nWhen you drop an array into a template literal, ",[21,317,318],{},"Array.prototype.toString()"," kicks in and the array gets turned into a string. That's why you see ",[21,321,322],{},"I'm Array"," instead of ",[21,325,326],{},"I'm ['Array']",".",[12,329,331],{"id":330},"filter-tricks","Filter tricks",[17,333,334],{},"Pretty often you'll want to strip certain values out of an array — things like...",[336,337,338,346,351,356,362,367],"ul",{},[339,340,341,342,345],"li",{},"empty strings (",[21,343,344],{},"'' or \"\"",")",[339,347,348],{},[21,349,350],{},"null",[339,352,353],{},[21,354,355],{},"undefined",[339,357,358,361],{},[21,359,360],{},"0"," (the number zero)",[339,363,364],{},[21,365,366],{},"false",[339,368,369,372],{},[21,370,371],{},"NaN"," (Not a Number)",[17,374,375],{},"These are what we call falsy values. The usual first instinct when filtering them out is to write something like this:",[38,377,379],{"className":40,"code":378,"language":42,"meta":43,"style":43},"const data = ['Is', '', 'Ray', 'Not', null, 'Array', undefined, 0, false, NaN];\n\nconst result = data.filter((value) => {\n  \u002F\u002F Run the value through if to coerce it to Boolean, keeping only the non-falsy ones\n  if (value) {\n    return value;\n  }\n});\n\nconsole.log(`I'm ${result.join('')}`); \u002F\u002F I'm Is Ray Not Array\n",[21,380,381,432,436,460,465,473,482,488,494,499],{"__ignoreMap":43},[47,382,383,385,387,389,391,393,395,398,400,402,404,406,408,410,412,414,416,418,420,422,424,426,428,430],{"class":49,"line":50},[47,384,54],{"class":53},[47,386,217],{"class":57},[47,388,61],{"class":53},[47,390,65],{"class":64},[47,392,224],{"class":185},[47,394,71],{"class":64},[47,396,397],{"class":185},"''",[47,399,71],{"class":64},[47,401,229],{"class":185},[47,403,71],{"class":64},[47,405,234],{"class":185},[47,407,71],{"class":64},[47,409,350],{"c