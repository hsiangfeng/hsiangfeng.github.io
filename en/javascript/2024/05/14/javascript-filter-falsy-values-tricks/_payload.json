, 'Array', undefined, 0, false, NaN];\n\nconst result = data.filter((str) => str);\n\nconsole.log(`I'm ${result.join(' ')}`); \u002F\u002F I'm Is Ray Not Array\n",[21,537,538,588,592,615,619],{"__ignoreMap":43},[47,539,540,542,544,546,548,550,552,554,556,558,560,562,564,566,568,570,572,574,576,578,580,582,584,586],{"class":49,"line":50},[47,541,54],{"class":53},[47,543,217],{"class":57},[47,545,61],{"class":53},[47,547,65],{"class":64},[47,549,224],{"class":185},[47,551,71],{"class":64},[47,553,397],{"class":185},[47,555,71],{"class":64},[47,557,229],{"class":185},[47,559,71],{"class":64},[47,561,234],{"class":185},[47,563,71],{"class":64},[47,565,350],{"class":57},[47,567,71],{"class":64},[47,569,239],{"class":185},[47,571,71],{"class":64},[47,573,355],{"class":57},[47,575,71],{"class":64},[47,577,360],{"class":57},[47,579,71],{"class":64},[47,581,366],{"class":57},[47,583,71],{"class":64},[47,585,371],{"class":57},[47,587,117],{"class":64},[47,589,590],{"class":49,"line":120},[47,591,124],{"emptyLinePlaceholder":123},[47,593,594,596,598,600,602,604,606,608,610,612],{"class":49,"line":127},[47,595,54],{"class":53},[47,597,132],{"class":57},[47,599,61],{"class":53},[47,601,256],{"class":64},[47,603,23],{"class":140},[47,605,143],{"class":64},[47,607,263],{"class":146},[47,609,150],{"class":64},[47,611,153],{"class":53},[47,613,614],{"class":64}," str);\n",[47,616,617],{"class":49,"line":168},[47,618,124],{"emptyLinePlaceholder":123},[47,620,621,623,625,627,629,631,633,635,637,640,642,644,646],{"class":49,"line":173},[47,622,176],{"class":64},[47,624,179],{"class":140},[47,626,182],{"class":64},[47,628,296],{"class":185},[47,630,189],{"class":64},[47,632,327],{"class":185},[47,634,516],{"class":140},[47,636,182],{"class":185},[47,638,639],{"class":185},"' '",[47,641,345],{"class":185},[47,643,192],{"class":185},[47,645,195],{"class":64},[47,647,529],{"class":198},[17,649,650,651,654,655,657,658,660],{},"That drops all the falsy values right there. So why does this work without an ",[21,652,653],{},"if","? Because ",[21,656,23],{}," already throws away anything that's falsy — so the ",[21,659,653],{}," check is redundant and we can skip it.",[307,662,663],{},[17,664,665,667,668,671,672,675,676,678],{},[312,666,314],{},"\nCareful not to turn ",[21,669,670],{},"data.filter((str) => str);"," into ",[21,673,674],{},"data.filter(str);"," — that breaks ",[21,677,23],{}," entirely.",[17,680,681,682,685,686,689,690,692,693,695],{},"So is that the shortest it gets? Can we drop the ",[21,683,684],{},"(str) => str"," part too? Turns out yes — but you'll need the ",[21,687,688],{},"Boolean"," function. Just swap ",[21,691,684],{}," for ",[21,694,688],{},":",[38,697,699],{"className":40,"code":698,"language":42,"meta":43,"style":43},"const data = ['Is', '', 'Ray', 'Not', null, 'Array', undefined, 0, false, NaN];\n\nconst result = data.filter(Boolean);\n\nconsole.log(`I'm ${result.join(' ')}`); \u002F\u002F I'm Is Ray Not Array\n",[21,700,701,751,755,770,774],{"__ignoreMap":43},[47,702,703,705,707,709,711,713,715,717,719,721,723,725,727,729,731,733,735,737,739,741,743,745,747,749],{"class":49,"line":50},[47,704,54],{"class":53},[47,706,217],{"class":57},[47,708,61],{"class":53},[47,710,65],{"class":64},[47,712,224],{"class":185},[47,714,71],{"class":64},[47,716,397],{"class":185},[47,718,71],{"class":64},[47,720,229],{"class":185},[47,722,71],{"class":64},[47,724,234],{"class":185},[47,726,71],{"class":64},[47,728,350],{"class":57},[47,730,71],{"class":64},[47,732,239],{"class":185},[47,734,71],{"class":64},[47,736,355],{"class":57},[47,738,71],{"class":64},[47,740,360],{"class":57},[47,742,71],{"class":64},[47,744,366],{"class":57},[47,746,71],{"class":64},[47,748,371],{"class":57},[47,750,117],{"class":64},[47,752,753],{"class":49,"line":120},[47,754,124],{"emptyLinePlaceholder":123},[47,756,757,759,761,763,765,767],{"class":49,"line":127},[47,758,54],{"class":53},[47,760,132],{"class":57},[47,762,61],{"class":53},[47,764,256],{"class":64},