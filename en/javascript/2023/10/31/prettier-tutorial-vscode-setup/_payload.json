[{"data":1,"prerenderedAt":1756},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2023\u002F10\u002F31\u002Fprettier-tutorial-vscode-setup\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2023\u002F10\u002F31\u002Fprettier-tutorial-vscode-setup\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2023\u002F10\u002F31\u002Fprettier-tutorial-vscode-setup\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2023\u002F10\u002F31\u002Fprettier-tutorial-vscode-setup\u002F":1732,"related:\u002Fen\u002Fjavascript\u002F2023\u002F10\u002F31\u002Fprettier-tutorial-vscode-setup\u002F":1741},"\u002Fjavascript\u002F20231031\u002F1586150719\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1714,"date":1715,"description":1716,"extension":1717,"lang":1718,"meta":1719,"navigation":105,"path":1720,"readingMinutes":1721,"seo":1722,"standalone":1723,"stem":1724,"tags":1725,"tldr":1728,"updated":1729,"url":1730,"__hash__":1731},"content\u002Fen\u002FJavaScript\u002Fprettier-tutorial-vscode-setup.md","Prettier Tutorial: You'll End Up Using It Anyway — Why Not Start Now? (Full VSCode Setup)","8617590163",{"type":9,"value":10,"toc":1701},"minimark",[11,19,24,27,31,34,37,40,130,133,192,195,199,202,245,252,580,583,604,623,630,646,652,663,666,673,711,718,723,726,730,736,739,867,870,942,955,964,967,1271,1275,1282,1293,1300,1304,1307,1316,1319,1322,1327,1330,1334,1337,1381,1384,1424,1427,1430,1481,1485,1492,1543,1546,1550,1553,1570,1573,1582,1585,1592,1603,1606,1609,1638,1641,1671,1674,1677,1686,1697],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Prettier","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Fprettier-setting\u002FPrettier.jpg",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"In frontend dev there's one tool you really have to know — Prettier. Even if you're not using it today, you'll end up using it sooner or later. So why not just start now? This post walks through how to actually use it.",[20,28,30],{"id":29},"whats-prettier","What's Prettier?",[12,32,33],{},"By tradition, let's start with what Prettier actually is.",[12,35,36],{},"When you write code, whether solo or on a team, you've definitely seen this — the same logic written in totally different styles. That's a bit vague though, so let me show a real example.",[12,38,39],{},"Dev A's style:",[41,42,47],"pre",{"className":43,"code":44,"language":45,"meta":46,"style":46},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","function hello (name){\n  return \"Hello, \"+name+\"!\"\n}\n\nconsole.log(hello(\"World\"))\n","js","",[48,49,50,74,94,100,107],"code",{"__ignoreMap":46},[51,52,55,59,63,67,71],"span",{"class":53,"line":54},"line",1,[51,56,58],{"class":57},"sOudu","function",[51,60,62],{"class":61},"scAaK"," hello",[51,64,66],{"class":65},"s8XSl"," (",[51,68,70],{"class":69},"syBk-","name",[51,72,73],{"class":65},"){\n",[51,75,77,80,84,87,89,91],{"class":53,"line":76},2,[51,78,79],{"class":57},"  return",[51,81,83],{"class":82},"sWayO"," \"Hello, \"",[51,85,86],{"class":57},"+",[51,88,70],{"class":65},[51,90,86],{"class":57},[51,92,93],{"class":82},"\"!\"\n",[51,95,97],{"class":53,"line":96},3,[51,98,99],{"class":65},"}\n",[51,101,103],{"class":53,"line":102},4,[51,104,106],{"emptyLinePlaceholder":105},true,"\n",[51,108,110,113,116,119,122,124,127],{"class":53,"line":109},5,[51,111,112],{"class":65},"console.",[51,114,115],{"class":61},"log",[51,117,118],{"class":65},"(",[51,120,121],{"class":61},"hello",[51,123,118],{"class":65},[51,125,126],{"class":82},"\"World\"",[51,128,129],{"class":65},"))\n",[12,131,132],{},"Dev B's style:",[41,134,136],{"className":43,"code":135,"language":45,"meta":46,"style":46},"function hello(name) {\n  return `Hello, ${name}!`;\n}\n\nconsole.log(hello('World'));\n",[48,137,138,151,166,170,174],{"__ignoreMap":46},[51,139,140,142,144,146,148],{"class":53,"line":54},[51,141,58],{"class":57},[51,143,62],{"class":61},[51,145,118],{"class":65},[51,147,70],{"class":69},[51,149,150],{"class":65},") {\n",[51,152,153,155,158,160,163],{"class":53,"line":76},[51,154,79],{"class":57},[51,156,157],{"class":82}," `Hello, ${",[51,159,70],{"class":65},[51,161,162],{"class":82},"}!`",[51,164,165],{"class":65},";\n",[51,167,168],{"class":53,"line":96},[51,169,99],{"class":65},[51,171,172],{"class":53,"line":102},[51,173,106],{"emptyLinePlaceholder":105},[51,175,176,178,180,182,184,186,189],{"class":53,"line":109},[51,177,112],{"class":65},[51,179,115],{"class":61},[51,181,118],{"class":65},[51,183,121],{"class":61},[51,185,118],{"class":65},[51,187,188],{"class":82},"'World'",[51,190,191],{"class":65},"));\n",[12,193,194],{},"Two completely different styles for the same function. It might not seem like a big deal here, but on a real project — especially as it grows and more devs join — this kind of inconsistency makes the code painful to read. You're always reading other people's code, and if everyone writes differently, it gets exhausting. That's where a tool like Prettier comes in — to unify code style.",[20,196,198],{"id":197},"installing-prettier","Installing Prettier",[12,200,201],{},"Set up a quick playground:",[41,203,207],{"className":204,"code":205,"language":206,"meta":46,"style":46},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","mkdir prettier-example\ncd prettier-example\nnpm init -y\ntouch index.js\n","bash",[48,208,209,218,226,237],{"__ignoreMap":46},[51,210,211,215],{"class":53,"line":54},[51,212,214],{"class":213},"smYoP","mkdir",[51,216,217],{"class":82}," prettier-example\n",[51,219,220,224],{"class":53,"line":76},[51,221,223],{"class":222},"stw71","cd",[51,225,217],{"class":82},[51,227,228,231,234],{"class":53,"line":96},[51,229,230],{"class":213},"npm",[51,232,233],{"class":82}," init",[51,235,236],{"class":222}," -y\n",[51,238,239,242],{"class":53,"line":102},[51,240,241],{"class":213},"touch",[51,243,244],{"class":82}," index.js\n",[12,246,247,248,251],{},"For ",[48,249,250],{},