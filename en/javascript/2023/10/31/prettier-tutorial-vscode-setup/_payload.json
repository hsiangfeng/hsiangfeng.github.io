:204,"code":633,"language":206,"meta":46,"style":46},"node --eval \"fs.writeFileSync('.prettierrc','{}\\n')\"\n",[48,635,636],{"__ignoreMap":46},[51,637,638,641,644],{"class":53,"line":54},[51,639,640],{"class":69},"node",[51,642,643],{"class":221}," --eval",[51,645,646],{"class":82}," \"fs.writeFileSync('.prettierrc','{}\\n')\"\n",[12,648,649,650,652],{},"Or just create ",[48,651,629],{}," in the project root with this content:",[41,654,658],{"className":655,"code":656,"language":657,"meta":46,"style":46},"language-json shiki shiki-themes github-dark-high-contrast","{}\n","json",[48,659,660],{"__ignoreMap":46},[51,661,662],{"class":53,"line":54},[51,663,656],{"class":65},[12,665,666],{},"(Don't worry about the content — we'll fill it in later.)",[12,668,669,670,673],{},"Add a script to ",[48,671,672],{},"package.json"," so you can run Prettier easily:",[41,675,677],{"className":655,"code":676,"language":657,"meta":46,"style":46},"{\n  \"scripts\": {\n    \"prettier\": \"prettier --write .\"\n  }\n}\n",[48,678,679,683,692,703,708],{"__ignoreMap":46},[51,680,681],{"class":53,"line":54},[51,682,382],{"class":65},[51,684,685,689],{"class":53,"line":76},[51,686,688],{"class":687},"sKpQp","  \"scripts\"",[51,690,691],{"class":65},": {\n",[51,693,694,697,700],{"class":53,"line":96},[51,695,696],{"class":687},"    \"prettier\"",[51,698,699],{"class":65},": ",[51,701,702],{"class":82},"\"prettier --write .\"\n",[51,704,705],{"class":53,"line":102},[51,706,707],{"class":65},"  }\n",[51,709,710],{"class":53,"line":109},[51,711,99],{"class":65},[12,713,714,715,718],{},"Now run ",[48,716,717],{},"npm run prettier"," — the code gets formatted:",[12,720,721],{},[15,722],{"alt":717,"src":723},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Fprettier-setting\u002FOct-31-2023%2014-11-21(1).gif",[12,725,726],{},"Pretty convenient. Prettier handles all of that for us.",[20,728,730],{"id":729},"configuring-prettier","Configuring Prettier",[12,732,733,734,736],{},"Real projects have their own style preferences though. That's where ",[48,735,629],{}," comes in — we use it to configure Prettier.",[12,738,739],{},"Here are some common settings:",[41,741,743],{"className":655,"code":742,"language":657,"meta":46,"style":46},"{\n  \"printWidth\": 80,\n  \"tabWidth\": 2,\n  \"useTabs\": false,\n  \"semi\": true,\n  \"singleQuote\": true,\n  \"quoteProps\": \"as-needed\",\n  \"trailingComma\": \"es5\",\n  \"bracketSpacing\": true,\n  \"arrowParens\": \"always\",\n  \"endOfLine\": \"lf\"\n}\n",[48,744,745,749,761,772,784,796,807,819,831,842,854,864],{"__ignoreMap":46},[51,746,747],{"class":53,"line":54},[51,748,382],{"class":65},[51,750,751,754,756,759],{"class":53,"line":76},[51,752,753],{"class":687},"  \"printWidth\"",[51,755,699],{"class":65},[51,757,758],{"class":221},"80",[51,760,315],{"class":65},[51,762,763,766,768,770],{"class":53,"line":96},[51,764,765],{"class":687},"  \"tabWidth\"",[51,767,699],{"class":65},[51,769,350],{"class":221},[51,771,315],{"class":65},[51,773,774,777,779,782],{"class":53,"line":102},[51,775,776],{"class":687},"  \"useTabs\"",[51,778,699],{"class":65},[51,780,781],{"class":221},"false",[51,783,315],{"class":65},[51,785,786,789,791,794],{"class":53,"line":109},[51,787,788],{"class":687},"  \"semi\"",[51,790,699],{"class":65},[51,792,793],{"class":221},"true",[51,795,315],{"class":65},[51,797,798,801,803,805],{"class":53,"line":306},[51,799,800],{"class":687},"  \"singleQuote\"",[51,802,699],{"class":65},[51,804,793],{"class":221},[51,806,315],{"class":65},[51,808,809,812,814,817],{"class":53,"line":318},[51,810,811],{"class":687},"  \"quoteProps\"",[51,813,699],{"class":65},[51,815,816],{"class":82},"\"as-needed\"",[51,818,315],{"class":65},[51,820,821,824,826,829],{"class":53,"line":329},[51,822,823],{"class":687},"  \"trailingComma\"",[51,825,699],{"class":65},[51,827,828],{"class":82},"\"es5\"",[51,830,315],{"class":65},[51,832,833,836,838,840],{"class":53,"line":338},[51,834,835],{"class":687},"  \"bracketSpacing\"",[51,837,699],{"class":65},[51,839,793],{"class":221},[51,841,315],{"class":65},[51,843,844,847,849,852],{"class":53,"line":344},[51,845,846],{"class":687},"  \"arrowParens\"",[51,848,699],{"class":65},[51,850,851],{"class":82},"\"always\"",[51,853,315],{"class":65},[51,855,856,859,861],{"class":53,"line":355},[51,857,858],{"class":687},"  \"endOfLine\"",[51,860,699],{"class":65},[51,862,863],{"class":82},"\"lf\"\n",[51,865,866],{"class":53,"line":365},[51,867,99],{"class":65},[12,869,870],{},"What each one does:",[872,873,874,881,887,893,899,905,915,921,927,933],"ul",{},[875,876,877,880],"li",{},[48,878,879],{},"printWidth",": line wrap after 80 characters",[875,882,883,886],{},[48,884,885],{},"tabWidth",": indent with 2 spaces",[875,888,889,892],{},[48,890,891],{},"useTabs",": use spaces, not tabs (default)",[875,894,895,898],{},[48,896,897],{},"semi",": add semicolons at the end of statements",[875,900,901,904],{},[48,902,903],{},"singleQuote",": single quotes instead of double quotes",[875,906,907,910,911,914],{},[48,908,909],{},"quoteProps",": default ",[48,912,913],{},"'as-needed'"," — only quote object keys when they contain special chars or spaces",[875,916,917,920],{},[48,918,919],{},"trailingComma",": add trailing comma to the last item in objects and arrays (ES5-compatible)",[875,922,923,926],{},[48,924,925],{},"bracketSpacing",": spaces inside object braces",[875,928,929,932],{},[48,930,931],{},"arrowParens",": always wrap arrow function params in parens, even single ones",[875,934,935,938,939,942],{},[48,936,937],{},"endOfLine",": use ",[48,940,941],{},"lf"," line endings (default)",[604,944,945],{},[12,946,947,949,950,957],{},[609,948,611],{},"\nPrettier has way more settings than this — see ",[951,952,956],"a",{"href":953,"rel":954},"https:\u002F\u002Fprettier.io\u002Fdocs\u002Fen\u002Foptions",[955],"nofollow","Prettier Options"," for the full list.",[12,959,960,961,963,964,966],{},"Paste the above into ",[48,962,629],{}," and run ",[48,965,717],{}," again. The code should be reformatted according to those rules.",[12,968,969],{},"You should end up with something like:",[41,971,973],{"className":43,"code":972,"language":45,"meta":46,"style":46},"function hello(name) {\n  return 'Hello, ' + name + '!';\n}\n\nconst data = [\n  {\n    id: 1,\n    name: 'Ray',\n    color: 'red',\n  },\n  {\n    id: 2,\n    name: 'Ray2',\n    color: 'blue',\n  },\n  {\n    id: 3,\n    name: 'Ray3',\n    color: 'green',\n  },\n  {\n    id: 4,\n    name: 'Ray4',\n    color: 'red',\n  },\n];\n\nfunction getRedColor(data) {\n  const filterData = data.filter(function (item) {\n    return item.color === 'red';\n  });\n\n  return filterData;\n}\n\nconsole.log(hello('Ray'));\nconsole.log(getRedColor(data));\n",[48,974,975,987,1007,1011,1015,1026,1031,1040,1049,1059,1064,1068,1076,1084,1093,1097,1101,1109,1117,1126,1130,1134,1142,1150,1158,1162,1167,1171,1183,1205,1218,1223,1227,1234,1238,1243,1260],{"__ignoreMap":46},[51,976,977,979,981,983,985],{"class":53,"line":54},[51,978,58],{"class":57},[51,980,62],{"class":61},[51,982,118],{"class":65},[51,984,70],{"class":69},[51,986,150],{"class":65},[51,988,989,991,994,997,1000,1002,1005],{"class":53,"line":76},[51,990,79],{"class":57},[51,992,993],{"class":82}," 'Hello, '",[51,995,996],{"class":57}," +",[51,998,999],{"class":65}," name ",[51,1001,86],{"class":57},[51,1003,1004],{"class":82}," '!'",[51,1006,165],{"class":65},[51,1008,1009],{"class":53,"line":96},[51,1010,99],{"class":65},[51,1012,1013],{"class":53,"line":102},[51,1014,106],{"emptyLinePlaceholder":105},[51,1016,1017,1019,1021,1023],{"class":53,"line":109},[51,1018,294],{"class":57},[51,1020,297],{"class":221},[51,1022,300],{"class":57},[51,1024,1025],{"class":65}," [\n",[51,1027,1028],{"class":53,"line":306},[51,1029,1030],{"class":65},"  {\n",[51,1032,1033,1036,1038],{"class":53,"line":318},[51,1034,1035],{"class":65},"    id: ",[51,1037,312],{"class":221},[51,1039,315],{"class":65},[51,1041,1042,1045,1047]