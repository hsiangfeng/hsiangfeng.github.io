627,628],{},".prettierrc"," file:",[41,631,633],{"className":204,"code":632,"language":206,"meta":46,"style":46},"node --eval \"fs.writeFileSync('.prettierrc','{}\\n')\"\n",[48,634,635],{"__ignoreMap":46},[51,636,637,640,643],{"class":53,"line":54},[51,638,639],{"class":213},"node",[51,641,642],{"class":222}," --eval",[51,644,645],{"class":82}," \"fs.writeFileSync('.prettierrc','{}\\n')\"\n",[12,647,648,649,651],{},"Or just create ",[48,650,628],{}," in the project root with this content:",[41,653,657],{"className":654,"code":655,"language":656,"meta":46,"style":46},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{}\n","json",[48,658,659],{"__ignoreMap":46},[51,660,661],{"class":53,"line":54},[51,662,655],{"class":65},[12,664,665],{},"(Don't worry about the content — we'll fill it in later.)",[12,667,668,669,672],{},"Add a script to ",[48,670,671],{},"package.json"," so you can run Prettier easily:",[41,674,676],{"className":654,"code":675,"language":656,"meta":46,"style":46},"{\n  \"scripts\": {\n    \"prettier\": \"prettier --write .\"\n  }\n}\n",[48,677,678,682,691,702,707],{"__ignoreMap":46},[51,679,680],{"class":53,"line":54},[51,681,383],{"class":65},[51,683,684,688],{"class":53,"line":76},[51,685,687],{"class":686},"sWTrB","  \"scripts\"",[51,689,690],{"class":65},": {\n",[51,692,693,696,699],{"class":53,"line":96},[51,694,695],{"class":686},"    \"prettier\"",[51,697,698],{"class":65},": ",[51,700,701],{"class":82},"\"prettier --write .\"\n",[51,703,704],{"class":53,"line":102},[51,705,706],{"class":65},"  }\n",[51,708,709],{"class":53,"line":109},[51,710,99],{"class":65},[12,712,713,714,717],{},"Now run ",[48,715,716],{},"npm run prettier"," — the code gets formatted:",[12,719,720],{},[15,721],{"alt":716,"src":722},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Fprettier-setting\u002FOct-31-2023%2014-11-21(1).gif",[12,724,725],{},"Pretty convenient. Prettier handles all of that for us.",[20,727,729],{"id":728},"configuring-prettier","Configuring Prettier",[12,731,732,733,735],{},"Real projects have their own style preferences though. That's where ",[48,734,628],{}," comes in — we use it to configure Prettier.",[12,737,738],{},"Here are some common settings:",[41,740,742],{"className":654,"code":741,"language":656,"meta":46,"style":46},"{\n  \"printWidth\": 80,\n  \"tabWidth\": 2,\n  \"useTabs\": false,\n  \"semi\": true,\n  \"singleQuote\": true,\n  \"quoteProps\": \"as-needed\",\n  \"trailingComma\": \"es5\",\n  \"bracketSpacing\": true,\n  \"arrowParens\": \"always\",\n  \"endOfLine\": \"lf\"\n}\n",[48,743,744,748,760,771,783,795,806,818,830,841,853,863],{"__ignoreMap":46},[51,745,746],{"class":53,"line":54},[51,747,383],{"class":65},[51,749,750,753,755,758],{"class":53,"line":76},[51,751,752],{"class":686},"  \"printWidth\"",[51,754,698],{"class":65},[51,756,757],{"class":222},"80",[51,759,316],{"class":65},[51,761,762,765,767,769],{"class":53,"line":96},[51,763,764],{"class":686},"  \"tabWidth\"",[51,766,698],{"class":65},[51,768,351],{"class":222},[51,770,316],{"class":65},[51,772,773,776,778,781],{"class":53,"line":102},[51,774,775],{"class":686},"  \"useTabs\"",[51,777,698],{"class":65},[51,779,780],{"class":222},"false",[51,782,316],{"class":65},[51,784,785,788,790,793],{"class":53,"line":109},[51,786,787],{"class":686},"  \"semi\"",[51,789,698],{"class":65},[51,791,792],{"class":222},"true",[51,794,316],{"class":65},[51,796,797,800,802,804],{"class":53,"line":307},[51,798,799],{"class":686},"  \"singleQuote\"",[51,801,698],{"class":65},[51,803,792],{"class":222},[51,805,316],{"class":65},[51,807,808,811,813,816],{"class":53,"line":319},[51,809,810],{"class":686},"  \"quoteProps\"",[51,812,698],{"class":65},[51,814,815],{"class":82},"\"as-needed\"",[51,817,316],{"class":65},[51,819,820,823,825,828],{"class":53,"line":330},[51,821,822],{"class":686},"  \"trailingComma\"",[51,824,698],{"class":65},[51,826,827],{"class":82},"\"es5\"",[51,829,316],{"class":65},[51,831,832,835,837,839],{"class":53,"line":339},[51,833,834],{"class":686},"  \"bracketSpacing\"",[51,836,698],{"class":65},[51,838,792],{"class":222},[51,840,316],{"class":65},[51,842,843,846,848,851],{"class":53,"line":345},[51,844,845],{"class":686},"  \"arrowParens\"",[51,847,698],{"class":65},[51,849,850],{"class":82},"\"always\"",[51,852,316],{"class":65},[51,854,855,858,860],{"class":53,"line":356},[51,856,857],{"class":686},"  \"endOfLine\"",[51,859,698],{"class":65},[51,861,862],{"class":82},"\"lf\"\n",[51,864,865],{"class":53,"line":366},[51,866,99],{"class":65},[12,868,869],{},"What each one does:",[871,872,873,880,886,892,898,904,914,920,926,932],"ul",{},[874,875,876,879],"li",{},[48,877,878],{},"printWidth",": line wrap after 80 characters",[874,881,882,885],{},[48,883,884],{},"tabWidth",": indent with 2 spaces",[874,887,888,891],{},[48,889,890],{},"useTabs",": use spaces, not tabs (default)",[874,893,894,897],{},[48,895,896],{},"semi",": add semicolons at the end of statements",[874,899,900,903],{},[48,901,902],{},"singleQuote",": single quotes instead of double quotes",[874,905,906,909,910,913],{},[48,907,908],{},"quoteProps",": default ",[48,911,912],{},"'as-needed'"," — only quote object keys when they contain special chars or spaces",[874,915,916,919],{},[48,917,918],{},"trailingComma",": add trailing comma to the last item in objects and arrays (ES5-compatible)",[874,921,922,925],{},[48,923,924],{},"bracketSpacing",": spaces inside object braces",[874,927,928,931],{},[48,929,930],{},"arrowParens",": always wrap arrow function params in parens, even single ones",[874,933,934,937,938,941],{},[48,935,936],{},"endOfLine",": use ",[48,939,940],{},"lf"," line endings (default)",[605,943,944],{"title":607,"type":608},[12,945,946,947,954],{},"Prettier has way more settings than this — see ",[948,949,953],"a",{"href":950,"rel":951},"https:\u002F\u002Fprettier.io\u002Fdocs\u002Fen\u002Foptions",[952],"nofollow","Prettier Options"," for the full list.",[12,956,957,958,960,961,963],{},"Paste the above into ",[48,959,628],{}," and run ",[48,962,716],{}," again. The code should be reformatted according to those rules.",[12,965,966],{},"You should end up with something like:",[41,968,970],{"className":43,"code":969,"language":45,"meta":46,"style":46},"function hello(name) {\n  return 'Hello, ' + name + '!';\n}\n\nconst data = [\n  {\n    id: 1,\n    name: 'Ray',\n    color: 'red',\n  },\n  {\n    id: 2,\n    name: 'Ray2',\n    color: 'blue',\n  },\n  {\n    id: 3,\n    name: 'Ray3',\n    color: 'green',\n  },\n  {\n    id: 4,\n    name: 'Ray4',\n    color: 'red',\n  },\n];\n\nfunction getRedColor(data) {\n  const filterData = data.filter(function (item) {\n    return item.color === 'red';\n  });\n\n  return filterData;\n}\n\nconsole.log(hello('Ray'));\nconsole.log(getRedColor(data));\n",[48,971,972,984,1004,1008,1012,1023,1028,1037,1046,1056,1061,1065,1073,1081,1090,1094,1098,1106,1114,1123,1127,1131,1139,1147,1155,1159,1164,1168,1180,1202,1215,1220,1224,1231,1235,1240,1257],{"__ignoreMap":46},[51,973,974,976,978,980,982],{"class":53,"line":54},[51,975,58],{"class":57},[51,977,62],{"class":61},[51,979,118],{"class":65},[51,981,70],{"class":69},[51,983,150],{"class":65},[51,985,986,988,991,994,997,999,1002],{"class":53,"line":76},[51,987,79],{"class":57},[51,989,990],{"class":82}," 'Hello, '",[51,992,993],{"class":57}," +",[51,995,996],{"class":65}," name ",[51,998,86],{"class":57},[51,1000,1001],{"class":82}," '!'",[51,1003,165],{"class":65},[51,1005,1006],{"class":53,"line":96},[51,1007,99],{"class":65},[51,1009,1010],{"class":53,"line":102},[51,1011,106],{"emptyLinePlaceholder":105},[51,1013,1014,1016,1018,1020],{"class":53,"line":109},[51,1015,295],{"class":57},[51,1017,298],{"class":222},[51,1019,301],{"class":57},[51,1021,1022],{"class":65}," [\n",[51,1024,1025],{"class":53,"line":307},[51,1026,1027],{"class":65},"  {\n",[51,1029,1030,1033,1035],{"class":53,"line":319},[51,1031,1032],{"class":65},"    id