"className":1287,"code":1288,"language":1289,"meta":46,"style":46},"language-txt shiki shiki-themes github-dark-high-contrast","build\n","txt",[48,1291,1292],{"__ignoreMap":46},[51,1293,1294],{"class":53,"line":54},[51,1295,1288],{},[12,1297,1298,1299,1302],{},"That keeps Prettier out of the ",[48,1300,1301],{},"build"," folder.",[20,1304,1306],{"id":1305},"prettier-in-vscode","Prettier in VSCode",[12,1308,1309],{},"VSCode is the editor most of us use, so naturally we want Prettier integrated. Install this extension:",[872,1311,1312],{},[875,1313,1314],{},[951,1315,1318],{"href":1316,"rel":1317},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=esbenp.prettier-vscode",[955],"Prettier - Code formatter",[12,1320,1321],{},"Now you can hit Option + Shift + F (Mac) or Alt + Shift + F (Windows) to format the current file.",[12,1323,1324],{},"If that doesn't work, two common causes:",[1326,1327,1329],"h3",{"id":1328},"no-default-formatter-set","No default formatter set",[12,1331,1332],{},"In VSCode settings, search for \"Editor: Default Formatter\" and set it to \"Prettier - Code formatter (esbenp.prettier-vscode)\". Then right-click → Format Document, or use the shortcut.",[1326,1334,1336],{"id":1335},"language-specific-formatter-override","Language-specific formatter override",[12,1338,1339],{},"You might have previously set something like:",[41,1341,1343],{"className":655,"code":1342,"language":657,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"vscode.typescript-language-features\"\n  },\n  \u002F\u002F ... other settings\n}\n",[48,1344,1345,1349,1355,1362,1372,1376,1380],{"__ignoreMap":46},[51,1346,1347],{"class":53,"line":54},[51,1348,382],{"class":65},[51,1350,1351],{"class":53,"line":76},[51,1352,1354],{"class":1353},"sQrFR","  \u002F\u002F ... other settings\n",[51,1356,1357,1360],{"class":53,"line":96},[51,1358,1359],{"class":687},"  \"[javascript]\"",[51,1361,691],{"class":65},[51,1363,1364,1367,1369],{"class":53,"line":102},[51,1365,1366],{"class":687},"    \"editor.defaultFormatter\"",[51,1368,699],{"class":65},[51,1370,1371],{"class":82},"\"vscode.typescript-language-features\"\n",[51,1373,1374],{"class":53,"line":109},[51,1375,1063],{"class":65},[51,1377,1378],{"class":53,"line":306},[51,1379,1354],{"class":1353},[51,1381,1382],{"class":53,"line":318},[51,1383,99],{"class":65},[12,1385,1386],{},"This overrides the default formatter for JavaScript. Change it to:",[41,1388,1390],{"className":655,"code":1389,"language":657,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \u002F\u002F ... other settings\n}\n",[48,1391,1392,1396,1400,1406,1415,1419,1423],{"__ignoreMap":46},[51,1393,1394],{"class":53,"line":54},[51,1395,382],{"class":65},[51,1397,1398],{"class":53,"line":76},[51,1399,1354],{"class":1353},[51,1401,1402,1404],{"class":53,"line":96},[51,1403,1359],{"class":687},[51,1405,691],{"class":65},[51,1407,1408,1410,1412],{"class":53,"line":102},[51,1409,1366],{"class":687},[51,1411,699],{"class":65},[51,1413,1414],{"class":82},"\"esbenp.prettier-vscode\"\n",[51,1416,1417],{"class":53,"line":109},[51,1418,1063],{"class":65},[51,1420,1421],{"class":53,"line":306},[51,1422,1354],{"class":1353},[51,1424,1425],{"class":53,"line":318},[51,1426,99],{"class":65},[12,1428,1429],{},"Now the shortcut will use Prettier.",[12,1431,1432],{},"If you set both, your VSCode settings end up like this:",[41,1434,1436],{"className":655,"code":1435,"language":657,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n  \u002F\u002F ... other settings\n}\n",[48,1437,1438,1442,1446,1452,1460,1464,1476,1480],{"__ignoreMap":46},[51,1439,1440],{"class":53,"line":54},[51,1441,382],{"class":65},[51,1443,1444],{"class":53,"line":76},[51,1445,1354],{"class":1353},[51,1447,1448,1450],{"class":53,"line":96},[51,1449,1359],{"class":687},[51,1451,691],{"class":65},[51,1453,1454,1456,1458],{"class":53,"line":102},[51,1455,1366],{"class":687},[51,1457,699],{"class":65},[51,1459,1414],{"class":82},[51,1461,1462],{"class":53,"line":109},[51,1463,1063],{"class":65},[51,1465,1466,1469,1471,1474],{"class":53,"line":306},[51,1467,1468],{"class":687},"  \"editor.defaultFormatter\"",[51,1470,699],{"class":65},[51,1472,1473],{"class":82},"\"esbenp.prettier-vscode\"",[51,1475,315],{"class":65},[51,1477,1478],{"class":53,"line":318},[51,1479,1354],{"class":1353},[51,1481,1482],{"class":53,"line":329},[51,1483,99],{"class":65},[1326,1485,1487],{"id":1486},"auto-format-on-save","Auto-format on save",[12,1489,1490,1491,1494],{},"Hitting a shortcut every time is annoying, so add ",[48,1492,1493],{},"formatOnSave"," for JavaScript:",[41,1496,1498],{"className":655,"code":1497,"language":657,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n    \"editor.formatOnSave\": true\n  },\n  \u002F\u002F ... other settings\n}\n",[48,1499,1500,1504,1508,1514,1524,1534,1538,1542],{"__ignoreMap":46},[51,1501,1502],{"class":53,"line":54},[51,1503,382],{"class":65},[51,1505,1506],{"class":53,"line":76},[51,1507,1354],{"class":1353},[51,1509,1510,1512],{"class":53,"line":96},[51,1511,1359],{"class":687},[51,1513,691],{"class":65},[51,1515,1516,1518,1520,1522],{"class":53,"line":102},[51,1517,1366],{"class":687},[51,1519,699],{"class":65},[51,1521,1473],{"class":82},[51,1523,315],{"class":65},[51,1525,1526,1529,1531],{"class":53,"line":109},[51,1527,1528],{"class":687},"    \"editor.formatOnSave\"",[51,1530,699],{"class":65},[51,1532,1533],{"class":221},"true\n",[51,1535,1536],{"class":53,"line":306},[51,1537,1063],{"class":65},[51,1539,1540],{"class":53,"line":318},[51,1541,1354],{"class":1353},[51,1543,1544],{"class":53,"line":329},[51,1545,99],{"class":65},[12,1547,1548],{},"Now Command + S (Mac) or Ctrl + S (Windows) will format the file automatically on save.",[20,1550,1552],{"id":1551},"how-is-prettier-different-from-eslint","How is Prettier different from ESLint?",[12,1554,1555],{},"These two get mixed up a lot — both help unify code, but they do different jobs.",[12,1557,1558,1559,1562,1563,1566,1567,1571],{},"Prettier handles ",[609,1560,1561],{},"code style",". ESLint handles ",[609,1564,1565],{},"code quality",". Different concerns. The fun part is that ESLint ",[1568,1569,1570],"em",{},"does"," have some formatting rules, which created the long-standing Prettier-vs-ESLint conflict.",[12,1573,1574],{},"I actually wrote about this before:",[872,1576,1577],{},[875,1578,1579],{},[951,1580,1583],{"href":1581,"rel":1582},"https:\u002F\u002Fisraynotarray.com\u002Fvscode\u002F20210709\u002F4359299\u002F",[955],"Auto-fix ESLint errors in VSCode (article in Mandarin)",[12,1585,1586],{},"Back then the fix was to use a Prettier + ESLint plugin to resolve the conflict. But things have changed — ESLint announced:",[12,1588,1589],{},[951,1590,1593],{"href":1591,"rel":1592},"https:\u002F\u002Feslint.org\u002Fblog\u002F2023\u002F10\u002Fdeprecating-formatting-rules\u002F",[955],"Deprecation of formatting rules",[12,1595,1596,1597,1600,1601,1604],{},"In short: ESLint is dropping its formatting rules. So we don't need that Prettier + ESLint workaround anymore. Use ",[609,1598,1599],{},"Prettier for style",", ",[609,1602,1603],{},"ESLint for quality",".",[12,1606,1607],{},"\"For style\" vs \"for quality\" might still feel abstract, so let me give examples.",[12,1609,1610],{},"Prettier handles things like:",[872,1612,1613,1616,1619,1622,1625,1628,1631,1634,1637],{},[875,1614,1615],{},"Indentation (tabs vs spaces)",[875,1617,1618],{},"Line wrapping (after how many chars)",[875,1620,1621],{},"How many spaces per indent",[875,1623,1624],{},"Single vs double quotes",[875,1626,1627],{},"Trailing commas (after last item in object\u002Farray)",[875,1629,1630],{},"Semicolons (at end of statements)",[875,1632,1633],{},"Arrow function parens (around single-param arrows)",[875,1635,1636],{},"Line endings (lf vs crlf)",[875,1638,1639],{},"...etc.",[12,1641,1642],{},"ESLint handles:",[872,1644,1645,1648,1654,1657,1665,1668,1671],{},[875,1646,1647],{},"Unused variables\u002Ffunctions",[875,1649,1650,1651,1653],{},"Variables declared but never reassigned (should be ",[48,1652,294],{},")",[875,1655,1656],{},"Use of deprecated APIs",[875,1658,1659,1662,1663],{},[48,1660,1661],{},"=="," instead of strict ",[48,1664,513],{},[875,1666,1667],{},"Naming conventions (camelCase vs snake_case)",[875,1669,1670],{},"Avoiding global variables",[875,1672,1639],{},[12,1674,1675],{},"Hope that clarifies the difference.",[12,1677,1678],{},"And here's my example repo if you want to play with it:",[872,1680,1681],{},[875,1682,1683],{},[951,1684,1687],{"href":1685,"rel":1686},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fprettier-example",[955],"Prettier Example",[604,1689,1690],{},[12,1691,1692,1694,1697,1698,1700],{},[609,1693,611],{},[48,1695,1696],{},"index.bak.js"," is the unformatted version, ",[48,1699,249],{}," is the formatted version.",[1702,1703,1704],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":46,"searchDepth":76,"depth":76,"links":1706},[1707,1708,1709,1710,1711,1712,1717],{"id":22,"depth":76,"text":23},{"id":29,"depth":76,"text":30},{"id":197,"depth":76,"text":198},{"id":729,"depth":76,"text":730},{"id":1276,"depth":76,"text":1277},{"id":1305,"depth":76,"text":1306,"children":1713},[1714,1715,1716],{"id":1328,"depth":96,"text":1329},{"id":1335,"depth":96,"text":1336},{"id":1486,"depth":96,"text":1487},{"id":1551,"depth":76,"text":1552},"JavaScript","2023-10-31 10:33:52","Prettier is one of those frontend tools you have to know. Even if you're not using it today, you'll end up using it eventually — so why not start now? This post walks through installing Prettier, configuring it, setting it up in VSCode, and how it differs from ESLint.","md","en",{},"\u002Fen\u002Fjavascript\u002Fprettier-tutorial-vscode-setup","5",{"title":6,"description":1720},false,"en\u002FJavaScript\u002Fprettier-tutorial-vscode-setup",[1718,17,1730,1731],"ESLint","VSCode",null,"2026-05-12 09:00:00","\u002Fen\u002Fjavascript\u002F2023\u002F10\u002F31\u002Fprettier-tutorial-vscode-setup\u002F","-gEDtMLr1rCGpEjnM2Rz1uV8ywof8brZQ66lriHLdwo",{"newer":1737,"older":1741},{"url":1738,"title":1739,"date":1740},"\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F","Nuxt 3.8.0 useFetch Error Cache Issue","2023-11-04 00:00:19",{"url":1742,"title":1743,"date":1744},"\u002Fen\u002Fmisc\u002F2023\u002F10\u002F29\u002Fservice-workers-stale-cache-blog-not-updating\u002F","Why My Blog Wouldn't Update: A Service Workers Stale-Cache Story","2023-10-29 00:12:47",[1746,1751,1756],{"url":1747,"title":1748,"d