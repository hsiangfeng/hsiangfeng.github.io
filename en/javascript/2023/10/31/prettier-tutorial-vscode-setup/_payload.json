ample. Add a ",[48,1279,1280],{},".prettierignore"," in the root:",[41,1283,1287],{"className":1284,"code":1285,"language":1286,"meta":46,"style":46},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","build\n","txt",[48,1288,1289],{"__ignoreMap":46},[51,1290,1291],{"class":53,"line":54},[51,1292,1285],{},[12,1294,1295,1296,1299],{},"That keeps Prettier out of the ",[48,1297,1298],{},"build"," folder.",[20,1301,1303],{"id":1302},"prettier-in-vscode","Prettier in VSCode",[12,1305,1306],{},"VSCode is the editor most of us use, so naturally we want Prettier integrated. Install this extension:",[871,1308,1309],{},[874,1310,1311],{},[948,1312,1315],{"href":1313,"rel":1314},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=esbenp.prettier-vscode",[952],"Prettier - Code formatter",[12,1317,1318],{},"Now you can hit Option + Shift + F (Mac) or Alt + Shift + F (Windows) to format the current file.",[12,1320,1321],{},"If that doesn't work, two common causes:",[1323,1324,1326],"h3",{"id":1325},"no-default-formatter-set","No default formatter set",[12,1328,1329],{},"In VSCode settings, search for \"Editor: Default Formatter\" and set it to \"Prettier - Code formatter (esbenp.prettier-vscode)\". Then right-click → Format Document, or use the shortcut.",[1323,1331,1333],{"id":1332},"language-specific-formatter-override","Language-specific formatter override",[12,1335,1336],{},"You might have previously set something like:",[41,1338,1340],{"className":654,"code":1339,"language":656,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"vscode.typescript-language-features\"\n  },\n  \u002F\u002F ... other settings\n}\n",[48,1341,1342,1346,1352,1359,1369,1373,1377],{"__ignoreMap":46},[51,1343,1344],{"class":53,"line":54},[51,1345,383],{"class":65},[51,1347,1348],{"class":53,"line":76},[51,1349,1351],{"class":1350},"sGBqm","  \u002F\u002F ... other settings\n",[51,1353,1354,1357],{"class":53,"line":96},[51,1355,1356],{"class":686},"  \"[javascript]\"",[51,1358,690],{"class":65},[51,1360,1361,1364,1366],{"class":53,"line":102},[51,1362,1363],{"class":686},"    \"editor.defaultFormatter\"",[51,1365,698],{"class":65},[51,1367,1368],{"class":82},"\"vscode.typescript-language-features\"\n",[51,1370,1371],{"class":53,"line":109},[51,1372,1060],{"class":65},[51,1374,1375],{"class":53,"line":307},[51,1376,1351],{"class":1350},[51,1378,1379],{"class":53,"line":319},[51,1380,99],{"class":65},[12,1382,1383],{},"This overrides the default formatter for JavaScript. Change it to:",[41,1385,1387],{"className":654,"code":1386,"language":656,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \u002F\u002F ... other settings\n}\n",[48,1388,1389,1393,1397,1403,1412,1416,1420],{"__ignoreMap":46},[51,1390,1391],{"class":53,"line":54},[51,1392,383],{"class":65},[51,1394,1395],{"class":53,"line":76},[51,1396,1351],{"class":1350},[51,1398,1399,1401],{"class":53,"line":96},[51,1400,1356],{"class":686},[51,1402,690],{"class":65},[51,1404,1405,1407,1409],{"class":53,"line":102},[51,1406,1363],{"class":686},[51,1408,698],{"class":65},[51,1410,1411],{"class":82},"\"esbenp.prettier-vscode\"\n",[51,1413,1414],{"class":53,"line":109},[51,1415,1060],{"class":65},[51,1417,1418],{"class":53,"line":307},[51,1419,1351],{"class":1350},[51,1421,1422],{"class":53,"line":319},[51,1423,99],{"class":65},[12,1425,1426],{},"Now the shortcut will use Prettier.",[12,1428,1429],{},"If you set both, your VSCode settings end up like this:",[41,1431,1433],{"className":654,"code":1432,"language":656,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n  \u002F\u002F ... other settings\n}\n",[48,1434,1435,1439,1443,1449,1457,1461,1473,1477],{"__ignoreMap":46},[51,1436,1437],{"class":53,"line":54},[51,1438,383],{"class":65},[51,1440,1441],{"class":53,"line":76},[51,1442,1351],{"class":1350},[51,1444,1445,1447],{"class":53,"line":96},[51,1446,1356],{"class":686},[51,1448,690],{"class":65},[51,1450,1451,1453,1455],{"class":53,"line":102},[51,1452,1363],{"class":686},[51,1454,698],{"class":65},[51,1456,1411],{"class":82},[51,1458,1459],{"class":53,"line":109},[51,1460,1060],{"class":65},[51,1462,1463,1466,1468,1471],{"class":53,"line":307},[51,1464,1465],{"class":686},"  \"editor.defaultFormatter\"",[51,1467,698],{"class":65},[51,1469,1470],{"class":82},"\"esbenp.prettier-vscode\"",[51,1472,316],{"class":65},[51,1474,1475],{"class":53,"line":319},[51,1476,1351],{"class":1350},[51,1478,1479],{"class":53,"line":330},[51,1480,99],{"class":65},[1323,1482,1484],{"id":1483},"auto-format-on-save","Auto-format on save",[12,1486,1487,1488,1491],{},"Hitting a shortcut every time is annoying, so add ",[48,1489,1490],{},"formatOnSave"," for JavaScript:",[41,1493,1495],{"className":654,"code":1494,"language":656,"meta":46,"style":46},"{\n  \u002F\u002F ... other settings\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n    \"editor.formatOnSave\": true\n  },\n  \u002F\u002F ... other settings\n}\n",[48,1496,1497,1501,1505,1511,1521,1531,1535,1539],{"__ignoreMap":46},[51,1498,1499],{"class":53,"line":54},[51,1500,383],{"class":65},[51,1502,1503],{"class":53,"line":76},[51,1504,1351],{"class":1350},[51,1506,1507,1509],{"class":53,"line":96},[51,1508,1356],{"class":686},[51,1510,690],{"class":65},[51,1512,1513,1515,1517,1519],{"class":53,"line":102},[51,1514,1363],{"class":686},[51,1516,698],{"class":65},[51,1518,1470],{"class":82},[51,1520,316],{"class":65},[51,1522,1523,1526,1528],{"class":53,"line":109},[51,1524,1525],{"class":686},"    \"editor.formatOnSave\"",[51,1527,698],{"class":65},[51,1529,1530],{"class":222},"true\n",[51,1532,1533],{"class":53,"line":307},[51,1534,1060],{"class":65},[51,1536,1537],{"class":53,"line":319},[51,1538,1351],{"class":1350},[51,1540,1541],{"class":53,"line":330},[51,1542,99],{"class":65},[12,1544,1545],{},"Now Command + S (Mac) or Ctrl + S (Windows) will format the file automatically on save.",[20,1547,1549],{"id":1548},"how-is-prettier-different-from-eslint","How is Prettier different from ESLint?",[12,1551,1552],{},"These two get mixed up a lot — both help unify code, but they do different jobs.",[12,1554,1555,1556,1560,1561,1564,1565,1569],{},"Prettier handles ",[1557,1558,1559],"strong",{},"code style",". ESLint handles ",[1557,1562,1563],{},"code quality",". Different concerns. The fun part is that ESLint ",[1566,1567,1568],"em",{},"does"," have some formatting rules, which created the long-standing Prettier-vs-ESLint conflict.",[12,1571,1572],{},"I actually wrote about this before:",[871,1574,1575],{},[874,1576,1577],{},[948,1578,1581],{"href":1579,"rel":1580},"https:\u002F\u002Fisraynotarray.com\u002Fvscode\u002F20210709\u002F4359299\u002F",[952],"Auto-fix ESLint errors in VSCode (article in Mandarin)",[12,1583,1584],{},"Back then the fix was to use a Prettier + ESLint plugin to resolve the conflict. But things have changed — ESLint announced:",[12,1586,1587],{},[948,1588,1591],{"href":1589,"rel":1590},"https:\u002F\u002Feslint.org\u002Fblog\u002F2023\u002F10\u002Fdeprecating-formatting-rules\u002F",[952],"Deprecation of formatting rules",[12,1593,1594,1595,1598,1599,1602],{},"In short: ESLint is dropping its formatting rules. So we don't need that Prettier + ESLint workaround anymore. Use ",[1557,1596,1597],{},"Prettier for style",", ",[1557,1600,1601],{},"ESLint for quality",".",[12,1604,1605],{},"\"For style\" vs \"for quality\" might still feel abstract, so let me give examples.",[12,1607,1608],{},"Prettier handles things like:",[871,1610,1611,1614,1617,1620,1623,1626,1629,1632,1635],{},[874,1612,1613],{},"Indentation (tabs vs spaces)",[874,1615,1616],{},"Line wrapping (after how many chars)",[874,1618,1619],{},"How many spaces per indent",[874,1621,1622],{},"Single vs double quotes",[874,1624,1625],{},"Trailing commas (after last item in object\u002Farray)",[874,1627,1628],{},"Semicolons (at end of statements)",[874,1630,1631],{},"Arrow function parens (around single-param arrows)",[874,1633,1634],{},"Line endings (lf vs crlf)",[874,1636,1637],{},"...etc.",[12,1639,1640],{},"ESLint handles:",[871,1642,1643,1646,1652,1655,1663,1666,1669],{},[874,1644,1645],{},"Unused variables\u002Ffunctions",[874,1647,1648,1649,1651],{},"Variables declared but never reassigned (should be ",[48,1650,295],{},")",[874,1653,1654],{},"Use of deprecated APIs",[874,1656,1657,1660,1661],{},[48,1658,1659],{},"=="," instead of strict ",[48,1662,514],{},[874,1664,1665],{},"Naming conventions (camelCase vs snake_case)",[874,1667,1668],{},"Avoiding global variables",[874,1670,1637],{},[12,1672,1673],{},"Hope that clarifies the difference.",[12,1675,1676],{},"And here's my example repo if you want to play with it:",[871,1678,1679],{},[874,1680,1681],{},[948,1682,1685],{"href":1683,"rel":1684},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fprettier-example",[952],"Prettier Example",[605,1687,1688],{"title":607,"type":608},[12,1689,1690,1693,1694,1696],{},[48,1691,1692],{},"index.bak.js"," is the unformatted version, ",[48,1695,250],{}," is the formatted version.",[1698,1699,1700],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syBk-, html code.shiki .syBk-{--shiki-light:#E36209;--shiki-default:#E36209;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}h