[{"data":1,"prerenderedAt":1085},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F":1060,"related:\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F":1069},"\u002Fjavascript\u002F20231120\u002F805843771\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1043,"date":1044,"description":1045,"extension":1046,"lang":1047,"meta":1048,"navigation":449,"path":1049,"readingMinutes":1050,"seo":1051,"standalone":1052,"stem":1053,"tags":1054,"tldr":1057,"updated":1044,"url":1058,"__hash__":1059},"content\u002Fen\u002FJavaScript\u002Ffunctional-programming-javascript-currying.md","A Friendly Look at Functional Programming in JavaScript: Currying","1001583803",{"type":9,"value":10,"toc":1038},"minimark",[11,18,23,26,30,33,36,42,45,49,52,123,130,136,143,170,188,191,194,199,205,283,286,289,318,321,374,377,520,529,532,648,651,700,703,717,849,852,1009,1016,1031,1034],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Ffp-currying\u002Fisray_notarray_Functional_Programming_--stylize_750_--v_5.2_5df82f93-316b-4019-b996-f4b4b22218dd.png",[19,20,22],"h2",{"id":21},"intro","Intro",[12,24,25],{},"Functional Programming has this one really special idea I want to talk about — it's called Currying. So that's what this whole post is about.",[19,27,29],{"id":28},"whats-currying","What's Currying?",[12,31,32],{},"First off, the Chinese name for Currying has a few different translations floating around, but they all point at the same thing — this one concept in Functional Programming called Currying.",[12,34,35],{},"So what's actually special about it? If I had to sum it up in a single sentence, it'd be this:",[37,38,39],"blockquote",{},[12,40,41],{},"Currying is the process of taking a function that takes multiple arguments and turning it into a chain of functions that each take one argument at a time, eventually returning the result.",[12,43,44],{},"Some people see that and assume Currying must use some new syntax. But honestly, it doesn't — it just makes good use of a JavaScript feature you already know: closures.",[19,46,48],{"id":47},"building-currying","Building Currying",[12,50,51],{},"Alright, let's actually build it. Start with this bit of code:",[53,54,59],"pre",{"className":55,"code":56,"language":57,"meta":58,"style":58},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","function add(a, b, c) {\n  return a + b + c;\n}\n","js","",[60,61,62,97,117],"code",{"__ignoreMap":58},[63,64,67,71,75,79,83,86,89,91,94],"span",{"class":65,"line":66},"line",1,[63,68,70],{"class":69},"sOudu","function",[63,72,74],{"class":73},"scAaK"," add",[63,76,78],{"class":77},"s8XSl","(",[63,80,82],{"class":81},"syBk-","a",[63,84,85],{"class":77},", ",[63,87,88],{"class":81},"b",[63,90,85],{"class":77},[63,92,93],{"class":81},"c",[63,95,96],{"class":77},") {\n",[63,98,100,103,106,109,112,114],{"class":65,"line":99},2,[63,101,102],{"class":69},"  return",[63,104,105],{"class":77}," a ",[63,107,108],{"class":69},"+",[63,110,111],{"class":77}," b ",[63,113,108],{"class":69},[63,115,116],{"class":77}," c;\n",[63,118,120],{"class":65,"line":119},3,[63,121,122],{"class":77},"}\n",[12,124,125,126,129],{},"So we've got a function called ",[60,127,128],{},"add"," that takes three arguments and returns the sum of all three.",[12,131,132],{},[15,133],{"alt":134,"src":135},"Function Add","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Ffp-currying\u002F%E6%88%AA%E5%9C%96%202023-11-20%2021.15.17.png",[12,137,138,139,142],{},"Looks fine, right? But here's the thing — if you accidentally leave out an argument when you call it, you get ",[60,140,141],{},"NaN",". For example:",[53,144,146],{"className":55,"code":145,"language":57,"meta":58,"style":58},"add(1, 2); \u002F\u002F NaN\n",[60,147,148],{"__ignoreMap":58},[63,149,150,152,154,158,160,163,166],{"class":65,"line":66},[63,151,128],{"class":73},[63,153,78],{"class":77},[63,155,157],{"class":156},"stw71","1",[63,159,85],{"class":77},[63,161,162],{"class":156},"2",[63,164,165],{"class":77},"); ",[63,167,169],{"class":168},"sGBqm","\u002F\u002F NaN\n",[171,172,175],"callout",{"title":173,"type":174},"Note","note",[12,176,177,178,180,181,184,185,187],{},"The ",[60,179,141],{}," here comes from ",[60,182,183],{},"1 + 2 + undefined",", which evaluates to ",[60,186,141],{},".",[12,189,190],{},"Now you might be thinking...",[12,192,193],{},"\"Can't I just give the function default parameters?\"",[12,195,196,197,187],{},"Sure, that's one way to deal with it. But then you have to know up front how many arguments your function takes, and every time you call it you've got to pass all of them. Which means there's always a chance you miss one and end up back at ",[60,198,141],{},[12,200,201,202,204],{},"This is where Currying comes in. We can rewrite that ",[60,203,128],{}," function like this:",[53,206,208],{"className":55,"code":207,"language":57,"meta":58,"style":58},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n",[60,209,210,223,237,250,266,272,278],{"__ignoreMap":58},[63,211,212,214,217,219,221],{"class":65,"line":66},[63,213,70],{"class":69},[63,215,216],{"class":73}," curryAdd",[63,218,78],{"class":77},[63,220,82],{"class":81},[63,222,96],{"class":77},[63,224,225,227,230,233,235],{"class":65,"line":99},[63,226,102],{"class":69},[63,228,229],{"class":69}," function",[63,231,232],{"class":77}," (",[63,234,88],{"class":81},[63,236,96],{"class":77},[63,238,239,242,244,246,248],{"class":65,"line":119},[63,240,241],{"class":69},"    return",[63,243,229],{"class":69},[63,245,232],{"class":77},[63,247,93],{"class":81},[63,249,96],{"class":77},[63,251,253,256,258,260,262,264],{"class":65,"line":252},4,[63,254,255],{"class":69},"      return",[63,257,105],{"class":77},[63,259,108],{"class":69},[63,261,111],{"class":77},[63,263,108],{"class":69},[63,265,116],{"class":77},[63,267,269],{"class":65,"line":268},5,[63,270,271],{"class":77},"    };\n",[63,273,275],{"class":65,"line":274},6,[63,276,277],{"class":77},"  };\n",[63,279,281],{"class":65,"line":280},7,[63,282,122],{"class":77},[12,284,285],{},"Pretty neat, right? We took a function that took three arguments and turned it into three functions that each take one argument, then return the result at the end.",[12,287,288],{},"To use it, you just write:",[53,290,292],{"className":55,"code":291,"language":57,"meta":58,"style":58},"curryAdd(1)(2)(3); \u002F\u002F 6\n",[60,293,294],{"__ignoreMap":58},[63,295,296,299,301,303,306,308,310,313,315],{"class":65,"line":66},[63,297,298],{"class":73},"curryAdd",[63,300,78],{"class":77},[63,302,157],{"class":156},[63,304,305],{"class":77},")(",[63,307,162],{"class":156},[63,309,305],{"class":77},[63,311,312],{"class":156},"3",[63,314,165],{"class":77},[63,316,317],{"class":168},"\u002F\u002F 6\n",[12,319,320],{},"That's a little hard to parse at first, so let's walk through what's happening:",[322,323,324,341,354],"ul",{},[325,326,327,328,331,332,334,335,337,338],"li",{},"First call, ",[60,329,330],{},"curryAdd(1)"," — this returns a function with ",[60,333,82],{}," set to ",[60,336,157],{},", i.e. ",[60,339,340],{},"function (b) { return function (c) { return 1 + b + c; }; }",[325,342,343,344,331,347,334,349,337,351],{},"Second call, ",[60,345,346],{},"curryAdd(1)(2)",[60,348,88],{},[60,350,162],{},[60,352,353],{},"function (c) { return 1 + 2 + c; }",[325,355,356,357,360,361,363,364,366,367,370,371],{},"Third call, ",[60,358,359],{},"curryAdd(1)(2)(3)"," — this sets ",[60,362,93],{}," to ",[60,365,312],{},", so we get ",[60,368,369],{},"1 + 2 + 3",", and it finally returns ",[60,372,373],{},"6",[12,375,376],{},"Not really feeling the benefit yet, huh? Remember I said Currying leans on closures. Because of that, we can hang onto the state of those variables — which means we can set up what are basically \"preset arguments.\" So you can write something like:",[53,378,380],{"className":55,"code":379,"language":57,"meta":58,"style":58},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n\nconst addOne = curryAdd(1);\nconst addTwo = addOne(2);\n\n\u002F\u002F ...a thousand lines later\n\naddTwo(3); \u002F\u002F 6\n",[60,381,382,394,406,418,432,436,440,444,451,472,490,495,501,506],{"__ignoreMap":58},[63,383,384,386,388,390,392],{"class":65,"line":66},[63,385,70],{"class":69},[63,387,216],{"class":73},[63,389,78],{"class":77},[63,391,82],{"class":81},[63,393,96],{"class":77},[63,395,396,398,400,402,404],{"class":65,"line":99},[63,397,102],{"class":69},[63,399,229],{"class":69},[63,401,232],{"class":77},[63,403,88],{"class":81},[63,405,96],{"class":77},[63,407,408,410,412,414,416],{"class":65,"line":119},[63,409,241],{"class":69},[63,411,229],{"class":69},[63,413,232],{"class":77},[63,415,93],{"class":81},[63,417,96],{"class":77},[63,419,420,422,424,426,428,430],{"class":65,"line":252},[63,421,255],{"class":69},[63,423,105],{"class":77},[63,425,108],{"class":69},[63,427,111],{"class":77},[63,429,108],{"class":69},[63,431,116],{"class":77},[63,433,434],{"class":65,"line":268},[63,435,271],{"class":77},[63,437,438],{"class":65,"line":274},[63,439,277],{"class":77},[63,441,442],{"class":65,"line":280},[63,443,122],{"class":77},[63,445,447],{"class":65,"line":446},8,[63,448,450],{"emptyLinePlaceholder":449},true,"\n",[63,452,454,457,460,463,465,467,469],{"class":65,"line":453},9,[63,455,456],{"class":69},"const",[63,458,459],{"class":156}," addOne",[63,461,462],{"class":69}," =",[63,464,216],{"class":73},[63,466,78],{"class":77},[63,468,157],{"class":156},[63,470,471],{"class":77},");\n",[63,473,475,477,480,482,484,486,488],{"class":65,"line":474},10,[63,476,456],{"class":69},[63,478,479],{"class":156}," addTwo",[63,481,462],{"class":69},[63,483,459],{"class":73},[63,485,78],{"class":77},[63,487,162],{"class":156},[63,489,471],{"class":77},[63,491,493],{"class":65,"line":492},11,[63,494,450],{"emptyLinePlaceholder":449},[63,496,498],{"class":65,"line":497},12,[63,499,500],{"class":168},"\u002F\u002F ...a thousand lines later\n",[63,502,504],{"class":65,"line":503},13,[63,505,450],{"emptyLinePlaceholder":449},[63,507,509,512,514,516,518],{"class":65,"line":508},14,[63,510,511],{"class":73},"addTwo",[63,513,78],{"class":77},[63,515,312],{"class":156},[63,517,165],{"class":77},[63,519,317],{"class":168},[12,521,522,523,525,526,528],{},"Notice that ",[60,524,82],{}," and ",[60,527,88],{}," are already locked in. So you don't have to worry about missing arguments anymore — you just focus on passing the last one.",[12,530,531],{},"You don't have to split it up exactly like that, of course. You could also lock in two arguments at once:",[53,533,535],{"className":55,"code":534,"language":57,"meta":58,"style":58},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n\nconst addOne = curryAdd(1)(2);\n\n\u002F\u002F ...a thousand lines later\n\naddOne(3); \u002F\u002F 6\n",[60,536,537,549,561,573,587,591,595,599,603,623,627,631,635],{"__ignoreMap":58},[63,538,539,541,543,545,547],{"class":65,"line":66},[63,540,70],{"class":69},[63,542,216],{"class":73},[63,544,78],{"class":77},[63,546,82],{"class":81},[63,548,96],{"class":77},[63,550,551,553,555,557,559],{"class":65,"line":99},[63,552,102],{"class":69},[63,554,229],{"class":69},[63,556,232],{"class":77},[63,558,88],{"class":81},[63,560,96],{"class":77},[63,562,563,565,567,569,571],{"class":65,"line":119},[63,564,241],{"class":69},[63,566,229],{"class":69},[63,568,232],{"class":77},[63,570,93],{"class":81},[63,572,96],{"class":77},[63,574,575,577,579,581,583,585],{"class":65,"line":252},[63,576,255],{"class":69},[63,578,105],{"class":77},[63,580,108],{"class":69},[63,582,111],{"class":77},[63,584,108],{"class":69},[63,586,116],{"class":77},[63,588,589],{"class":65,"line":268},[63,590,271],{"class":77},[63,592,593],{"class":65,"line":274},[63,594,277],{"class":77},[63,596,597],{"class":65,"line":280},[63,598,122],{"class":77},[63,600,601],{"class":65,"line":446},[63,602,450],{"emptyLinePlaceholder":449},[63,604,605,607,609,611,613,615,617,619,621],{"class":65,"line":453},[63,606,456],{"class":69},[63,608,459],{"class":156},[63,610,462],{"class":69},[63,612,216],{"class":73},[63,614,78],{"class":77},[63,616,157],{"class":156},[63,618,305],{"class":77},[63,620,162],{"class":156},[63,622,471],{"class":77},[63,624,625],{"class":65,"line":474},[63,626,450],{"emptyLinePlaceholder":449},[63,628,629],{"class":65,"line":492},[63,630,500],{"class":168},[63,632,633],{"class":65,"line":497},[63,634,450],{"emptyLinePlaceholder":449},[63,636,637,640,642,644,646],{"class":65,"line":503},[63,638,639],{"class":73},"addOne",[63,641,78],{"class":77},[63,643,312],{"class":156},[63,645,165],{"class":77},[63,647,317],{"class":168},[12,649,650],{},"That's the classic intro-to-Currying explanation. But there's more than one way to write it. For instance, we can use ES6 arrow functions to do Currying, like this:",[53,652,654],{"className":55,"code":653,"language":57,"meta":58,"style":58},"const curryAdd = (a) => (b) => (c) => a + b + c;\n",[60,655,656],{"__ignoreMap":58},[63,657,658,660,662,664,666,668,671,674,676,678,680,682,684,686,688,690,692,694,696,698],{"class":65,"line":66},[63,659,456],{"class":69},[63,661,216],{"class":73},[63,663,462],{"class":69},[63,665,232],{"class":77},[63,667,82],{"class":81},[63,669,670],{"class":77},") ",[63,672,673],{"class":69},"=>",[63,675,232],{"class":77},[63,677,88],{"class":81},[63,679,670],{"class":77},[63,681,673],{"class":69},[63,683,232],{"class":77},[63,685,93],{"class":81},[63,687,670],{"class":77},[63,689,673],{"class":69},[63,691,105],{"class":77},[63,693,108],{"class":69},[63,695,111],{"class":77},[63,697,108],{"class":69},[63,699,116],{"class":77},[12,701,702],{},"(Mysterious voice from offstage: the first time a beginner sees this line they usually go \"what on earth,\" but it's exactly the same as the version above — just written more compactly.)",[12,704,705,706,525,709,712,713,716],{},"So where else might you use Currying? Say we've got two objects, ",[60,707,708],{},"user",[60,710,711],{},"product",", and they both have an ",[60,714,715],{},"id"," property. We could write:",[53,718,720],{"className":55,"code":719,"language":57,"meta":58,"style":58},"const user = {\n  id: 1,\n  name: 'Ray',\n};\n\nconst product = {\n  id: 1,\n  name: 'Apple',\n};\n\nconst isSameId = (a) => (b) => a.id === b.id;\n\nisSameId(user)(product); \u002F\u002F true\n",[60,721,722,734,744,755,760,764,775,783,792,796,800,834,838],{"__ignoreMap":58},[63,723,724,726,729,731],{"class":65,"line":66},[63,725,456],{"class":69},[63,727,728],{"class":156}," user",[63,730,462],{"class":69},[63,732,733],{"class":77}," {\n",[63,735,736,739,741],{"class":65,"line":99},[63,737,738],{"class":77},"  id: ",[63,740,157],{"class":156},[63,742,743],{"class":77},",\n",[63,745,746,749,753],{"class":65,"line":119},[63,747,748],{"class":77},"  name: ",[63,750,752],{"class":751},"sWayO","'Ray'",[63,754,743],{"class":77},[63,756,757],{"class":65,"line":252},[63,758,759],{"class":77},"};\n",[63,761,762],{"class":65,"line":268},[63,763,450],{"emptyLinePlaceholder":449},[63,765,766,768,771,773],{"class":65,"line":274},[63,767,456],{"class":69},[63,769,770],{"class":156}," product",[63,772,462],{"class":69},[63,774,733],{"class":77},[63,776,777,779,781],{"class":65,"line":280},[63,778,738],{"class":77},[63,780,157],{"class":156},[63,782,743],{"class":77},[63,784,785,787,790],{"class":65,"line":446},[63,786,748],{"class":77},[63,788,789],{"class":751},"'Apple'",[63,791,743],{"class":77},[63,793,794],{"class":65,"line":453},[63,795,759],{"class":77},[63,797,798],{"class":65,"line":474},[63,799,450],{"emptyLinePlaceholder":449},[63,801,802,804,807,809,811,813,815,817,819,821,823,825,828,831],{"class":65,"line":492},[63,803,456],{"class":69},[63,805,806],{"class":73}," isSameId",[63,808,462],{"class":69},[63,810,232],{"class":77},[63,812,82],{"class":81},[63,814,670],{"class":77},[63,816,673],{"class":69},[63,818,232],{"class":77},[63,820,88],{"class":81},[63,822,670],{"class":77},[63,824,673],{"class":69},[63,826,827],{"class":77}," a.id ",[63,829,830],{"class":69},"===",[63,832,833],{"class":77}," b.id;\n",[63,835,836],{"class":65,"line":497},[63,837,450],{"emptyLinePlaceholder":449},[63,839,840,843,846],{"class":65,"line":503},[63,841,842],{"class":73},"isSameId",[63,844,845],{"class":77},"(user)(product); ",[63,847,848],{"class":168},"\u002F\u002F true\n",[12,850,851],{},"Or you could use it to pull values out of objects:",[53,853,855],{"className":55,"code":854,"language":57,"meta":58,"style":58},"const data = {\n  user: {\n    id: 1,\n    name: 'Ray',\n  },\n  product: {\n    id: 1,\n    name: 'Apple',\n  },\n};\n\nconst get = (key) => (obj) => obj[key];\n\nconst getUserName = get('name');\n\ngetUserName(data.user); \u002F\u002F Ray\ngetUserName(data.product); \u002F\u002F Apple\n",[60,856,857,868,873,882,891,896,901,909,917,921,925,929,959,963,981,986,998],{"__ignoreMap":58},[63,858,859,861,864,866],{"class":65,"line":66},[63,860,456],{"class":69},[63,862,863],{"class":156}," data",[63,865,462],{"class":69},[63,867,733],{"class":77},[63,869,870],{"class":65,"line":99},[63,871,872],{"class":77},"  user: {\n",[63,874,875,878,880],{"class":65,"line":119},[63,876,877],{"class":77},"    id: ",[63,879,157],{"class":156},[63,881,743],{"class":77},[63,883,884,