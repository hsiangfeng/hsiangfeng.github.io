,595,597,599,602],{"class":40,"line":596},38,[38,598,174],{"class":118},[38,600,601],{"class":177},"template",[38,603,185],{"class":118},[38,605,607,610,613,616,619,622],{"class":40,"line":606},39,[38,608,609],{"class":118},"  \u003C",[38,611,612],{"class":177},"div",[38,614,615],{"class":181}," class",[38,617,618],{"class":114},"=",[38,620,621],{"class":48},"\"globalEditor\"",[38,623,185],{"class":118},[38,625,627,630],{"class":40,"line":626},40,[38,628,629],{"class":118},"    \u003C",[38,631,633],{"class":632},"sWTrB","QuillEditor\n",[38,635,637,640,642],{"class":40,"line":636},41,[38,638,639],{"class":181},"      ref",[38,641,618],{"class":114},[38,643,644],{"class":48},"\"editorRef\"\n",[38,646,648],{"class":40,"line":647},42,[38,649,651],{"class":650},"s37k-","      :options=\"options\"\n",[38,653,655,658,660],{"class":40,"line":654},43,[38,656,657],{"class":181},"      content-type",[38,659,618],{"class":114},[38,661,662],{"class":48},"\"html\"\n",[38,664,666],{"class":40,"line":665},44,[38,667,668],{"class":118},"    \u002F>\n",[38,670,672,675,677],{"class":40,"line":671},45,[38,673,674],{"class":118},"  \u003C\u002F",[38,676,612],{"class":177},[38,678,185],{"class":118},[38,680,682,685,687],{"class":40,"line":681},46,[38,683,684],{"class":118},"\u003C\u002F",[38,686,601],{"class":177},[38,688,185],{"class":118},[17,690,691,692,694,695,698,699,701],{},"So why go with ",[35,693,161],{},"? I did try the way VueQuill wraps things officially, but I found that extending it gets pretty hard (like pulling in ",[35,696,697],{},"highlight",", for example), so I switched to the ",[35,700,161],{}," approach instead.",[17,703,704,705,708,709,711],{},"Now let me circle back and explain why \"",[35,706,707],{},"quill Overwriting modules\u002Fxxx with class...","\" keeps showing up in the first place. We know that with ",[35,710,71],{}," and route switching, the component itself gets destroyed. But Quill's modules are registered on Quill as a whole — they don't get cleared automatically just because the component was destroyed. So when you create the component again, it tries to register the same module again, and that's where the warning comes from.",[17,713,714],{},"So all you need to do is check whether it's already been registered before registering, and skip it if it has. That clears the problem right up.",[12,716,718],{"id":717},"wrapping-up","Wrapping up",[17,720,721],{},"For a moment there I suspected VueQuill was the culprit, but it turned out it wasn't — so I figured I'd jot this down.",[723,724,725],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark