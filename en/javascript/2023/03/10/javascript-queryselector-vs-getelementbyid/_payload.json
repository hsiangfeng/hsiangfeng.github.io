,1484,1486,1488],{"class":67,"line":68},[65,1482,1483],{"class":120},"$",[65,1485,123],{"class":71},[65,1487,982],{"class":86},[65,1489,129],{"class":71},[12,1491,1492,1493,1495],{},"Nice and tidy. But with ",[27,1494,600],{}," you have to write:",[56,1497,1499],{"className":98,"code":1498,"language":100,"meta":61,"style":61},"document.querySelector('.test');\n",[27,1500,1501],{"__ignoreMap":61},[65,1502,1503,1506,1508,1510,1512],{"class":67,"line":68},[65,1504,1505],{"class":71},"document.",[65,1507,29],{"class":120},[65,1509,123],{"class":71},[65,1511,982],{"class":86},[65,1513,129],{"class":71},[12,1515,1516,1517,1519],{},"Which is way more verbose by comparison. So we can declare a function to build our own ",[27,1518,1483],{}," method, and get that jQuery-like brevity:",[56,1521,1523],{"className":98,"code":1522,"language":100,"meta":61,"style":61},"const $ = (selector) => document.querySelector(selector);\n",[27,1524,1525],{"__ignoreMap":61},[65,1526,1527,1529,1532,1534,1537,1540,1542,1544,1546,1548],{"class":67,"line":68},[65,1528,108],{"class":107},[65,1530,1531],{"class":120}," $",[65,1533,114],{"class":107},[65,1535,1536],{"class":71}," (",[65,1538,1539],{"class":1105},"selector",[65,1541,1109],{"class":71},[65,1543,1112],{"class":107},[65,1545,117],{"class":71},[65,1547,29],{"class":120},[65,1549,1550],{"class":71},"(selector);\n",[12,1552,1553],{},"Now selecting elements is as clean as jQuery:",[56,1555,1556],{"className":98,"code":1476,"language":100,"meta":61,"style":61},[27,1557,1558],{"__ignoreMap":61},[65,1559,1560,1562,1564,1566],{"class":67,"line":68},[65,1561,1483],{"class":120},[65,1563,123],{"class":71},[65,1565,982],{"class":86},[65,1567,129],{"class":71},[12,1569,1570,1571,1574],{},"You can also hang it off ",[27,1572,1573],{},"window"," so it's available globally:",[56,1576,1578],{"className":98,"code":1577,"language":100,"meta":61,"style":61},"window.$ = (selector) => document.querySelector(selector);\n",[27,1579,1580],{"__ignoreMap":61},[6