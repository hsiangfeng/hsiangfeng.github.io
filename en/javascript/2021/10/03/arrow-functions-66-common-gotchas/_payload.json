[{"data":1,"prerenderedAt":811},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":786,"related:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":795},"\u002Fjavascript\u002F20211003\u002F2825307925\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":769,"date":770,"description":771,"extension":772,"lang":773,"meta":774,"navigation":542,"path":775,"readingMinutes":776,"seo":777,"standalone":778,"stem":779,"tags":780,"tldr":783,"updated":770,"url":784,"__hash__":785},"content\u002Fen\u002FJavaScript\u002Farrow-functions-66-common-gotchas.md","JavaScript Core (66) - ES6 Arrow Functions: The Gotchas That Trip Everyone Up","1001148258",{"type":9,"value":10,"toc":764},"minimark",[11,16,20,24,27,89,96,144,147,197,214,254,257,315,318,382,385,436,439,492,495,626,629,737,744,748,760],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We've already gone over a bunch of differences between arrow functions and traditional functions. But in real code there are still a few situations that come up all the time, so this chapter rounds up the arrow function problems you'll actually run into.",[12,21,23],{"id":22},"common-gotchas","Common gotchas",[17,25,26],{},"Arrow functions can be written super short. When your code is just one line, you can shrink it down to this:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var myName = () => 'Ray';\nconsole.log(myName()); \u002F\u002F Ray\n","js","",[35,36,37,67],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57,60,64],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sj_SG"," myName",[38,51,52],{"class":44}," =",[38,54,56],{"class":55},"sMAXC"," () ",[38,58,59],{"class":44},"=>",[38,61,63],{"class":62},"sTRMh"," 'Ray'",[38,65,66],{"class":55},";\n",[38,68,70,73,76,79,82,85],{"class":40,"line":69},2,[38,71,72],{"class":55},"console.",[38,74,75],{"class":48},"log",[38,77,78],{"class":55},"(",[38,80,81],{"class":48},"myName",[38,83,84],{"class":55},"()); ",[38,86,88],{"class":87},"sQrFR","\u002F\u002F Ray\n",[17,90,91,92,95],{},"But watch out here — if you're trying to return an object, this breaks. You won't get the object you expected, you'll just get ",[35,93,94],{},"undefined",":",[28,97,99],{"className":30,"code":98,"language":32,"meta":33,"style":33},"var myName = () => { name: 'Ray'};\nconsole.log(myName()); \u002F\u002F undefined\n",[35,100,101,129],{"__ignoreMap":33},[38,102,103,105,107,109,111,113,116,120,123,126],{"class":40,"line":41},[38,104,45],{"class":44},[38,106,49],{"class":48},[38,108,52],{"class":44},[38,110,56],{"class":55},[38,112,59],{"class":44},[38,114,115],{"class":55}," { ",[38,117,119],{"class":118},"s_sBn","name",[38,121,122],{"class":55},": ",[38,124,125],{"class":62},"'Ray'",[38,127,128],{"class":55},"};\n",[38,130,131,133,135,137,139,141],{"class":40,"line":69},[38,132,72],{"class":55},[38,134,75],{"class":48},[38,136,78],{"class":55},[38,138,81],{"class":48},[38,140,84],{"class":55},[38,142,143],{"class":87},"\u002F\u002F undefined\n",[17,145,146],{},"So why does that happen? Let me reformat it a bit:",[28,148,150],{"className":30,"code":149,"language":32,"meta":33,"style":33},"var myName = () => {\n  name: 'Ray'\n};\nconsole.log(myName()); \u002F\u002F undefined\n",[35,151,152,167,177,182],{"__ignoreMap":33},[38,153,154,156,158,160,162,164],{"class":40,"line":41},[38,155,45],{"class":44},[38,157,49],{"class":48},[38,159,52],{"class":44},[38,161,56],{"class":55},[38,163,59],{"class":44},[38,165,166],{"class":55}," {\n",[38,168,169,172,174],{"class":40,"line":69},[38,170,171],{"class":118},"  name",[38,173,122],{"class":55},[38,175,176],{"class":62},"'Ray'\n",[38,178,180],{"class":40,"line":179},3,[38,181,128],{"class":55},[38,183,185,187,189,191,193,195],{"class":40,"line":184},4,[38,186,72],{"class":55},[38,188,75],{"class":48},[38,190,78],{"class":55},[38,192,81],{"class":48},[38,194,84],{"class":55},[38,196,143],{"class":87},[17,198,199,200,203,204,207,208,210,211,213],{},"See it now? Those outer ",[35,201,202],{},"{}"," get mistaken by the arrow function as its own function body, not an object literal. So really it's just running ",[35,205,206],{},"name: 'Ray'"," as a statement, and since JavaScript can't return ",[35,209,206],{}," like that, it just hands you back ",[35,212,94],{},". If you want this to actually work, wrap the object in parentheses:",[28,215,217],{"className":30,"code":216,"language":32,"meta":33,"style":33},"var myName = () => ({ name: 'Ray'});\nconsole.log(myName()); \u002F\u002F { name: 'Ray'}\n",[35,218,219,239],{"__ignoreMap":33},[38,220,221,223,225,227,229,231,234,236],{"class":40,"line":41},[38,222,45],{"class":44},[38,224,49],{"class":48},[38,226,52],{"class":44},[38,228,56],{"class":55},[38,230,59],{"class":44},[38,232,233],{"class":55}," ({ name: ",[38,235,125],{"class":62},[38,237,238],{"class":55},"});\n",[38,240,241,243,245,247,249,251],{"class":40,"line":69},[38,242,72],{"class":55},[38,244,75],{"class":48},[38,246,78],{"class":55},[38,248,81],{"class":48},[38,250,84],{"class":55},[38,252,253],{"class":87},"\u002F\u002F { name: 'Ray'}\n",[17,255,256],{},"So the takeaway is: the shorthand form of an arrow function can't directly return an object literal — unless you write it out the long way:",[28,258,260],{"className":30,"code":259,"language":32,"meta":33,"style":33},"var myName = () => {\n  return {\n    name: 'Ray'\n  }\n};\nconsole.log(myName()); \u002F\u002F { name: 'Ray'}\n",[35,261,262,276,283,290,295,300],{"__ignoreMap":33},[38,263,264,266,268,270,272,274],{"class":40,"line":41},[38,265,45],{"class":44},[38,267,49],{"class":48},[38,269,52],{"class":44},[38,271,56],{"class":55},[38,273,59],{"class":44},[38,275,166],{"class":55},[38,277,278,281],{"class":40,"line":69},[38,279,280],{"class":44},"  return",[38,282,166],{"class":55},[38,284,285,288],{"class":40,"line":179},[38,286,287],{"class":55},"    name: ",[38,289,176],{"class":62},[38,291,292],{"class":40,"line":184},[38,293,294],{"class":55},"  }\n",[38,296,298],{"class":40,"line":297},5,[38,299,128],{"class":55},[38,301,303,305,307,309,311,313],{"class":40,"line":302},6,[38,304,72],{"class":55},[38,306,75],{"class":48},[38,308,78],{"class":55},[38,310,81],{"class":48},[38,312,84],{"class":55},[38,314,253],{"class":87},[17,316,317],{},"Next, another arrow function quirk. The course mentioned a special pattern — and I call it special because honestly I've never written it this way in my own work:",[28,319,321],{"className":30,"code":320,"language":32,"meta":33,"style":33},"var num = false;\nvar fn = num || function() { return 'Ray' }\nconsole.log(fn()); \u002F\u002F Ray\n",[35,322,323,339,367],{"__ignoreMap":33},[38,324,325,327,330,333,337],{"class":40,"line":41},[38,326,45],{"class":44},[38,328,329],{"class":55}," num ",[38,331,332],{"class":44},"=",[38,334,336],{"class":335},"sCcAr"," false",[38,338,66],{"class":55},[38,340,341,343,346,348,350,353,356,359,362,364],{"class":40,"line":69},[38,342,45],{"class":44},[38,344,345],{"class":55}," fn ",[38,347,332],{"class":44},[38,349,329],{"class":55},[38,351,352],{"class":44},"||",[38,354,355],{"class":44}," function",[38,357,358],{"class":55},"() { ",[38,360,361],{"class":44},"return",[38,363,63],{"class":62},[38,365,366],{"class":55}," }\n",[38,368,369,371,373,375,378,380],{"class":40,"line":179},[38,370,72],{"class":55},[38,372,75],{"class":48},[38,374,78],{"class":55},[38,376,377],{"class":48},"fn",[38,379,84],{"class":55},[38,381,88],{"class":87},[17,383,384],{},"Arrow functions can't be used like that — you'll get an error:",[28,386,388],{"className":30,"code":387,"language":32,"meta":33,"style":33},"var num = false;\nvar fn = num || () => 'Ray'\nconsole.log(fn()); \u002F\u002F Uncaught SyntaxError: Malformed arrow function parameter list\n",[35,389,390,402,421],{"__ignoreMap":33},[38,391,392,394,396,398,400],{"class":40,"line":41},[38,393,45],{"class":44},[38,395,329],{"class":55},[38,397,332],{"class":44},[38,399,336],{"class":335},[38,401,66],{"class":55},[38,403,404,406,408,410,412,414,416,418],{"class":40,"line":69},[38,405,45],{"class":44},[38,407,345],{"class":55},[38,409,332],{"class":44},[38,411,329],{"class":55},[38,413,352],{"class":44},[38,415,56],{"class":55},[38,417,59],{"class":44},[38,419,420],{"class":62}," 'Ray'\n",[38,422,423,425,427,429,431,433],{"class":40,"line":179},[38,424,72],{"class":55},[38,426,75],{"class":48},[38,428,78],{"class":55},[38,430,377],{"class":48},[38,432,84],{"class":55},[38,434,435],{"class":87},"\u002F\u002F Uncaught SyntaxError: Malformed arrow function parameter list\n",[17,437,438],{},"If you want it to work, you have to add parentheses:",[28,440,442],{"className":30,"code":441,"language":32,"meta":33,"style":33},"var num = false;\nvar fn = num || (() => 'Ray')\nconsole.log(fn()); \u002F\u002F Ray\n",[35,443,444,456,478],{"__ignoreMap":33},[38,445,446,448,450,452,454],{"class":40,"line":41},[38,447,45],{"class":44},[38,449,329],{"class":55},[38,451,332],{"class":44},[38,453,336],{"class":335},[38,455,66],{"class":55},[38,457,458,460,462,464,466,468,471,473,475],{"class":40,"line":69},[38,459,45],{"class":44},[38,461,345],{"class":55},[38,463,332],{"class":44},[38,465,329],{"class":55},[38,467,352],{"class":44},[38,469,470],{"class":55}," (() ",[38,472,59],{"class":44},[38,474,63],{"class":62},[38,476,477],{"class":55},")\n",[38,479,480,482,484,486,488,490],{"class":40,"line":179},[38,481,72],{"class":55},[38,483,75],{"class":48},[38,485,78],{"class":55},[38,487,377],{"class":48},[38,489,84],{"class":55},[38,491,88],{"class":87},[17,493,494],{},"Earlier we talked about the problem with arrow functions in constructors, so I'll mention one more thing here. Sometimes we add prototype methods to a constructor, and those prototype methods are usually traditional functions:",[28,496,498],{"className":30,"code":497,"language":32,"meta":33,"style":33},"const fn = function(a) {\n  this.myName = a\n}\n\nfn.prototype.callName = function () {\n  return this.myName;\n}\n\nvar qq = new fn('Ray');\n\nqq.callName(); \u002F\u002F Ray\n",[35,499,500,520,533,538,544,566,576,581,586,608,613],{"__ignoreMap":33},[38,501,502,505,508,510,512,514,517],{"class":40,"line":41},[38,503,504],{"class":44},"const",[38,506,507],{"class":48}," fn",[38,509,52],{"class":44},[38,511,355],{"class":44},[38,513,78],{"class":55},[38,515,516],{"class":118},"a",[38,518,519],{"class":55},") {\n",[38,521,522,525,528,530],{"class":40,"line":69},[38,523,524],{"class":335},"  this",[38,526,527],{"class":55},".myName ",[38,529,332],{"class":44},[38,531,532],{"class":55}," a\n",[38,534,535],{"class":40,"line":179},[38,536,537],{"class":55},"}\n",[38,539,540],{"class":40,"line":184},[38,541,543],{"emptyLinePlaceholder":542},true,"\n",[38,545,546,548,551,554,556,559,561,563],{"class":40,"line":297},[38,547,377],{"class":335},[38,549,550],{"class":55},".",[38,552,553],{"class":335},"prototype",[38,555,550],{"class":55},[38,557,558],{"class":48},"callName",[38,560,52],{"class":44},[38,562,355],{"class":44},[38,564,565],{"class":55}," () {\n",[38,567,568,570,573],{"class":40,"line":302},[38,569,280],{"class":44},[38,571,572],{"class":335}," this",[38,574,575],{"class":55},".myName;\n",[38,577,579],{"class":40,"line":578},7,[38,580,537],{"class":55},[38,582,584],{"class":40,"line":583},8,[38,585,543],{"emptyLinePlaceholder":542},[38,587,589,591,594,596,599,601,603,605],{"class":40,"line":588},9,[38,590,45],{"class":44},[38,592,593],{"class":55}," qq ",[38,595,332],{"class":44},[38,597,598],{"class":44}," new",[38,600,507],{"class":48},[38,602,78],{"class":55},[38,604,125],{"class":62},[38,606,607],{"class":55},");\n",[38,609,611],{"class":40,"line":610},10,[38,612,543],{"emptyLinePlaceholder":542},[38,614,616,619,621,624],{"class":40,"line":615},11,[38,617,618],{"class":55},"qq.",[38,620,558],{"class":48},[38,622,623],{"class":55},"(); ",[38,625,88],{"class":87},[17,627,628],{},"Now what happens if that prototype method becomes an arrow function — does it still work?",[28,630,632],{"className":30,"code":631,"language":32,"meta":33,"style":33},"const fn = function(a) {\n  this.myName = a\n}\n\nfn.prototype.callName =  () => {\n  return this.myName;\n}\n\nvar qq = new fn('Ray');\n\nqq.callName(); \u002F\u002F undefined\n",[35,633,634,650,660,664,668,689,697,701,705,723,727],{"__ignoreMap":33},[38,635,636,638,640,642,644,646,648],{"class":40,"line":41},[38,637,504],{"class":44},[38,639,507],{"class":48},[38,641,52],{"class":44},[38,643,355],{"class":44},[38,645,78],{"class":55},[38,647,516],{"class":118},[38,649,519],{"class":55},[38,651,652,654,656,658],{"class":40,"line":69},[38,653,524],{"class":335},[38,655,527],{"class":55},[38,657,332],{"class":44},[38,659,532],{"class":55},[38,661,662],{"class":40,"line":179},[38,663,537],{"class":55},[38,665,666],{"class":40,"line":184},[38,667,543],{"emptyLinePlaceholder":542},[38,669,670,672,674,676,678,680,682,685,687],{"class":40,"line":297},[38,671,377],{"class":335},[38,673,550],{"class":55},[38,675,553],{"class":335},[38,677,550],{"class":55},[38,679,558],{"class":48},[38,681,52],{"class":44},[38,683,684],{"class":55},"  () ",[38,686,59],{"class":44},[38,688,166],{"class":55},[38,690,691,693,695],{"class":40,"line":302},[38,692,280],{"class":44},[38,694,572],{"class":335},[38,696,575],{"class":55},[38,698,699],{"class":40,"line":578},[38,700,537],{"class":55},[38,702,703],{"class":40,"line":583},[38,704,543],{"emptyLinePlaceholder":542},[38,706,707,709,711,713,715,717,719,721],{"class":40,"line":588},[38,708,45],{"class":44},[38,710,593],{"class":55},[38,712,332],{"class":44},[38,714,598],{"class":44},[38,716,507],{"class":48},[38,718,78],{"class":55},[38,720,125],{"class":62},[38,722,607],{"class":55},[38,724,725],{"class":40,"line":610},[38,726,543],{"emptyLinePlaceholder":542},[38,728,729,731,733,735],{"class":40,"line":615},[38,730,618],{"class":55},[38,732,558],{"class":48},[38,734,623],{"class":55},[38,736,143],{"class":87},[17,738,739,740,743],{},"The main reason is, again, that arrow functions bind ",[35,741,742],{},"this"," differently. So this is one more thing to keep in mind when you're actually building stuff.",[12,745,747],{"id":746},"references","References",[749,750,751],"ul",{},[752,753,754],"li",{},[516,755,759],{"href":756,"rel":757},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[758],"nofollow","JavaScript Core (course in Mandarin)",[761,762,763],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":33,"searchDepth":69,"depth":69,"links":765},[766,767,768],{"id":14,"d