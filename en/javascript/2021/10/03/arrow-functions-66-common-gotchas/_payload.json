[{"data":1,"prerenderedAt":812},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":787,"related:\u002Fen\u002Fjavascript\u002F2021\u002F10\u002F03\u002Farrow-functions-66-common-gotchas\u002F":796},"\u002Fjavascript\u002F20211003\u002F2825307925\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":770,"date":771,"description":772,"extension":773,"lang":774,"meta":775,"navigation":543,"path":776,"readingMinutes":777,"seo":778,"standalone":779,"stem":780,"tags":781,"tldr":784,"updated":771,"url":785,"__hash__":786},"content\u002Fen\u002FJavaScript\u002Farrow-functions-66-common-gotchas.md","JavaScript Core (66) - ES6 Arrow Functions: The Gotchas That Trip Everyone Up","1001148258",{"type":9,"value":10,"toc":765},"minimark",[11,16,20,24,27,89,96,144,147,197,214,254,257,315,318,382,385,436,439,492,495,627,630,738,745,749,761],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We've already gone over a bunch of differences between arrow functions and traditional functions. But in real code there are still a few situations that come up all the time, so this chapter rounds up the arrow function problems you'll actually run into.",[12,21,23],{"id":22},"common-gotchas","Common gotchas",[17,25,26],{},"Arrow functions can be written super short. When your code is just one line, you can shrink it down to this:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","var myName = () => 'Ray';\nconsole.log(myName()); \u002F\u002F Ray\n","js","",[35,36,37,67],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57,60,64],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sOudu","var",[38,47,49],{"class":48},"scAaK"," myName",[38,51,52],{"class":44}," =",[38,54,56],{"class":55},"s8XSl"," () ",[38,58,59],{"class":44},"=>",[38,61,63],{"class":62},"sWayO"," 'Ray'",[38,65,66],{"class":55},";\n",[38,68,70,73,76,79,82,85],{"class":40,"line":69},2,[38,71,72],{"class":55},"console.",[38,74,75],{"class":48},"log",[38,77,78],{"class":55},"(",[38,80,81],{"class":48},"myName",[38,83,84],{"class":55},"()); ",[38,86,88],{"class":87},"sGBqm","\u002F\u002F Ray\n",[17,90,91,92,95],{},"But watch out here — if you're trying to return an object, this breaks. You won't get the object you expected, you'll just get ",[35,93,94],{},"undefined",":",[28,97,99],{"className":30,"code":98,"language":32,"meta":33,"style":33},"var myName = () => { name: 'Ray'};\nconsole.log(myName()); \u002F\u002F undefined\n",[35,100,101,129],{"__ignoreMap":33},[38,102,103,105,107,109,111,113,116,120,123,126],{"class":40,"line":41},[38,104,45],{"class":44},[38,106,49],{"class":48},[38,108,52],{"class":44},[38,110,56],{"class":55},[38,112,59],{"class":44},[38,114,115],{"class":55}," { ",[38,117,119],{"class":118},"smYoP","name",[38,121,122],{"class":55},": ",[38,124,125],{"class":62},"'Ray'",[38,127,128],{"class":55},"};\n",[38,130,131,133,135,137,139,141],{"class":40,"line":69},[38,132,72],{"class":55},[38,134,75],{"class":48},[38,136,78],{"class":55},[38,138,81],{"class":48},[38,140,84],{"class":55},[38,142,143],{"class":87},"\u002F\u002F undefined\n",[17,145,146],{},"So why does that happen? Let me reformat it a bit:",[28,148,150],{"className":30,"code":149,"language":32,"meta":33,"style":33},"var myName = () => {\n  name: 'Ray'\n};\nconsole.log(myName()); \u002F\u002F undefined\n",[35,151,152,167,177,182],{"__ignoreMap":33},[38,153,154,156,158,160,162,164],{"class":40,"line":41},[38,155,45],{"class":44},[38,157,49],{"class":48},[38,159,52],{"class":44},[38,161,56],{"class":55},[38,163,59],{"class":44},[38,165,166],{"class":55}," {\n",[38,168,169,172,174],{"class":40,"line":69},[38,170,171],{"class":118},"  name",[38,173,122],{"class":55},[38,175,176],{"class":62},"'Ray'\n",[38,178,180],{"class":40,"line":179},3,[38,181,128],{"class":55},[38,183,185,187,189,191,193,195],{"class":40,"line":184},4,[38,186,72],{"class":55},[38,188,75],{"class":48},[38,190,78],{"class":55},[38,192,81],{"class":48},[38,194,84],{"class":55},[38,196,143],{"class":87},[17,198,199,200,203,204,207,208,210,211,213],{},"See it now? Those outer ",[35,201,202],{},"{}"," get mistaken by the arrow function as its own function body, not an object literal. So really it's just running ",[35,205,206],{},"name: 'Ray'"," as a statement, and since JavaScript can't return ",[35,209,206],{}," like that, it just hands you back ",[35,212,94],{},". If you want this to actually work, wrap the object in parentheses:",[28,215,217],{"className":30,"code":216,"language":32,"meta":33,"style":33},"var myName = () => ({ name: 'Ray'});\nconsole.log(myName()); \u002F\u002F { name: 'Ray'}\n",[35,218,219,239],{"__ignoreMap":33},[38,220,221,223,225,227,229,231,234,236],{"class":40,"line":41},[38,222,45],{"class":44},[38,224,49],{"class":48},[38,226,52],{"class":44},[38,228,56],{"class":55},[38,230,59],{"class":44},[38,232,233],{"class":55}," ({ name: ",[38,235,125],{"class":62},[38,237,238],{"class":55},"});\n",[38,240,241,243,245,247,249,251],{"class":40,"line":69},[38,242,72],{"class":55},[38,244,75],{"class":48},[38,246,78],{"class":55},[38,248,81],{"class":48},[38,250,84],{"class":55},[38,252,253],{"class":87},"\u002F\u002F { name: 'Ray'}\n",[17,255,256],{},"So the takeaway is: the shorthand form of an arrow function can't directly return an object literal — unless you write it out the long way:",[28,258,260],{"className":30,"code":259,"language":32,"meta":33,"style":33},"var myName = () => {\n  return {\n    name: 'Ray'\n  }\n};\nconsole.log(myName()); \u002F\u002F { name: 'Ray'}\n",[35,261,262,276,283,290,295,300],{"__ignoreMap":33},[38,263,264,266,268,270,272,274],{"class":40,"line":41},[38,265,45],{"class":44},[38,267,49],{"class":48},[38,269,52],{"class":44},[38,271,56],{"class":55},[38,273,59],{"class":44},[38,275,166],{"class":55},[38,277,278,281],{"class":40,"line":69},[38,279,280],{"class":44},"  return",[38,282,166],{"class":55},[38,284,285,288],{"class":40,"line":179},[38,286,287],{"class":55},"    name: ",[38,289,176],{"class":62},[38,291,292],{"class":40,"line":184},[38,293,294],{"class":55},"  }\n",[38,296,298],{"class":40,"line":297},5,[38,299,128],{"class":55},[38,301,303,305,307,309,311,313],{"class":40,"line":302},6,[38,304,72],{"class":55},[38,306,75],{"class":48},[38,308,78],{"class":55},[38,310,81],{"class":48},[38,312,84],{"class":55},[38,314,253],{"class":87},[17,316,317],{},"Next, another arrow function quirk. The course mentioned a special pattern — and I call it special because honestly I've never written it this way in my own work:",[28,319,321],{"className":30,"code":320,"language":32,"meta":33,"style":33},"var num = false;\nvar fn = num || function() { return 'Ray' }\nconsole.log(fn()); \u002F\u002F Ray\n",[35,322,323,339,367],{"__ignoreMap":33},[38,324,325,327,330,333,337],{"class":40,"line":41},[38,326,45],{"class":44},[38,328,329],{"class":55}," num ",[38,331,332],{"class":44},"=",[38,334,336],{"class":335},"stw71"," false",[38,338,66],{"class":55},[38,340,341,343,346,348,350,353,356,359,362,364],{"class":40,"line":69},[38,342,45],{"class":44},[38,344,345],{"class":55}," fn ",[38,347,332],{"class":44},[38,349,329],{"class":55},[38,351,352],{"class":44},"||",[38,354,355],{"class":44}," function",[38,357,358],{"class":55},"() { ",[38,360,361],{"class":44},"return",[38,363,63],{"class":62},[38,365,366],{"class":55}," }\n",[38,368,369,371,373,375,378,380],{"class":40,"line":179},[38,370,72],{"class":55},[38,372,75],{"class":48},[38,374,78],{"class":55},[38,376,377],{"class":48},"fn",[38,379,84],{"class":55},[38,381,88],{"class":87},[17,383,384],{},"Arrow functions can't be used like that — you'll get an error:",[28,386,388],{"className":30,"code":387,"language":32,"meta":33,"style":33},"var num = false;\nvar fn = num || () => 'Ray'\nconsole.log(fn()); \u002F\u002F Uncaught SyntaxError: Malformed arrow function parameter list\n",[35,389,390,402,421],{"__ignoreMap":33},[38,391,392,394,396,398,400],{"class":40,"line":41},[38,393,45],{"class":44},[38,395,329],{"class":55},[38,397,332],{"class":44},[38,399,336],{"class":335},[38,401,66],{"class":55},[38,403,404,406,408,410,412,414,416,418],{"class":40,"line":69},[38,405,45],{"class":44},[38,407,345],{"class":55},[38,409,332],{"class":44},[38,411,329],{"class":55},[38,413,352],{"class":44},[38,415,56],{"class":55},[38,417,59],{"class":44},[38,419,420],{"class":62}," 'Ray'\n",[38,422,423,425,427,429,431,433],{"class":40,"line":179},[38,424,72],{"class":55},[38,426,75],{"class":48},[38,428,78],{"class":55},[38,430,377],{"class":48},[38,432,84],{"class":55},[38,434,435],{"class":87},"\u002F\u002F Uncaught SyntaxError: Malformed arrow function parameter list\n",[17,437,438],{},"If you want it to work, you have to add parentheses:",[28,440,442],{"className":30,"code":441,"language":32,"meta":33,"style":33},"var num = false;\nvar fn = num || (() => 'Ray')\nconsole.log(fn()); \u002F\u002F Ray\n",[35,443,444,456,478],{"__ignoreMap":33},[38,445,446,448,450,452,454],{"class":40,"line":41},[38,447,45],{"class":44},[38,449,329],{"class":55},[38,451,332],{"class":44},[38,453,336],{"class":335},[38,455,66],{"class":55},[38,457,458,460,462,464,466,468,471,473,475],{"class":40,"line":69},[38,459,45],{"class":44},[38,461,345],{"class":55},[38,463,332],{"class":44},[38,465,329],{"class":55},[38,467,352],{"class":44},[38,469,470],{"class":55}," (() ",[38,472,59],{"class":44},[38,474,63],{"class":62},[38,476,477],{"class":55},")\n",[38,479,480,482,484,486,488,490],{"class":40,"line":179},[38,481,72],{"class":55},[38,483,75],{"class":48},[38,485,78],{"class":55},[38,487,377],{"class":48},[38,489,84],{"class":55},[38,491,88],{"class":87},[17,493,494],{},"Earlier we talked about the problem with arrow functions in constructors, so I'll mention one more thing here. Sometimes we add prototype methods to a constructor, and those prototype methods are usually traditional functions:",[28,496,498],{"className":30,"code":497,"language":32,"meta":33,"style":33},"const fn = function(a) {\n  this.myName = a\n}\n\nfn.prototype.callName = function () {\n  return this.myName;\n}\n\nvar qq = new fn('Ray');\n\nqq.callName(); \u002F\u002F Ray\n",[35,499,500,521,534,539,545,567,577,582,587,609,614],{"__ignoreMap":33},[38,501,502,505,508,510,512,514,518],{"class":40,"line":41},[38,503,504],{"class":44},"const",[38,506,507],{"class":48}," fn",[38,509,52],{"class":44},[38,511,355],{"class":44},[38,513,78],{"class":55},[38,515,517],{"class":516},"syBk-","a",[38,519,520],{"class":55},") {\n",[38,522,523,526,529,531],{"class":40,"line":69},[38,524,525],{"class":335},"  this",[38,527,528],{"class":55},".myName ",[38,530,332],{"class":44},[38,532,533],{"class":55}," a\n",[38,535,536],{"class":40,"line":179},[38,537,538],{"class":55},"}\n",[38,540,541],{"class":40,"line":184},[38,542,544],{"emptyLinePlaceholder":543},true,"\n",[38,546,547,549,552,555,557,560,562,564],{"class":40,"line":297},[38,548,377],{"class":335},[38,550,551],{"class":55},".",[38,553,554],{"class":335},"prototype",[38,556,551],{"class":55},[38,558,559],{"class":48},"callName",[38,561,52],{"class":44},[38,563,355],{"class":44},[38,565,566],{"class":55}," () {\n",[38,568,569,571,574],{"class":40,"line":302},[38,570,280],{"class":44},[38,572,573],{"class":335}," this",[38,575,576],{"class":55},".myName;\n",[38,578,580],{"class":40,"line":579},7,[38,581,538],{"class":55},[38,583,585],{"class":40,"line":584},8,[38,586,544],{"emptyLinePlaceholder":543},[38,588,590,592,595,597,600,602,604,606],{"class":40,"line":589},9,[38,591,45],{"class":44},[38,593,594],{"class":55}," qq ",[38,596,332],{"class":44},[38,598,599],{"class":44}," new",[38,601,507],{"class":48},[38,603,78],{"class":55},[38,605,125],{"class":62},[38,607,608],{"class":55},");\n",[38,610,612],{"class":40,"line":611},10,[38,613,544],{"emptyLinePlaceholder":543},[38,615,617,620,622,625],{"class":40,"line":616},11,[38,618,619],{"class":55},"qq.",[38,621,559],{"class":48},[38,623,624],{"class":55},"(); ",[38,626,88],{"class":87},[17,628,629],{},"Now what happens if that prototype method becomes an arrow function — does it still work?",[28,631,633],{"className":30,"code":632,"language":32,"meta":33,"style":33},"const fn = function(a) {\n  this.myName = a\n}\n\nfn.prototype.callName =  () => {\n  return this.myName;\n}\n\nvar qq = new fn('Ray');\n\nqq.callName(); \u002F\u002F undefined\n",[35,634,635,651,661,665,669,690,698,702,706,724,728],{"__ignoreMap":33},[38,636,637,639,641,643,645,647,649],{"class":40,"line":41},[38,638,504],{"class":44},[38,640,507],{"class":48},[38,642,52],{"class":44},[38,644,355],{"class":44},[38,646,78],{"class":55},[38,648,517],{"class":516},[38,650,520],{"class":55},[38,652,653,655,657,659],{"class":40,"line":69},[38,654,525],{"class":335},[38,656,528],{"class":55},[38,658,332],{"class":44},[38,660,533],{"class":55},[38,662,663],{"class":40,"line":179},[38,664,538],{"class":55},[38,666,667],{"class":40,"line":184},[38,668,544],{"emptyLinePlaceholder":543},[38,670,671,673,675,677,679,681,683,686,688],{"class":40,"line":297},[38,672,377],{"class":335},[38,674,551],{"class":55},[38,676,554],{"class":335},[38,678,551],{"class":55},[38,680,559],{"class":48},[38,682,52],{"class":44},[38,684,685],{"class":55},"  () ",[38,687,59],{"class":44},[38,689,166],{"class":55},[38,691,692,694,696],{"class":40,"line":302},[38,693,280],{"class":44},[38,695,573],{"class":335},[38,697,576],{"class":55},[38,699,700],{"class":40,"line":579},[38,701,538],{"class":55},[38,703,704],{"class":40,"line":584},[38,705,544],{"emptyLinePlaceholder":543},[38,707,708,710,712,714,716,718,720,722],{"class":40,"line":589},[38,709,45],{"class":44},[38,711,594],{"class":55},[38,713,332],{"class":44},[38,715,599],{"class":44},[38,717,507],{"class":48},[38,719,78],{"class":55},[38,721,125],{"class":62},[38,723,608],{"class":55},[38,725,726],{"class":40,"line":611},[38,727,544],{"emptyLinePlaceholder":543},[38,729,730,732,734,736],{"class":40,"line":616},[38,731,619],{"class":55},[38,733,559],{"class":48},[38,735,624],{"class":55},[38,737,143],{"class":87},[17,739,740,741,744],{},"The main reason is, again, that arrow functions bind ",[35,742,743],{},"this"," differently. So this is one more thing to keep in mind when you're actually building stuff.",[12,746,748],{"id":747},"references","References",[750,751,752],"ul",{},[753,754,755],"li",{},[517,756,760],{"href":757,"rel":758},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[759],"nofollow","JavaScript Core (course in Mandarin)",[762,763,764],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html pre.shiki code .sGBqm, html code.shiki .sGBqm{--shiki-light:#6A737D;--shiki-default:#6A737D;--shiki-dark:#BDC4CC}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration