[{"data":1,"prerenderedAt":1197},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F05\u002F01\u002Fjavascript-core-54-object-property-descriptors\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F05\u002F01\u002Fjavascript-core-54-object-property-descriptors\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F05\u002F01\u002Fjavascript-core-54-object-property-descriptors\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F05\u002F01\u002Fjavascript-core-54-object-property-descriptors\u002F":1172,"related:\u002Fen\u002Fjavascript\u002F2021\u002F05\u002F01\u002Fjavascript-core-54-object-property-descriptors\u002F":1181},"\u002Fjavascript\u002F20210501\u002F1403517775\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1155,"date":1156,"description":1157,"extension":1158,"lang":1159,"meta":1160,"navigation":80,"path":1161,"readingMinutes":1162,"seo":1163,"standalone":1164,"stem":1165,"tags":1166,"tldr":1169,"updated":1156,"url":1170,"__hash__":1171},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-54-object-property-descriptors.md","JavaScript Core (54) - Property Descriptors: The Hidden Settings on Every Object Property","1001053230",{"type":9,"value":10,"toc":1150},"minimark",[11,16,20,24,27,99,111,114,166,169,234,242,292,303,384,397,477,484,487,555,568,578,644,655,746,749,872,892,898,982,992,1131,1135,1146],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This is a bonus chapter on object property descriptors. It's a smaller topic, but once these ideas click, you'll find a lot of framework behavior suddenly makes more sense.",[12,21,23],{"id":22},"property-descriptors","Property descriptors",[17,25,26],{},"Normally, if you type something like this into Chrome, you just see a plain old object:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var obj = {\n  myName: 'Ray',\n};\n\nconsole.log(obj); \u002F\u002F obj\n","js","",[35,36,37,56,69,75,82],"code",{"__ignoreMap":33},[38,39,42,46,50,53],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," obj ",[38,51,52],{"class":44},"=",[38,54,55],{"class":48}," {\n",[38,57,59,62,66],{"class":40,"line":58},2,[38,60,61],{"class":48},"  myName: ",[38,63,65],{"class":64},"sTRMh","'Ray'",[38,67,68],{"class":48},",\n",[38,70,72],{"class":40,"line":71},3,[38,73,74],{"class":48},"};\n",[38,76,78],{"class":40,"line":77},4,[38,79,81],{"emptyLinePlaceholder":80},true,"\n",[38,83,85,88,92,95],{"class":40,"line":84},5,[38,86,87],{"class":48},"console.",[38,89,91],{"class":90},"sj_SG","log",[38,93,94],{"class":48},"(obj); ",[38,96,98],{"class":97},"sQrFR","\u002F\u002F obj\n",[17,100,101,102,106,107,110],{},"What you can't see directly in Chrome is the property's ",[103,104,105],"em",{},"descriptor",". So what's a property descriptor? It's the set of hidden settings that decide things like whether a property can be added, rewritten, or read out in a loop. To actually look at those settings, you need a specific method: ",[35,108,109],{},"Object.getOwnPropertyDescriptor",".",[17,112,113],{},"It's not hard to use. The first argument is usually the object itself, and the second is the property you want to inspect:",[28,115,117],{"className":30,"code":116,"language":32,"meta":33,"style":33},"var obj = {\n  myName: 'Ray',\n};\n\nconsole.log(Object.getOwnPropertyDescriptor(obj, 'myName'));\n",[35,118,119,129,137,141,145],{"__ignoreMap":33},[38,120,121,123,125,127],{"class":40,"line":41},[38,122,45],{"class":44},[38,124,49],{"class":48},[38,126,52],{"class":44},[38,128,55],{"class":48},[38,130,131,133,135],{"class":40,"line":58},[38,132,61],{"class":48},[38,134,65],{"class":64},[38,136,68],{"class":48},[38,138,139],{"class":40,"line":71},[38,140,74],{"class":48},[38,142,143],{"class":40,"line":77},[38,144,81],{"emptyLinePlaceholder":80},[38,146,147,149,151,154,157,160,163],{"class":40,"line":84},[38,148,87],{"class":48},[38,150,91],{"class":90},[38,152,153],{"class":48},"(Object.",[38,155,156],{"class":90},"getOwnPropertyDescriptor",[38,158,159],{"class":48},"(obj, ",[38,161,162],{"class":64},"'myName'",[38,164,165],{"class":48},"));\n",[17,167,168],{},"Paste that into Chrome and you should see something like this:",[28,170,172],{"className":30,"code":171,"language":32,"meta":33,"style":33},"{\n  configurable: true,\n  enumerable: true,\n  value: \"Ray\",\n  writable: true,\n}\n",[35,173,174,179,194,205,217,228],{"__ignoreMap":33},[38,175,176],{"class":40,"line":41},[38,177,178],{"class":48},"{\n",[38,180,181,185,188,192],{"class":40,"line":58},[38,182,184],{"class":183},"s_sBn","  configurable",[38,186,187],{"class":48},": ",[38,189,191],{"class":190},"sCcAr","true",[38,193,68],{"class":48},[38,195,196,199,201,203],{"class":40,"line":71},[38,197,198],{"class":183},"  enumerable",[38,200,187],{"class":48},[38,202,191],{"class":190},[38,204,68],{"class":48},[38,206,207,210,212,215],{"class":40,"line":77},[38,208,209],{"class":183},"  value",[38,211,187],{"class":48},[38,213,214],{"class":64},"\"Ray\"",[38,216,68],{"class":48},[38,218,219,222,224,226],{"class":40,"line":84},[38,220,221],{"class":183},"  writable",[38,223,187],{"class":48},[38,225,191],{"class":190},[38,227,68],{"class":48},[38,229,231],{"class":40,"line":230},6,[38,232,233],{"class":48},"}\n",[17,235,236,237,241],{},"Those four fields are the ",[238,239,240],"strong",{},"property descriptor",":",[243,244,245,257,268,274],"ul",{},[246,247,248,251,252],"li",{},[35,249,250],{},"configurable"," — whether the property can be reconfigured\n",[243,253,254],{},[246,255,256],{},"Basically, whether the property itself can be modified or deleted.",[246,258,259,262,263],{},[35,260,261],{},"enumerable"," — whether the property can be enumerated\n",[243,264,265],{},[246,266,267],{},"In short, whether it shows up when you loop over the object.",[246,269,270,273],{},[35,271,272],{},"value"," — the value",[246,275,276,279,280],{},[35,277,278],{},"writable"," — whether the property's value can be rewritten\n",[243,281,282],{},[246,283,284,285,288,289,110],{},"Basically, whether you can change the value itself, like switching ",[35,286,287],{},"Ray"," to ",[35,290,291],{},"Hello",[17,293,294,295,298,299,302],{},"OK, that's a lot of talk. So how do we actually adjust these descriptors on an object's property? That's where ",[35,296,297],{},"Object.defineProperty"," comes in. It takes three arguments: the object you want to adjust, the property you're targeting, and an object describing the descriptor changes. Say I want ",[35,300,301],{},"myName"," to be locked so it can't be rewritten — here's how:",[28,304,306],{"className":30,"code":305,"language":32,"meta":33,"style":33},"var obj = {\n  myName: 'Ray',\n};\n\nObject.defineProperty(obj, 'myName', {\n  writable: false,\n});\n\nobj.myName = 'Hello';\n",[35,307,308,318,326,330,334,349,359,365,370],{"__ignoreMap":33},[38,309,310,312,314,316],{"class":40,"line":41},[38,311,45],{"class":44},[38,313,49],{"class":48},[38,315,52],{"class":44},[38,317,55],{"class":48},[38,319,320,322,324],{"class":40,"line":58},[38,321,61],{"class":48},[38,323,65],{"class":64},[38,325,68],{"class":48},[38,327,328],{"class":40,"line":71},[38,329,74],{"class":48},[38,331,332],{"class":40,"line":77},[38,333,81],{"emptyLinePlaceholder":80},[38,335,336,339,342,344,346],{"class":40,"line":84},[38,337,338],{"class":48},"Object.",[38,340,341],{"class":90},"defineProperty",[38,343,159],{"class":48},[38,345,162],{"class":64},[38,347,348],{"class":48},", {\n",[38,350,351,354,357],{"class":40,"line":230},[38,352,353],{"class":48},"  writable: ",[38,355,356],{"class":190},"false",[38,358,68],{"class":48},[38,360,362],{"class":40,"line":361},7,[38,363,364],{"class":48},"});\n",[38,366,368],{"class":40,"line":367},8,[38,369,81],{"emptyLinePlaceholder":80},[38,371,373,376,378,381],{"class":40,"line":372},9,[38,374,375],{"class":48},"obj.myName ",[38,377,52],{"class":44},[38,379,380],{"class":64}," 'Hello'",[38,382,383],{"class":48},";\n",[17,385,386,387,389,390,393,394,396],{},"If you copy-paste that into Chrome, you'll see it return ",[35,388,291],{}," — but if you then check ",[35,391,392],{},"console.log(obj.myName);",", you'll find the property is still ",[35,395,287],{},". Heads up: this is a silent error, so you get no warning at all. You can also rewrite it like this:",[28,398,400],{"className":30,"code":399,"language":32,"meta":33,"style":33},"'use strict'\n\nvar obj = {\n  myName: 'Ray',\n};\n\nObject.defineProperty(obj, 'myName', {\n  writable: false,\n});\n\nobj.myName = 'Hello';\n",[35,401,402,407,411,421,429,433,437,449,457,461,466],{"__ignoreMap":33},[38,403,404],{"class":40,"line":41},[38,405,406],{"class":64},"'use strict'\n",[38,408,409],{"class":40,"line":58},[38,410,81],{"emptyLinePlaceholder":80},[38,412,413,415,417,419],{"class":40,"line":71},[38,414,45],{"class":44},[38,416,49],{"class":48},[38,418,52],{"class":44},[38,420,55],{"class":48},[38,422,423,425,427],{"class":40,"line":77},[38,424,61],{"class":48},[38,426,65],{"class":64},[38,428,68],{"class":48},[38,430,431],{"class":40,"line":84},[38,432,74],{"class":48},[38,434,435],{"class":40,"line":230},[38,436,81],{"emptyLinePlaceholder":80},[38,438,439,441,443,445,447],{"class":40,"line":361},[38,440,338],{"class":48},[38,442,341],{"class":90},[38,444,159],{"class":48},[38,446,162],{"class":64},[38,448,348],{"class":48},[38,450,451,453,455],{"class":40,"line":367},[38,452,353],{"class":48},[38,454,356],{"class":190},[38,456,68],{"class":48},[38,458,459],{"class":40,"line":372},[38,460,364],{"class":48},[38,462,464],{"class":40,"line":463},10,[38,465,81],{"emptyLinePlaceholder":80},[38,467,469,471,473,475],{"class":40,"line":468},11,[38,470,375],{"class":48},[38,472,52],{"class":44},[38,474,380],{"class":64},[38,476,383],{"class":48},[17,478,479,480,483],{},"Now you'll get the error message ",[35,481,482],{},"Uncaught TypeError: Cannot assign 