bject.seal(obj);\n\nconsole.log('Is it sealed?', Object.isSealed(obj)); \u002F\u002F true\nconsole.log('myName attributes:', Object.getOwnPropertyDescriptor(obj, 'myName')); \u002F\u002F {value: \"Ray\", writable: true, enumerable: true, configurable: false}\n\nobj.myName = 'QQ123'; \u002F\u002F can be modified\nobj.url = 'https:\u002F\u002Fisraynotarray.com\u002F'; \u002F\u002F can be modified\ndelete obj.myName \u002F\u002F false, can't be deleted\nobj.blog = false; \u002F\u002F can't be extended\n\n\u002F\u002F If you try to adjust the property attributes it throws right away: Uncaught TypeError: Cannot redefine property: myName\nObject.defineProperty(obj, 'myName', {\n  configurable: true,\n});\n",[21,548,549,559,567,571,575,579,588,592,613,641,645,661,674,686,702,707,713,727,738],{"__ignoreMap":69},[73,550,551,553,555,557],{"class":75,"line":76},[73,552,80],{"class":79},[73,554,84],{"class":83},[73,556,87],{"class":79},[73,558,90],{"class":83},[73,560,561,563,565],{"class":75,"line":93},[73,562,96],{"class":83},[73,564,100],{"class":99},[73,566,103],{"class":83},[73,568,569],{"class":75,"line":106},[73,570,109],{"class":83},[73,572,573],{"class":75,"line":112},[73,574,115],{"class":83},[73,576,577],{"class":75,"line":159},[73,578,163],{"emptyLinePlaceholder":162},[73,580,581,583,586],{"class":75,"line":166},[73,582,169],{"class":83},[73,584,585],{"class":172},"seal",[73,587,176],{"class":83},[73,589,590],{"class":75,"line":179},[73,591,163],{"emptyLinePlaceholder":162},[73,593,594,596,598,600,603,605,608,610],{"class":75,"line":184},[73,595,201],{"class":83},[73,597,204],{"class":172},[73,599,397],{"class":83},[73,601,602],{"class":99},"'Is it sealed?'",[73,604,403],{"class":83},[73,606,607],{"class":172},"isSealed",[73,609,409],{"class":83},[73,611,612],{"class":210},"\u002F\u002F true\n",[73,614,615,617,619,621,624,626,629,632,635,638],{"class":75,"line":198},[73,616,201],{"class":83},[73,618,204],{"class":172},[73,620,397],{"class":83},[73,622,623],{"class":