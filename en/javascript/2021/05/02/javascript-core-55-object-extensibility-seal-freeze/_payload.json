class":83},[73,264,265],{"class":75,"line":184},[73,266,163],{"emptyLinePlaceholder":162},[73,268,269,271,273,275],{"class":75,"line":198},[73,270,187],{"class":83},[73,272,87],{"class":79},[73,274,192],{"class":99},[73,276,195],{"class":83},[73,278,280,282,284,286],{"class":75,"line":279},10,[73,281,201],{"class":83},[73,283,204],{"class":172},[73,285,207],{"class":83},[73,287,288],{"class":210},"\u002F\u002F Uncaught TypeError: Cannot add property url, object is not extensible\n",[17,290,291],{},"Otherwise, normally you'd expect a result like this:",[64,293,295],{"className":66,"code":294,"language":68,"meta":69,"style":69},"{\n  myName: \"Ray\",\n  blog: {},\n  url: \"https:\u002F\u002Fisraynotarray.com\u002F\"\n}\n",[21,296,297,302,316,324,334],{"__ignoreMap":69},[73,298,299],{"class":75,"line":76},[73,300,301],{"class":83},"{\n",[73,303,304,308,311,314],{"class":75,"line":93},[73,305,307],{"class":306},"s_sBn","  myName",[73,309,310],{"class":83},": ",[73,312,313],{"class":99},"\"Ray\"",[73,315,103],{"class":83},[73,317,318,321],{"class":75,"line":106},[73,319,320],{"class":306},"  blog",[73,322,323],{"class":83},": {},\n",[73,325,326,329,331],{"class":75,"line":112},[73,327,328],{"class":306},"  url",[73,330,310],{"class":83},[73,332,333],{"class":99},"\"https:\u002F\u002Fisraynotarray.com\u002F\"\n",[73,335,336],{"class":75,"line":159},[73,337,338],{"class":83},"}\n",[17,340,341,342,345],{},"Now you might be wondering, \"how do I even know whether an object can be extended?\" You can check with ",[21,343,344],{},"Object.isExtensible",":",[64,347,349],{"className":66,"code":348,"language":68,"meta":69,"style":69},"var obj = {\n  myName: 'Ray',\n  blog: {},\n};\n\nObject.preventExtensions(obj);\nconsole.log('Can it be extended?', Object.isExtensible(obj)); \u002F\u002F false\n\nobj.url = 'https:\u002F\u002Fisraynotarray.com\u002F';\n\nconsole.log(obj); \u002F\u002F no url property here\n",[21,350,351,361,369,373,377,381,389,413,417,427,431],{"__ignoreMap":69},[