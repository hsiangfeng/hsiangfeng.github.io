nd object-level operations come down to three methods:",[36,37,38,45,51],"ul",{},[39,40,41,44],"li",{},[21,42,43],{},"Object.preventExtensions"," — object can't be extended",[39,46,47,50],{},[21,48,49],{},"Object.seal"," — object is sealed",[39,52,53,56],{},[21,54,55],{},"Object.freeze"," — object is frozen",[17,58,59,60,62],{},"Let's start with what ",[21,61,43],{}," actually does. Here's some basic code to work with:",[64,65,70],"pre",{"className":66,"code":67,"language":68,"meta":69,"style":69},"language-js shiki shiki-themes github-dark-high-contrast","var obj = {\n  myName: 'Ray',\n  blog: {},\n};\n","js","",[21,71,72,91,104,110],{"__ignoreMap":69},[73,74,77,81,85,88],"span",{"class":75,"line":76},"line",1,[73,78,80],{"class":79},"sWyjQ","var",[73,82,84],{"class":83},"sMAXC"," obj ",[73,86,87],{"class":79},"=",[73,89,90],{"class":83}," {\n",[73,92,94,97,101],{"class":75,"line":93},2,[73,95,96],{"class":83},"  myName: ",[73,98,100],{"class":99},"sTRMh","'Ray'",[73,102,103],{"class":83},",\n",[73,105,107],{"class":75,"line":106},3,[73,108,109],{"class":83},"  blog: {},\n",[73,111,113],{"class":75,"line":112},4,[73,114,115],{"class":83},"};\n",[17,117,118,119,121,122,125],{},"Using ",[21,120,43],{}," is dead simple. If I want to stop the whole ",[21,123,124],{},"obj"," from ever being extended again, I just write this:",[64,127,129],{"className":66,"code":128,"language":68,"meta":69,"style":69},"var obj = {\n  myName: 'Ray',\n  blog: {},\n};\n\nObject.preventExtensions(obj);\n\nobj.url = 'https:\u002F\u002Fisraynotarray.com\u002F';\nconsole.log(obj); \u002F\u002F no url property here\n",[21,130,131,141,149,153,157,164,177,182,196],{"__ignoreMap":69},[73,132,133,135,137,139],{"class":75,"line":76},[73,134,80],{"class":79},[73,136,84],{"class":83},[73,138,87],{"class":79},[73,140,90],{"class":83},[73,142,143,145,147],{"class":75,"line":93},[73,144,96],{"class":83},[73,146,100],{"class":99},[73,148,103],{"class":83},[73,150,151],{"class":75,"line":106},[73,152,109],{