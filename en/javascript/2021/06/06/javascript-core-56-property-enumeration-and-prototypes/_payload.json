ect property's attributes. And if you want, you can compare the native prototype against the one we defined ourselves:",[28,797,799],{"className":30,"code":798,"language":32,"meta":33,"style":33},"console.log(Object.getOwnPropertyDescriptor(ray.__proto__.__proto__, 'toString'));\n",[35,800,801],{"__ignoreMap":33},[38,802,803,805,807,809,811,813,815,817,819,821,824],{"class":40,"line":41},[38,804,183],{"class":52},[38,806,186],{"class":48},[38,808,726],{"class":52},[38,810,729],{"class":48},[38,812,732],{"class":52},[38,814,199],{"class":59},[38,816,63],{"class":52},[38,818,199],{"class":59},[38,820,784],{"class":52},[38,822,823],{"class":75},"'toString'",[38,825,826],{"class":52},"));\n",[17,828,829],{},"So how do we fix this? It's actually pretty simple. A function is itself a kind of object, so we can adjust the attribute descriptor on the function:",[28,831,833],{"className":30,"code":832,"language":32,"meta":33,"style":33},"function myName() {}\nmyName.prototype.name = 'QQ';\n\nObject.defineProperty(myName.prototype, 'name', {\n  enumerable: false,\n});\n\nvar ray = new myName();\n\nray.a = 'Hello';\n\nfor(var key in ray) {\n  console.log(key);\n}\n",[35,834,835,843,859,863,886,895,900,904,918,922,932,936,951,960],{"__ignoreMap":33},[38,836,837,839,841],{"class":40,"line":41},[38,838,45],{"class":44},[38,840,49],{"class":48},[38,842,53],{"class":52},[38,844,845,847,849,851,853,855,857],{"class":40,"line":56},[38,846,60],{"class":59},[38,848,63],{"class":52},[38,850,66],{"class":59},[38,852,69],{"class":52},[38,854,72],{"class":44},[38,856,76],{"class":75},[38,858,79],{"class":52},[38,860,861],{"class":40,"line":82},[38,862,86],{"emptyLinePlaceholder":85},[38,864,865,868,871,873,875,877,879,881,883],{"class":40,"line":89},[38,866,867],{"class":52},"Object.",[38,869,870],{"class":48},"defineProperty",[38,872,270],{"class":52},[38,874,60],{"class":59},[38,876,63],{"class":52},[38,878,66],{"class":59},[38,880,784],{"class":52},[38,882,607],{"class":75},[38,884,885],