llet ",[38,51,52],{"class":44},"=",[38,54,55],{"class":48}," {\n",[38,57,59,62,66],{"class":40,"line":58},2,[38,60,61],{"class":48},"  total: ",[38,63,65],{"class":64},"sCcAr","100",[38,67,68],{"class":48},",\n",[38,70,72],{"class":40,"line":71},3,[38,73,74],{"class":48},"}\n",[17,76,77,78,81],{},"Normally, if we wanted to change the amount, we'd just write ",[35,79,80],{},"wallet.total = 300;",". We solve it by reassigning the value. But sometimes what we actually want is to do a bit of work when we read or write a value — maybe after you assign something, you want the value you read back to be divided by two. That's exactly when Getter and Setter come in. So what are they?",[83,84,85,89],"ul",{},[86,87,88],"li",{},"Getter: the method for reading a value",[86,90,91],{},"Setter: the method for storing a value",[17,93,94,95,98,99,102],{},"So how do we use them? Every object has a ",[35,96,97],{},"get"," and a ",[35,100,101],{},"set"," — you just add a name after them. The idea feels a lot like a function (but it isn't really a function, so you can't call it like one):",[28,104,106],{"className":30,"code":105,"language":32,"meta":33,"style":33},"var wallet = {\n  total: 100,\n  set save(price) {\n    this.total += price;\n  }\n}\n",[35,107,108,118,126,145,160,166],{"__ignoreMap":33},[38,109,110,112,114,116],{"class":40,"line":41},[38,111,45],{"class":44},[38,113,49],{"class":48},[38,115,52],{"class":44},[38,117,55],{"class":48},[38,119,120,122,124],{"class":40,"line":58},[38,121,61],{"class":48},[38,123,65],{"class":64},[38,125,68],{"class":48},[38,127,128,131,135,138,142],{"class":40,"line":71},[38,129,130],{"class":44},"  set",[38,132,134],{"class":133},"sj_SG"," save",[38,136,137],{"class":48},"(",[38,139,141],{"class":140},"s_sBn","price",[38,143,144],{"class":48},") {\n",[38,146,148,151,154,157],{"class":40,"line":147},4,[38,149,150],{"class":64},"    this",[38,152,153],{"class":48},".total ",[38,155,156],{"class":44},"+=",[38,158,159],{"class":48}," price;\n",[38,161,163],{"class":40,"line":162},5,[38,164,165],{"class":48},"  }\n",[38,167,169],{"class":40,"line":168},6,[38,170,74],{"class":48},[17,172,173,174,177],{},"The thing to notice here is that when you write the amount, you don't do ",[35,175,176],{},"wallet.save(100)"," — you assign to it just like any normal value:",[28,179,181],{"className":30,"code":180,"language":32,"meta":33,"style":33},"var wallet = {\n  total: 100,\n  set save(price) {\n    this.total += price \u002F 2;\n  }\n}\n\nwallet.save = 100;\nconsole.log(wallet.total); \u002F\u002F 150\n",[35,182,183,193,201,213,233,237,241,248,261],{"__ignoreMap":33},[38,184,185,187,189,191],{"class":40,"line":41},[38,186,45],{"class":44},[38,188,49],{"class":48},[38,190,52],{"class":44},[38,192,55],{"class":48},[38,194,195,197,199],{"class":40,"line":58},[38,196,61],{"class":48},[38,198,65],{"class":64},[38,200,68],{"class":48},[38,202,203,205,207,209,211],{"class":40,"line":71},[38,204,130],{"class":44},[38,206,134],{"class":133},[38,208,137],{"class":48},[38,210,141],{"class":140},[38,212,144],{"class":48},[38,214,215,217,219,221,224,227,230],{"class":40,"line":147},[38,216,150],{"class":64},[38,218,153],{"class":48},[38,220,156],{"class":44},[38,222,223],{"class":48}," price ",[38,225,226],{"class":44},"\u002F",[38,228,229],{"class":64}," 2",[38,231,232],{"class":48},";\n",[38,234,235],{"class":40,"line":162},[38,236,165],{"class":48},[38,238,239],{"class":40,"line":168},[38,240,74],{"class":48},[38,242,244],{"class":40,"line":243},7,[38,245,247],{"emptyLinePlaceholder":246},true,"\n",[38,249,251,254,256,259],{"class":40,"line":250},8,[38,252,253],{"class":48},"wallet.save ",[38,255,52],{"class":44},[38,257,258],{"class":64}," 100",[38,260,232],{"class":48},[38,262,264,267,270,273],{"class":40,"line":263},9,[38,265,266],{"class":48},"console.",[38,268,269],{"class":133},"log",[38,271,272],{"class":48},"(wallet.total); ",[38,274,276],{"class":275},"sQrFR","\u002F\u002F 150\n",[17,278,279],{},"So with a Setter we can change what a normal assignment actually does and sneak some logic in.",[17,281,282,283,286],{},"Getter works the same way, except a Getter doesn't take a parameter — it's a way of reading a value. It can still do some work, but keep in mind a Getter has to ",[35,284,285],{},"return"," something:",[28,288,290],{"className":30,"code":289,"language":32,"meta":33,"style":33},"var wallet = {\n  total: 100,\n  set save(price) {\n    this.total += price \u002F 2;\n  },\n  get save() {\n    return this.total \u002F 2;\n  }\n}\n\nwallet.save = 100;\nconsole.log(wallet.total); \u002F\u002F 150\nconsole.log(wallet.save); \u002F\u002F 75\n",[35,291,292,302,310,322,338,343,353,369,373,377,382,393,404],{"__ignoreMap":33},[38,293,294,296,298,300],{"class":40,"line":41},[38,295,45],{"class":44},[38,297,49],{"class":48},[38,299,52],{"class":44},[38,301,55],{"class":48},[38,303,304,306,308],{"class":40,"line":58},[38,305,61],{"class":48},[38,307,65],{"class":64},[38,309,68],{"class":48},[38,311,312,314,316,318,320],{"class":40,"line":71},[38,313,130],{"class":44},[38,315,134],{"class":133},[38,317,137],{"class":48},[38,319,141],{"class":140},[38,321,144],{"class":48},[38,323,324,326,328,330,332,334,336],{"class":40,"line":147},[38,325,150],{"class":64},[38,327,153],{"class":48},[38,329,156],{"class":44},[38,331,223],{"class":48},[38,333,226],{"class":44},[38,335,229],{"class":64},[38,337,232],{"class":48},[38,339,340],{"class":40,"line":162},[38,341,342],{"class":48},"  },\n",[38,344,345,348,350],{"class":40,"line":168},[38,346,347],{"class":44},"  get",[38,349,134],{"class":133},[38,351,352],{"class":48},"() {\n",[38,354,355,358,361,363,365,367],{"class":40,"line":243},[38,356,357],{"class":44},"    return",[38,359,360],{"class":64}," this",[38,362,153],{"class":48},[38,364,226],{"class":44},[38,366,229],{"class":64},[38,368,232],{"class":48},[38,370,371],{"class":40,"line":250},[38,372,165],{"class":48},[38,374,375],{"class":40,"line":263},[38,376,74],{"class":48},[38,378,380]