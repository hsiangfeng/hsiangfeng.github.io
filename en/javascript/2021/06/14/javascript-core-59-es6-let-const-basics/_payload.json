[{"data":1,"prerenderedAt":686},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F06\u002F14\u002Fjavascript-core-59-es6-let-const-basics\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F06\u002F14\u002Fjavascript-core-59-es6-let-const-basics\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F06\u002F14\u002Fjavascript-core-59-es6-let-const-basics\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F06\u002F14\u002Fjavascript-core-59-es6-let-const-basics\u002F":661,"related:\u002Fen\u002Fjavascript\u002F2021\u002F06\u002F14\u002Fjavascript-core-59-es6-let-const-basics\u002F":670},"\u002Fjavascript\u002F20210614\u002F664758344\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":644,"date":645,"description":646,"extension":647,"lang":648,"meta":649,"navigation":135,"path":650,"readingMinutes":651,"seo":652,"standalone":653,"stem":654,"tags":655,"tldr":658,"updated":645,"url":659,"__hash__":660},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-59-es6-let-const-basics.md","JavaScript Core Concepts (59) - ES6: let and const - The Basics","1001092825",{"type":9,"value":10,"toc":639},"minimark",[11,16,20,24,27,43,46,94,100,149,152,223,229,237,259,279,285,341,347,380,388,421,437,476,482,521,529,620,624,635],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Time for a brand new chapter. From this one on, we're getting into ES6 syntax.",[12,21,23],{"id":22},"let-and-const-the-basics","let and const: the basics",[17,25,26],{},"So what's ES6 about, basically? It's there to clean up a bunch of problems we used to run into when writing code. You can think of ES6 as syntactic sugar. And what's syntactic sugar? It's just newer syntax that doesn't change what the language can actually do — it usually just gives you a cleaner, more readable way to write the same thing.",[17,28,29,30,34,35,38,39,42],{},"The ",[31,32,33],"code",{},"let"," and ",[31,36,37],{},"const"," that ES6 brought in are both for declaring variables, same job as the ",[31,40,41],{},"var"," we've been using all along. But in practice they behave a little differently.",[17,44,45],{},"First, in the old way of doing things, we all know variables get hoisted:",[47,48,53],"pre",{"className":49,"code":50,"language":51,"meta":52,"style":52},"language-js shiki shiki-themes github-dark-high-contrast","console.log(myName); \u002F\u002F undefined\nvar myName = 'Ray';\n","js","",[31,54,55,75],{"__ignoreMap":52},[56,57,60,64,68,71],"span",{"class":58,"line":59},"line",1,[56,61,63],{"class":62},"sMAXC","console.",[56,65,67],{"class":66},"sj_SG","log",[56,69,70],{"class":62},"(myName); ",[56,72,74],{"class":73},"sQrFR","\u002F\u002F undefined\n",[56,76,78,81,84,87,91],{"class":58,"line":77},2,[56,79,41],{"class":80},"sWyjQ",[56,82,83],{"class":62}," myName ",[56,85,86],{"class":80},"=",[56,88,90],{"class":89},"sTRMh"," 'Ray'",[56,92,93],{"class":62},";\n",[17,95,96,97,99],{},"That one's not a big deal on its own. The really annoying thing about ",[31,98,41],{}," is that if you declare the same variable twice, it just gets overwritten — no error, nothing:",[47,101,103],{"className":49,"code":102,"language":51,"meta":52,"style":52},"var myName = 'Ray';\nvar myName = 'Ray2';\n\nconsole.log(myName); \u002F\u002F Ray2\n",[31,104,105,117,130,137],{"__ignoreMap":52},[56,106,107,109,111,113,115],{"class":58,"line":59},[56,108,41],{"class":80},[56,110,83],{"class":62},[56,112,86],{"class":80},[56,114,90],{"class":89},[56,116,93],{"class":62},[56,118,119,121,123,125,128],{"class":58,"line":77},[56,120,41],{"class":80},[56,122,83],{"class":62},[56,124,86],{"class":80},[56,126,127],{"class":89}," 'Ray2'",[56,129,93],{"class":62},[56,131,133],{"class":58,"line":132},3,[56,134,136],{"emptyLinePlaceholder":135},true,"\n",[56,138,140,142,144,146],{"class":58,"line":139},4,[56,141,63],{"class":62},[56,143,67],{"class":66},[56,145,70],{"class":62},[56,147,148],{"class":73},"\u002F\u002F Ray2\n",[17,150,151],{},"In real projects, that kind of silent overwrite is exactly how bugs sneak in. And that's before we even get to the scope problem:",[47,153,155],{"className":49,"code":154,"language":51,"meta":52,"style":52},"for(var i = 0; i \u003C 10; i++) {\n  console.log(i); \u002F\u002F 1..2..3..4..5..\n}\nconsole.log(i); \u002F\u002F10\n",[31,156,157,194,207,212],{"__ignoreMap":52},[56,158,159,162,165,167,170,172,176,179,182,185,188,191],{"class":58,"line":59},[56,160,161],{"class":80},"for",[56,163,164],{"class":62},"(",[56,166,41],{"class":80},[56,168,169],{"class":62}," i ",[56,171,86],{"class":80},[56,173,175],{"class":174},"sCcAr"," 0",[56,177,178],{"class":62},"; i ",[56,180,181],{"class":80},"\u003C",[56,183,184],{"class":174}," 10",[56,186,187],{"class":62},"; i",[56,189,190],{"class":80},"++",[56,192,193],{"class":62},") {\n",[56,195,196,199,201,204],{"class":58,"line":77},[56,197,198],{"class":62},"  console.",[56,200,67],{"class":66},[56,202,203],{"class":62},"(i); ",[56,205,206],{"class":73},"\u002F\u002F 1..2..3..4..5..\n",[56,208,209],{"class":58,"line":132},[56,210,211],{"class":62},"}\n",[56,213,214,216,218,220],{"class":58,"line":139},[56,215,63],{"class":62},[56,217,67],{"class":66},[56,219,203],{"class":62},[56,221,222],{"class":73},"\u002F\u002F10\n",[17,224,225,226,228],{},"After all, ",[31,227,41],{}," is function-scoped.",[17,230,231,232,34,234,236],{},"This is where ES6's ",[31,233,33],{},[31,235,37],{}," come in to fix things. Each of these has its own name:",[238,239,240,250],"ul",{},[241,242,243,245],"li",{},[31,244,33],{},[238,246,247],{},[241,248,249],{},"variable",[241,251,252,254],{},[31,253,37],{},[238,255,256],{},[241,257,258],{},"constant",[17,260,261,262,264,265,267,268,270,271,273,274,34,276,278],{},"Let's start with ",[31,263,33],{},". It's really similar to ",[31,266,41],{}," — you can pretty much swap ",[31,269,41],{}," straight out for ",[31,272,33],{}," and it'll keep working. At which point you might ask, \"OK so then what's actually different between ",[31,275,33],{},[31,277,41],{},"?\"",[17,280,281,282,284],{},"The difference is huge. For one, ",[31,283,33],{}," is block-scoped:",[47,286,288],{"className":49,"code":287,"language":51,"meta":52,"style":52},"for(var i = 0; i \u003C 10; i++) {\n  console.log(i); \u002F\u002F 1..2..3..4..5..\n}\nconsole.log(i); \u002F\u002F i is not defined\n",[31,289,290,316,326,330],{"__ignoreMap":52},[56,291,292,294,296,298,300,302,304,306,308,310,312,314],{"class":58,"line":59},[56,293,161],{"class":80},[56,295,164],{"class":62},[56,297,41],{"class":80},[56,299,169],{"class":62},[56,301,86],{"class":80},[56,303,175],{"class":174},[56,305,178],{"class":62},[56,307,181],{"class":80},[56,309,184],{"class":174},[56,311,187],{"class":62},[56,313,190],{"class":80},[56,315,193],{"class":62},[56,317,318,320,322,324],{"class":58,"line":77},[56,319,198],{"class":62},[56,321,67],{"class":66},[56,323,203],{"class":62},[56,325,206],{"class":73},[56,327,328],{"class":58,"line":132},[56,329,211],{"class":62},[56,331,332,334,336,338],{"class":58,"line":139},[56,333,63],{"class":62},[56,335,67],{"class":66},[56,337,203],{"class":62},[56,339,340],{"class":73},"\u002F\u002F i is not defined\n",[17,342,343,344,346],{},"On top of that, ",[31,345,33],{}," can't be redeclared:",[47,348,350],{"className":49,"code":349,"language":51,"meta":52,"style":52},"let myName = 'Ray';\nlet myName = 'Ray2'; \u002F\u002F Uncaught SyntaxError: Identifier 'myName' has already been declared\n",[31,351,352,364],{"__ignoreMap":52},[56,353,354,356,358,360,362],{"class":58,"line":59},[56,355,33],{"class":80},[56,357,83],{"class":62},[56,359,86],{"class":80},[56,361,90],{"class":89},[56,363,93],{"class":62},[56,365,366,368,370,372,374,377],{"class":58,"line":77},[56,367,33],{"class":80},[56,369,83],{"class":62},[56,371,86],{"class":80},[56,373,127],{"class":89},[56,375,376],{"class":62},"; ",[56,378,379],{"class":73},"\u002F\u002F Uncaught SyntaxError: Identifier 'myName' has already been declared\n",[17,381,382,384,385,387],{},[31,383,37],{}," is a little simpler. A variable declared with ",[31,386,37],{}," can't be reassigned a new value:",[47,389,391],{"className":49,"code":390,"language":51,"meta":52,"style":52},"const myName = 'Ray';\nmyName = 'Ray2'; \u002F\u002F Uncaught TypeError: Assignment to constant variable.\n",[31,392,393,407],{"__ignoreMap":52},[56,394,395,397,400,403,405],{"class":58,"line":59},[56,396,37],{"class":80},[56,398,399],{"class":174}," myName",[56,401,402],{"class":80}," =",[56,404,90],{"class":89},[56,406,93],{"class":62},[56,408,409,412,414,416,418],{"class":58,"line":77},[56,410,411],{"class":62},"myName ",[56,413,86],{"class":80},[56,415,127],{"class":89},[56,417,376],{"class":62},[56,419,420],{"class":73},"\u002F\u002F Uncaught TypeError: Assignment to constant variable.\n",[17,422,423,424,428,429,34,431,433,434,436],{},"Now here's a special case. You ",[425,426,427],"em",{},"can"," mix ",[31,430,41],{},[31,432,33],{}," (mixing is generally a bad idea though — the scopes are different, so it's easy to trip yourself up). But if ",[31,435,33],{}," comes first, you get an error:",[47,438,440],{"className":49,"code":439,"language":51,"meta":52,"style":52},"let myName = 'Ray';\nvar myName = 'Ray2';\nconsole.log(myName); \u002F\u002F Uncaught SyntaxError: Identifier 'myName' has already been declared\n",[31,441,442,454,466],{"__ignoreMap":52},[56,443,444,446,448,450,452],{"class":58,"line":59},[56,445,33],{"class":80},[56,447,83],{"class":62},[56,449,86],{"class":80},[56,451,90],{"class":89},[56,453,93],{"class":62},[56,455,456,458,460,462,464],{"class":58,"line":77},[56,457,41],{"class":80},[56,459,83],{"class":62},[56,461,86],{"class":80},[56,463,127],{"class":89},[56,465,93],{"class":62},[56,467,468,470,472,474],{"class":58,"line":132},[56,469,63],{"class":62},[56,471,67],{"class":66},[56,473,70],{"class":62},[56,475,379],{"class":73},[17,477,478,479,481],{},"And the other way around — ",[31,480,41],{}," declared first — still throws an error:",[47,483,485],{"className":49,"code":484,"language":51,"meta":52,"style":52},"var myName = 'Ray';\nlet myName = 'Ray2';\nconsole.log(myName); \u002F\u002F Uncaught SyntaxError: Identifier 'myName' has already been declared\n",[31,486,487,499,511],{"__ignoreMap":52},[56,488,489,491,493,495,497],{"class":58,"line":59},[56,490,41],{"class":80},[56,492,83],{"class":62},[56,494,86],{"class":80},[56,496,90],{"class":89},[56,498,93],{"class":62},[56,500,501,503,505,507,509],{"class":58,"line":77},[56,502,33],{"class":80},[56,504,83],{"class":62},[56,506,86],{"class":80},[56,508,127],{"class":89},[56,510,93],{"class":62},[56,512,513,515,517,519],{"class":58,"line":132},[56,514,63],{"class":62},[56,516,67],{"class":66},[56,518,70],{"class":62},[56,520,379],{"class":73},[17,522,523,524,34,526,528],{},"Now, since I mentioned ",[31,525,33],{},[31,527,37],{}," are block-scoped, if you really do want to \"redeclare\" the name, you can write it like this:",[47,530,532],{"className":49,"code":531,"language":51,"meta":52,"style":52},"let myName = 'Ray';\nconsole.log('A:', myName); \u002F\u002F A: Ray\n{\n  let myName = 'Ray2';\n  console.log('B:', myName); \u002F\u002F B: Ray2\n}\nconsole.log('C:', myName); \u002F\u002F C: Ray\n",[31,533,534,546,563,568,581,598,603],{"__ignoreMap":52},[56,535,536,538,540,542,544],{"class":58,"line":59},[56,537,33],{"class":80},[56,539,83],{"class":62},[56,541,86],{"class":80},[56,543,90],{"class":89},[56,545,93],{"class":62},[56,547,548,550,552,554,557,560],{"class":58,"line":77},[56,549,63],{"class":62},[56,551,67],{"class":66},[56,553,164],{"class":62},[56,555,556],{"class":89},"'A:'",[56,558,559],{"class":62},", myName); ",[56,561,562],{"class":73},"\u002F\u002F A: Ray\n",[56,564,565],{"class":58,"line":132},[56,566,567],{"class":62},"{\n",[56,569,570,573,575,577,579],{"class":58,"line":139},[56,571,572],{"class":80},"  let",[56,574,83],{"class":62},[56,576,86],{"class":80},[56,578,127],{"class":89},[56,580,93],{"class":62},[56,582,584,586,588,590,593,595],{"cla