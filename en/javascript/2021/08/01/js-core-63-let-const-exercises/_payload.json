],{},[105,188,189],{},[35,190,191],{},"Casper",[105,193,194],{},[35,195,118],{},[105,197,198],{},[35,199,113],{},[105,201,202],{},[35,203,123],{},[125,205,206,208,211],{},[128,207,130],{},[17,209,210],{},"The answer is: \"3\"",[17,212,213,214,216,217,219],{},"In ES6, both ",[35,215,63],{}," and ",[35,218,149],{}," have the temporal dead zone problem.",[12,221,223],{"id":222},"question-3","Question 3",[17,225,226,227,230],{},"Same idea as before — if we move the ",[35,228,229],{},"console.log()"," to after the declaration, what do we get?",[28,232,234],{"className":30,"code":233,"language":32,"meta":33,"style":33},"let a;\nconsole.log(a);\n",[35,235,236,243],{"__ignoreMap":33},[38,237,238,240],{"class":40,"line":41},[38,239,63],{"class":62},[38,241,242],{"class":48}," a;\n",[38,244,245,247,249],{"class":40,"line":52},[38,246,160],{"class":48},[38,248,84],{"class":44},[38,250,165],{"class":48},[102,252,253,257,261,265],{},[105,254,255],{},[35,256,113],{},[105,258,259],{},[35,260,118],{},[105,262,263],{},[35,264,45],{},[105,266,267],{},[35,268,123],{},[125,270,271,273,275],{},[128,272,130],{},[17,274,133],{},[17,276,277,278,280,281,283],{},"If a ",[35,279,63],{}," variable isn't assigned a value, it defaults to ",[35,282,118],{},".",[12,285,287],{"id":286},"question-4","Question 4",[17,289,290],{},"Same as above, but with const instead?",[28,292,294],{"className":30,"code":293,"language":32,"meta":33,"style":33},"const a;\nconsole.log(a);\n",[35,295,296,304],{"__ignoreMap":33},[38,297,298,300,302],{"class":40,"line":41},[38,299,149],{"class":62},[38,301,66],{"class":176},[38,303,184],{"class":48},[38,305,306,308,310],{"class":40,"line":52},[38,307,160],{"class":48},[38,309,84],{"class":44},[38,311,165],{"class":48},[102,313,314,318,322,326],{},[105,315,316],{},[35,317,123],{},[105,319,320],{},[35,321,113],{},[105,323,324],{},[35,325,118],{},[105,327,328],{},"None of the above",[125,330,331,333,336],{},[128,332,130],{},[17,334,335],{},"The answer is: \"1\"",[17,337,338,339,341,342,283],{},"A ",[35,340,149],{}," has to be assigned a value, otherwise you get a ",[35,343,123],{},[12,345,347],{"id":346},"question-5","Question 5",[17,349,350,351,353],{},"What will ",[35,352,229],{}," show here?",[28,355,357],{"className":30,"code":356,"language":32,"meta":33,"style":33},"const array = [];\narray.push('Casper');\nconsole.log(array);\n",[35,358,359,371,386],{"__ignoreMap":33},[38,360,361,363,366,368],{"class":40,"line":41},[38,362,149],{"class":62},[38,364,365],{"class":176}," array",[38,367,69],{"class":62},[38,369,370],{"class":48}," [];\n",[38,372,373,376,379,381,384],{"class":40,"line":52},[38,374,375],{"class":48},"array.",[38,377,378],{"class":44},"push",[38,380,87],{"class":48},[38,382,383],{"class":90},"'Casper'",[38,385,94],{"class":48},[38,387,388,390,392],{"class":40,"line":59},[38,389,160],{"class":48},[38,391,84],{"class":44},[38,393,394],{"class":48},"(array);\n",[102,396,397,401,405,410],{},[105,398,399],{},[35,400,113],{},[105,402,403],{},[35,404,123],{},[105,406,407],{},[35,408,409],{},"[]",[105,411,412],{},[35,413,414],{},"['Casper']",[125,416,417,419,422],{},[128,418,130],{},[17,420,421],{},"The answer is: \"4\"",[17,423,424,425,427],{},"Yes, ",[35,426,149],{}," is an immutable constant — but for objects or arrays, modifying the values or properties inside doesn't really matter. When a variable points to one of these, it points to a memory location, and we haven't changed that memory location (we didn't swap in a brand new array or object).",[12,429,431],{"id":430},"question-6","Question 6",[17,433,434,435,150],{},"What's the result of ",[35,436,229],{},[28,438,440],{"className":30,"code":439,"language":32,"meta":33,"style":33},"let a = 10;\nfunction fu() {\n  console.log(a);\n  let a = 20;\n}\n\nfu();\n",[35,441,442,457,467,475,489,493,498],{"__ignoreMap":33},[38,443,444,446,449,452,455],{"class":40,"line":41},[38,445,63],{"class":62},[38,447,448],{"class":48}," a ",[38,450,451],{"class":62},"=",[38,453,454],{"class":