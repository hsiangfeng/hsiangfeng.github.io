2);\nconsole.log('a:', a);\nconsole.log('b:', b);\n","js","",[49,50,51,83,103],"code",{"__ignoreMap":47},[52,53,56,60,64,67,70,74,77,80],"span",{"class":54,"line":55},"line",1,[52,57,59],{"class":58},"sWyjQ","var",[52,61,63],{"class":62},"sMAXC"," a, b ",[52,65,66],{"class":58},"=",[52,68,69],{"class":62}," (",[52,71,73],{"class":72},"sCcAr","1",[52,75,76],{"class":62},", ",[52,78,79],{"class":72},"2",[52,81,82],{"class":62},");\n",[52,84,86,89,93,96,100],{"class":54,"line":85},2,[52,87,88],{"class":62},"console.",[52,90,92],{"class":91},"sj_SG","log",[52,94,95],{"class":62},"(",[52,97,99],{"class":98},"sTRMh","'a:'",[52,101,102],{"class":62},", a);\n",[52,104,106,108,110,112,115],{"class":54,"line":105},3,[52,107,88],{"class":62},[52,109,92],{"class":91},[52,111,95],{"class":62},[52,113,114],{"class":98},"'b:'",[52,116,117],{"class":62},", b);\n",[17,119,120,121,123,124,127],{},"Before you scroll down, take a second and guess what ",[49,122,28],{}," and ",[49,125,126],{},"b"," are.",[129,130,131,140,147,155],"ol",{},[132,133,134,76,137],"li",{},[49,135,136],{},"a: 1",[49,138,139],{},"b: 2",[132,141,142,76,145],{},[49,143,144],{},"a: undefined",[49,146,139],{},[132,148,149,76,152],{},[49,150,151],{},"a: 2",[49,153,154],{},"b: 1",[132,156,157,76,159],{},[49,158,136],{},[49,160,161],{},"b: undefined",[163,164,165,169,176],"details",{},[166,167,168],"summary",{},"Click for the answer (think it through first)",[17,170,171,172,76,174],{},"The answer is ",[49,173,144],{},[49,175,139],{},[17,177,178],{},"Did you get it right?",[12,180,182],{"id":181},"breaking-it-down","Breaking it down",[17,184,185],{},"Let's take this thing apart piece by piece.",[17,187,188,189,192,193,197,198,202,203,205],{},"First up is the ",[49,190,191],{},"var a, b"," part. This is a multiple variable declaration — meaning we're declaring more than one variable at once. Why does that matter? Well, in \"",[28,194,196],{"href":195},"\u002Fjavascript\u002F20200726\u002F2777973914\u002F","JavaScript Core Concepts (23) - Objects - Extra: the difference between variables and object properties (article in Mandarin)","\" I mentioned that if you ",[199,200,201],"em",{},"don't"," use ",[49,204,59],{}," to declare something, it's really just a property added to an object, which means it can be deleted. So we can try this:",[42,207,209],{"className":44,"code":208,"language":46,"meta":47,"style":47},"var a, b\n\ndelete a; \u002F\u002F false\ndelete b; \u002F\u002F false\n",[49,210,211,218,224,236],{"__ignoreMap":47},[52,212,213,215],{"class":54,"line":55},[52,214,59],{"class":58},[52,216,217],{"class":62}," a, b\n",[52,219,220],{"class":54,"line":85},[52,221,223],{"emptyLinePlaceholder":222},true,"\n",[52,225,226,229,232],{"class":54,"line":105},[52,227,228],{"class":58},"delete",[52,230,231],{"class":62}," a; ",[52,233,235],{"class":234},"sQrFR","\u002F\u002F false\n",[52,237,239,241,244],{"class":54,"line":238},4,[52,240,228],{"class":58},[52,242,243],{"class":62}," b; ",[52,245,235],{"class":234},[17,247,248,249,252,253,123,255,257,258,261],{},"Both return ",[49,250,251],{},"false",", which tells us ",[49,254,28],{},[49,256,126],{}," are genuinely declared variables. Okay, next up is ",[49,259,260],{},"(1, 2)",". The outermost thing here is the grouping operator (the parentheses), and what does that do? MDN explains it like this:",[263,264,265],"blockquote",{},[17,266,267,268,271],{},"The grouping operator ",[49,269,270],{},"( )"," controls the precedence of evaluation in expressions.",[17,273,274],{},"In short, it's used to control the precedence of an expression. For example:",[42,276,278],{"className":44,"code":277,"language":46,"meta":47,"style":47},"3 + 3 * 2; \u002F\u002F 9\n",[49,279,280],{"__ignoreMap":47},[52,281,282,285,288,291,294,297,300],{"class":54,"line":55},[52,283,284],{"class":72},"3",[52,286,287],{"class":58}," +",[52,289,290],{"class":72}," 3",[52,292,293],{"class":58}," *",[52,295,296],{"class":72}," 2",[52,298,299],{"class":62},"; ",[52,301,302],{"class":234},"\u002F\u002F 9\n",[17,304,305],{},"Wrap part of it in the grouping operator and you get:",[42,307,309],{"className":44,"code":308,"language":46,"meta":47,"style":47},"(3 + 3) * 2; \u002F\u002F 12\n",[49,310,311],{"__ignoreMap":47},[52,312,313,315,317,319,321,324,327,329,331],{"class":54,"line":55},[52,314,95],{"class":62},[52,316,284],{"class":72},[52,318,287],{"class":58},[52,320,290],{"class":72},[52,322,323],{"class":62},") ",[52,325,326],{"class":58},"*",[52,328,296],{"class":72},[52,330,299],{"class":62},[52,332,333],{"class":234},"\u002F\u002F 12\n",[17,335,336,337,342],{},"There's a key phrase in that MDN line — \"precedence of evaluation in expressions\" — which tells us the comma inside is an expression. So let's go look up the ",[28,338,341],{"href":339,"rel":340},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FOperators\u002FComma_Operator",[32],"comma operator",". MDN describes how it works:",[263,344,345],{},[17,346,347],{},"The comma operator (,) evaluates each of its operands (from left to right) and returns the value of the last operand.",[17,349,350],{},"So basically the comma operator evaluates from left to right and returns the value of the last one. We can test it like this:",[42,352,354],{"className":44,"code":353,"language":46,"meta":47,"style":47},"1, 2, 3, 4, 5; \u002F\u002F 5\n",[49,355,356],{"__ignoreMap":47},[52,357,358,360,362,364,366,368,370,373,375,378,380],{"class":54,"line":55},[52,359,73],{"class":72},[52,361,76],{"class":62},[52,363,79],{"class":72},[52,365,76],{"class":62},[52,367,284],{"class":72},[52,369,76],{"class":62},[52,371,372],{"class":72},"4",[52,374,76],{"class":62},[52,376,377],{"class":72},"5",[52,379,299],{"class":62},[52,381,382],{"class":234},"\u002F\u002F 5\n",[17,384,385,386,389],{},"(Don't write ",[49,387,388],{},"console.log(1,2,3,4,5);"," — that'll just log all of them.)",[17,391,392],{},"So you can also play around with it like this:",[42,394,396],{"className":44,"code":395,"language":46,"meta":47,"style":47},"3 * 3, 9 * 9; \u002F\u002F 81\n",[49,397,398],{"__ignoreMap":47},[52,399,400,402,404,406,408,411,413,416,418],{"class":54,"line":55},[52,401,284],{"class":72},[52,403,293],{"class":58},[52,405,290],{"class":72},[52,407,76],{"class":62},[52,409,410],{"class":72},"9",[52,412,293],{"class":58},[52,414,415],{"class":72}," 9",[52,417,299],{"class":62},[52,419,420],{"class":234},"\u002F\u002F 81\n",[17,422,423,424,427,428,430,431,433,434,436,437,439,440,443],{},"Now let's go back to the puzzle: ",[49,425,426],{},"var a, b = (1, 2);",". From the examples above we know the comma operator always returns the second value, so out of ",[49,429,191],{},", it's ",[49,432,126],{}," that gets assigned the result of ",[49,435,260],{},". And ",[49,438,28],{},"? Because of the comma operator, it just gets ignored — so it ends up as ",[49,441,442],{},"undefined",".",[17,445,446],{},"Which means you can probably tell exactly what this one outputs now:",[42,448,450],{"className":44,"code":449,"language":46,"meta":47,"style":47},"var a, b = (1, 2 * 2, 8 \u002F 2);\nconsole.log('a:', a);\nconsole.log('b:', b);\n",[49,451,452,484,496],{"__ignoreMap":47},[52,453,454,456,458,460,462,464,466,468,470,472,474,477,480,482],{"class":54,"line":55},[52,455,59],{"class":58},[52,457,63],{"class":62},[52,459,66],{"class":58},[52,461,69],{"class":62},[52,463,73],{"class":72},[52,465,76],{"class":62},[52,467,79],{"class":72},[52,469,293],{"class":58},[52,471,296],{"class":72},[52,473,76],{"class":62},[52,475,476],{"class":72},"8",[52,478,479],{"class":58}," \u002F",[52,481,296],{"class":72},[52,483,82],{"class":62},[52,485,486,488,490,492,494],{"class":54,"line":85},[52,487,88],{"class":62},[52,489,92],{"class":91},[52,491,95],{"class":62},[52,493,99],{"class":98},[52,495,102],{"class":62},[52,497,498,500,502,504,506],{"class":54,"line":105},[52,499,88],{"class":62},[52,501,92],{"class":91},[52,503,95],{"class":62},[52,505,114],{"c