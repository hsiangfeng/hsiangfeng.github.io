{\n  setTimeout(function () {\n    console.log('Run number ' + i);\n  }, 1000);\n}\nconsole.log(i);\n","js","",[21,44,45,89,104,125,137,143],{"__ignoreMap":42},[46,47,50,54,58,61,64,67,71,74,77,80,83,86],"span",{"class":48,"line":49},"line",1,[46,51,53],{"class":52},"sWyjQ","for",[46,55,57],{"class":56},"sMAXC","(",[46,59,60],{"class":52},"var",[46,62,63],{"class":56}," i ",[46,65,66],{"class":52},"=",[46,68,70],{"class":69},"sCcAr"," 0",[46,72,73],{"class":56},"; i ",[46,75,76],{"class":52},"\u003C",[46,78,79],{"class":69}," 10",[46,81,82],{"class":56},"; i",[46,84,85],{"class":52},"++",[46,87,88],{"class":56},") {\n",[46,90,92,96,98,101],{"class":48,"line":91},2,[46,93,95],{"class":94},"sj_SG","  setTimeout",[46,97,57],{"class":56},[46,99,100],{"class":52},"function",[46,102,103],{"class":56}," () {\n",[46,105,107,110,113,115,119,122],{"class":48,"line":106},3,[46,108,109],{"class":56},"    console.",[46,111,112],{"class":94},"log",[46,114,57],{"class":56},[46,116,118],{"class":117},"sTRMh","'Run number '",[46,120,121],{"class":52}," +",[46,123,124],{"class":56}," i);\n",[46,126,128,131,134],{"class":48,"line":127},4,[46,129,130],{"class":56},"  }, ",[46,132,133],{"class":69},"1000",[46,135,136],{"class":56},");\n",[46,138,140],{"class":48,"line":139},5,[46,141,142],{"class":56},"}\n",[46,144,146,149,151],{"class":48,"line":145},6,[46,147,148],{"class":56},"console.",[46,150,112],{"class":94},[46,152,153],{"class":56},"(i);\n",[17,155,156,157,160,161,164,165,168],{},"Take a second and think about it. We expect the outer ",[21,158,159],{},"i"," to be ",[21,162,163],{},"10",", sure — but what does ",[21,166,167],{},"console.log('Run number ' + i);"," actually print?",[17,170,171,172,174],{},"If you've got a decent handle on ",[21,173,60],{},"'s scope and the event queue, you can probably call the answer right away. But let me walk through how this code runs anyway.",[17,176,177,178,181],{},"The loop runs ten times, and each time it runs it sets up a timer — so you end up with ten timers. You'd think you'd see ten different messages, one for each run. But what you actually get is ",[21,179,180],{},"Run number 10"," printed ten times.",[17,183,184],{},[185,186],"img",{"alt":180,"src":187},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-07-10%2022.22.27.png",[17,189,190,191,193,194,197,198,201],{},"The reason comes down to ",[21,192,60],{}," being function-scoped. So the ",[21,195,196],{},"var i = 0; i \u003C 10; i++"," you wrote inside the for loop is actually declared on ",[21,199,200],{},"window"," — it's a global variable.",[17,203,204,205,208,209,212,213,215,216,218,219,221],{},"And the ",[21,206,207],{},"setTimeout"," inside is an async event, so it gets dropped into the event queue. It only runs after everything else has finished (including the loop running all the way through and hitting the outer ",[21,210,211],{},"console","). By that point, the ",[21,214,159],{}," it grabs is the global ",[21,217,159],{},", not some per-iteration ",[21,220,159],{}," from the loop. Not following? Try running this version to see it:",[37,223,225],{"className":39,"code":224,"language":41,"meta":42,"style":42},"for(var i = 0; i \u003C 10; i++) {\n  console.log('Run number ' + i);\n}\nconsole.log(i);\n",[21,226,227,253,268,272],{"__ignoreMap":42},[46,228,229,231,233,235,237,239,241,243,245,247,249,251],{"class":48,"line":49},[46,230,53],{"class":52},[46,232,57],{"class":56},[46,234,60],{"class":52},[46,236,63],{"class":56},[46,238,66],{"class":52},[46,240,70],{"class":69},[46,242,73],{"class":56},[46,244,76],{"class":52},[46,246,79],{"class":69},[46,248,82],{"class":56},[46,250,85],{"class":52},[46,252,88],{"class":56},[46,254,255,258,260,262,264,266],{"class":48,"line":91},[46,256,257],{"class":56},"  console.",[46,259,112],{"class":94},[46,261,57],{"class":56},[46,263,118],{"class":117},[46,265,121],{"class":52},[46,267,124],{"class":56},[46,269,270],{"class":48,"line":106},[46,271,142],{"class":56},[46,273,274,276,278],{"class":48,"line":127},[46,275,148],{"class":56},[46,277,112],{"class":94},[46,279,153],{"class":56},[17,281,282,283,286,287,290,291,293,294,296,297,299],{},"Now, if what you actually want is ",[21,284,285],{},"Run number 0",", ",[21,288,289],{},"Run number 1",", and so on inside ",[21,292,207],{},", you can fix it with ",[21,295,23],{},". ",[21,298,23],{}," is block-scoped, so the variable only lives inside the block for that iteration:",[37,301,303],{"className":39,"code":302,"language":41,"meta":42,"style":42},"for(let i = 0; i \u003C 10; i++) {\n  setTimeout(function () {\n    console.log('Run number ' + i);\n  }, 1000);\n}\nconsole.log(i);\n",[21,304,305,331,341,355,363,367],{"__ignoreMap":42},[46,306,307,309,311,313,315,317,319,321,323,325,327,329],{"class":48,"line":49},[46,308,53],{"class":52},[46,310,57],{"class":56},[46,312,23],{"class":52},[46,314,63],{"class":56},[46,316,66],{"class":52},[46,318,70],{"class":69},[46,320,73],{"class":56},[46,322,76],{"class":52},[46,324,79],{"class":69},[46,326,82],{"class":56},[46,328,85],{"class":52},[46,330,88],{"class":56},[46,332,333,335,337,339],{"class":48,"line":91},[46,334,95],{"class":94},[46,336,57],{"class":56},[46,338,100],{"class":52},[46,340,103],{"class":56},[46,342,343,345,347,349,351,353],{"class":48,"line":106},[46,344,109],{"class":56},[46,346,112],{"class":94},[46,348,57],{"class":56},[46,350,118],{"class":117},[46,352,121],{"class":52},[46,354,124],{"class":56},[46,356,357,359,361],{"class":48,"line":127},[46,358,130],{"class":56},[46,360,133],{"class":69},[46,362,136],{"class":56},[46,364,365],{"class":48,"line":139},[46,366,142],{"class":56},[46,368,369,371,373],{"class":48,"line":145},[46,370,148],{"class":56},[46,372,112],{"class":94},[46,374,153],{"class":56},[17,376,377,378,381],{},"This is also why you'll get a ",[21,379,380],{},"VM111:6 Uncaught ReferenceError: i is not defined"," error.",[17,383,384],{},[185,385],{"alt":386,"src":387},"i is not defined","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-07-10%2022.32.16.png",[17,389,390,391,393,394,396,397,399,400,402,403,405],{},"Beyond ",[21,392,23],{},"'s scope, there's a closure thing going on here too — memory getting stashed somewhere because you plan to use it. Since we're holding onto ",[21,395,159],{},", that forms a simple closure. Every time the loop iterates, it'd normally release the memory inside it. But because our ",[21,398,207],{}," points at ",[21,401,159],{},", that memory can't be freed — which is exactly why we can still read ",[21,404,159],{}," correctly later.",[17,407,408,409,411,412,414],{},"As for ",[21,410,27],{},", we said in an earlier chapter it's a constant — you can't reassign it. But if your ",[21,413,27],{}," points at an object, you might run into something like this:",[37,416,418],{"className":39,"code":417,"language":41,"meta":42,"style":42},"const obj = {\n  myName: 'Ray',\n}\n\nobj.myName = 'https:\u002F\u002Fisraynotarray.com\u002F';\n",[21,419,420,433,444,448,454],{"__ignoreMap":42},[46,421,422,424,427,430],{"class":48,"line":49},[46,423,27],{"class":52},[46,425,426],{"class":69}," obj",[46,428,429],{"class":52}," =",[46,431,432],{"class":56}," {\n",[46,434,435,438,441],{"class":48,"line":91},[46,436,437],{"class":56},"  myName: ",[46,439,440],{"class":117},"'Ray'",[46,442,443],{"class":56},",\n",[46,445,446],{"class":48,"line":106},[46,447,142],{"class":56},[46,449,450],{"class":48,"line":127},[46,451,453],{"emptyLinePlaceholder":452},true,"\n",[46,455,456,459,461,464],{"class":48,"line":139},[46,457,458],{"class":56},"obj.myName ",[46,460,66],{"class":52},[46,462,463],{"class":117}," 'https:\u002F\u002Fisraynotarray.com\u002F'",[46,465,466],{"class":56},";\n",[17,468,469,470,472,473,476],{},"You might find it weird that there's no error, no warning, nothing. The reason is that the ",[21,471,27],{}," points at the object's memory. When you do ",[21,474,475],{},"obj.myName",", you're not changing the object's memory location — you're just modifying a property inside it. So nothing breaks. This is the \"objects are passed by reference\" idea.",[17,478,479],{},"You only get an error if you reassign the whole object:",[37,481,483],{"className":39,"code":482,"language":41,"meta":42,"style":42},"const obj = {\n  myName: 'Ray',\n}\n\nobj.myName = 'https:\u002F\u002Fisraynotarray.com\u002F';\n\nobj = {};\n",[21,484,485,495,503,507,511,521,525],{"__ignoreMap":42},[46,486,487,489,491,493],{"class":48,"line":49},[46,488,27],{"class":52},[46,490,426],{"class":69},[46,492,429],{"class":52},[46,494,432],{"class":56},[46,496,497,499,501],{"class":48,"line":91},[46,498,437],{"class":56},[46,500,440],{"class":117},[46,502,443],{"class":56},[46,504,505],{"class":48,"line":106},[46,506,142],{"class":56},[46,508,509],{"class":48,"line":127},[46,510,453],{"emptyLinePlaceholder":452},[46,512,513,515,517,519],{"class":48,"line":139},[46,514,458],{"class":56},[46,516,66],{"class":52},[46,518,463],{"class":117},[46,520,466],{"class":56},[46,522,523],{"class":48,"line":145},[46,524,453],{"emptyLinePlaceholder":452},[46,526,528,531,533],{"class":48,"line":527},7,[46,529,530],{"class":56},"obj ",[46,532,66],{"class":52},[46,534,535],{"class":56}," {};\n",[17,537,538],{},[185,539],{"alt":540,"src":541},"Uncaught TypeError: Assignment to constant variable.","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-07-10%2022.45.42.png",[17,543,544,545,548],{},"At this point you might be thinking — okay, beyond locking the object's memory location, I'd also like the object's properties locked the same way. For that you can reach for ",[21,546,547],{},"Object.freeze"," from the objects chapter to freeze the whole thing:",[37,550,552],{"className":39,"code":551,"language":41,"meta":42,"style":42},"const obj = {\n  myName: 'Ray',\n}\n\nObject.freeze(obj);\n\nobj.myName = 'https:\u002F\u002Fisraynotarray.com\u002F';\nconsole.log(obj);\n",[21,553,554,564,572,576,580,591,595,605],{"__ignoreMap":42},[46,555,556,558,560,562],{"class":48,"line":49},[46,557,27],{"class":52},[46,559,426],{"class":69},[46,561,429],{"class":52},[46,563,432],{"class":56},[46,565,566,568,570],{"class":48,"line":91},[46,567,437],{"class":56},[46,569,440],{"class":117},[46,571,443],{"class":56},[46,573,574],{"class":48,"line":106},[46,575,142],{"class":56},[46,577,578],{"class":48,"line":127},[46,579,453],{"emptyLinePlaceholder":452},[46,581,582,585,588],{"class":48,"line":139},[46,583,584],{"class":56},"Object.",[46,586,587],{"class":94},"freeze",[46,589,590],{"class":56},"(obj);\n",[46,592,593],{"class":48,"line":145},[46,594,453],{"emptyLinePlaceholder":452},[46,596,597,599,601,603],{"class":48,"line":527},[46,598,458],{"class":56},[46,600,66],{"class":52},[46,602,463],{"class":117},[46,604,466],{"class":56},[46,606,608,610,612],{"class":48,"line":607},8,[46,609,148],{"class":56},[46,611,112],{"class":94},[46,613,590],{"class":56},[17,615,616],{},[185,617],{"alt":547,"src":618},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-07-10%2022.49.20.png",[17,620,621,622,625],{},"And again you might find it weird — JavaScript won't let you modify it, but it doesn't throw any error either. That's a silent error. To surface it, try adding ",[21,623,624],{},"'use strict'",":",[37,627,629],{"className":39,"code":628,"language":41,"meta":42,"style":42},"'use strict'\nconst obj = {\n  myName: 'Ray',\n}\n\nObject.freeze(obj);\n\nobj.myName = 'https:\u002F\u002Fisraynotarray.com\u002F';\nconsole.log(obj);\n",[21,630,631,636,646,654,658,662,670,674,684],{"__ignoreMap":42},[46,632,633],{"class":48,"line":49},[46,634,635],{"class":117},"'use strict'\n",[46,