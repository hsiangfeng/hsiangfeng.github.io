,823,824],{"class":82},"){\n",[68,826,827],{"class":70,"line":126},[68,828,829],{"class":74},"  ...\n",[68,831,832],{"class":70,"line":132},[68,833,129],{"class":82},[12,835,836,837,839],{},"Why bring this up? Mainly because when we work with arrays, we usually do some operation on them — like adding ",[54,838,767],{}," to every number.",[59,841,843],{"className":61,"code":842,"language":63,"meta":64,"style":64},"var list = [1, 2, 3];\n\nfor(var i = 0; i \u003C list.length; i+=1){\n  list[i] +=1;\n}\n\nconsole.log(list); \u002F\u002F [ 2, 3, 4 ]\n",[54,844,845,867,871,901,912,916,920],{"__ignoreMap":64},[68,846,847,849,851,853,855,857,859,861,863,865],{"class":70,"line":71},[68,848,194],{"class":74},[68,850,759],{"class":82},[68,852,200],{"class":74},[68,854,764],{"class":82},[68,856,767],{"class":409},[68,858,770],{"class":82},[68,860,773],{"class":409},[68,862,770],{"class":82},[68,864,778],{"class":409},[68,866,781],{"class":82},[68,868,869],{"class":70,"line":93},[68,870,136],{"emptyLinePlaceholder":135},[68,872,873,875,877,879,881,883,885,887,889,891,893,895,897,899],{"class":70,"line":111},[68,874,742],{"class":74},[68,876,83],{"class":82},[68,878,194],{"class":74},[68,880,796],{"class":82},[68,882,200],{"class":74},[68,884,801],{"class":409},[68,886,804],{"class":82},[68,888,807],{"class":74},[68,890,810],{"class":82},[68,892,813],{"class":409},[68,894,816],{"class":82},[68,896,819],{"class":74},[68,898,767],{"class":409},[68,900,824],{"class":82},[68,902,903,906,908,910],{"class":70,"line":126},[68,904,905],{"class":82},"  list[i] ",[68,907,819],{"class":74},[68,909,767],{"class":409},[68,911,206],{"class":82},[68,913,914],{"class":70,"line":132},[68,915,129],{"class":82},[68,917,918],{"class":70,"line":139},[68,919,136],{"emptyLinePlaceholder":135},[68,921,922,925,927,930],{"class":70,"line":152},[68,923,924],{"class":82},"console.",[68,926,99],{"class":78},[68,928,929],{"class":82},"(list); ",[68,931,932],{"class":155},"\u002F\u002F [ 2, 3, 4 ]\n",[12,934,