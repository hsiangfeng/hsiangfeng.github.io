",[12,1037,1038],{},"Avoid Mutability basically means avoid changing variables that shouldn't change. For example, the side-effect section above had this example:",[59,1040,1041],{"className":61,"code":187,"language":63,"meta":64,"style":64},[54,1042,1043,1055,1059],{"__ignoreMap":64},[68,1044,1045,1047,1049,1051,1053],{"class":70,"line":71},[68,1046,194],{"class":74},[68,1048,197],{"class":82},[68,1050,200],{"class":74},[68,1052,203],{"class":104},[68,1054,206],{"class":82},[68,1056,1057],{"class":70,"line":93},[68,1058,136],{"emptyLinePlaceholder":135},[68,1060,1061,1063,1065,1067],{"class":70,"line":111},[68,1062,215],{"class":82},[68,1064,200],{"class":74},[68,1066,220],{"class":104},[68,1068,206],{"class":82},[12,1070,1071,1072,1074],{},"If the name is supposed to be unchangeable, then you shouldn't write it like this. At this point you might think, \"Well, I'll just declare it with ",[54,1073,406],{}," then, right?\"",[59,1076,1078],{"className":61,"code":1077,"language":63,"meta":64,"style":64},"const myName = 'Ray';\n\nmyName = 'Array'; \u002F\u002F throws an error\n",[54,1079,1080,1092,1096],{"__ignoreMap":64},[68,1081,1082,1084,1086,1088,1090],{"class":70,"line":71},[68,1083,406],{"class":74},[68,1085,410],{"class":409},[68,1087,413],{"class":74},[68,1089,203],{"class":104},[68,1091,206],{"class":82},[68,1093,1094],{"class":70,"line":93},[68,1095,136],{"emptyLinePlaceholder":135},[68,1097,1098,1100,1102,1104,1107],{"class":70,"line":111},[68,1099,215],{"class":82},[68,1101,200],{"class":74},[68,1103,220],{"class":104},[68,1105,1106],{"class":82},"; ",[68,1108,1109],{"class":155},"\u002F\u002F throws an error\n",[12,1111,1112,1113,770,1115,1118],{},"Right, plain variable declarations can indeed be protected through how you declare them (",[54,1114,406],{},[54,1116,1117],{},"let","). But what about an array or an object?",[59,1120,1122],{"className":61,"code":1121,"language":63,"meta":64,"style":64},"const arr = [1, 2, 3];\n\narr[1] = 4;\n\nconsole.log(arr);