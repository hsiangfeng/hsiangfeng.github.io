[{"data":1,"prerenderedAt":1415},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F02\u002F27\u002Fjavascript-core-52-prototype-chain-constructor-overview\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F02\u002F27\u002Fjavascript-core-52-prototype-chain-constructor-overview\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F02\u002F27\u002Fjavascript-core-52-prototype-chain-constructor-overview\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F02\u002F27\u002Fjavascript-core-52-prototype-chain-constructor-overview\u002F":1390,"related:\u002Fen\u002Fjavascript\u002F2021\u002F02\u002F27\u002Fjavascript-core-52-prototype-chain-constructor-overview\u002F":1399},"\u002Fjavascript\u002F20210227\u002F1004701564\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1373,"date":1374,"description":1375,"extension":1376,"lang":1377,"meta":1378,"navigation":118,"path":1379,"readingMinutes":1380,"seo":1381,"standalone":1382,"stem":1383,"tags":1384,"tldr":1387,"updated":1374,"url":1388,"__hash__":1389},"content\u002Fen\u002FJavaScript\u002Fjavascript-core-52-prototype-chain-constructor-overview.md","JavaScript Core (52) — Inheritance & Prototype Chains: The Big-Picture View of the Prototype Chain and Constructors","1001037392",{"type":9,"value":10,"toc":1368},"minimark",[11,16,20,24,27,440,459,466,469,496,577,593,644,672,678,689,734,744,749,760,765,768,1061,1070,1096,1107,1110,1137,1159,1185,1190,1237,1240,1303,1311,1317,1346,1350,1364],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This time we're going to look at the whole prototype chain as one big picture. So you can think of this post as more of a recap — we'll revisit the concepts we've already covered and tie them together.",[12,21,23],{"id":22},"the-big-picture-prototype-chain-and-constructors","The big picture: prototype chain and constructors",[17,25,26],{},"We've talked about a lot of prototype concepts already, and we've practiced building our own prototypes:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","function Animal(family) {\n  this.kingdom = '動物界';\n  this.family = family || '人科'; \u002F\u002F family\n}\n\nAnimal.prototype.breathe = function() {\n  console.log(this.name + ' 正在持續呼吸');\n}\n\nfunction Dog(name, color, size) {\n  Animal.call(this, '犬科')\n  this.name = name; \u002F\u002F dog's name\n  this.color = color; \u002F\u002F dog's color\n  this.size = size; \u002F\u002F dog's size\n}\n\nDog.prototype = Object.create(Animal.prototype);\nDog.prototype.constructor = Dog;\n\nDog.prototype.back = function() {\n  console.log(this.name + ' 吠叫');\n}\n\nvar bibi = new Dog('bibi', '棕色', '小');\nconsole.log(bibi.constructor); \u002F\u002F Dog's constructor\n","js","",[35,36,37,61,81,107,113,120,146,172,177,182,208,229,244,260,276,281,286,314,333,338,358,378,383,388,421],"code",{"__ignoreMap":33},[38,39,42,46,50,54,58],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","function",[38,47,49],{"class":48},"sj_SG"," Animal",[38,51,53],{"class":52},"sMAXC","(",[38,55,57],{"class":56},"s_sBn","family",[38,59,60],{"class":52},") {\n",[38,62,64,68,71,74,78],{"class":40,"line":63},2,[38,65,67],{"class":66},"sCcAr","  this",[38,69,70],{"class":52},".kingdom ",[38,72,73],{"class":44},"=",[38,75,77],{"class":76},"sTRMh"," '動物界'",[38,79,80],{"class":52},";\n",[38,82,84,86,89,91,94,97,100,103],{"class":40,"line":83},3,[38,85,67],{"class":66},[38,87,88],{"class":52},".family ",[38,90,73],{"class":44},[38,92,93],{"class":52}," family ",[38,95,96],{"class":44},"||",[38,98,99],{"class":76}," '人科'",[38,101,102],{"class":52},"; ",[38,104,106],{"class":105},"sQrFR","\u002F\u002F family\n",[38,108,110],{"class":40,"line":109},4,[38,111,112],{"class":52},"}\n",[38,114,116],{"class":40,"line":115},5,[38,117,119],{"emptyLinePlaceholder":118},true,"\n",[38,121,123,126,129,132,134,137,140,143],{"class":40,"line":122},6,