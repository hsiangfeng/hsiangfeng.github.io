":109},[38,1213,1079],{"class":52},[38,1215,481],{"class":66},[38,1217,128],{"class":52},[38,1219,481],{"class":66},[38,1221,128],{"class":52},[38,1223,481],{"class":66},[38,1225,128],{"class":52},[38,1227,481],{"class":66},[38,1229,1084],{"class":44},[38,1231,1232],{"class":66}," null",[38,1234,102],{"class":52},[38,1236,1095],{"class":105},[17,1238,1239],{},"I won't re-explain the function side — I'll just give you the code and the results:",[28,1241,1243],{"className":30,"code":1242,"language":32,"meta":33,"style":33},"Dog.__proto__ === Function.prototype; \u002F\u002F true\nAnimal.__proto__ === Function.prototype; \u002F\u002F true\nObject.__proto__ === Function.prototype; \u002F\u002F true\n",[35,1244,1245,1265,1284],{"__ignoreMap":33},[38,1246,1247,1250,1252,1254,1257,1259,1261,1263],{"class":40,"line":41},[38,1248,1249],{"class":52},"Dog.",[38,1251,481],{"class":66},[38,1253,1084],{"class":44},[38,1255,1256],{"class":66}," Function",[38,1258,128],{"class":52},[38,1260,131],{"class":66},[38,1262,102],{"class":52},[38,1264,1095],{"class":105},[38,1266,1267,1270,1272,1274,1276,1278,1280,1282],{"class":40,"line":63},[38,1268,1269],{"class":52},"Animal.",[38,1271,481],{"class":66},[38,1273,1084],{"class":44},[38,1275,1256],{"class":66},[38,1277,128],{"class":52},[38,1279,131],{"class":66},[38,1281,102],{"class":52},[38,1283,1095],{"class":105},[38,1285,1286,1289,1291,1293,1295,1297,1299,1301],{"class":40,"line":83},[38,1287,1288],{"class":52},"Object.",[38,1290,481],{"class":66},[38,1292,1084],{"class":44},[38,1294,1256],{"class":66},[38,1296,128],{"class":52},[38,1298,131],{"class":66},[38,1300,102],{"class":52},[38,1302,1095],{"class":105},[17,1304,1305,1306,1308,1309,743],{},"So functions can use ",[35,1307,131],{}," because they all come from ",[35,1310,742],{},[17,1312,1313,1314,1316],{},"And last of all, ",[35,1315,742],{}," itself also inherits from Object:",[28,1318,1320],{"className":30,"code":1319,"language":32,"meta":33,"style":33},"Function.__proto__._