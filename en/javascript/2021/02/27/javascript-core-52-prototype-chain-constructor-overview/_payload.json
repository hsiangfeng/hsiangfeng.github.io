":76},[38,621,80],{"class":52},[38,623,624,626,628,630,632,634,636,638],{"class":40,"line":83},[38,625,67],{"class":66},[38,627,88],{"class":52},[38,629,73],{"class":44},[38,631,93],{"class":52},[38,633,96],{"class":44},[38,635,99],{"class":76},[38,637,102],{"class":52},[38,639,106],{"class":105},[38,641,642],{"class":40,"line":109},[38,643,112],{"class":52},[17,645,646,647,649,650,653,654,657,658,665,666,668,669,128],{},"If we keep climbing from ",[35,648,585],{},", we reach ",[35,651,652],{},"Object.prototype",", which of course points to the corresponding ",[35,655,656],{},"Object"," constructor. So here's a key takeaway: ",[659,660,661,662,664],"strong",{},"every prototype has its own constructor — that's the ",[35,663,327],{}," property."," But watch out for one thing: once you're at ",[35,667,656],{}," and you keep looking up, all you find is the primitive value ",[35,670,671],{},"null",[17,673,674],{},[462,675],{"alt":676,"src":677},"Prototype chain","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-02-27%2021.49.22.png",[17,679,680,681,197,683,685,686,688],{},"In the image above we see ",[35,682,291],{},[35,684,125],{},", and ",[35,687,656],{},", and for each of these constructors we can add methods onto the prototype:",[28,690,692],{"className":30,"code":691,"language":32,"meta":33,"style":33},"Dog.prototype.back = function() {\n  console.log(this.name + ' 吠叫');\n}\n",[35,693,694,712,730],{"__ignoreMap":33},[38,695,696,698,700,702,704,706,708,710],{"class":40,"line":41},[38,697,291],{"class":66},[38,699,128],{"class":52},[38,701,131],{"class":66},[38,703,128],{"class":52},[38,705,351],{"class":48},[38,707,139],{"class":44},[38,709,142],{"class":44},[38,711,145],{"class":52},[38,713,714,716,718,720,722,724,726,728],{"class":40,"line":63},[38,715,151],{"class":52},[38,717,154],{"class":48},[38,719,53],{"class":52},[38,721,159],{"class":66},[38,723,162]