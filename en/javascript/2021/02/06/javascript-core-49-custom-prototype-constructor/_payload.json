,"line":178},12,[38,180,74],{"class":48},[38,182,183],{"class":64},"'白色'",[38,185,68],{"class":48},[38,187,189,191,194],{"class":40,"line":188},13,[38,190,85],{"class":48},[38,192,193],{"class":64},"'大'",[38,195,68],{"class":48},[38,197,199,201,203,205],{"class":40,"line":198},14,[38,200,97],{"class":96},[38,202,100],{"class":48},[38,204,103],{"class":44},[38,206,106],{"class":48},[38,208,210,212,214,216,218,220,222,224],{"class":40,"line":209},15,[38,211,112],{"class":48},[38,213,115],{"class":96},[38,215,118],{"class":48},[38,217,122],{"class":121},[38,219,125],{"class":48},[38,221,128],{"class":44},[38,223,131],{"class":64},[38,225,134],{"class":48},[38,227,229],{"class":40,"line":228},16,[38,230,140],{"class":48},[38,232,234],{"class":40,"line":233},17,[38,235,146],{"class":48},[17,237,238],{},"What we want to do is generate these two objects through a constructor instead, and have them both inherit the same prototype.",[17,240,241],{},"Both of these are dogs, and they share the same properties and methods. So first we'll declare a function that holds a dog's name, color, and size:",[28,243,245],{"className":30,"code":244,"language":32,"meta":33,"style":33},"function Dog(name, color, size) {\n  this.name = name;\n  this.color = color;\n  this.size = size;\n}\n",[35,246,247,274,286,298,310],{"__ignoreMap":33},[38,248,249,251,254,256,260,263,266,268,271],{"class":40,"line":41},[38,250,103],{"class":44},[38,252,253],{"class":96}," Dog",[38,255,118],{"class":48},[38,257,259],{"class":258},"s_sBn","name",[38,261,262],{"class":48},", ",[38,264,265],{"class":258},"color",[38,267,262],{"class":48},[38,269,270],{"class":258},"size",[38,272,273],{"class":48},") {\n",[38,275,276,279,281,283],{"class":40,"line":58},[38,277,278],{"class":121},"  this",[38,280,125],{"class":48},[38,282,52],{"class":44},[38,284,285],{"class":48}," name;\n",[38,287,288,290,293,295],{"class":40,"line":71},[38,289,278],{"class":121},[38,291,292],{"class":48},".color ",[38,294,52],{"class":44},[38,296,297],{"class":48}," color;\n",[38,299,300,302,305,307],{"class":40,"line":82},[38,301,278],{"class":121},[38,303,304],{"class":48},".size ",[38,306,52],{"class":44},[38,308,309],{"class":48}," size;\n",[38,311,312],{"class":40,"line":93},[38,313,146],{"class":48},[17,315,316,317,319,320,323,324,327,328,330,331,334],{},"Here ",[35,318,122],{}," refers to ",[35,321,322],{},"Dog"," itself, so when we create an instance with ",[35,325,326],{},"new",", the values we pass in get attached to ",[35,329,322],{},". But notice we didn't put the ",[35,332,333],{},"bark"," method inside the constructor.",[17,336,337,338,340,341,348],{},"Quick word on ",[35,339,326],{}," first. The MDN docs ",[342,343,347],"a",{"href":344,"rel":345},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FOperators\u002Fnew",[346],"nofollow","explain"," that it creates a new object, and you'll notice MDN's own example looks a lot like ours:",[28,350,352],{"className":30,"code":351,"language":32,"meta":33,"style":33},"function Car(make, model, year) {\n  this.make = make;\n  this.model = model;\n  this.year = year;\n}\n\nconst car1 = new Car('Eagle', 'Talon TSi', 1993);\n\nconsole.log(car1.make);\n\u002F\u002F expected output: \"Eagle\"\n",[35,353,354,378,390,402,414,418,422,455,459,469],{"__ignoreMap":33},[38,355,356,358,361,363,366,368,371,373,376],{"class":40,"line":41},[38,357,103],{"class":44},[38,359,360],{"class":96}," Car",[38,362,118],{"class":48},[38,364,365],{"class":258},"make",[38,367,262],{"class":48},[38,369,370],{"class":258},"model",[38,372,262],{"class":48},[38,374,375],{"class":258},"year",[38,377,273],{"class":48},[38,379,380,382,385,387],{"class":40,"line":58},[38,381,278],{"class":121},[38,383,384],{"class":48},".make ",[38,386,52],{"class":44},[38,388,389],{"class":48}," make;\n",[38,391,392,394,397,399],{"class":40,"line":71},[38,393,278],{"class":121},[38,395,396],{"class":48},".model ",[38,398,52],{"class":44},[38,400,401],{"class":48}," model;\n",[38,403,404,406,409,411],{"class":40,"line":82},[38,405,278],{"class":121},[38,407,408],{"class":48},".year ",[38,410,52],{"class":44},[38,412,413],{"class":48}," year;\n",[38,415,416],{"class":40,"line":93},[38,417,146],{"class":48},[38,419,420],{"class":40,"line":109},[38,421,153],{"emptyLinePlaceholder":152},[38,423,424,427,430,433,436,438,440,443,445,448,450,453],{"class":40,"line":137},[38,425,426],{"class":44},"const",[38,428,429],{"class":121}," car1",[38,431,432],{"class":44}," =",[38,434,435],{"class":44}," new",[38,437,360],{"class":96},[38,439,118],{"class":48},[38,441,442],{"class":64},"'Eagle'",[38,444,262],{"class":48},[38,446,447],{"class":64},"'Talon TSi'",[38,449,262],{"class":48},[38,451,452],{"class":121},"1993",[38,454,134],{"class":48},[38,456,457],{"class":40,"line":143},[38,458,153],{"emptyLinePlaceholder":152},[38,460,461,464,466],{"class":40,"line":149},[38,462,463],{"class":48},"console.",[38,465,115],{"class":96},[38,467,468],{"class":48},"(car1.make);\n",[38,470,471],{"class":40,"line":156},[38,472,474],{"class":473},"sQrFR","\u002F\u002F expected output: \"Eagle\"\n",[17,476,477,478,480,481,483],{},"And the ",[35,479,122],{}," we just used is also covered in MDN. When you call a function with ",[35,482,326],{},", it does roughly the following:",[485,486,487],"blockquote",{},[488,489,490,494,505,511],"ol",{},[491,492,493],"li",{},"A new empty object is created.",[491,495,496,497,500,501,504],{},"That object is linked to another object by setting its prototype (the internal ",[35,498,499],{},"[[Prototype]]",", i.e. the constructor's ",[35,502,503],{},"prototype",").",[491,506,507,508,510],{},"The newly created object from step 1 is bound as the ",[35,509,122],{}," context.",[491,512,513,514,516],{},"If the function doesn't return its own object, ",[35,515,122],{}," is returned.",[17,518,519,520,522],{},"Now let's use ",[35,521,326],{}," to bring our Bibi and Pupu back:",[28,524,526],{"className":30,"code":525