long object literal from before becomes something every instance inherits the same properties from — and each one is still an object.",[17,642,643],{},[644,645],"img",{"alt":646,"src":647},"instances","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202021-02-06%2020.39.35.png",[17,649,650,651,654,655,657],{},"And if you look one level up at ",[35,652,653],{},"__proto__",", you'll see it was built through ",[35,656,322],{},"'s constructor.",[17,659,660,661,663,664,666,667,669],{},"But right now there's no prototype method on there — no ",[35,662,333],{},". So how do we add one? This is where we need ",[35,665,503],{},". ",[35,668,503],{}," is a property unique to the prototype object, and if you want to add a method, you have to use it:",[28,671,673],{"className":30,"code":672,"language":32,"meta":33,"style":33},"function Dog(name, color, size) {\n  this.name = name;\n  this.color = color;\n  this.size = size;\n}\n\nDog.prototype.back = function() {\n  console.log(this.name + ' 吠叫');\n}\n\nvar bibi = new Dog('比比', '棕色', '小');\nvar pupu = new Dog('噗噗', '白色', '大');\n",[35,674,675,695,705,715,725,729,733,754,773,777,781,807],{"__ignoreMap":33},[38,676,677,679,681,683,685,687,689,691,693],{"class":40,"line":41},[38,678,103],{"class":44},[38,680,253],{"class":96},[38,682,118],{"class":48},[38,684,259],{"class":258},[38,686,262],{"class":48},[38,688,265],{"class":258},[38,690,262],{"class":48},[38,692,270],{"class":258},[38,694,273],{"class":48},[38,696,697,699,701,703],{"class":40,"line":58},[38,698,278],{"class":121},[38,700,125],{"class":48},[38,702,52],{"class":44},[38,704,285],{"class":48},[38,706,707,709,711,713],{"class":40,"line":71},[38,708,278],{"class":121},[38,710,292],{"class":48},[38,712,52],{"class":44},[38,714,297],{"class":48},[38,716,717,719,721,723],{"class":40,"line":82},[38,718,278],{"class":121},[38,720,304],{"class":48},[38,722,52],{"class":44},[38