985,986,989,990,992],{},"A quick aside — prototypes actually have levels too, they just keep looking upward. If you expand ",[42,977,978],{},"Array"," and then click ",[42,981,301],{}," one more time, you'll see this ",[42,984,301],{}," points to ",[42,987,988],{},"Object",". So the entire array prototype is inherited from the Object prototype. And the reason you can't find a ",[42,991,301],{}," on the Object prototype is that the Object prototype is the very top level of the prototype hierarchy.",[17,994,995],{},"Now let's do a fun experiment. We just said the Object prototype sits at the top of all prototypes. So what happens if you create an object and assign a method directly to it?",[35,997,999],{"className":37,"code":998,"language":39,"meta":40,"style":40},"\nvar obj = {\n  myName: 'Ray',\n}\n\nobj.__proto__.getName = function() {\n  console.log(this.myName + ' is Goods!');\n}\n\nobj.getName();\u002F\u002F Ray is Goods!\n",[42,1000,1001,1005,1016,1026,1030,1034,1052,1073,1077,1081],{"__ignoreMap":40},[45,1002,1003],{"class":47,"line":48},[45,1004,350],{"emptyLinePlaceholder":349},[45,1006,1007,1009,1012,1014],{"class":47,"line":65},[45,1008,52],{"class":51},[45,1010,1011],{"class":55}," obj ",[45,1013,59],{"class":51},[45,1015,62],{"class":55},[45,1017,1018,1021,1024],{"class":47,"line":78},[45,1019,1020],{"class":55},"  myName: ",[45,1022,1023],{"class":71},"'Ray'",[45,1025,75],{"class":55},[45,1027,1028],{"class":47,"line":89},[45,1029,904],{"class":55},[45,1031,1032],{"class":47,"line":105},[45,1033,350],{"emptyLinePlaceholder":349},[45,1035,1036,1039,1041,1043,1046,1048,1050],{"class":47,"line":123},[45,1037,1038],{"class":55},"obj.",[45,1040,301],{"class":266},[45,1042,873],{"class":55},[45,1044,1045],{"class":92},"getName",[45,1047,879],{"class":51},[45,1049,882],{"class":51},[45,1051,102],{"class":55},[45,1053,1054,1056,1058,1060,1063,1065,1068,1071],{"class":47,"line":129},[45,1055,377],{"class":55},[45,1057,111],{"class":92},[45,1059,114],{"class":55}