nsole"," gives ",[49,745,188],{},". The thing is, after the assignment happens the function isn't immediately run — it runs ",[748,749,750],"em",{},"after"," the assignment, which makes it a simple call. This is really about expressions: the expression returns a value and then you execute it. When you write ",[49,753,754],{},"foo.bar = foo.bar",", what comes back is ",[49,757,758],{},"function() { return this.value; }",", and we're calling that function directly. So this is basically the same idea as ",[49,761,762],{},"a = b = 1",[17,764,765,766,769,770,772],{},"The third one is the same concept, just with the ",[49,767,768],{},"||"," operator added. With ",[49,771,768],{},", if the first operand is falsy it returns the second one. So again you end up with a simple call.",[17,774,775],{},"Here's a little bonus question on the side:",[42,777,779],{"className":44,"code":778,"language":46,"meta":47,"style":47},"var b = {};\n\nObject.defineProperty(b, 'a', {\n  value: undefined, \u002F\u002F default value\n  writable: false, \u002F\u002F not writable\n})\n\nb.a = 'a';\nconsole.log(b.a); \u002F\u002F undefined\n",[49,780,781,792,796,813,825,837,842,846,858],{"__ignoreMap":47},[52,782,783,785,787,789],{"class":54,"line":55},[52,784,59],{"class":58},[52,786,298],{"class":62},[52,788,66],{"class":58},[52,790,791],{"class":62}," {};\n",[52,793,794],{"class":54,"line":76},[52,795,80],{"emptyLinePlaceholder":79},[52,797,798,801,804,807,810],{"class":54,"line":83},[52,799,800],{"class":62},"Object.",[52,802,803],{"class":111},"defineProperty",[52,805,806],{"class":62},"(b, ",[52,808,809],{"class":69},"'a'",[52,811,812],{"class":62},", {\n",[52,814,815,817,820,822],{"class":54,"line":96},[52,816,624],{"class":62},[52,818,819],{"class":130},"undefined",[52,821,257],{"class":62},[52,823,824],{"class":582},"\u002F\u002F default value\n",[52,826,827,830,832,834],{"class":54,"line":108},[52,828,829],{"class":62},"  writable: ",[52,831,718],{"class":130},[52,833,257],{"class":62},[52,835,836],{"class":582},"\u002F\u002F not writable\n",[52,838,839],{"class":54,"line":124},[52,840,841],{"class":62},"})\n",[52,843,844],{"class":54,"line":137},[52,845,80],{"emptyLinePlaceholder":79},[52,847,848,851,853,856],{"class":54,"line":143},[52,849,850],{"class":62},"b.a ",[52,852,66],{"class":58},[52,854,855],{"class":69}," 'a'",[52,857,73],{"class":62},[52,859,860,862,864,867],{"class":54,"line":149},[52,861,170],{"class":62},[52,863,173],{"class":111},[52,865,866],{"class":62},"(b.a); ",[52,868,869],{"class":582},"\u002F\u002F undefined\n",[17,871,872,873,197],{},"The reason the second and third questions are tied to expressions is this: if you tweak the question to the following, you'll find the result is still ",[49,874,188],{},[42,876,878],{"className":44,"code":877,"language":46,"meta":47,"style":47},"var value = 'Global';\n\nvar foo = {\n  value: 'local',\n  bar: function() {\n    return this.value;\n  }\n}\n\nvar b = {};\n\nObject.defineProperty(b, 'a', {\n  value: undefined, \u002F\u002F default value\n  writable: false, \u002F\u002F not writable\n})\n\nb.a = 'a';\n\n\u002F\u002F assignment\nconsole.log((b.a = foo.bar)());\n",[49,879,880,892,896,906,914,924,932,936,940,944,954,958,970,980,990,994,999,1010,1015,1020],{"__ignoreMap":47},[52,881,882,884,886,888,890],{"class":54,"line":55},[52,883,59],{"class":58},[52,885,598],{"class":62},[52,887,66],{"class":58},[52,889,70],{"class":69},[52,891,73],{"class":62},[52,893,894],{"class":54,"line":76},[52,895,80],{"emptyLinePlaceholder":79},[52,897,898,900,902,904],{"class":54,"line":83},[52,899,59],{"class":58},[52,901,615],{"class":62},[52,903,66],{"class":58},[52,905,93],{"class":62},[52,907,908,910,912],{"class":54,"line":96},[52,909,624],{"class":62},[52,911,627],{"class":69},[52,913,105],{"class":62},[52,915,916,918,920,922],{"class":54,"line":108},[52,917,634],{"class":111},[52,919,115],{"class":62},[52,921,118],{"class":58},[52,923,121],{"class":62},[52,925,926,928,930],{"class":54,"line":124},[52,927,127],{"class":58},[52,929,131],{"class":130},[52,931,649],{"class":62},[52,933,934],{"class":54,"line":137},[52,935,140],{"class":62},[52,937,938],{"class":54,"line":143},[52,939,146],{"class":62},[52,941,942],{"class":54,"line":149},[52,943,80],{"emptyLinePlaceholder":79},[52,945,946,948,950,952],{"class":54,"line":154},[52,947,59],{"class":58},[52,949,298],{"class":62},[52,951,66],{"class":58},[52,953,791],{"class":62},[52,955,956],{"class":54,"line":167},[52,957,80],{"emptyLinePlaceholder":79},[52,959,960,962,964,966,968],{"class":54,"line":362},[52,961,800],{"class":62},[52,963,803],{"class":111},[52,965,806],{"class":62},[52,967,809],{"class":69},[52,969,812],{"class":62},[52,971,972,974,976,978],{"class":54,"line":560},[52,973,624],{"class":62},[52,975,819],{"class":130},[52,977,257],{"class":62},[52,979,824],{"class":582},[52,981,982,984,986,988],{"class":54,"line":702},[52,983,829],{"class":62},[52,985,718],{"class":130},[52,987,257],{"class":62},[52,989,836],{"class":582},[52,991,992],{"class":54,"line":708},[52,993,841],{"class":62},[52,995,997],{"class":54,"line":996},16,[52,998,80],{"emptyLinePlaceholder":79},[52,1000,1002,1004,1006,1008],{"class":54,"line":1001},17,[52,1003,850],{"class":62},[52,1005,66],{"class":58},[52,1007,855],{"class":69},[52,1009,73],{"class":62},[52,1011,1013],{"class":54,"line":1012},18,[52,1014,80],{"emptyLinePlaceholder":79},[52,1016,1018],{"class":54,"line":1017},19,[52,1019,685],{"class":582},[52,1021,1023,1025,1027,1030,1032],{"class":54,"line":1022},20,[52,1024,170],{"class":62},[52,1026,173],{"class":111},[52,1028,1029],{"class":62},"((b.a ",[52,1031,66],{"class":58},[52,1033,699],{"class":62},[17,1035,1036,1037,1040],{},"So this assignment process is an expression, and what actually gets executed is the ",[748,1038,1039],{},"result of the expression",", not the result of the assignment.",[17,1042,1043],{},"Now let's look at the fourth one:",[42,1045,1047],{"className":44,"code":1046,"language":46,"meta":47,"style":47},"var arr = ['1', '2', '3'].map(parseInt);\nconsole.log(arr);\n",[49,1048,1049,1083],{"__ignoreMap":47},[52,1050,1051,1053,1056,1058,1061,1064,1066,1069,1071,1074,1077,1080],{"class":54,"line":55},[52,1052,59],{"class":58},[52,1054,1055],{"class":62}," arr ",[52,1057,66],{"class":58},[52,1059,1060],{"class":62}," [",[52,1062,1063],{"class":69},"'1'",[52,1065,257],{"class":62},[52,1067,1068],{"class":69},"'2'",[52,1070,257],{"class":62},[52,1072,1073],{"class":69},"'3'",[52,1075,1076],{"class":62},"].",[52,1078,1079],{"class":111},"map",[52,1081,1082],{"class":62},"(parseInt);\n",[52,1084,1085,1087,1089],{"class":54,"line":76},[52,1086,170],{"class":62},[52,1088,173],{"class":111},[52,1090,1091],{"class":62},"(arr);\n",[17,1093,185,1094,1097,1098,1101,1102,1107],{},[49,1095,1096],{},"'1', NaN, NaN",". So why does this happen? First, ",[49,1099,1100],{},"parseInt"," converts a string into an integer, and the quirky part is that if you don't specify a radix, something interesting happens. Here's a snippet from MDN's ",[28,1103,1106],{"href":1104,"rel":1105},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FGlobal_Objects\u002FparseInt",[32],"explanation",":",[1109,1110,1111],"blockquote",{},[17,1112,1113],{},"An integer between 2 and 36 that represents the radix (the base in mathematical numeral systems) of the string. If 10, the value is parsed as a decimal number. It is always good practice to specify this parameter to eliminate reader confusion and to guarantee predictable behavior. Different implementations produce different results when a radix is not specified, usually defaulting the value to 10.",[17,1115,1116,1117,1119],{},"On top of that, ",[49,1118,1079],{}," takes a callback function, and that callback receives several arguments: the array element, the index, and the array itself. So if we expand what's really happening, it looks like this:",[42,1121,1123],{"className":44,"code":1122,"language":46,"meta":47,"style":47},"var arr = ['1', '2', '3'].map(function(item, index) {\n  return parseInt(item, index);\n});\n",[49,1124,1125,1165,1176],{"__ignoreMap":47},[52,1126,1127,1129,1131,1133,1135,1137,1139,1141,1143,1145,1147,1149,1151,1153,1155,1158,1160,1163],{"class":54,"line":55},[52,1128,59],{"class":58},[52,1130,1055],{"class":62},[52,1132,66],{"class":58},[52,1134,1060],{"class":62},[52,1136,1063],{"class":69},[52,1138,257],{"class":62},[52,1140,1068],{"class":69},[52,1142,257],{"class":62},[52,1144,1073],{"class":69},[52,1146,1076],{"class":62},[52,1148,1079],{"class":111},[52,1150,176],{"class":62},[52,1152,118],{"class":58},[52,1154,176],{"class":62},[52,1156,1157],{"class":254},"item",[52,1159,257],{"class":62},[52,1161,1162],{"class":254},"index",[52,1164,268],{"class":62},[52,1166,1167,1170,1173],{"class":54,"line":76},[52,1168,1169],{"class":58},"  return",[52,1171,1172],{"class":111}," parseInt",[52,1174,1175],{"class":62},"(item, index);\n",[52,1177,1178],{"class":54,"line":83},[52,1179,1180],{"class":62},"});\n",[17,1182,1183,1184,1186,1187,1190,1191,1193],{},"Like I just said, the second argument to ",[49,1185,1100],{}," is the radix. So on the first iteration it runs as ",[49,1188,1189],{},"parseInt(1, 0)",". There's no such thing as radix ",[49,1192,352],{},", so it falls back to the default. Here's MDN's explanation of that part:",[1109,1195,1196],{},[17,1197,1198],{},"If radix is undefined, 0, or unspecified, JavaScript assumes the following:\nIf the input string begins with \"0x\" or \"0X\" (a zero, followed by lowercase or uppercase X), radix is assumed to be 16 and the rest of the string is parsed as a hexadecimal number.\nIf the input string begins with \"0\" (a zero), radix is assumed to be 8 (octal) or 10 (decimal). Exactly which radix is chosen is implementation-dependent. ECMAScript 5 specifies that 10 (decimal) is used, but not all browsers support this yet. For this reason, always specify a radix when using parseInt.\nIf the input string begins with any other value, the radix is 10 (decimal).",[17,1200,1201,1202,197],{},"So when it's the default, it might be whatever the browser defaults to, usually octal or decimal. Either way, with this value it correctly converts to ",[49,1203,376],{},[17,1205,1206,1207,1210,1211,1213,1214,197],{},"On the second iteration it becomes ",[49,1208,1209],{},"parseInt(2, 1)",". When the radix is ",[49,1212,376],{},", every time the value reaches 1 it carries over to the next position, so it can't convert properly — and the answer is ",[49,1215,1216],{},"NaN",[17,1218,1219,1220,1223,1224,1227],{},"On the third iteration it's similar: ",[49,1221,1222],{},"parseInt(3, 2)",". Same idea — when the radix is 2, the value carries over every time it reaches 2, so ",[49,1225,1226],{},"3"," doesn't exist (and neither does 2 itself, for that matter).",[12,1229,1231],{"id":1230},"references","References",[1233,1234,1235],"ul",{},[1236,1237,1238],"li",{},[28,1239,1242],{"href":1240,"rel":1241},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[32],"JavaScript Core (course in Mandarin)",[1244,1245,1246],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);