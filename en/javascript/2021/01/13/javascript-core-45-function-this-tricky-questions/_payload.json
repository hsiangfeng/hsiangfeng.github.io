[49,405,347],{},", so there's no real ",[49,408,192],{}," to set, which means it falls back to a simple call.",[17,411,412,413,415],{},"One extra note: if you actually want the answer to be ",[49,414,347],{},", you have to use strict mode.",[42,417,419],{"className":44,"code":418,"language":46,"meta":47,"style":47},"var myName = 'Global';\n\nvar obj = {\n  myName: 'Ray',\n  fn: function(a, b, c) {\n    'use strict';\n    return this + ',' + a + ',' + b + ',' + c\n  }\n}\nvar fnA = obj.fn;\nvar fnB = obj.bind(null, 0);\n\nconsole.log(fnB(1, 2)); \u002F\u002F null, 0, 1, 2\n",[49,420,421,433,437,447,455,477,484,514,518,522,532,554,558],{"__ignoreMap":47},[52,422,423,425,427,429,431],{"class":54,"line":55},[52,424,59],{"class":58},[52,426,63],{"class":62},[52,428,66],{"class":58},[52,430,70],{"class":69},[52,432,73],{"class":62},[52,434,435],{"class":54,"line":76},[52,436,80],{"emptyLinePlaceholder":79},[52,438,439,441,443,445],{"class":54,"line":83},[52,440,59],{"class":58},[52,442,228],{"class":62},[52,444,66],{"class":58},[52,446,93],{"class":62},[52,448,449,451,453],{"class":54,"line":96},[52,450,99],{"class":62},[52,452,102],{"class":69},[52,454,105],{"class":62},[52,456,457,459,461,463,465,467,469,471,473,475],{"class":54,"line":108},[52,458,245],{"class":111},[52,460,115],{"class":62},[52,462,118],{"class":58},[52,464,176],{"class":62},[52,466,28],{"class":254},[52,468,257],{"class":62},[52,470,260],{"class":254},[52,472,257],{"class":62},[52,474,265],{"class":254},[52,476,268],{"class":62},[52,478,479,482],{"class":54,"line":124},[52,480,481],{"class":69},"    'use strict'",[52,483,73],{"class":62},[52,485,486,488,490,492,494,496,498,500,502,504,506,508,510,512],{"class":54,"line":137},[52,487,127],{"class":58},[52,489,131],{"class":130},[52,491,286],{"class":58},[52,493,283],{"class":69},[52,495,286],{"class":58},[52,497,289],{"class":62},[52,499,280],{"class":58},[52,501,283],{"class":69},[52,503,286],{"class":58},[52,505,298],{"class":62},[52,507,280],{"clas