, anytime you see a function being executed directly and it uses ",[28,173,30],{}," inside, you've got a Simple Call. Here's a course example to look at:",[33,176,178],{"className":35,"code":177,"language":37,"meta":38,"style":38},"var myName = 'Ray';\n(function() {\n  console.log(this.myName); \u002F\u002F Ray\n  function callSomeone() {\n    console.log(this.myName); \u002F\u002F Ray\n  }\n\n  callSomeone();\n})();\n",[28,179,180,197,205,221,231,246,252,257,266],{"__ignoreMap":38},[42,181,182,185,188,191,195],{"class":44,"line":45},[42,183,184],{"class":48},"var",[42,186,187],{"class":56}," myName ",[42,189,190],{"class":48},"=",[42,192,194],{"class":193},"sWayO"," 'Ray'",[42,196,141],{"class":56},[42,198,199,201,203],{"class":44,"line":60},[42,200,69],{"class":56},[42,202,49],{"class":48},[42,204,57],{"class":56},[42,206,207,209,211,213,215,218],{"class":44,"line":78},[42,208,63],{"class":56},[42,210,66],{"class":52},[42,212,69],{"class":56},[42,214,30],{"class":72},[42,216,217],{"class":56},".myName); ",[42,219,220],{"class":100},"\u002F\u002F Ray\n",[42,222,223,226,229],{"class":44,"line":84},[42,224,225],{"class":48},"  function",[42,227,228],{"class":52}," callSomeone",[42,230,57],{"class":56},[42,232,233,236,238,240,242,244],{"class":44,"line":91},[42,234,235],{"class":56},"    console.",[42,237,66],{"class":52},[42,239,69],{"class":56},[42,241,30],{"class":72},[42,243,217],{"class":56},[42,245,220],{"class":100},[42,247,249],{"class":44,"line":248},6,[42,250,251],{"class":56},"  }\n",[42,253,255],{"class":44,"line":254},7,[42,256,88],{"emptyLinePlaceholder":87},[42,258,260,263],{"class":44,"line":259},8,[42,261,262],{"class":52},"  callSomeone",[42,264,265],{"class":56},"();\n",[42,267,269],{"class":44,"line":268},9,[42,270,271],{"class":56},"})();\n",[17,273,274,275,277,278,281],{},"You can see here that no matter what, ",[28,276,30],{}," points at ",[28,279,280],{},"window",". An IIFE always produces a Simple Call — so what about closures?",[33,283,285],{"className":35,"code":284,"language":37,"meta":38,"style":38},"function fn() {\n  var a = 1;\n  return function(update) {\n    a = a + update;\n    console.log(this, this.a)\n  }\n}\n\nvar qq = fn();\nqq(10);\n",[28,286,287,295,310,326,341,359,363,367,371,384],{"__ignoreMap":38},[42,288,289,291,293],{"class":44,"line":45},[42,290,49],{"class":48},[42,292,53],{"class":52},[42,294,57],{"class":56},[42,296,297,300,303,305,308],{"class":44,"line":60},[42,298,299],{"class":48},"  var",[42,301,302],{"class":56}," a ",[42,304,190],{"class":48},[42,306,307],{"class":72}," 1",[42,309,141],{"class":56},[42,311,312,314,317,319,323],{"class":44,"line":78},[42,313,135],{"class":48},[42,315,316],{"class":48}," function",[42,318,69],{"class":56},[42,320,322],{"class":321},"syBk-","update",[42,324,325],{"class":56},") {\n",[42,327,328,331,333,335,338],{"class":44,"line":84},[42,329,330],{"class":56},"    a ",[42,332,190],{"class":48},[42,334,302],{"class":56},[42,336,337],{"class":48},"+",[42,339,340],{"class":56}," update;\n",[42,342,343,345,347,349,351,354,356],{"class":44,"line":91},[42,344,235],{"class":56},[42,346,66],{"class":52},[42,348,69],{"class":56},[42,350,30],{"class":72},[42,352,353],{"class":56},", ",[42,355,30],{"class":72},[42,357,358],{"class":56},".a)\n",[42,360,361],{"class":44,"line":248},[42,362,251],{"class":56},[42,364,365],{"class":44,"line":254},[42,366,81],{"class":56},[42,368,369],{"class":44,"line":259},[42,370,88],{"emptyLinePlaceholder":87},[42,372,373,375,378,380,382],{"class":44,"line":268},[42,374,184],{"class":48},[42,376,377],{"class":56}," qq ",[42,379,190],{"class":48},[42,381,53],{"class":52},[42,383,265],{"class":56},[42,385,387,390,392,395],{"class":44,"line":386},10,[42,388,389],{"class":52},"qq",[42,391,69],{"class":56},[42,393,394],{"class":72},"10",[42,396,75],{"class":56},[17,398,399,400,402,403,405,406,408,409,411,412,415,416,419],{},"In this example ",[28,401,30],{}," still points at ",[28,404,280],{},", and since ",[28,407,30],{}," is ",[28,410,280],{},", there's no ",[28,413,414],{},"a"," variable on it — so you get ",[28,417,418],{},"undefined",". Again, this happens because we \"called the function directly\", which produces a Simple Call. So from now on, whenever you see a function being called directly, it's guaranteed to produce a Simple Call.",[17,421,422],{},"There's one more situation that creates a Simple Call too — the callback form. For example:",[33,424,426],{"className":35,"code":425,"language":37,"meta":38,"style":38},"function fn(cb) {\n  var myName = 'Ray';\n  cb();\n}\n\nfn(function() {\n  console.log(this, this.myName);\n})\n",[28,427,428,441,453,460,464,468,478,495],{"__ignoreMap":38},[42,429,430,432,434,436,439],{"class":44,"line":45},[42,431,49],{"class":48},[42,433,53],{"class":52},[42,435,69],{"class":56},[42,437,438],{"class":321},"cb",[42,440,325],{"class":56},[42,442,443,445,447,449,451],{"class":44,"line":60},[42,444,299],{"class":48},[42,446,187],{"class":56},[42,448,190],{"class":48},[42,450,194],{"class":193},[42,452,141],{"class":56},[42,454,455,458],{"class":44,"line":78},[42,456,457],{"class":52},"  cb",[42,459,265],{"class":56},[42,461,462],{"class":44,"line":84},[42,463,81],{"class":56},[42,465,466],{"class":44,"line":91},[42,467,88],{"emptyLinePlaceholder":87},[42,469,470,472,474,476],{"class":44,"line":248},[42,471,94],{"class":52},[42,473,69],{"class":56},[42,475,49],{"class":48},[42,477,57],{"class":56},[42,479,480,482,484,486,488,490,492],{"class":44,"line":254},[42,481,63],{"class":56},[42,483,66],{"class":52},[42,485,69],{"class":56},[42,487,30],{"class":72},[42,489,353],{"class":56},[42,491,30],{"class":72},[42,493,494],{"class":56},".myName);\n",[42,496,497],{"class":44,"line":259},[42,498,499],{"class":56},"})\n",[17,501,502,503,507,508,510],{},"This produces a Simple Call as well. Basically, you have to look at ",[504,505,506],"em",{},"how"," it gets executed. If it's executed directly, you'll definitely get a Simple Call and ",[28,509,30],{}," will go off the rails. But if we change the code to this, the result is different:",[33,512,514],{"className":35,"code":513,"language":37,"meta":38,"style":38},"function fn(cb) {\n  var obj = {\n    myName: 'Ray',\n    cb: cb,\n  };\n  obj.cb();\n}\n\nfn(function() {\n  console.log(this, this.myName);\n})\n",[28,515,516,528,540,551,556,561,570,574,578,588,604],{"__ignoreMap":38},[42,517,518,520,522,524,526],{"class":44,"line":45},[42,519,49],{"class":48},[42,521,53],{"class":52},[42,523,69],{"class":56},[42,525,438],{"class":321},[42,527,325],{"class":56},[42,529,530,532,535,537],{"class":44,"line":60},[42,531,299],{"class":48},[42,533,534],{"class":56}," obj ",[42,536,190],{"class":48},[42,538,539],{"class":56}," {\n",[42,541,542,545,548],{"class":44,"line":78},[42,543,544],{"class":56},"    myName: ",[42,546,547],{"class":193},"'Ray'",[42,549,550],{"class":56},",\n",[42,552,553],{"class":44,"line":84},[42,554,555],{"class":56},"    cb: cb,\n",[42,557,558],{"class":44,"line":91},[42,559,560],{"class":56},"  };\n",[42,562,563,566,568],{"class":44,"line":248},[42,564,565],{"class":56},"  obj.",[42,567,438],{"class":52},[42,569,265],{"class":56},[42,571,572],{"class":44,"line":254},[42,573,81],{"class":56},[42,575,576],{"class":44,"line":259},[42,577,88],{"emptyLinePlaceholder":87},[42,579,580,582,584,586],{"class":44,"line":268},[42,581,94],{"class":52},[42,583,69],{"class":56},[42,585,49],{"class":48},[42,587,57],{"class":56},[42,589,590,592,594,596,598,600,602],{"class":44,"line":386},[42,591,63],{"class":56},[42,593,66],{"class":52},[42,595,69],{"class":56},[42,597,30],{"class":72},[42,599,353],{"class":56},[42,601,30],{"class":72},[42,603,494],{"class":56},[42,605,607],{"class":44,"line":606},11,[42,608,499],{"class":56},[17,610,611,612,614,615,617],{},"Now the call happens on an object, so ",[28,613,30],{}," doesn't point at ",[28,616,280],{},". But normally callbacks end up as Simple Calls — especially JavaScript's own built-in methods, which run into this problem all the time. The earlier example is one such case:",[33,619,621],{"className":35,"code":620,"language":37,"meta":38,"style":38},"var myName = 'JavaScript'\nfunction fn () {\n  setTimeout(function() {\n    console.log(this.myName);\n  }, 1000);\n}\nvar data = {\n  myName: 'Ray',\n  callName: fn,\n  ming: {\n    myName: 'Ray2',\n    callName: fn,\n  }\n}\n\ndata.callName();\n",[28,622,623,634,643,654,666,676,680,691,700,705,710,719,725,730,735,740],{"__ignoreMap":38},[42,624,625,627,629,631],{"class":44,"line":45},[42,626,184],{"class":48},[42,628,187],{"class":56},[42,630,190],{"class":48},[42,632,633],{"class":193}," 'JavaScript'\n",[42,635,636,638,640],{"class":44,"line":60},[42,637,49],{"class":48},[42,639,53],{"class":52},[42,641,642],{"class":56}," () {\n",[42,644,645,648,650,652],{"class":44,"line":78},[42,646,647],{"class":52},"  setTimeout",[42,649,69],{"class":56},[42,651,49],{"class":48},[42,653,57],{"class":56},[42,655,656,658,660,662,664],{"class":44,"line":84},[42,657,235],{"class":56},[42,659,66],{"class":52},[42,661,69],{"class":56},[42,663,30],{"class":72},[42,665,494],{"class":56},[42,667,668,671,674],{"class":44,"line":91},[42,669,670],{"class":56},"  }, ",[42,672,673],{"class":72},"1000",[42,675,75],{"class":56},[42,677,678],{"class":44,"line":248},[42,679,81],{"class":56},[42,681,682,684,687,689],{"class":44,"line":254},[42,683,184],{"class":48},[42,685,686],{"class":56}," data ",[42,688,190],{"class":48},[42,690,539],{"class":56},[42,692,693,696,698],{"class":44,"line":259},[42,694,695],{"class":56},"  myName: ",[42,697,547],{"class":193},[42,699,550],{"class":56},[42,701,702],{"class":44,"line":268},[42,703,704],{"class":56},"  callName: fn,\n",[42,706,707],{"class":44,"line":386},[42,708,709],{"class":56},"  ming: {\n",[42,711,712,714,717],{"class":44,"line":606},[42,713,544],{"class":56},[42,715,716],{"class":193},"'Ray2'",[42,718,550],{"class":56},[42,720,722],{"class":44,"line":721},12,[42,723,724],{"class":56},"    callName: fn,\n",[42,72