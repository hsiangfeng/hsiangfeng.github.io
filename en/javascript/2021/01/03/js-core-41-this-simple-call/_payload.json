[{"data":1,"prerenderedAt":1407},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F01\u002F03\u002Fjs-core-41-this-simple-call\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F01\u002F03\u002Fjs-core-41-this-simple-call\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F01\u002F03\u002Fjs-core-41-this-simple-call\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F01\u002F03\u002Fjs-core-41-this-simple-call\u002F":1382,"related:\u002Fen\u002Fjavascript\u002F2021\u002F01\u002F03\u002Fjs-core-41-this-simple-call\u002F":1391},"\u002Fjavascript\u002F20210103\u002F2997707827\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1365,"date":1366,"description":1367,"extension":1368,"lang":1369,"meta":1370,"navigation":87,"path":1371,"readingMinutes":1372,"seo":1373,"standalone":1374,"stem":1375,"tags":1376,"tldr":1379,"updated":1366,"url":1380,"__hash__":1381},"content\u002Fen\u002FJavaScript\u002Fjs-core-41-this-simple-call.md","JavaScript Core (41) — Functions and This: The Simple Call","1000950283",{"type":9,"value":10,"toc":1360},"minimark",[11,16,20,24,32,102,118,166,175,272,282,397,420,423,500,511,609,618,751,758,846,849,852,970,990,1120,1123,1316,1335,1341,1345,1356],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This one picks up where the last chapter left off — we're finally covering the \"Simple Call\", a.k.a. Simple Call.",[12,21,23],{"id":22},"simple-call","Simple Call",[17,25,26,27,31],{},"So what's a Simple Call? In Chinese it's 簡易呼叫 (\"simple call\"), and basically, whenever you call a function directly and read ",[28,29,30],"code",{},"this"," inside it, you get a Simple Call.",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","function fn() {\n  console.log(this);\n}\n\nfn(); \u002F\u002F window\n","js","",[28,40,41,58,76,82,89],{"__ignoreMap":38},[42,43,46,50,54],"span",