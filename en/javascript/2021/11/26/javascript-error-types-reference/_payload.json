[{"data":1,"prerenderedAt":977},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F26\u002Fjavascript-error-types-reference\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F26\u002Fjavascript-error-types-reference\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F26\u002Fjavascript-error-types-reference\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F26\u002Fjavascript-error-types-reference\u002F":952,"related:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F26\u002Fjavascript-error-types-reference\u002F":961},"\u002Fjavascript\u002F20211126\u002F12988607\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":936,"date":937,"description":938,"extension":939,"lang":940,"meta":941,"navigation":494,"path":942,"readingMinutes":943,"seo":944,"standalone":945,"stem":946,"tags":947,"tldr":949,"updated":937,"url":950,"__hash__":951},"content\u002Fen\u002FJavaScript\u002Fjavascript-error-types-reference.md","A Field Guide to JavaScript Error Types (So You Can Debug Faster)","1001314557",{"type":9,"value":10,"toc":925},"minimark",[11,16,20,24,27,46,49,52,55,106,109,133,136,182,185,232,243,311,320,338,341,344,347,381,384,426,429,432,452,460,521,524,549,552,607,610,613,616,648,651,688,697,706,743,748,782,785,788,791,838,842,845,873,876,898,906,910,921],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This post is a quick roundup of the different error messages JavaScript can throw at you. We stare at red error messages all day when we're building stuff, and honestly, if you can recognize the error type the moment you see it, that alone makes debugging a lot faster.",[12,21,23],{"id":22},"error-types-error-reference","Error Types (Error Reference)",[17,25,26],{},"JavaScript has these error types:",[28,29,30,34,37,40,43],"ul",{},[31,32,33],"li",{},"SyntaxError",[31,35,36],{},"RangeError",[31,38,39],{},"ReferenceError",[31,41,42],{},"TypeError",[31,44,45],{},"URIError",[12,47,33],{"id":48},"syntaxerror",[17,50,51],{},"SyntaxError is exactly what it sounds like — you wrote the syntax wrong.",[17,53,54],{},"Declaring a variable with an invalid name:",[56,57,62],"pre",{"className":58,"code":59,"language":60,"meta":61,"style":61},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F Uncaught SyntaxError: missing variable name\nvar 1;\n\u002F\u002F Uncaught SyntaxError: missing variable name\nvar '小明' = 1;\n","js","",[63,64,65,74,85,90],"code",{"__ignoreMap":61},[66,67,70],"span",{"class":68,"line":69},"line",1,[66,71,73],{"class":72},"sQrFR","\u002F\u002F Uncaught SyntaxError: missing variable name\n",[66,75,77,81],{"class":68,"line":76},2,[66,78,80],{"class":79},"sWyjQ","var",[66,82,84],{"class":83},"sMAXC"," 1;\n",[66,86,88],{"class":68,"line":87},3,[66,89,73],{"class":72},[66,91,93,95,98,102],{"class":68,"line":92},4,[66,94,80],{"class":79},[66,96,97],{"class":83}," '小明",[66,99,101],{"class":100},"sTRMh","' = 1",[66,103,105],{"class":104},"szH_Z",";\n",[17,107,108],{},"A common LHS (Left-Hand Side) error:",[56,110,112],{"className":58,"code":111,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: invalid assignment left-hand side\n'小明' = 1;\n",[63,113,114,119],{"__ignoreMap":61},[66,115,116],{"class":68,"line":69},[66,117,118],{"class":72},"\u002F\u002F Uncaught SyntaxError: invalid assignment left-hand side\n",[66,120,121,124,127,131],{"class":68,"line":76},[66,122,123],{"class":100},"'小明'",[66,125,126],{"class":79}," =",[66,128,130],{"class":129},"sCcAr"," 1",[66,132,105],{"class":83},[17,134,135],{},"Mismatched brackets:",[56,137,139],{"className":58,"code":138,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: expected expression, got '}'\nif(true) \n  console.log('Ray');\n}\n",[63,140,141,146,160,177],{"__ignoreMap":61},[66,142,143],{"class":68,"line":69},[66,144,145],{"class":72},"\u002F\u002F Uncaught SyntaxError: expected expression, got '}'\n",[66,147,148,151,154,157],{"class":68,"line":76},[66,149,150],{"class":79},"if",[66,152,153],{"class":83},"(",[66,155,156],{"class":129},"true",[66,158,159],{"class":83},") \n",[66,161,162,165,169,171,174],{"class":68,"line":87},[66,163,164],{"class":83},"  console.",[66,166,168],{"class":167},"sj_SG","log",[66,170,153],{"class":83},[66,172,173],{"class":100},"'Ray'",[66,175,176],{"class":83},");\n",[66,178,179],{"class":68,"line":92},[66,180,181],{"class":83},"}\n",[17,183,184],{},"Missing comma:",[56,186,188],{"className":58,"code":187,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: missing } after property list\nvar obj = {\n  myName: 'Ray' \n  Url: 'https:\u002F\u002Fisraynotarray.com\u002F'\n};\n",[63,189,190,195,208,218,226],{"__ignoreMap":61},[66,191,192],{"class":68,"line":69},[66,193,194],{"class":72},"\u002F\u002F Uncaught SyntaxError: missing } after property list\n",[66,196,197,199,202,205],{"class":68,"line":76},[66,198,80],{"class":79},[66,200,201],{"class":83}," obj ",[66,203,204],{"class":79},"=",[66,206,207],{"class":83}," {\n",[66,209,210,213,215],{"class":68,"line":87},[66,211,212],{"class":83},"  myName: ",[66,214,173],{"class":100},[66,216,217],{"class":83}," \n",[66,219,220,223],{"class":68,"line":92},[66,221,222],{"class":83},"  Url: ",[66,224,225],{"class":100},"'https:\u002F\u002Fisraynotarray.com\u002F'\n",[66,227,229],{"class":68,"line":228},5,[66,230,231],{"class":83},"};\n",[17,233,234,235,238,239,242],{},"Redeclaring with ",[63,236,237],{},"const"," or ",[63,240,241],{},"let",":",[56,244,246],{"className":58,"code":245,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: redeclaration of const myName\nconst myName = 'Ray';\nconst myName = 'Array';\n\u002F\u002F Uncaught SyntaxError: redeclaration of let myName\nlet myName = 'Ray';\nlet myName = 'Array';\n",[63,247,248,253,267,280,285,298],{"__ignoreMap":61},[66,249,250],{"class":68,"line":69},[66,251,252],{"class":72},"\u002F\u002F Uncaught SyntaxError: redeclaration of const myName\n",[66,254,255,257,260,262,265],{"class":68,"line":76},[66,256,237],{"class":79},[66,258,259],{"class":129}," myName",[66,261,126],{"class":79},[66,263,264],{"class":100}," 'Ray'",[66,266,105],{"class":83},[66,268,269,271,273,275,278],{"class":68,"line":87},[66,270,237],{"class":79},[66,272,259],{"class":129},[66,274,126],{"class":79},[66,276,277],{"class":100}," 'Array'",[66,279,105],{"class":83},[66,281,282],{"class":68,"line":92},[66,283,284],{"class":72},"\u002F\u002F Uncaught SyntaxError: redeclaration of let myName\n",[66,286,287,289,292,294,296],{"class":68,"line":228},[66,288,241],{"class":79},[66,290,291],{"class":83}," myName ",[66,293,204],{"class":79},[66,295,264],{"class":100},[66,297,105],{"class":83},[66,299,301,303,305,307,309],{"class":68,"line":300},6,[66,302,241],{"class":79},[66,304,291],{"class":83},[66,306,204],{"class":79},[66,308,277],{"class":100},[66,310,105],{"class":83},[17,312,313,314,316,317,319],{},"A ",[63,315,237],{}," with no initial value (",[63,318,241],{}," doesn't have this problem):",[56,321,323],{"className":58,"code":322,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: missing = in const declaration\nconst myName;\n",[63,324,325,330],{"__ignoreMap":61},[66,326,327],{"class":68,"line":69},[66,328,329],{"class":72},"\u002F\u002F Uncaught SyntaxError: missing = in const declaration\n",[66,331,332,334,336],{"class":68,"line":76},[66,333,237],{"class":79},[66,335,259],{"class":129},[66,337,105],{"class":83},[17,339,340],{},"There are way too many ways to trigger a syntax error, so I'm only listing a few of the common ones here.",[12,342,36],{"id":343},"rangeerror",[17,345,346],{},"You don't run into this one much. The most common case is an invalid array length, like:",[56,348,350],{"className":58,"code":349,"language":60,"meta":61,"style":61},"const array = new Array(-1); \u002F\u002F Uncaught RangeError: invalid array length\n",[63,351,352],{"__ignoreMap":61},[66,353,354,356,359,361,364,367,369,372,375,378],{"class":68,"line":69},[66,355,237],{"class":79},[66,357,358],{"class":129}," array",[66,360,126],{"class":79},[66,362,363],{"class":79}," new",[66,365,366],{"class":167}," Array",[66,368,153],{"class":83},[66,370,371],{"class":79},"-",[66,373,374],{"class":129},"1",[66,376,377],{"class":83},"); ",[66,379,380],{"class":72},"\u002F\u002F Uncaught RangeError: invalid array length\n",[17,382,383],{},"Or something like this:",[56,385,387],{"className":58,"code":386,"language":60,"meta":61,"style":61},"let arr = [];\narr.length = arr.length - 1; \u002F\u002F Uncaught RangeError: invalid array length\n",[63,388,389,401],{"__ignoreMap":61},[66,390,391,393,396,398],{"class":68,"line":69},[66,392,241],{"class":79},[66,394,395],{"class":83}," arr ",[66,397,204],{"class":79},[66,399,400],{"class":83}," [];\n",[66,402,403,406,409,411,414,416,419,421,424],{"class":68,"line":76},[66,404,405],{"class":83},"arr.",[66,407,408],{"class":129},"length",[66,410,126],{"class":79},[66,412,413],{"class":83}," arr.",[66,415,408],{"class":129},[66,417,418],{"class":79}," -",[66,420,130],{"class":129},[66,422,423],{"class":83},"; ",[66,425,380],{"class":72},[12,427,39],{"id":428},"referenceerror",[17,430,431],{},"Calling a variable or function that doesn't exist:",[56,433,435],{"className":58,"code":434,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught ReferenceError: myName is not defined\nconsole.log(myName);\n",[63,436,437,442],{"__ignoreMap":61},[66,438,439],{"class":68,"line":69},[66,440,441],{"class":72},"\u002F\u002F Uncaught ReferenceError: myName is not defined\n",[66,443,444,447,449],{"class":68,"line":76},[66,445,446],{"class":83},"console.",[66,448,168],{"class":167},[66,450,451],{"class":83},"(myName);\n",[17,453,454,455,238,457,459],{},"Calling a ",[63,456,241],{},[63,458,237],{}," before it's declared:",[56,461,463],{"className":58,"code":462,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization\nconsole.log(myName);\nconst myName = 'Ray';\n\n\u002F\u002F Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization\nconsole.log(myName);\nlet myName = 'Ray';\n",[63,464,465,470,478,490,496,500,508],{"__ignoreMap":61},[66,466,467],{"class":68,"line":69},[66,468,469],{"class":72},"\u002F\u002F Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization\n",[66,471,472,474,476],{"class":68,"line":76},[66,473,446],{"class":83},[66,475,168],{"class":167},[66,477,451],{"class":83},[66,479,480,482,484,486,488],{"class":68,"line":87},[66,481,237],{"class":79},[66,483,259],{"class":129},[66,485,126],{"class":79},[66,487,264],{"class":100},[66,489,105],{"class":83},[66,491,492],{"class":68,"line":92},[66,493,495],{"emptyLinePlaceholder":494},true,"\n",[66,497,498],{"class":68,"line":228},[66,499,469],{"class":72},[66,501,502,504,506],{"class":68,"line":300},[66,503,446],{"class":83},[66,505,168],{"class":167},[66,507,451],{"class":83},[66,509,511,513,515,517,519],{"class":68,"line":510},7,[66,512,241],{"class":79},[66,514,291],{"class":83},[66,516,204],{"class":79},[66,518,264],{"class":100},[66,520,105],{"class":83},[17,522,523],{},"An invalid assignment:",[56,525,527],{"className":58,"code":526,"language":60,"meta":61,"style":61},"console.log = 1 || console.log = 1\n",[63,528,529],{"__ignoreMap":61},[66,530,531,534,536,538,541,544,546],{"class":68,"line":69},[66,532,533],{"class":83},"console.log ",[66,535,204],{"class":79},[66,537,130],{"class":129},[66,539,540],{"class":79}," ||",[66,542,543],{"class":83}," console.log ",[66,545,204],{"class":79},[66,547,548],{"class":129}," 1\n",[17,550,551],{},"There's also one special case that triggers a ReferenceError — using an undeclared variable in strict mode:",[56,553,555],{"className":58,"code":554,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught ReferenceError: assignment to undeclared variable myName\nfunction fn() {\n  'use strict';\n  myName = 'Ray';\n}\n\nfn()\n",[63,556,557,562,573,580,591,595,599],{"__ignoreMap":61},[66,558,559],{"class":68,"line":69},[66,560,561],{"class":72},"\u002F\u002F Uncaught ReferenceError: assignment to undeclared variable myName\n",[66,563,564,567,570],{"class":68,"line":76},[66,565,566],{"class":79},"function",[66,568,569],{"class":167}," fn",[66,571,572],{"class":83},"() {\n",[66,574,575,578],{"class":68,"line":87},[66,576,577],{"class":100},"  'use strict'",[66,579,105],{"class":83},[66,581,582,585,587,589],{"class":68,"line":92},[66,583,584],{"class":83},"  myName ",[66,586,204],{"class":79},[66,588,264],{"class":100},[66,590,105],{"class":83},[66,592,593],{"class":68,"line":228},[66,594,181],{"class":83},[66,596,597],{"class":68,"line":300},[66,598,495],{"emptyLinePlaceholder":494},[66,600,601,604],{"class":68,"line":510},[66,602,603],{"class":167},"fn",[66,605,606],{"class":83},"()\n",[12,608,42],{"id":609},"typeerror",[17,611,612],{},"This is probably the one you'll see the most.",[17,614,615],{},"Accessing a property that doesn't exist:",[56,617,619],{"className":58,"code":618,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught TypeError: obj.data is undefined\nvar obj = {};\nobj.data.myName = 'Ray';\n",[63,620,621,626,637],{"__ignoreMap":61},[66,622,623],{"class":68,"line":69},[66,624,625],{"class":72},"\u002F\u002F Uncaught TypeError: obj.data is undefined\n",[66,627,628,630,632,634],{"class":68,"line":76},[66,629,80],{"class":79},[66,631,201],{"class":83},[66,633,204],{"class":79},[66,635,636],{"class":83}," {};\n",[66,638,639,642,644,646],{"class":68,"line":87},[66,640,641],{"class":83},"obj.data.myName ",[66,643,204],{"class":79},[66,645,264],{"class":100},[66,647,105],{"class":83},[17,649,650],{},"Calling a method that doesn't exist:",[56,652,654],{"className":58,"code":653,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught TypeError: set.filter is not a function\nconst set = new Set();\nset.filter();\n",[63,655,656,661,678],{"__i