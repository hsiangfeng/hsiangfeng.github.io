lass":48},"sj_SG"," fn",[38,51,53],{"class":52},"sMAXC","() {\n",[38,55,57,60,64],{"class":40,"line":56},2,[38,58,59],{"class":44},"  return",[38,61,63],{"class":62},"sTRMh"," '是 Ray 不是 Array'",[38,65,66],{"class":52},";\n",[38,68,70],{"class":40,"line":69},3,[38,71,72],{"class":52},"}\n",[38,74,76],{"class":40,"line":75},4,[38,77,79],{"emptyLinePlaceholder":78},true,"\n",[38,81,83,86,89,92,95,97,100,103,106],{"class":40,"line":82},5,[38,84,85],{"class":52},"console.",[38,87,88],{"class":48},"log",[38,90,91],{"class":52},"(",[38,93,94],{"class":62},"`我的名字 ${",[38,96,49],{"class":48},[38,98,99],{"class":62},"() ",[38,101,102],{"class":62},"}`",[38,104,105],{"class":52},"); ",[38,107,109],{"class":108},"sQrFR","\u002F\u002F 我的名字 是 Ray 不是 Array\n",[17,111,112],{},"But what about a statement?",[28,114,116],{"className":30,"code":115,"language":32,"meta":33,"style":33},"console.log(`我的名字是 ${ if(true) return 'Ray' }`); \u002F\u002F Uncaught SyntaxError: Unexpected token 'if'\n",[35,117,118],{"__ignoreMap":33},[38,119,120,122,124,126,129,132,134,138,141,144,147,150,152],{"class":40,"line":41},[38,121,85],{"class":52},[38,123,88],{"class":48},[38,125,91],{"class":52},[38,127,128],{"class":62},"`我的名字是 ${",[38,130,131],{"class":48}," if",[38,133,91],{"class":62},[38,135,137],{"class":136},"sCcAr","true",[38,139,140],{"class":62},") ",[38,142,143],{"class":52},"return",[38,145,146],{"class":62}," 'Ray'",[38,148,149],{"class":62}," }`",[38,151,105],{"class":52},[38,153,154],{"class":108},"\u002F\u002F Uncaught SyntaxError: Unexpected token 'if'\n",[17,156,157],{},"From these few quick examples you can already see the rule: template literals accept expressions, but not statements.",[17,159,160,161,164],{},"Here's a question that comes up a lot — is a variable declaration like ",[35,162,163],{},"let myName = 'Ray';"," an expression?",[28,166,168],{"className":30,"code":167,"language":32,"meta":33,"style":33},"console.log(`我的名字是 ${ let myName = 'Ray'; }`); \u002F\u002F Uncaught SyntaxError: Missing } in template expression\n",[35,169,170],{"__ignoreMap":33},[38,171,172,174,176,178,180,183,186,189,191,194,196,198],{"class":40,"line":41},[38,173,85],{"class":52},[38,175,88],{"class":48},[38,177,91],{"class":52},[38,179,128],{"class":62},[38,181,182],{"class":52}," let",[38,184,185],{"class":52}," myName",[38,187,188],{"class":44}," =",[38,190,146],{"class":62},[38,192,193],{"class":62},"; ",[38,195,102],{"class":62},[38,197,105],{"class":52},[38,199,200],{"class":108},"\u002F\u002F Uncaught SyntaxError: Missing } in template expression\n",[17,202,203],{},"Going by that error message, you can tell a variable declaration is a statement, not an expression.",[17,205,206],{},"Now, a template literal is itself an expression — which means you can nest one inside another like this:",[28,208,210],{"className":30,"code":209,"language":32,"meta":33,"style":33},"let myName = 'Ray';\nconsole.log(`我的名字${ `是 ${myName}` }`); \u002F\u002F 我的名字是 Ray\n",[35,211,212,227],{"__ignoreMap":33},[38,213,214,217,220,223,225],{"class":40,"line":41},[38,215,216],{"class":44},"let",[38,218,219],{"class":52}," myName ",[38,221,222],{"class":44},"=",[38,224,146],{"class":62},[38,226,66],{"class":52},[38,228,229,231,233,235,238,241,244,246,248,250],{"class":40,"line":56},[38,230,85],{"class":52},[38,232,88],{"class":48},[38,234,91],{"class":52},[38,236,237],{"class":62},"`我的名字${",[38,239,240],{"class":62}," `是 ${",[38,242,243],{"class":52},"myName",[38,245,102],{"class":62},[38,247,149],{"class":62},[38,249,105],{"class":52},[38,251,252],{"class":108},"\u002F\u002F 我的名字是 Ray\n",[17,254,255],{},"In practice, we end up assembling DOM strings a lot. For example:",[28,257,259],{"className":30,"code":258,"language":32,"meta":33,"style":33},"const people = [\n  {\n    myName: 'Ray',\n    url: 'https:\u002F\u002Fisraynotarray.com\u002F',\n  },\n  {\n    myName: 'is Ray not Array',\n    url: 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray',\n  },\n];\n\nconst list = `\u003Cul>