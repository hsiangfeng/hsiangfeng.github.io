[{"data":1,"prerenderedAt":1013},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F14\u002Fjs-core-72-es6-tagged-template-literals\u002F":3,"page:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F14\u002Fjs-core-72-es6-tagged-template-literals\u002F":4,"alt:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F14\u002Fjs-core-72-es6-tagged-template-literals\u002F":3,"prev-next:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F14\u002Fjs-core-72-es6-tagged-template-literals\u002F":988,"related:\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F14\u002Fjs-core-72-es6-tagged-template-literals\u002F":997},"\u002Fjavascript\u002F20211114\u002F136128318\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":971,"date":972,"description":973,"extension":974,"lang":975,"meta":976,"navigation":114,"path":977,"readingMinutes":978,"seo":979,"standalone":980,"stem":981,"tags":982,"tldr":985,"updated":972,"url":986,"__hash__":987},"content\u002Fen\u002FJavaScript\u002Fjs-core-72-es6-tagged-template-literals.md","JS Core (72) - ES6 Tagged Template Literals: The Backtick Trick You've Never Used","1001195772",{"type":9,"value":10,"toc":966},"minimark",[11,16,20,24,27,90,93,197,200,287,290,305,311,317,320,462,465,468,627,630,766,774,933,947,951,962],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This time we're getting into a more advanced trick — tagged template literals.",[12,21,23],{"id":22},"tagged-template-literals","Tagged Template Literals",[17,25,26],{},"A tagged template literal is the advanced form of the regular template literal. Let's start with a plain example first:",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","const myName = 'Ray';\nconsole.log(`Hello ${myName}！`); \u002F\u002F Hello Ray!\n","js","",[35,36,37,61],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","const",[38,47,49],{"class":48},"sCcAr"," myName",[38,51,52],{"class":44}," =",[38,54,56],{"class":55},"sTRMh"," 'Ray'",[38,58,60],{"class":59},"sMAXC",";\n",[38,62,64,67,71,74,77,80,83,86],{"class":40,"line":63},2,[38,65,66],{"class":59},"console.",[38,68,70],{"class":69},"sj_SG","log",[38,72,73],{"class":59},"(",[38,75,76],{"class":55},"`Hello ${",[38,78,79],{"class":59},"myName",[38,81,82],{"class":55},"}！`",[38,84,85],{"class":59},"); ",[38,87,89],{"class":88},"sQrFR","\u002F\u002F Hello Ray!\n",[17,91,92],{},"That's the basic template literal you've seen a hundred times. So how do you write the tagged version? The syntax is kind of unusual — it looks like this:",[28,94,96],{"className":30,"code":95,"language":32,"meta":33,"style":33},"const myName = 'Ray';\n\nfunction fn(strings, arg) {\n  console.log(`strings:${strings}`, `arg:${arg}`); \u002F\u002F strings:Hello ,！ arg:Ray\n}\n\nfn`Hello ${myName}！`;\n",[35,97,98,110,116,140,172,178,183],{"__ignoreMap":33},[38,99,100,102,104,106,108],{"class":40,"line":41},[38,101,45],{"class":44},[38,103,49],{"class":48},[38,105,52],{"class":44},[38,107,56],{"class":55},[38,109,60],{"class":59},[38,111,112],{"class":40,"line":63},[38,113,115],{"emptyLinePlaceholder":114},true,"\n",[38,117,119,122,125,127,131,134,137],{"class":40,"line":118},3,[38,120,121],{"class":44},"function",[38,123,124],{"class":69}," fn",[38,126,73],{"class":59},[38,128,130],{"class":129},"s_sBn","strings",[38,132,133],{"class":59},", ",[38,135,136],{"class":129},"arg",[38,138,139],{"class":59},") {\n",[38,141,143,146,148,150,153,155,158,160,163,165,167,169],{"class":40,"line":142},4,[38,144,145],{"class":59},"  console.",[38,147,70],{"class":69},[38,149,73],{"class":59},[38,151,152],{"class":55},"`strings:${",[38,154,130],{"class":59},[38,156,157],{"class":55},"}`",[38,159,133],{"class":59},[38,161,162],{"class":55},"`arg:${",[38,164,136],{"class":59},[38,166,157],{"class":55},[38,168,85],{"class":59},[38,170,171],{"class":88},"\u002F\u002F strings:Hello ,！ arg:Ray\n",[38,173,175],{"class":40,"line":174},5,[38,176,177],{"class":59},"}\n",[38,179,181],{"class":40,"line":180},6,[38,182,115],{"emptyLinePlaceholder":114},[38,184,186,189,191,193,195],{"class":40,"line":185},7,[38,187,188],{"class":69},"fn",[38,190,76],{"class":55},[38,192,79],{"class":59},[38,194,82],{"class":55},[38,196,60],{"class":59},[17,198,199],{},"Declaring the variable and the function is probably nothing new to you. But watch what happens if you change it to this instead — you get a completely different result:",[28,201,203],{"className":30,"code":202,"language":32,"meta":33,"style":33},"const myName = 'Ray';\n\nfunction fn(strings, arg) {\n  console.log(`strings:${strings}`, `arg:${arg}`); \u002F\u002F strings:Hello Ray！ arg:undefined\n}\n\nfn(`Hello ${myName}！`);\n",[35,204,205,217,221,237,264,268,272],{"__ignoreMap":33},[38,206,207,209,211,213,215],{"class":40,"line":41},[38,208,45],{"class":44},[38,210,49],{"class":48},[38,212,52],{"class":44},[38,214,56],{"class":55},[38,216,60],{"class":59},[38,218,219],{"class":40,"line":63},[38,220,115],{"emptyLinePlaceholder":114},[38,222,223,225,227,229,231,233,235],{"class":40,"line":118},[38,224,121],{"class":44},[38,226,124],{"class":69},[38,228,73],{"class":59},[38,230,130],{"class":129},[38,232,133],{"class":59},[38,234,136],{"class":129},[38,236,139],{"class":59},[38,238,239,241,243,245,247,249,251,253,255,257,259,261],{"class":40,"line":142},[38,240,145],{"class":59},[38,242,70],{"class":69},[38,244,73],{"class":59},[38,246,152],{"class":55},[38,248,130],{"class":59},[38,250,157],{"class":55},[38,252,133],{"class":59},[38,254,162],{"class":55},[38,256,136],{"class":59},[38,258,157],{"class":55},[38,260,85],{"class":59},[38,262,263],{"class":88},"\u002F\u002F strings:Hello Ray！ arg:undefined\n",[38,265,266],{"class":40,"line":174},[38,267,177],{"class":59},[38,269,270],{"class":40,"line":180},[38,271,115],{"emptyLinePlaceholder":114},[38,273,274,276,278,280,282,284],{"class":40,"line":185},[38,275,188],{"class":69},[38,277,73],{"class":59},[38,279,76],{"class":55},[38,281,79],{"class":59},[38,283,82],{"class":55},[38,285,286],{"class":59},");\n",[17,288,289],{},"So the correct way to write it is the first one, without the parentheses.",[17,291,292,293,296,297,304],{},"Now, why does the tagged version output something like ",[35,294,295],{},"strings:Hello ,！ arg:Ray","? Let's check what ",[298,299,303],"a",{"href":300,"rel":301},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FTemplate_literals#tagged_templates",[302],"nofollow","MDN"," has to say:",[306,307,308],"blockquote",{},[17,309,310],{},"Tagged templates allow you to parse template literals with a function. The first argument of a tag function contains an array of string values. The remaining arguments are related to the expressions. The tag function can then perform whatever operations on these arguments you wish, and return the manipulated string (or it can return something completely different, as described in the next example).",[17,312,313,314,316],{},"So when we use a tagged template literal, the function's first argument is an array of strings, and the second argument is the variable being passed in. That's why it shows up as ",[35,315,295],{},".",[17,318,319],{},"Of course, the number of variables we pass in isn't always fixed. So for the second argument we can use the rest operator to handle that:",[28,321,323],{"className":30,"code":322,"language":32,"meta":33,"style":33},"const myName = 'Ray';\nconst Url = 'https:\u002F\u002Fisraynotarray.com\u002F';\n\nfunction fn(strings, ...arg) {\n  console.log(arg);\n  console.log(`strings:${strings}`, `arg:${arg[0]} ${arg[1]}`); \u002F\u002F strings:Hello ,！ arg:Ray\n}\n\nfn`Hello ${myName}！ My Blog Url is ${Url}`; \u002F\u002F strings:Hello ,！ My Blog Url is , arg:Ray https:\u002F\u002Fisraynotarray.com\u002F\n",[35,324,325,337,351,355,374,383,430,434,439],{"__ignoreMap":33},[38,326,327,329,331,333,335],{"class":40,"line":41},[38,328,45],{"class":44},[38,330,49],{"class":48},[38,332,52],{"class":44},[38,334,56],{"class":55},[38,336,60],{"class":59},[38,338,339,341,344,346,349],{"class":40,"line":63},[38,340,45],{"class":44},[38,342,343],{"class":48}," Url",[38,345,52],{"class":44},[38,347,348],{"class":55}," 'https:\u002F\u002Fisraynotarray.com\u002F'",[38,350,60],{"class":59},[38,352,353],{"class":40,"line":118},[38,354,115],{"emptyLinePlaceholder":114},[38,356,357,359,361,363,365,367,370,372],{"class":40,"line":142},[38,358,121],{"class":44},[38,360,124],{"class":69},[38,362,73],{"class":59},[38,364,130],{"class":129},[38,366,133],{"class":59},[38,368,369],{"class":44},"...",[38,371,136],{"class":129},[38,373,139],{"class":59},[38,375,376,378,380],{"class":40,"line":174},[38,377,145],{"class":59},[38,379,70],{"class":69},[38,381,382],{"class":59},"(arg);\n",[38,384,385,387,389,391,393,395,397,399,401,403,406,409,412,415,417,419,422,424,426,428],{"class":40,"line":180},[38,386,145],{"class":59},[38,388,70],{"class":69},[38,390,73],{"class":59},[38,392,152],{"class":55},[38,394,130],{"class":59},[38,396,157],{"class":55},[38,398,133],{"class":59},[38,400,162],{"class":55},[38,402,136],{"class":59},[38,404,405],{"class":55},"[",[38,407,408],{"class":48},"0",[38,410,411],{"class":55},"]",[38,413,414],{"class":55},"} ${",[38,416,136],{"class":59},[38,418,405],{"class":55},[38,420,421],{"class":48},"1",[38,423,411],{"class":55},[38,425,157],{"class":55},[38,427,85],{"class":59},[38,429,171],{"class":88},[38,431,432],{"class":40,"line":185},[38,433,177],{"class":59},[38,435,437],{"class":40,"line":436},8,[38,438,115],{"emptyLinePlaceholder":114},[38,440,442,444,446,448,451,454,456,459],{"class":40,"line":441},9,[38,443,188],{"class":69},[38,445,76],{"class":55},[38,447,79],{"class":59},[38,449,450],{"class":55},"}！ My Blog Url is ${",[38,452,453],{"class":59},"Url",[38,455,157],{"class":55},[38,457,458],{"class":59},"; ",[38,460,461],{"class":88},"\