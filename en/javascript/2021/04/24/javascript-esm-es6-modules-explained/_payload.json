":1524},"default-export-and-import","Default export and import",[17,1527,1528],{},"Basically you can think of a default export like an anonymous function, so when you import it you have to give it a variable to receive it. The most common way to write a default export is as a single object:",[46,1530,1532],{"className":48,"code":1531,"language":50,"meta":51,"style":51},"\u002F* app.js *\u002F\nexport default {\n  sayHello() {\n    console.log('Hello Ray');\n  },\n  myName: 'Ray',\n  obj: {\n    myName: 'Ray',\n  },\n  arr: [1, 2, 3],\n};\n",[34,1533,1534,1538,1547,1558,1571,1578,1586,1591,1600,1606,1626],{"__ignoreMap":51},[55,1535,1536],{"class":57,"line":58},[55,1537,1130],{"class":61},[55,1539,1540,1542,1545],{"class":57,"line":65},[55,1541,771],{"class":68},[55,1543,1544],{"class":68}," default",[55,1546,1196],{"class":80},[55,1548,1549,1552,1555],{"class":57,"line":87},[55,1550,1551],{"class":72},"  sayHello",[55,1553,1554],{"class":80},"() ",[55,1556,1557],{"class":76},"{\n",[55,1559,1560,1563,1565,1567,1569],{"class":57,"line":102},[55,1561,1562],{"class":76},"    console.",[55,1564,750],{"class":72},[55,1566,77],{"class":76},[55,1568,1171],{"class":123},[55,1570,738],{"class":76},[55,1572,1573,1576],{"class":57,"line":113},[55,1574,1575],{"class":76},"  }",[55,1577,1207],{"class":80},[55,1579,1580,1582,1584],{"class":57,"line":130},[55,1581,1201],{"class":76},[55,1583,1204],{"class":123},[55,1585,1207],{"class":80},[55,1587,1588],{"class":57,"line":165},[55,1589,1590],{"class":76},"  obj: {\n",[55,1592,1593,1596,1598],{"class":57,"line":180},[55,1594,1595],{"class":76},"    myName: ",[55,1597,1204],{"class":123},[55,1599,1207],{"class":76},[55,1601,1602,1604],{"class":57,"line":192},[55,1603,1575],{"class":76},[55,1605,1207],{"class":80},[55,1607,1608,1611,1613,1615,1617,1619,1621,1624],{"class":57,"line":198},[55,1609,1610],{"class":76},"  arr: [",[55,1612,1232],{"class":147},[55,1614,1235],{"class":76},[55,1616,1238],{"class":147},[55,1618,1235],{"class":7