k to the main topic. ESM mostly uses ",[34,767,768],{},"import",[34,770,771],{},"export",". If you've used webpack before — heads up, this ESM intro isn't about the webpack side of things, it's about writing ESM directly in the browser. ESM basically absorbed the best parts of AMD and CommonJS, which is why it's considered such an important piece of JavaScript syntax.",[17,774,775,776,779,780,783],{},"Now, the key thing if you want to use it: you have to add ",[34,777,778],{},"type=\"module\""," to your ",[34,781,782],{},"\u003Cscript>"," tag. Otherwise you can't use ESM at all.",[17,785,786],{},"On top of that, let me walk through a few key points about ESM and how to use it.",[658,788,790],{"id":789},"esm-is-strict-mode-by-default","ESM is strict mode by default",[17,792,793,794,797,798,800],{},"Once you're in ESM, your code automatically becomes ",[34,795,796],{},"'use strict'"," (strict mode). Whether or not you actually wrote ",[34,799,796],{},", it's always strict mode.",[17,802,803],{},"So what's strict mode? JavaScript is a pretty loose language, so if you don't have a solid grip on it, you're going to step on a lot of landmines while developing. Strict mode exists to keep us from stepping on those weird landmines. A really common example is typos:",[46,805,807],{"className":48,"code":806,"language":50,"meta":51,"style":51},"var person;\npersom = {};\nconsole.log(persom);\n",[34,808,809,816,826],{"__ignoreMap":51},[55,810,811,813],{"class":57,"line":58},[55,812,139],{"class":68},[55,814,815],{"class":76}," person;\n",[55,817,818,821,823],{"class":57,"line":65},[55,819,820],{"class":76},"persom ",[55,822,96],{"class":68},[55,824,825],{"class":76}," {};\n",[55,827,828,830,832],{"class":57,"line":87},[55,829,747],{"class":76},[55,831,750],{"class":72},[55,833,834],{"class":76},"(persom);\n",[17,836,837],{},[838,839],"img",{"alt":840,"src":841},"Non-strict mode","https:\u002F\u002Fi.imgur.com\u002F6r8jupR.png",[17,843,844],{},"Without strict mode, this throws no error and even runs just fine. Once you turn on strict mode, it's a completely different story:",[46,846,848],{"className":48,"code":847,"language":50,"meta":51,"style":51},"\"use strict\";\nvar person ; \npersom = {};\nconsole.log(persom);\n",[34,849,850,857,864,872],{"__ignoreMap":51},[55,851,852,855],{"class":57,"line":58},[55,853,854],{"class":123},"\"use strict\"",[55,856,127],{"class":76},[55,858,859,861],{"class":57,"line":65},[55,860,139],{"class":68},[55,862,863],{"class":76}," person ; \n",[55,865,866,868,870],{"class":57,"line":87},[55,867,820],{"class":76},[55,869,96],{"class":68},[55,871,825],{"class":76},[55,873,874,876,878],{"class":57,"line":102},[55,875,747],{"class":76},[55,877,750],{"class":72},[55,879,834],{"class":76},[17,881,882],{},[838,883],{"alt":884,"src":885},"Strict mode","https:\u002F\u002Fi.imgur.com\u002FqBty2bo.png",[17,887,888],{},"So now you've got a basic feel for strict mode. Next, try pasting the code below into CodePen — you'll see the same error message pop up. I won't bother re-posting the screenshot here.",[46,890,894],{"className":891,"code":892,"language":893,"meta":51,"style":51},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript type=\"module\">\n  var person;\n  persom = {};\n  console.log(persom);\n\u003C\u002Fscript>\n","html",[34,895,896,915,921,930,939],{"__ignoreMap":51},[55,897,898,900,904,907,909,912],{"class":57,"line":58},[55,899,154],{"class":76},[55,901,903],{"class":902},"sKpQp","script",[55,905,906],{"class":147}," type",[55,908,96],{"class":76},[55,910,911],{"class":123},"\"module\"",[55,913,914],{"class":76},">\n",[55,916,917,919],{"class":57,"line":65},[55,918,90],{"class":68},[55,920,815],{"class":76},[55,922,923,926,928],{"class":57,"line":87},[55,924,925],{"class":76},"  persom ",[55,927,96],{"class":68},[55,929,825],{"class":76},[55,931,932,935,937],{"class":57,"line":102},[55,933,934],{"class":76},"  console.",[55,936,750],{"class":72},[55,938,834],{"class":76},[55,940,941,94