, it's a whole different story:",[46,1039,1041],{"className":891,"code":1040,"language":893,"meta":51,"style":51},"\u003Cscript type=\"module\">\n  var person = 'Hello Ray';\n\u003C\u002Fscript>\n\n\u003Cscript>\n  console.log(person); \u002F\u002F ReferenceError: person is not defined \n\u003C\u002Fscript>\n",[34,1042,1043,1057,1069,1077,1081,1089,1100],{"__ignoreMap":51},[55,1044,1045,1047,1049,1051,1053,1055],{"class":57,"line":58},[55,1046,154],{"class":76},[55,1048,903],{"class":902},[55,1050,906],{"class":147},[55,1052,96],{"class":76},[55,1054,911],{"class":123},[55,1056,914],{"class":76},[55,1058,1059,1061,1063,1065,1067],{"class":57,"line":65},[55,1060,90],{"class":68},[55,1062,981],{"class":76},[55,1064,96],{"class":68},[55,1066,986],{"class":123},[55,1068,127],{"class":76},[55,1070,1071,1073,1075],{"class":57,"line":87},[55,1072,943],{"class":76},[55,1074,903],{"class":902},[55,1076,914],{"class":76},[55,1078,1079],{"class":57,"line":102},[55,1080,687],{"emptyLinePlaceholder":686},[55,1082,1083,1085,1087],{"class":57,"line":113},[55,1084,154],{"class":76},[55,1086,903],{"class":902},[55,1088,914],{"class":76},[55,1090,1091,1093,1095,1097],{"class":57,"line":130},[55,1092,934],{"class":76},[55,1094,750],{"class":72},[55,1096,1017],{"class":76},[55,1098,1099],{"class":61},"\u002F\u002F ReferenceError: person is not defined \n",[55,1101,1102,1104,1106],{"class":57,"line":165},[55,1103,943],{"class":76},[55,1105,903],{"class":902},[55,1107,914],{"class":76},[17,1109,1110],{},"So when you're using ESM, make sure you're at least aware of these two things — otherwise you'll keep stepping on landmines.",[12,1112,1114],{"id":1113},"named-export-and-import","Named export and import",[17,1116,1117,1118,1120],{},"Next let me cover what a named export is. The concept is actually pretty similar to named functions vs. anonymous functions — when you export a module, it has a name, same idea. As mentioned earlier, you mainly use ",[34,1119,771],{},", and named exports aren't really restricted: you can export objects, variables, functions, whatever:",[46,1122,1124],{"className":48,"code":1123,"language":50,"meta":51,"style":51},"\u002F* app.js *\u002F\nexport const myName = 'Hello Ray';\n\nexport sayHi() {\n  console.log('Hello Ray');\n}\n\nexport const obj = {\n  myName: 'Ray',\n}\n\nexport const arr = [1, 2, 3];\n",[34,1125,1126,1131,1147,1151,1161,1174,1179,1183,1197,1208,1212,1216],{"__ignoreMap":51},[55,1127,1128],{"class":57,"line":58},[55,1129,1130],{"class":61},"\u002F* app.js *\u002F\n",[55,1132,1133,1135,1138,1141,1143,1145],{"class":57,"line":65},[55,1134,771],{"class":68},[55,1136,1137],{"class":68}," const",[55,1139,1140],{"class":147}," myName",[55,1142,701],{"class":68},[55,1144,986],{"class":123},[55,1146,127],{"class":76},[55,1148,1149],{"class":57,"line":87},[55,1150,687],{"emptyLinePlaceholder":686},[55,1152,1153,1155,1158],{"class":57,"line":102},[55,1154,771],{"class":68},[55,1156,1157],{"class":72}," sayHi",[55,1159,1160],{"class":76},"() {\n",[55,1162,1163,1165,1167,1169,1172],{"class":57,"line":113},[55,1164,934],{"class":76},[55,1166,750],{"class":72},[55,1168,77],{"class":76},[55,1170,1171],{"class":123},"'Hello Ray'",[55,1173,738],{"class":76},[55,1175,1176],{"class":57,"line":130},[55,1177,1178],{"class":76},"}\n",[55,1180,1181],{"class":57,"line":165},[55,1182,687],{"emptyLinePlaceholder":686},[55,1184,1185,1187,1189,1192,1194],{"class":57,"line":180},[55,1186,771],{"class":68},[55,1188,1137],{"class":68},[55,1190,1191],{"class":147}," obj",[55,1193,701],{"class":68},[55,1195,1196],{"class":76}," {\n",[55,1198,1199,1202,1205],{"class":57,"line":192},[55,1200,1201],{"class":76},"  myName: ",[55,1203,1204],{"class":123},"'Ray'",[55,1206,1207],{"class":76},",\n",[55,1209,1210],{"class":57,"line":198},[55,1211,1178],{"class":76},[55,1213,1214],{"class":57,"line":204},[55,1215,687],{"emptyLinePlaceholder":686},[55,1217,1218,1220,1222,1225,1227,1230,1233,1236,1239,1241,1244],{"class":57,"line":222},[55,1219,771