[{"data":1,"prerenderedAt":251},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fpwa\u002F2019\u002F11\u002F26\u002Fpwa-dev-environment-day5\u002F":3,"page:\u002Fen\u002Fpwa\u002F2019\u002F11\u002F26\u002Fpwa-dev-environment-day5\u002F":4,"alt:\u002Fen\u002Fpwa\u002F2019\u002F11\u002F26\u002Fpwa-dev-environment-day5\u002F":3,"prev-next:\u002Fen\u002Fpwa\u002F2019\u002F11\u002F26\u002Fpwa-dev-environment-day5\u002F":232,"related:\u002Fen\u002Fpwa\u002F2019\u002F11\u002F26\u002Fpwa-dev-environment-day5\u002F":241},"\u002Fpwa\u002F20191126\u002F3955439291\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":216,"date":217,"description":218,"extension":219,"lang":220,"meta":221,"navigation":222,"path":223,"readingMinutes":224,"seo":225,"standalone":226,"stem":227,"tags":228,"tldr":229,"updated":217,"url":230,"__hash__":231},"content\u002Fen\u002FPWA\u002Fpwa-dev-environment-day5.md","Day 5 — PWA First Look: Dev Environment Setup","8357205250",{"type":9,"value":10,"toc":202},"minimark",[11,16,20,24,27,37,41,49,55,62,68,71,75,86,92,95,101,104,110,114,121,127,130,137,143,146,172,175,179,182,188,191,195],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We've covered a fair bit. Time to set up the dev environment for PWA.",[12,21,23],{"id":22},"dev-environment","Dev environment",[17,25,26],{},"A sharper tool means better work. PWA development happens mostly in Chrome. Before continuing, make sure you have:",[28,29,30,34],"ul",{},[31,32,33],"li",{},"Chrome (version 74 or higher).",[31,35,36],{},"Basic HTML, CSS, JavaScript knowledge, and familiarity with Chrome DevTools.",[12,38,40],{"id":39},"enable-chromes-pwa-dev-mode","Enable Chrome's PWA dev mode",[17,42,43,44,48],{},"Chrome's PWA simulation mode has to be enabled manually. In Chrome's URL bar, type ",[45,46,47],"code",{},"chrome:\u002F\u002Fflags\u002F",":",[17,50,51],{},[52,53],"img",{"alt":47,"src":54},"https:\u002F\u002Fi.imgur.com\u002FWyPv7Wn.png",[17,56,57,58,61],{},"Find ",[45,59,60],{},"Desktop PWAs local updating"," and switch it from Default to Enabled:",[17,63,64],{},[52,65],{"alt":66,"src":67},"Enabled","https:\u002F\u002Fi.imgur.com\u002FWliug1Z.png",[17,69,70],{},"Restart Chrome.",[12,72,74],{"id":73},"verifying-pwa-is-on","Verifying PWA is on",[17,76,77,78,85],{},"To verify PWA is enabled, hit the ",[79,80,84],"a",{"href":81,"rel":82},"https:\u002F\u002Fevents.google.com\u002Fio2016\u002F",[83],"nofollow","Google I\u002FO 2016"," official site. You should see an install option in the top right:",[17,87,88],{},[52,89],{"alt":90,"src":91},"PWA install option","https:\u002F\u002Fi.imgur.com\u002FmbSnSSd.png",[17,93,94],{},"After installing, it'll auto-launch in PWA mode:",[17,96,97],{},[52,98],{"alt":99,"src":100},"PWA mode","https:\u002F\u002Fi.imgur.com\u002FHMs2IHl.png",[17,102,103],{},"In that PWA window, press F12 to open DevTools:",[17,105,106],{},[52,107],{"alt":108,"src":109},"DevTools","https:\u002F\u002Fi.imgur.com\u002Fye2Xsv4.png",[12,111,113],{"id":112},"viewing-manifest-and-service-workers","Viewing manifest and Service Workers",[17,115,116,117,120],{},"We covered both ",[45,118,119],{},"manifest"," and Service Workers in the last two posts, so let me show you how to view them. Open DevTools, click Application, and you'll see manifest and Service Workers in the sidebar:",[17,122,123],{},[52,124],{"alt":125,"src":126},"Application panel","https:\u002F\u002Fi.imgur.com\u002FsEwkNtc.png",[128,129,119],"h3",{"id":119},[17,131,132,133,136],{},"We talked about ",[45,134,135],{},"manifest.json"," being where you set the app name, icons, etc. — you can inspect all of those fields here:",[17,138,139],{},[52,140],{"alt":141,"src":142},"manifest panel","https:\u002F\u002Fi.imgur.com\u002FX0DnKee.png",[17,144,145],{},"Generally I'd recommend providing multiple icon sizes. I haven't deeply researched this, so I'll just point at Google's recommended sizes:",[28,147,148,151,154,157,160,163,166,169],{},[31,149,150],{},"48x48",[31,152,153],{},"72x72",[31,155,156],{},"96x96",[31,158,159],{},"144x144",[31,161,162],{},"168x168",[31,164,165],{},"192x192",[31,167,168],{},"256x256",[31,170,171],{},"512x512",[17,173,174],{},"(In practice I just use 192x192 and 512x512.)",[128,176,178],{"id":177},"service-workers","Service Workers",[17,180,181],{},"For Service Workers, you'll mostly use this panel:",[17,183,184],{},[52,185],{"alt":186,"src":187},"Service Workers panel","https:\u002F\u002Fi.imgur.com\u002FygYBFUM.png",[17,189,190],{},"I'll explain this part more clearly during the hands-on, since right now we're just doing dev-environment basics. For now, just know where things live.",[12,192,194],{"id":193},"references","References",[17,196,197],{},[79,198,201],{"href":199,"rel":200},"https:\u002F\u002Fdevelopers.google.com\u002Fweb\u002Ffundamentals\u002Fcodelabs\u002Fyour-first-pwapp",[83],"Your First Progressive Web App",{"title":203,"searchDepth":204,"depth":204,"links":205},"",2,[206,207,208,209,210,215],{"id":14,"depth":204,"text":15},{"id":22,"depth":204,"text":23},{"id":39,"depth":204,"text":40},{"id":73,"depth":204,"text":74},{"id":112,"depth":204,"text":113,"children":211},[212,214],{"id":119,"depth":213,"text":119},3,{"id":177,"depth":213,"text":178},{"id":193,"depth":204,"text":194},"PWA","2019-11-26 09:24:48","We've covered the basics. Now let's set up the dev environment for PWA.","md","en",{},true,"\u002Fen\u002Fpwa\u002Fpwa-dev-environment-day5","2",{"title":6,"description":218},false,"en\u002FPWA\u002Fpwa-dev-environment-day5",[216],null,"\u002Fen\u002Fpwa\u002F2019\u002F11\u002F26\u002Fpwa-dev-environment-day5\u002F","MzVnyAWJUBSehCKPRdD-zHSBor83mN7mXwhdoZbuVWY",{"newer":233,"older":237},{"url":234,"title":235,"date":236},"\u002Fen\u002Fpwa\u002F2019\u002F12\u002F03\u002Fpwa-hands-on-day6\u002F","Day 6 — PWA First Look: Hands-On With a Real Project","2019-12-03 09:53:48",{"url":238,"title":239,"date":240},"\u002Fen\u002Fjavascript\u002F2019\u002F11\u002F19\u002Fjavascript-functions-deep-dive\u002F","A (Slightly Long) Casual Look at JavaScript Functions","2019-11-19 21:11:19",[242,243,247],{"url":234,"title":235,"date":236,"readingMinutes":224},{"url":244,"title":245,"date":246,"readingMinutes":224},"\u002Fen\u002Fpwa\u002F2019\u002F11\u002F14\u002Fpwa-architecture-service-workers-day4\u002F","Day 4 — PWA First Look: Architecture (Part 2, Service Workers)","2019-11-14 22:56:48",{"url":248,"title":249,"date":250,"readingMinutes":224},"\u002Fen\u002Fpwa\u002F2019\u002F11\u002F04\u002Fpwa-architecture-manifest-day3\u002F","Day 3 — PWA First Look: Architecture (Part 1, Web App Manifest)","2019-11-04 17:24:48",1784020374337]