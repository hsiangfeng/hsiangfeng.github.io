ow","TDX API sample code",[17,37,38],{},"For Postman, the JavaScript version is the closest match. The sample:",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","$(function () {\n    $.ajax({\n        type: 'GET',\n        url: 'https:\u002F\u002Fptx.transportdata.tw\u002FMOTC\u002Fv2\u002FRail\u002FTRA\u002FStation?$top=10&$format=JSON', \u002F\u002F API URL — this example fetches TRA railway station data\n        dataType: 'json',\n        headers: GetAuthorizationHeader(),\n        success: function (Data) {\n            $('body').text(JSON.stringify(Data));\n        }\n    });\n});\n\nfunction GetAuthorizationHeader() {\n    var AppID = 'FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF';\n    var AppKey = 'FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF';\n\n    var GMTString = new Date().toGMTString();\n    var ShaObj = new jsSHA('SHA-1', 'TEXT');\n    ShaObj.setHMACKey(AppKey, 'TEXT');\n    ShaObj.update('x-date: ' + GMTString);\n    var HMAC = ShaObj.getHMAC('B64');\n    var Authorization = 'hmac username=\\\"' + AppID + '\\\", algorithm=\\\"hmac-sha1\\\", headers=\\\"x-date\\\", signature=\\\"' + HMAC + '\\\"';\n\n    return { 'Authorization': Authorization, 'X-Date': GMTString \u002F*,'Accept-Encoding': 'gzip'*\u002F};\n}\n","js","",[47,48,49,69,81,94,110,121,133,154,186,192,198,204,211,222,240,254,259,284,312,328,347,371,443,448,475],"code",{"__ignoreMap":45},[50,51,54,58,62,66],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sj_SG","$",[50,59,61],{"class":60},"sMAXC","(",[50,63,65],{"class":64},"sWyjQ","function",[50,67,68],{"class":60}," () {\n",[50,70,72,75,78],{"class":52,"line":71},2,[50,73,74],{"class":60},"    $.",[50,76,77],{"class":56},"ajax",[50,79,80],{"class":60},"({\n",[50,82,84,87,91],{"class":52,"line":83},3,[50,85,86],{"class":60},"        type: ",[50,88,90],{"class":89},"sTRMh","'GET'",[50,92,93],{"class":60},",\n",[50,95,97,100,103,106],{"class":52,"line":96