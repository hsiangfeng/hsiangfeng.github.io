lass":73,"line":1052},15,[71,1054,232],{"class":141},[71,1056,42],{"class":145},[71,1058,1032],{"class":141},[71,1060,42],{"class":145},[71,1062,153],{"class":141},[71,1064,1066,1068,1070,1072,1074],{"class":73,"line":1065},16,[71,1067,232],{"class":141},[71,1069,42],{"class":145},[71,1071,1032],{"class":141},[71,1073,42],{"class":145},[71,1075,153],{"class":141},[71,1077,1079,1081,1083],{"class":73,"line":1078},17,[71,1080,247],{"class":141},[71,1082,39],{"class":145},[71,1084,153],{"class":141},[71,1086,1088,1090,1093,1096,1098],{"class":73,"line":1087},18,[71,1089,177],{"class":141},[71,1091,1092],{"class":145},"footer",[71,1094,1095],{"class":141},">Footer\u003C\u002F",[71,1097,1092],{"class":145},[71,1099,153],{"class":141},[71,1101,1103,1105,1107],{"class":73,"line":1102},19,[71,1104,192],{"class":141},[71,1106,214],{"class":145},[71,1108,153],{"class":141},[71,1110,1112,1114,1116],{"class":73,"line":1111},20,[71,1113,266],{"class":141},[71,1115,204],{"class":145},[71,1117,153],{"class":141},[71,1119,1121,1123,1125],{"class":73,"line":1120},21,[71,1122,266],{"class":141},[71,1124,134],{"class":145},[71,1126,153],{"class":141},[17,1128,1129,1130,1133,1134,1136],{},"How it works — at build time, the framework (Nuxt, Next, etc.) calls your AJAX endpoints once, pulls initial data, and ",[28,1131,1132],{},"writes it into the HTML output",". So when a user \"View Source\"s a SSG-built page, they see a fully rendered tree, not just ",[68,1135,866],{},".",[17,1138,1139],{},"Which is why the \"View Source = SSR vs CSR\" trick is just a heuristic — you can't be 100% sure without other context.",[12,1141,1143],{"id":1142},"references","References",[39,1145,1146,1153],{},[42,1147,1148],{},[298,1149,1152],{"href":1150,"rel":1151},"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FServer-side_rendering",[302],"Server-side rendering (Wikipedia)",[42,1154,1155],{},[298,1156,1159],{"href":1157,"rel":1158},"https:\u002F\u002Fen.wikipedia.org\u002Fwiki\u002FSingle-page_applicati