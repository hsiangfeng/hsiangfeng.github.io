[{"data":1,"prerenderedAt":146},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fmisc\u002F2019\u002F12\u002F20\u002Fdisable-slack-auto-format-messages\u002F":3,"page:\u002Fen\u002Fmisc\u002F2019\u002F12\u002F20\u002Fdisable-slack-auto-format-messages\u002F":4,"alt:\u002Fen\u002Fmisc\u002F2019\u002F12\u002F20\u002Fdisable-slack-auto-format-messages\u002F":3,"prev-next:\u002Fen\u002Fmisc\u002F2019\u002F12\u002F20\u002Fdisable-slack-auto-format-messages\u002F":121,"related:\u002Fen\u002Fmisc\u002F2019\u002F12\u002F20\u002Fdisable-slack-auto-format-messages\u002F":130},"\u002Fother\u002F20191220\u002F4162492528\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":103,"date":104,"description":105,"extension":106,"lang":107,"meta":108,"navigation":109,"path":110,"readingMinutes":111,"seo":112,"standalone":113,"stem":114,"tags":115,"tldr":118,"updated":118,"url":119,"__hash__":120},"content\u002Fen\u002FMisc\u002Fdisable-slack-auto-format-messages.md","Turn Off Slack's Auto-Format Messages in One Minute","1624925284",{"type":9,"value":10,"toc":95},"minimark",[11,16,20,24,27,34,37,41,44,50,58,63,66,72,76,79],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"A recent Slack update added a feature called Slack Auto-Format Messages. What is it?",[12,21,23],{"id":22},"slack-auto-format-messages","Slack Auto-Format Messages",[17,25,26],{},"It auto-converts your Markdown into rendered text in real time as you type — WYSIWYG. Nice for some, painful for others (like me).",[17,28,29],{},[30,31],"img",{"alt":32,"src":33},"Auto-format in action","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F1576726470091.gif",[17,35,36],{},"Sometimes the auto-formatting also makes multi-line composition awkward. So I want to turn it off.",[12,38,40],{"id":39},"turning-off-auto-format-messages","Turning off Auto-Format Messages",[17,42,43],{},"Click your Slack workspace name → Preferences:",[17,45,46],{},[30,47],{"alt":48,"src":49},"Preferences","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F2019-12-19_11-37-41.png",[17,51,52,53,57],{},"Switch to Advanced → check ",[54,55,56],"strong",{},"Format messages with markup",":",[17,59,60],{},[30,61],{"alt":56,"src":62},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F2019-12-19_11-39-50.png",[17,64,65],{},"Done — Auto-Format is off, and you still get Markdown rendering in messages:",[17,67,68],{},[30,69],{"alt":70,"src":71},"After","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F1576726877413.gif",[12,73,75],{"id":74},"bonus","Bonus",[17,77,78],{},"Two other options worth knowing in the same panel:",[80,81,82,89],"ul",{},[83,84,85,88],"li",{},[54,86,87],{},"When typing code with ``` , Enter should not send the message"," — once you've opened a triple-backtick code block, Enter no longer submits. You have to use Shift + Enter to send.",[83,90,91,94],{},[54,92,93],{},"Show send button"," — adds a visible Send button to the composer.",{"title":96,"searchDepth":97,"depth":97,"links":98},"",2,[99,100,101,102],{"id":14,"depth":97,"text":15},{"id":22,"depth":97,"text":23},{"id":39,"depth":97,"text":40},{"id":74,"depth":97,"text":75},"Misc","2019-12-20 11:30:34","Recent Slack updates added an auto-formatting feature that converts your Markdown into rendered text in real time as you type. For some people that's nice; for others (myself included) it makes multi-line composition annoying. Two-click fix to turn it off without losing Markdown support entirely.","md","en",{},true,"\u002Fen\u002Fmisc\u002Fdisable-slack-auto-format-messages","1",{"title":6,"description":105},false,"en\u002FMisc\u002Fdisable-slack-auto-format-messages",[116,117],"Slack","Software",null,"\u002Fen\u002Fmisc\u002F2019\u002F12\u002F20\u002Fdisable-slack-auto-format-messages\u002F","Iwkj7JMoaZydNlRSWNXft78WVClawT9J4DS7_aMTx0M",{"newer":122,"older":126},{"url":123,"title":124,"date":125},"\u002Fen\u002Fgulp\u002F2019\u002F12\u002F20\u002Fgulp-deploy-typeerror-cannot-read-property-fix\u002F","Gulp deploy Throws TypeError: Cannot read property 0 of null","2019-12-20 14:48:05",{"url":127,"title":128,"date":129},"\u002Fen\u002Fgulp\u002F2019\u002F12\u002F13\u002Fgulp-series-20-heroku-deploy\u002F","Gulp Series Bonus: Deploying Gulp to Heroku","2019-12-13 21:37:33",[131,136,141],{"url":132,"title":133,"date":134,"readingMinutes":135},"\u002Fen\u002Fmisc\u002F2026\u002F06\u002F23\u002Fmac-stats-menu-bar-system-monitor\u002F","Stats — The Free Open-Source macOS Menu Bar System Monitor I Use Every Day (CPU, GPU, Temperature, Network)","2026-06-23 10:00:00","5",{"url":137,"title":138,"date":139,"readingMinutes":140},"\u002Fen\u002Fmisc\u002F2026\u002F05\u002F26\u002Fhow-much-does-a-blog-really-earn-with-google-adsense\u002F","Can a Blog Really Make Tens of Thousands of Dollars a Month? Real Google AdSense Numbers, Explained","2026-05-26 21:00:00","6",{"url":142,"title":143,"date":144,"readingMinutes":145},"\u002Fen\u002Fmisc\u002F2026\u002F05\u002F18\u002Fvscode-disable-integrated-browser-auto-open\u002F","VSCode Opens Every Link in the Integrated Browser? How to Disable Auto Takeover","2026-05-18 14:30:00","4",1784011704844]