[{"data":1,"prerenderedAt":726},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fmisc\u002F2022\u002F01\u002F04\u002Fcommon-http-status-codes-2xx-4xx-5xx\u002F":3,"page:\u002Fen\u002Fmisc\u002F2022\u002F01\u002F04\u002Fcommon-http-status-codes-2xx-4xx-5xx\u002F":4,"alt:\u002Fen\u002Fmisc\u002F2022\u002F01\u002F04\u002Fcommon-http-status-codes-2xx-4xx-5xx\u002F":3,"prev-next:\u002Fen\u002Fmisc\u002F2022\u002F01\u002F04\u002Fcommon-http-status-codes-2xx-4xx-5xx\u002F":701,"related:\u002Fen\u002Fmisc\u002F2022\u002F01\u002F04\u002Fcommon-http-status-codes-2xx-4xx-5xx\u002F":710},"\u002Fother\u002F20220104\u002F255997626\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":684,"date":685,"description":686,"extension":687,"lang":688,"meta":689,"navigation":590,"path":690,"readingMinutes":691,"seo":692,"standalone":693,"stem":694,"tags":695,"tldr":698,"updated":698,"url":699,"__hash__":700},"content\u002Fen\u002FMisc\u002Fcommon-http-status-codes-2xx-4xx-5xx.md","Common HTTP Status Codes — 2xx, 4xx, 5xx Explained","6259976210",{"type":9,"value":10,"toc":664},"minimark",[11,16,20,24,27,30,49,61,64,67,74,77,87,162,168,174,177,180,185,192,251,266,270,273,330,333,336,344,348,351,355,358,361,365,368,371,375,388,394,397,403,406,462,465,468,474,478,481,486,489,636,640,646,650,660],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"If you've used the internet, you've definitely seen HTTP status codes. If you're heading toward backend dev, knowing them is non-negotiable. So this post is the quick tour of the common ones.",[12,21,23],{"id":22},"http-status-codes","HTTP Status Codes",[17,25,26],{},"This isn't an exhaustive list — there are way too many codes and edge cases. I'm listing the common, foundational ones. Cover those and you've got 80% of what you need for day-to-day debugging.",[17,28,29],{},"HTTP status codes split into five categories:",[31,32,33,37,40,43,46],"ul",{},[34,35,36],"li",{},"1xx — Informational",[34,38,39],{},"2xx — Success",[34,41,42],{},"3xx — Redirects",[34,44,45],{},"4xx — Client errors",[34,47,48],{},"5xx — Server errors",[17,50,51,52,56,57,60],{},"Just from the leading digit you know what's up. ",[53,54,55],"code",{},"5xx"," always points at the backend. ",[53,58,59],{},"4xx"," is usually a client\u002Fdev mistake. And so on.",[17,62,63],{},"If you don't want to memorize a lot, just remember those five categories. Look the rest up as needed. The list below is the genuinely common ones.",[17,65,66],{},"But honestly, the one you'll see most is 404.",[17,68,69],{},[70,71],"img",{"alt":72,"src":73},"Ahhh, this page doesn't exist","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002FrjpHeSm.gif",[12,75,39],{"id":76},"_2xx-success",[17,78,79,80,83,84,86],{},"Easy mode. The vast majority of working page loads return ",[53,81,82],{},"200",". Most frameworks default to ",[53,85,82],{}," — in Express.js, even this minimal handler returns 200:",[88,89,94],"pre",{"className":90,"code":91,"language":92,"meta":93,"style":93},"language-js shiki shiki-themes github-dark-high-contrast","router.get('\u002F', (req, res) => {\n  res.send('True');\n})\n","js","",[53,95,96,139,156],{"__ignoreMap":93},[97,98,101,105,109,112,116,119,123,126,129,132,136],"span",{"class":99,"line":100},"line",1,[97,102,104],{"class":103},"sMAXC","router.",[97,106,108],{"class":107},"sj_SG","get",[97,110,111],{"class":103},"(",[97,113,115],{"class":114},"sTRMh","'\u002F'",[97,117,118],{"class":103},", (",[97,120,122],{"class":121},"s_sBn","req",[97,124,125],{"class":103},", ",[97,127,128],{"class":121},"res",[97,130,131],{"class":103},") ",[97,133,135],{"class":134},"sWyjQ","=>",[97,137,138],{"class":103}," {\n",[97,140,142,145,148,150,153],{"class":99,"line":141},2,[97,143,144],{"class":103},"  res.",[97,146,147],{"class":107},"send",[97,149,111],{"class":103},[97,151,152],{"class":114},"'True'",[97,154,155],{"class":103},");\n",[97,157,159],{"class":99,"line":158},3,[97,160,161],{"class":103},"})\n",[17,163,164,165,167],{},"As long as the request hit the route and got a response, it defaults to ",[53,166,82],{},". Super common.",[17,169,170,171,173],{},"In short, ",[53,172,82],{}," means \"you successfully got the resource \u002F loaded the page\".",[12,175,42],{"id":176},"_3xx-redirects",[17,178,179],{},"Most common ones are 301 Moved Permanently and 302 Found.",[181,182,184],"h3",{"id":183},"_301-moved-permanently","301 Moved Permanently",[17,186,187,188,191],{},"After a project's been around for a while, some pages move. ",[53,189,190],{},"301"," tells the browser \"this page has moved here permanently\". Express.js:",[88,193,195],{"className":90,"code":194,"language":92,"meta":93,"style":93},"router.get('\u002F', (req, res) => {\n  res.status(301).redirect('http:\u002F\u002Fyourotherdomain.com')\n})\n",[53,196,197,221,247],{"__ignoreMap":93},[97,198,199,201,203,205,207,209,211,213,215,217,219],{"class":99,"line":100},[97,200,104],{"class":103},[97,202,108],{"class":107},[97,204,111],{"class":103},[97,206,115],{"class":114},[97,208,118],{"class":103},[97,210,122],{"class":121},[97,212,125],{"class":103},[97,214,128],{"class":121},[97,216,131],{"class":103},[97,218,135],{"class":134},[97,220,138],{"class":103},[97,222,223,225,228,230,233,236,239,241,244],{"class":99,"line":141},[97,224,144],{"class":103},[97,226,227],{"class":107},"status",[97,229,111],{"class":103},[97,231,190],{"class":232},"sCcAr",[97,234,235],{"class":103},").",[97,237,238],{"class":107},"redirect",[97,240,111],{"class":103},[97,242,243],{"class":114},"'http:\u002F\u002Fyourotherdomain.com'",[97,245,246],{"class":103},")\n",[97,248,249],{"class":99,"line":158},[97,250,161],{"class":103},[17,252,253,254,257,258,261,262,265],{},"For example, going to ",[53,255,256],{},"www.google.com"," permanently redirects you to ",[53,259,260],{},"google.com"," without the ",[53,263,264],{},"www",".",[181,267,269],{"id":268},"_302-found","302 Found",[17,271,272],{},"What if it's just a temporary move? Same idea:",[88,274,276],{"className":90,"code":275,"language":92,"meta":93,"style":93},"router.get('\u002F', (req, res) => {\n  res.status(302).sendFile(__dirname, 'newPage.html');\n})\n",[53,277,278,302,326],{"__ignoreMap":93},[97,279,280,282,284,286,288,290,292,294,296,298,300],{"class":99,"line":100},[97,281,104],{"class":103},[97,283,108],{"class":107},[97,285,111],{"class":103},[97,287,115],{"class":114},[97,289,118],{"class":103},[97,291,122],{"class":121},[97,293,125],{"class":103},[97,295,128],{"class":121},[97,297,131],{"class":103},[97,299,135],{"class":134},[97,301,138],{"class":103},[97,303,304,306,308,310,313,315,318,321,324],{"class":99,"line":141},[97,305,144],{"class":103},[97,307,227],{"class":107},[97,309,111],{"class":103},[97,311,312],{"class":232},"302",[97,314,235],{"class":103},[97,316,317],{"class":107},"sendFile",[97,319,320],{"class":103},"(__dirname, ",[97,322,323],{"class":114},"'newPage.html'",[97,325,155],{"class":103},[97,327,328],{"class":99,"line":158},[97,329,161],{"class":103},[17,331,332],{},"Just temporary.",[12,334,45],{"id":335},"_4xx-client-errors",[17,337,338,339,343],{},"4xx has ",[340,341,342],"em",{},"so many"," variants — too many.",[181,345,347],{"id":346},"_400-bad-request","400 Bad Request",[17,349,350],{},"Hard to give one example because the cases are so varied. Sending the wrong format (you passed an array when the server wanted a JSON object), file too large, malformed body — all 400.",[181,352,354],{"id":353},"_401-unauthorized","401 Unauthorized",[17,356,357],{},"Common on auth-protected pages. If you don't include some kind of identity proof (a token, etc.) you get a 401. It implies rejection too.",[17,359,360],{},"Think of it as \"you haven't given me anything to authenticate with, so I'm refusing to give you anything\". Bottom line — \"not logged in\".",[181,362,364],{"id":363},"_403-forbidden","403 Forbidden",[17,366,367],{},"403 is similar to 401, but it's more \"I'm rejecting you\" \u002F \"blocklist territory\". I know who you are and I'm still refusing. Example — you have read access to the products list, but you try to read the orders list. 403.",[17,369,370],{},"Or to flip the analogy — \"your friend asks you out, you reject them and block them\". (Sad analogy.)",[181,372,374],{"id":373},"_404-not-found","404 Not Found",[17,376,377,378,381,382,387],{},"If you've ever used the internet, you've hit ",[53,379,380],{},"404",". \"Resource \u002F path \u002F page not found\". Click ",[383,384,386],"a",{"href":385},"\u002F1","this link"," on this blog to see my 404 page:",[17,389,390],{},[70,391],{"alt":392,"src":393},"404 Error","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-01-04%2010.29.35.png",[17,395,396],{},"404 is the textbook common one. It also matters for SEO — telling the user (and the crawler) \"this page doesn't exist\". You'll see a lot of nicely-designed 404 pages out there:",[17,398,399],{},[70,400],{"alt":401,"src":402},"Pretty 404","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-01-04%2010.34.00.png",[17,404,405],{},"In AJAX contexts, 404 usually means you've typed the wrong API URL. Express.js handles this by default:",[88,407,409],{"className":90,"code":408,"language":92,"meta":93,"style":93},"app.use(function(req, res, next) {\n  next(createError(404));\n});\n",[53,410,411,440,457],{"__ignoreMap":93},[97,412,413,416,419,421,424,426,428,430,432,434,437],{"class":99,"line":100},[97,414,415],{"class":103},"app.",[97,417,418],{"class":107},"use",[97,420,111],{"class":103},[97,422,423],{"class":134},"function",[97,425,111],{"class":103},[97,427,122],{"class":121},[97,429,125],{"class":103},[97,431,128],{"class":121},[97,433,125],{"class":103},[97,435,436],{"class":121},"next",[97,438,439],{"class":103},") {\n",[97,441,442,445,447,450,452,454],{"class":99,"line":141},[97,443,444],{"class":107},"  next",[97,446,111],{"class":103},[97,448,449],{"class":107},"createError",[97,451,111],{"class":103},[97,453,380],{"class":232},[97,455,456],{"class":103},"));\n",[97,458,459],{"class":99,"line":158},[97,460,461],{"class":103},"});\n",[17,463,464],{},"In short — 404 is \"page not found \u002F path not found \u002F resource not found\".",[12,466,48],{"id":467},"_5xx-server-errors",[17,469,470,471,473],{},"If you're a frontend dev and you see a ",[53,472,55],{},", 60-70% of the time you can pass it back to the backend — these errors are server-side.",[181,475,477],{"id":476},"_500-internal-server-error","500 Internal Server Error",[17,479,480],{},"500 is the catch-all server error. You'll bump into it browsing the web — the server hit something unrecoverable and couldn't give you back what you wanted.",[17,482,483],{},[70,484],{"alt":477,"src":485},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-01-04%2010.53.42.png",[17,487,488],{},"Express.js handles this out of the box too:",[88,490,492],{"className":90,"code":491,"language":92,"meta":93,"style":93},"\u002F\u002F error handler\napp.use((err, req, res, next) => {\n  \u002F\u002F set locals, only providing error in development\n  res.locals.message = err.message;\n  res.locals.error = req.app.get('env') === 'development' ? err : {};\n\n  \u002F\u002F render the error page\n  res.status(err.status || 500);\n  res.render('error');\n});\n",[53,493,494,500,530,535,547,585,592,598,616,631],{"__ignoreMap":93},[97,495,496],{"class":99,"line":100},[97,497,499],{"class":498},"sQrFR","\u002F\u002F error handler\n",[97,501,502,504,506,509,512,514,516,518,520,522,524,526,528],{"class":99,"line":141},[97,503,415],{"class":103},[97,505,418],{"class":107},[97,507,508],{"class":103},"((",[97,510,511],{"class":121},"err",[97,513,125],{"class":103},[97,515,122],{"class":121},[97,517,125],{"class":103},[97,519,128],{"class":121},[97,521,125],{"class":103},[97,523,436],{"class":121},[97,525,131],{"class":103},[97,527,135],{"class":134},[97,529,138],{