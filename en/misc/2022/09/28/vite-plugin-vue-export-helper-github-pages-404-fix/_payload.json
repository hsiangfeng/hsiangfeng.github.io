[{"data":1,"prerenderedAt":606},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fmisc\u002F2022\u002F09\u002F28\u002Fvite-plugin-vue-export-helper-github-pages-404-fix\u002F":3,"page:\u002Fen\u002Fmisc\u002F2022\u002F09\u002F28\u002Fvite-plugin-vue-export-helper-github-pages-404-fix\u002F":4,"alt:\u002Fen\u002Fmisc\u002F2022\u002F09\u002F28\u002Fvite-plugin-vue-export-helper-github-pages-404-fix\u002F":3,"prev-next:\u002Fen\u002Fmisc\u002F2022\u002F09\u002F28\u002Fvite-plugin-vue-export-helper-github-pages-404-fix\u002F":581,"related:\u002Fen\u002Fmisc\u002F2022\u002F09\u002F28\u002Fvite-plugin-vue-export-helper-github-pages-404-fix\u002F":590},"\u002Fother\u002F20220928\u002F1377668819\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":562,"date":563,"description":564,"extension":565,"lang":566,"meta":567,"navigation":156,"path":568,"readingMinutes":569,"seo":570,"standalone":571,"stem":572,"tags":573,"tldr":578,"updated":578,"url":579,"__hash__":580},"content\u002Fen\u002FMisc\u002Fvite-plugin-vue-export-helper-github-pages-404-fix.md","Vite Deployed to GitHub Pages but _plugin-vue_export-helper Returns 404","9181766770",{"type":9,"value":10,"toc":556},"minimark",[11,16,25,29,36,42,45,49,52,59,70,76,89,96,528,534,538,552],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"Recently I hit this — Vite builds and deploys to GitHub Pages fine, but the site doesn't actually work. Turns out ",[21,22,23],"code",{},"_plugin-vue_export-helper"," was the culprit. Writing it up.",[12,26,28],{"id":27},"what-happened","What happened",[17,30,31,32,35],{},"After running ",[21,33,34],{},"npm run build"," and deploying to GitHub Pages, I started getting:",[37,38,39],"blockquote",{},[17,40,41],{},"TypeError: error loading dynamically imported module\nFailed to load module from \"\u002Fassets\u002F_plugin-vue_export-helper.cdc0426e.js\".",[17,43,44],{},"And then a totally blank page. Here's how I got it working.",[12,46,48],{"id":47},"the-fix","The fix",[17,50,51],{},"First instinct — path issue. So I tried hitting other built file URLs in the browser, and they all loaded fine. Only this one file kept 404'ing.",[17,53,54],{},[55,56],"img",{"alt":57,"src":58},"404","https:\u002F\u002Fi.imgur.com\u002F57qRC5h.png",[17,60,61,62,69],{},"I searched \"_plugin-vue_export-helper\" and found this GitHub issue: ",[63,64,68],"a",{"href":65,"rel":66},"https:\u002F\u002Fgithub.com\u002Fvitejs\u002Fvite\u002Fissues\u002F9119",[67],"nofollow","_plugin-vue_export-helper js file cant not be access with Github Pages(404)",".",[17,71,72,73,75],{},"The problem — ",[21,74,23],{}," as a filename hits a naming edge case in some environments (specifically GitHub Pages' Jekyll, which ignores underscore-prefixed files). Solution is to rename the file. Vite uses Rollup under the hood for bundling, so the rename is done through Rollup config.",[17,77,78,79,84,85,88],{},"The relevant Rollup source file is ",[63,80,83],{"href":81,"rel":82},"https:\u002F\u002Fgithub.com\u002Frollup\u002Frollup\u002Fblob\u002Fmaster\u002Fsrc\u002Futils\u002FsanitizeFileName.ts",[67],"sanitizeFileName.ts"," — that's what handles output filenames. We're not going to edit ",[21,86,87],{},"node_modules"," directly though; we override the behavior through Vite config instead.",[17,90,91,92,95],{},"Open ",[21,93,94],{},"vite.config.js"," and add this:",[97,98,103],"pre",{"className":99,"code":100,"language":101,"meta":102,"style":102},"language-js shiki shiki-themes github-dark-high-contrast","import { defineConfig } from 'vite'\nimport vue from '@vitejs\u002Fplugin-vue'\nimport path from 'path'\n\n\u002F\u002F eslint-disable-next-line no-control-regex\nconst INVALID_CHAR_REGEX = \u002F[\\x00-\\x1F\\x7F\u003C>*#\"{}|^[\\]`;?:&=+$,]\u002Fg;\nconst DRIVE_LETTER_REGEX = \u002F^[a-z]:\u002Fi;\n\nexport default defineConfig({\n  plugins: [vue()],\n  resolve: {\n    alias: {\n      \"@\": fileURLToPath(new URL(\".\u002Fsrc\", import.meta.url)),\n    },\n  },\n  build: {\n    rollupOptions: {\n      output: {\n        \u002F\u002F https:\u002F\u002Fgithub.com\u002Frollup\u002Frollup\u002Fblob\u002Fmaster\u002Fsrc\u002Futils\u002FsanitizeFileName.ts\n        sanitizeFileName(name) {\n          const match = DRIVE_LETTER_REGEX.exec(name);\n          const driveLetter = match ? match[0] : '';\n          \u002F\u002F substr is deprecated, swap to slice\n          return (\n            driveLetter +\n            name.slice(driveLetter.length).replace(INVALID_CHAR_REGEX, \"\")\n          );\n        },\n      },\n    },\n  },\n});\n","js","",[21,104,105,125,138,151,158,165,212,238,243,260,275,281,287,326,332,340,346,352,358,364,378,399,432,438,447,456,490,496,502,508,513,520],{"__ignoreMap":102},[106,107,110,114,118,121],"span",{"class":108,"line":109},"line",1,[106,111,113],{"class":112},"sWyjQ","import",[106,115,117],{"class":116},"sMAXC"," { defineConfig } ",[106,119,120],{"class":112},"from",[106,122,124],{"class":123},"sTRMh"," 'vite'\n",[106,126,128,130,133,135],{"class":108,"line":127},2,[106,129,113],{"class":112},[106,131,132],{"class":116}," vue ",[106,134,120],{"class":112},[106,136,137],{"class":123}," '@vitejs\u002Fplugin-vue'\n",[106,139,141,143,146,148],{"class":108,"line":140},3,[106,142,113],{"class":112},[106,144,145],{"class":116}," path ",[106,147,120],{"class":112},[106,149,150],{"class":123}," 'path'\n",[106,152,154],{"class":108,"line":153},4,[106,155,157],{"emptyLinePlaceholder":156},true,"\n",[106,159,161],{"class":108,"line":160},5,[106,162,164],{"class":163},"sQrFR","\u002F\u002F eslint-disable-next-line no-control-regex\n",[106,166,168,171,175,178,181,184,187,190,193,196,200,203,206,209],{"class":108,"line":167},6,[106,169,170],{"class":112},"const",[106,172,174],{"class":173},"sCcAr"," INVALID_CHAR_REGEX",[106,176,177],{"class":112}," =",[106,179,180],{"class":123}," \u002F",[106,182,183],{"class":173},"[",[106,185,186],{"class":112},"\\x00",[106,188,189],{"class":173},"-",[106,191,192],{"class":112},"\\x1F