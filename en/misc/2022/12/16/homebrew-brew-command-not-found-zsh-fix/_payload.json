[{"data":1,"prerenderedAt":464},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F":3,"page:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F":4,"alt:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F":3,"prev-next:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F":439,"related:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F":448},"\u002Fother\u002F20221216\u002F325048828\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":420,"date":421,"description":422,"extension":423,"lang":424,"meta":425,"navigation":426,"path":427,"readingMinutes":428,"seo":429,"standalone":430,"stem":431,"tags":432,"tldr":436,"updated":421,"url":437,"__hash__":438},"content\u002Fen\u002FMisc\u002Fhomebrew-brew-command-not-found-zsh-fix.md","Homebrew zsh: command not found: brew — How I Fixed It","8082450523",{"type":9,"value":10,"toc":414},"minimark",[11,16,20,24,32,69,76,96,103,110,114,117,144,147,173,176,182,188,276,279,301,312,349,362,369,388,395,399,410],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"One day I went to install something and got \"zsh: command not found: brew install\". So I'm writing this down.",[12,21,23],{"id":22},"what-i-saw","What I saw",[17,25,26,27,31],{},"One day I typed ",[28,29,30],"code",{},"brew install flyctl"," and got:",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-bash shiki shiki-themes github-dark-high-contrast","zsh: command not found: brew install flyctl\n","bash","",[28,40,41],{"__ignoreMap":38},[42,43,46,50,54,57,60,63,66],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"s_sBn","zsh:",[42,51,53],{"class":52},"sTRMh"," command",[42,55,56],{"class":52}," not",[42,58,59],{"class":52}," found:",[42,61,62],{"class":52}," brew",[42,64,65],{"class":52}," install",[42,67,68],{"class":52}," flyctl\n",[17,70,71,72,75],{},"Then I tried ",[28,73,74],{},"brew list",", same thing:",[33,77,79],{"className":35,"code":78,"language":37,"meta":38,"style":38},"zsh: command not found: brew list\n",[28,80,81],{"__ignoreMap":38},[42,82,83,85,87,89,91,93],{"class":44,"line":45},[42,84,49],{"class":48},[42,86,53],{"class":52},[42,88,56],{"class":52},[42,90,59],{"class":52},[42,92,62],{"class":52},[42,94,95],{"class":52}," list\n",[17,97,98,99,102],{},"But I hadn't changed anything recently. And weirder still — when I typed just ",[28,100,101],{},"brew",", I got the help output:",[17,104,105],{},[106,107],"img",{"alt":108,"src":109},"brew help works","https:\u002F\u002Fi.imgur.com\u002FfRcqilN.png",[12,111,113],{"id":112},"the-fix","The fix",[17,115,116],{},"First thought — maybe my PATH got broken. The line in question:",[33,118,120],{"className":35,"code":119,"language":37,"meta":38,"style":38},"export PATH=\"\u002Fusr\u002Flocal\u002Fbin:$PATH\"\n",[28,121,122],{"__ignoreMap":38},[42,123,124,128,132,135,138,141],{"class":44,"line":45},[42,125,127],{"class":126},"sWyjQ","export",[42,129,131],{"class":130},"sMAXC"," PATH",[42,133,134],{"class":126},"=",[42,136,137],{"class":52},"\"\u002Fusr\u002Flocal\u002Fbin:",[42,139,140],{"class":130},"$PATH",[42,142,143],{"class":52},"\"\n",[17,145,146],{},"Gut call was reinstalling Homebrew:",[33,148,150],{"className":35,"code":149,"language":37,"meta":38,"style":38},"\u002Fbin\u002Fbash -c \"$(curl -fsSL https:\u002F\u002Fraw.githubusercontent.com\u002FHomebrew\u002Finstall\u002FHEAD\u002Finstall.sh)\"\n",[28,151,152],{"__ignoreMap":38},[42,153,154,157,161,164,167,170],{"class":44,"line":45},[42,155,156],{"class":48},"\u002Fbin\u002Fbash",[42,158,160],{"class":159},"sCcAr"," -c",[42,162,163],{"class":52}," \"$(",[42,165,166],{"class":48},"curl",[42,168,169],{"class":159}," -fsSL",[42,171,172],{"class":52}," https:\u002F\u002Fraw.githubusercontent.com\u002FHomebrew\u002Finstall\u002FHEAD\u002Finstall.sh)\"\n",[17,174,175],{},"(Homebrew's install is painfully slow, by the way.)",[17,177,178,179,181],{},"After install, ",[28,180,30],{}," still failed. So I actually read the installer's output this time:",[17,183,184],{},[106,185],{"alt":186,"src":187},"Installer hint","https:\u002F\u002Fi.imgur.com\u002FA9ozPdN.png",[33,189,191],{"className":35,"code":190,"language":37,"meta":38,"style":38},"- Run these three commands in your terminal to add Homebrew to your PATH:\n    echo '# Set PATH, MANPATH, etc., for Homebrew.' >> \u002FUsers\u002Frayxu\u002F.zprofile\n    echo 'eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"' >> \u002FUsers\u002Frayxu\u002F.zprofile\n    eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"\n",[28,192,193,235,250,262],{"__ignoreMap":38},[42,194,195,198,201,204,207,210,213,216,219,222,225,228,230,232],{"class":44,"line":45},[42,196,197],{"class":48},"-",[42,199,200],{"class":52}," Run",[42,202,203],{"class":52}," these",[42,205,206],{"class":52}," three",[42,208,209],{"class":52}," commands",[42,211,212],{"class":52}," in",[42,214,215],{"class":52}," your",[42,217,218],{"class":52}," terminal",[42,220,221],{"class":52}," to",[42,223,224],{"class":52}," add",[42,226,227],{"class":52}," Homebrew",[42,229,221],{"class":52},[42,231,215],{"class":52},[42,233,234],{"class":52}," PATH:\n",[42,236,238,241,244,247],{"class":44,"line":237},2,[42,239,240],{"class":159},"    echo",[42,242,243],{"class":52}," '# Set PATH, MANPATH, etc., for Homebrew.'",[42,245,246],{"class":126}," >>",[42,248,249],{"class":52}," \u002FUsers\u002Frayxu\u002F.zprofile\n",[42,251,253,255,258,260],{"class":44,"line":252},3,[42,254,240],{"class":159},[42,256,257],{"class":52}," 'eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"'",[42,259,246],{"class":126},[42,261,249],{"class":52},[42,263,265,268,270,273],{"class":44,"line":264},4,[42,266,267],{"class":159},"    eval",[42,269,163],{"class":52},[42,271,272],{"class":48},"\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew",[42,274,275],{"class":52}," shellenv)\"\n",[17,277,278],{},"These three lines just set up Homebrew's PATH — they boil down to:",[33,280,282],{"className":35,"code":281,"language":37,"meta":38,"style":38},"# Set PATH, MANPATH, etc., for Homebrew.\neval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"\n",[28,283,284,290],{"__ignoreMap":38},[42,285,286],{"class":44,"line":45},[42,287,289],{"class":288},"sQrFR","# Set PATH, MANPATH, etc., for Homebrew.\n",[42,291,292,295,297,299],{"class":44,"line":237},[42,293,294],{"class":159},"eval",[42,296,163],{"class":52},[42,298,272],{"class":48},[42,300,275],{"class":52},[17,302,303,304,307,308,311],{},"The installer defaults to ",[28,305,306],{},".zprofile",", but I use zsh, so I swapped it to ",[28,309,310],{},".zshrc",":",[33,313,315],{"className":35,"code":314,"language":37,"meta":38,"style":38},"echo '# Set PATH, MANPATH, etc., for Homebrew.' >> \u002FUsers\u002Frayxu\u002F.zshrc\necho 'eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"' >> \u002FUsers\u002Frayxu\u002F.zshrc\neval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"\n",[28,316,317,329,339],{"__ignoreMap":38},[42,318,319,322,324,326],{"class":44,"line":45},[42,320,321],{"class":159},"echo",[42,323,243],{"class":52},[42,325,246],{"class":126},[42,327,328],{"class":52}," \u002FUsers\u002Frayxu\u002F.zshrc\n",[42,330,331,333,335,337],{"class":44,"line":237},[42,332,321],{"class":159},[42,334,257],{"class":52},[42,336,246],{"class":126},[42,338,328],{"class":52},[42,340,341,343,345,347],{"class":44,"line":252},[42,342,294],{"class":159},[42,344,163],{"class":52},[42,346,272],{"class":48},[42,348,275],{"class":52},[17,350,351,352,354,355,358,359,361],{},"Reopened the terminal, ran ",[28,353,30],{}," — still no luck. Poking around the docs, I noticed an example ",[28,356,357],{},"brew install wget",", so I tried it. That one worked. And after that, ",[28,360,30],{}," worked too.",[17,363,364,365,368],{},"So why? It turns out ",[28,366,367],{},"brew install"," pulls in a few basic dependencies behind the scenes:",[370,371,372,376,379,382,385],"ul",{},[373,374,375],"li",{},"gettext",[373,377,378],{},"libunistring",[373,380,381],{},"libidn2",[373,383,384],{},"ca-certificates",[373,386,387],{},"openssl@1.1",[17,389,390,391,394],{},"For some reason my ",[28,392,393],{},"wget"," had gone missing, which was blocking other installs that depended on it. Installing wget pulled those basics back in, and everything else started working.",[12,396,398],{"id":397},"references","References",[370,400,401],{},[373,402,403],{},[404,405,409],"a",{"href":406,"rel":407},"https:\u002F\u002Fbrew.sh\u002F",[408],"nofollow","Homebrew",[411,412,413],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":38,"searchDepth":237,"depth":237,"links":415},[416,417,418,419],{"id":14,"depth":237,"text":15},{"id":22,"depth":237,"text":23},{"id":112,"depth":237,"text":113},{"id":397,"depth":237,"text":398},"Misc","2022-12-16 21:19:14","One day brew install just stopped working — zsh told me it couldn't find \"brew install\", but plain `brew` did show output. This post walks through what was wrong (PATH-related setup against the wrong shell rc file, plus a missing wget dependency), and the steps that actually got brew install back up and running.","md","en",{},true,"\u002Fen\u002Fmisc\u002Fhomebrew-brew-command-not-found-zsh-fix","2",{"title":6,"description":422},false,"en\u002FMisc\u002Fhomebrew-brew-command-not-found-zsh-fix",[433,434,409,435],"Troubleshooting","Mac","zsh",null,"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F","H8cB28hbPyw1PW6axguyPrnA5XNEEB3ogTvSTjniO_8",{"newer":440,"older":444},{"url":441,"title":442,"date":443},"\u002Fen\u002Fgsap\u002F2022\u002F12\u002F17\u002Fgsap3-fx-10-timeline\u002F","(10) Fun Frontend Effects With GSAP3 - Timeline","2022-12-17 16:23:00",{"url":445,"title":446,"date":447},"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F","Deploy Your Node.js Project to fly.io With flyctl","2022-12-16 21:06:54",[449,454,459],{"url":450,"title":451,"date":452,"readingMinutes":453},"\u002Fen\u002Fmisc\u002F2026\u002F06\u002F23\u002Fmac-stats-menu-bar-system-monitor\u002F","Stats — The Free Open-Source macOS Menu Bar System Monitor I Use Every Day (CPU, GPU, Temperature, Network)","2026-06-23 10:00:00","5",{"url":455,"title":456,"date":457,"readingMinutes":458},"\u002Fen\u002Fmisc\u002F2026\u002F05\u002F26\u002Fhow-much-does-a-blog-really-earn-with-google-adsense\u002F","Can a Blog Really Make Tens of Thousands of Dollars a Month? Real Google AdSense Numbers, Explained","2026-05-26 21:00:00","6",{"url":460,"title":461,"date":462,"readingMinutes":463},"\u002Fen\u002Fmisc\u002F2026\u002F05\u002F18\u002Fvscode-disable-integrated-browser-auto-open\u002F","VSCode Opens Every Link in the Integrated Browser? How to Disable Auto Takeover","2026-05-18 14:30:00","4",1784012781026]