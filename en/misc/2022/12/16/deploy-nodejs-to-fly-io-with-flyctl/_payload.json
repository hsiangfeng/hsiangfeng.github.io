[{"data":1,"prerenderedAt":565},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F":3,"page:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F":4,"alt:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F":3,"prev-next:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F":540,"related:\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F":549},"\u002Fother\u002F20221216\u002F786812101\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":522,"date":523,"description":524,"extension":525,"lang":526,"meta":527,"navigation":271,"path":528,"readingMinutes":529,"seo":530,"standalone":531,"stem":532,"tags":533,"tldr":536,"updated":537,"url":538,"__hash__":539},"content\u002Fen\u002FMisc\u002Fdeploy-nodejs-to-fly-io-with-flyctl.md","Deploy Your Node.js Project to fly.io With flyctl","8121017868",{"type":9,"value":10,"toc":508},"minimark",[11,16,20,24,30,39,47,57,61,70,73,99,102,108,111,116,128,131,155,159,180,184,200,204,207,223,226,230,233,247,250,306,309,313,316,328,331,369,375,382,385,397,403,406,458,462,471,476,483,488,491,495,504],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"After Heroku killed its free tier, I started trying other platforms. fly.io is one. This post is the deploy walkthrough.",[12,21,23],{"id":22},"flyio","Fly.io",[17,25,26],{},[27,28],"img",{"alt":23,"src":29},"https:\u002F\u002Fi.imgur.com\u002FoxshkHr.png",[17,31,32,33,38],{},"fly.io is similar to Render (which I covered in ",[34,35,37],"a",{"href":36},"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F13\u002Fmigrating-from-heroku-to-render-deployment-guide\u002F","Migrating From Heroku to Render",") — a PaaS for backend apps. So why a separate post? Because the deploy flow is different from Render's, and it's worth knowing.",[17,40,41,42],{},"Sample code: ",[34,43,44],{"href":44,"rel":45},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002F2022-express-example",[46],"nofollow",[48,49,50],"blockquote",{},[17,51,52,56],{},[53,54,55],"strong",{},"Danger","\nHeads up — fly.io now requires a credit card on file even for the free tier (changed since this post was originally written).",[12,58,60],{"id":59},"install-flyctl","Install flyctl",[17,62,63,64,69],{},"Before anything, register an account at ",[34,65,68],{"href":66,"rel":67},"https:\u002F\u002Ffly.io\u002F",[46],"fly.io"," and log in.",[17,71,72],{},"flyctl is fly.io's CLI tool — install it to deploy from terminal. Install via:",[74,75,80],"pre",{"className":76,"code":77,"language":78,"meta":79,"style":79},"language-bash shiki shiki-themes github-dark-high-contrast","brew install flyctl\n","bash","",[81,82,83],"code",{"__ignoreMap":79},[84,85,88,92,96],"span",{"class":86,"line":87},"line",1,[84,89,91],{"class":90},"s_sBn","brew",[84,93,95],{"class":94},"sTRMh"," install",[84,97,98],{"class":94}," flyctl\n",[17,100,101],{},"The official site shows the OS-appropriate install command on the home page:",[17,103,104],{},[27,105],{"alt":106,"src":107},"Install command","https:\u002F\u002Fi.imgur.com\u002FG9w7UcZ.png",[17,109,110],{},"For each OS:",[112,113,115],"h3",{"id":114},"macos","macOS",[74,117,118],{"className":76,"code":77,"language":78,"meta":79,"style":79},[81,119,120],{"__ignoreMap":79},[84,121,122,124,126],{"class":86,"line":87},[84,123,91],{"class":90},[84,125,95],{"class":94},[84,127,98],{"class":94},[17,129,130],{},"Or via curl if you don't have Homebrew:",[74,132,134],{"className":76,"code":133,"language":78,"meta":79,"style":79},"curl -L https:\u002F\u002Ffly.io\u002Finstall.sh | sh\n",[81,135,136],{"__ignoreMap":79},[84,137,138,141,145,148,152],{"class":86,"line":87},[84,139,140],{"class":90},"curl",[84,142,144],{"class":143},"sCcAr"," -L",[84,146,147],{"class":94}," https:\u002F\u002Ffly.io\u002Finstall.sh",[84,149,151],{"class":150},"sWyjQ"," |",[84,153,154],{"class":90}," sh\n",[112,156,158],{"id":157},"windows","Windows",[74,160,162],{"className":76,"code":161,"language":78,"meta":79,"style":79},"iwr https:\u002F\u002Ffly.io\u002Finstall.ps1 -useb | iex\n",[81,163,164],{"__ignoreMap":79},[84,165,166,169,172,175,177],{"class":86,"line":87},[84,167,168],{"class":90},"iwr",[84,170,171],{"class":94}," https:\u002F\u002Ffly.io\u002Finstall.ps1",[84,173,174],{"class":143}," -useb",[84,176,151],{"class":150},[84,178,179],{"class":90}," iex\n",[112,181,183],{"id":182},"linux","Linux",[74,185,186],{"className":76,"code":133,"language":78,"meta":79,"style":79},[81,187,188],{"__ignoreMap":79},[84,189,190,192,194,196,198],{"class":86,"line":87},[84,191,140],{"class":90},[84,193,144],{"class":143},[84,195,147],{"class":94},[84,197,151],{"class":150},[84,199,154],{"class":90},[12,201,203],{"id":202},"register","Register",[17,205,206],{},"Two ways to sign up — through the website or via CLI:",[74,208,210],{"className":76,"code":209,"language":78,"meta":79,"style":79},"flyctl auth signup\n",[81,211,212],{"__ignoreMap":79},[84,213,214,217,220],{"class":86,"line":87},[84,215,216],{"class":90},"flyctl",[84,218,219],{"class":94}," auth",[84,221,222],{"class":94}," signup\n",[17,224,225],{},"This opens a browser to walk you through registration.",[12,227,229],{"id":228},"log-in","Log in",[17,231,232],{},"CLI login:",[74,234,236],{"className":76,"code":235,"language":78,"meta":79,"style":79},"flyctl auth login\n",[81,237,238],{"__ignoreMap":79},[84,239,240,242,244],{"class":86,"line":87},[84,241,216],{"class":90},[84,243,219],{"class":94},[84,245,246],{"class":94}," login\n",[17,248,249],{},"Opens a browser to authenticate. After login, the terminal shows:",[74,251,253],{"className":76,"code":252,"language":78,"meta":79,"style":79},"Opening https:\u002F\u002Ffly.io\u002Fapp\u002Fauth\u002Fcli\u002F ...\n\nWaiting for session... Done\nsuccessfully logged in as example@gmail.com\n",[81,254,255,266,273,288],{"__ignoreMap":79},[84,256,257,260,263],{"class":86,"line":87},[84,258,259],{"class":90},"Opening",[84,261,262],{"class":94}," https:\u002F\u002Ffly.io\u002Fapp\u002Fauth\u002Fcli\u002F",[84,264,265],{"class":94}," ...\n",[84,267,269],{"class":86,"line":268},2,[84,270,272],{"emptyLinePlaceholder":271},true,"\n",[84,274,276,279,282,285],{"class":86,"line":275},3,[84,277,278],{"class":90},"Waiting",[84,280,281],{"class":94}," for",[84,283,284],{"class":94}," session...",[84,286,287],{"class":94}," Done\n",[84,289,291,294,297,300,303],{"class":86,"line":290},4,[84,292,293],{"class":90},"successfully",[84,295,296],{"class":94}," logged",[84,298,299],{"class":94}," in",[84,301,302],{"class":94}," as",[84,304,305],{"class":94}," example@gmail.com\n",[17,307,308],{},"You're in.",[12,310,312],{"id":311},"deploy-a-project","Deploy a project",[17,314,315],{},"In your project root:",[74,317,319],{"className":76,"code":318,"language":78,"meta":79,"style":79},"flyctl launch\n",[81,320,321],{"__ignoreMap":79},[84,322,323,325],{"class":86,"line":87},[84,324,216],{"class":90},[84,326,327],{"class":94}," launch\n",[17,329,330],{},"flyctl auto-detects your project language and prompts:",[332,333,334,341,351,361],"ul",{},[335,336,337,340],"li",{},[53,338,339],{},"Choose an app name (leave blank to generate one)"," — type your own name or hit Enter for a generated one",[335,342,343,346,347,350],{},[53,344,345],{},"Choose a region for deployment"," — I picked ",[81,348,349],{},"sin"," (Singapore)",[335,352,353,356,357,360],{},[53,354,355],{},"Would you like to set up a Postgresql database now?"," — I said ",[81,358,359],{},"n"," (no DB needed)",[335,362,363,366,367],{},[53,364,365],{},"Would you like to set up an Upstash Redis database now?"," — also ",[81,368,359],{},[17,370,371],{},[27,372],{"alt":373,"src":374},"flyctl launch","https:\u002F\u002Fi.imgur.com\u002FyKpN1vO.png",[17,376,377,378,381],{},"flyctl generates a ",[81,379,380],{},"fly.toml"," in your project root — that's your fly.io config (app name, region, etc.). You can dig into it if you want.",[17,383,384],{},"Then deploy:",[74,386,388],{"className":76,"code":387,"language":78,"meta":79,"style":79},"flyctl deploy\n",[81,389,390],{"__ignoreMap":79},[84,391,392,394],{"class":86,"line":87},[84,393,216],{"class":90},[84,395,396],{"class":94}," deploy\n",[17,398,399],{},[27,400],{"alt":401,"src":402},"Deploying","https:\u002F\u002Fi.imgur.com\u002F2byO36L.png",[17,404,405],{},"When you see this in the output, deploy succeeded:",[74,407,409],{"className":76,"code":408,"language":78,"meta":79,"style":79},"...\n 1 desired, 1 placed, 1 healthy, 0 unhealthy\n--> v0 deployed successfully\n",[81,410,411,416,440],{"__ignoreMap":79},[84,412,413],{"class":86,"line":87},[84,414,415],{"class":143},"...\n",[84,417,418,421,424,426,429,431,434,437],{"class":86,"line":268},[84,419,420],{"class":90}," 1",[84,422,423],{"class":94}," desired,",[84,425,420],{"class":143},[84,427,428],{"class":94}," placed,",[84,430,420],{"class":143},[84,432,433],{"class":94}," healthy,",[84,435,436],{"class":143}," 0",[84,438,439],{"class":94}," unhealthy\n",[84,441,442,445,449,452,455],{"class":86,"line":275},[84,443,444],{"class":90},"--",[84,446,448],{"class":447},"sMAXC","> ",[84,450,451],{"class":94},"v0",[84,453,454],{"class":94}," deployed",[84,456,457],{"class":94}," successfully\n",[12,459,461],{"id":460},"check-deploy-status","Check deploy status",[17,463,464,465,470],{},"Two ways. Via the fly.io ",[34,466,469],{"href":467,"rel":468},"https:\u002F\u002Ffly.io\u002Fdashboard\u002Fpersonal",[46],"Dashboard",":",[17,472,473],{},[27,474],{"alt":469,"src":475},"https:\u002F\u002Fi.imgur.com\u002FPmvM563.png",[17,477,478,479,482],{},"Or via CLI — ",[81,480,481],{},"flyctl status"," shows the deploy status. The red arrow in the image points at your project's public URL:",[17,484,485],{},[27,486],{"alt":481,"src":487},"https:\u002F\u002Fi.imgur.com\u002FVeVnRuw.png",[17,489,490],{},"That's it — your Node.js app is live.",[12,492,494],{"