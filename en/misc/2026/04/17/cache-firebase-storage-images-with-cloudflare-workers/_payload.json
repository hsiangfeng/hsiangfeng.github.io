ss":345},[59,838,840],{"class":61,"line":839},37,[59,841,411],{"emptyLinePlaceholder":410},[59,843,845,848,850,852],{"class":61,"line":844},38,[59,846,847],{"class":322},"    return",[59,849,581],{"class":322},[59,851,584],{"class":338},[59,853,854],{"class":345},"(response.body, {\n",[59,856,858],{"class":61,"line":857},39,[59,859,860],{"class":345},"      status: response.status,\n",[59,862,864],{"class":61,"line":863},40,[59,865,866],{"class":345},"      headers,\n",[59,868,870],{"class":61,"line":869},41,[59,871,872],{"class":345},"    });\n",[59,874,876,879],{"class":61,"line":875},42,[59,877,878],{"class":345},"  }",[59,880,378],{"class":329},[59,882,884,887],{"class":61,"line":883},43,[59,885,886],{"class":329},"}",[59,888,445],{"class":345},[157,890,891],{},[12,892,893,895,896,899,900,903],{},[30,894,163],{},"\nRemember to replace ",[56,897,898],{},"YOUR_PROJECT.appspot.com"," with your actual Firebase project name, and ",[56,901,902],{},"allowedOrigins"," with your own domain.",[222,905,906],{"start":389},[225,907,238,908,277],{},[30,909,910],{},"Save and Deploy",[166,912,914],{"id":913},"what-does-this-code-do","What does this code do?",[12,916,917],{},"In case you're wondering what's actually happening — three things:",[222,919,920,926,932],{},[225,921,922,925],{},[30,923,924],{},"Domain restriction",": checks the request origin and only allows your own domain and local dev. Stops other people from hotlinking your image proxy.",[225,927,928,931],{},[30,929,930],{},"Reverse proxy",": builds the Firebase Storage URL from the request path, fetches from Firebase.",[225,933,934,937],{},[30,935,936],{},"Cache headers",": adds cache-control headers on the response, telling the Cloudflare CDN and the browser to cache the image for a year.",[12,939,940,941,944,945,947],{},"The ",[56,942,943],{},"localhost"," entry exists so local development still shows images. Since we're using ",[56,946,540],{}," for matching, any port (4000, 3000, 8080…) works fine.",[166,949,951],{"id":950},"step-3-bind-a-subdomain","Step 3: Bind a subdomain",[222,953,954,963,971,976],{},[225,955,956,957,283,960,277],{},"In the Worker → ",[30,958,959],{},"Settings",[30,961,962],{},"Domains & Routes",[225,964,238,965,283,968,277],{},[30,966,967],{},"Add",[30,969,970],{},"Custom Domain",[225,972,973,974,277],{},"Enter ",[56,975,193],{},[225,977,978],{},"Cloudflare creates the DNS record for you, click confirm.",[166,980,982],{"id":981},"step-4-configure-firebase-storage-rules","Step 4: Configure Firebase Storage Rules",[12,984,985],{},"Because our Worker requests Firebase Storage without a token, the images need to be publicly readable.",[12,987,988],{},"Firebase Console → Storage → Rules:",[49,990,992],{"className":51,"code":991,"language":53,"meta":54,"style":54},"rules_version = '2';\nservice firebase.storage {\n  match \u002Fb\u002F{bucket}\u002Fo {\n    match \u002Fblog2\u002F{allPaths=**} {\n      allow read;\n    }\n  }\n}\n",[56,993,994,999,1004,1009,1014,1019,1023,1028],{"__ignoreMap":54},[59,995,996],{"class":61,"line":62},[59,997,998],{},"rules_version = '2';\n",[59,1000,1001],{"class":61,"line":68},[59,1002,1003],{},"service firebase.storage {\n",[59,1005,1006],{"class":61,"line":74},[59,1007,1008],{},"  match \u002Fb\u002F{bucket}\u002Fo {\n",[59,1010,1011],{"class":61,"line":355},[59,1012,1013],{},"    match \u002Fblog2\u002F{allPaths=**} {\n",[59,1015,1016],{"class":61,"line":371},[59,1017,1018],{},"      allow read;\n",[59,1020,1021],{"class":61,"line":381},[59,1022,604],{},[59,1024,1025],{"class":61,"line":389},[59,1026,1027],{},"  }\n",[59,1029,1030],{"class":61,"line":401},[59,1031,1032],{},"}\n",[12,1034,1035,1036,1039],{},"This only opens up ",[56,1037,1038],{},"blog2\u002F"," for public read — other paths are unaffected.",[12,1041,1042],{},"You might be worried about the security implications, but consider: these images were already public via blog articles — anyone could see them. The original token was sitting in your HTML for anyone who opens devtools to grab anyway. Switching to public read doesn't actually add any new risk.",[166,1044,1046],{"id":1045},"step-5-verify","Step 5: Verify",[12,1048,1049],{},"Open a browser and type in:",[49,1051,1053],{"className":51,"code":1052,"language":53,"meta":54,"style":54},"https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Fyour-folder\u002Fyour-image.png\n",[56,1054,1055],{"__ignoreMap":54},[59,1056,1057],{"class":61,"line":62},[59,1058,1052],{},[12,1060,1061],{},"If you see the image, you're good.",[19,1063,1065],{"id":1064},"updating-image-links","Updating image links",[12,1067,1068],{},"Now you need to replace all the Firebase Storage image URLs in your blog with the new format.",[12,1070,1071],{},"Original looks like:",[49,1073,1075],{"className":51,"code":1074,"language":53,"meta":54,"style":54},"https:\u002F\u002Ffirebasestorage.googleapis.com\u002Fv0\u002Fb\u002FYOUR_PROJECT.appspot.com\u002Fo\u002Fblog2%2Ffolder%2Fimage.png?alt=media&token=xxx\n",[56,1076,1077],{"__ignoreMap":54},[59,1078,1079],{"class":61,"line":62},[59,1080,1074],{},[12,1082,1083],{},"Becomes:",[49,1085,1087],{"className":51,"code":1086,"language":53,"meta":54,"style":54},"https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Ffolder\u002Fimage.png\n",[56,1088,1089],{"__ignoreMap":54},[59,1090,1091],{"class":61,"line":62},[59,1092,1086],{},[12,1094,1095],{},"The rules:",[222,1097,1098,1103,1109],{},[225,1099,1100,1101,277],{},"Swap the Firebase domain for ",[56,1102,193],{},[225,1104,1105,1106,277],{},"Drop the ",[56,1107,1108],{},"?alt=media&token=xxx",[225,1110,1111,1112,1115,1116,277],{},"Convert ",[56,1113,1114],{},"%2F"," to ",[56,1117,1118],{},"\u002F",[12,1120,1121,1122,1125],{},"If you have lots of articles, doing it by hand isn't realistic. Bulk replace with ",[56,1123,1124],{},"sed",":",[49,1127,1131],{"className":1128,"code":1129,"language":1130,"meta":54,"style":54},"language-bash shiki shiki-themes github-dark-high-contrast","# Step 1: replace domain and strip token\ngrep -rl \"firebasestorage\\.googleapis\\.com\u002Fv0\u002Fb\u002FYOUR_PROJECT\\.appspot\\.com\" source\u002F | \\\nwhile IFS= read -r f; do\n  sed -i '' 's|https:\u002F\u002Ffirebasestorage\\.googleapis\\.com\u002Fv0\u002Fb\u002FYOUR_PROJECT\\.appspot\\.com\u002Fo\u002F\\([^?]*\\)?alt=media&token=[a-f0-9\\-]*|https:\u002F\u002Fimages.yourdomain.com\u002F\\1|g' \"$f\"\ndone\n\n# Step 2: replace %2F with \u002F\nfor i in $(seq 1 5); do\n  grep -rl \"images\\.yourdomain\\.com\u002F[^)]*%2F\" source\u002F 2>\u002Fdev\u002Fnull | \\\n  while IFS= read -r f; do\n    sed -i '' 's|\\(images\\.yourdomain\\.com\u002F[^)]*\\)%2F|\\1\u002F|g' \"$f\"\n  done\ndone\n","bash",[56,1132,1133,1138,1158,1184,1206,1211,1215,1220,1248,1270,1289,1307,1312],{"__ignoreMap":54},[59,1134,1135],{"class":61,"line":62},[59,1136,1137],{"class":351},"# Step 1: replace domain and strip token\n",[59,1139,1140,1143,1146,1149,1152,1155],{"class":61,"line":68},[59,1141,1142],{"class":329},"grep",[59,1144,1145],{"class":361}," -rl",[59,1147,1148],{"class":374}," \"firebasestorage\\.googleapis\\.com\u002Fv0\u002Fb\u002FYOUR_PROJECT\\.appspot\\.com\"",[59,1150,1151],{"class":374}," source\u002F",[59,1153,1154],{"class":322}," |",[59,1156,1157],{"class":322}," \\\n",[59,1159,1160,1163,1166,1169,1172,1175,1178,1181],{"class":61,"line":74},[59,1161,1162],{"class":322},"while",[59,1164,1165],{"class":374}," IFS",[59,1167,1168],{"class":322},"=",[59,1170,1171],{"class":374}," read",[59,1173,1174],{"class":361}," -r",[59,1176,1177],{"class":374}," f",[59,1179,1180],{"class":345},"; ",[59,1182,1183],{"class":322},"do\n",[59,1185,1186,1189,1192,1194,1197,1200,1203],{"class":61,"line":355},[59,1187,1188],{"class":329},"  sed",[59,1190,1191],{"class":361}," -i",[59,1193,442],{"class":374},[59,1195,1196],{"class":374}," 's|https:\u002F\u002Ffirebasestorage\\.googleapis\\.com\u002Fv0\u002Fb\u002FYOUR_PROJECT\\.appspot\\.com\u002Fo\u002F\\([^?]*\\)?alt=media&token=[a-f0-9\\-]*|https:\u002F\u002Fimages.yourdomain.com\u002F\\1|g'",[59,1198,1199],{"class":374}," \"",[59,1201,1202],{"class":345},"$f",[59,1204,1205],{"class":374},"\"\n",[59,1207,1208],{"class":61,"line":371},[59,1209,1210],{"class":322},"done\n",[59,1212,1213],{"class":61,"line":381},[59,1214,411],{"emptyLinePlaceholder":410},[59,1216,1217],{"class":61,"line":389},[59,1218,1219],{"class":351},"# Step 2: replace %2F with \u002F\n",[59,1221,1222,1225,1228,1231,1234,1237,1240,1243,1246],{"class":61,"line":401},[59,1223,1224],{"class":322},"for",[59,1226,1227],{"class":345}," i ",[59,1229,1230],{"class":322},"in",[59,1232,1233],{"class":345}," $(",[59,1235,1236],{"class":329},"seq",[59,1238,1239],{"class":361}," 1",[59,1241,1242],{"class":361}," 5",[59,1244,1245],{"class":345},"); ",[59,1247,1183],{"class":322},[59,1249,1250,1253,1255,1258,1260,1263,1266,1268],{"class":61,"line":407},[59,1251,1252],{"class":329},"  grep",[59,1254,1145],{"class":361},[59,1256,1257],{"class":374}," \"images\\.yourdomain\\.com\u002F[^)]*%2F\"",[59,1259,1151],{"class":374},[59,1261,1262],{"class":322}," 2>",[59,1264,1265],{"class":374},"\u002Fdev\u002Fnull",[59,1267,1154],{"class":322},[59,1269,1157],{"class":322},[59,1271,1272,1275,1277,1279,1281,1283,1285,1287],{"class":61,"line":414},[59,1273,1274],{"class":322},"  while",[59,1276,1165],{"class":374},[59,1278,1168],{"class":322},[59,1280,1171],{"class":374},[59,1282,1174],{"class":361},[59,1284,1177],{"class":374},[59,1286,1180],{"class":345},[59,1288,1183],{"class":322},[59,1290,1291,1294,1296,1298,1301,1303,1305],{"class":61,"line":448},[59,1292,1293],{"class":329},"    sed",[59,1295,1191],{"class":361},[59,1297,442],{"class":374},[59,1299,1300],{"class":374}," 's|\\(images\\.yourdomain\\.com\u002F[^)]*\\)%2F|\\1\u002F|g'",[59,1302,1199],{"class":374},[59,1304,1202],{"class":345},[59,1306,1205],{"class":374},[59,1308,1309],{"class":61,"line":475},[59,1310,1311],{"class":322},"  done\n",[59,1313,1314],{"class":61,"line":480},[59,1315,1210],{"class":322},[157,1317,1318],{},[12,1319,1320,1322,1323,1325,1326,1328],{},[30,1321,163],{},"\nStep 2 needs to run multiple times because ",[56,1324,1124],{}," only replaces one ",[56,1327,1114],{}," per pass — the loop ensures all of them get converted. Also, if you have images from multiple Firebase projects, double-check you're only replacing URLs from the target project so you don't accidentally touch other projects' image URLs.",[166,1330,1332,1333,1335,1336,1338],{"id":1331},"important-use-instead-of-2f-in-url-paths","Important: use ",[56,1334,1118],{}," instead of ",[56,1337,1114],{}," in URL paths",[12,1340,1341],{},"One detail worth highlighting.",[12,1343,1344,1345,1347,1348,1125],{},"Firebase Storage's URL format uses ",[56,1346,1114],{}," to separate paths (because the whole file path is treated as a single URL segment), but on our own subdomain, ",[30,1349,1350,1351],{},"you must use a regular ",[56,1352,1118],{},[49,1354,1356],{"className":51,"code":1355,"language":53,"meta":54,"style":54},"❌ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2%2Fai%2Fmy-post%2Fimage.png\n✅ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Fai\u002Fmy-post\u002Fimage.png\n",[56,1357,1358,1363],{"__ignoreMap":54},[59,1359,1360],{"class":61,"line":62},[59,1361,1362],{},"❌ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2%2Fai%2Fmy-post%2Fimage.png\n",[59,1364,1365],{"class":61,"line":68},[59,1366,1367],{},"✅ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Fai\u002Fmy-post\u002Fimage.png\n",[12,1369,1370,1371,1373,1374,1376,1377,1379,1380,1383],{},"Why? Because Cloudflare doesn't handle ",[56,1372,1114],{}," correctly in this context — you'll get 404s. The Worker internally converts ",[56,1375,1118],{}," back to Firebase's ",[56,1378,1114],{}," format (via ",[56,1381,1382],{},"encodeURIComponent","), so on your end you just use normal paths and don't need to worry about encoding.",[19,1385,1387],{"id":1386},"getting-urls-for-new-images","Getting URLs for new images",[12,1389,1390],{},"How do you get URLs for new images going forward? The rule is just:",[49,1392,1394],{"className":51,"code":1393,"language":53,"meta":54,"style":54},"https:\u002F\u002Fimages.yourdomain.com\u002F + the path in Firebase Storage\n",[56,1395,1396],{"__ignoreMap":54},[59,1397,1398],{"class":61,"line":62},[59,1399,1393],{},[12,1401,1402,1403,1406],{},"For example, if you upload an image to ",[56,1404,1405],{},"blog2\u002Fai\u002Fmy-post\u002Fscreenshot.png"," in Firebase Storage, the URL is:",[49,1408,1409],{"className":51,"code":197,"language":53,"meta":54,"style":54},[56,1410,1411],{"__ignoreMap":54},[59,1412,1413],{"class":61,"line":62},[59,1414,197],{},[12,1416,1417],{},"No more tokens. Just concatenate the path. Way more convenient.",[19,1419,1421],{"id":1420},"how-the-caching-works","How the caching works",[12,1423,1424],{},"Last bit: let's cover how the caching actually flows, so you can feel more confident about the setup.",[12,1426,1427],{},"The Worker sets two key headers:",[49,1429,1431],{"className":313,"code":1430,"language":315,"meta":54,"style":54},"headers.set('Cache-Control', 'public, max-age=31536000, immutable');\nheaders.set('CDN-Cache-Control', 'max-age=31536000');\n",[56,1432,1433,1450],{"__ignoreMap":54},[59,1434,1435,1438,1440,1442,1444,1446,1448],{"class":61,"line":62},[59,1436,1437],{"class":345},"headers.",[59,1439,785],{"class":338},[59,1441,430],{"class":345},[59,1443,790],{"class":374},[59,1445,395],{"class":345},[59,1447,795],{"class":374},[59,1449,798],{"class":345},[59,1451,1452,1454,1456,1458,1460,1462,1464],{"class":61,"line":68},[59,1453,1437],{"class":345},[59,1455,785],{"class":338},[59,1457,430],{"class":345},[59,1459,810],{"class":374},[59,1461,395],{"class":345},[59,1463,815],{"class":374},[59,1465,798],{"class":345},[12,1467,1468,1469,277],{},"These set up ",[30,1470,1471],{},"two cache layers",[166,1473,1475],{"id":1474},"layer-1-cloudflare-cdn-edge-cache","Layer 1: Cloudflare CDN edge cache",[12,1477,1478,1481,1482,277],{},[56,1479,1480],{},"CDN-Cache-Control"," tells Cloudflare's edge nodes: \"cache this for a year\". On the first request, Cloudflare fetches from Firebase and stores a copy at the edge closest to the user. After that, anyone requesting the same image gets it straight from the edge — ",[30,1483,1484],{},"no Worker invocation, no Firebase hit",[166,1486,1488],{"id":1487},"layer-2-browser-local-cache","Layer 2: Browser local cache",[12,1490,1491,1494,1495,277],{},[56,1492,1493],{},"Cache-Control: public, max-age=31536000, immutable"," tells the browser: \"cache this locally for a year, and it won't change\". So when the same user visits the same post again, the browser uses its local copy — ",[30,1496,1497],{},"doesn't even hit Cloudflare",[166,1499,1501],{"id":1500},"overall-flow","Overall flow",[12,1503,1504],{},[30,1505,1506],{},"First request (cold cache):",[49,1508,1510],{"className":51,"code":1509,"language":53,"meta":54,"style":54},"User → Cloudflare edge (no cache) → Worker → Firebase Storage\n                ↓\n        Store copy at edge + return to user\n",[56,1511,1512,1517,1522],{"__ignoreMap":54},[59,1513,1514],{"class":61,"line":62},[59,1515,1516],{},"User → Cloudflare edge (no cache) → Worker → Firebase Storage\n",[59,1518,1519],{"class":61,"line":68},[59,1520,1521],{},"                ↓\n",[59,1523,1524],{"class":61,"line":74},[59,1525,1526],{},"        Store copy at edge + return to user\n",[12,1528,1529],{},[30,1530,1531],{},"Second request (CDN hit):",[49,1533,1535],{"className":51,"code":1534,"language":53,"meta":54,"style":54},"User → Cloudflare edge (cached) → return directly\n",[56,1536,1537],{"__ignoreMap":54},[59,1538,1539],{"class":61,"line":62},[59,1540,1534],{},[12,1542,1543],{},[30,1544,1545],{},"Same user revisiting (browser cache hit):",[49,1547,1549],{"className":51,"code":1548,"language":53,"meta":54,"style":54},"User → browser local cache → render directly\n",[56,1550,1551],{"__ignoreMap":54},[59,1552,1553],{"class":61,"line":62},[59,1554,1548],{},[12,1556,1557,1558,1561],{},"Since blog images don't change after upload, setting a 1-year cache with ",[56,1559,1560],{},"immutable"," is totally reasonable.",[19,1563,1565],{"id":1564},"closing-thoughts","Closing thoughts",[12,1567,1568],{},"With Cloudflare Workers + CDN caching, you can dramatically cut Firebase Storage bandwidth — for $0. Setup doesn't take much time, but the savings are long-term.",[12,1570,1571],{},"Recap of the benefits:",[1573,1574,1575,1581,1587,1593,1598],"ul",{},[225,1576,1577,1580],{},[30,1578,1579],{},"Completely free",": no credit card, no paid plan needed.",[225,1582,1583,1586],{},[30,1584,1585],{},"Global acceleration",": Cloudflare has 300+ edge nodes worldwide; images come from the closest one.",[225,1588,1589,1592],{},[30,1590,1591],{},"Reduced bandwidth",": cache hits never touch Firebase, bandwidth goes to zero.",[225,1594,1595,1597],{},[30,1596,924],{},": only your own site can access — stops hotlinking.",[225,1599,1600,1603],{},[30,1601,1602],{},"Shorter URLs",": from long Firebase URLs to clean subdomain paths.",[12,1605,1606],{},"If you're also using Firebase Storage for images, this approach is worth trying.",[1608,1609,1610],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":54,"searchDepth":68,"depth":68,"links":1612},[1613,1614,1615,1618,1619,1627,1631,1632,1637],{"id":21,"depth":68,"text":22},{"id":40,"depth":68,"text":41},{"id":87,"depth":68,"text":88,"children":1616},[1617],{"id":168,"depth":74,"text":169},{"id":179,"depth":68,"text":180},{"id":209,"depth":68,"text":210,"children":1620},[1621,1622,1623,1624,1625,1626],{"id":216,"depth":74,"text":217},{"id":267,"depth":74,"text":268},{"id":913,"depth":74,"text":914},{"id":950,"depth":74,"text":951},{"id":981,"depth":74,"text":982},{"id":1045,"depth":74,"text":1046},{"id":1064,"depth":68,"text":1065,"children":1628},[1629],{"id":1331,"depth":74,"text":1630},"Important: use \u002F instead of %2F in URL paths",{"id":1386,"depth":68,"text":1387},{"id":1420,"depth":68,"text":1421,"children":1633},[1634,1635,1636],{"id":1474,"depth":74,"text":1475},{"id":1487,"depth":74,"text":1488},{"id":1500,"depth":74,"text":1501},{"id":1564,"depth":68,"text":1565},"Misc","2026-04-17 10:00:00","If you're using Firebase Storage to host blog images like I was, you've probably noticed bandwidth costs creeping up — every article view pulls the images straight from Firebase Storage, and all of it lands on your Firebase bill. This post walks through how to use Cloudflare Workers plus a custom subdomain to cache those images. The whole setup is free and doesn't require a credit card.","md","en",{},"\u002Fen\u002Fmisc\u002Fcache-firebase-storage-images-with-cloudflare-workers","7",{"title":6,"description":1640},false,"en\u002FMisc\u002Fcache-firebase-storage-images-with-cloudflare-workers",[234,1650,1651,1652,36],"Firebase","CDN","Cache",null,"\u002Fen\u002Fmisc\u002F2026\u002F04\u002F17\u002Fcache-firebase-storage-images-with-cloudflare-workers\u002F","ikvkxSYnnNuKl4D-KAq911vva1dB2t8Cdbk47PSMtEY",{"newer":1657,"older":1661},{"url":1658,"title":1659,"date":1660},"\u002Fen\u002Fmisc\u002F2026\u002F04\u002F20\u002Fmigrating-from-firebase-storage-to-cloudflare-r2\u002F","Migrating from Firebase Storage to Cloudflare R2 — the Full Move","2026-04-20 23:00:00",{"url":1662,"title":1663,"date":1664},"\u002Fen\u002Fai\u002F2026\u002F04\u002F12\u002Fllm-parameters-quantization-guide\u002F","Want to Run Your Own LLM? Understanding Model Parameters and Quantization","2026-04-12 23:30:00",[1666,1671,1676],{"url":1667,"title":1668,"date":1669,"readingMinutes":1670},"\u002Fen\u002Fmisc\u002F2026\u002F06\u002F23\u002Fmac-stats-menu-bar-system-monitor\u002F","Stats — The Free Open-Source macOS Menu Bar System Monitor I Use Every Day (CPU, GPU, Temperature, Network)","2026-06-23 10:00:00","5",{"url":1672,"title":1673,"date":1674,"readingMinutes":1675},"\u002Fen\u002Fmisc\u002F2026\u002F05\u002F26\u002Fhow-much-does-a-blog-really-earn-with-google-adsense\u002F","Can a Blog Really Make Tens of Thousands of Dollars a Month? Real Google AdSense Numbers, Explained","2026-05-26 21:00:00","6",{"url":1677,"title":1678,"date":1679,"readingMinutes":1680},"\u002Fen\u002Fmisc\u002F2026\u002F05\u002F18\u002Fvscode-disable-integrated-browser-auto-open\u002F","VSCode Opens Every Link in the Integrated Browser? How to Disable Auto Takeover","2026-05-18 14:30:00","4",1784020370469]