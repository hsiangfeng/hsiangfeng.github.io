[{"data":1,"prerenderedAt":415},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fcss\u002F2020\u002F05\u002F23\u002Fcss-design-patterns-sass-7-1-pattern\u002F":3,"page:\u002Fen\u002Fcss\u002F2020\u002F05\u002F23\u002Fcss-design-patterns-sass-7-1-pattern\u002F":4,"alt:\u002Fen\u002Fcss\u002F2020\u002F05\u002F23\u002Fcss-design-patterns-sass-7-1-pattern\u002F":3,"prev-next:\u002Fen\u002Fcss\u002F2020\u002F05\u002F23\u002Fcss-design-patterns-sass-7-1-pattern\u002F":391,"related:\u002Fen\u002Fcss\u002F2020\u002F05\u002F23\u002Fcss-design-patterns-sass-7-1-pattern\u002F":400},"\u002Fcss\u002F20200523\u002F116058774\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":373,"date":374,"description":375,"extension":376,"lang":377,"meta":378,"navigation":379,"path":380,"readingMinutes":381,"seo":382,"standalone":383,"stem":384,"tags":385,"tldr":388,"updated":374,"url":389,"__hash__":390},"content\u002Fen\u002FCSS\u002Fcss-design-patterns-sass-7-1-pattern.md","CSS Design Patterns — Sass 7-1 Pattern","4242004320",{"type":9,"value":10,"toc":359},"minimark",[11,16,25,29,32,57,60,65,68,71,76,87,89,92,103,105,108,119,121,124,132,134,137,145,147,158,169,171,174,182,186,192,195,323,334,338,355],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"The 7-1 pattern is about organising your folder structure. Back when CSS had to live in one place, maintenance got painful fast. Sass lets you use ",[21,22,23],"code",{},"@import"," and folders to split things up — that's the Sass 7-1 pattern.",[12,26,28],{"id":27},"sass-7-1-pattern","Sass 7-1 Pattern",[17,30,31],{},"The 7-1 in Sass 7-1 stands for seven folders and one file — to make Sass easier to organise.",[33,34,35,39,42,45,48,51,54],"ul",{},[36,37,38],"li",{},"base",[36,40,41],{},"components",[36,43,44],{},"layout",[36,46,47],{},"pages",[36,49,50],{},"themes",[36,52,53],{},"utils",[36,55,56],{},"vendors",[17,58,59],{},"Plus the main entry file:",[33,61,62],{},[36,63,64],{},"all.scss or main.scss",[17,66,67],{},"That's the Sass 7-1 pattern in a nutshell. The point is to split files so maintenance isn't a nightmare.",[69,70,38],"h3",{"id":38},[17,72,73,75],{},[21,74,38],{}," is for resets, SMACSS-style initialisation, base font setup, etc.",[33,77,78,81,84],{},[36,79,80],{},"_reset.scss",[36,82,83],{},"_base.scss",[36,85,86],{},"_fontStyle.scss",[69,88,41],{"id":41},[17,90,91],{},"Same concept as Bootstrap components — these aren't tied to a specific section like the header. They can be used anywhere.",[33,93,94,97,100],{},[36,95,96],{},"_button.scss",[36,98,99],{},"_dropdown.scss",[36,101,102],{},"_alert.scss",[69,104,44],{"id":44},[17,106,107],{},"Self-explanatory — layout\u002Fsection styles.",[33,109,110,113,116],{},[36,111,112],{},"_header.scss",[36,114,115],{},"_footer.scss",[36,117,118],{},"_nav.scss",[69,120,47],{"id":47},[17,122,123],{},"Styles that only apply to a specific page.",[33,125,126,129],{},[36,127,128],{},"_index.scss",[36,130,131],{},"_content.scss",[69,133,50],{"id":50},[17,135,136],{},"If your site has multiple themes (e.g. light and dark), put them here.",[33,138,139,142],{},[36,140,141],{},"_theme.scss",[36,143,144],{},"_admin.scss",[69,146,53],{"id":53},[17,148,149,150,153,154,157],{},"Utility files — things like ",[21,151,152],{},"p-1",", ",[21,155,156],{},"mt-10"," helpers.",[33,159,160,163,166],{},[36,161,162],{},"_helpers.scss",[36,164,165],{},"_mixin.scss",[36,167,168],{},"_function.scss",[69,170,56],{"id":56},[17,172,173],{},"Third-party styles.",[33,175,176,179],{},[36,177,178],{},"_bootstrap.scss",[36,180,181],{},"_swiper.scss",[69,183,185],{"id":184},"main-or-all","main or all",[17,187,188,189,191],{},"The entry file — usually just ",[21,190,23],{}," statements.",[17,193,194],{},"Example:",[196,197,202],"pre",{"className":198,"code":199,"language":200,"meta":201,"style":201},"language-scss shiki shiki-themes github-dark-high-contrast","\u002F\u002F base\n@import '_reset';\n\u002F\u002F utils\n@import '_helpers';\n\u002F\u002F compon