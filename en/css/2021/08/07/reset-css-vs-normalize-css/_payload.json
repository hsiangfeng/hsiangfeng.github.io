51,956,962,967,972],{},[354,907,908],{},[39,909,910],{},"margin: 0;",[354,912,913],{},[39,914,915],{},"padding: 0;",[354,917,918],{},[39,919,920],{},"border: 0;",[354,922,923],{},[39,924,925],{},"font-size: 100%;",[354,927,928],{},[39,929,930],{},"font: inherit;",[354,932,933],{},[39,934,935],{},"vertical-align: baseline;",[354,937,938],{},[39,939,940],{},"display: block;",[354,942,943],{},[39,944,945],{},"line-height: 1;",[354,947,948],{},[39,949,950],{},"list-style: none;",[354,952,953],{},[39,954,955],{},"quotes: none;",[354,957,958,961],{},[39,959,960],{},"content: '';"," (for pseudo-elements)",[354,963,964,961],{},[39,965,966],{},"content: none;",[354,968,969],{},[39,970,971],{},"border-collapse: collapse;",[354,973,974],{},[39,975,976],{},"border-spacing: 0;",[17,978,979,980,983,984,986,987,989,990,992,993,995],{},"The interesting part is ",[39,981,982],{},"content"," is set twice. Back then, most browsers only supported ",[39,985,745],{},", but Safari and Chrome only supported ",[39,988,824],{},". So if ",[39,991,966],{}," isn't supported, browsers fall back to ",[39,994,960],{}," — ensuring consistent styling.",[12,997,999],{"id":998},"normalizecss","Normalize.css",[17,1001,1002],{},"Normalize.css is also a kind of Reset CSS, but the big difference vs meyerweb is that it preserves browser default styles. Key features:",[349,1004,1005,1008,1011],{},[354,1006,1007],{},"Preserves defaults (with HTML5 support)",[354,1009,1010],{},"Fixes browser bugs",[354,1012,1013],{},"Clear comments",[17,1015,1016,1017,1021],{},"Since ",[28,1018,999],{"href":1019,"rel":1020},"https:\u002F\u002Fnecolas.github.io\u002Fnormalize.css\u002F",[32]," has more content, I'd recommend reading it directly on the official site.",[148,1023,1025],{"id":1024},"preserving-defaults","Preserving defaults",[17,1027,1028,1029,1032],{},"In meyerweb, ",[39,1030,1031],{},"h1, h2, h3, h4, h5, h6"," get all their styles wiped. Normalize.css preserves those defaults — so you don't have to re-style heading tags.",[17,1034,1035,1036,1038],{},"How did they get away with it? The Normalize.css author spent hundreds of hours figuring out each browser's defaults and only normalises when a browser-specific default has drifted. For example, ",[39,1037,139],{}," slightly differs across browsers:",[51,1040,1042],{"className":53,"code":1041,"language":55,"meta":56,"style":56},"\u002F**\n * Correct the font size and margin on `h1` elements within `section` and\n * `article` contexts in Chrome, Firefox, and Safari.\n *\u002F\n\nh1 {\n  font-size: 2em;\n  margin: 0.67em 0;\n}\n",[39,1043,1044,1049,1054,1059,1064,1068,1074,1087,1103],{"__ignoreMap":56},[60,1045,1046],{"class":62,"line":63},[60,1047,1048],{"class":66},"\u002F**\n",[60,1050,1051],{"class":62,"line":70},[60,1052,1053],{"class":66}," * Correct the font size and margin on `h1` elements within `section` and\n",[60,1055,1056],{"class":62,"line":76},[60,1057,1058],{"class":66}," * `article` contexts in Chrome, Firefox, and Safari.\n",[60,1060,1061],{"class":62,"line":82},[60,1062,1063],{"class":66}," *\u002F\n",[60,1065,1066],{"class":62,"line":88},[60,1067,92],{"emptyLinePlaceholder":91},[60,1069,1070,1072],{"class":62,"line":95},[60,1071,139],{"class":98},[60,1073,535],{"class":102},[60,1075,1076,1078,1080,1083,1085],{"class":62,"line":136},[60,1077,581],{"class":541},[60,1079,545],{"class":102},[60,1081,1082],{"class":541},"2",[60,1084,230],{"class":589},[60,1086,551],{"class":102},[60,1088,1089,1091,1093,1096,1098,1101],{"class":62,"line":181},[60,1090,542],{"class":541},[60,1092,545],{"class":102},[60,1094,1095],{"class":541},"0.67",[60,1097,230],{"class":589},[60,1099,1100],{"class":541}," 0",[60,1102,551],{"class":102},[60,1104,1105],{"class":62,"line":217},[60,1106,624],{"class":102},[17,1108,1109,1110,1112],{},"The clearest case is ",[39,1111,106],{}," — every browser has slightly different default margins:",[51,1114,1116],{"className":53,"code":1115,"language":55,"meta":56,"style":56},"\u002F**\n * Remove the margin in all browsers.\n *\u002F\n\nbody {\n  margin: 0;\n}\n",[39,1117,1118,1122,1127,1131,1135,1141,1151],{"__ignoreMap":56},[60,1119,1120],{"class":62,"line":63},[60,1121,1048],{"class":66},[60,1123,1124],{"class":62,"line":70},[60,1125,1126],{"class":66}," * Remove the margin in all browsers.\n",[60,1128,1129],{"class":62,"line":76},[60,1130,1063],{"class":66},[60,1132,1133],{"class":62,"line":82},[60,1134,92],{"emptyLinePlaceholder":91},[60,1136,1137,1139],{"class":62,"line":88},[60,1138,106],{"class":98},[60,1140,535],{"class":102},[60,1142,1143,1145,1147,1149],{"class":62,"line":95},[60,1144,542],{"class":541},[60,1146,545],{"class":102},[60,1148,548],{"class":541},[60,1150,551],{"class":102},[60,1152,1153],{"class":62,"line":136},[60,1154,624],{"class":102},[148,1156,1158],{"id":1157},"fixing-browser-bugs","Fixing browser bugs",[17,1160,1161],{},"A fun bit — for example, iOS Safari has a quirk where clickable elements can't be styled:",[51,1163,1165],{"className":53,"code":1164,"language":55,"meta":56,"style":56},"\u002F**\n * Correct the inability to style clickable types in iOS and Safari.\n *\u002F\n\nbutton,\n[type=\"button\"],\n[type=\"reset\"],\n[type=\"submit\"] {\n  -webkit-appearance: button;\n}\n",[39,1166,1167,1171,1176,1180,1184,1191,1208,1221,1235,1243],{"__ignoreMap":56},[60,1168,1169],{"class":62,"line":63},[60,1170,1048],{"class":66},[60,1172,1173],{"class":62,"line":70},[60,1174,1175],{"class":66}," * Correct the inability to style clickable types in iOS and Safari.\n",[60,1177,1178],{"class":62,"line":76},[60,1179,1063],{"class":66},[60,1181,1182],{"class":62,"line":82},[60,1183,92],{"emptyLinePlaceholder":91},[60,1185,1186,1189],{"class":62,"line":88},[60,1187,1188],{"class":98},"button",[60,1190,133],{"class":102},[60,1192,1193,1196,1199,1202,1205],{"class":62,"line":95},[60,1194,1195],{"class":102},"[",[60,1197,1198],{"class":541},"type",[60,1200,1201],{"class":589},"=",[60,1203,1204],{"class":823},"\"button\"",[60,1206,1207],{"class":102},"],\n",[60,1209,1210,1212,1214,1216,1219],{"class":62,"line":136},[60,1211,1195],{"class":102},[60,1213,1198],{"class":541},[60,1215,1201],{"class":589},[60,1217,1218],{"class":823},"\"reset\"",[60,1220,1207],{"class":102},[60,1222,1223,1225,1227,1229,1232],{"class":62,"line":181},[60,1224,1195],{"class":102},[60,1226,1198],{"class":541},[60,1228,1201],{"class":589},[60,1230,1231],{"class":823},"\"submit\"",[60,1233,1234],{"class":102},"] {\n",[60,1236,1237,1240],{"class":62,"line":217},[60,1238,1239],{"class":541},"  -webkit-appearance",[60,1241,1242],{"class":102},": button;\n",[60,1244,1245],{"class":62,"line":265},[60,1246,624],{"class":102},[148,1248,1013],{"id":1249},"clear-comments",[17,1251,1252],{},"One thing I personally like about Normalize.css — every rule has a clear comment explaining what it does and why. (Skipping examples here since the earlier code samples already showed plenty of comments.)",[17,1254,1255,1256,1261],{},"The ",[28,1257,1260],{"href":1258,"rel":1259},"https:\u002F\u002Fgithub.com\u002Fnecolas\u002Fnormalize.css\u002F",[32],"GitHub README"," is also thorough.",[17,1263,1264],{},"Normalize.css still gets updates for new browser versions, so a lot of CSS frameworks pick it — including Bootstrap, which ships with Normalize.css built in.",[12,1266,1268],{"id":1267},"normalizecss-vs-reset-css","Normalize.css vs Reset CSS",[17,1270,1271],{},"So which do you actually use in real-world dev?",[17,1273,1274],{},"Reset CSS:",[349,1276,1277,1280],{},[354,1278,1279],{},"Pro — all defaults uniform, fully standardised init",[354,1281,1282],{},"Con — you have to re-style every tag yourself, and you need to know which tags got wiped",[17,1284,1285],{},"Normalize.css:",[349,1287,1288,1291],{},[354,1289,1290],{},"Pro — preserves defaults, less style work for you",[354,1292,1293],{},"Con — small chance of style inconsistency, but rare these days",[17,1295,1296],{},"Both have pros and cons. You might be thinking Normalize.css sounds better since you don't have to re-style everything — and yeah, that's a fact.",[17,1298,1299],{},"But in practice, I still use Reset more often, because designers often want styles that don't match Normalize.css's defaults. In that case, starting from zero with Reset is cleaner. Unless the designer is basing the design on Bootstrap, in which case Normalize.css is the natural pick.",[17,1301,1302],{},"So which one? Honestly, the designer decides.",[17,1304,1305],{},"Heads up — if you use Reset CSS with a rich-text editor like CKEditor or TinyMCE, you might end up with no styles on headings, links, or list items. Worth being aware of when picking your CSS approach.",[12,1307,1309],{"id":1308},"references","References",[349,1311,1312,1317,1322],{},[354,1313,1314],{},[28,1315,33],{"href":30,"rel":1316},[32],[354,1318,1319],{},[28,1320,999],{"href":1019,"rel":1321},[32],[354,1323,1324],{},[28,1325,1328],{"href":1326,"rel":1327},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F6803250\u002Fcontent-vs-content-none\u002F6803278",[32],"content: '' vs content: none",[1330,1331,1332],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":56,"searchDepth":70,"depth":70,"links":1334},[1335,1336,1337,1342,1343],{"id":14,"depth":70,"text":15},{"id":22,"depth":70,"text":23},{"id":998,"depth":70,"text":999,"children":1338},[1339,1340,1341],{"id":1024,"depth":76,"text":1025},{"id":1157,"depth":76,"text":1158},{"id":1249,"depth":76,"text":1013},{"id":1267,"depth":70,"text":1268},{"id":1308,"depth":70,"text":1309},"CSS","2021-08-07 20:54:14","Haven't written a CSS post in ages. Here's a quick look at the differences between Reset CSS and Normalize.css.","md","en",{},"\u002Fen\u002Fcss\u002Freset-css-vs-normalize-css","4",{"title":6,"description":1346},false,"en\u002FCSS\u002Freset-css-vs-normalize-css",[1356,999],"Reset CSS",null,"\u002Fen\u002Fcss\u002F2021\u002F08\u002F07\u002Freset-css-vs-normalize-css\u002F","8IMhNyRnHawNoBCm4jn2Q227Em4VWvnIHfcwo7QSGEY",{"newer":1361,"older":1365},{"url":1362,"title":1363,"date":1364},"\u002Fen\u002Fjavascript\u002F2021\u002F08\u002F07\u002Fjavascript-core-64-arrow-functions-intro\u002F","JavaScript Core (64) - ES6: Arrow Functions - A Quick Intro","2021-08-07 23:37:11",{"url":1366,"title":1367,"date":1368},"\u002Fen\u002Fjavascript\u002F2021\u002F08\u002F01\u002Fjs-core-63-let-const-exercises\u002F","Let & Const Quiz: Can You Predict the Output Before Looking? (JS Core #63)","2021-08-01 20:15:59",[1370,1375,1379],{"url":1371,"title":1372,"date":1373,"readingMinutes":1374},"\u002Fen\u002Fcss\u002F2026\u002F05\u002F18\u002Foverflow-scroll-no-scrollbar-macos-chrome-vs-windows\u002F","Why CSS overflow: scroll Shows No Scrollbar on macOS Chrome (vs. Windows)","2026-05-18 17:00:00","6",{"url":1376,"title":1377,"date":1378,"readingMinutes":1082},"\u002Fen\u002Fcss\u002F2024\u002F05\u002F05\u002Fprevent-mouse-text-selection\u002F","How to Stop Users From Selecting Specific Elements","2024-05-05 14:02:05",{"url":1380,"title":1381,"date":1382,"readingMinutes":1374},"\u002Fen\u002Fcss\u002F2021\u002F02\u002F05\u002Fbootstrap-4-to-5-migration\u002F","What?! Bootstrap 4 Became Bootstrap 5","2021-02-05 11:41:28",1784011697881]