[{"data":1,"prerenderedAt":454},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-52-new-and-functions\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-52-new-and-functions\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-52-new-and-functions\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-52-new-and-functions\u002F":430,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-52-new-and-functions\u002F":439},"\u002Fjsweirdworld\u002F20190522\u002F2771076089\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":413,"date":414,"description":415,"extension":416,"lang":417,"meta":418,"navigation":139,"path":419,"readingMinutes":420,"seo":421,"standalone":422,"stem":423,"tags":424,"tldr":427,"updated":414,"url":428,"__hash__":429},"content\u002Fen\u002FJsWeirdWorld\u002Fjsweirdworld-52-new-and-functions.md","[JS Weird World] No.52 A Dangerous Little Reminder: `new` and Functions","1000372196",{"type":9,"value":10,"toc":407},"minimark",[11,16,32,38,44,183,190,204,207,361,367,377,380,390,394,403],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24,25,27,28,31],"p",{},"This chapter is a dangerous little reminder about ",[21,22,23],"code",{},"new"," and functions. We covered the basics earlier: when you add ",[21,26,23],{},", JavaScript creates an empty object, ",[21,29,30],{},"this"," points at that empty object, and if you don't return anything yourself, it returns the new object for you. But this is exactly where functions get dangerous.",[12,33,35,37],{"id":34},"new-and-functions",[21,36,23],{}," and Functions",[17,39,40,41,43],{},"So what happens if we forget to add ",[21,42,23],{},"?",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"language-js shiki shiki-themes github-dark-high-contrast","function Person(first, last) {\n  console.log(this);\n  this.firstname = first;\n  this.lastname = last;\n}\n\nvar john = Person('John', 'Doe');\n\nconsole.log(john);\n","js","",[21,52,53,83,100,115,128,134,141,167,172],{"__ignoreMap":50},[54,55,58,62,66,70,74,77,80],"span",{"class":56,"line":57},"line",1,[54,59,61],{"class":60},"sWyjQ","function",[54,63,65],{"class":64},"sj_SG"," Person",[54,67,69],{"class":68},"sMAXC","(",[54,71,73],{"class":72},"s_sBn","first",[54,75,76],{"class":68},", ",[54,78,79],{"class":72},"last",[54,81,82],{"class":68},") {\n",[54,84,86,89,92,94,97],{"class":56,"line":85},2,[54,87,88],{"class":68},"  console.",[54,90,91],{"class":64},"log",[54,93,69],{"class":68},[54,95,30],{"class":96},"sCcAr",[54,98,99],{"class":68},");\n",[54,101,103,106,109,112],{"class":56,"line":102},3,[54,104,105],{"class":96},"  this",[54,107,108],{"class":68},".firstname ",[54,110,111],{"class":60},"=",[54,113,114],{"class":68}," first;\n",[54,116,118,120,123,125],{"class":56,"line":117},4,[54,119,105],{"class":96},[54,121,122],{"class":68},".lastname ",[54,124,111],{"class":60},[54,126,127],{"class":68}," last;\n",[54,129,131],{"class":56,"line":130},5,[54,132,133],{"class":68},"}\n",[54,135,137],{"class":56,"line":136},6,[54,138,140],{"emptyLinePlaceholder":139},true,"\n",[54,142,144,147,150,152,154,156,160,162,165],{"class":56,"line":143},7,[54,145,146],{"class":60},"var",[54,148,149],{"class":68}," john ",[54,151,111],{"class":60},[54,153,65],{"class":64},[54,155,69],{"class":68},[54,157,159],{"class":158},"sTRMh","'John'",[54,161,76],{"class":68},[54,163,164],{"class":158},"'Doe'",[54,166,99],{"class":68},[54,168,170],{"class":56,"line":169},8,[54,171,140],{"emptyLinePlaceholder":139},[54,173,175,178,180],{"class":56,"line":174},9,[54,176,177],{"class":68},"console.",[54,179,91],{"class":64},[54,181,182],{"class":68},"(john);\n",[17,184,185],{},[186,187],"img",{"alt":188,"src":189},"this points at window","https:\u002F\u002Fi.imgur.com\u002FXWrtxYF.png",[17,191,192,193,195,196,199,200,203],{},"First thing you'll notice: ",[21,194,30],{}," points at ",[21,197,198],{},"window",". JavaScript has no idea we wanted to run this as a constructor — to it, this is just a plain function. And because of that, it only returns ",[21,201,202],{},"undefined",".",[17,205,206],{},"So what's the problem with that? The moment we try to use a prototype method, we get an error.",[45,208,210],{"className":47,"code":209,"language":49,"meta":50,"style":50},"function Person(first, last) {\n  console.log(this);\n  this.firstname = first;\n  this.lastname = last;\n}\nPerson.prototype.getFullName = function() {\n  return this.firstname + ' ' + this.lastname;\n}\n\nvar john = Person('John', 'Doe');\n\nconsole.log(john.getFullName());\n",[21,211,212,228,240,250,260,264,288,312,316,320,341,346],{"__ignoreMap":50},[54,213,214,216,218,220,222,224,226],{"class":56,"line":57},[54,215,61],{"class":60},[54,217,65],{"class":64},[54,219,69],{"class":68},[54,221,73],{"class":72},[54,223,76],{"class":68},[54,225,79],{"class":72},[54,227,82],{"class":68},[54,229,230,232,234,236,238],{"class":56,"line":85},[54,231,88],{"class":68},[54,233,91],{"class":64},[54,235,69],{"class":68},[54,237,30],{"class":96},[54,239,99],{"class":68},[54,241,242,244,246,248],{"class":56,"line":102},[54,243,105],{"class":96},[54,245,108],{"class":68},[54,247,111],{"class":60},[54,249,114],{"class":68},[54,251,252,254,256,258],{"class":56,"line":117},[54,253,105],{"class":96},[54,255,122],{"class":68},[54,257,111],{"class":60},[54,259,127],{"class":68},[54,261,262],{"class":56,"line":130},[54,263,133],{"class":68},[54,265,266,269,271,274,276,279,282,285],{"class":56,"line":136},[54,267,268],{"class":96},"Person",[54,270,203],{"class":68},[54,272,273],{"class":96},"prototype",[54,275,203],{"class":68},[54,277,278],{"class":64},"getFullName",[54,280,281],{"class":60}," =",[54,283,284],{"class":60}," function",[54,286,287],{"class":68},"() {\n",[54,289,290,293,296,298,301,304,307,309],{"class":56,"line":143},[54,291,292],{"class":60},"  return",[54,294,295],{"class":96}," this",[54,297,108],{"class":68},[54,299,300],{"class":60},"+",[54,302,303],{"class":158}," ' '",[54,305,306],{"class":60}," +",[54,308,295],{"class":96},[54,310,311],{"class":68},".lastname;\n",[54,313,314],{"class":56,"line":169},[54,315,133],{"class":68},[54,317,318],{"class":56,"line":174},[54,319,140],{"emptyLinePlaceholder":139},[54,321,323,325,327,329,331,333,335,337,339],{"class":56,"line":322},10,[54,324,146],{"class":60},[54,326,149],{"class":68},[54,328,111],{"class":60},[54,330,65],{"class":64},[54,332,69],{"class":68},[54,334,159],{"class":158},[54,336,76],{"class":68},[54,338,164],{"class":158},[54,340,99],{"class":68},[54,342,344],{"class":56,"line":343},11,[54,345,140],{"emptyLinePlaceholder":139},[54,347,349,351,353,356,358],{"class":56,"line":348},12,[54,350,177],{"class":68},[54,352,91],{"class":64},[54,354,355],{"class":68},"(john.",[54,357,278],{"class":64},[54,359,360],{"class":68},"());\n",[17,362,363],{},[186,364],{"alt":365,"src":366},"error calling a method on undefined","https:\u002F\u002Fi.imgur.com\u002FqEtM49X.png",[17,368,369,370,373,374,376],{},"This error happens because ",[21,371,372],{},"john"," is ",[21,375,202],{},", so there's no way to grab the method off it.",[17,378,379],{},"Most people see this as the big downside of function constructors. But if we follow a few conventions, we can dodge a lot of the trouble. For example: any function we intend to use as a constructor should have its first letter capitalized. Capitalizing the first letter makes it way easier to debug, and it's a long-standing tradition.",[381,382,383],"blockquote",{},[17,384,385,389],{},[386,387,388],"strong",{},"Note","\nAny function you intend to use as a constructor should always start with a capital letter as its name.",[12,391,393],{"id":392},"image-source","Image Source",[17,395,396],{},[397,398,402],"a",{"href":399,"rel":400},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[401],"nofollow"