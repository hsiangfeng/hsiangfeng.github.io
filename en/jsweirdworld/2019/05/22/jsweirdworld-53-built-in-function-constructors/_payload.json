irstname: ",[41,154,155],{"class":131},"'jack'",[41,157,158],{"class":51},"});\n",[17,160,161],{},[79,162],{"alt":163,"src":164},"Output of three built-in constructors","https:\u002F\u002Fi.imgur.com\u002FowJcGFO.png",[17,166,167],{},"A function constructor has a prototype, so we can peek at the prototype — and it comes with some built-in methods.",[31,169,171],{"className":33,"code":170,"language":35,"meta":36,"style":36},"var a = new Number(3);\nNumber.prototype\n",[38,172,173,191],{"__ignoreMap":36},[41,174,175,177,179,181,183,185,187,189],{"class":43,"line":44},[41,176,48],{"class":47},[41,178,52],{"class":51},[41,180,55],{"class":47},[41,182,58],{"class":47},[41,184,62],{"class":61},[41,186,65],{"class":51},[41,188,69],{"class":68},[41,190,72],{"class":51},[41,192,193,196,199],{"class":43,"line":114},[41,194,195],{"class":68},"Number",[41,197,198],{"class":51},".",[41,200,201],{"class":68},"prototype\n",[17,203,204],{},[79,205],{"alt":206,"src":207},"Number.prototype methods","https:\u002F\u002Fi.imgur.com\u002FszhGQgW.png",[17,209,210],{},"Which means we can do stuff like this:",[31,212,214],{"className":33,"code":213,"language":35,"meta":36,"style":36},"var a = new Number(3);\na.toFixed(2)\n",[38,215,216,234],{"__ignoreMap":36},[41,217,218,220,222,224,226,228,230,232],{"class":43,"line":44},[41,219,48],{"class":47},[41,221,52],{"class":51},[41,223,55],{"class":47},[41,225,58],{"class":47},[41,227,62],{"class":61},[41,229,65],{"class":51},[41,231,69],{"class":68},[41,233,72],{"class":51},[41,235,236,239,242,244,247],{"class":43,"line":114},[41,237,238],{"class":51},"a.",[41,240,241],{"class":61},"toFixed",[41,243,65],{"class":51},[41,245,246],{"class":68},"2",[41,248,249],{"class":51},")\n",[17,251,252],{},[79,253],{"alt":254,"src":255},"Calling a.toFixed(2)","https:\u002F\u002Fi.imgur.com\u002FFfJfFrB.png",[17,257,258,259,262],{},"One quick thing about ",[38,260,261],{},"b"," — it's not a string, and it's not a primitive value either.",[31,264,266],{"className":33,"code":265,"language":35,"meta":36,"style":36},"var b = new String('Hellow');\n",[38,267,268],{"__ignoreMap":36},[41,269,270,272,274,276,278,280,282,284],{"class":43,"line":44},[41,271,48],{"class":47},[41,273,119],{"class":51},[41,275,55],{"class":47},[41,277,58],{"class":47},[41,279,126],{"class":61},[41,281,65],{"class":51},[41,283,132],{"class":131},[41,285,72],{"class":51},[17,287,288],{},[79,289],{"alt":290,"src":291},"new String is an object","https:\u002F\u002Fi.imgur.com\u002FXzRMMdi.png",[17,293,294,295,298],{},"It's an object. That's exactly why we can call ",[38,296,297],{},"indexOf()"," on it:",[31,300,302],{"className":33,"code":301,"language":35,"meta":36,"style":36},"var b = new String('Hellow');\nb.indexOf('e');\n",[38,303,304,322],{"__ignoreMap":36},[41,305,306,308,310,312,314,316,318,320],{"class":43,"line":44},[41,307,48],{"class":47},[41,309,119],{"class":51},[41,311,55],{"class":47},[41,313,58],{"class":47},[41,315,126],{"class":61},[41,317,65],{"class":51},[41,319,132],{"class":131},[41,321,72],{"class":51},[41,323,324,327,330,332,335],{"class":43,"line":114},[41,325,326],{"class":51},"b.",[41,328,329],{"class":61},"indexOf",[41,331,65],{"class":51},[41,333,334],{"class":131},"'e'",[41,336,72],{"class":51},[17,338,339],{},[79,340],{"alt":341,"src":342},"Calling b.indexOf('e')","https:\u002F\u002Fi.imgur.com\u002FSpDfvRV.png",[17,344,345],{},"So these built-in function constructors look like they're handing us a string, but really they're handing us an object that wraps a string.",[17,347,348],{},"And the thing is, this:",[31,350,352],{"className":33,"code":351,"language":35,"meta":36,"style":36},"\"Hello\".length;\n",[38,353,354],{"__ignoreMap":36},[41,355,356,359,361,364],{"class":43,"line":44},[41,357,358],{"class":131},"\"Hello\"",[41,360,198],{"class":51},[41,362,363],{"class":68},"length",[41,365,366],{"class":51},";\n",[17,368,369],{},"is basically the same as this:",[31,371,373],{"className":33,"code":372,"language":35,"meta":36,"style":36},"new String(\"Hello\");\n",[38,374,375],{"__ignoreMap":36},[41,376,377,380,382,384,386],{"class":43,"line":44},[41,378,379],{"class":47},"new",[41,381,126],{"class":61},[41,383,65],{"class":51},[41,385,358],{"class":131},[41,387,72],{"class":51},[17,389,390,391,393,394,397],{},"So next time you see ",[38,392,379],{}," — say ",[38,395,396],{},"new Date",":",[31,399,401],{"className":33,"code":400,"language":35,"meta":36,"style":36},"var a = new Date('2019\u002F05\u002F23');\n",[38,402,403],{"__ignoreMap":36},[41,404,405,407,409,411,413,416,418,421],{"class":43,"line":44},[41,406,48],{"class":47},[41,408,52],{"class":51},[41,410,55],{"class":47},[41,412,58],{"class":47},[41,414,415],{"class":61}," Date",[41,417,65],{"class":51},[41,419,420],{"class":131},"'2019\u002F05\u002F23'",[41,422,72],{"class":51},[17,424,425],{},[79,426],{"alt":427,"src":428},"new Date example","https:\u002F\u002Fi.imgur.com\u002FaDUsKqP.png",[17,430,431],{},"what you're really getting is an object, and then you're using the methods JavaScript provides built in.",[17,433,434],{},[79,435],{"alt":436,"src":437},"Using built-in Date methods","https:\u002F\u002Fi.imgur.com\u002FYSeKzlu.png",[17,439,440,441,198],{},"And those methods actually live on ",[38,442,443],{},"Date",[17,445,446],{},[79,447],{"alt":448,"src":449},"Date prototype methods","https:\u002F\u002Fi.imgur.com\u002FkRRMaOI.png",[17,451,452],{},"Now what if we wanted to add our own method to the prototype?",[31,454,458],{"className":455,"code":456,"language":457,"meta":36,"style":36},"language-JS shiki shiki-themes github-dark-high-contrast","String.prototype.isLengthGreaterThan = function (limit) {\n  return this.length > limit;\n}\n\nconsole.log('jack'.isLengthGreaterThan(3));\n","JS",[38,459,460,491,509,514,521],{"__ignoreMap":36},[41,461,462,465,467,470,472,475,478,481,484,488],{"class":43,"line":44},[41,463,464],{"class":68},"String",[41,466,198],{"class":51},[41,468,469],{"class":68},"prototype",[41,471,198],{"class":