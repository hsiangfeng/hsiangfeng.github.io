Dec',\n}\n","js","",[35,36,37,56,69,80],"code",{"__ignoreMap":33},[38,39,42,46,50,53],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," jack ",[38,51,52],{"class":44},"=",[38,54,55],{"class":48}," {\n",[38,57,59,62,66],{"class":40,"line":58},2,[38,60,61],{"class":48},"  firstname: ",[38,63,65],{"class":64},"sTRMh","'jack'",[38,67,68],{"class":48},",\n",[38,70,72,75,78],{"class":40,"line":71},3,[38,73,74],{"class":48},"  lastname: ",[38,76,77],{"class":64},"'Dec'",[38,79,68],{"class":48},[38,81,83],{"class":40,"line":82},4,[38,84,85],{"class":48},"}\n",[17,87,88],{},"But there's another way to create objects too.",[28,90,92],{"className":30,"code":91,"language":32,"meta":33,"style":33},"var jack = new Person();\n",[35,93,94],{"__ignoreMap":33},[38,95,96,98,100,102,105,109],{"class":40,"line":41},[38,97,45],{"class":44},[38,99,49],{"class":48},[38,101,52],{"class":44},[38,103,104],{"class":44}," new",[38,106,108],{"class":107},"sj_SG"," Person",[38,110,111],{"class":48},"();\n",[17,113,114],{},[115,116],"img",{"alt":117,"src":118},"Creating an object with new","https:\u002F\u002Fi.imgur.com\u002F99XMVcR.png",[17,120,121,122,124,125,127],{},"So why does ",[35,123,22],{}," even exist? It comes down to how JavaScript was born. A language that nobody uses is basically a dead language, so back when JavaScript was created, it was named \"JavaScript\" specifically to attract Java developers. Java devs were used to writing ",[35,126,22],{}," to define objects and so on, so when they saw this syntax it felt familiar. The thing is, building objects this way has a few quirks — but we still need to understand it, because it shows up all over the place in real projects and source code.",[17,129,130],{},"Let's have a little fun with the example from the course.",[28,132,134],{"className":30,"code":133,"language":32,"meta":33,"style":33},"function Person() {\n  this.fistname = 'John';\n  this.lastname = 'Doe';\n}\n\nvar john = new Person();\n\nconsole.log(john);\n",[35,135,136,146,163,177,181,188,204,209],{"__ignoreMap":33},[38,137,138,141,143],{"class":40,"line":41},[38,139,140],{"class":44},"function",[38,142,108],{"class":107},[38,144,145],{"class":48},"() {\n",[38,147,148,152,155,157,160],{"class":40,"line":58},[38,149,151],{"class":150},"sCcAr","  this",[38,153,154],{"class":48},".fistname ",[38,156,52],{"class":44},[38,158,159],{"class":64}," 'John'",[38,161,162],{"class":48},";\n",[38,164,165,167,170,172,175],{"class":40,"line":71},[38,166,151],{"class":150},[38,168,169],{"class":48},".lastname ",[38,171,52],{"class":44},[38,173,174],{"class":64}," 'Doe'",[38,176,162],{"class":48},[38,178,179],{"class":40,"line":82},[38,180,85],{"class":48},[38,182,184],{"class":40,"line":183},5,[38,185,187],{"emptyLinePlaceholder":186},true,"\n",[38,189,191,193,196,198,200,202],{"class":40,"line":190},6,[38,192,45],{"class":44},[38,194,195],{"class":48}," john ",[38,197,52],{"class":44},[38,199,104],{"class":44},[38,201,108],{"class":107},[38,203,111],{"class":48},[38,205,207],{"class":40,"line":206},7,[38,208,187],{"emptyLinePlaceholder":186},[38,210,212,215,218],{"class":40,"line":211},8,[38,213,214],{"class":48},"console.",[38,216,217],{"class":107},"log",[38,219,220],{"class":48},"(john);\n",[17,222,223],{},[115,224],{"alt":225,"src":226},"john logged as an object","https:\u002F\u002Fi.imgur.com\u002FJfMqfO4.png",[17,228,229,230,233],{},"We can see ",[35,231,232],{},"john"," became an object. But keep one thing in mind here: we're just using some tricks to create objects in JavaScript. To build an object, we give it properties and methods, then set up the prototype — and we're doing it this way mostly so it's easier to follow. Next we'll use a more correct way to add properties and methods, and to set the prototype.",[17,235,236,237,239,240,247],{},"Now, ",[35,238,22],{}," is actually an operator. Why do I say that? Let's flip back to a doc we looked at before — ",[241,242,246],"a",{"href":243,"rel":244},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FOperators\u002FOperator_Precedence",[245],"nofollow","the MDN page on operator precedence"," (scroll down a bit).",[17,249,250],{},[115,251],{"alt":252,"src":253},"MDN operator precedence table","https:\u002F\u002Fi.imgur.com\u002FsoeegDz.png",[17,255,256,257,259,260,263,264,266,267,269,270,273,274,276,277,279],{},"In the example above, ",[35,258,22],{}," changes what ",[35,261,262],{},"this"," points to. ",[35,265,262],{}," points to an empty object — ",[35,268,22],{}," creates a new object, then calls ",[35,271,272],{},"Person()",". So now the ",[35,275,262],{}," variable points to the memory address of the new empty object that ",[35,278,22],{}," created.",[17,281,282,283,286,287,290],{},"That means when we write ",[35,284,285],{},".firstname"," and ",[35,288,289],{},".lastname",", they get added onto that empty object, kind of like this.",[28,292,294],{"className":30,"code":293,"language":32,"meta":33,"style":33},"var john = {};\n\njohn.fistname = 'John';\njohn.lastname = 'Doe';\n\nconsole.log(john);\n",[35,295,296,307,311,322,333,337],{"__ignoreMap":33},[38,297,298,300,302,304],{"class":40,"line":41},[38,299,45],{"class":44},[38,301,195],{"class":48},[38,303,52],{"class":44},[38,305,306],{"class":48}," {};\n",[38,308,309],{"class":40,"line":58},[38,310,187],{"emptyLinePlaceholder":186},[38,312,313,316,318,320],{"class":40,"line":71},[38,314,315],{"class":48},"john.fistname ",[38,317,52],{"class":44},[38,319,159],{"class":64},[38,321,162],{"class":48},[38,323,324,327,329,331],{"class":40,"line":82},[38,325,326],{"class":48},"john.lastname ",[38,328,52],{"class":44},[38,330,174],{"class":64},[38,332,162],{"class":48},[38,334,335],{"class":40,"line":183},[38,336,187],{"emptyLinePlaceholder":186},[38,338,339,341,343],{"class":40,"line":190},[38,340,214],{"class":48},[38,342,217],{"class":107},[38,344,220],{"class":48},[17,346,347,348,350],{},"