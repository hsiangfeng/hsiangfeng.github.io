[{"data":1,"prerenderedAt":791},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjs-weird-world-51-function-constructors-prototype\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjs-weird-world-51-function-constructors-prototype\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjs-weird-world-51-function-constructors-prototype\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjs-weird-world-51-function-constructors-prototype\u002F":767,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjs-weird-world-51-function-constructors-prototype\u002F":776},"\u002Fjsweirdworld\u002F20190522\u002F2014268419\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":750,"date":751,"description":752,"extension":753,"lang":754,"meta":755,"navigation":106,"path":756,"readingMinutes":757,"seo":758,"standalone":759,"stem":760,"tags":761,"tldr":764,"updated":751,"url":765,"__hash__":766},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-51-function-constructors-prototype.md","[JS Weird World] No.51 Function Constructors and `.prototype`","1000364277",{"type":9,"value":10,"toc":745},"minimark",[11,16,20,23,26,155,162,169,172,178,181,187,190,196,199,342,348,355,361,367,487,493,499,505,508,719,725,728,732,741],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We already know a function constructor can set up properties and methods on a new object. But what about the prototype? So this time we're going to look at how to set up the prototype.",[12,21,22],{"id":22},"prototype",[17,24,25],{},"Here's the example from the last chapter:",[27,28,33],"pre",{"className":29,"code":30,"language":31,"meta":32,"style":32},"language-js shiki shiki-themes github-dark-high-contrast","function Person(first, last) {\n  this.firstname = first;\n  this.lastname = last;\n}\n\nvar john = new Person('John', 'Doe');\n\nconsole.log(john);\n","js","",[34,35,36,66,82,95,101,108,138,143],"code",{"__ignoreMap":32},[37,38,41,45,49,53,57,60,63],"span",{"class":39,"line":40},"line",1,[37,42,44],{"class":43},"sWyjQ","function",[37,46,48],{"class":47},"sj_SG"," Person",[37,50,52],{"class":51},"sMAXC","(",[37,54,56],{"class":55},"s_sBn","first",[37,58,59],{"class":51},", ",[37,61,62],{"class":55},"last",[37,64,65],{"class":51},") {\n",[37,67,69,73,76,79],{"class":39,"line":68},2,[37,70,72],{"class":71},"sCcAr","  this",[37,74,75],{"class":51},".firstname ",[37,77,78],{"class":43},"=",[37,80,81],{"class":51}," first;\n",[37,83,85,87,90,92],{"class":39,"line":84},3,[37,86,72],{"class":71},[37,88,89],{"class":51},".lastname ",[37,91,78],{"class":43},[37,93,94],{"class":51}," last;\n",[37,96,98],{"class":39,"line":97},4,[37,99,100],{"class":51},"}\n",[37,102,104],{"class":39,"line":103},5,[37,105,107],{"emptyLinePlaceholder":106},true,"\n",[37,109,111,114,117,119,122,124,126,130,132,135],{"class":39,"line":110},6,[37,112,113],{"class":43},"var",[37,115,116],{"class":51}," john ",[37,118,78],{"class":43},[37,120,121],{"class":43}," new",[37,123,48],{"class":47},[37,125,52],{"class":51},[37,127,129],{"class":128},"sTRMh","'John'",[37,131,59],{"class":51},[37,133,134],{"class":128},"'Doe'",[37,136,137],{"class":51},");\n",[37,139,141],{"class":39,"line":140},7,[37,142,107],{"emptyLinePlaceholder":106},[37,144,146,149,152],{"class":39,"line":145},8,[37,147,148],{"class":51},"console.",[37,150,151],{"class":47},"log",[37,153,154],{"class":51},"(john);\n",[17,156,157,158,161],{},"The moment we use a function constructor, JavaScript has already set things up for us. So we can go ahead and type ",[34,159,160],{},"john.__proto__",":",[17,163,164],{},[165,166],"img",{"alt":167,"src":168},"john.proto output","https:\u002F\u002Fi.imgur.com\u002FAFL1p93.png",[17,170,171],{},"We get back an object. Don't believe me? Let me collapse it so you can see:",[17,173,174],{},[165,175],{"alt":176,"src":177},"collapsed prototype object","https:\u002F\u002Fi.imgur.com\u002Fzsg4x2Z.png",[17,179,180],{},"So what is this object? We talked about this before — functions are objects. In JavaScript a function is an object, and every object has a prototype property. Normally we don't actually touch it though; it just sits there.",[17,182,183],{},[165,184],{"alt":185,"src":186},"prototype property sitting there","https:\u002F\u002Fi.imgur.com\u002FbibCjxG.png",[17,188,189],{},"Unless we use the function as a function constructor.",[17,191,192],{},[165,193],{"alt":194,"src":195},"function used as a constructor","https:\u002F\u002Fi.imgur.com\u002FDi2qKXA.png",[17,197,198],{},"Let's give it a try.",[27,200,202],{"className":29,"code":201,"language":31,"meta":32,"style":32},"function Person(first, last) {\n  this.firstname = first;\n  this.lastname = last;\n}\n\nPerson.prototype.getFullName = function() {\n  return this.firstname + ' ' + this.lastname;\n}\n\nvar john = new Person('John', 'Doe');\n\nconsole.log(john);\n",[34,203,204,220,230,240,244,248,272,296,300,305,328,333],{"__ignoreMap":32},[37,205,206,208,210,212,214,216,218],{"class":39,"line":40},[37,207,44],{"class":43},[37,209,48],{"class":47},[37,211,52],{"class":51},[37,213,56],{"class":55},[37,215,59],{"class":51},[37,217,62],{"class":55},[37,219,65],{"class":51},[37,221,222,224,226,228],{"class":39,"line":68},[37,223,72],{"class":71},[37,225,75],{"class":51},[37,227,78],{"class":43},[37,229,81],{"class":51},[37,231,232,234,236,238],{"class":39,"line":84},[37,233,72],{"class":71},[37,235,89],{"class":51},[37,237,78],{"class":43},[37,239,94],{"class":51},[37,241,242],{"class":39,"line":97},[37,243,100],{"class":51},[37,245,246],{"class":39,"line":103},[37,247,107],{"emptyLinePlaceholder":106},[37,249,250,253,256,258,260,263,266,269],{"class":39,"line":110},[37,251,252],{"class":71},"Person",[37,254,255],{"class":51},".",[37,257,22],{"class":71},[37,259,255],{"class":51},[37,261,262],{"class":47},"getFullName",[37,264,265],{"class":43}," =",[37,267,268],{"class":43}," function",[37,270,271],{"class":51},"() {\n",[37,273,274,277,280,282,285,288,291,293],{"class":39,"line":140},[37,275,276],{"class":43},"  return",[37,278,279],{"class":71}," this",[37,281,75],{"class":51},[37,283,284],{"class":43},"+",[37,286,287],{"class":128}," ' '",[37,289,290],{"class":43}," +",[37,292,279],{"class":71},[37,294,295],{"class":51},".lastname;\n",[37,297,298],{"class":39,"line":145},[37,299,100],{"class":51},[37,301,303],{"class":39,"line":302},9,[37,304,107],{"emptyLinePlaceholder":106},[37,306,308,310,312,314,316,318,320,322,324,326],{"class":39,"line":307},10,[37,309,113],{"class":43},[37,311,116],{"class":51},[37,313,78],{"class":43},[37,315,121],{"class":43},[37,317,48],{"class":47},[37,319,52],{"class":51},[37,321,129],{"class":128},[37,323,59],{"class":51},[37,325,134],{"class":128},[37,327,137],{"class":51},[37,329,331],{"class":39,"line":330},11,[37,332,107],{"emptyLinePlaceholder":106},[37,334,336,338,340],{"class":39,"line":335},12,[37,337,148],{"class":51},[37,339,151],{"class":47},[37,341,154],{"class":51},[17,343,344],{},[165,345],{"alt":346,"src":347},"getFullName on the prototype","https:\u002F\u002Fi.imgur.com\u002FHhXSu6M.png",[17,349,350,351,354],{},"You can see ",[34,352,353],{},"getFullName()"," now lives under the prototype. Here's another angle on it:",[17,356,357],{},[165,358],{"alt":359,"src":360},"getFullName from another angle","https:\u002F\u002Fi.imgur.com\u002FVdLU4LL.png",[17,362,363,364,366],{},"So we can see that when a function is used as a function constructor, it has a prototype. But why would we put ",[34,365,262],{}," on the prototype? Couldn't we just put it straight inside the function constructor?",[27,368,370],{"className":29,"code":369,"language":31,"meta":32,"style":32},"function Person(first, last) {\n  this.firstname = first;\n  this.lastname = last;\n  this.getFullName = function() {\n  return this.firstname + ' ' + this.lastname;\n  }\n}\n\nvar john = new Person('John', 'Doe');\n\nconsole.log(john);\n",[34,371,372,388,398,408,422,440,445,449,453,475,479],{"__ignoreMap":32},[37,373,374,376,378,380,382,384,386],{"class":39,"line":40},[37,375,44],{"class":43},[37,377,48],{"class":47},[37,379,52],{"class":51},[37,381,56],{"class":55},[37,383,59],{"class":51},[37,385,62],{"class":55},[37,387,65],{"class":51},[37,389,390,392,394,396],{"class":39,"line":68},[37,391,72],{"class":71},[37,393,75],{"class":51},[37,395,78],{"class":43},[37,397,81],{"class":51},[37,399,400,402,404,406],{"class":39,"line":84},[37,401,72],{"class":71},[37,403,89],{"class":51},[37,405,78],{"class":43},[37,407,94],{"class":51},[37,409,410,412,414,416,418,420],{"class":39,"line":97},[37,411,72],{"class":71},[37,413,255],{"class":51},[37,415,262],{"class":47},[37,417,265],{"class":43},[37,419,268],{"class":43},[37,421,271],{"class":51},[37,423,424,426,428,430,432,434,436,438],{"class":39,"line":103},[37,425,276],{"class":43},[37,427,279],{"class":71},[37,429,75],{"class":51},[37,431,284],{"class":43},[37,433,287],{"class":128},[37,435,290],{"class":43},[37,437,279],{"class":71},[37,439,295],{"class":51},[37,441,442],{"class":39,"line":110},[37,443,444],{"class":51},"  }\n",[37,446,447],{"class":39,"line":140},[37,448,100],{"class":51},[37,450,451],{"class":39,"line":145},[37,452,107],{"emptyLinePlaceholder":106},[37,454,455,457,459,461,463,465,467,469,471,473],{"class":39,"line":302},[37,456,113],{"class":43},[37,458,116],{"class":51},[37,460,78],{"class":43},[37,462,121],{"class":43},[37,464,48],{"class":47},[37,466,52],{"class":51},[37,468,129],{"class":128},[37,470,59],{"class":51},[37,472,134],{"class":128},[37,474,137],{"class":51},[37,476,477],{"class":39,"line":307},[37,478,107],{"emptyLinePlaceholder":106},[37,480,481,483,485],{"class":39,"line":330},[37,482,148],{"class":51},[37,484,151],{"class":47},[37,486,154],{"class":51},[17,488,489],{},[165,490],{"alt":491,"src":492},"getFullName inside the constructor","https:\u002F\u002Fi.imgur.com\u002FrBT5tYf.png",[17,494,495,496,498],{},"Say you had a thousand objects, each carrying its own ",[34,497,262],{}," — that'd eat up a lot more memory. Putting it on the prototype is the better move.",[17,500,501,502,504],{},"Performance-wise, putting shared properties and methods on the prototype is better, because that way we don't have to add the object into ",[34,503,252],{}," every single time. We just put the stuff that gets reused on the prototype, and grab it through the prototype when we need it.",[17,506,507],{},"So you can write it like this:",[27,509,511],{"className":29,"code":510,"language":31,"meta":32,"style":32},"function Person(first, last) {\n  this.firstname = first;\n  this.lastname = last;\n}\n\nPerson.prototype.getFullName = function() {\n  return this.firstname + ' ' + this.lastname;\n}\n\nPerson.prototype.getFormaFullName = function() {\n  return this.firstname + ', ' + this.lastname;\n}\n\nvar john = new Person('John', 'Doe');\nconsole.log(john);\n\nvar jack = new Person('John', 'Doe');\nconsole.log(jack);\n",[34,512,513,529,539,549,553,557,575,593,597,601,620,639,643,648,671,680,685,709],{"__ignoreMap":32},[37,514,515,517,519,521,523,525,527],{"class":39,"line":40},[37,516,44],{"class":43},[37,518,48],{"class":47},[37,520,52],{"class":51},[37,522,56],{"class":55},[37,524,59],{"class":51},[37,526,62],{"class":55},[37,528,65],{"class":51},[37,530,531,533,535,537],{"class":39,"line":68},[37,532,72],{"class":71},[37,534,75],{"class":51},[37,536,78],{"class":43},[37,538,81],{"class":51},[37,540,541,543,545,547],{"class":39,"line":84},[37,542,72],{"class":71},[37,544,89],{"class":51},[37,546,78],{"class":43},[37,548,94],{"class":51},[37,550,551],{"class":39,"line":97},[37,552,100],{"class":51},[37,554,555],{"class":39,"line":103},[37,556,107],{"emptyLinePlaceholder":106},[37,558,559,561,563,565,567,569,571,573],{"class":39,"line":110},[37,560,252],{"class":71},[37,562,255],{"class":51},[37,564,22],{"class":71},[37,566,255],{"class":51},[37,568,262],{"class":47},[37,570,265],{"class":43},