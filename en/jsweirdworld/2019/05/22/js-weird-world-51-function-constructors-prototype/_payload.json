9],{"class":51},[37,706,134],{"class":128},[37,708,137],{"class":51},[37,710,712,714,716],{"class":39,"line":711},18,[37,713,148],{"class":51},[37,715,151],{"class":47},[37,717,718],{"class":51},"(jack);\n",[17,720,721],{},[165,722],{"alt":723,"src":724},"both instances sharing the prototype methods","https:\u002F\u002Fi.imgur.com\u002FJGo8aC7.png",[17,726,727],{},"And both of them can use it.",[12,729,731],{"id":730},"image-source","Image source",[17,733,734],{},[735,736,740],"a",{"href":737,"rel":738},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[739],"nofollow","JavaScript: Understanding the Weird Parts",[742,743,744],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":32,"searchDepth":68,"depth":68,"links":746},[747,748,749],{"id":14,"depth":68,"text":15},{"id":22,"depth":68,"text":22},{"id":730,"depth":68,"text":731},"JsWeirdWorld","2019-05-22 15:40:00","How does a function constructor wire up an object's prototype? This post starts from `john.__proto__` and walks through writing something like `Person.prototype.getFullName` — how that hangs a method off the shared prototype object that every instance gets to use. We'll also see why putting shared methods on the prototype beats stuffing them into the constructor.","md","en",{},"\u002Fen\u002Fjsweirdworld\u002Fjs-weird-world-51-function-constructors-prototype","2",{"title":6,"description":752},false,"en\u002FJsWeirdWorld\u002Fjs-weird-world-51-function-constructors-prototype",[762,763],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分",null,"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjs-weird-world-51-function-constructors-prototype\u002F","u4eGtbSf2BBPs7xUmlf3oaOv7tPRnDkP1H9IBBP2MkI",{"newer":768,"older":772},{"url":769,"title":770,"date":771},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-52-new-and-functions\u002F","[JS Weird World] No.52 A Dangerous Little Reminder: `new` and Functions","2019-05-22 16:20:00",{"url":773,"title":774,"date":775},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F22\u002Fjsweirdworld-50-function-constructors-new-history\u002F","[JS Weird World] No.50 Function Constructors, `new`, and a Bit of JavaScript History","2019-05-22 14:15:00",[777,782,787],{"url":778,"title":779,"date":780,"readingMinutes":781},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F","[JS Weird World] Bonus: Closures, One More Time","2019-05-27 13:50:04","5",{"url":783,"title":784,"date":785,"readingMinutes":786},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F25\u002Fjs-weird-world-68-the-end-is-a-new-beginning\u002F","[JS Weird World] No.68 Wrapping Up the Weird Parts of JavaScript","2019-05-25 16:36:00","1",{"url":788,"title":789,"date":790,"readingMinutes":757},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F25\u002Fjs-weird-world-67-adding-jquery-support\u002F","[JS Weird World] No.67 Adding jQuery Support to Our Mini Framework","2019-05-25 16:19:00",1784012778612]