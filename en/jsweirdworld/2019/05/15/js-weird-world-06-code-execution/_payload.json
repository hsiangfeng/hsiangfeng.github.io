,104,113,124,129,145],"code",{"__ignoreMap":39},[44,45,48,52,56],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sWyjQ","function",[44,53,55],{"class":54},"sj_SG"," say",[44,57,59],{"class":58},"sMAXC","(){\n",[44,61,63,66,69,72,76],{"class":46,"line":62},2,[44,64,65],{"class":50}," var",[44,67,68],{"class":58}," b ",[44,70,71],{"class":50},"=",[44,73,75],{"class":74},"sTRMh"," 'Tom'",[44,77,78],{"class":58},";\n",[44,80,82,85,88],{"class":46,"line":81},3,[44,83,84],{"class":58}," console.",[44,86,87],{"class":54},"log",[44,89,90],{"class":58},"(b);\n",[44,92,94],{"class":46,"line":93},4,[44,95,96],{"class":58},"}\n",[44,98,100],{"class":46,"line":99},5,[44,101,103],{"emptyLinePlaceholder":102},true,"\n",[44,105,107,110],{"class":46,"line":106},6,[44,108,109],{"class":54},"say",[44,111,112],{"class":58},"();\n",[44,114,116,119,121],{"class":46,"line":115},7,[44,117,118],{"class":58},"console.",[44,120,87],{"class":54},[44,122,123],{"class":58},"(a);\n",[44,125,127],{"class":46,"line":126},8,[44,128,103],{"emptyLinePlaceholder":102},[44,130,132,135,138,140,143],{"class":46,"line":131},9,[44,133,134],{"class":50},"var",[44,136,137],{"class":58}," a ",[44,139,71],{"class":50},[44,141,142],{"class":74}," 'Hello World!'",[44,144,78],{"class":58},[44,146,148,150,152],{"class":46,"line":147},10,[44,149,118],{"class":58},[44,151,87],{"class":54},[44,153,123],{"class":58},[17,155,156,157,161,162,165],{},"Back in the ",[158,159,160],"strong",{},"No.4 Execution Context: Creation and Hoisting"," chapter, I mentioned that the creation phase hoists all variables and functions to the top, sets them up, and gives them a ",[158,163,164],{},"default value (undefined)",". Then it runs the code you actually wrote. So if we pull it apart, it looks like this:",[34,167,169],{"className":36,"code":168,"language":38,"meta":39,"style":39},"function say(){\n ...\n}\n\nvar a;\n\nsay();\n\nconsole.log(a);\n\na = 'Hello World!';\n\nconsole.log(a);\n",[41,170,171,179,184,188,192,1