[{"data":1,"prerenderedAt":813},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-04-creation-and-hoisting\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-04-creation-and-hoisting\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-04-creation-and-hoisting\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-04-creation-and-hoisting\u002F":788,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-04-creation-and-hoisting\u002F":797},"\u002Fjsweirdworld\u002F20190515\u002F3344152504\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":772,"date":773,"description":774,"extension":775,"lang":776,"meta":777,"navigation":65,"path":778,"readingMinutes":779,"seo":780,"standalone":781,"stem":782,"tags":783,"tldr":785,"updated":773,"url":786,"__hash__":787},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-04-creation-and-hoisting.md","[JS Weird World] No.4 The Execution Context: Creation and Hoisting","1000261330",{"type":9,"value":10,"toc":766},"minimark",[11,16,20,24,27,114,130,133,211,222,229,232,242,313,319,329,332,342,345,383,399,402,452,459,523,536,539,566,585,609,650,653,659,675,724,730,734,744,751,755,762],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This chapter digs into one of the genuinely weird corners of JavaScript: \"creation and hoisting.\" It's also one of those things a lot of people never quite wrap their heads around.",[12,21,23],{"id":22},"creation-and-hoisting","Creation and Hoisting",[17,25,26],{},"Let's start by borrowing the example code from the last chapter.",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Hello World!';\n\nfunction say(){\n var b = 'Tom';\n console.log(b);\n}\n","js","",[35,36,37,60,67,80,96,108],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," a ",[38,51,52],{"class":44},"=",[38,54,56],{"class":55},"sTRMh"," 'Hello World!'",[38,58,59],{"class":48},";\n",[38,61,63],{"class":40,"line":62},2,[38,64,66],{"emptyLinePlaceholder":65},true,"\n",[38,68,70,73,77],{"class":40,"line":69},3,[38,71,72],{"class":44},"function",[38,74,76],{"class":75},"sj_SG"," say",[38,78,79],{"class":48},"(){\n",[38,81,83,86,89,91,94],{"class":40,"line":82},4,[38,84,85],{"class":44}," var",[38,87,88],{"class":48}," b ",[38,90,52],{"class":44},[38,92,93],{"class":55}," 'Tom'",[38,95,59],{"class":48},[38,97,99,102,105],{"class":40,"line":98},5,[38,100,101],{"class":48}," console.",[38,103,104],{"class":75},"log",[38,106,107],{"class":48},"(b);\n",[38,109,111],{"class":40,"line":110},6,[38,112,113],{"class":48},"}\n",[17,115,116,117,121,122,125,126,129],{},"So here I've created a ",[118,119,120],"strong",{},"global variable"," and a ",[118,123,124],{},"global function",", and inside the function I've got ",[35,127,128],{},"console.log(b)"," — that's the syntax that lets us print data to the console.",[17,131,132],{},"Now let's try running this.",[28,134,136],{"className":30,"code":135,"language":32,"meta":33,"style":33},"var a = 'Hello World!';\n\nfunction say(){\n var b = 'Tom';\n console.log(b);\n}\n\nconsole.log(a);\nsay();\n",[35,137,138,150,154,162,174,182,186,191,202],{"__ignoreMap":33},[38,139,140,142,144,146,148],{"class":40,"line":41},[38,141,45],{"class":44},[38,143,49],{"class":48},[38,145,52],{"class":44},[38,147,56],{"class":55},[38,149,59],{"class":48},[38,151,152],{"class":40,"line":62},[38,153,66],{"emptyLinePlaceholder":65},[38,155,156,158,160],{"class":40,"line":69},[38,157,72],{"class":44},[38,159,76],{"class":75},[38,161,79],{"class":48},[38,163,164,166,168,170,172],{"class":40,"line":82},[38,165,85],{"class":44},[38,167,88],{"class":48},[38,169,52],{"class":44},[38,171,93],{"class":55},[38,173,59],{"class":48},[38,175,176,178,180],{"class":40,"line":98},[38,177,101],{"class":48},[38,179,104],{"class":75},[38,181,107],{"class":48},[38,183,184],{"class":40,"line":110},[38,185,113],{"class":48},[38,187,189],{"class":40,"line":188},7,[38,190,66],{"emptyLinePlaceholder":65},[38,192,194,197,199],{"class":40,"line":193},8,[38,195,196],{"class":48},"console.",[38,198,104],{"class":75},[38,200,201],{"class":48},"(a);\n",[38,203,205,208],{"class":40,"line":204},9,[38,206,207],{"class":75},"say",[38,209,210],{"class":48},"();\n",[17,212,213,214,217,218,221],{},"We'd expect to see ",[35,215,216],{},"Hello World!"," and ",[35,219,220],{},"Tom",".",[17,223,224],{},[225,226],"img",{"alt":227,"src":228},"Result","https:\u002F\u002Fi.imgur.com\u002FaWOppst.png",[17,230,231],{},"And sure enough, that's exactly what happens.",[17,233,234,235,217,238,241],{},"But here's the fun part — what if I move ",[35,236,237],{},"console.log(a);",[35,239,240],{},"say();"," to the very top?",[28,243,245],{"className":30,"code":244,"language":32,"meta":33,"style":33},"console.log(a);\nsay();\n\nvar a = 'Hello World!';\n\nfunction say(){\n var b = 'Tom';\n console.log(b);\n}\n",[35,246,247,255,261,265,277,281,289,301,309],{"__ignoreMap":33},[38,248,249,251,253],{"class":40,"line":41},[38,250,196],{"class":48},[38,252,104],{"class":75},[38,254,201],{"class":48},[38,256,257,259],{"class":40,"line":62},[38,258,207],{"class":75},[38,260,210],{"class":48},[38,262,263],{"class":40,"line":69},[38,264,66],{"emptyLinePlaceholder":65},[38,266,267,269,271,273,275],{"class":40,"line":82},[38,268,45],{"class":44},[38,270,49],{"class":48},[38,272,52],{"class":44},[38,274,56],{"class":55},[38,276,59],{"class":48},[38,278,279],{"class":40,"line":98},[38,280,66],{"emptyLinePlaceholder":65},[38,282,283,285,287],{"class":40,"line":110},[38,284,72],{"class":44},[38,286,76],{"class":75},[38,288,79],{"class":48},[38,290,291,293,295,297,299],{"class":40,"line":188},[38,292,85],{"class":44},[38,294,88],{"class":48},[38,296,52],{"class":44},[38,298,93],{"class":55},[38,300,59],{"class":48},[38,302,303,305,307],{"class":40,"line":193},[38,304,101],{"class":48},[38,306,104],{"class":75},[38,308,107],{"class":48},[38,310,311],{"class":40,"line":204},[38,312,113],{"class":48},[17,314,315],{},[225,316],{"alt":317,"src":318},"Time to witness a miracle","https:\u002F\u002Fi.imgur.com\u002FNC694eO.png",[17,320,321,322,325,326,328],{},"In most languages this would just throw an error, because you're using things before they're defined. But JavaScript doesn't throw — it hands you back a value: ",[35,323,324],{},"undefined",". We won't get into what ",[35,327,324],{}," actually is right now.",[17,330,331],{},"So what's really going on under the hood? Let's break it down. JavaScript goes through two phases:",[333,334,335,339],"ul",{},[336,337,338],"li",{},"Creation phase",[336,340,341],{},"Assignment phase",[17,343,344],{},"When JavaScript enters the creation phase, it goes through and finds all the variables and functions first, then sets them up ahead of time. Something like this:",[28,346,348],{"className":30,"code":347,"language":32,"meta":33,"style":33},"var a\n\nfunction say(){\n ...\n}\n...\n",[35,349,350,357,361,369,374,378],{"__ignoreMap":33},[38,351,352,354],{"class":40,"line":41},[38,353,45],{"class":44},[38,355,356],{"class":48}," a\n",[38,358,359],{"class":40,"line":62},[38,360,66],{"emptyLinePlaceholder":65},[38,362,363,365,367],{"class":40,"line":69},[38,364,72],{"class":44},[38,366,76],{"class":75},[38,368,79],{"class":48},[38,370,371],{"class":40,"line":82},[38,372,373],{"class":44}," ...\n",[38,375,376],{"class":40,"line":98},[38,377,113],{"class":48},[38,379,380],{"class":40,"line":110},[38,381,382],{"class":44},"...\n",[17,384,385,386,389,390,392,393,395,396,398],{},"Now, after creating the variable ",[35,387,388],{},"a",", at this point ",[35,391,388],{}," doesn't have a value yet. So while JavaScript is setting up the default execution context, it gives ",[35,394,388],{}," a special keyword — and that keyword is ",[35,397,324],{},". This whole situation is what we call hoisting.",[17,400,401],{},"So if we look at the full picture, it's basically this:",[28,403,405],{"className":30,"code":404,"language":32,"meta":33,"style":33},"var a = 'undefined'\n\nfunction say(){\n ...\n}\nconsole.log(a);\nsay();\n",[35,406,407,418,422,430,434,438,446],{"__ignoreMap":33},[38,408,409,411,413,415],{"class":40,"line":41},[38,410,45],{"class":44},[38,412,49],{"class":48},[38,414,52],{"class":44},[38,416,417],{"class":55}," 'undefined'\n",[38,419,420],{"class":40,"line":62},[38,421,66],{"emptyLinePlaceholder":65},[38,423,424,426,428],{"class":40,"line":69},[38,425,72],{"class":44},[38,427,76],{"class":75},[38,429,79],{"class":48},[38,431,432],{"class":40,"line":82},[38,433,373],{"class":44},[38,435,436],{"class":40,"line":98},[38,437,113],{"class":48},[38,439,440,442,444],{"class":40,"line":110},[38,441,196],{"class":48},[38,443,104],{"class":75},[38,445,201],{"class":48},[38,447,448,450],{"class":40,"line":188},[38,449,207],{"class":75},[38,451,210],{"class":48},[17,453,454,455,458],{},"So when does ",[35,456,457],{},"'Hello World!'"," actually get assigned? Let's trace through the example.",[28,460,462],{"className":30,"code":461,"language":32,"meta":33,"style":33},"var a = 'undefined'\n\nfunction say(){\n ...\n}\nconsole.log(a);\nsay();\n\na = 'Hello World!';\n",[35,463,464,474,478,486,490,494,502,508,512],{"__ignoreMap":33},[38,465,466,468,470,472],{"class":40,"line":41},[38,467,45],{"class":44},[38,469,49],{"class":48},[38,471,52],{"class":44},[38,473,417],{"class":55},[38,475,476],{"class":40,"line":62},[38,477,66],{"emptyLinePlaceholder":65},[38,479,480,482,484],{"class":40,"line":69},[38,481,72],{"class":44},[38,483,76],{"class":75},[38,485,79],{"class":48},[38,487,488],{"class":40,"line":82},[38,489,373],{"class":44},[38,491,492],{"class":40,"line":98},[38,493,113],{"class":48},[38,495,496,498,500],{"class":40,"line":110},[38,497,196],{"class":48},[38,499,104],{"class":75},[38,501,201],{"class":48},[38,503,504,506],{"class":40,"line":188},[38,505,207],{"class":75},[38,507,210],{"class":48},[38,509,510],{"class":40,"line":193},[38,511,66],{"emptyLinePlaceholder":65},[38,513,514,517,519,521],{"class":40,"line":204},[38,515,516],{"class":48},"a ",[38,518,52],{"class":44},[38,520,56],{"class":55},[38,522,59],{"class":48},[17,524,525,526,528,529,531,532,535],{},"That's exactly why ",[35,527,388],{}," comes back as ",[35,530,324],{},". But heads up — the word \"hoisting\" gets misunderstood all the time. It does ",[118,533,534],{},"not"," mean your code literally gets moved to the top. Your code doesn't change at all. It's just one of JavaScript's quirky behaviors.",[17,537,538],{},"So let's pull together everything from earlier chapters up to now. Generally speaking, JavaScript runs in two phases:",[333,540,541,555],{},[336,542,543,544],{},"Creation phase (creation — i.e. building the execution context)\n",[333,545,546,549,552],{},[336,547,548],{},"Global Object (window)",[336,550,551],{},"this",[336,553,554],{},"Outer environment",[336,556,557,558],{},"Hoisting phase\n",[333,559,560,563],{},[336,561,562],{},"Variables",[336,564,565],{},"Functions",[17,567,568,569,571,572,217,575,578,579,581,582,221],{},"The key takeaway here is the same: it does ",[118,570,534],{}," mean your code actually moves to the top. It's just that the \"compiler\" pre-creates the ",[118,573,574],{},"variables",[118,576,577],{},"functions"," before running. One thing to watch out for though — a ",[118,580,72],{}," that's been set up \"reserves memory ahead of time.\" That's why people say ",[118,583,584],{},"having too many functions can hurt performance",[17,586,587,588,590,591,594,595,597,598,601,602,604,605,608],{},"Variables, because of hoisting, end up in this special state. Since ",[35,589,388],{}," hasn't been given a ",[118,592,593],{},"value"," yet, it won't know what it should be until it actually runs. So in the meantime JavaScript gives it a default value — ",[35,596,324],{}," — right up until the compiler runs ",[35,599,600],{},"a = 'Hello World!'",", at which point ",[35,603,388],{}," finally becomes ",[35,606,607],{},"Hello World",". Let's try it out.",[28,610,612],{"className":30,"code":611,"language":32,"meta":33,"style":33},"console.log(a);\n\nvar a = 'Hello World!';\n\nconsole.log(a);\n",[35,613,614,622,626,638,642],{"__ignoreMap":33},[38,615,616,618,620],{"class":40,"line":41},[38,617,196],{"class":48},[38,619,104],{"class":75},[38,621,201],{"class":48},[38,623,624],{"class":40,"line":62},[38,625,66],{"emptyLinePlaceholder":65},[38,627,628,630,632,634,636],{"class":40,"line":69},[38,629,45],{"class":44},[38,631,49],{"class":48},[38,633,52],{"class":44},[38,635,56],{"class":55},[38,637,59],{"class":48},[38,639,640],{"class":40,"line":82},[38,641,66],{"emptyLinePlaceholder":65},[38,643,644,646,648],{"class":40,"line":98},[38,645,196],{"class":48},[38,647,104],{"class":75},[38,649,201],{"class":48},[17,651,652],{},"And the result?",[17,654,655],{},[225,656],{"alt":657,"src":658},"Variable a","https:\u002F\u002Fi.imgur.com\u002FsR9kmmq.png",[17,660,661,662,665,666,668,669,671,672,674],{},"We can see the second ",[35,663,664],{},"console.log"," for ",[35,667,388],{}," shows ",[35,670,607],{},", but the first one shows ",[35,673,324],{},". If we break it apart to analyze, it ends up looking like this:",[28,676,678],{"className":30,"code":677,"language":32,"meta":33,"style":33},"var a\n\nconsole.log(a);\n\na = 'Hello World!';\n\nconsole.log(a);\n",[35,679,680,686,690,698,702,712,716],{"__ignoreMap":33},[38,681,682,684],{"class":40,"line":41},[38,683,45],{"class":44},[38,685,356],{"class":48},[38,687,688],{"class":40,"line":62},[38,689,66],{"emptyLinePlaceholder":65},[38,691,692,694,696],{"class":40,"line":69},[38,693,196],{"class":48},[38,695,104],{"class":75},[38,697,201],{"class":48},[38,699,700],{"class":40,"line":82},[38,701,66],{"emptyLinePlaceholder":65},[38,703,704,706,708,710],{"class":40,"line":98},[38,705,516],{"class":48},[38,707,52],{"class":44},[38,709,56],{"class":55},[38,711,59],{"class":48},[38,713,714],{"class":40,"line":110},[38,715,66],{"emptyLinePlaceholder":65},[38,717,718,720,722],{"class":40,"line":188},[38,719,196],{"class":48},[38,721,104],{"class":75},[38,723,201],{"class":48},[17,725,726,727,729],{},"So in short, every variable in JavaScript starts out set to ",[35,728,324],{},", while functions get fully set up and stored in memory. The thing this chapter teaches us is that your code doesn't get turned into machine instructions instantly. Instead, the \"compiler\" runs it through a few phases first (creation and hoisting) before converting it into instructions the computer can understand.",[12,731,733],{"id":732},"extra-resources","Extra Resources",[17,735,736,737,743],{},"For more on hoisting, you can also check out the Hexschool ",[388,738,742],{"href":739,"rel":740},"https:\u002F\u002Fquip.com\u002FoCBZAmsfvECS\u002F419-JS-",[741],"nofollow","shared notes doc"," (in Mandarin).",[17,745,746,747,221],{},"And of course, you can also check out the post I wrote earlier — ",[388,748,750],{"href":749},"\u002Fjavascript\u002F20190419\u002F3635730318\u002F","Hoisting in JavaScript (article in Mandarin)",[12,752,754],{"id":753},"image-source","Image Source",[17,756,757],{},[388,758,761],{"href":759,"rel":760},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[741],"JavaScript Full Guide: Conquering the Weird Parts of JS",[763,764,765],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":33,"searchDepth":62,"depth":62,"links":767},[768,769,770,771],{"id":14,"depth":62,"text":15},{"id":22,"depth":62,"text":23},{"id":732,"depth":62,"text":733},{"id":753,"depth":62,"text":754},"JsWeirdWorld","2019-05-15 12:00:35","This chapter digs into one of the genuinely strange corners of JavaScript: \"creation and hoisting.\" It's a topic that trips up a ton of people. We'll walk through what actually happens when JavaScript runs your code, why a variable can come back as undefined before you ever assigned it, and what hoisting really means (hint: your code doesn't actually move).","md","en",{},"\u002Fen\u002Fjsweirdworld\u002Fjs-weird-world-04-creation-and-hoisting","4",{"title":6,"description":774},false,"en\u002FJsWeirdWorld\u002Fjs-weird-world-04-creation-and-hoisting",[784,761],"JavaScript",null,"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-04-creation-and-hoisting\u002F","Ar-lOq6s5SOWOPJQyUvRGLwY4oBjfi9tEsqkuYEf0OA",{"newer":789,"older":793},{"url":790,"title":791,"date":792},"\u002Fen\u002Fhexo\u002F2019\u002F05\u002F15\u002Fhexo-app-like-push-notifications\u002F","Adding App-Like Push Notifications to Hexo","2019-05-15 13:58:15",{"url":794,"title":795,"date":796},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-03-global-environment-object\u002F","[JS Weird World] No.3 The Global Environment and the Global Object","2019-05-15 11:30:35",[798,803,808],{"url":799,"title":800,"date":801,"readingMinutes":802},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F","[JS Weird World] Bonus: Closures, One More Time","2019-05-27 13:50:04","5",{"url":804,"title":805,"date":806,"readingMinutes":807},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F25\u002Fjs-weird-world-68-the-end-is-a-new-beginning\u002F","[JS Weird World] No.68 Wrapping Up the Weird Parts of JavaScript","2019-05-25 16:36:00","1",{"url":809,"title":810,"date":811,"readingMinutes":812},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F25\u002Fjs-weird-world-67-adding-jquery-support\u002F","[JS Weird World] No.67 Adding jQuery Support to Our Mini Framework","2019-05-25 16:19:00","2",1784010279063]