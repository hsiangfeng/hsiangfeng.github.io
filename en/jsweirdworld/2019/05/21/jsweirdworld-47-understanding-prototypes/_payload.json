Kd.png",[17,462,463,464,467,468,471,472,474],{},"Why doesn't it grab ",[31,465,466],{},"Default","? Because of the prototype chain — the dot operator finds ",[31,469,470],{},"firstname"," right there on ",[31,473,312],{},", so it stops and doesn't look any further. Now let's add a bit more.",[158,476,478],{"className":160,"code":477,"language":162,"meta":163,"style":163},"var person = {\n  firstname: 'Default',\n  lastname: 'Default',\n  getFullName: function() {\n    return this.firstname + ' ' + this.lastname;\n  }\n}\n\nvar john = {\n  firstname: 'John',\n  lastname: 'Doe',\n}\n\u002F\u002F Never use this approach in real project work — it's only here to help understand prototypes.\njohn.__proto__ = person;\nconsole.log(john.getFullName());\n\nvar jane = {\n  firstname: 'jane',\n}\n\n\u002F\u002F Never use this approach in real project work — it's only here to help understand prototypes.\njane.__proto__ = person;\nconsole.log(jane.lastname);\nconsole.log(jane.getFullName());\n",[31,479,480,490,498,506,516,534,538,542,546,556,564,572,576,580,590,602,607,619,629,634,639,644,656,666],{"__ignoreMap":163},[167,481,482,484,486,488],{"class":169,"line":170},[167,483,174],{"class":173},[167,485,178],{"class":177},[167,487,181],{"class":173},[167,489,184],{"class":177},[167,491,492,494,496],{"class":169,"line":187},[167,493,190],{"class":177},[167,495,194],{"class":193},[167,497,197],{"class":177},[167,499,500,502,504],{"class":169,"line":200},[167,501,203],{"class":177},[167,503,194],{"class":193},[167,505,197],{"class":177},[167,507,508,510,512,514],{"class":169,"line":210},[167,509,214],{"class":213},[167,511,217],{"class":177},[167,513,220],{"class":173},[167,515,223],{"class":177},[167,517,518,520,522,524,526,528,530,532],{"class":169,"line":226},[167,519,229],{"class":173},[167,521,233],{"class":232},[167,523,236],{"class":177},[167,525,239],{"class":173},[167,527,242],{"class":193},[167,529,245],{"class":173},[167,531,233],{"class":232},[167,533,250],{"class":177},