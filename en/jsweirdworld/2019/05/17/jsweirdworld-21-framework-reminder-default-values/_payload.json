[{"data":1,"prerenderedAt":609},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjsweirdworld-21-framework-reminder-default-values\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjsweirdworld-21-framework-reminder-default-values\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjsweirdworld-21-framework-reminder-default-values\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjsweirdworld-21-framework-reminder-default-values\u002F":585,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjsweirdworld-21-framework-reminder-default-values\u002F":594},"\u002Fjsweirdworld\u002F20190517\u002F3961604918\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":568,"date":569,"description":570,"extension":571,"lang":572,"meta":573,"navigation":165,"path":574,"readingMinutes":575,"seo":576,"standalone":577,"stem":578,"tags":579,"tldr":582,"updated":569,"url":583,"__hash__":584},"content\u002Fen\u002FJsWeirdWorld\u002Fjsweirdworld-21-framework-reminder-default-values.md","[JS Weird World] No.21 A Framework Reminder: Default Values","1000102950",{"type":9,"value":10,"toc":564},"minimark",[11,16,20,36,47,60,63,95,98,116,119,368,379,408,415,418,436,438,456,459,466,486,489,492,515,527,530,536,547,551,560],[12,13,15],"h2",{"id":14},"a-little-framework-reminder","A Little Framework Reminder",[17,18,19],"p",{},"Now I want to give you a small conceptual heads-up about frameworks. The course uses jQuery as the example here. Why jQuery? Because back in the day, the most popular framework around was hands-down jQuery — animations, effects, all of it was handled by jQuery, not to mention all the browser-compatibility headaches it smoothed over. So jQuery is honestly the perfect thing to use as an example in this chapter.",[17,21,22,23,27,28,31,32,35],{},"This time we're going to combine a few things we've already learned — ",[24,25,26],"strong",{},"default parameter values",", plus ",[24,29,30],{},"execution context"," and ",[24,33,34],{},"global context"," — and use them to actually understand some jQuery code.",[17,37,38,39,31,43,46],{},"The course sets up three files as an example. Let's say ",[40,41,42],"code",{},"lib1",[40,44,45],{},"lib2"," are both third-party libraries written by other people.",[48,49,50,54,57],"ul",{},[51,52,53],"li",{},"lib1.js",[51,55,56],{},"lib2.js",[51,58,59],{},"app.js \u002F\u002F our own core js",[17,61,62],{},"Here's what's in lib1.js:",[64,65,70],"pre",{"className":66,"code":67,"language":68,"meta":69,"style":69},"language-js shiki shiki-themes github-dark-high-contrast","var libraryName = 'Lib1';\n","js","",[40,71,72],{"__ignoreMap":69},[73,74,77,81,85,88,92],"span",{"class":75,"line":76},"line",1,[73,78,80],{"class":79},"sWyjQ","var",[73,82,84],{"class":83},"sMAXC"," libraryName ",[73,86,87],{"class":79},"=",[73,89,91],{"class":90},"sTRMh"," 'Lib1'",[73,93,94],{"class":83},";\n",[17,96,97],{},"And lib2.js:",[64,99,101],{"className":66,"code":100,"language":68,"meta":69,"style":69},"var libraryName = 'Lib2';\n",[40,102,103],{"__ignoreMap":69},[73,104,105,107,109,111,114],{"class":75,"line":76},[73,106,80],{"class":79},[73,108,84],{"class":83},[73,110,87],{"class":79},[73,112,113],{"class":90}," 'Lib2'",[73,115,94],{"class":83},[17,117,118],{},"So what happens if we load both at the same time?",[64,120,124],{"className":121,"code":122,"language":123,"meta":69,"style":69},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"en\">\n\n  \u003Chead>\n    \u003Cmeta charset=\"UTF-8\">\n    \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    \u003Cmeta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\n    \u003Ctitle>Document\u003C\u002Ftitle>\n    \u003Cscript src=\"lib1.js\">\u003C\u002Fscript>\n    \u003Cscript src=\"lib2.js\">\u003C\u002Fscript>\n    \u003Cscript src=\"all.js\">\u003C\u002Fscript>\n  \u003C\u002Fhead>\n  \u003Cbody>\n  \u003C\u002Fbody>\n\n\u003C\u002Fhtml>\n","html",[40,125,126,142,160,167,178,197,222,246,261,284,304,324,334,344,353,358],{"__ignoreMap":69},[73,127,128,131,135,139],{"class":75,"line":76},[73,129,130],{"class":83},"\u003C!",[73,132,134],{"class":133},"sKpQp","DOCTYPE",[73,136,138],{"class":137},"sCcAr"," html",[73,140,141],{"class":83},">\n",[73,143,145,148,150,153,155,158],{"class":75,"line":144},2,[73,146,147],{"class":83},"\u003C",[73,149,123],{"class":133},[73,151,152],{"class":137}," lang",[73,154,87],{"class":83},[73,156,157],{"class":90},"\"en\"",[73,159,141],{"class":83},[73,161,163],{"class":75,"line":162},3,[73,164,166],{"emptyLinePlaceholder":165},true,"\n",[73,168,170,173,176],{"class":75,"line":169},4,[73,171,172],{"class":83},"  \u003C",[73,174,175],{"class":133},"head",[73,177,141],{"class":83},[73,179,181,184,187,190,192,195],{"class":75,"line":180},5,[73,182,183],{"class":83},"    \u003C",[73,185,186],{"class":133},"meta",[73,188,189],{"class":137}," charset",[73,191,87],{"class":83},[73,193,194],{"class":90},"\"UTF-8\"",[73,196,141],{"class":83},[73,198,200,202,204,207,209,212,215,217,220],{"class":75,"line":199},6,[73,201,183],{"class":83},[73,203,186],{"class":133},[73,205,206],{"class":137}," name",[73,208,87],{"class":83},[73,210,211],{"class":90},"\"viewport\"",[73,213,214],{"class":137}," content",[73,216,87],{"class":83},[73,218,219],{"class":90},"\"width=device-width, initial-scale=1.0\"",[73,221,141],{"class":83},[73,223,225,227,229,232,234,237,239,241,244],{"class":75,"line":224},7,[73,226,183],{"class":83},[73,228,186],{"class":133},[73,230,231],{"class":137}," http-equiv",[73,233,87],{"class":83},[73,235,236],{"class":90},"\"X-UA-Compatible\"",[73,238,214],{"class":137},[73,240,87],{"class":83},[73,242,243],{"class":90},"\"ie=edge\"",[73,245,141],{"class":83},[73,247,249,251,254,257,259],{"class":75,"line":248},8,[73,250,183],{"class":83},[73,252,253],{"class":133},"title",[73,255,256],{"class":83},">Document\u003C\u002F",[73,258,253],{"class":133},[73,260,141],{"class":83},[73,262,264,266,269,272,274,277,280,282],{"class":75,"line":263},9,[73,265,183],{"class":83},[73,267,268],{"class":133},"script",[73,270,271],{"class":137}," src",[73,273,87],{"class":83},[73,275,276],{"class":90},"\"lib1.js\"",[73,278,279],{"class":83},">\u003C\u002F",[73,281,268],{"class":133},[73,283,141],{"class":83},[73,285,287,289,291,293,295,298,300,302],{"class":75,"line":286},10,[73,288,183],{"class":83},[73,290,268],{"class":133},[73,292,271],{"class":137},[73,294,87],{"class":83},[73,296,297],{"class":90},"\"lib2.js\"",[73,299,279],{"class":83},[73,301,268],{"class":133},[73,303,141],{"class":83},[73,305,307,309,311,313,315,318,320,322],{"class":75,"line":306},11,[73,308,183],{"class":83},[73,310,268],{"class":133},[73,312,271],{"class":137},[73,314,87],{"class":83},[73,316,317],{"class":90},"\"all.js\"",[73,319,279],{"class":83},[73,321,268],{"class":133},[73,323,141],{"class":83},[73,325,327,330,332],{"class":75,"line":326},12,[73,328,329],{"class":83},"  \u003C\u002F",[73,331,175],{"class":133},[73,333,141],{"class":83},[73,335,337,339,342],{"class":75,"line":336},13,[73,338,172],{"class":83},[73,340,341],{"class":133},"body",[73,343,141],{"class":83},[73,345,347,349,351],{"class":75,"line":346},14,[73,348,329],{"class":83},[73,350,341],{"class":133},[73,352,141],{"class":83},[73,354,356],{"class":75,"line":355},15,[73,357,166],{"emptyLinePlaceholder":165},[73,359,361,364,366],{"class":75,"line":360},16,[73,362,363],{"class":83},"\u003C\u002F",[73,365,123],{"class":133},[73,367,141],{"class":83},[17,369,370,371,374,375,378],{},"Now let's try writing ",[40,372,373],{},"console.log(libraryName);"," in ",[40,376,377],{},"all.js",". Which one does it pick up?",[17,380,381,382,385,386,389,390,393,394,397,398,401,402,404,405,407],{},"The answer is lib2.js. Why? In the HTML, lib1.js loads first with ",[40,383,384],{},"var libraryName = 'Lib1';",", then lib2.js loads next with ",[40,387,388],{},"var libraryName = 'Lib2';",". And right now ",[40,391,392],{},"var libraryName"," is being created in the ",[24,395,396],{},"global execution context",", which means ",[40,399,400],{},"libraryName"," is a global variable. So when lib2's ",[24,403,400],{}," gets created, it just overwrites the original ",[40,406,400],{}," from lib1.js.",[17,409,410,411,414],{},"So how do we fix this? One option is to use ES6's ",[40,412,413],{},"let",":",[17,416,417],{},"Here's lib1.js:",[64,419,421],{"className":66,"code":420,"language":68,"meta":69,"style":69},"var libraryName = 'tomy';\n",[40,422,423],{"__ignoreMap":69},[73,424,425,427,429,431,434],{"class":75,"line":76},[73,426,80],{"class":79},[73,428,84],{"class":83},[73,430,87],{"class":79},[73,432,433],{"class":90}," 'tomy'",[73,435,94],{"class":83},[17,437,97],{},[64,439,441],{"className":66,"code":440,"language":68,"meta":69,"style":69},"var libraryName = 'jack';\n",[40,442,443],{"__ignoreMap":69},[73,444,445,447,449,451,454],{"class":75,"line":76},[73,446,80],{"class":79},[73,448,84],{"class":83},[73,450,87],{"class":79},[73,452,453],{"class":90}," 'jack'",[73,455,94],{"class":83},[17,457,458],{},"What happens now?",[17,460,461],{},[462,463],"img",{"alt":464,"src":465},"redeclaration error in the console","https:\u002F\u002Fi.imgur.com\u002F0D1M4Ui.png",[17,467,468,469,472,473,476,477,479,480,482,483,485],{},"The result is ",[40,470,471],{},"tomy",", and you also get an error: ",[40,474,475],{},"SyntaxError: redeclaration of let libraryName",". That error is saying ",[40,478,400],{}," got declared twice. In other words, because of how ES6 ",[40,481,413],{}," works, lib2.js loading later doesn't overwrite ",[40,484,400],{}," anymore.",[17,487,488],{},"The course also shows another way to do this without ES6:",[17,490,491],{},"Here's lib2.js:",[64,493,495],{"className":66,"code":494,"language":68,"meta":69,"style":69},"window.libraryName = window.libraryName || 'lib2';\n",[40,496,497],{"__ignoreMap":69},[73,498,499,502,504,507,510,513],{"class":75,"line":76},[73,500,501],{"class":83},"window.libraryName ",[73,503,87],{"class":79},[73,505,506],{"class":83}," window.libraryName ",[73,508,509],{"class":79},"||",[73,511,512],{"class":90}," 'lib2'",[73,514,94],{"class":83},[17,516,517,518,520,521,523,524,526],{},"What this does is check whether the global context already has a ",[40,519,400],{}," variable. If it does, do nothing. If it doesn't, create a new ",[40,522,400],{}," set to ",[40,525,45],{},".",[17,528,529],{},"The result?",[17,531,532],{},[462,533],{"alt":534,"src":535},"window.libraryName check","https:\u002F\u002Fi.imgur.com\u002FyLbOeaO.png",[17,537,538,539,542,543,546],{},"So now you can see that if we're not using ES6, we can do it this way to avoid the conflict. This is what people call ",[24,540,541],{},"global variable pollution",", and this technique has its own formal name in the course too: ",[24,544,545],{},"checking the global namespace",". Personally though, I lean towards just using ES6.",[12,548,550],{"id":549},"image-source","Image Source",[17,552,553],{},[554,555,559],"a",{"href":556,"rel":557},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[558],"nofollow","JavaScript: Understanding the Weird Parts",[561,562,563],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sKpQ