ne",1,[43,48,23],{"class":49},"sj_SG",[43,51,53],{"class":52},"sMAXC","(",[43,55,31],{"class":56},"sCcAr",[43,58,59],{"class":52},");\n",[17,61,62,63,66],{},"You get back ",[21,64,65],{},"false",".",[17,68,69,70,73],{},"What about ",[21,71,72],{},"null","?",[34,75,77],{"className":36,"code":76,"language":38,"meta":39,"style":39},"Boolean(null);\n",[21,78,79],{"__ignoreMap":39},[43,80,81,83,85,87],{"class":45,"line":46},[43,82,23],{"class":49},[43,84,53],{"class":52},[43,86,72],{"class":56},[43,88,59],{"class":52},[17,90,91,92,66],{},"Same thing — you get ",[21,93,65],{},[17,95,96],{},"An empty string?",[34,98,100],{"className":36,"code":99,"language":38,"meta":39,"style":39},"Boolean('');\n",[21,101,102],{"__ignoreMap":39},[43,103,104,106,108,112],{"class":45,"line":46},[43,105,23],{"class":49},[43,107,53],{"class":52},[43,109,111],{"class":110},"sTRMh","''",[43,113,59],{"class":52},[17,115,116,117,66],{},"Still ",[21,118,65],{},[17,120,121],{},"And that's basically telling us these three things all mean \"doesn't exist, nothing here.\" So if we lean on this behavior inside a condition, we can figure out whether there's any data. Something like this:",[34,123,125],{"className":36,"code":124,"language":38,"meta":39,"style":39},"var a = '';\n\nif (a) {\n console.log('has data');\n} else {\n console.log('no data');\n};\n",[21,126,127,145,152,161,177,189,203],{"__ignoreMap":39},[43,128,129,133,136,139,142],{"class":45,"line":46},[43,130,132],{"class":131},"sWyjQ","var",[43,134,135],{"class":52}," a ",[43,137,138],{"class":131},"=",[43,140,141],{"class":110}," ''",[43,143,144],{"class":52},";\n",[43,146,148],{"class":45,"line":147},2,[43,149,151],{"emptyLinePlaceholder":150},true,"\n",[43,153,155,158],{"class":45,"line":154},3,[43,156,157],{"class":131},"if",[43,159,160],{"class":52}," (a) {\n",[43,162,164,167,170,172,175],{"class":45,"line":163},4,[43,165,166],{"class":52}," console.",[43,168,169],{"class":49},"log",[43,171,53],{"class":52},[43,173,174],{"class":110},"'has data'",[43,176,59],{"class":52},[43,178,180,183,186],{"class":45,"line":179},5,[43,181,182],{"class":52},"} ",[43,184,185],{"class":131},"else",[43,187,188],{"class":52}," {\n",[43,190,192,194,196,198,201],{"class":45,"line":191},6,[43,193,166],{"class":52},[43,195,169],{"class":49},[43,197,53],{"class":52},[43,199,200],{"class":110},"'no data'",[43,202,59],{"class":52},[43,204,206],{"class":45,"line":205},7,[43,207,208],{"class":52},"};\n",[17,210,211],{},"Now here's the part with a bit of a trap, which the course calls out too:",[34,213,215],{"className":36,"code":214,"language":38,"meta":39,"style":39},"Boolean(0);\n",[21,216,217],{"__ignoreMap":39},[43,218,219,221,223,226],{"class":45,"line":46},[43,220,23],{"class":49},[43,222,53],{"class":52},[43,224,225],{"class":56},"0",[43,227,59],{"class":52},[17,229,230,231,233],{},"This is also ",[21,232,65],{},". The course gives an example for this one:",[34,235,237],{"className":36,"code":236,"language":38,"meta":39,"style":39},"var a = '';\n\nif (a || a === 0) {\n console.log('has data');\n} else {\n console.log('no data');\n};\n",[21,238,239,251,255,276,288,296,308],{"__ignoreMap":39},[43,240,241,243,245,247,249],{"class":45,"line":46},[43,242,132],{"class":131},[43,244,135],{"class":52},[43,246,138],{"class":131},[43,248,141],{"class":110},[43,250,144],{"class":52},[43,252,253],{"class":45,"line":147},[43,254,151],{"emptyLinePlaceholder":150},[43,256,257,259,262,265,267,270,273],{"class":45,"line":154},[43,258,157],{"class":131},[43,260,261],{"class":52}," (a ",[43,263,264],{"class":131},"||",[43,266,135],{"class":52},[43,268,269],{"class":131},"===",[43,271,272],{"class":56}," 0",[43,274,275],{"class":52},") {\n",[43,277,278,280,282,284,286],{"class":45,"line":163},[43,279,166],{"class":52},[43,281,169],{"class":49},[43,283,53],{"class":52},[43,285,174],{"class":110},[43,287,59],{"class":52},[43,289,290,292,294],{"class":45,"line":179},[43,291,182],{"class":52},[43,293,185],{"class":131},[43,295,188],{"class":52},[43,297,298,300,302,304,306],{"class":45,"line":191},[43,299,166],{"class":52},[43,301,169],{"class":49},[43,303,53],{"class":52},[43,305,200],{"class":110},[43,307,59],{"class":52},[43,309,310],{"class":45,"line":205},[43,311,208],{"class":52},[17,313,314,315,317,318,320,321,323],{},"In this example the course mentions that the ",[21,316,264],{}," operator has lower precedence than ",[21,319,269],{},", so the ",[21,322,269],{}," check runs first.",[17,325,326],{},"So after the engine processes it, the code effectively becomes:",[34,328,330],{"className":36,"code":329,"language":38,"meta":39,"style":39},"var a = 0;\n\nif (a || true) {\n console.log('has data');\n} else {\n console.log('no data');\n};\n",[21,331,332,344,348,361,373,381,393],{"__ignoreMap":39},[43,333,334,336,338,340,342],{"class":45,"line":46},[43,335,132],{"class":131},[43,337,135],{"class":52},[43,339,138],{"class":131},[43,341,272],{"class":56},[43,343,144],{"class":52},[43,345,346],{"class":45,"line":147},[43,347,151],{"emptyLinePlaceholder":150},[43,349,350,352,354,356,359],{"class":45,"line":154},[43,351,157],{"class":131},[43,353,261],{"class":52},[43,355,264],{"class":131},[43,357,358],{"class":56}," true",[43,360,275],{"class":52},[43,362,363,365,367,369,371],{"class":45,"line":163},[43,364,166],{"class":52},[43,366,169],{"class":49},[43,368,53],{"class":52},[43,370,174],{"class":110},[43,372,59],{"class":52},[43,374,375,377,379],{"class":45,"line":179},[43,376,182],{"class":52},[43,378,185],{"class":131},[43,380,188],{"class":52},[43,382,383,385,387,389,391],{"class":45,"line":191},[43,384,166],{"class":52},[43,386,169],{"class":49},[43,388,53],{"class":52},[43,390,200],{"class":110},[43,392,59],{"class":52},[43,394,395],{"class":45,"line":205},[43,396,208],{"class":52},[17,398,399,400,403,404,406,407,409],{},"Then ",[21,401,402],{},"a"," gets coerced into a boolean, and ",[21,405,225],{}," means ",[21,408,65],{},":",[34,411,413],{"className":36,"code":412,"language":38,"meta":39,"style