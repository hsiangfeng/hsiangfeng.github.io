[{"data":1,"prerenderedAt":396},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjs-weird-world-20-default-values\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjs-weird-world-20-default-values\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjs-weird-world-20-default-values\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjs-weird-world-20-default-values\u002F":372,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjs-weird-world-20-default-values\u002F":381},"\u002Fjsweirdworld\u002F20190517\u002F600418516\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":356,"date":357,"description":358,"extension":359,"lang":360,"meta":361,"navigation":86,"path":362,"readingMinutes":363,"seo":364,"standalone":365,"stem":366,"tags":367,"tldr":369,"updated":357,"url":370,"__hash__":371},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-20-default-values.md","[JS Weird World] No.20 Default Values","1000095031",{"type":9,"value":10,"toc":352},"minimark",[11,16,20,102,109,155,158,165,168,181,189,240,246,252,255,262,329,335,339,348],[12,13,15],"h2",{"id":14},"default-values","Default Values",[17,18,19],"p",{},"Last time we went through some of the quirks of coercion. So this time we're going to look at it from another angle and actually put those quirks to use. The course kicks off with this bit of sample code:",[21,22,27],"pre",{"className":23,"code":24,"language":25,"meta":26,"style":26},"language-js shiki shiki-themes github-dark-high-contrast","function green(name) {\n console.log('Hello' + name);\n}\n\ngreen('Tom');\n","js","",[28,29,30,54,75,81,88],"code",{"__ignoreMap":26},[31,32,35,39,43,47,51],"span",{"class":33,"line":34},"line",1,[31,36,38],{"class":37},"sWyjQ","function",[31,40,42],{"class":41},"sj_SG"," green",[31,44,46],{"class":45},"sMAXC","(",[31,48,50],{"class":49},"s_sBn","name",[31,52,53],{"class":45},") {\n",[31,55,57,60,63,65,69,72],{"class":33,"line":56},2,[31,58,59],{"class":45}," console.",[31,61,62],{"class":41},"log",[31,64,46],{"class":45},[31,66,68],{"class":67},"sTRMh","'Hello'",[31,70,71],{"class":37}," +",[31,73,74],{"class":45}," name);\n",[31,76,78],{"class":33,"line":77},3,[31,79,80],{"class":45},"}\n",[31,82,84],{"class":33,"line":83},4,[31,85,87],{"emptyLinePlaceholder":86},true,"\n",[31,89,91,94,96,99],{"class":33,"line":90},5,[31,92,93],{"class":41},"green",[31,95,46],{"class":45},[31,97,98],{"class":67},"'Tom'",[31,100,101],{"class":45},");\n",[17,103,104,105,108],{},"You already know this prints ",[28,106,107],{},"Hello Tom",". Okay, let me pause here, because this is where I started wondering — what happens if I don't pass an argument at all?",[21,110,112],{"className":23,"code":111,"language":25,"meta":26,"style":26},"function green(name) {\n console.log('Hello' + name);\n}\n\ngreen();\n",[28,113,114,126,140,144,148],{"__ignoreMap":26},[31,115,116,118,120,122,124],{"class":33,"line":34},[31,117,38],{"class":37},[31,119,42],{"class":41},[31,121,46],{"class":45},[31,123,50],{"class":49},[31,125,53],{"class":45},[31,127,128,130,132,134,136,138],{"class":33,"line":56},[31,129,59],{"class":45},[31,131,62],{"class":41},[31,133,46],{"class":45},[31,135,68],{"class":67},[31,137,71],{"class":37},[31,139,74],{"class":45},[31,141,142],{"class":33,"line":77},[31,143,80],{"class":45},[31,145,146],{"class":33,"line":83},[31,147,87],{"emptyLinePlaceholder":86},[31,149,150,152],{"class":33,"line":90},[31,151,93],{"class":41},[31,153,154],{"class":45},"();\n",[17,156,157],{},"What do you think comes out?",[17,159,160],{},[161,162],"img",{"alt":163,"src":164},"undefined","https:\u002F\u002Fi.imgur.com\u002Fo4JwYY0.png",[17,166,167],{},"undefined!",[17,169,170,171,173,174,176,177,180],{},"So when you don't pass an argument, JavaScript fills in the default value ",[28,172,163],{}," for you. Which means the ",[28,175,50],{}," in ",[28,178,179],{},"green(name)"," is really just a variable.",[17,182,183,184,188],{},"The course also points out that JavaScript originally couldn't give function parameters a default value at all — that's something ",[185,186,187],"strong",{},"ES6"," added. So when no argument is passed, we can use ES6's default value syntax to set one for the parameter:",[21,190,192],{"className":23,"code":191,"language":25,"meta":26,"style":26},"function green(name = 'jack') {\n console.log('Hello' + name);\n}\n\ngreen();\n",[28,193,194,212,226,230,234],{"__ignoreMap":26},[31,195,196,198,200,202,204,207,210],{"class":33,"line":34},[31,197,38],{"class":37},[31,199,42],{"class":41},[31,201,46],{"class":45},[31,203,50],{"class":49},[31,205,206],{"class":37}," =",[31,208,209],{"class":67}," 'jack'",[31,211,53],{"class":45},[31,213,214,216,218,220,222,224],{"class":33,"line":56},[31,215,59],{"class":45},[31,217,62],{"class":41},[31,219,46],{"class":45},[31,221,68],{"class":67},[31,223,71],{"class":37},[31,225,74],{"class":45},[31,227,228],{"class":33,"line":77},[31,229,80],{"class":45},[31,231,232],{"class":33,"line":83},[31,233,87],{"emptyLinePlaceholder":86},[31,235,236,238],{"class":33,"line":90},[31,237,93],{"class":41},[31,239,154],{"class":45},[17,241,242,243,245],{},"So what happens now — still ",[28,244,163],{},"?",[17,247,248],{},[161,249],{"alt":250,"src":251},"jack","https:\u002F\u002Fi.imgur.com\u002Fx192BJJ.png",[17,253,254],{},"Nope, different this time.",[17,256,257,258,261],{},"And if you'd rather not use ES6's ",[185,259,260],{},"default parameter"," approach, here's another way to do it:",[21,263,265],{"className":23,"code":264,"language":25,"meta":26,"style":26},"function green(name) {\n var name = name || 'jack';\n console.log('Hello' + name);\n}\n\ngreen();\n",[28,266,267,279,300,314,318,322],{"__ignoreMap":26},[31,268,269,271,273,275,277],{"class":33,"line":34},[31,270,38],{"class":37},[31,272,42],{"class":41},[31,274,46],{"class":45},[31,276,50],{"class":49},[31,278,53],{"class":45},[31,280,281,284,287,290,292,295,297],{"class":33,"line":56},[31,282,283],{"class":37}," var",[31,285,286],{"class":45}," name ",[31,288,289],{"class":37},"=",[31,291,286],{"class":45},[31,293,294],{"class":37},"||",[31,296,209],{"class":67},[31,298,299],{"class":45},";\n",[31,301,302,304,306,308,310,312],{"class":33,"line":77},[31,303,59],{"class":45},[31,305,62],{"class":41},[31,307,46],{"class":45},[31,309,68],{"class":67},[31,311,71],{"class":37},[31,313,74],{"class":45},[31,315,316],{"class":33,"line":83},[31,317,80],{"class":45},[31,319,320],{"class":33,"line":90},[31,321,87],{"emptyLinePlaceholder":86},[31,323,325,327],{"class":33,"line":324},6,[31,326,93],{"class":41},[31,328,154],{"class":45},[17,330,331],{},[161,332],{"alt":333,"src":334},"default parameter value","https:\u002F\u002Fi.imgur.com\u002FC7mf8r4.png",[12,336,338],{"id":337},"image-source","Image source",[17,340,341],{},[342,343,347],"a",{"href":344,"rel":345},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[346],"nofollow","JavaScript Full Guide: Conquering the Weird Parts of JS",[349,350,351],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":26,"searchDepth":56,"depth":56,"links":353},[354,355],{"id"