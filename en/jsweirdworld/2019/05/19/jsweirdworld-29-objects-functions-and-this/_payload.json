t this point:",[17,772,773],{},[28,774],{"alt":58,"src":775},"https:\u002F\u002Fi.imgur.com\u002FSm12Azz.png",[17,777,778,779,782,783,786],{},"You'll find ",[21,780,781],{},"this.name = newname;"," got created on the global object. That proves one thing: the execution context of ",[21,784,785],{},"var setname = function (newname) { this.name = newname; }"," is the global object.",[17,788,789,790,793],{},"So when you run into this situation, how do you make sure you get the right object property? You set a variable up in ",[21,791,792],{},"log()",":",[64,795,797],{"className":66,"code":796,"language":68,"meta":69,"style":69},"var c = {\n  name: 'The C object',\n  log: function() {\n    var vm = this;\n    var setname = function (newname) {\n      vm.name = newname;\n    }\n    setname('Updated again!');\n    console.log(vm);\n  },\n};\n\nc.log();\n",[21,798,799,809,817,827,840,856,865,869,879,888,892,896,900],{"__ignoreMap":69},[73,800,801,803,805,807],{"class":75,"line":76},[73,802,169],{"class":106},[73,804,413],{"class":79},[73,806,269],{"class":106},[73,808,418],{"class":79},[73,810,811,813,815],{"class":75,"line":116},[73,812,423],{"class":79},[73,814,426],{"class":272},[73,816,429],{"class":79},[73,818,819,821,823,825],{"class":75,"line":130},[73,820,434],{"class":83},[73,822,437],{"class":79},[73,824,107],{"class":106},[73,826,442],{"class":79},[73,828,829,831,834,836,838],{"class":75,"line":136},[73,830,675],{"class":106},[73,832,833],{"class":79}," vm ",[73,835,269],{"class":106},[73,837,263],{"class":90},[73,839,276],{"class":79},[73,841,842,844,846,848,850,852,854],{"class":75,"line":143},[73,843,675],{"class":106},[73,845,678],{"class":83},[73,847,175],{"class":106},[73,849,178],{"class":106},[73,851,685],{"class":79},[73,853,689],{"class":688},[73,855,692],{"class":79},[73,857,858,861,863],{"class":75,"line":287},[73,859,860],{"class":79},"      vm.name ",[73,862,269],{"class":106},[73,864,704],{"class":79},[73,866,867],{"class":75,"line":294},[73,868,709],{"class":79},[73,870,871,873,875,877],{"class":75,"line":471},[73,872,714],{"class":83},[73,874,87],{"class":79},[73,876,719],{"class":272},[73,878,93],{"class":79},[73,880,881,883,885],{"class":75,"line":590},[73,882,447],{"class":79},[73,884,84],{"class":83},[73,886,887],{"class":79},"(vm);\n",[73,889,890],{"class":75,"line":595},[73,891,460],{"class":79},[73,893,894],{"class":75,"line":600},[73,895,199],{"class":79},[73,897,898],{"class":75,"line":748},[73,899,140],{"emptyLinePlaceholder":139},[73,901,903,905,907],{"class":75,"line":902},13,[73,904,474],{"class":79},[73,906,84],{"class":83},[73,908,149],{"class":79},[17,910,911],{},[28,912],{"alt":913,"src":914},"screenshot","https:\u002F\u002Fi.imgur.com\u002FmxApEob.png",[17,916,917,918,920,921,924,925,927],{},"Why does this work? Because ",[21,919,23],{}," is an object, so here we lean on the pass-by-reference behavior of objects — ",[21,922,923],{},"vm"," points to the same memory location. The nice part is we don't have to worry about ",[21,926,23],{}," pointing at the wrong place.",[17,929,930,931,933,934,24],{},"This ties back to JavaScript's scope chain idea too. ",[21,932,923],{}," isn't declared inside the anonymous function, so JavaScript looks outward to the outer context, and one level up it finds ",[21,935,936],{},"var vm = this;",[17,938,939],{},"Every language has its weird corners, but you can usually find the clues by following the thread.",[620,941,942],{},[17,943,944,946,947,949,950,953],{},[625,945,627],{},"\nIf you're not sure where ",[21,948,23],{}," is pointing, just ",[21,951,952],{},"console.log()"," it and you'll know.",[12,955,957],{"id":956},"image-source","Image Source",[17,959,960],{},[146,961,965],{"href":962,"rel":963},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[964],"nofollow","JavaScript Full Guide: Beating the Weird Parts of JS",[967,968,969],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html