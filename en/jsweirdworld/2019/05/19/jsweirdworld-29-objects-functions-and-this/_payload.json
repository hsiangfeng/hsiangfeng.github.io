[{"data":1,"prerenderedAt":1017},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-29-objects-functions-and-this\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-29-objects-functions-and-this\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-29-objects-functions-and-this\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-29-objects-functions-and-this\u002F":992,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-29-objects-functions-and-this\u002F":1001},"\u002Fjsweirdworld\u002F20190519\u002F2086093631\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":976,"date":977,"description":978,"extension":979,"lang":980,"meta":981,"navigation":139,"path":982,"readingMinutes":983,"seo":984,"standalone":985,"stem":986,"tags":987,"tldr":989,"updated":977,"url":990,"__hash__":991},"content\u002Fen\u002FJsWeirdWorld\u002Fjsweirdworld-29-objects-functions-and-this.md","[JS Weird World] No.29 Objects, Functions, and this","1000166302",{"type":9,"value":10,"toc":970},"minimark",[11,16,25,32,37,45,47,63,94,97,150,155,160,211,216,234,302,308,322,380,383,392,396,402,479,485,494,607,612,619,631,635,638,755,761,771,776,787,794,909,915,928,937,940,954,958,966],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"This time we're going back to the execution context we mentioned way back at the start, plus the thing I kept skipping over earlier: ",[21,22,23],"code",{},"this",".",[17,26,27],{},[28,29],"img",{"alt":30,"src":31},"Objects, functions, and this","https:\u002F\u002Fi.imgur.com\u002FwYjH4Nv.png",[17,33,34,35,24],{},"So what actually happens when we run a function object? We already know every execution context has its own context, and it can also reference the outer context. When an execution context gets created, JavaScript builds something we never declared ourselves — ",[21,36,23],{},[17,38,39,41,42,44],{},[21,40,23],{}," is one of those things a lot of people hit a wall on. In certain situations ",[21,43,23],{}," changes what it points to depending on how the function was called.",[12,46,23],{"id":23},[17,48,49,50,52,53,55,56,59,60,62],{},"I'll use a few small examples to show where ",[21,51,23],{}," points in different environments. We already saw earlier that ",[21,54,23],{}," references ",[21,57,58],{},"window"," — that's because in the current execution context, ",[21,61,23],{}," points to the global object.",[64,65,70],"pre",{"className":66,"code":67,"language":68,"meta":69,"style":69},"language-js shiki shiki-themes github-dark-high-contrast","console.log(this);\n","js","",[21,71,72],{"__ignoreMap":69},[73,74,77,81,85,88,91],"span",{"class":75,"line":76},"line",1,[73,78,80],{"class":79},"sMAXC","console.",[73,82,84],{"class":83},"sj_SG","log",[73,86,87],{"class":79},"(",[73,89,23],{"class":90},"sCcAr",[73,92,93],{"class":79},");\n",[17,95,96],{},"And what about this? Where does it point now?",[64,98,100],{"className":66,"code":99,"language":68,"meta":69,"style":69},"function a (){\n console.log(this);\n}\n\na();\n",[21,101,102,114,128,134,141],{"__ignoreMap":69},[73,103,104,108,111],{"class":75,"line":76},[73,105,107],{"class":106},"sWyjQ","function",[73,109,110],{"class":83}," a",[73,112,113],{"class":79}," (){\n",[73,115,117,120,122,124,126],{"class":75,"line":116},2,[73,118,119],{"class":79}," console.",[73,121,84],{"class":83},[73,123,87],{"class":79},[73,125,23],{"class":90},[73,127,93],{"class":79},[73,129,131],{"class":75,"line":130},3,[73,132,133],{"class":79},"}\n",[73,135,137],{"class":75,"line":136},4,[73,138,140],{"emptyLinePlaceholder":139},true,"\n",[73,142,144,147],{"class":75,"line":143},5,[73,145,146],{"class":83},"a",[73,148,149],{"class":79},"();\n",[17,151,152],{},[28,153],{"alt":23,"src":154},"https:\u002F\u002Fi.imgur.com\u002FQdsa3bL.png",[17,156,157,159],{},[21,158,23],{}," points to the global object. Okay, what if we use an anonymous function instead?",[64,161,163],{"className":66,"code":162,"language":68,"meta":69,"style":69},"var b = function () {\n  console.log(this);\n};\n\nb();\n",[21,164,165,182,195,200,204],{"__ignoreMap":69},[73,166,167,170,173,176,179],{"class":75,"line":76},[73,168,169],{"class":106},"var",[73,171,172],{"class":83}," b",[73,174,175],{"class":106}," =",[73,177,178],{"class":106}," function",[73,180,181],{"class":79}," () {\n",[73,183,184,187,189,191,193],{"class":75,"line":116},[73,185,186],{"class":79},"  console.",[73,188,84],{"class":83},[73,190,87],{"class":79},[73,192,23],{"class":90},[73,194,93],{"class":79},[73,196,197],{"class":75,"line":130},[73,198,199],{"class":79},"};\n",[73,201,202],{"class":75,"line":136},[73,203,140],{"emptyLinePlaceholder":139},[73,205,206,209],{"class":75,"line":143},[73,207,208],{"class":83},"b",[73,210,149],{"class":79},[17,212,213],{},[28,214],{"alt":23,"src":215},"https:\u002F\u002Fi.imgur.com\u002FwO9BEak.png",[17,217,218,219,221,222,224,225,227,228,230,231,233],{},"Same thing — it points to the global object. From these examples you can see that whether it's a function expression or a function statement, ",[21,220,23],{}," points to ",[21,223,58],{},". But here's the thing to notice: every function has its own execution context, so each one has its own ",[21,226,23],{},". Yet in the examples above, ",[21,229,23],{}," keeps pointing at the same place — ",[21,232,58],{},". Why? Let's keep going.",[64,235,237],{"className":66,"code":236,"language":68,"meta":69,"style":69},"function a (){\n console.log(this);\n this.newvalue = 'hello';\n}\n\na();\nconsole.log(newvalue);\n",[21,238,239,247,259,277,281,285,292],{"__ignoreMap":69},[73,240,241,243,245],{"class":75,"line":76},[73,242,107],{"class":106},[73,244,110],{"class":83},[73,246,113],{"class":79},[73,248,249,251,253,255,257],{"class":75,"line":116},[73,250,119],{"class":79},[73,252,84],{"class":83},[73,254,87],{"class":79},[73,256,23],{"class":90},[73,258,93],{"class":79},[73,260,261,264,267,270,274],{"class":75,"line":130},[73,262,263],{"class":90}," this",[73,265,266],{"class":79},".newvalue ",[73,268,269],{"class":106},"=",[73,271,273],{"class":272},"sTRMh"," 'hello'",[73,275,276],{"class":79},";\n",[73,278,279],{"class":75,"line":136},[73,280,133],{"class":79},[73,282,283],{"class":75,"line":143},[73,284,140],{"emptyLinePlaceholder":139},[73,286,288,290],{"class":75,"line":287},6,[73,289,146],{"class":83},[73,291,149],{"class":79},[73,293,295,297,299],{"class":75,"line":294},7,[73,296,80],{"class":79},[73,298,84],{"class":83},[73,300,301],{"class":79},"(newvalue);\n",[17,303,304],{},[28,305],{"alt":306,"src":307},"newvalue","https:\u002F\u002Fi.imgur.com\u002FRdQysjJ.png",[17,309,310,311,313,314,317,318,321],{},"You can see ",[21,312,306],{}," shows up as the ",[21,315,316],{},"hello"," set inside function ",[21,319,320],{},"a()",". So if we spell it out in more detail, the code is really doing this:",[64,323,325],{"className":66,"code":324,"language":68,"meta":69,"style":69},"function a (){\n console.log(this);\n window.newvalue = 'hello';\n}\n\na();\nconsole.log(newvalue);\n",[21,326,327,335,347,358,362,366,372],{"__ignoreMap":69},[73,328,329,331,333],{"class":75,"line":76},[73,330,107],{"class":106},[73,332,110],{"class":83},[73,334,113],{"class":79},[73,336,337,339,341,343,345],{"class":75,"line":116},[73,338,119],{"class":79},[73,340,84],{"class":83},[73,342,87],{"class":79},[73,344,23],{"class":90},[73,346,93],{"class":79},[73,348,349,352,354,356],{"class":75,"line":130},[73,350,351],{"class":79}," window.newvalue ",[73,353,269],{"class":106},[73,355,273],{"class":272},[73,357,276],{"class":79},[73,359,360],{"class":75,"line":136},[73,361,133],{"class":79},[73,363,364],{"class":75,"line":143},[73,365,140],{"emptyLinePlaceholder":139},[73,367,368,370],{"class":75,"line":287},[73,369,146],{"class":83},[73,371,149],{"class":79},[73,373,374,376,378],{"class":75,"line":294},[73,375,80],{"class":79},[73,377,84],{"class":83},[73,379,301],{"class":79},[17,381,382],{},"Basically, it's creating a variable on the global object.",[384,385,391],"iframe",{"height":386,"style":387,"scrolling":388,"title":23,"src":389,"frameBorder":388,"allowTransparency":390,"allowFullScreen":390},265,"width: 100%;","no","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FOYEJwL\u002F?height=265&theme-id=0&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FOYEJwL\u002F'>this\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,393,395],{"id":394},"objects","Objects",[17,397,398,399,401],{},"So what happens when we use ",[21,400,23],{}," inside an object?",[64,403,405],{"className":66,"code":404,"language":68,"meta":69,"style":69},"var c = {\n  name: 'The C object',\n  log: function() {\n    console.log(this);\n  },\n};\n\nc.log();\n",[21,406,407,419,430,443,456,461,465,469],{"__ignoreMap":69},[73,408,409,411,414,416],{"class":75,"line":76},[73,410,169],{"class":106},[73,412,413],{"class":79}," c ",[73,415,269],{"class":106},[73,417,418],{"class":79}," {\n",[73,420,421,424,427],{"class":75,"line":116},[73,422,423],{"class":79},"  name: ",[73,425,426],{"class":272},"'The C object'",[73,428,429],{"class":79},",\n",[73,431,432,435,438,440],{"class":75,"line":130},[73,433,434],{"class":83},"  log",[73,436,437],{"class":79},": ",[73,439,107],{"class":106},[73,441,442],{"class":79},"() {\n",[73,444,445,448,450,452,454],{"class":75,"line":136},[73,446,447],{"class":79},"    console.",[73,449,84],{"class":83},[73,451,87],{"class":79},[73,453,23],{"class":90},[73,455,93],{"class":79},[73,457,458],{"class":75,"line":143},[73,459,460],{"class":79},"  },\n",[73,462,463],{"class":75,"line":287},[73,464,199],{"class":79},[73,466,467],{"class":75,"line":294},[73,468,140],{"emptyLinePlaceholder":139},[73,470,472,475,477],{"class":75,"line":471},8,[73,473,474],{"class":79},"c.",[73,476,84],{"class":83},[73,478,149],{"class":79},[17,480,481],{},[28,482],{"alt":483,"src":484},"object","https:\u002F\u002Fi.imgur.com\u002FvLmOAJ4.png",[17,486,487,488,490,491,493],{},"Now ",[21,489,23],{}," doesn't point to the global object anymore — it points to the object itself. When JavaScript sees a function attached to an object as a method, ",[21,492,23],{}," switches to point at the object. So we can use that to grab data:",[64,495,497],{"className":66,"code":496,"language":68,"meta":69,"style":69},"var c = {\n  name: 'The C object',\n  log: function() {\n    console.log(this.name);\n    console.log(this);\n    console.log(this.name = 'Hello C');\n    console.log(this.name);\n  },\n};\n\nc.log();\n",[21,498,499,509,517,527,540,552,572,584,588,593,598],{"__ignoreMap":69},[73,500,501,503,505,507],{"class":75,"line":76},[73,502,169],{"class":106},[73,504,413],{"class":79},[73,506,269],{"class":106},[73,508,418],{"class":79},[73,510,511,513,515],{"class":75,"line":116},[73,512,423],{"class":79},[73,514,426],{"class":272},[73,516,429],{"class":79},[73,518,519,521,523,525],{"class":75,"line":130},[73,520,434],{"class":83},[73,522,437],{"class":79},[73,524,107],{"class":106},[73,526,442],{"class":79},[73,528,529,531,533,535,537],{"class":75,"line":136},[73,530,447],{"class":79},[73,532,84],{"class":83},[73,534,87],{"class":79},[73,536,23],{"class":90},[73,538,539],{"class":79},".name);\n",[73,541,542,544,546,548,550],{"class":75,"line":143},[73,543,447],{"class":79},[73,545,84],{"class":83},[73,547,87],{"class":79},[73,549,23],{"class":90},[73,551,93],{"class":79},[73,553,554,556,558,560,562,565,567,570],{"class":75,"line":287},[73,555,447],{"class":79},[73,557,84],{"class":83},[73,559,87],{"class":79},[73,561,23],{"class":90},[73,563,564],{"class":79},".name ",[73,566,269],{"class":106},[73,568,569],{"class":272}," 'Hello C'",[73,571,93],{"class":79},[73,573,574,57