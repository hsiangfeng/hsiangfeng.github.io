ironment for the scope chain, the special ",[21,35,36],{},"this"," keyword, and finally one more special keyword: ",[21,39,23],{},".",[17,42,43],{},[44,45],"img",{"alt":23,"src":46},"https:\u002F\u002Fi.imgur.com\u002F5s9wgMJ.png",[17,48,49,50,52],{},"So what's ",[21,51,23],{},"? It holds all the values — basically everything we passed into the function.",[17,54,55],{},[44,56],{"alt":23,"src":57},"https:\u002F\u002Fi.imgur.com\u002F5KbpgLC.png",[17,59,60,62,63,65],{},[21,61,23],{}," is a kind of parameter concept. It's just another name for the variables we passed into the function, which is why you'll sometimes hear them called parameters too. That's a bit vague, so let's look at some code to understand what ",[21,64,23],{}," really is.",[67,68,73],"pre",{"className":69,"code":70,"language":71,"meta":72,"style":72},"language-js shiki shiki-themes github-dark-high-contrast","function greet(firstName, lastName, languaue) {\n  console.log(firstName);\n  console.log(lastName);\n  console.log(languaue);\n}\ngreet();\n","js","",[21,74,75,110,122,132,142,148],{"__ignoreMap":72},[76,77,80,84,88,92,96,99,102,104,107],"span",{"class":78,"line":79},"line",1,[76,81,83],{"class":82},"sWyjQ","function",[76,85,87],{"class":86},"sj_SG"," greet",[76,89,91],{"class":90},"sMAXC","(",[76,93,95],{"class":94},"s_sBn","firstName",[76,97,98],{"class":90},", ",[76,100,101],{"class":94},"lastName",[76,103,98],{"class":90},[76,105,106],{"class":94},"languaue",[76,108,109],{"class":90},") {\n",[76,111,113,116,119],{"class":78,"line":112},2,[76,114,115],{"class":90},"  console.",[76,117,118],{"class":86},"log",[76,120,121],{"class":90},"(firstName);\n",[76,123,125,127,129],{"class":78,"line":124},3,[76,126,115],{"class":90},[76,128,118],{"class":86},[76,130,131],{"class":90},"(lastName);\n",[76,133,135,137,139],{"class":78,"line":134},4,[76,136,115],{"class":90},[76,138,118],{"class":86},[76,140,141],{"class":90},"(languaue);\n",[76,143,145],{"class":78,"line":144},5,[76,146,147],{"class":90},