[{"data":1,"prerenderedAt":617},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjs-weird-world-28-pass-by-value-vs-reference\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjs-weird-world-28-pass-by-value-vs-reference\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjs-weird-world-28-pass-by-value-vs-reference\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjs-weird-world-28-pass-by-value-vs-reference\u002F":592,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjs-weird-world-28-pass-by-value-vs-reference\u002F":601},"\u002Fjsweirdworld\u002F20190519\u002F956767180\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":576,"date":577,"description":578,"extension":579,"lang":580,"meta":581,"navigation":180,"path":582,"readingMinutes":199,"seo":583,"standalone":584,"stem":585,"tags":586,"tldr":589,"updated":577,"url":590,"__hash__":591},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-28-pass-by-value-vs-reference.md","[JS Weird World] No.28 A Quick Reminder: Pass by Value vs Pass by Reference","1000158383",{"type":9,"value":10,"toc":567},"minimark",[11,16,20,24,27,94,107,114,118,128,134,144,148,151,190,210,276,282,291,295,298,339,353,420,426,431,438,443,446,452,456,460,463,532,538,547,551,555,563],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We're going to dig into one of the things you'll bump into constantly in JavaScript — pass by value and pass by reference. It's a really important concept, and if it's fuzzy in your head, it'll come back to bite you later during development and debugging.",[12,21,23],{"id":22},"pass-by-value","Pass by value",[17,25,26],{},"Pass by value is actually pretty simple. Let's understand it through an example.",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var a = 2;\nb = a;\nconsole.log(a);\nconsole.log(b);\n","js","",[35,36,37,60,71,84],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," a ",[38,51,52],{"class":44},"=",[38,54,56],{"class":55},"sCcAr"," 2",[38,58,59],{"class":48},";\n",[38,61,63,66,68],{"class":40,"line":62},2,[38,64,65],{"class":48},"b ",[38,67,52],{"class":44},[38,69,70],{"class":48}," a;\n",[38,72,74,77,81],{"class":40,"line":73},3,[38,75,76],{"class":48},"console.",[38,78,80],{"class":79},"sj_SG","log",[38,82,83],{"class":48},"(a);\n",[38,85,87,89,91],{"class":40,"line":86},4,[38,88,76],{"class":48},[38,90,80],{"class":79},[38,92,93],{"class":48},"(b);\n",[17,95,96,99,100,103,104,106],{},[35,97,98],{},"b"," goes and finds the memory address of ",[35,101,102],{},"a",", then copies that same value into ",[35,105,98],{}," and gets a brand new memory address. That whole process is what we call pass by value.",[17,108,109],{},[110,111],"img",{"alt":112,"src":113},"by value","https:\u002F\u002Fi.imgur.com\u002FzcNW7gc.png",[12,115,117],{"id":116},"pass-by-reference","Pass by reference",[17,119,120,121,124,125,127],{},"This one shows up a lot more often. If you have an object in JavaScript, assigning a variable to that object also gives you a memory address. But when you say ",[35,122,123],{},"b = a",", what you're really saying is \"make these two things the same.\" So ",[35,126,98],{}," does NOT get a new memory address. That's pass by reference.",[17,129,130],{},[110,131],{"alt":132,"src":133},"by reference","https:\u002F\u002Fi.imgur.com\u002FB09t5JT.png",[135,136,137],"blockquote",{},[17,138,139,143],{},[140,141,142],"strong",{},"Note","\nEvery object behaves with pass-by-reference.",[12,145,147],{"id":146},"example-pass-by-value","Example: pass by value",[17,149,150],{},"Let's look at a pass-by-value example first.",[28,152,154],{"className":30,"code":153,"language":32,"meta":33,"style":33},"var a = 3;\nvar b;\n\nb = a;\n",[35,155,156,169,176,182],{"__ignoreMap":33},[38,157,158,160,162,164,167],{"class":40,"line":41},[38,159,45],{"class":44},[38,161,49],{"class":48},[38,163,52],{"class":44},[38,165,166],{"class":55}," 3",[38,168,59],{"class":48},[38,170,171,173],{"class":40,"line":62},[38,172,45],{"class":44},[38,174,175],{"class":48}," b;\n",[38,177,178],{"class":40,"line":73},[38,179,181],{"emptyLinePlaceholder":180},true,"\n",[38,183,184,186,188],{"class":40,"line":86},[38,185,65],{"class":48},[38,187,52],{"class":44},[38,189,70],{"class":48},[17,191,192,193,196,197,200,201,203,204,206,207,209],{},"Here's the key thing to remember: as long as it's not an object, you're dealing with ",[140,194,195],{},"pass by value",". Since ",[35,198,199],{},"3"," is a primitive — just a number — ",[35,202,98],{}," copies the value of ",[35,205,102],{}," and creates a new memory address. So if we do this, it won't affect ",[35,208,98],{}," at all:",[28,211,213],{"className":30,"code":212,"language":32,"meta":33,"style":33},"var a = 3;\nvar b;\n\nb = a;\na = 10;\nconsole.log(a);\nconsole.log(b);\n",[35,214,215,227,233,237,245,258,267],{"__ignoreMap":33},[38,216,217,219,221,223,225],{"class":40,"line":41},[38,218,45],{"class":44},[38,220,49],{"class":48},[38,222,52],{"class":44},[38,224,166],{"class":55},[38,226,59],{"class":48},[38,228,229,231],{"class":40,"line":62},[38,230,45],{"class":44},[38,232,175],{"class":48},[38,234,235],{"class":40,"line":73},[38,236,181],{"emptyLinePlaceholder":180},[38,238,239,241,243],{"class":40,"line":86},[38,240,65],{"class":48},[38,242,52],{"class":44},[38,244,70],{"class":48},[38,246,248,251,253,256],{"class":40,"line":247},5,[38,249,250],{"class":48},"a ",[38,252,52],{"class":44},[38,254,255],{"class":55}," 10",[38,257,59],{"class":48},[38,259,261,263,265],{"class":40,"line":260},6,[38,262,76],{"class":48},[38,264,80],{"class":79},[38,266,83],{"class":48},[38,268,270,272,274],{"class":40,"line":269},7,[38,271,76],{"class":48},[38,273,80],{"class":79},[38,275,93],{"class":48},[17,277,278,279,281],{},"And that's ",[140,280,195],{},".",[283,284,290],"iframe",{"height":285,"style":286,"scrolling":287,"title":112,"src":288,"frameBorder":287,"allowTransparency":289,"allowFullScreen":289},265,"width: 100%;","no","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FjoKOaW\u002F?height=265&theme-id=0&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FjoKOaW\u002F'>by value\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,292,294],{"id":293},"example-pass-by-reference","Example: pass by reference",[17,296,297],{},"First, let's set up an object example.",[28,299,301],{"className":30,"code":300,"language":32,"meta":33,"style":33},"var c = { greeting: 'hi' };\nvar d;\nd = c;\n",[35,302,303,322,329],{"__ignoreMap":33},[38,304,305,307,310,312,315,319],{"class":40,"line":41},[38,306,45],{"class":44},[38,308,309],{"class":48}," c ",[38,311,52],{"class":44},[38,313,314],{"class":48}," { greeting: ",[38,316,318],{"class":317},"sTRMh","'hi'",[38,320,321],{"class":48}," };\n",[38,323,324,326],{"class":40,"line":62},[38,325,45],{"class":44},[38,327,328],{"class":48}," d;\n",[38,330,331,334,336],{"class":40,"line":73},[38,332,333],{"class":48},"d ",[38,335,52],{"class":44},[38,337,338],{"class":48}," c;\n",[17,340,341,342,345,346,348,349,352],{},"What happens when this code runs? ",[35,343,344],{},"d"," knows that what's being assigned is an object, so it doesn't create a new memory address — instead it points ",[35,347,344],{}," at the same memory address as ",[35,350,351],{},"c",". They print the same thing, but under the hood they point to the same memory. So if we do this:",[28,354,356],{"className":30,"code":355,"language":32,"meta":33,"style":33},"var c = { greeting: 'hi' };\nvar d;\nd = c;\nc.greeting = 'hello';\n\nconsole.log(c.greeting);\nconsole.log(d.greeting);\n",[35,357,358,372,378,386,398,402,411],{"__ignoreMap":33},[38,359,360,362,364,366,368,370],{"class":40,"line":41},[38,361,45],{"class":44},[38,363,309],{"class":48},[38,365,52],{"class":44},[38,367,314],{"class":48},[38,369,318],{"class":317},[38,371,321],{"class":48},[38,373,374,376],{"class":40,"line":62},[38,375,45],{"class":44},[38,377,328],{"class":48},[38,379,380,382,384],{"class":40,"line":73},[38,381,333],{"class":48},[38,383,52],{"class":44},[38,385,338],{"class":48},[38,387,388,391,393,396],{"class":40,"line":86},[38,389,390],{"class":48},"c.greeting ",[38,392,52],{"class":44},[38,394,395],{"class":317}," 'hello'",[38,397,59],{"class":48},[38,399,400],{"class":40,"line":247},[38,401,181],{"emptyLinePlaceholder":180},[38,403,404,406,408],{"class":40,"line":260},[38,405,76],{"class":48},[38,407,80],{"class":79},[38,409,410],{"class":48},"(c.greeting);\n",[38,412,413,415,417],{"class":40,"line":269},[38,414,76],{"class":48},[38,416,80],{"class":79},[38,418,419],{"class":48},"(d.greeting);\n",[17,421,422,423,425],{},"We can see ",[35,424,344],{}," changed along with it.",[17,427,428],{},[110,429],{"alt":132,"src":430},"https:\u002F\u002Fi.imgur.com\u002FQicw0Wn.png",[17,432,433,434,437],{},"That's pass by reference, and the ",[35,435,436],{},"c.greeting = 'hello';"," step is what we call mutate.",[17,439,440],{},[110,441],{"alt":132,"src":442},"https:\u002F\u002Fi.imgur.com\u002FHpkw6lw.png",[17,444,445],{},"So when the assignment operator knows you want to change some value, it goes and mutates it.",[17,447,448,449,451],{},"Mutate just means \"change something.\" When we say \"I mutate my object,\" it means I'm going to change it (the object). So here's the thing to take away: no matter which line we make the change on, ",[35,450,344],{}," ends up changed too, because they both point to the same memory.",[283,453,455],{"height":285,"style":286,"scrolling":287,"title":132,"src":454,"frameBorder":287,"allowTransparency":289,"allowFullScreen":289},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FBeVaJX\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FBeVaJX\u002F'>by reference\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,457,459],{"id":458},"the-exception","The exception",[17,461,462],{},"There's one more thing you need to know. The assignment operator can set up a brand new chunk of memory. So if we modify things this way:",[28,464,466],{"className":30,"code":465,"language":32,"meta":33,"style":33},"var c = { greeting: 'hi' };\nvar d;\nd = c;\nc = { greeting: 'hello' };\n\nconsole.log(c);\nconsole.log(d);\n",[35,467,468,482,488,496,510,514,523],{"__ignoreMap":33},[38,469,470,472,474,476,478,480],{"class":40,"line":41},[38,471,45],{"class":44},[38,473,309],{"class":48},[38,475,52],{"class":44},[38,477,314],{"class":48},[38,479,318],{"class":317},[38,481,321],{"class":48},[38,483,484,486],{"class":40,"line":62},[38,485,45],{"class":44},[38,487,328],{"class":48},[38,489,490,492,494],{"class":40,"line":73},[38,491,333],{"class":48},[38,493,52],{"class":44},[38,495,338],{"class":48},[38,497,498,501,503,505,508],{"class":40,"line":86},[38,499,500],{"class":48},"c ",[38,502,52],{"class":44},[38,504,314],{"class":48},[38,506,507],{"class":317},"'hello'",[38,509,321],{"class":48},[38,511,512],{"class":40,"line":247},[38,513,181],{"emptyLinePlaceholder":180},[38,515,516,518,520],{"class":40,"line":260},[38,517,76],{"class":48},[38,519,80],{"class":79},[38,521,522],{"class":48},"(c);\n",[38,524,525,527,529],{"class":40,"line":269},[38,526,76],{"class":48},[38,528,80],{"class":79},[38,530,531],{"class":48},"(d);\n",[17,533,534],{},[110,535],{"alt":536,"src":537},"the exception","https:\u002F\u002Fi.imgur.com\u002FQLcozpH.png",[17,539,540,541,543,544,546],{},"Now ",[35,542,344],{}," and ",[35,545,351],{}," no longer point to the same memory address. That's the special case to watch out for.",[283,548,550],{"height":285,"style":286,"scrolling":287,"title":536,"src":549,"frameBorder":287,"allowTransparency":289,"allowFullScreen":289},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FYbvzeR\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FYbvzeR\u002F'>the exception\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,552,554],{"id":553},"image-source","Image source",[17,556,557],{},[102,558,562],{"href":559,"rel":560},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[561],"nofollow","JavaScript: Understanding the Weird Parts",[564,565,566],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":33,"searchDepth":62,"depth":62,"links":568},[569,570,571,572,573,574,575],{"id":14,"depth":62,"text":15},{"id":22,"depth":62,"text":23},{"id":116,"depth":62,"text":117},{"id":146,"depth":62