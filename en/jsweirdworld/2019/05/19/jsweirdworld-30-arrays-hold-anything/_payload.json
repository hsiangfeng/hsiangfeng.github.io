[{"data":1,"prerenderedAt":635},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-30-arrays-hold-anything\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-30-arrays-hold-anything\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-30-arrays-hold-anything\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-30-arrays-hold-anything\u002F":612,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F19\u002Fjsweirdworld-30-arrays-hold-anything\u002F":621},"\u002Fjsweirdworld\u002F20190519\u002F678282594\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":596,"date":597,"description":598,"extension":599,"lang":600,"meta":601,"navigation":128,"path":602,"readingMinutes":84,"seo":603,"standalone":604,"stem":605,"tags":606,"tldr":609,"updated":597,"url":610,"__hash__":611},"content\u002Fen\u002FJsWeirdWorld\u002Fjsweirdworld-30-arrays-hold-anything.md","[JS Weird World] No.30 Quick Reminder: An Array Can Hold Literally Anything","1000182140",{"type":9,"value":10,"toc":592},"minimark",[11,16,20,56,59,93,96,146,149,155,163,304,307,314,317,439,445,451,569,575,579,588],[12,13,15],"h2",{"id":14},"an-array-can-hold-anything","An array can hold anything",[17,18,19],"p",{},"An array can hold a bunch of stuff, and you can actually create one through a constructor function:",[21,22,27],"pre",{"className":23,"code":24,"language":25,"meta":26,"style":26},"language-js shiki shiki-themes github-dark-high-contrast","var arr = new Array();\n","js","",[28,29,30],"code",{"__ignoreMap":26},[31,32,35,39,43,46,49,53],"span",{"class":33,"line":34},"line",1,[31,36,38],{"class":37},"sWyjQ","var",[31,40,42],{"class":41},"sMAXC"," arr ",[31,44,45],{"class":37},"=",[31,47,48],{"class":37}," new",[31,50,52],{"class":51},"sj_SG"," Array",[31,54,55],{"class":41},"();\n",[17,57,58],{},"But honestly nobody really declares arrays this way. It's not intuitive, and it's more typing. So the version you'll see way more often is the array literal:",[21,60,62],{"className":23,"code":61,"language":25,"meta":26,"style":26},"var arr = [1, 2, 3];\n",[28,63,64],{"__ignoreMap":26},[31,65,66,68,70,72,75,79,82,85,87,90],{"class":33,"line":34},[31,67,38],{"class":37},[31,69,42],{"class":41},[31,71,45],{"class":37},[31,73,74],{"class":41}," [",[31,76,78],{"class":77},"sCcAr","1",[31,80,81],{"class":41},", ",[31,83,84],{"class":77},"2",[31,86,81],{"class":41},[31,88,89],{"class":77},"3",[31,91,92],{"class":41},"];\n",[17,94,95],{},"In JavaScript arrays are zero-based, so you grab values like this:",[21,97,99],{"className":23,"code":98,"language":25,"meta":26,"style":26},"var arr = [1, 2, 3];\n\narr[0]; \u002F\u002F note: the brackets are an operator\n",[28,100,101,123,130],{"__ignoreMap":26},[31,102,103,105,107,109,111,113,115,117,119,121],{"class":33,"line":34},[31,104,38],{"class":37},[31,106,42],{"class":41},[31,108,45],{"class":37},[31,110,74],{"class":41},[31,112,78],{"class":77},[31,114,81],{"class":41},[31,116,84],{"class":77},[31,118,81],{"class":41},[31,120,89],{"class":77},[31,122,92],{"class":41},[31,124,126],{"class":33,"line":125},2,[31,127,129],{"emptyLinePlaceholder":128},true,"\n",[31,131,133,136,139,142],{"class":33,"line":132},3,[31,134,135],{"class":41},"arr[",[31,137,138],{"class":77},"0",[31,140,141],{"class":41},"]; ",[31,143,145],{"class":144},"sQrFR","\u002F\u002F note: the brackets are an operator\n",[17,147,148],{},"Pretty standard array stuff — if you've written any other language, you already know this. But the course made one point I want to flag.",[150,151,152],"blockquote",{},[17,153,154],{},"JavaScript is a dynamically typed language.",[17,156,157,158,162],{},"So what does that mean here? In most languages an array can only hold a series of values of the ",[159,160,161],"em",{},"same"," type — an all-number array, an all-string array, an all-object array, and so on. Ja