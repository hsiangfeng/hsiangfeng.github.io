s show.",[17,512,513],{},[313,514],{"alt":515,"src":516},"i ends up at 3 in memory","https:\u002F\u002Fi.imgur.com\u002FXHEdsav.png",[17,518,519,520,522,523,525,526,528],{},"These functions live inside a closure. Inside each anonymous function there's no ",[35,521,484],{}," of its own, so it walks up the scope chain to grab ",[35,524,484],{}," — and ",[35,527,484],{}," is currently 3. That's the whole reason you always get 3.",[17,530,531],{},[313,532],{"alt":533,"src":534},"scope chain pointing to i = 3","https:\u002F\u002Fi.imgur.com\u002F4QZC4cg.png",[17,536,537],{},"But what if we actually want it to log 0...1...2? Then we do this.",[28,539,541],{"className":30,"code":540,"language":32,"meta":33,"style":33},"function buildFunction () {\n  var arr = [];\n  for(var i = 0; i \u003C 3; i++) {\n    let j = i;\n    arr.push(\n      function () {\n        console.log(j);\n      }\n    );\n  }\n  return arr;\n}\n\nvar fs = buildFunction();\nconsole.log(fs);\nfs[0]()\nfs[1]()\nfs[2]()\n",[35,542,543,551,561,587,600,608,614,623,627,631,635,641,645,649,661,669,677,685],{"__ignoreMap":33},[38,544,545,547,549],{"class":40,"line":41},[38,546,45],{"class":44},[38,548,49],{"class":48},[38,550,53],{"class":52},[38,552,553,555,557,559],{"class":40,"line":56},[38,554,59],{"class":44},[38,556,62],{"class":52},[38,558,65],{"class":44},[38,560,68],{"class":52},[38,562,563,565,567,569,571,573,575,577,579,581,583,585],{"class":40,"line":71},[38,564,74],{"class":44},[38,566,77],{"class":52},[38,568,80],{"class":44},[38,570,83],{"class":52},[38,572,65],{"class":44},[38,574,89],{"class":88},[38,576,92],{"class":52},[38,578,95],{"class":44},[38,580,98],{"class":88},[38,582,101],{"class":52},[38,584,104],{"class":44},[38,586,107],{"class":52},[38,588,589,592,595,597],{"class":40,"line":110},[38,590,591],{"class":44},"    let",[38,593,594],{"class":52}," j ",[38,596,65],{"class":44},[38,598,599],{"class":52}," i;\n",[38,601,602,604,606],{"class":40,"line":122},[38,603,113],{"class":52},[38,6