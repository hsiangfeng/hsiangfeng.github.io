[{"data":1,"prerenderedAt":441},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjsweirdworld-41-closures-and-callbacks\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjsweirdworld-41-closures-and-callbacks\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjsweirdworld-41-closures-and-callbacks\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjsweirdworld-41-closures-and-callbacks\u002F":417,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjsweirdworld-41-closures-and-callbacks\u002F":426},"\u002Fjsweirdworld\u002F20190520\u002F930615887\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":401,"date":402,"description":403,"extension":404,"lang":405,"meta":406,"navigation":197,"path":407,"readingMinutes":408,"seo":409,"standalone":410,"stem":411,"tags":412,"tldr":414,"updated":402,"url":415,"__hash__":416},"content\u002Fen\u002FJsWeirdWorld\u002Fjsweirdworld-41-closures-and-callbacks.md","[JS Weird World] No.41 Closures and Callbacks","1000277168",{"type":9,"value":10,"toc":396},"minimark",[11,16,25,29,32,121,128,135,172,175,182,185,188,335,340,355,360,370,379,383,392],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24],"p",{},"We've already covered closures, first-class functions, and all that — and honestly, just like the course instructor warned, my brain is close to melting at this point. So this chapter just builds on the previous one. The thing is, if you've ever used ",[21,22,23],"code",{},"setTimeout"," or jQuery in JavaScript, you've already been using closures without even realising it. So in this chapter let's talk about closures and callbacks.",[12,26,28],{"id":27},"closures-and-callbacks","Closures and Callbacks",[17,30,31],{},"First, let's build a simple little function example:",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","function sayHiLater() {\n  var greeting = 'Hi';\n  setTimeout(function() {\n    console.log(greeting);\n  }, 3000);\n}\n","js","",[21,40,41,58,77,90,102,115],{"__ignoreMap":38},[42,43,46,50,54],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sWyjQ","function",[42,51,53],{"class":52},"sj_SG"," sayHiLater",[42,55,57],{"class":56},"sMAXC","() {\n",[42,59,61,64,67,70,74],{"class":44,"line":60},2,[42,62,63],{"class":48},"  var",[42,65,66],{"class":56}," greeting ",[42,68,69],{"class":48},"=",[42,71,73],{"class":72},"sTRMh"," 'Hi'",[42,75,76],{"class":56},";\n",[42,78,80,83,86,88],{"class":44,"line":79},3,[42,81,82],{"class":52},"  setTimeout",[42,84,85],{"class":56},"(",[42,87,49],{"class":48},[42,89,57],{"class":56},[42,91,93,96,99],{"class":44,"line":92},4,[42,94,95],{"class":56},"    console.",[42,97,98],{"class":52},"log",[42,100,101],{"class":56},"(greeting);\n",[42,103,105,108,112],{"class":44,"line":104},5,[42,106,107],{"class":56},"  }, ",[42,109,111],{"class":110},"sCcAr","3000",[42,113,114],{"class":56},");\n",[42,116,118],{"class":44,"line":117},6,[42,119,120],{"class":56},"}\n",[17,122,123,124,127],{},"We all know this one prints ",[21,125,126],{},"Hi"," after three seconds. And in that process, we've actually already used a function expression and a closure.",[17,129,130,131,134],{},"jQuery is the same — take a ",[21,132,133],{},"click"," event, for example.",[33,136,138],{"className":35,"code":137,"language":37,"meta":38,"style":38},"$('button').click(function () {\n  ...\n});\n",[21,139,140,162,167],{"__ignoreMap":38},[42,141,142,145,147,150,153,155,157,159],{"class":44,"line":45},[42,143,144],{"class":52},"$",[42,146,85],{"class":56},[42,148,149],{"class":72},"'button'",[42,151,152],{"class":56},").",[42,154,133],{"class":52},[42,156,85],{"class":56},[42,158,49],{"class":48},[42,160,161],{"class":56}," () {\n",[42,163,164],{"class":44,"line":60},[42,165,166],{"class":48},"  ...\n",[42,168,169],{"class":44,"line":79},[42,170,171],{"class":56},"});\n",[17,173,174],{},"This is also a closure. So from these two examples, chances are you've already used closures, function expressions, and first-class functions without thinking about it.",[17,176,177],{},[178,179],"img",{"alt":180,"src":181},"Closure","https:\u002F\u002Fi.imgur.com\u002F7daxcOm.png",[17,183,184],{},"A callback function is this: when some function finishes running the function you handed it, it then calls back the function you gave it. In plain English — the function you hand over to be run once some other function is done is what we call a callback.",[17,186,187],{},"Let's look at an example.",[33,189,191],{"className":35,"code":190,"language":37,"meta":38,"style":38},"\nfunction tellMeWhenDone(callback) {\n  var a = 1000;\n  var b = 2000;\n  \u002F\u002F when it's done, call the other function\n  callback();\n}\n\ntellMeWhenDone(function() {\n  console.log('Done!');\n})\n\ntellMeWhenDone(function() {\n  console.log('Still working on it');\n})\n",[21,192,193,199,215,229,243,249,257,262,267,279,294,300,305,316,330],{"__ignoreMap":38},[42,194,195],{"class":44,"line":45},[42,196,198],{"emptyLinePlaceholder":197},true,"\n",[42,200,201,203,206,208,212],{"class":44,"line":60},[42,202,49],{"class":48},[42,204,205],{"class":52}," tellMeWhenDone",[42,207,85],{"class":56},[42,209,211],{"class":210},"s_sBn","callback",[42,213,214],{"class":56},") {\n",[42,216,217,219,222,224,227],{"class":44,"line":79},[42,218,63],{"class":48},[42,220,221],{"class":56}," a ",[42,223,69],{"class":48},[42,225,226],{"class":110}," 1000",[42,228,76],{"class":56},[42,230,231,233,236,238,241],{"class":44,"line":92},[42,232,63],{"class":48},[42,234,235],{"class":56}," b ",[42,237,69],{"class":48},[42,239,240],{"class":110}," 2000",[42,242,76],{"class":56},[42,244,245],{"class":44,"line":104},[42,246,248],{"class":247},"sQrFR","  \u002F\u002F when it's done, call the other function\n",[42,250,251,254],{"class":44,"line":117},[42,252,253],{"class":52},"  callback",[42,255,256],{"class":56},"();\n",[42,258,260],{"class":44,"line":259},7,[42,261,120],{"class":56},[42,263,265],{"class":44,"line":264},8,[42,266,198],{"emptyLinePlaceholder":197},[42,268,270,273,275,277],{"class":44,"line":269},9,[42,271,272],{"class":52},"tellMeWhenDone",[42,274,85],{"class":56},[42,276,49],{"class":48},[42,278,57],{"class":56},[42,280,282,285,287,289,292],{"class":44,"line":281},10,[42,283,284],{"class":56},"  console.",[42,286,98],{"class":52},[42,288,85],{"class":56},[42,290,291],{"class":72},"'Done!'",[42,293,114],{"class":56},[42,295,297],{"class":44,"line":296},11,[42,298,299],{"class":56},"})\n",[42,301,303],{"class":44,"line":302},12,[42,304,198],{"emptyLinePlaceholder":197},[42,306,308,310,312,314],{"class":44,"line":307},13,[42,309,272],{"class":52},[42,311,85],{"class":56},[42,313,49],{"class":48},[42,315,57],{"class":56},[42,317,319,321,323,325,328],{"class":44,"line":318},14,[42,320,284],{"class":56},[42,322,98],{"class":52},[42,324,85],{"class":56},[42,326,327],{"class":72},"'Still working on it'",[42,329,114],{"class":56},[42,331,333],{"class":44,"line":332},15,[42,334,299],{"class":56},[17,336,337],{},[178,338],{"alt":211,"src":339},"https:\u002F\u002Fi.imgur.com\u002FHEkHNxy.png",[17,341,342,343,345,346,348,349,351,352,354],{},"You can see we called ",[21,344,272],{}," twice, passing a ",[21,347,49],{}," in as the ",[21,350,211],{}," parameter. Once ",[21,353,272],{}," finishes, it calls the function we just passed in. That's a callback.",[17,356,357],{},[178,358],{"alt":211,"src":359},"https:\u002F\u002Fi.imgur.com\u002Fzu1fZPA.png",[361,362,363],"blockquote",{},[17,364,365,369],{},[366,367,368],"strong",{},"Note","\nBasically: once a function finishes running, it then runs another one.",[371,372,378],"iframe",{"height":373,"style":374,"scrolling":375,"title":211,"src":376,"frameBorder":375,"allowTransparency":377,"allowFullScreen":377},265,"width: 100%;","no","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002F