[{"data":1,"prerenderedAt":630},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-38-closures-part-1\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-38-closures-part-1\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-38-closures-part-1\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-38-closures-part-1\u002F":605,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-38-closures-part-1\u002F":614},"\u002Fjsweirdworld\u002F20190520\u002F2896946513\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":588,"date":589,"description":590,"extension":591,"lang":592,"meta":593,"navigation":179,"path":594,"readingMinutes":595,"seo":596,"standalone":597,"stem":598,"tags":599,"tldr":602,"updated":589,"url":603,"__hash__":604},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-38-closures-part-1.md","[JS Weird World] No.38 Closures (Part 1)","1000245492",{"type":9,"value":10,"toc":583},"minimark",[11,16,20,24,27,114,121,201,208,217,220,304,310,322,412,417,423,432,437,449,454,457,463,470,475,481,525,535,541,544,550,553,558,566,570,579],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"This chapter is where we start digging into one of the scariest, most notorious things in JavaScript — closures (yes, the title's typo aside). Since we're trying to really understand this language, closures are a super important concept. A lot of people get confused by them, or honestly just hate them, because they're genuinely hard to grasp.",[12,21,23],{"id":22},"closures","Closures",[17,25,26],{},"To show off what closures can do, we first need to write a bit of code, then work backwards to understand the mechanism and why it's so handy.",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","function greet(whattosay) {\n  return function(name) {\n    console.log(whattosay + ' ' + name);\n  }\n}\n","js","",[35,36,37,61,77,102,108],"code",{"__ignoreMap":33},[38,39,42,46,50,54,58],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","function",[38,47,49],{"class":48},"sj_SG"," greet",[38,51,53],{"class":52},"sMAXC","(",[38,55,57],{"class":56},"s_sBn","whattosay",[38,59,60],{"class":52},") {\n",[38,62,64,67,70,72,75],{"class":40,"line":63},2,[38,65,66],{"class":44},"  return",[38,68,69],{"class":44}," function",[38,71,53],{"class":52},[38,73,74],{"class":56},"name",[38,76,60],{"class":52},[38,78,80,83,86,89,92,96,99],{"class":40,"line":79},3,[38,81,82],{"class":52},"    console.",[38,84,85],{"class":48},"log",[38,87,88],{"class":52},"(whattosay ",[38,90,91],{"class":44},"+",[38,93,95],{"class":94},"sTRMh"," ' '",[38,97,98],{"class":44}," +",[38,100,101],{"class":52}," name);\n",[38,103,105],{"class":40,"line":104},4,[38,106,107],{"class":52},"  }\n",[38,109,111],{"class":40,"line":110},5,[38,112,113],{"class":52},"}\n",[17,115,116,117,120],{},"At this point you might be wondering — how do I call the function that's sitting inside the ",[35,118,119],{},"return","? Turns out it's this simple:",[28,122,124],{"className":30,"code":123,"language":32,"meta":33,"style":33},"function greet(whattosay) {\n  return function(name) {\n    console.log(whattosay + ' ' + name);\n  }\n}\n\ngreet('Hi')('Tomy');\n",[35,125,126,138,150,166,170,174,181],{"__ignoreMap":33},[38,127,128,130,132,134,136],{"class":40,"line":41},[38,129,45],{"class":44},[38,131,49],{"class":48},[38,133,53],{"class":52},[38,135,57],{"class":56},[38,137,60],{"class":52},[38,139,140,142,144,146,148],{"class":40,"line":63},[38,141,66],{"class":44},[38,143,69],{"class":44},[38,145,53],{"class":52},[38,147,74],{"class":56},[38,149,60],{"class":52},[38,151,152,154,156,158,160,162,164],{"class":40,"line":79},[38,153,82],{"class":52},[38,155,85],{"class":48},[38,157,88],{"class":52},[38,159,91],{"class":44},[38,161,95],{"class":94},[38,163,98],{"class":44},[38,165,101],{"class":52},[38,167,168],{"class":40,"line":104},[38,169,107],{"class":52},[38,171,172],{"class":40,"line":110},[38,173,113],{"class":52},[38,175,177],{"class":40,"line":176},6,[38,178,180],{"emptyLinePlaceholder":179},true,"\n",[38,182,184,187,189,192,195,198],{"class":40,"line":183},7,[38,185,186],{"class":48},"greet",[38,188,53],{"class":52},[38,190,191],{"class":94},"'Hi'",[38,193,194],{"class":52},")(",[38,196,197],{"class":94},"'Tomy'",[38,199,200],{"class":52},");\n",[17,202,203],{},[204,205],"img",{"alt":206,"src":207},"return function","https:\u002F\u002Fi.imgur.com\u002F3ThekIe.png",[17,209,210,211,213,214,216],{},"Even though the inner function doesn't have a ",[35,212,57],{}," variable of its own, the scope chain lets it reach out to the outer environment and find ",[35,215,57],{},". So far this still feels pretty reasonable.",[17,218,219],{},"But the next example is where things get a little weird:",[28,221,223],{"className":30,"code":222,"language":32,"meta":33,"style":33},"function greet(whattosay) {\n  return function(name) {\n    console.log(whattosay + ' ' + name);\n  }\n}\nvar sayHi = greet('Hi');\nsayHi('Tony');\n",[35,224,225,237,249,265,269,273,292],{"__ignoreMap":33},[38,226,227,229,231,233,235],{"class":40,"line":41},[38,228,45],{"class":44},[38,230,49],{"class":48},[38,232,53],{"class":52},[38,234,57],{"class":56},[38,236,60],{"class":52},[38,238,239,241,243,245,247],{"class":40,"line":63},[38,240,66],{"class":44},[38,242,69],{"class":44},[38,244,53],{"class":52},[38,246,74],{"class":56},[38,248,60],{"class":52},[38,250,251,253,255,257,259,261,263],{"class":40,"line":79},[38,252,82],{"class":52},[38,254,85],{"class":48},[38,256,88],{"class":52},[38,258,91],{"class":44},[38,260,95],{"class":94},[38,262,98],{"class":44},[38,264,101],{"class":52},[38,266,267],{"class":40,"line":104},[38,268,107],{"class":52},[38,270,271],{"class":40,"line":110},[38,272,113],{"class":52},[38,274,275,278,281,284,286,288,290],{"class":40,"line":176},[38,276,277],{"class":44},"var",[38,279,280],{"class":52}," sayHi ",[38,282,283],{"class":44},"=",[38,285,49],{"class":48},[38,287,53],{"class":52},[38,289,191],{"class":94},[38,291,200],{"class":52},[38,293,294,297,299,302],{"class":40,"line":183},[38,295,296],{"class":48},"sayHi",[38,298,53],{"class":52},[38,300,301],{"class":94},"'Tony'",[38,303,200],{"class":52},[17,305,306],{},[204,307],{"alt":308,"src":309},"closure","https:\u002F\u002Fi.imgur.com\u002Fjri5EvX.png",[17,311,312,313,315,316,318,319,321],{},"Why does ",[35,314,296],{}," still know what ",[35,317,57],{}," is? You might be asking why I'm even making a fuss about this — so let's just log ",[35,320,296],{}," directly and you'll see why:",[28,323,325],{"className":30,"code":324,"language":32,"meta":33,"style":33},"function greet(whattosay) {\n  return function(name) {\n    console.log(whattosay + ' ' + name);\n  }\n}\nvar sayHi = greet('Hi');\nconsole.log(sayHi);\nsayHi('Tony');\n",[35,326,327,339,351,367,371,375,391,401],{"__ignoreMap":33},[38,328,329,331,333,335,337],{"class":40,"line":41},[38,330,45],{"class":44},[38,332,49],{"class":48},[38,334,53],{"class":52},[38,336,57],{"class":56},[38,338,60],{"class":52},[38,340,341,343,345,347,349],{"class":40,"line":63},[38,342,66],{"class":44},[38,344,69],{"class":44},[38,346,53],{"class":52},[38,348,74],{"class":56},[38,350,60],{"class":52},[38,352,353,355,357,359,361,363,365],{"class":40,"line":79},[38,354,82],{"class":52},[38,356,85],{"class":48},[38,358,88],{"class":52},[38,360,91],{"class":44},[38,362,95],{"class":94},[38,364,98],{"class":44},[38,366,101],{"class":52},[38,368,369],{"class":40,"line":104},[38,370,107],{"class":52},[38,372,373],{"class":40,"line":110},[38,374,113],{"class":52},[38,376,377,379,381,383,385,387,389],{"class":40,"line":176},[38,378,277],{"class":44},[38,380,280],{"class":52},[38,382,283],{"class":44},[38,384,49],{"class":48},[38,386,53],{"class":52},[38,388,191],{"class":94},[38,390,200],{"class":52},[38,392,393,396,398],{"class":40,"line":183},[38,394,395],{"class":52},"console.",[38,397,85],{"class":48},[38,399,400],{"class":52},"(sayHi);\n",[38,402,404,406,408,410],{"class":40,"line":403},8,[38,405,296],{"class":48},[38,407,53],{"class":52},[38,409,301],{"class":94},[38,411,200],{"class":52},[17,413,414],{},[204,415],{"alt":296,"src":416},"https:\u002F\u002Fi.imgur.com\u002Fyz6Vdih.png",[17,418,419,420,422],{},"All we see is the inner function — there's no sign of the ",[35,421,57],{}," variable anywhere. So how on earth does it find it?",[17,424,425,426,428,429,431],{},"First, when ",[35,427,186],{}," runs, an execution context gets created, and the ",[35,430,57],{}," variable gets passed into that context.",[17,433,434],{},[204,435],{"alt":186,"src":436},"https:\u002F\u002Fi.imgur.com\u002FE4WCefp.png",[17,438,439,440,442,443,445,446,448],{},"Then once ",[35,441,186],{}," finishes running, it returns a function object — so ",[35,444,186],{}," itself leaves the execution stack, but it leaves the ",[35,447,57],{}," variable behind.",[17,450,451],{},[204,452],{"alt":57,"src":453},"https:\u002F\u002Fi.imgur.com\u002FPUgimZc.png",[17,455,456],{},"But every execution context has its own chunk of memory. So when that execution context disappears, what happens to its memory?",[458,459,460],"blockquote",{},[17,461,462],{},"Normally it gets cleared out — that's what we call garbage collection.",[17,464,465,466,469],{},"But here's the thing: even after the execution context ends, the memory still sits there. The context is gone, yet the variable still exists somewhere. So we're back in the global environment, and we start running ",[35,467,468],{},"sayHi('Tony');",".",[17,471,472],{},[204,473],{"alt":296,"src":474},"https:\u002F\u002Fi.imgur.com\u002Fxbm7B7N.png",[17,476,477,478,480],{},"At this point ",[35,479,468],{}," is an anonymous function, roughly like this:",[28,482,484],{"className":30,"code":483,"language":32,"meta":33,"style":33},"var sayHi = function(name) {\n  console.log(whattosay + ' ' + name);\n}\n",[35,485,486,504,521],{"__ignoreMap":33},[38,487,488,490,493,496,498,500,502],{"class":40,"line":41},[38,489,277],{"class":44},[38,491,492],{"class":48}," sayHi",[38,494,495],{"class":44}," =",[38,497,69],{"class":44},[38,499,53],{"class":52},[38,501,74],{"class":56},[38,503,60],{"class":52},[38,505,506,509,511,513,515,517,519],{"class":40,"line":63},[38,507,508],{"class":52},"  console.",[38,510,85],{"class":48},[38,512,88],{"class":52},[38,514,91],{"class":44},[38,516,95],{"class":94},[38,518,98],{"class":44},[38,520,101],{"class":52},[38,522,523],{"class":40,"line":79},[38,524,113],{"class":52},[17,526,527,528,531,532,534],{},"When we run that anonymous function, we know it'll hit ",[35,529,530],{},"console.log(whattosay + ' ' + name);",". But notice there's no ",[35,533,57],{}," variable inside it — so JavaScript heads out to the outer environment to look for it. That's the scope chain again.",[17,536,537],{},[204,538],{"alt":539,"src":540},"scope chain","https:\u002F\u002Fi.imgur.com\u002FQfmSs2H.png",[17,542,543],{},"So as the course explains, to make sure we never come up empty-handed, JavaScript forms a kind of box that wraps everything up and seals it in, guaranteeing we can still find what we need.",[17,545,546],{},[204,547],{"alt":548,"src":549},"the box","https:\u002F\u002Fi.imgur.com\u002F6Tf0V6D.png",[17,551,552],{},"And that behavior is exactly what we call a closure.",[17,554,555],{},[204,556],{"alt":308,"src":557},"https:\u002F\u002Fi.imgur.com\u002Fn0JFpW3.png",[17,559,560,561,565],{},"A closure is just one of JavaScript's features that makes sure we can always find the thing we're after. It has nothing directly to do with ",[562,563,564],"em",{},"when"," we call the function.",[12,567,569],{"id":568},"image-source","Image Source",[17,571,572],{},[573,574,578],"a",{"href":575,"rel":576},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[577],"nofollow","JavaScript: Understanding the Weird Parts",[580,581,582],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":33,"searchDepth":63,"depth":63,"links":584},[585,586,587],{"id":14,"depth":63,"text":15},{"id":22,"depth":63,"text":23},{"id":568,"depth":63,"text":569},"JsWeirdWorld","2019-05-20 14:22:00","This chapter kicks off one of the scariest, most notorious topics in JavaScript — closures. If we want to really understand this language, closures are a must-know concept. A lot of people get confused by closures, or honestly just hate them, because they're genuinely hard to wrap your head around. In this post we walk through what's actually happening under the hood.","md","en",{},"\u002Fen\u002Fjsweirdworld\u002Fjs-weird-world-38-closures-part-1","3",{"title":6,"description":590},false,"en\u002FJsWeirdWorld\u002Fjs-weird-world-38-closures-part-1",[600,601],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分",null,"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-38-closures-part-1\u002F","TH1WTGliSuF9BDr__MRBE0W0UbKBaCDV_Mgy3Y4bVCw",{"newer":606,"older":610},{"url":607,"title":608,"date":609},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjs-weird-world-39-closures-loop-variable\u002F","[JS Weird World] No.39 Closures, Part 2: Why Your Loop Always Logs the Same Number","2019-05-20 15:45:00",{"url":611,"title":612,"date":613},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F20\u002Fjsweirdworld-37-iife-safe-code\u002F","[JS Weird World] No.37 A Framework Tip: IIFEs and Safe Code","2019-05-20 13:49:00",[615,620,625],{"url":616,"title":617,"date":618,"readingMinutes":619},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F","[JS Weird World] Bonus: Closures, One More Time","2019-05-27 13:50:04","5",{"url":621,"title":622,"date":623,"readingMinutes":624},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F25\u002Fjs-weird-world-68-the-end-is-a-new-beginning\u002F","[JS Weird World] No.68 Wrapping Up the Weird Parts of JavaScript","2019-05-25 16:36:00","1",{"url":626,"title":627,"date":628,"readingMinutes":629},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F25\u002Fjs-weird-world-67-adding-jquery-support\u002F","[JS Weird World] No.67 Adding jQuery Support to Our Mini Framework","2019-05-25 16:19:00","2",1784020365596]