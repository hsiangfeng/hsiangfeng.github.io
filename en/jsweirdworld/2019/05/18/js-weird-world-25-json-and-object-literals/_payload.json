46],"span",{"class":33,"line":34},"line",1,[31,36,38],{"class":37},"sWyjQ","var",[31,40,42],{"class":41},"sMAXC"," objectLiteral ",[31,44,45],{"class":37},"=",[31,47,48],{"class":41}," {\n",[31,50,52,55,59],{"class":33,"line":51},2,[31,53,54],{"class":41}," firstname: ",[31,56,58],{"class":57},"sTRMh","'mary'",[31,60,61],{"class":41},",\n",[31,63,65,68,72],{"class":33,"line":64},3,[31,66,67],{"class":41}," isAProgrammer: ",[31,69,71],{"class":70},"sCcAr","true",[31,73,61],{"class":41},[31,75,77],{"class":33,"line":76},4,[31,78,79],{"class":41},"};\n",[31,81,83,86,90],{"class":33,"line":82},5,[31,84,85],{"class":41},"console.",[31,87,89],{"class":88},"sj_SG","log",[31,91,92],{"class":41},"(objectLiteral);\n",[17,94,95],{},"Back in the day, data was usually sent in a format that looked something like this:",[21,97,101],{"className":98,"code":99,"language":100,"meta":26,"style":26},"language-xml shiki shiki-themes github-dark-high-contrast","\u003Cobject>\n \u003Cfirstname>mary\u003C\u002Ffirstname>\n \u003CisAProgrammer>true\u003C\u002FisAProgrammer>\n\u003C\u002Fobject>\n","xml",[28,102,103,115,130,144],{"__ignoreMap":26},[31,104,105,108,112],{"class":33,"line":34},[31,106,107],{"class":41},"\u003C",[31,109,111],{"class":110},"sKpQp","object",[31,113,114],{"class":41},">\n",[31,116,117,120,123,126,128],{"class":33,"line":51},[31,118,119],{"class":41}," \u003C",[31,121,122],{"class":110},"firstname",[31,124,125],{"class":41},">mary\u003C\u002F",[31,127,122],{"class":110},[31,129,114],{"class":41},[31,131,132,134,137,140,142],{"class":33,"line":64},[31,133,119],{"class":41},[31,135,136],{"class":110},"isAProgrammer",[31,138,139],{"class":41},">true\u003C\u002F",[31,141,136],{"class":110},[31,143,114],{"class":41},[31,145,146,149,151],{"class":33,"line":76},[31,147,148],{"class":41},"\u003C\u002F",[31,150,111],{"class":110},[31,152,114],{"class":41},[17,154,155],{},"The problem is, once the data starts to grow, this gets really inefficient. The file gets huge because it's packed with unnecessary symbols and a ton of repeated tags, and all of that hurts speed. That's why people came up with a leaner approach (JSON):",[21,157,159],{"className":23,"code":158,"language":25,"meta":26,"style":26},"{\n firstname: 'mary',\n isAProgrammer: true,\n};\n",[28,160,161,166,179,190],{"__ignoreMap":26},[31,162,163],{"class":33,"line":34},[31,164,165],{"class":41},"{\n",[31,167,168,172,175,177],{"class":33,"line":51},[31,169,171],{"class":170},"s_sBn"," firstname",[31,173,174],{"class":41},": ",[31,176,58],{"class":57},[31,178,61],{"class":41},[31,180,181,184,186,188],{"class":33,"line":64},[31,182,183],{"class":170}," isAProgrammer",[31,185,174],{"class":41},[31,187,71],{"class":70},[31,189,61],{"class":41},[31,191,192],{"class":33,"line":76},[31,193,79],{"class":41},[17,195,196,197,201],{},"That's the reason we now use JSON to send and receive data. But JSON's format is ",[198,199,200],"strong",{},"a little bit different"," — for one, the keys have to be wrapped in quotes:",[21,203,207],{"className":204,"code":205,"language":206,"meta":26,"style":26},"language-json shiki shiki-themes github-dark-high-contrast","{\n 'firstname': 'mary',\n 'isAProgrammer': true,\n};\n","json",[28,208,209,213,225,236],{"__ignoreMap":26},[31,210,211],{"class":33,"line":34},[31,212,165],{"class":41},[31,214,215,219,221,223],{"class":33,"line":51},[31,216,218],{"class":217},"szH_Z"," 'firstname'",[31,220,174],{"class":41},[31,222,58],{"class":217},[31,224,61],{"class":41},[31,226,227,230,232,234],{"class":33,"line":64},[31,228,229],{"class":217}," 'isAProgrammer'",[31,231,174],{"class":41},[31,233,71],{"class":70},[31,235,61],{"class":41},[31,237,238],{"class":33,"line":76},[31,239,79],{"class":41},[17,241,242],{},"Here's the thing the course points out: JSON syntax is valid object literal syntax, but not all object literal syntax is valid JSON, because JSON is a stricter format. So JSON isn't actually part of JavaScript — but it's super popular in JavaScript, so JavaScript gives us two methods to convert between JSON and object literals.",[17,244,245,246,249],{},"For example, to turn an object literal into JSON, use ",[28,247,248],{},"JSON.stringify()",":",[21,251,253],{"className":23,"code":252,"language":25,"meta":26,"style":26},"var objectLiteral = {\n firstname: 'mary',\n isAProgrammer: true,\n};\nconsole.log(JSON.stringify(objectLiteral));\n",[28,254,255,265,273,281,285],{"__ignoreMap":26},[31,256,257,259,261,263],{"class":33,"line":34},[31,258,38],{"class":37},[31,260,42],{"class":41},[31,262,45],{"class":37},[31,264,48],{"class":41},[31,266,267,269,271],{"class":33,"line":51},[31,268,54],{"class":41},[31,270,58],{"class":57},[31,272,61],{"class":41},[31,274,275,277,279],{"class":33,"line":64},[31,276,67],{"class":41},[31,278,71],{"class":70},[31,280,61],{"class":41},[31,282,283],{"class":33,"line":76},[31,284,79],{"class":41},[31,286,287,289,291,294,297,300,303],{"class":33,"line":82},[31,288,85],{"class":41},[31,290,89],{"class":88},[31,292,293],{"class":41},"(",[31,295,296],{"class":70},"JSON",[31,298,299],{"class":41},".",[31,301,302],{"class":88},"stringify",[31,304,305],{"class":41},"(objectLiteral));\n",[17,307,308,310],{},[28,309,248],{}," adds quotes around the object literal's keys:",[21,312,314],{"className":204,"code":313,"language":206,"meta":26,"style":26},"'{\"firstname\": \"mary\", \"isAProgrammer\": true}'\n",[28,315,316],{"__ignoreMap":26},[31,317,318,321,324,326,329,332,335,337,339],{"class":33,"line":34},[31,319,320],{"class":41},"'{",[31,322,323],{"class":110},"\"firstname\"",[31,325,174],{"class":41},[31,327,328],{"class":57},"\"mary\"",[31,330,331],{"class":41},", ",[31,333,334],{"class":110},"\"isAProgrammer\"",[31,336,174],{"class":41},[31,338,71],{"class":70},[31,340,341],{"class":41},"}'\n",[17,343,344],{},[345,346],"img",{"alt":347,"src":348},"JSON stringify","https:\u002F\u002Fi.imgur.com\u002FXw6Qvcm.png",[17,350,351,352,249],{},"And to go the other way — JSON into an object literal — use ",[