[{"data":1,"prerenderedAt":903},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F18\u002Fjsweirdworld-24-faking-namespaces-with-objects\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F18\u002Fjsweirdworld-24-faking-namespaces-with-objects\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F18\u002Fjsweirdworld-24-faking-namespaces-with-objects\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F18\u002Fjsweirdworld-24-faking-namespaces-with-objects\u002F":879,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F18\u002Fjsweirdworld-24-faking-namespaces-with-objects\u002F":888},"\u002Fjsweirdworld\u002F20190518\u002F3335281250\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":862,"date":863,"description":864,"extension":865,"lang":866,"meta":867,"navigation":91,"path":868,"readingMinutes":869,"seo":870,"standalone":871,"stem":872,"tags":873,"tldr":876,"updated":863,"url":877,"__hash__":878},"content\u002Fen\u002FJsWeirdWorld\u002Fjsweirdworld-24-faking-namespaces-with-objects.md","[JS Weird World] No.24 A Framework Tip: Faking Namespaces in JavaScript","1000126707",{"type":9,"value":10,"toc":858},"minimark",[11,16,24,36,39,106,113,123,169,175,186,313,322,325,437,443,465,589,594,597,707,723,835,841,845,854],[12,13,15],"h2",{"id":14},"faking-namespaces","Faking Namespaces",[17,18,19],"p",{},[20,21],"img",{"alt":22,"src":23},"Faking namespaces","https:\u002F\u002Fi.imgur.com\u002FsTXhfU0.png",[17,25,26,27,31,32,35],{},"In most modern languages a namespace is a container for variables and functions. Basically it's there to ",[28,29,30],"strong",{},"keep variable and function names separate so that A doesn't infect B",". JavaScript doesn't actually have namespaces — but here's the thing, we can use objects to ",[28,33,34],{},"fake a namespace",".",[17,37,38],{},"The course gives this example:",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","var greet = 'Hello!';\nvar greet = 'Hola!';\n\nconsole.log(greet);\n","js","",[47,48,49,72,86,93],"code",{"__ignoreMap":45},[50,51,54,58,62,65,69],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sWyjQ","var",[50,59,61],{"class":60},"sMAXC"," greet ",[50,63,64],{"class":56},"=",[50,66,68],{"class":67},"sTRMh"," 'Hello!'",[50,70,71],{"class":60},";\n",[50,73,75,77,79,81,84],{"class":52,"line":74},2,[50,76,57],{"class":56},[50,78,61],{"class":60},[50,80,64],{"class":56},[50,82,83],{"class":67}," 'Hola!'",[50,85,71],{"class":60},[50,87,89],{"class":52,"line":88},3,[50,90,92],{"emptyLinePlaceholder":91},true,"\n",[50,94,96,99,103],{"class":52,"line":95},4,[50,97,98],{"class":60},"console.",[50,100,102],{"class":101},"sj_SG","log",[50,104,105],{"class":60},"(greet);\n",[17,107,108,109,112],{},"So what does ",[47,110,111],{},"console.log"," output here?",[17,114,115,116,122],{},"We know every variable and function in JavaScript goes through a creation phase (hoisting), and every variable gets a ",[28,117,118,119],{},"default value of ",[47,120,121],{},"undefined",". It's clearer if you pull the code apart like this:",[40,124,126],{"className":42,"code":125,"language":44,"meta":45,"style":45},"var greet;\n\ngreet = 'Hello!';\ngreet = 'Hola!';\nconsole.log(greet);\n",[47,127,128,135,139,150,160],{"__ignoreMap":45},[50,129,130,132],{"class":52,"line":53},[50,131,57],{"class":56},[50,133,134],{"class":60}," greet;\n",[50,136,137],{"class":52,"line":74},[50,138,92],{"emptyLinePlaceholder":91},[50,140,141,144,146,148],{"class":52,"line":88},[50,142,143],{"class":60},"greet ",[50,145,64],{"class":56},[50,147,68],{"class":67},[50,149,71],{"class":60},[50,151,152,154,156,158],{"class":52,"line":95},[50,153,143],{"class":60},[50,155,64],{"class":56},[50,157,83],{"class":67},[50,159,71],{"class":60},[50,161,163,165,167],{"class":52,"line":162},5,[50,164,98],{"class":60},[50,166,102],{"class":101},[50,168,105],{"class":60},[17,170,171],{},[20,172],{"alt":173,"src":174},"greet","https:\u002F\u002Fi.imgur.com\u002FCGntE1v.png",[17,176,177,178,181,182,185],{},"In practice you'll often reuse the same variable name. In other languages you'd solve the name-collision problem with a ",[28,179,180],{},"namespace",". JavaScript doesn't have those, so we use an object to build a ",[28,183,184],{},"fake namespace"," instead, like this:",[40,187,189],{"className":42,"code":188,"language":44,"meta":45,"style":45},"var greet;\n\ngreet = 'Hello!';\ngreet = 'Hola!';\nconsole.log(greet);\n\nvar english = {};\nvar spanish = {};\n\nenglish.greet = 'Hello!';\nspanish.greet = 'Hola!';\n\nconsole.log(english);\nconsole.log(spanish);\n",[47,190,191,197,201,211,221,229,234,247,259,264,276,288,293,303],{"__ignoreMap":45},[50,192,193,195],{"class":52,"line":53},[50,194,57],{"class":56},[50,196,134],{"class":60},[50,198,199],{"class":52,"line":74},[50,200,92],{"emptyLinePlaceholder":91},[50,202,203,205,207,209],{"class":52,"line":88},[50,204,143],{"class":60},[50,206,64],{"class":56},[50,208,68],{"class":67},[50,210,71],{"class":60},[50,212,213,215,217,219],{"class":52,"line":95},[50,214,143],{"class":60},[50,216,64],{"class":56},[50,218,83],{"class":67},[50,220,71],{"class":60},[50,222,223,225,227],{"class":52,"line":162},[50,224,98],{"class":60},[50,226,102],{"class":101},[50,228,105],{"class":60},[50,230,232],{"class":52,"line":231},6,[50,233,92],{"emptyLinePlaceholder":91},[50,235,237,239,242,244],{"class":52,"line":236},7,[50,238,57],{"class":56},[50,240,241],{"class":60}," english ",[50,243,64],{"class":56},[50,245,246],{"class":60}," {};\n",[50,248,250,252,255,257],{"class":52,"line":249},8,[50,251,57],{"class":56},[50,253,254],{"class":60}," spanish ",[50,256,64],{"class":56},[50,258,246],{"class":60},[50,260,262],{"class":52,"line":261},9,[50,263,92],{"emptyLinePlaceholder":91},[50,265,267,270,272,274],{"class":52,"line":266},10,[50,268,269],{"class":60},"english.greet ",[50,271,64],{"class":56},[50,273,68],{"class":67},[50,275,71],{"class":60},[50,277,279,282,284,286],{"class":52,"line":278},11,[50,280,281],{"class":60},"spanish.greet ",[50,283,64],{"class":56},[50,285,83],{"class":67},[50,287,71],{"class":60},[50,289,291],{"class":52,"line":290},12,[50,292,92],{"emptyLinePlaceholder":91},[50,294,296,298,300],{"class":52,"line":295},13,[50,297,98],{"class":60},[50,299,102],{"class":101},[50,301,302],{"class":60},"(english);\n",[50,304,306,308,310],{"class":52,"line":305},14,[50,307,98],{"class":60},[50,309,102],{"class":101},[50,311,312],{"class":60},"(spanish);\n",[17,314,315,316,318,319,321],{},"Now you can hold two variables with the same name (",[47,317,173],{},"), and that's what we mean by a ",[28,320,184],{},". The upside is you sidestep the variable-collision problem — and really, you're just leaning on how objects work to pull it off.",[17,323,324],{},"But you can't write it like this:",[40,326,328],{"className":42,"code":327,"language":44,"meta":45,"style":45},"var greet;\n\ngreet = 'Hello!';\ngreet = 'Hola!';\nconsole.log(greet);\n\nvar english = {};\nvar spanish = {};\n\nenglish.greetings.greet = 'Hello!';\nspanish.greet = 'Hola!';\n\nconsole.log(english);\nconsole.log(spanish);\n",[47,329,330,336,340,350,360,368,372,382,392,396,407,417,421,429],{"__ignoreMap":45},[50,331,332,334],{"class":52,"line":53},[50,333,57],{"class":56},[50,335,134],{"class":60},[50,337,338],{"class":52,"line":74},[50,339,92],{"emptyLinePlaceholder":91},[50,341,342,344,346,348],{"class":52,"line":88},[50,343,143],{"class":60},[50,345,64],{"class":56},[50,347,68],{"class":67},[50,349,71],{"class":60},[50,351,352,354,356,358],{"class":52,"line":95},[50,353,143],{"class":60},[50,355,64],{"class":56},[50,357,83],{"class":67},[50,359,71],{"class":60},[50,361,362,364,366],{"class":52,"line":162},[50,363,98],{"class":60},[50,365,102],{"class":101},[50,367,105],{"class":60},[50,369,370],{"class":52,"line":231},[50,371,92],{"emptyLinePlaceholder":91},[50,373,374,