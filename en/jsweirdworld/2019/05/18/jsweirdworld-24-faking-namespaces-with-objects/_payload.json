 dot operator is left-associative, so ",[47,711,712],{},"english.greetings"," gets evaluated first. But ",[47,715,456],{}," doesn't have a ",[47,718,460],{}," on it, so JavaScript hands back the default value ",[47,721,121],{},". Which effectively turns the code into this:",[40,724,726],{"className":42,"code":725,"language":44,"meta":45,"style":45},"var greet;\n\ngreet = 'Hello!';\ngreet = 'Hola!';\nconsole.log(greet);\n\nvar english = {};\nvar spanish = {};\n\nundefined.greet = 'Hello!';\nspanish.greet = 'Hola!';\n\nconsole.log(english);\nconsole.log(spanish);\n",[47,727,728,734,738,748,758,766,770,780,790,794,805,815,819,827],{"__ignoreMap":45},[50,729,730,732],{"class":52,"line":53},[50,731,57],{"class":56},[50,733,134],{"class":60},[50,735,736],{"class":52,"line":74},[50,737,92],{"emptyLinePlaceholder":91},[50,739,740,742,744,746],{"class":52,"line":88},[50,741,143],{"class":60},[50,743,64],{"class":56},[50,745,68],{"class":67},[50,747,71],{"class":60},[50,749,750,752,754,756],{"class":52,"line":95},[50,751,143],{"class":60},[50,753,64],{"class":56},[50,755,83],{"class":67},[50,757,71],{"class":60},[50,759,760,762,764],{"class":52,"line":162},[50,761,98],{"class":60},[50,763,102],{"class":101},[50,765,105],{"class":60},[50,767,768],{"class":52,"line":231},[50,769,92],{"emptyLinePlaceholder":91},[50,771,772,774,776,778],{"class":52,"line":236},[50,773,57],{"class":56},[50,775,241],{"class":60},[50,777,64],{"class":56},[50,779,246],{"class":60},[50,781,782,784,786,788],{"class":52,"line":249},[50,783,57],{"class":56},[50,785,254],{"class":60},[50,787,64],{"class":56},[50,789,246],{"class":60},[50,791,792],{"class":52,"line":261},[50,793,92],{"emptyLinePlaceholder":91},[50,795,796,799,801,803],{"class":52,"line":266},[50,797,798],{"class":60},"undefined.greet ",[50,800,64],{"class":56},[50,802,68],{"class":67},[50,804,71],{"class":60},[50,806,807,809,811,813],{"class":52,"line":278},[50,808,281],{"class":60},[50,810,64],{"class":56},[50,812,83],{"class":67},[50,814