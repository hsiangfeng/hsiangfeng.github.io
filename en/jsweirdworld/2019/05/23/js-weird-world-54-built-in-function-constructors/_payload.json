[{"data":1,"prerenderedAt":492},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-54-built-in-function-constructors\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-54-built-in-function-constructors\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-54-built-in-function-constructors\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-54-built-in-function-constructors\u002F":468,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-54-built-in-function-constructors\u002F":477},"\u002Fjsweirdworld\u002F20190523\u002F1428987064\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":451,"date":452,"description":453,"extension":454,"lang":455,"meta":456,"navigation":91,"path":457,"readingMinutes":458,"seo":459,"standalone":460,"stem":461,"tags":462,"tldr":465,"updated":452,"url":466,"__hash__":467},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-54-built-in-function-constructors.md","[JS Weird World] No.54 A Little Danger Warning: Built-in Function Constructors","1000388034",{"type":9,"value":10,"toc":445},"minimark",[11,16,20,24,27,105,112,119,167,170,176,187,254,260,267,330,336,342,352,355,358,387,394,403,409,413,430,434,441],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"We've already covered built-in function constructors in earlier chapters, but they've got some dangerous spots too. They're nice and concise, but that comes with traps. This chapter is mainly about why built-in function constructors get risky when they're handling primitives, booleans, numbers, and strings.",[12,21,23],{"id":22},"built-in-function-constructors","Built-in Function Constructors",[17,25,26],{},"Let's start with an example.",[28,29,34],"pre",{"className":30,"code":31,"language":32,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","var a = 3;\nvar b = new Number(3);\n\na == b;\n","js","",[35,36,37,60,86,93],"code",{"__ignoreMap":33},[38,39,42,46,50,53,57],"span",{"class":40,"line":41},"line",1,[38,43,45],{"class":44},"sWyjQ","var",[38,47,49],{"class":48},"sMAXC"," a ",[38,51,52],{"class":44},"=",[38,54,56],{"class":55},"sCcAr"," 3",[38,58,59],{"class":48},";\n",[38,61,63,65,68,70,73,77,80,83],{"class":40,"line":62},2,[38,64,45],{"class":44},[38,66,67],{"class":48}," b ",[38,69,52],{"class":44},[38,71,72],{"class":44}," new",[38,74,76],{"class":75},"sj_SG"," Number",[38,78,79],{"class":48},"(",[38,81,82],{"class":55},"3",[38,84,85],{"class":48},");\n",[38,87,89],{"class":40,"line":88},3,[38,90,92],{"emptyLinePlaceholder":91},true,"\n",[38,94,96,99,102],{"class":40,"line":95},4,[38,97,98],{"class":48},"a ",[38,100,101],{"class":44},"==",[38,103,104],{"class":48}," b;\n",[17,106,107],{},[108,109],"img",{"alt":110,"src":111},"comparing with double equals returns true","https:\u002F\u002Fi.imgur.com\u002F2k5hXEV.png",[17,113,114,115,118],{},"We get ",[35,116,117],{},"true",", which basically seems fine. But what happens if we force a strict type check?",[28,120,122],{"className":30,"code":121,"language":32,"meta":33,"style":33},"var a = 3;\nvar b = new Number(3);\n\na === b;\n",[35,123,124,136,154,158],{"__ignoreMap":33},[38,125,126,128,130,132,134],{"class":40,"line":41},[38,127,45],{"class":44},[38,129,49],{"class":48},[38,131,52],{"class":44},[38,133,56],{"class":55},[38,135,59],{"class":48},[38,137,138,140,142,144,146,148,150,152],{"class":40,"line":62},[38,139,45],{"class":44},[38,141,67],{"class":48},[38,143,52],{"class":44},[38,145,72],{"class":44},[38,147,76],{"class":75},[38,149,79],{"class":48},[38,151,82],{"class":55},[38,153,85],{"class":48},[38,155,156],{"class":40,"line":88},[38,157,92],{"emptyLinePlaceholder":91},[38,159,160,162,165],{"class":40,"line":95},[38,161,98],{"class":48},[38,163,164],{"class":44},"===",[38,166,104],{"class":48},[17,168,169],{},"Take a second and try to guess the answer before scrolling.",[17,171,172],{},[108,173],{"alt":174,"src":175},"comparing with triple equals returns false","https:\u002F\u002Fi.imgur.com\u002FCDbR8Dy.png",[17,177,178,179,182,183,186],{},"The answer is ",[35,180,181],{},"false",". The reason is that ",[35,184,185],{},"b",", created through the built-in constructor, is an object.",[28,188,190],{"className":30,"code":189,"language":32,"meta":33,"style":33},"var a = 3;\nvar b = new Number(3);\n\na === b;\n\nb\ntypeof(b);\n",[35,191,192,204,222,226,234,239,245],{"__ignoreMap":33},[38,193,194,196,198,200,202],{"class":40,"line":41},[38,195,45],{"class":44},[38,197,49],{"class":48},[38,199,52],{"class":44},[38,201,56],{"class":55},[38,203,59],{"class":48},[38,205,206,208,210,212,214,216,218,220],{"class":40,"line":62},[38,207,45],{"class":44},[38,209,67],{"class":48},[38,211,52],{"class":44},[38,213,72],{"class":44},[38,215,76],{"class":75},[38,217,79],{"class":48},[38,219,82],{"class":55},[38,221,85],{"class":48},[38,223,224],{"class":40,"line":88},[38,225,92],{"emptyLinePlaceholder":91},[38,227,228,230,232],{"class":40,"line":95},[38,229,98],{"class":48},[38,231,164],{"class":44},[38,233,104],{"class":48},[38,235,237],{"class":40,"line":236},5,[38,238,92],{"emptyLinePlaceholder":91},[38,240,242],{"class":40,"line":241},6,[38,243,244],{"class":48},"b\n",[38,246,248,251],{"class":40,"line":247},7,[38,249,250],{"class":44},"typeof",[38,252,253],{"class":48},"(b);\n",[17,255,256],{},[108,257],{"alt":258,"src":259},"typeof b returns object","https:\u002F\u002Fi.imgur.com\u002F6VBUuyw.png",[17,261,262,263,266],{},"So what about ",[35,264,265],{},"a","?",[28,268,270],{"className":30,"code":269,"language":32,"meta":33,"style":33},"var a = 3;\nvar b = new Number(3);\n\na === b;\n\na\ntypeof(a);\n",[35,271,272,284,302,306,314,318,323],{"__ignoreMap":33},[38,273,274,276,278,280,282],{"class":40,"line":41},[38,275,45],{"class":44},[38,277,49],{"class":48},[38,279,52],{"class":44},[38,281,56],{"class":55},[38,283,59],{"class":48},[38,285,286,288,290,292,294,296,298,300],{"class":40,"line":62},[38,287,45],{"class":44},[38,289,67],{"class":48},[38,291,52],{"class":44},[38,293,72],{"class":44},[38,295,76],{"class":75},[38,297,79],{"class":48},[38,299,82],{"class":55},[38,301,85],{"class":48},[38,303,304],{"class":40,"line":88},[38,305,92],{"emptyLinePlaceholder":91},[38,307,308,310,312],{"class":40,"line":95},[38,309,98],{"class":48},[38,311,164],{"class":44},[38,313,104],{"class":48},[38,315,316],{"class":40,"line":236},[38,317,92],{"emptyLinePlaceholder":91},[38,319,320],{"class":40,"line":241},[38,321,322],{"class":48},"a\n",[38,324,325,327],{"class":40,"line":247},[38,326,250],{"class":44},[38,328,329],{"class":48},"(a);\n",[17,331,332],{},[108,333],{"alt":334,"src":335},"typeof a returns number","https:\u002F\u002Fi.imgur.com\u002FMb1z6iS.png",[17,337,338,339,341],{},"It's a primitive. So under double equals, JavaScript coerces both sides to the same type, but under triple equals you get ",[35,340,181],{},". Which tells us that a primitive built through a built-in function constructor isn't actually a real primitive. So we can wrap up with a takeaway here.",[343,344,345],"blockquote",{},[17,346,347,351],{},[348,349,350],"strong",{},"Note","\nGenerally speaking, it's better not to use built-in function constructors — just use the literal syntax.",[17,353,354],{},"If you really do need a built-in function constructor, you need to know exactly what you're doing, like the type differences involved.",[17,356,357],{},"But some situations are a bit different.",[28,359,361],{"className":30,"code":360,"language":32,"meta":33,"style":33},"var a = Number('3');\ntypeof(a);\n",[35,362,363,381],{"__ignoreMap":33},[38,364,365,367,369,371,373,375,379],{"class":40,"line":41},[38,366,45],{"class":44},[38,368,49],{"class":48},[38,370,52],{"class":44},[38,372,76],{"class":75},[38,374,79],{"class":48},[38,376,378],{"class":377},"sTRMh","'3'",[38,380,85],{"class":48},[38,382,383,385],{"class":40,"line":62},[38,384,250],{"class":44},[38,386,329],{"class":48},[17,388,389,390,393],{},"In some cases writing it like the above is totally fine — but you have to be clear about the difference between using ",[35,391,392],{},"new"," and not using it.",[343,395,396],{},[17,397,398,400,402],{},[348,399,350],{},[35,401,392],{}," creates an object first, then calls the function, and you end up with the object.",[17,404,405],{},[108,406],{"alt":407,"src":408},"Number without new returns a primitive number","https:\u002F\u002Fi.imgur.com\u002FdftcJmI.png",[12,410,412],{"id":411},"momentjs","moment.js",[17,414,415,416,419,420,425,426,429],{},"Normally we use ",[35,417,418],{},"Date"," to handle time functions, so the course recommended a pretty good package: ",[265,421,412],{"href":422,"rel":423},"https:\u002F\u002Fmomentjs.com\u002F",[424],"nofollow",". It's got a ton of functions for working with dates and doing date math. The course also mentioned that if you need to deal with a lot of dates, this package is the way to go — it keeps you from stepping on a bunch of unnecessary landmines, instead of leaning on the built-in function constructor (",[35,427,428],{},"new Date",").",[12,431,433],{"id":432},"image-source","Image Source",[17,435,436],{},[265,437,440],{"href":438,"rel":439},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[424],"JavaScript 全攻略:克服 JS 奇怪的部分",[442,443,444],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":33,"searchDepth":62,"depth":62,"links":446},[447,448,449,450],{"id":14,"depth":62,"text":15},{"id":22,"depth":62,"text":23},{"id":411,"depth":62,"text":412},{"id":432,"depth":62,"text":433},"JsWeirdWorld","2019-05-23 21:16:00","We've already talked about built-in function constructors in earlier chapters, but they come with some genuinely dangerous corners. They're concise, sure, but that conciseness hides traps. This chapter focuses on why built-in function constructors get sketchy when they're dealing with primitives, booleans, numbers, and strings.","md","en",{},"\u002Fen\u002Fjsweirdworld\u002Fjs-weird-world-54-built-in-function-constructors","2",{"title":6,"description":453},false,"en\u002FJsWeirdWorld\u002Fjs-weird-world-54-built-in-function-constructors",[463,464],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分",null,"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-54-built-in-function-constructors\u002F","1pJHDMRz4YubgRU5nxoA7JPGBG5djFWYuWZthJvhUHw",{"newer":469,"older":473},{"url":470,"title":471,"date":472},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F23\u002Fjs-weird-world-55-arrays-and-for-in\u002F","[JS Weird World] No.55 A Dangerous Reminder: Arrays and for in","2019-05-23 22:27:00",{"url":474,"title":475,"date":476},"\u002Fen\u002Fmisc\u002F2019\u002F05\u002F23\u002Fwhat-is-a-user-story\u002F","What's a User Story?","2019-05-23 13:00:04",[478,483,488],{"url":479,"title":480,"date":481,"readingMinutes":482},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F","[JS Weird World] Bonus: Closures, One More Time","2019-05-27 13:50:04","5",{"url":484,"title":485,"date":486,"readingMinutes":487},"\u002Fen\u002Fjsweirdworld\u