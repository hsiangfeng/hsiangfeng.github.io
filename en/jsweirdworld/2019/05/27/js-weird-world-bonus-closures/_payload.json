[{"data":1,"prerenderedAt":1345},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F":1324,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F27\u002Fjs-weird-world-bonus-closures\u002F":1333},"\u002Fjsweirdworld\u002F20190527\u002F1292017914\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1307,"date":1308,"description":1309,"extension":1310,"lang":1311,"meta":1312,"navigation":467,"path":1313,"readingMinutes":1314,"seo":1315,"standalone":1316,"stem":1317,"tags":1318,"tldr":1321,"updated":1308,"url":1322,"__hash__":1323},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-bonus-closures.md","[JS Weird World] Bonus: Closures, One More Time","1000538495",{"type":9,"value":10,"toc":1298},"minimark",[11,16,20,23,35,43,47,55,181,196,203,212,216,219,232,237,247,250,374,377,382,402,527,533,536,539,597,613,616,628,631,706,728,731,1229,1241,1245,1249,1252,1256,1261,1266,1273,1280,1287,1294],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"I already talked about closures earlier in this series, but to be honest I still felt kind of half-sure about them. So I decided to pull the closure stuff out into its own bonus episode and record a bit more of what I learned.",[17,21,22],{},"Previous posts for context:",[17,24,25],{},[26,27,29,30,34],"a",{"href":28},"\u002Fjsweirdworld\u002F20190520\u002F2896946513\u002F","'",[31,32,33],"span",{},"JS Weird World"," No.38 Closures (Part 1) (article in Mandarin)'",[17,36,37],{},[26,38,29,40,42],{"href":39},"\u002Fjsweirdworld\u002F20190520\u002F3725371318\u002F",[31,41,33],{}," No.39 Closures (Part 2) (article in Mandarin)'",[12,44,46],{"id":45},"closures","Closures",[17,48,49,50,54],{},"So first off, what's a closure? The simplest way to put it: ",[51,52,53],"strong",{},"it's a function that returns another function — that's a closure",". Here's a quick example so you can see how one is written.",[56,57,62],"pre",{"className":58,"code":59,"language":60,"meta":61,"style":61},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Window';\nfunction sayHi (){\n  var a = 'Closure';\n  console.log('now is Function.');\n  return function () {\n    console.log('Hello' + ' ' + a);\n  }\n}\n","js","",[63,64,65,87,100,115,133,145,169,175],"code",{"__ignoreMap":61},[31,66,69,73,77,80,84],{"class":67,"line":68},"line",1,[31,70,72],{"class":71},"sWyjQ","var",[31,74,76],{"class":75},"sMAXC"," a ",[31,78,79],{"class":71},"=",[31,81,83],{"class":82},"sTRMh"," 'Window'",[31,85,86],{"class":75},";\n",[31,88,90,93,97],{"class":67,"line":89},2,[31,91,92],{"class":71},"function",[31,94,96],{"class":95},"sj_SG"," sayHi",[31,98,99],{"class":75}," (){\n",[31,101,103,106,108,110,113],{"class":67,"line":102},3,[31,104,105],{"class":71},"  var",[31,107,76],{"class":75},[31,109,79],{"class":71},[31,111,112],{"class":82}," 'Closure'",[31,114,86],{"class":75},[31,116,118,121,124,127,130],{"class":67,"line":117},4,[31,119,120],{"class":75},"  console.",[31,122,123],{"class":95},"log",[31,125,126],{"class":75},"(",[31,128,129],{"class":82},"'now is Function.'",[31,131,132],{"class":75},");\n",[31,134,136,139,142],{"class":67,"line":135},5,[31,137,138],{"class":71},"  return",[31,140,141],{"class":71}," function",[31,143,144],{"class":75}," () {\n",[31,146,148,151,153,155,158,161,164,166],{"class":67,"line":147},6,[31,149,150],{"class":75},"    console.",[31,152,123],{"class":95},[31,154,126],{"class":75},[31,156,157],{"class":82},"'Hello'",[31,159,160],{"class":71}," +",[31,162,163],{"class":82}," ' '",[31,165,160],{"class":71},[31,167,168],{"class":75}," a);\n",[31,170,172],{"class":67,"line":171},7,[31,173,174],{"class":75},"  }\n",[31,176,178],{"class":67,"line":177},8,[31,179,180],{"class":75},"}\n",[17,182,183,184,187,188,191,192,195],{},"To run it, you call ",[63,185,186],{},"sayHi()",". And if you want to run the inner function — the closure itself — you use two sets of parentheses: ",[63,189,190],{},"sayHi()()",". You'll see two ",[63,193,194],{},"console"," outputs here, and that's intentional, I did it on purpose.",[17,197,198],{},[199,200],"img",{"alt":201,"src":202},"Closure","https:\u002F\u002Fi.imgur.com\u002FXgZvDPr.png",[204,205,211],"iframe",{"height":206,"style":207,"scrolling":208,"title":201,"src":209,"frameBorder":208,"allowTransparency":210,"allowFullScreen":210},265,"width: 100%;","no","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FvwrKKr\u002F?height=265&theme-id=0&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FvwrKKr\u002F'>Closure\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,213,215],{"id":214},"why-write-a-closure","Why write a closure?",[17,217,218],{},"So why bother learning to write closures? There are a few main reasons:",[220,221,222,226,229],"ol",{},[223,224,225],"li",{},"You can keep variables private",[223,227,228],{},"The outer variable can be accessed by the inner function",[223,230,231],{},"The inner variable doesn't get released",[233,234,236],"h3",{"id":235},"what-does-the-inner-variable-doesnt-get-released-mean","What does \"the inner variable doesn't get released\" mean?",[17,238,239,240,246],{},"Let me show you with an example. I'm borrowing the idea from this article — ",[26,241,245],{"href":242,"rel":243},"https:\u002F\u002Fwcc723.github.io\u002Fjavascript\u002F2017\u002F12\u002F13\u002Fjavascript-closure\u002F",[244],"nofollow","Iron Man series: another way to explain JavaScript closures (article in Mandarin)"," — and rewriting it with some numbers so it's easier to follow.",[17,248,249],{},"Say three people — Ming, Mei, and Wang — share 1000 dollars between them. Ming spends 100, Mei spends 50, and Wang spends 700. So there should be 150 left over. A normal first attempt might look like this:",[56,251,253],{"className":58,"code":252,"language":60,"meta":61,"style":61},"function myMoney(price) {\n  var money = 1000;\n  return money = money - price;\n}\nvar count = myMoney; \u002F\u002F store the result in the count variable\n\u002F\u002F Ming spends 100$\ncount(100);\n\u002F\u002F Mei spends 50$\ncount(50);\n\u002F\u002F Wang spends 700$\ncount(700);\n",[63,254,255,271,286,302,306,322,327,339,344,356,362],{"__ignoreMap":61},[31,256,257,259,262,264,268],{"class":67,"line":68},[31,258,92],{"class":71},[31,260,261],{"class":95}," myMoney",[31,263,126],{"class":75},[31,265,267],{"class":266},"s_sBn","price",[31,269,270],{"class":75},") {\n",[31,272,273,275,278,280,284],{"class":67,"line":89},[31,274,105],{"class":71},[31,276,277],{"class":75}," money ",[31,279,79],{"class":71},[31,281,283],{"class":282},"sCcAr"," 1000",[31,285,86],{"class":75},[31,287,288,290,292,294,296,299],{"class":67,"line":102},[31,289,138],{"class":71},[31,291,277],{"class":75},[31,293,79],{"class":71},[31,295,277],{"class":75},[31,297,298],{"class":71},"-",[31,300,301],{"class":75}," price;\n",[31,303,304],{"class":67,"line":117},[31,305,180],{"class":75},[31,307,308,310,313,315,318],{"class":67,"line":135},[31,309,72],{"class":71},[31,311,312],{"class":75}," count ",[31,314,79],{"class":71},[31,316,317],{"class":75}," myMoney; ",[31,319,321],{"class":320},"sQrFR","\u002F\u002F store the result in the count variable\n",[31,323,324],{"class":67,"line":147},[31,325,326],{"class":320},"\u002F\u002F Ming spends 100$\n",[31,328,329,332,334,337],{"class":67,"line":171},[31,330,331],{"class":95},"count",[31,333,126],{"class":75},[31,335,336],{"class":282},"100",[31,338,132],{"class":75},[31,340,341],{"class":67,"line":177},[31,342,343],{"class":320},"\u002F\u002F Mei spends 50$\n",[31,345,347,349,351,354],{"class":67,"line":346},9,[31,348,331],{"class":95},[31,350,126],{"class":75},[31,352,353],{"class":282},"50",[31,355,132],{"class":75},[31,357,359],{"class":67,"line":358},10,[31,360,361],{"class":320},"\u002F\u002F Wang spends 700$\n",[31,363,365,367,369,372],{"class":67,"line":364},11,[31,366,331],{"class":95},[31,368,126],{"class":75},[31,370,371],{"class":282},"700",[31,373,132],{"class":75},[17,375,376],{},"And we notice something — the result isn't what we expected.",[17,378,379],{},[199,380],{"alt":92,"src":381},"https:\u002F\u002Fi.imgur.com\u002FY8rH5ev.png",[17,383,384,385,388,389,392,393,396,397,401],{},"The reason is that every time ",[63,386,387],{},"count();"," runs, JavaScript re-declares a brand new variable called ",[63,390,391],{},"money"," with a value of ",[63,394,395],{},"1000",". Even though we stored the returned value, once the function finishes running, the variables inside it get released along with it. So if that ",[398,399,400],"em",{},"was"," the result you wanted, then nothing's wrong here. But our problem is that everyone shares 1000$, and after each of them spends, the wallet should have 150$ left. That's exactly where a closure comes in — because we need to keep the variable's result around.",[56,403,405],{"className":58,"code":404,"language":60,"meta":61,"style":61},"function myMoney() {\n  var money = 1000;\n  return function(price) {\n    return money = money - price;\n  }\n}\n\nvar count = myMoney();\n\u002F\u002F Ming spends 100$\ncount(100);\n\u002F\u002F Mei spends 50$\ncount(50);\n\u002F\u002F Wang spends 700$\ncount(700);\n",[63,406,407,416,428,440,455,459,463,469,482,486,496,500,511,516],{"__ignoreMap":61},[31,408,409,411,413],{"class":67,"line":68},[31,410,92],{"class":71},[31,412,261],{"class":95},[31,414,415],{"class":75},"() {\n",[31,417,418,420,422,424,426],{"class":67,"line":89},[31,419,105],{"class":71},[31,421,277],{"class":75},[31,423,79],{"class":71},[31,425,283],{"class":282},[31,427,86],{"class":75},[31,429,430,432,434,436,438],{"class":67,"line":102},[31,431,138],{"class":71},[31,433,141],{"class":71},[31,435,126],{"class":75},[31,437,267],{"class":266},[31,439,270],{"class":75},[31,441,442,445,447,449,451,453],{"class":67,"line":117},[31,443,444],{"class":71},"    return",[31,446,277],{"class":75},[31,448,79],{"class":71},[31,450,277],{"class":75},[31,452,298],{"class":71},[31,454,301],{"class":75},[31,456,457],{"class":67,"line":135},[31,458,174],{"class":75},[31,460,461],{"class":67,"line":147},[31,462,180],{"class":75},[31,464,465],{"class":67,"line":171},[31,466,468],{"emptyLinePlaceholder":467},true,"\n",[31,470,471,473,475,477,479],{"class":67,"line":177},[31,472,72],{"class":71},[31,474,312],{"class":75},[31,476,79],{"class":71},[31,478,261],{"class":95},[31,480,481],{"class":75},"();\n",[31,483,484],{"class":67,"line":346},[31,485,326],{"class":320},[31,487,488,490,492,494],{"class":67,"line":358},[31,489,331],{"class":95},[31,491,126],{"class":75},[31,493,336],{"class":282},[31,495,132],{"class":75},[31,497,498],{"class":67,"line":364},[31,499,343],{"class":320},[31,501,503,505,507,509],{"class":67,"line":502},12,[31,504,331],{"class":95},[31,506,126],{"class":75},[31,508,353],{"class":282},[31,510,132],{"class":75},[31,512,514],{"class":67,"line":513},13,[31,515,361],{"class":320},[31,517,519,521,523,525],{"class":67,"line":518},14,[31,520,331],{"class":95},[31,522,126],{"class":75},[31,524,371],{"class":282},[31,526,132],{"class":75},[17,528,529],{},[199,530],{"alt":531,"src":532},"closure","https:\u002F\u002Fi.imgur.com\u002FGRan6ij.png",[17,534,535],{},"And now the result is what we wanted. So let me try to explain how it actually works.",[17,537,538],{},"In the earlier example:",[56,540,542],{"className":58,"code":541,"language":60,"meta":61,"style":61},"function myMoney(price) {\n  var money = 1000;\n  return money = money - price;\n}\nvar count = myMoney;\n",[63,543,544,556,568,582,586],{"__ignoreMap":61},[31,545,546,548,550,552,554],{"class":67,"line":68},[31,547,92],{"class":71},[31,549,261],{"class":95},[31,551,126],{"class":75},[31,553,267],{"class":266},[31,555,270],{"class":75},[31,557,558,560,562,564,566],{"class":67,"line":89},[31,559,105],{"class":71},[31,561,277],{"class":75},[31,563,79],{"class":71},[31,565,283],{"class":282},[31,567,86],{"class":75},[31,569,570,572,574,576,578,580],{"class":67,"line":102},[31,571,138],{"class":71},[31,573,277],{"class":75},[31,575,79],{"class":71},[31,577,277],{"class":75},[31,579,298],{"class":71},[31,581,301],{"class":75},[31,583,584],{"class":67,"line":117},[31,585,180],{"class":75},[31,587,588,590,592,594],{"class":67,"line":135},[31,589,72],{"class":71},[31,591,312],{"class":75},[31,593,79],{"class":71},[31,595,596],{"class":75}," myMoney;\n",[17,598,599,600,603,604,606,607,609,610,612],{},"After JavaScript runs this, it never actually assigns the ",[63,601,602],{},"function myMoney"," to the ",[63,605,331],{}," variable. So every time I call ",[63,608,387],{},", it's creating a fresh execution context — which is exactly why ",[63,611,391],{}," always equals 1000$.",[17,614,615],{},"What about the closure version? Like I said earlier:",[617,618,619],"blockquote",{},[17,620,621,622,624,625,627],{},"A closure is a ",[63,623,92],{}," that returns a ",[63,626,92],{},".",[17,629,630],{},"So in the closure example:",[56,632,634],{"className":58,"code":633,"language":60,"meta":61,"style":61},"function myMoney() {\n  var money = 1000;\n  return function(price) {\n    return money = money - price;\n  }\n}\n\nvar count = myMoney();\n",[63,635,636,644,656,668,682,686,690,694],{"__ignoreMap":61},[31,637,638,640,642],{"class":67,"line":68},[31,639,92],{"class":71},[31,641,261],{"class":95},[31,643,415],{"class":75},[31,645,646,648,650,652,654],{"class":67,"line":89},[31,647,105],{"class":71},[31,649,277],{"class":75},[31,651,79],{"class":71},[31,653,283],{"class":282},[31,655,86],{"class":75},[31,657,658,660,662,664,666],{"class":67,"line":102},[31,659,138],{"class":71},[31,661,141],{"class":71},[31,663,126],{"class":75},[31,665,267],{"class":266},[31,667,270],{"class":75},[31,669,670,672,674,676,678,680],{"class":67,"line":117},[31,671,444],{"class":71},[31,673,277],{"class":75},[31,675,79],{"class":71},[31,677,277],{"class":75},[31,679,298],{"class":71},[31,681,301],{"class":75},[31,683,684],{"class":67,"line":135},[31,685,174],{"class":75},[31,687,688],{"class":67,"line":147},[31,689,180],{"class":75},[31,691,692],{"class":67,"line":171},[31,693,468],{"emptyLinePlaceholder":467},[31,695,696,698,700,702,704],{"class":67,"line":177},[31,697,72],{"class":71},[31,699,312],{"class":75},[31,701,79],{"class":71},[31,703,261],{"class":95},[31,705,481],{"class":75},[17,707,708,709,711,712,714,715,717,718,721,722,725,726,627],{},"During JavaScript's creation phase, ",[63,710,602],{}," gets its execution context created and stored in the ",[63,713,331],{}," variable. Because of that, the ",[63,716,391],{}," variable inside ",[63,719,720],{},"myMoney"," stays held in memory, so every time you call ",[63,723,724],{},"count()",", it can keep updating ",[63,727,391],{},[17,729,730],{},"We can take closures further and build something a bit more useful — for example, giving each person their own stored-value transit card.",[56,732,734],{"className":58,"code":733,"language":60,"meta":61,"style":61},"function myMoney(storage) {\n  var money = storage;\n  console.log(money);\n  return function(price) {\n    return { \u002F\u002F use an object of functions to check and deduct the balance\n      nowMoney: function () {\n        return console.log(money);\n      },\n      count: function (price) {\n        if(money \u003C price) return console.log('Insufficient balance, current balance: ' + money + ' $'); \u002F\u002F if price is greater than the current balance, return an error\n        if (!money \u003C= 0) { \u002F\u002F if money equals 0 or is less, skip the calculation\n          return money = money - price;\n        }\n        return console.log('Deduction failed, current balance: ' + money + ' $');\n      }\n    }\n  }\n}\n\u002F\u002F Ming's a bit broke, only loads 500$\nvar ming = myMoney(500);\n\u002F\u002F Mei's loaded, tops up 5000$\nvar mei = myMoney(5000);\n\u002F\u002F Wang's got money from who-knows-where, tops up 30000$\nvar wang = myMoney(30000);\n\n\u002F\u002F Ming spends 500$ over three days\nming().count(100);\nming().count(100);\nming().count(300);\n\u002F\u002F check Ming's current balance\nming().nowMoney();\n\u002F\u002F Mei spends 2300\nmei().count(1600);\nmei().count(100);\nmei().count(600);\n\u002F\u002F check Mei's current balance\nmei().nowMoney();\n\u002F\u002F Wang only spends 300\nwang().count(300);\n\u002F\u002F check Wang's current balance\nwang().nowMoney();\n",[63,735,736,749,760,769,781,791,803,815,820,836,878,902,917,922,945,951,957,962,967,973,992,998,1017,1023,1042,1047,1053,1070,1085,1101,1107,1119,1125,1142,1157,1173,1179,1190,1196,1212,1218],{"__ignoreMap":61},[31,737,738,740,742,744,747],{"class":67,"line":68},[31,739,92],{"class":71},[31,741,261],{"class":95},[31,743,126],{"class":75},[31,745,746],{"class":266},"storage",[31,748,270],{"class":75},[31,750,751,753,755,757],{"class":67,"line":89},[31,752,105],{"class":71},[31,754,277],{"class":75},[31,756,79],{"class":71},[31,758,759],{"class":75}," storage;\n",[31,761,762,764,766],{"class":67,"line":102},[31,763,120],{"class":75},[31,765,123],{"class":95},[31,767,768],{"class":75},"(money);\n",[31,770,771,773,775,777,779],{"class":67,"line":117},[31,772,138],{"class":71},[31,774,141],{"class":71},[31,776,126],{"class":75},[31,778,267],{"class":266},[31,780,270],{"class":75},[31,782,783,785,788],{"class":67,"line":135},[31,784,444],{"class":71},[31,786,787],{"class":75}," { ",[31,789,790],{"class":320},"\u002F\u002F use an object of functions to check and deduct the balance\n",[31,792,793,796,799,801]