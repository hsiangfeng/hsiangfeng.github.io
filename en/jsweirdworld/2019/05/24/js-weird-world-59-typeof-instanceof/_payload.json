[{"data":1,"prerenderedAt":617},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F24\u002Fjs-weird-world-59-typeof-instanceof\u002F":3,"page:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F24\u002Fjs-weird-world-59-typeof-instanceof\u002F":4,"alt:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F24\u002Fjs-weird-world-59-typeof-instanceof\u002F":3,"prev-next:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F24\u002Fjs-weird-world-59-typeof-instanceof\u002F":593,"related:\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F24\u002Fjs-weird-world-59-typeof-instanceof\u002F":602},"\u002Fjsweirdworld\u002F20190524\u002F3586839887\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":576,"date":577,"description":578,"extension":579,"lang":580,"meta":581,"navigation":249,"path":582,"readingMinutes":583,"seo":584,"standalone":585,"stem":586,"tags":587,"tldr":590,"updated":577,"url":591,"__hash__":592},"content\u002Fen\u002FJsWeirdWorld\u002Fjs-weird-world-59-typeof-instanceof.md","[JS Weird World] No.59 typeof, instanceof, and Figuring Out What Something Actually Is","1000427629",{"type":9,"value":10,"toc":571},"minimark",[11,16,32,36,44,58,400,403,410,413,419,430,436,442,486,492,507,513,519,532,544,550,556,560,567],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19,20,24,25,27,28,31],"p",{},"By now we know JavaScript is a dynamically typed language. That lets us do some pretty special things, but it's also dangerous. Usually when we want to know a variable's type, we reach for ",[21,22,23],"code",{},"typeof"," — but the thing is, that method isn't actually that great. So this chapter walks through ",[21,26,23],{}," and ",[21,29,30],{},"instanceof",".",[12,33,35],{"id":34},"typeof-and-instanceof","typeof and instanceof",[17,37,38,39,43],{},"I know the title — ",[40,41,42],"strong",{},"typeof, instanceof, and figuring out what something is"," — reads kind of weird. The original is \"typeof, instanceof, and figuring out what something is.\" But that's the course's chapter title, so I'm just keeping it. Let's jump straight into an example.",[17,45,46,47,49,50,53,54,57],{},"Side note: the course writes ",[21,48,23],{}," like ",[21,51,52],{},"console.log(typeof a);",", while I'm used to writing it ",[21,55,56],{},"console.log(typeof(a));",". Both give the same result, so don't worry about it.",[59,60,65],"pre",{"className":61,"code":62,"language":63,"meta":64,"style":64},"language-js shiki shiki-themes github-dark-high-contrast","var a = 3;\nconsole.log('a: ' + typeof(a));\nvar b = 'Hello';\nconsole.log('b: ' + typeof(b));\nvar c = {};\nconsole.log('c: ' + typeof(c)); \nvar d = [];\nconsole.log('d: ' + typeof(d));\nconsole.log('d prototype call: ' + Object.prototype.toString.call(d));\n\nfunction Person (name) {\n  this.name = name;\n}\n\nvar e = new Person('Jane');\nconsole.log('e: ' + typeof(e));\nconsole.log(e instanceof Person);\nconsole.log('undefined: ' + typeof(undefined));\nconsole.log('null: ' + typeof(null));\n","js","",[21,66,67,90,116,131,150,163,182,195,214,244,251,270,284,290,295,318,337,353,377],{"__ignoreMap":64},[68,69,72,76,80,83,87],"span",{"class":70,"line":71},"line",1,[68,73,75],{"class":74},"sWyjQ","var",[68,77,79],{"class":78},"sMAXC"," a ",[68,81,82],{"class":74},"=",[68,84,86],{"class":85},"sCcAr"," 3",[68,88,89],{"class":78},";\n",[68,91,93,96,100,103,107,110,113],{"class":70,"line":92},2,[68,94,95],{"class":78},"console.",[68,97,99],{"class":98},"sj_SG","log",[68,101,102],{"class":78},"(",[68,104,106],{"class":105},"sTRMh","'a: '",[68,108,109],{"class":74}," +",[68,111,112],{"class":74}," typeof",[68,114,115],{"class":78},"(a));\n",[68,117,119,121,124,126,129],{"class":70,"line":118},3,[68,120,75],{"class":74},[68,122,123],{"class":78}," b ",[68,125,82],{"class":74},[68,127,128],{"class":105}," 'Hello'",[68,130,89],{"class":78},[68,132,134,136,138,140,143,145,147],{"class":70,"line":133},4,[68,135,95],{"class":78},[68,137,99],{"class":98},[68,139,102],{"class