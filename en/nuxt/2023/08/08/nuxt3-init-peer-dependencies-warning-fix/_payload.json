roject scaffolded. Following the prompt, change directory:",[28,60,62],{"className":30,"code":61,"language":32,"meta":33,"style":33},"cd my-app\n",[35,63,64],{"__ignoreMap":33},[38,65,66,70],{"class":40,"line":41},[38,67,69],{"class":68},"sCcAr","cd",[38,71,55],{"class":48},[17,73,74,75,78],{},"Then install the dependencies. I'm using ",[35,76,77],{},"pnpm",":",[28,80,82],{"className":30,"code":81,"language":32,"meta":33,"style":33},"pnpm install\n",[35,83,84],{"__ignoreMap":33},[38,85,86,88],{"class":40,"line":41},[38,87,77],{"class":44},[38,89,90],{"class":48}," install\n",[17,92,93],{},"After install, you'll see this warning in the terminal:",[28,95,97],{"className":30,"code":96,"language":32,"meta":33,"style":33}," WARN  Issues with peer dependencies found\n.\n└─┬ @nuxt\u002Fdevtools 0.7.5\n  ├── ✕ missing peer vite@\"*\"\n  ├─┬ vite-plugin-inspect 0.7.35\n  │ └── ✕ missing peer vite@\"^3.1.0 || ^4.0.0\"\n  ├─┬ vite-plugin-vue-inspector 3.5.0\n  │ └── ✕ missing peer vite@\"^3.0.0-0 || ^4.0.0-0\"\n  └─┬ @nuxt\u002Fdevtools-kit 0.7.5\n    └── ✕ missing peer vite@\"*\"\n✕ Conflicting peer dependencies:\n  vite\n",[35,98,99,119,125,137,154,166,184,195,211,222,236,250],{"__ignoreMap":33},[38,100,101,104,107,110,113,116],{"class":40,"line":41},[38,102,103],{"class":44}," WARN",[38,105,106],{"class":48},"  Issues",[38,108,109],{"class":48}," with",[38,111,112],{"class":48}," peer",[38,114,115],{"class":48}," dependencies",[38,117,118],{"class":48}," found\n",[38,120,122],{"class":40,"line":121},2,[38,123,124],{"class":68},".\n",[38,126,128,131,134],{"class":40,"line":127},3,[38,129,130],{"class":44},"└─┬",[38,132,133],{"class":48}," @nuxt\u002Fdevtools",[38,135,136],{"class":68}," 0.7.5\n",[38,138,140,143,146,149,151],{"class":40,"line":139},4,[38,141,142],{"class":44},"  ├──",[38,144,145],{"class":48}," ✕",[38,147,148],{"class":48}," missing",[38,150,112],{"class":48},[38,152,153],{"class":48}," vite@\"*\"\n",[38,155,157,160,163],{"class":40,"line":156},5,[38,158,159],{"class":44},"  ├─┬",[38,161,162],{"class":48}," vite-plugin-inspect",[38,164,165],{"class":68}," 0.7.35\n",[38,167,169,172,175,177,179,181],{"class":40,"line":168},6,[38,170,171],{"class":44},"  │",[38,173,174],{"class":48}," └──",[38,176,145],{"class":48},[38,178,148],{"class":48},[38,180,112],{"class":48},[38,182,183],{"class":48}," vite@\"^3.1.0 || ^4.0.0\"\n",[38,185,187,189,192],{"class":40,"line":186},7,[38,188,159],{"class":44},[38,190,191],{"class":48}," vite-plugin-vue-inspector",[38,193,194],{"class":68}," 3.5.0\n",[38,196,198,200,202,204,206,208],{"class":40,"line":197},8,[38,199,171],{"class":44},[38,201,174],{"class":48},[38,203,145],{"class":48},[38,205,148],{"class":48},[38,207,112],{"class":48},[38,209,210],{"class":48}," vite@\"^3.0.0-0 || ^4.0.0-0\"\n",[38,212,214,217,220],{"class":40,"line":213},9,[38,215,216],{"class":44},"  └─┬",[38,218,219],{"class":48}," @nuxt\u002Fdevtools-kit",[38,221,136],{"class":68},[38,223,225,228,230,232,234],{"class":40,"line":224},10,[38,226,227],{"class":44},"    └──",[38,229,145],{"class":48},[38,231,148],{"class":48},[38,233,112],{"class":48},[38,235,153],{"class":48},[38,237,239,242,245,247],{"class":40,"line":238},11,[38,240,241],{"class":44},"✕",[38,243,244],{"class":48}," Conflicting",[38,246,112],{"class":48},[38,248,249],{"class":48}," dependencies:\n",[38,251,253],{"class":40,"line":252},12,[38,254,255],{"class":44},"  vite\n",[17,257,258],{},[259,260],"img",{"alt":261,"src":262},"Issues with peer dependencies found","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt-init-warn\u002F2023-08-08%2013.52.05.png",[12,264,266],{"id":265},"how-to-fix-it","How to fix it",[17,268,269,270,273],{},"Running ",[35,271,272],{},"pnpm run dev"," actually works fine:",[28,275,277],{"className":30,"code":276,"language":32,"meta":33,"style":33},"[1:55:04 PM] Nuxi 3.6.5\n[1:55:04 PM] Nuxt 3.6.5 with Nitro 2.5.2\n[1:55:06 PM] \n  > Local:    http:\u002F\u002Flocalhost:3000\u002F \n  > Network:  http:\u002F\u002F192.168.100.38:3000\u002F\n\n[1:55:06 PM] ✔ Nuxt Devtools is enabled v0.7.5 (experimental)\n",[35,278,279,285,290,295,310,320,326],{"__ignoreMap":33},[38,280,281],{"class":40,"line":41},[38,282,284],{"class":283},"sMAXC","[1:55:04 PM] Nuxi 3.6.5\n",[38,286,287],{"class":40,"line":121},[38,288,289],{"class":283},"[1:55:04 PM] Nuxt 3.6.5 with Nitro 2.5.2\n",[38,291,292],{"class":40,"line":127},[38,293,294],{"class":283},"[1:55:06 PM] \n",[38,296,297,301,304,307],{"class":40,"line":139},[38,298,300],{"class":299},"sWyjQ","  >",[38,302,303],{"class":44}," Local:",[38,305,306],{"class":48},"    http:\u002F\u002Flocalhost:3000\u002F",[38,308,309],{"class":283}," \n",[38,311,312,314,317],{"class":40,"line":156},[38,313,300],{"class":299},[38,315,316],{"class":44}," Network:",[38,318,319],{"class":48},"  http:\u002F\u002F192.168.100.38:3000\u002F\n",[38,321,322],{"class":40,"line":168},[38,323,325],{"emptyLinePlaceholder":324},true,"\n",[38,327,328,331,334],{"class":40,"line":186},[38,329,330],{"class":283},"[1:55:06 PM] ✔ Nuxt Devtools is enabled v0.7.5 (",[38,332,333],{"class":44},"experimental",[38,335,336],{"class":283},")\n",[17,338,339],{},"But seeing the warning still bugged me, so I dug in.",[17,341,342,343,346],{},"Package managers check peer dependencies when installing. The warning shows up because ",[35,344,345],{},"@nuxt\u002Fdevtools"," is missing Vite as a peer dep.",[17,348,349],{},"There are two fixes. First — just install Vite explicitly:",[28,351,353],{"className":30,"code":352,"language":32,"meta":33,"style":33},"pnpm install vite\n",[35,354,355],{"__ignoreMap":33},[38,356,357,359,362],{"class":40,"line":41},[38,358,77],{"class":44},[38,360,361],{"class":48}," install",[38,363,364],{"class":48}," vite\n",[17,366,367,368,370],{},"Personally I don't think that's necessary, since Nuxt ships with Vite already — ",[35,369,345],{}," just can't detect it.",[17,372,373,374,377],{},"The second option — open ",[35,375,376],{},".npmrc"," in your Nuxt 3 project and update it to:",[28,379,381],{"className":30,"code":380,"language":32,"meta":33,"style":33},"shamefully-hoist=true\nstrict-peer-dependencies=false\nauto-install-peers=true # add this line\n",[35,382,383,394,404],{"__ignoreMap":33},[38,384,385,388,391],{"class":40,"line":41},[38,386,387],{"class":283},"shamefully-hoist",[38,389,390],{"class":299},"=",[38,392,393],{"class":48},"true\n",[38,395,396,399,401],{"class":40,"line":121},[38,397,398],{"class":283},"strict-peer-dependencies",[38,400,390],{"class":299},[38,402,403],{"class":48},"false\n",[38,405,406,409,411,414],{"class":40,"line":127},[38,407,408],{"class":283},"auto-install-peers",[38,410,390],{"class":299},[38,412,413],{"class":48},"true",[38,415,417],{"class":416},"sQrFR"," # add this line\n",[17,419,420],{},"That clears it up.",[12,422,424],{"id":423},"references","References",[426,427,428],"ul",{},[429,430,431],"li",{},[432,433,437],"a",{"href":434,"rel":435},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fissues\u002F22054",[436],"nofollow","Conflicting peer dependencies",[439,440,441],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4