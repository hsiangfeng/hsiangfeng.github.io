[{"data":1,"prerenderedAt":506},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnuxt\u002F2023\u002F08\u002F08\u002Fnuxt3-nitro-proxy-cors-fix\u002F":3,"page:\u002Fen\u002Fnuxt\u002F2023\u002F08\u002F08\u002Fnuxt3-nitro-proxy-cors-fix\u002F":4,"alt:\u002Fen\u002Fnuxt\u002F2023\u002F08\u002F08\u002Fnuxt3-nitro-proxy-cors-fix\u002F":3,"prev-next:\u002Fen\u002Fnuxt\u002F2023\u002F08\u002F08\u002Fnuxt3-nitro-proxy-cors-fix\u002F":482,"related:\u002Fen\u002Fnuxt\u002F2023\u002F08\u002F08\u002Fnuxt3-nitro-proxy-cors-fix\u002F":491},"\u002Fnuxt\u002F20230808\u002F2129825058\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":464,"date":465,"description":466,"extension":467,"lang":468,"meta":469,"navigation":470,"path":471,"readingMinutes":472,"seo":473,"standalone":474,"stem":475,"tags":476,"tldr":479,"updated":465,"url":480,"__hash__":481},"content\u002Fen\u002FNuxt\u002Fnuxt3-nitro-proxy-cors-fix.md","Solving CORS in Nuxt 3 with Nitro Proxy","2829551802",{"type":9,"value":10,"toc":459},"minimark",[11,19,24,27,31,42,45,48,142,164,167,178,181,245,248,251,260,267,323,326,333,344,348,351,438,447,455],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Nuxt Proxy","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt-proxy\u002F2023-08-08%2010.06.33.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"A quick note on how to use Nitro Proxy to solve CORS issues in Nuxt 3.",[20,28,30],{"id":29},"nitro-proxy","Nitro Proxy",[12,32,33,34,41],{},"Nuxt 3 uses a brand new server engine called ",[35,36,40],"a",{"href":37,"rel":38},"https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fguide\u002Fconcepts\u002Fserver-engine",[39],"nofollow","Nitro",", which ships with a Proxy feature that makes it easy to deal with CORS during dev.",[12,43,44],{},"I hit a small gotcha while playing with Nitro Proxy recently, so I figured I'd write it down.",[12,46,47],{},"Per Nitro's official example, you'd write:",[49,50,55],"pre",{"className":51,"code":52,"language":53,"meta":54,"style":54},"language-ts shiki shiki-themes github-dark-high-contrast","\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  devProxy: {\n    '\u002Fproxy\u002Ftest': 'http:\u002F\u002Flocalhost:3001',\n    '\u002Fproxy\u002Fexample': { target: 'https:\u002F\u002Fexample.com', changeOrigin: true }\n  }\n})\n","ts","",[56,57,58,67,85,92,108,130,136],"code",{"__ignoreMap":54},[59,60,63],"span",{"class":61,"line":62},"line",1,[59,64,66],{"class":65},"sQrFR","\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\n",[59,68,70,74,77,81],{"class":61,"line":69},2,[59,71,73],{"class":72},"sWyjQ","export",[59,75,76],{"class":72}," default",[59,78,80],{"class":79},"sj_SG"," defineNuxtConfig",[59,82,84],{"class":83},"s_sBn","({\n",[59,86,88],{"class":61,"line":87},3,[59,89,91],{"class":90},"sMAXC","  devProxy: {\n",[59,93,95,99,102,105],{"class":61,"line":94},4,[59,96,98],{"class":97},"sTRMh","    '\u002Fproxy\u002Ftest'",[59,100,101],{"class":90},": ",[59,103,104],{"class":97},"'http:\u002F\u002Flocalhost:3001'",[59,106,107],{"class":90},",\n",[59,109,111,114,117,120,123,127],{"class":61,"line":110},5,[59,112,113],{"class":97},"    '\u002Fproxy\u002Fexample'",[59,115,116],{"class":90},": { target: ",[59,118,119],{"class":97},"'https:\u002F\u002Fexample.com'",[59,121,122],{"class":90},", changeOrigin: ",[59,124,126],{"class":125},"sCcAr","true",[59,128,129],{"class":90}," }\n",[59,131,133],{"class":61,"line":132},6,[59,134,135],{"class":90},"  }\n",[59,137,139],{"class":61,"line":138},7,[59,140,141],{"class":83},"})\n",[143,144,145],"blockquote",{},[12,146,147,151,152,157,158,163],{},[148,149,150],"strong",{},"Note","\nNitro's Proxy is built on top of ",[35,153,156],{"href":154,"rel":155},"https:\u002F\u002Fgithub.com\u002Fhttp-party\u002Fnode-http-proxy",[39],"node-http-proxy",". For other options, check ",[35,159,162],{"href":160,"rel":161},"https:\u002F\u002Fgithub.com\u002Fhttp-party\u002Fnode-http-proxy#options",[39],"node-http-proxy#options",".",[12,165,166],{},"Say your remote API looks like:",[49,168,172],{"className":169,"code":170,"language":171,"meta":54,"style":54},"language-bash shiki shiki-themes github-dark-high-contrast","https:\u002F\u002Fapi-example.com\u002Fapi\u002Fv1\u002Fusers\u002Fprofile\n","bash",[56,173,174],{"__ignoreMap":54},[59,175,176],{"class":61,"line":62},[59,177,170],{"class":83},[12,179,180],{},"You'd probably write something like:",[49,182,184],{"className":51,"code":183,"language":53,"meta":54,"style":54},"\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  devProxy: {\n    '\u002Fapi': {\n      target: 'https:\u002F\u002Fapi-example.com',\n      changeOrigin: true\n    }\n  }\n})\n",[56,185,186,190,200,204,212,222,230,235,240],{"__ignoreMap":54},[59,187,188],{"class":61,"line":62},[59,189,66],{"class":65},[59,191,192,194,196,198],{"class":61,"line":69},[59,193,73],{"class":72},[59,195,76],{"class":72},[59,197,80],{"class":79},[59,199,84],{"class":83},[59,201,202],{"class":61,"line":87},[59,203,91],{"class":90},[59,205,206,209],{"class":61,"line":94},[59,207,208],{"class":97},"    '\u002Fapi'",[59,210,211],{"class":90},": {\n",[59,213,214,217,220],{"class":61,"line":110},[59,215,216],{"class":90},"      target: ",[59,218,219],{"class":97},"'https:\u002F\u002Fapi-example.com'",[59,221,107],{"class":90},[59,223,224,227],{"class":61,"line":132},[59,225,226],{"class":90},"      changeOrigin: ",[59,228,229],{"class":125},"true\n",[59,231,232],{"class":61,"line":138},[59,233,234],{"class":90},"    }\n",[59,236,238],{"class":61,"line":237},8,[59,239,135],{"class":90},[59,241,243],{"class":61,"line":242},9,[59,244,141],{"class":83},[12,246,247],{},"(That's how most Proxy packages work.)",[12,249,250],{},"This does solve CORS, but you'll hit another issue — no matter what you do, requests go to:",[49,252,254],{"className":169,"code":253,"language":171,"meta":54,"style":54},"http:\u002F\u002Flocalhost:3000\u002Fv1\u002Fusers\u002Fprofile\n",[56,255,256],{"__ignoreMap":54},[59,257,258],{"class":61,"line":62},[59,259,253],{"class":83},[12,261,262,263,266],{},"Weird, right? So I checked the Proxy Request and found that Nitro Proxy rewrites ",[56,264,265],{},"\u002Fapi"," to empty. You need to write it like this instead:",[49,268,270],{"className":51,"code":269,"language":53,"meta":54,"style":54},"\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  devProxy: {\n    '\u002Fapi': {\n      target: 'https:\u002F\u002Fapi-example.com\u002Fv1',\n      changeOrigin: true\n    }\n  }\n})\n",[56,271,272,276,286,290,296,305,311,315,319],{"__ignoreMap":54},[59,273,274],{"class":61,"line":62},[59,275,66],{"class":65},[59,277,278,280,282,284],{"class":61,"line":69},[59,279,73],{"class":72},[59,281,76],{"class":72},[59,283,80],{"class":79},[59,285,84],{"class":83},[59,287,288],{"class":61,"line":87},[59,289,91],{"class":90},[59,291,292,294],{"class":61,"line":94},[59,293,208],{"class":97},[59,295,211],{"class":90},[59,297,298,300,303],{"class":61,"line":110},[59,299,216],{"class":90},[59,301,302],{"class":97},"'https:\u002F\u002Fapi-example.com\u002Fv1'",[59,304,107],{"class":90},[59,306,307,309],{"class":61,"line":132},[59,308,226],{"class":90},[59,310,229],{"class":125},[59,312,313],{"class":61,"line":138},[59,314,234],{"class":90},[59,316,317],{"class":61,"line":237},[59,318,135],{"class":90},[59,320,321],{"class":61,"line":242},[59,322,141],{"class":83},[12,324,325],{},"Now requests hit the right URL.",[143,327,328],{},[12,329,330,332],{},[148,331,150],{},"\nNitro Proxy is designed to solve CORS during development, so don't use it in production. It's for frontend → API requests; the backend (SSR) won't hit CORS in the first place.",[12,334,335,336,339,340,343],{},"Some posts recommend ",[56,337,338],{},"routeRules",", but the official docs still mark it as \"",[148,341,342],{},"Experimental!","\", so I haven't bothered with it.",[20,345,347],{"id":346},"vite-proxy","Vite Proxy",[12,349,350],{},"If you'd rather use Vite's Proxy instead of Nitro's, the same example becomes:",[49,352,354],{"className":51,"code":353,"language":53,"meta":54,"style":54},"\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  vite: {\n    server: {\n      proxy: {\n        '\u002Fapi': {\n          target: 'https:\u002F\u002Fapi-example.com',\n          changeOrigin: true\n        }\n      }\n    }\n  }\n});\n",[56,355,356,360,370,375,380,385,392,401,408,413,419,424,429],{"__ignoreMap":54},[59,357,358],{"class":61,"line":62},[59,359,66],{"class":65},[59,361,362,364,366,368],{"class":61,"line":69},[59,363,73],{"class":72},[59,365,76],{"class":72},[59,367,80],{"class":79},[59,369,84],{"class":83},[59,371,372],{"class":61,"line":87},[59,373,374],{"class":90},"  vite: {\n",[59,376,377],{"class":61,"line":94},[59,378,379],{"class":90},"    server: {\n",[59,381,382],{"class":61,"line":110},[59,383,384],{"class":90},"      proxy: {\n",[59,386,387,390],{"class":61,"line":132},[59,388,389],{"class":97},"        '\u002Fapi'",[59,391,211],{"class":90},[59,393,394,397,399],{"class":61,"line":138},[59,395,396],{"class":90},"          target: ",[59,398,219],{"class":97},[59,400,107],{"class":90},[59,402,403,406],{"class":61,"line":237},[59,404,405],{"class":90},"          changeOrigin: ",[59,407,229],{"class":125},[59,409,410],{"class":61,"line":242},[59,411,412],{"class":90},"        }\n",[59,414,416],{"class":61,"line":415},10,[59,417,418],{"class":90},"      }\n",[59,420,422],{"class":61,"line":421},11,[59,423,234],{"class":90},[59,425,427],{"class":61,"line":426},12,[59,428,135],{"class":90},[59,430,432,435],{"class":61,"line":431},13,[59,433,434],{"class":83},"})",[59,436,437],{"class":90},";\n",[12,439,440,