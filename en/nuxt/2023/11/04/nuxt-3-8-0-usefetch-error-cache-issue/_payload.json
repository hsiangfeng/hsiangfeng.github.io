n      statusMessage: 'ID should be an integer',\n    })\n  }\n  return 'All good'\n})\n","js",[28,285,286,305,321,325,345,355,364,374,379,384,392],{"__ignoreMap":70},[74,287,288,291,294,297,301,303],{"class":76,"line":77},[74,289,290],{"class":98},"export",[74,292,293],{"class":98}," default",[74,295,296],{"class":102}," defineEventHandler",[74,298,300],{"class":299},"s_sBn","((event) ",[74,302,112],{"class":98},[74,304,115],{"class":80},[74,306,307,310,313,315,318],{"class":76,"line":95},[74,308,309],{"class":98},"  const",[74,311,312],{"class":88}," id",[74,314,106],{"class":98},[74,316,317],{"class":102}," parseInt",[74,319,320],{"class":80},"(event.context.params.id)\n",[74,322,323],{"class":76,"line":118},[74,324,186],{"emptyLinePlaceholder":185},[74,326,327,330,333,336,339,342],{"class":76,"line":134},[74,328,329],{"class":98},"  if",[74,331,332],{"class":80}," (",[74,334,335],{"class":98},"!",[74,337,338],{"class":80},"Number.",[74,340,341],{"class":102},"isInteger",[74,343,344],{"class":80},"(id)) {\n",[74,346,347,350,353],{"class":76,"line":146},[74,348,349],{"class":98},"    throw",[74,351,352],{"class":102}," createError",[74,354,161],{"class":80},[74,356,357,360,362],{"class":76,"line":164},[74,358,359],{"class":80},"      statusCode: ",[74,361,59],{"class":88},[74,363,143],{"class":80},[74,365,366,369,372],{"class":76,"line":170},[74,367,368],{"class":80},"      statusMessage: ",[74,370,371],{"class":127},"'ID should be an integer'",[74,373,143],{"class":80},[74,375,376],{"class":76,"line":176},[74,377,378],{"class":80},"    })\n",[74,380,381],{"class":76,"line":182},[74,382,383],{"class":80},"  }\n",[74,385,386,389],{"class":76,"line":189},[74,387,388],{"class":98},"  return",[74,390,391],{"class":127}," 'All good'\n",[74,393,394,397],{"class":76,"line":194},[74,395,396],{"class":80},"}",[74,398,399],{"class":299},")\n",[12,401,402],{},"Where does this hit you? Imagine a login screen — if a user types wrong credentials the first time, then types the correct ones the second time, they still can't log in. The API simply won't fire again.",[20,404,406],{"id":405},"how-to-fix-it","How to fix it",[12,408,409],{},"I just mentioned the login scenario. Users will absolutely type wrong credentials, so this is something we have to fix.",[12,411,412,413,416,417,420],{},"Basically any ",[28,414,415],{},"4xx"," or ",[28,418,419],{},"5xx"," triggers the issue, but refreshing the page lets it fire again — which tells you our error is being cached.",[12,422,423],{},"I found the matching issue on the official tracker:",[425,426,427],"ul",{},[428,429,430],"li",{},[431,432,436],"a",{"href":433,"rel":434},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fissues\u002F24008",[435],"nofollow","useFetch cache Error response and never load it again",[12,438,439,440,445],{},"The official team also opened a PR (",[431,441,444],{"href":442,"rel":443},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fpull\u002F23889\u002Ffiles",[435],"fix(nuxt): only skip refetching errors when hydrating",") to fix it. The change rewrites...",[65,447,449],{"className":281,"code":448,"language":283,"meta":70,"style":70},"if (asyncData.error.value || (fetchOnServer && nuxt.isHydrating && hasCachedData())) ...\n",[28,450,451],{"__ignoreMap":70},[74,452,453,456,459,462,465,468,471,473,476,479],{"class":76,"line":77},[74,454,455],{"class":98},"if",[74,457,458],{"class":80}," (asyncData.error.value ",[74,460,461],{"class":98},"||",[74,463,464],{"class":80}," (fetchOnServer ",[74,466,467],{"class":98},"&&",[74,469,470],{"class":80}," nuxt.isHydrating ",[74,472,467],{"class":98},[74,474,475],{"class":102}," hasCachedData",[74,477,478],{"class":80},"())) ",[74,480,481],{"class":98},"...\n",[12,483,484],{},"...to:",[65,486,488],{"className":281,"code":487,"language":283,"meta":70,"style":70},"if (fetchOnServer && nuxt.isHydrating && (asyncData.error.value || hasCachedData())) ...\n",[28,489,490],{"__ignoreMap":70},[74,491,492,494,496,498,500,502,504,506,508,510],{"class":76,"line":77},[74,493,455],{"class":98},[74,495,464],{"class":80},[74,497,467],{"class":98},[74,499,470],{"class":80},[74,501,467],{"class":98},[74,503,458],{"class":80},[74,505,461],{"class":98},[74,507,475],{"class":102},[74,509,478],{"class":80},[74,511,481],{"class":98},[12,513,514],{},"It's been merged, but no new release yet — so we have to handle this ourselves QQ.",[12,516,517,518,521,522,524,525,528],{},"So how do we deal with it? Simplest approach — destructure ",[28,519,520],{},"error"," from ",[28,523,30],{},", and when it errors, set it to ",[28,526,527],{},"null",":",[65,530,532],{"className":67,"code":531,"language":69,"meta":70,"style":70},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n\n  if(error.value) {\n    error.value = null\n    console.log(error.value)\n  }\n}\n\u003C\u002Fscript>\n",[28,533,534,544,558,581,589,601,605,609,613,620,630,641,645,649],{"__ignoreMap":70},[74,535,536,538,540,542],{"class":76,"line":77},[74,537,81],{"class":80},[74,539,85],{"class":84},[74,541,89],{"class":88},[74,543,92],{"class":80},[74,545,546,548,550,552,554,556],{"class":76,"line":95},[74,547,99],{"class":98},[74,549,103],{"class":102},[74,551,106],{"class":98},[74,553,109],{"class":80},[74,555,112],{"class":98},[74,557,115],{"class":80},[74,559,560,562,565,567,570,572,575,577,579],{"class":76,"line":118},[74,561,309],{"class":98},[74,563,564],{"class":80}," { ",[74,566,520],{"class":88},[74,568,569],{"class":80}," } ",[74,571,242],{"class":98},[74,573,574],{"class":102}," useFetch",[74,576,124],{"class":80},[74,578,128],{"class":127},[74,580,131],{"class":80},[74,582,583,585,587],{"class":76,"line":134},[74,584,137],{"class":80},[74,586,140],{"class":127},[74,588,143],{"class":80},[74,590,591,593,595,597,599],{"class":76,"line":146},[74,592,149],{"class":80},[74,594,152],{"class":88},[74,596,155],{"class":80},[74,598,158],{"class":102},[74,600,161],{"class":80},[74,602,603],{"class":76,"line":164},[74,604,167],{"class":80},[74,606,607],{"class":76,"line":170},[74,608,173],{"class":80},[74,610,611],{"class":76,"line":176},[74,612,186],{"emptyLinePlaceholder":185},[74,614,615,617],{"class":76,"line":182},[74,616,329],{"class":98},[74,618,619],{"class":80},"(error.value) {\n",[74,621,622,625,627],{"class":76,"line":189},[74,623,624],{"class":80},"    error.value ",[74,626,242],{"class":98},[74,628,629],{"class":88}," null\n",[74,631,632,635,638],{"class":76,"line":194},[74,633,634],{"class":80},"    console.",[74,636,637],{"class":102},"log",[74,639,640],{"class":80},"(error.value)\n",[74,642,643],{"class":76,"line":204},[74,644,383],{"class":80},[74,646,647],{"class":76,"line":209},[74,648,179],{"class":80},[74,650,651,653,655],{"class":76,"line":219},[74,652,197],{"class":80},[74,654,85],{"class":84},[74,656,92],{"class":80},[12,658,659],{},"With this simple trick, even after an API error you can still trigger the API again.",[12,661,662],{},[15,663],{"alt":664,"src":665},"Back to normal","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt_usefetch_error\u002FNov-04-2023%2000-49-30(1).gif",[12,667,668,669,671,672,675,676,679],{},"What ",[28,670,30],{}," returns is a ",[28,673,674],{},"ref",", so we're leveraging the Proxy's reactivity to clear the error. Lucky for us, Nuxt 3 doesn't make the returned data ",[28,677,678],{},"readonly"," — otherwise this trick wouldn't work.",[12,681,682],{},"There's one drawback — when the API errors, you lose the backend's error message. You can work around it:",[65,684,686],{"className":67,"code":685,"language":69,"meta":70,"style":70},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n\n  if(error.value) {\n    const cacheError = JSON.parse(JSON.stringify(error.value))\n    error.value = null\n    console.log