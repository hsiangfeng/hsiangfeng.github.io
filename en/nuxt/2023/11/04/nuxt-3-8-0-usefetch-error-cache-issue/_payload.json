[{"data":1,"prerenderedAt":906},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":3,"page:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":4,"alt:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":3,"prev-next:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":883,"related:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":892},"\u002Fnuxt\u002F20231104\u002F4026785494\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":865,"date":866,"description":867,"extension":868,"lang":869,"meta":870,"navigation":185,"path":871,"readingMinutes":872,"seo":873,"standalone":874,"stem":875,"tags":876,"tldr":879,"updated":880,"url":881,"__hash__":882},"content\u002Fen\u002FNuxt\u002Fnuxt-3-8-0-usefetch-error-cache-issue.md","Nuxt 3.8.0 useFetch Error Cache Issue","4048457962",{"type":9,"value":10,"toc":860},"minimark",[11,19,24,32,36,39,45,48,54,61,64,272,279,400,403,407,410,421,424,437,446,482,485,512,515,529,657,660,666,680,683,832,835,841,856],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"useFetch Bug","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxy-usefetch-bug\u002Fisray_notarray_nuxt_bug_b1040d0d-398c-452b-b981-d0bffbfede2d.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26,27,31],{},"Hit a weird ",[28,29,30],"code",{},"useFetch"," issue in Nuxt 3 recently — once the API errors out, you can't trigger it again. Here's a note on what's happening.",[20,33,35],{"id":34},"the-problem","The problem",[12,37,38],{},"I'm on Nuxt 3.8.0 with Nitro 2.7.2.",[12,40,41,42,44],{},"When using ",[28,43,30],{},", here's what happens — after the API hits an error, clicking won't trigger the API anymore QQ.",[12,46,47],{},"Here's the situation as a Gif:",[12,49,50],{},[15,51],{"alt":52,"src":53},"API Error","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt_usefetch_error\u002FNov-04-2023%2000-35-31(1).gif",[12,55,56,57,60],{},"After clicking the \"Click for error\" button, it does throw ",[28,58,59],{},"400",", but no matter how many times I click after that, the API never fires again.",[12,62,63],{},"The code is dead simple:",[65,66,71],"pre",{"className":67,"code":68,"language":69,"meta":70,"style":70},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript setup>\nconst apiPostError = () => {\n  useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n}\n\n\n\u003C\u002Fscript>\n\n\u003Ctemplate>\n  \u003Cdiv>\n    \u003Cbutton @click=\"apiPostError\">Click for error\u003C\u002Fbutton>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n","html","",[28,72,73,93,116,132,144,162,168,174,180,187,192,202,207,217,228,253,263],{"__ignoreMap":70},[74,75,78,82,86,90],"span",{"class":76,"line":77},"line",1,[74,79,81],{"class":80},"sMAXC","\u003C",[74,83,85],{"class":84},"sKpQp","script",[74,87,89],{"class":88},"sCcAr"," setup",[74,91,92],{"class":80},">\n",[74,94,96,100,104,107,110,113],{"class":76,"line":95},2,[74,97,99],{"class":98},"sWyjQ","const",[74,101,103],{"class":102},"sj_SG"," apiPostError",[74,105,106],{"class":98}," =",[74,108,109],{"class":80}," () ",[74,111,112],{"class":98},"=>",[74,114,115],{"class":80}," {\n",[74,117,119,122,125,129],{"class":76,"line":118},3,[74,120,121],{"class":102},"  useFetch",[74,123,124],{"class":80},"(",[74,126,128],{"class":127},"sTRMh","'\u002Fapi\u002Fhello'",[74,130,131],{"class":80},", {\n",[74,133,135,138,141],{"class":76,"line":134},4,[74,136,137],{"class":80},"    method: ",[74,139,140],{"class":127},"'POST'",[74,142,143],{"class":80},",\n",[74,145,147,150,153,156,159],{"class":76,"line":146},5,[74,148,149],{"class":80},"    body: ",[74,151,152],{"class":88},"JSON",[74,154,155],{"class":80},".",[74,157,158],{"class":102},"stri