[{"data":1,"prerenderedAt":912},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":3,"page:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":4,"alt:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":3,"prev-next:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":889,"related:\u002Fen\u002Fnuxt\u002F2023\u002F11\u002F04\u002Fnuxt-3-8-0-usefetch-error-cache-issue\u002F":898},"\u002Fnuxt\u002F20231104\u002F4026785494\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":871,"date":872,"description":873,"extension":874,"lang":875,"meta":876,"navigation":186,"path":877,"readingMinutes":878,"seo":879,"standalone":880,"stem":881,"tags":882,"tldr":885,"updated":886,"url":887,"__hash__":888},"content\u002Fen\u002FNuxt\u002Fnuxt-3-8-0-usefetch-error-cache-issue.md","Nuxt 3.8.0 useFetch Error Cache Issue","4048457962",{"type":9,"value":10,"toc":866},"minimark",[11,19,24,32,36,39,45,48,54,61,64,273,280,408,411,415,418,429,432,445,454,490,493,520,523,537,665,668,674,688,691,840,843,849,862],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"useFetch Bug","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxy-usefetch-bug\u002Fisray_notarray_nuxt_bug_b1040d0d-398c-452b-b981-d0bffbfede2d.png",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26,27,31],{},"Hit a weird ",[28,29,30],"code",{},"useFetch"," issue in Nuxt 3 recently — once the API errors out, you can't trigger it again. Here's a note on what's happening.",[20,33,35],{"id":34},"the-problem","The problem",[12,37,38],{},"I'm on Nuxt 3.8.0 with Nitro 2.7.2.",[12,40,41,42,44],{},"When using ",[28,43,30],{},", here's what happens — after the API hits an error, clicking won't trigger the API anymore QQ.",[12,46,47],{},"Here's the situation as a Gif:",[12,49,50],{},[15,51],{"alt":52,"src":53},"API Error","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt_usefetch_error\u002FNov-04-2023%2000-35-31(1).gif",[12,55,56,57,60],{},"After clicking the \"Click for error\" button, it does throw ",[28,58,59],{},"400",", but no matter how many times I click after that, the API never fires again.",[12,62,63],{},"The code is dead simple:",[65,66,71],"pre",{"className":67,"code":68,"language":69,"meta":70,"style":70},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cscript setup>\nconst apiPostError = () => {\n  useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n}\n\n\n\u003C\u002Fscript>\n\n\u003Ctemplate>\n  \u003Cdiv>\n    \u003Cbutton @click=\"apiPostError\">Click for error\u003C\u002Fbutton>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n","html","",[28,72,73,93,116,132,144,163,169,175,181,188,193,203,208,218,229,254,264],{"__ignoreMap":70},[74,75,78,82,86,90],"span",{"class":76,"line":77},"line",1,[74,79,81],{"class":80},"s8XSl","\u003C",[74,83,85],{"class":84},"syv7_","script",[74,87,89],{"class":88},"sK3KL"," setup",[74,91,92],{"class":80},">\n",[74,94,96,100,104,107,110,113],{"class":76,"line":95},2,[74,97,99],{"class":98},"sOudu","const",[74,101,103],{"class":102},"scAaK"," apiPostError",[74,105,106],{"class":98}," =",[74,108,109],{"class":80}," () ",[74,111,112],{"class":98},"=>",[74,114,115],{"class":80}," {\n",[74,117,119,122,125,129],{"class":76,"line":118},3,[74,120,121],{"class":102},"  useFetch",[74,123,124],{"class":80},"(",[74,126,128],{"class":127},"sWayO","'\u002Fapi\u002Fhello'",[74,130,131],{"class":80},", {\n",[74,133,135,138,141],{"class":76,"line":134},4,[74,136,137],{"class":80},"    method: ",[74,139,140],{"class":127},"'POST'",[74,142,143],{"class":80},",\n",[74,145,147,150,154,157,160],{"class":76,"line":146},5,[74,148,149],{"class":80},"    body: ",[74,151,153],{"class":152},"stw71","JSON",[74,155,156],{"class":80},".",[74,158,159],{"class":102},"stringify",[74,161,162],{"class":80},"({\n",[74,164,166],{"class":76,"line":165},6,[74,167,168],{"class":80},"    }),\n",[74,170,172],{"class":76,"line":171},7,[74,173,174],{"class":80},"  })\n",[74,176,178],{"class":76,"line":177},8,[74,179,180],{"class":80},"}\n",[74,182,184],{"class":76,"line":183},9,[74,185,187],{"emptyLinePlaceholder":186},true,"\n",[74,189,191],{"class":76,"line":190},10,[74,192,187],{"emptyLinePlaceholder":186},[74,194,196,199,201],{"class":76,"line":195},11,[74,197,198],{"class":80},"\u003C\u002F",[74,200,85],{"class":84},[74,202,92],{"class":80},[74,204,206],{"class":76,"line":205},12,[74,207,187],{"emptyLinePlaceholder":186},[74,209,211,213,216],{"class":76,"line":210},13,[74,212,81],{"class":80},[74,214,215],{"class":84},"template",[74,217,92],{"class":80},[74,219,221,224,227],{"class":76,"line":220},14,[74,222,223],{"class":80},"  \u003C",[74,225,226],{"class":84},"div",[74,228,92],{"class":80},[74,230,232,235,238,241,244,247,250,252],{"class":76,"line":231},15,[74,233,234],{"class":80},"    \u003C",[74,236,237],{"class":84},"button",[74,239,240],{"class":88}," @click",[74,242,243],{"class":80},"=",[74,245,246],{"class":127},"\"apiPostError\"",[74,248,249],{"class":80},">Click for error\u003C\u002F",[74,251,237],{"class":84},[74,253,92],{"class":80},[74,255,257,260,262],{"class":76,"line":256},16,[74,258,259],{"class":80},"  \u003C\u002F",[74,261,226],{"class":84},[74,263,92],{"class":80},[74,265,267,269,271],{"class":76,"line":266},17,[74,268,198],{"class":80},[74,270,215],{"class":84},[74,272,92],{"class":80},[12,274,275,276,279],{},"And ",[28,277,278],{},"\u002Fapi\u002Fhello"," is just an API I built with Nuxt 3's API Routes:",[65,281,285],{"className":282,"code":283,"language":284,"meta":70,"style":70},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","export default defineEventHandler((event) => {\n  const id = parseInt(event.context.params.id)\n\n  if (!Number.isInteger(id)) {\n    throw createError({\n      statusCode: 400,\n      statusMessage: 'ID should be an integer',\n    })\n  }\n  return 'All good'\n})\n","js",[28,286,287,313,329,333,353,363,372,382,387,392,400],{"__ignoreMap":70},[74,288,289,292,295,298,302,306,309,311],{"class":76,"line":77},[74,290,291],{"class":98},"export",[74,293,294],{"class":98}," default",[74,296,297],{"class":102}," defineEventHandler",[74,299,301],{"class":300},"sTzn1","((",[74,303,305],{"class":304},"syBk-","event",[74,307,308],{"class":300},") ",[74,310,112],{"class":98},[74,312,115],{"class":80},[74,314,315,318,321,323,326],{"class":76,"line":95},[74,316,317],{"class":98},"  const",[74,319,320],{"class":152}," id",[74,322,106],{"class":98},[74,324,325],{"class":102}," parseInt",[74,327,328],{"class":80},"(event.context.params.id)\n",[74,330,331],{"class":76,"line":118},[74,332,187],{"emptyLinePlaceholder":186},[74,334,335,338,341,344,347,350],{"class":76,"line":134},[74,336,337],{"class":98},"  if",[74,339,340],{"class":80}," (",[74,342,343],{"class":98},"!",[74,345,346],{"class":80},"Number.",[74,348,349],{"class":102},"isInteger",[74,351,352],{"class":80},"(id)) {\n",[74,354,355,358,361],{"class":76,"line":146},[74,356,357],{"class":98},"    throw",[74,359,360],{"class":102}," createError",[74,362,162],{"class":80},[74,364,365,368,370],{"class":76,"line":165},[74,366,367],{"class":80},"      statusCode: ",[74,369,59],{"class":152},[74,371,143],{"class":80},[74,373,374,377,380],{"class":76,"line":171},[74,375,376],{"class":80},"      statusMessage: ",[74,378,379],{"class":127},"'ID should be an integer'",[74,381,143],{"class":80},[74,383,384],{"class":76,"line":177},[74,385,386],{"class":80},"    })\n",[74,388,389],{"class":76,"line":183},[74,390,391],{"class":80},"  }\n",[74,393,394,397],{"class":76,"line":190},[74,395,396],{"class":98},"  return",[74,398,399],{"class":127}," 'All good'\n",[74,401,402,405],{"class":76,"line":195},[74,403,404],{"class":80},"}",[74,406,407],{"class":300},")\n",[12,409,410],{},"Where does this hit you? Imagine a login screen — if a user types wrong credentials the first time, then types the correct ones the second time, they still can't log in. The API simply won't fire again.",[20,412,414],{"id":413},"how-to-fix-it","How to fix it",[12,416,417],{},"I just mentioned the login scenario. Users will absolutely type wrong credentials, so this is something we have to fix.",[12,419,420,421,424,425,428],{},"Basically any ",[28,422,423],{},"4xx"," or ",[28,426,427],{},"5xx"," triggers the issue, but refreshing the page lets it fire again — which tells you our error is being cached.",[12,430,431],{},"I found the matching issue on the official tracker:",[433,434,435],"ul",{},[436,437,438],"li",{},[439,440,444],"a",{"href":441,"rel":442},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fissues\u002F24008",[443],"nofollow","useFetch cache Error response and never load it again",[12,446,447,448,453],{},"The official team also opened a PR (",[439,449,452],{"href":450,"rel":451},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fpull\u002F23889\u002Ffiles",[443],"fix(nuxt): only skip refetching errors when hydrating",") to fix it. The change rewrites...",[65,455,457],{"className":282,"code":456,"language":284,"meta":70,"style":70},"if (asyncData.error.value || (fetchOnServer && nuxt.isHydrating && hasCachedData())) ...\n",[28,458,459],{"__ignoreMap":70},[74,460,461,464,467,470,473,476,479,481,484,487],{"class":76,"line":77},[74,462,463],{"class":98},"if",[74,465,466],{"class":80}," (asyncData.error.value ",[74,468,469],{"class":98},"||",[74,471,472],{"class":80}," (fetchOnServer ",[74,474,475],{"class":98},"&&",[74,477,478],{"class":80}," nuxt.isHydrating ",[74,480,475],{"class":98},[74,482,483],{"class":102}," hasCachedData",[74,485,486],{"class":80},"())) ",[74,488,489],{"class":98},"...\n",[12,491,492],{},"...to:",[65,494,496],{"className":282,"code":495,"language":284,"meta":70,"style":70},"if (fetchOnServer && nuxt.isHydrating && (asyncData.error.value || hasCachedData())) ...\n",[28,497,498],{"__ignoreMap":70},[74,499,500,502,504,506,508,510,512,514,516,518],{"class":76,"line":77},[74,501,463],{"class":98},[74,503,472],{"class":80},[74,505,475],{"class":98},[74,507,478],{"class":80},[74,509,475],{"class":98},[74,511,466],{"class":80},[74,513,469],{"class":98},[74,515,483],{"class":102},[74,517,486],{"class":80},[74,519,489],{"class":98},[12,521,522],{},"It's been merged, but no new release yet — so we have to handle this ourselves QQ.",[12,524,525,526,529,530,532,533,536],{},"So how do we deal with it? Simplest approach — destructure ",[28,527,528],{},"error"," from ",[28,531,30],{},", and when it errors, set it to ",[28,534,535],{},"null",":",[65,538,540],{"className":67,"code":539,"language":69,"meta":70,"style":70},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n\n  if(error.value) {\n    error.value = null\n    console.log(error.value)\n  }\n}\n\u003C\u002Fscript>\n",[28,541,542,552,566,589,597,609,613,617,621,628,638,649,653,657],{"__ignoreMap":70},[74,543,544,546,548,550],{"class":76,"line":77},[74,545,81],{"class":80},[74,547,85],{"class":84},[74,549,89],{"class":88},[74,551,92],{"class":80},[74,553,554,556,558,560,562,564],{"class":76,"line":95},[74,555,99],{"class":98},[74,557,103],{"class":102},[74,559,106],{"class":98},[74,561,109],{"class":80},[74,563,112],{"class":98},[74,565,115],{"class":80},[74,567,568,570,573,575,578,580,583,585,587],{"class":76,"line":118},[74,569,317],{"class":98},[74,571,572],{"class":80}," { ",[74,574,528],{"class":152},[74,576,577],{"class":80}," } ",[74,579,243],{"class":98},[74,581,582],{"class":102}," useFetch",[74,584,124],{"class":80},[74,586,128],{"class":127},[74,588,131],{"class":80},[74,590,591,593,595],{"class":76,"line":134},[74,592,137],{"class":80},[74,594,140],{"class":127},[74,596,143],{"class":80},[74,598,599,601,603,605,607],{"class":76,"line":146},[74,600,149],{"class":80},[74,602,153],{"class":152},[74,604,156],{"class":80},[74,606,159],{"class":102},[74,608,162],{"class":80},[74,610,611],{"class":76,"line":165},[74,612,168],{"class":80},[74,614,615],{"class":76,"line":171},[74,616,174],{"class":80},[74,618,619],{"class":76,"line":177},[74,620,187],{"emptyLinePlaceholder":186},[74,622,623,625],{"class":76,"line":183},[74,624,337],{"class":98},[74,626,627],{"class":80},"(error.value) {\n",[74,629,630,633,635],{"class":76,"line":190},[74,631,632],{"class":80},"    error.value ",[74,634,243],{"class":98},[74,636,637],{"class":152}," null\n",[74,639,640,643,646],{"class":76,"line":195},[74,641,642],{"class":80},"    console.",[74,644,645],{"class":102},"log",[74,647,648],{"class":80},"(error.value)\n",[74,650,651],{"class":76,"line":205},[74,652,391],{"class":80},[74,654,655],{"class":76,"line":210},[74,656,180],{"class":80},[74,658,659,661,663],{"class":76,"line":220},[74,660,198],{"class":80},[74,662,85],{"class":84},[74,664,92],{"class":80},[12,666,667],{},"With this simple trick, even after an API error you can still trigger the API again.",[12,669,670],{},[15,671],{"alt":672,"src":673},"Back to normal","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt_usefetch_error\u002FNov-04-2023%2000-49-30(1).gif",[12,675,676,677,679,680,683,684,687],{},"What ",[28,678,30],{}," returns is a ",[28,681,682],{},"ref",", so we're leveraging the Proxy's reactivity to clear the error. Lucky for us, Nuxt 3 doesn't make the returned data ",[28,685,686],{},"readonly"," — otherwise this trick wouldn't work.",[12,689,690],{},"There's one drawback — when the API errors, you lose the backend's error message. You can work around it:",[65,692,694],{"className":67,"code":693,"language":69,"meta":70,"style":70},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\