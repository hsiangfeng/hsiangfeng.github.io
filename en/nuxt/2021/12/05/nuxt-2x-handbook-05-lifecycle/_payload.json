ycle hooks, not the Vue lifecycle you might know. Vue itself doesn't have any of these.",[17,65,66,67,70,71,74],{},"Also, ",[34,68,69],{},"this"," won't work in these hooks — you'll get ",[34,72,73],{},"undefined",":",[28,76,77,81,85,89],{},[31,78,79,37],{},[34,80,36],{},[31,82,83,43],{},[34,84,42],{},[31,86,87,49],{},[34,88,48],{},[31,90,91,55],{},[34,92,54],{},[17,94,95,96,98],{},"That's because these run on the server, so there's no ",[34,97,69],{},".",[12,100,102],{"id":101},"nuxtserverinit-server-init","nuxtServerInit (server init)",[17,104,105,107],{},[34,106,36],{}," fires when Nuxt.js initializes the environment. You can use this to initialize Vuex:",[109,110,115],"pre",{"className":111,"code":112,"language":113,"meta":114,"style":114},"language-js shiki shiki-themes github-dark-high-contrast","export default {\n  nuxtServerInit (store, content) {\n    console.log('nuxtServerInit');\n  },\n}\n","js","",[34,116,117,133,147,166,175],{"__ignoreMap":114},[118,119,122,126,129],"span",{"class":120,"line":121},"line",1,[118,123,125],{"class":124},"sWyjQ","export",[118,127,128],{"class":124}," default",[118,130,132],{"class":131},"s_sBn"," {\n",[118,134,136,140,143],{"class":120,"line":135},2,[118,137,139],{"class":138},"sj_SG","  nuxtServerInit",[118,141,142],{"class":131}," (store, content) ",[118,144,146],{"class":145},"sMAXC","{\n",[118,148,150,153,156,159,163],{"class":120,"line":149},3,[118,151,152],{"class":145},"    console.",[118,154,155],{"class":138},"log",[118,157,158],{"class":145},"(",[118,160,162],{"class":161},"sTRMh","'nuxtServerInit'",[118,164,165],{"class":145},");\n",[118,167,169,172],{"class":120,"line":168},4,[118,170,171],{"class":145},"  }",[118,173,174],{"class":131},",\n",[118,176,178],{"class":120,"line":177},5,[118,179,180],{"class":131},"}\n",[12,182,42],{"id":42},[17,184,185,187],{},[34,186,42],{}," comes in three flavors — Global, Layout, and Page. Watch the execution order though: Nuxt.js runs middleware in the order Global → Layout →