[{"data":1,"prerenderedAt":528},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fnuxt\u002F2021\u002F10\u002F11\u002Fnuxt-2x-handbook-01-intro-and-setup\u002F":3,"page:\u002Fen\u002Fnuxt\u002F2021\u002F10\u002F11\u002Fnuxt-2x-handbook-01-intro-and-setup\u002F":4,"alt:\u002Fen\u002Fnuxt\u002F2021\u002F10\u002F11\u002Fnuxt-2x-handbook-01-intro-and-setup\u002F":3,"prev-next:\u002Fen\u002Fnuxt\u002F2021\u002F10\u002F11\u002Fnuxt-2x-handbook-01-intro-and-setup\u002F":505,"related:\u002Fen\u002Fnuxt\u002F2021\u002F10\u002F11\u002Fnuxt-2x-handbook-01-intro-and-setup\u002F":514},"\u002Fnuxt\u002F20211011\u002F3406447097\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":488,"date":489,"description":19,"extension":490,"lang":491,"meta":492,"navigation":120,"path":493,"readingMinutes":494,"seo":495,"standalone":496,"stem":497,"tags":498,"tldr":502,"updated":489,"url":503,"__hash__":504},"content\u002Fen\u002FNuxt\u002Fnuxt-2x-handbook-01-intro-and-setup.md","Nuxt.js 2.x Hands-On Handbook (1) — Nuxt.js & Setup","3474406907",{"type":9,"value":10,"toc":481},"minimark",[11,16,20,24,33,36,39,81,93,96,100,103,139,146,155,158,239,242,245,273,276,280,283,300,303,311,314,334,345,451,454,461,464,468,477],[12,13,15],"h2",{"id":14},"intro","Intro",[17,18,19],"p",{},"Nuxt.js is a framework built on Vue.js, Node.js, and Webpack. I've got some Nuxt.js experience from past projects, so I figured I'd write a series to document it.",[12,21,23],{"id":22},"getting-to-know-nuxtjs","Getting to know Nuxt.js",[17,25,26,27,32],{},"First, why use Nuxt.js, and what even is it? Before going further I'd recommend reading my earlier post — \"",[28,29,31],"a",{"href":30},"\u002Fen\u002Fmisc\u002F2021\u002F05\u002F29\u002Fspa-csr-ssr-mpa-ssg-explained\u002F","SPA, CSR, SSR, MPA, SSG — A Quick Take on Frontend Terminology","\". You really need to know what SPA and SSR are first, or this will be rough.",[17,34,35],{},"OK, back to the topic.",[17,37,38],{},"Websites built with JavaScript frameworks all share a common issue — SEO. When a crawler hits your site, what it sees is basically an empty element:",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cdiv id=\"app\">\u003C\u002Fdiv>\n","html","",[47,48,49],"code",{"__ignoreMap":45},[50,51,54,58,62,66,69,73,76,78],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sMAXC","\u003C",[50,59,61],{"class":60},"sKpQp","div",[50,63,65],{"class":64},"sCcAr"," id",[50,67,68],{"class":56},"=",[50,70,72],{"class":71},"sTRMh","\"app\"",[50,74,75],{"class":56},">\u003C\u002F",[50,77,61],{"class":60},[50,79,80],{"class":56},">\n",[17,82,83,84,88,89,92],{},"Everything on screen gets ",[85,86,87],"strong",{},"dynamically written in"," by JavaScript — imagine a giant pile of ",[47,90,91],{},"innerHTML",". So when crawlers read the page, they can't get the content. SPA solves UX issues, but it creates SEO issues. Nuxt.js exists to fix that.",[17,94,95],{},"I don't want to get too theoretical — just know what Nuxt.js is trying to solve, and let's jump into the hands-on stuff.",[12,97,99],{"id":98},"creating-a-nuxtjs-project","Creating a Nuxt.js project",[17,101,102],{},"There are three ways to scaffold a Nuxt.js project — Yarn, NPX, and npm:",[40,104,108],{"className":105,"code":106,"language":107,"meta":45,"style":45},"language-cmd shiki shiki-themes github-dark-high-contrast","yarn create nuxt-app \u003Cproject-name>\n\nnpx create-nuxt-app \u003Cproject-name>\n\nnpm init nuxt-app \u003Cproject-name>\n","cmd",[47,109,110,115,122,128,133],{"__ignoreMap":45},[50,111,112],{"class":52,"line":53},[50,113,114],{},"yarn create nuxt-app \u003Cproject-name>\n",[50,116,118],{"class":52,"line":117},2,[50,119,121],{"emptyLinePlaceholder":120},true,"\n",[50,123,125],{"class":52,"line":124},3,[50,126,127],{},"npx create-nuxt-app \u003Cproject-name>\n",[50,129,131],{"class":52,"line":130},4,[50,132,121],{"emptyLinePlaceholder":120},[50,134,136],{"class":52,"line":135},5,[50,137,138],{},"npm init nuxt-app \u003Cproject-name>\n",[17,140,141,142,145],{},"Pick whichever you prefer. I usually go with ",[47,143,144],{},"npx"," — whatever gets the job done:",[40,147,149],{"className":105,"code":148,"language":107,"meta":45,"style":45},"npx create-nuxt-app nuxtExample\n",[47,150,151],{"__ignoreMap":45},[50,152,153],{"class":52,"line":53},[50,154,148],{},[17,156,157],{},"After running the command in your terminal, you'll be walked through some config. Here are the choices I made for this example:",[159,160,161,168,174,180,186,192,198,203,209,215,221,227,233],"ul",{},[162,163,164,165],"li",{},"? Project name: ",[47,166,167],{},"nuxtExample",[162,169,170,171],{},"? Programming language: ",[47,172,173],{},"JavaScript",[162,175,176,177],{},"? Package manager: ",[47,178,179],{},"Npm",[162,181,182,183],{},"? UI framework: ",[47,184,185],{},"None",[162,187,188,189],{},"? Nuxt.js modules: ",[47,190,191],{},"Axios - Promise based HTTP client",[162,193,194,195],{},"? Linting tools: ",[47,196,197],{},"ESLint",[162,199,200,201],{},"? Testing framework: ",[47,202,185],{},[162,204,205,206],{},"? Rendering mode: ",[47,207,208],{},"Universal (SSR \u002F SSG)",[162,210,211,212],{},"? Deployment target: ",[47,213,214],{},"Server (Node.js hosting)",[162,216,217,218],{},"? Development tools: ",[47,219,220],{},"Dependabot (For auto-updating dependencies, GitHub only)",[162,222,223,224],{},"? Continuous integration: ",[47,225,226],{},"GitHub Actions (GitHub only)",[162,228,229,230],{},"? What is your GitHub username? ",[47,231,232],{},"Ray",[162,234,235,236],{},"? Version control system: ",[47,237,238],{},"Git",[17,240,241],{},"This series is mainly about SSR, so naturally I'm picking SSR.",[17,243,244],{},"My example is on 2.15.7. If you want a specific version (say 2.8.1), use:",[40,246,248],{"className":105,"code":247,"language":107,"meta":45,"style":45},"yarn create nuxt-app 2.8.1 \u003Cproject-name>\n\nnpx create-nuxt-app 2.8.1 \u003Cproject-name>\n\nnpm init nuxt-app 2.8.1 \u003Cproject-name>\n",[47,249,250,255,259,264,268],{"__ignoreMap":45},[50,251,252],{"class":52,"line":53},[50,253,254],{},"yarn create nuxt-app 2.8.1 \u003Cproject-name>\n",[50,256,257],{"class":52,"line":117},[50,258,121],{"emptyLinePlaceholder":120},[50,260,261],{"class":52,"line":124},[50,262,263],{},"npx create-nuxt-app 2.8.1 \u003Cproject-name>\n",[50,265,266],{"class":52,"line":130},[50,267,121],{"emptyLinePlaceholder":120},[50,269,270],{"class":52,"line":135},[50,271,272],{},"npm init nuxt-app 2.8.1 \u003Cproject-name>\n",[17,274,275],{},"Once scaffolded, open the project in VSCode.",[12,277,279],{"id":278},"nuxtjs-architecture-setup","Nuxt.js architecture setup",[17,281,282],{},"I'm on version 2.15.7, so the structure is fairly minimal. It looks intimidating but the folders you'll actually touch are these:",[159,284,285,288,291,294,297],{},[162,286,287],{},"nuxt.config.js",[162,289,290],{},"pages",[162,292,293],{},"components",[162,295,296],{},"static",[162,298,299],{},"store",[17,301,302],{},"On 2.15.7 you also need to manually create two more folders:",[159,304,305,308],{},[162,306,307],{},"layouts",[162,309,310],{},"assets",[17,312,313],{},"Nuxt.js made some changes later on, so we need to add them manually for what's coming up. More details later.",[17,315,316,317,319,320,322,323,326,327,333],{},"One more tweak — in ",[47,318,287],{},", set ",[47,321,293],{}," to ",[47,324,325],{},"false",". Around version 2.12~2.13, Nuxt.js introduced auto-import for components. Auto stuff tends to bite, so I'd recommend turning it off. You can read ",[28,328,332],{"href":329,"rel":330},"https:\u002F\u002Fgo.nuxtjs.dev\u002Fconfig-components",[331],"nofollow","the docs"," for what the feature actually does.",[17,335,336,337,340,341,344],{},"If you want to follow along with this handbook, I'd suggest deleting everything under ",[47,338,339],{},"components\u002F",", then changing ",[47,342,343],{},"pages\u002Findex.vue"," to:",[40,346,350],{"className":347,"code":348,"language":349,"meta":45,"style":45},"language-vue shiki shiki-themes github-dark-high-contrast","\u003Ctemplate>\n  \u003Cdiv>\n    \u003Cp>\n      This is a body paragraph\n    \u003C\u002Fp>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\u003Cscript>\nexport default {}\n\u003C\u002Fscript>\n","vue",[47,351,352,361,370,379,384,393,403,413,418,428,442],{"__ignoreMap":45},[50,353,354,356,359],{"class":52,"line":53},[50,355,57],{"class":56},[50,357,358],{"class":60},"template",[50,360,80],{"class":56},[50,362,363,366,368],{"class":52,"line":117},[50,364,365],{"class":56},"  \u003C",[50,367,61],{"class":60},[50,369,80],{"class":56},[50,371,372,375,377],{"class":52,"line":124},[50,373,374],{"class":56},"    \u003C",[50,376,17],{"class":60},[50,378,80],{"class":56},[50,380,381],{"class":52,"line":130},[50,382,383],{"class":56},"      This is a body paragraph\n",[50,385,386,389,391],{"class":52,"line":135},[50,387,388],{"class":56},"    \u003C\u002F",[50,390,17],{"class":60},[50,392,80],{"class":56},[50,394,396,399,401],{"class":52,"line":395},6,[50,397,398],{"class":56},"  \u003C\u002F",[50,400,61],{"class":60},[50,402,80],{"class":56},[50,404,406,409,411],{"class":52,"line":405},7,[50,407,408],{"class":56},"\u003C\u002F",[50,410,358],{"class":60},[50,412,80],{"class":56},[50,414,416],{"class":52,"line":415},8,[50,417,121],{"emptyLinePlaceholder":120},[50,419,421,423,426],{"class":52,"line":420},9,[50,422,57],{"class":56},[50,424,425],{"class":60},"script",[50,427,80],{"class":56},[50,429,431,435,438],{"class":52,"line":430},10,[50,432,434],{"class":433},"sWyjQ","export",[50,436,437],{"class":433}," default",[50,439,441],{"class":440},"s_sBn"," {}\n",[50,443,445,447,449],{"class":52,"line":444},11,[50,446,408],{"class":56},[50,448,425],{"class":60},[50,450,80],{"class":56},[17,452,453],{},"After that, the screenshot below should be your starting structure.",[17,455,456],{},[457,458],"img",{"alt":459,"src":460