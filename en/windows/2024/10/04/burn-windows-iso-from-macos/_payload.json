[{"data":1,"prerenderedAt":294},["ShallowReactive",2],{"header-locale:\u002Fen\u002Fwindows\u002F2024\u002F10\u002F04\u002Fburn-windows-iso-from-macos\u002F":3,"page:\u002Fen\u002Fwindows\u002F2024\u002F10\u002F04\u002Fburn-windows-iso-from-macos\u002F":4,"alt:\u002Fen\u002Fwindows\u002F2024\u002F10\u002F04\u002Fburn-windows-iso-from-macos\u002F":3,"prev-next:\u002Fen\u002Fwindows\u002F2024\u002F10\u002F04\u002Fburn-windows-iso-from-macos\u002F":280,"related:\u002Fen\u002Fwindows\u002F2024\u002F10\u002F04\u002Fburn-windows-iso-from-macos\u002F":289},"\u002Fwindows\u002F20241004\u002F850567104\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":261,"date":262,"description":263,"extension":264,"lang":265,"meta":266,"navigation":267,"path":268,"readingMinutes":269,"seo":270,"standalone":271,"stem":272,"tags":273,"tldr":277,"updated":262,"url":278,"__hash__":279},"content\u002Fen\u002FWindows\u002Fburn-windows-iso-from-macos.md","Creating a Windows Install USB From macOS","8140783163",{"type":9,"value":10,"toc":250},"minimark",[11,19,24,27,30,33,43,49,55,64,68,71,78,81,87,90,96,101,104,108,111,117,120,126,130,133,156,159,165,168,191,194,213,216,222,225,246],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Windows ISO","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F_8bdaf450-56ad-46b3-b516-d0ac546d4a03.jpg",[20,21,23],"h2",{"id":22},"intro","Intro",[12,25,26],{},"Had to reinstall Windows on a machine at home, but my main machine is a Mac. So here's how to make a Windows install USB from macOS.",[20,28,17],{"id":29},"windows-iso",[12,31,32],{},"Grab the Windows ISO from Microsoft's official site. I'll use Windows 10 here.",[12,34,35,36],{},"Download: ",[37,38,42],"a",{"href":39,"rel":40},"https:\u002F\u002Fwww.microsoft.com\u002Fen-us\u002Fsoftware-download\u002Fwindows10ISO",[41],"nofollow","Windows 10 download page",[12,44,45],{},[15,46],{"alt":47,"src":48},"Windows 10","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F%E6%88%AA%E5%9C%96%202024-10-04%2012.32.56.png",[12,50,51],{},[52,53,54],"strong",{},"This post doesn't provide a Windows license key.",[56,57,58],"blockquote",{},[12,59,60,63],{},[52,61,62],{},"Note","\nISO is a disc image format — basically a single-file archive of a disc's contents. Burning software writes the ISO contents to a disc (or in our case, a USB).",[20,65,67],{"id":66},"formatting-the-usb","Formatting the USB",[12,69,70],{},"You'll need a USB drive of at least 64GB. Before anything else, format it.",[56,72,73],{},[12,74,75,77],{},[52,76,62],{},"\nFormatting ensures the USB is clean, so the Windows install gets written correctly.",[12,79,80],{},"Insert the USB. You should see the drive on your desktop. Right-click and pick \"Erase\".",[12,82,83],{},[15,84],{"alt":85,"src":86},"Erase","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F%E6%88%AA%E5%9C%96%202024-10-04%2013.10.11.png",[12,88,89],{},"In the erase dialog, pick \"ExFAT\" as the format and click \"Erase\".",[12,91,92],{},[15,93],{"alt":94,"src":95},"ExFAT","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F%E6%88%AA%E5%9C%96%202024-10-04%2013.10.19.png",[97,98,100],"h3",{"id":99},"exfat-vs-ms-dos-fat","ExFAT vs MS-DOS (FAT)",[12,102,103],{},"MS-DOS is the older format. ExFAT is what you want.",[20,105,107],{"id":106},"mounting-the-windows-iso","Mounting the Windows ISO",[12,109,110],{},"Double-click the downloaded Windows 10 ISO. macOS automatically mounts it as a virtual disc, and you'll see it on your desktop.",[12,112,113],{},[15,114],{"alt":115,"src":116},"Windows mounted","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F202410041315.jpg",[12,118,119],{},"Open it and you'll see the Windows 10 install files.",[12,121,122],{},[15,123],{"alt":124,"src":125},"Windows files","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F%E6%88%AA%E5%9C%96%202024-10-04%2013.16.46.png",[20,127,129],{"id":128},"copying-to-the-usb","Copying to the USB",[12,131,132],{},"Open a terminal (I'm using iTerm2) and run:",[134,135,140],"pre",{"className":136,"code":137,"language":138,"meta":139,"style":139},"language-bash shiki shiki-themes github-dark-high-contrast","diskutil list\n","bash","",[141,142,143],"code",{"__ignoreMap":139},[144,145,148,152],"span",{"class":146,"line":147},"line",1,[144,149,151],{"class":150},"s_sBn","diskutil",[144,153,155],{"class":154},"sTRMh"," list\n",[12,157,158],{},"This lists all disks so you can find the USB's name. Mine's called \"UFDRecovery\".",[12,160,161],{},[15,162],{"alt":163,"src":164},"diskutil list","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F%E6%88%AA%E5%9C%96%202024-10-04%2013.22.34.png",[12,166,167],{},"Now copy the Windows files to the USB:",[134,169,171],{"className":136,"code":170,"language":138,"meta":139,"style":139},"cp -rp \u002FVolumes\u002F[ISO-mount-name]\u002F* \u002FVolumes\u002F[USB-name]\u002F\n",[141,172,173],{"__ignoreMap":139},[144,174,175,178,182,185,188],{"class":146,"line":147},[144,176,177],{"class":150},"cp",[144,179,181],{"class":180},"sCcAr"," -rp",[144,183,184],{"class":154}," \u002FVolumes\u002F[ISO-mount-name]\u002F",[144,186,187],{"class":180},"*",[144,189,190],{"class":154}," \u002FVolumes\u002F[USB-name]\u002F\n",[12,192,193],{},"For my case:",[134,195,197],{"className":136,"code":196,"language":138,"meta":139,"style":139},"cp -rp \u002FVolumes\u002FWindows10\u002F* \u002FVolumes\u002FUFDRecovery\u002F\n",[141,198,199],{"__ignoreMap":139},[144,200,201,203,205,208,210],{"class":146,"line":147},[144,202,177],{"class":150},[144,204,181],{"class":180},[144,206,207],{"class":154}," \u002FVolumes\u002FWindows10\u002F",[144,209,187],{"class":180},[144,211,212],{"class":154}," \u002FVolumes\u002FUFDRecovery\u002F\n",[12,214,215],{},"Hit Enter and the Windows 10 install files start copying to the USB. Takes a moment.",[12,217,218],{},[15,219],{"alt":220,"src":221},"Copy result","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fwindows\u002Fmac-iso-windows\u002F202410041329.jpg",[12,223,224],{},"When done, it looks like the above. (Note: there's no completion prompt — when it returns, it's done.)",[56,226,227],{},[12,228,229,231,233,234,237,238,241,242,245],{},[52,230,62],{},[141,232,177],{}," copies files, ",[141,235,236],{},"-rp"," is recursive. So this copies the Windows 10 install files recursively from ",[141,239,240],{},"\u002FVolumes\u002FWindows10\u002F"," to ",[141,243,244],{},"\u002FVolumes\u002FUFDRecovery\u002F",".",[247,248,249],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":139,"searchDepth":251,"depth":251,"links":252},2,[253,254,255,259,260],{"id":22,"depth":251,"text":23},{"id":29,"depth":251,"text":17},{"id":66,"depth":251,"text":67,"children":256},[257],{"id":99,"depth":258,"text":100},3,{"id":106,"depth":251,"text":107},{"id":128,"depth":251,"text":129},"Windows","2024-10-04 11:47:14","Need to reinstall Windows but only have a Mac? Making a Windows 10 install USB on macOS — ExFAT vs MS-DOS, where to grab the ISO, and writing the image.","md","en",{},true,"\u002Fen\u002Fwindows\u002Fburn-windows-iso-from-macos","2",{"title":6,"description":263},false,"en\u002FWindows\u002Fburn-windows-iso-from-macos",[274,261,275,276],"macOS","USB","ISO",null,"\u002Fen\u002Fwindows\u002F2024\u002F10\u002F04\u002Fburn-windows-iso-from-macos\u002F","WCKC__582bNDgOsH0n2CQDkvXxrQFvGUzISmfPnsftA",{"newer":281,"older":285},{"url":282,"title":283,"date":284},"\u002Fen\u002Flearning\u002F2024\u002F12\u002F05\u002Fwhat-to-do-after-traffic-accident-1-on-scene\u002F","What to Do When You Get in a Traffic Accident? — On-Scene Handling (1)","2024-12-05 20:01:26",{"url":286,"title":287,"date":288},"\u002Fen\u002Ftypescript\u002F2024\u002F09\u002F30\u002Ftypescript-generics-and-vue3-generics\u002F","Getting Comfortable With TypeScript Generics (and Vue 3 Generics)","2024-09-30 17:31:32",[290],{"url":291,"title":292,"date":293,"readingMinutes":269},"\u002Fen\u002Fwindows\u002F2024\u002F03\u002F24\u002Fwindows-shutdown-isnt-really-shutting-down\u002F","Did You Know? Windows' Shutdown Isn't Actually Shutting Down","2024-03-24 13:46:56",1784013081155]