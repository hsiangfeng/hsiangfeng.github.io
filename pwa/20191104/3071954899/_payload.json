[{"data":1,"prerenderedAt":562},["ShallowReactive",2],{"header-locale:\u002Fpwa\u002F20191104\u002F3071954899\u002F":3,"page:\u002Fpwa\u002F20191104\u002F3071954899\u002F":4,"alt:\u002Fpwa\u002F20191104\u002F3071954899\u002F":3,"prev-next:\u002Fpwa\u002F20191104\u002F3071954899\u002F":540,"related:\u002Fpwa\u002F20191104\u002F3071954899\u002F":549},"\u002Fen\u002Fpwa\u002F2019\u002F11\u002F04\u002Fpwa-architecture-manifest-day3\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":525,"date":526,"description":18,"extension":527,"lang":528,"meta":529,"navigation":530,"path":531,"readingMinutes":532,"seo":533,"standalone":534,"stem":535,"tags":536,"tldr":537,"updated":537,"url":538,"__hash__":539},"content\u002FPWA 初體驗\u002FDay3-PWA-初體驗-PWA-架構-1.md","Day3-PWA 初體驗 - PWA 架構(一)","3071954899",{"type":9,"value":10,"toc":519},"minimark",[11,15,19,23,29,32,43,269,273,461,464,470,473,483,486,492,495,502,509,515],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來這一篇將會來了解 PWA 的架構，但是這邊將會拆成兩個章節介紹。",[12,20,22],{"id":21},"web-app-manifest","Web App Manifest",[16,24,25,26],{},"PWA 最主要將會仰賴兩個檔案也就是 manifest.json 以及 Service Worker，但是這邊將會集中介紹 Web App Manifest ",[27,28],"d",{},[16,30,31],{},"首先 manifest.json 是一個 JSON 格式的檔案，而這個 JSON 格式裏面包含了 PWA 所需要的應用程式名稱、icon 以及應用程式 URL 等等。",[16,33,34,35,42],{},"以下為 ",[36,37,41],"a",{"href":38,"rel":39},"https:\u002F\u002Fdevelopers.google.com\u002Fweb\u002Ffundamentals\u002Fweb-app-manifest",[40],"nofollow","Google 官方"," 所提供的 manifest.json 範本格式：",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"short_name\": \"Maps\",\n  \"name\": \"Google Maps\",\n  \"icons\": [\n    {\n      \"src\": \"\u002Fimages\u002Ficons-192.png\",\n      \"type\": \"image\u002Fpng\",\n      \"sizes\": \"192x192\"\n    },\n    {\n      \"src\": \"\u002Fimages\u002Ficons-512.png\",\n      \"type\": \"image\u002Fpng\",\n      \"sizes\": \"512x512\"\n    }\n  ],\n  \"start_url\": \"\u002Fmaps\u002F?source=pwa\",\n  \"background_color\": \"#3367D6\",\n  \"display\": \"standalone\",\n  \"scope\": \"\u002Fmaps\u002F\",\n  \"theme_color\": \"#3367D6\"\n}\n","json","",[51,52,53,62,79,92,101,107,120,133,144,150,155,167,178,188,194,200,213,226,239,252,263],"code",{"__ignoreMap":49},[54,55,58],"span",{"class":56,"line":57},"line",1,[54,59,61],{"class":60},"sMAXC","{\n",[54,63,65,69,72,76],{"class":56,"line":64},2,[54,66,68],{"class":67},"sKpQp","  \"short_name\"",[54,70,71],{"class":60},": ",[54,73,75],{"class":74},"sTRMh","\"Maps\"",[54,77,78],{"class":60},",\n",[54,80,82,85,87,90],{"class":56,"line":81},3,[54,83,84],{"class":67},"  \"name\"",[54,86,71],{"class":60},[54,88,89],{"class":74},"\"Google Maps\"",[54,91,78],{"class":60},[54,93,95,98],{"class":56,"line":94},4,[54,96,97],{"class":67},"  \"icons\"",[54,99,100],{"class":60},": [\n",[54,102,104],{"class":56,"line":103},5,[54,105,106],{"class":60},"    {\n",[54,108,110,113,115,118],{"class":56,"line":109},6,[54,111,112],{"class":67},"      \"src\"",[54,114,71],{"class":60},[54,116,117],{"class":74},"\"\u002Fimages\u002Ficons-192.png\"",[54,119,78],{"class":60},[54,121,123,126,128,131],{"class":56,"line":122},7,[54,124,125],{"class":67},"      \"type\"",[54,127,71],{"class":60},[54,129,130],{"class":74},"\"image\u002Fpng\"",[54,132,78],{"class":60},[54,134,136,139,141],{"class":56,"line":135},8,[54,137,138],{"class":67},"      \"sizes\"",[54,140,71],{"class":60},[54,142,143],{"class":74},"\"192x192\"\n",[54,145,147],{"class":56,"line":146},9,[54,148,149],{"class":60},"    },\n",[54,151,153],{"class":56,"line":152},10,[54,154,106],{"class":60},[54,156,158,160,162,165],{"class":56,"line":157},11,[54,159,112],{"class":67},[54,161,71],{"class":60},[54,163,164],{"class":74},"\"\u002Fimages\u002Ficons-512.png\"",[54,166,78],{"class":60},[54,168,170,172,174,176],{"class":56,"line":169},12,[54,171,125],{"class":67},[54,173,71],{"class":60},[54,175,130],{"class":74},[54,177,78],{"class":60},[54,179,181,183,185],{"class":56,"line":180},13,[54,182,138],{"class":67},[54,184,71],{"class":60},[54,186,187],{"class":74},"\"512x512\"\n",[54,189,191],{"class":56,"line":190},14,[54,192,193],{"class":60},"    }\n",[54,195,197],{"class":56,"line":196},15,[54,198,199],{"class":60},"  ],\n",[54,201,203,206,208,211],{"class":56,"line":202},16,[54,204,205],{"class":67},"  \"start_url\"",[54,207,71],{"class":60},[54,209,210],{"class":74},"\"\u002Fmaps\u002F?source=pwa\"",[54,212,78],{"class":60},[54,214,216,219,221,224],{"class":56,"line":215},17,[54,217,218],{"class":67},"  \"background_color\"",[54,220,71],{"class":60},[54,222,223],{"class":74},"\"#3367D6\"",[54,225,78],{"class":60},[54,227,229,232,234,237],{"class":56,"line":228},18,[54,230,231],{"class":67},"  \"display\"",[54,233,71],{"class":60},[54,235,236],{"class":74},"\"standalone\"",[54,238,78],{"class":60},[54,240,242,245,247,250],{"class":56,"line":241},19,[54,243,244],{"class":67},"  \"scope\"",[54,246,71],{"class":60},[54,248,249],{"class":74},"\"\u002Fmaps\u002F\"",[54,251,78],{"class":60},[54,253,255,258,260],{"class":56,"line":254},20,[54,256,257],{"class":67},"  \"theme_color\"",[54,259,71],{"class":60},[54,261,262],{"class":74},"\"#3367D6\"\n",[54,264,266],{"class":56,"line":265},21,[54,267,268],{"class":60},"}\n",[12,270,272],{"id":271},"json-欄位說明","JSON 欄位說明",[274,275,276,296],"table",{},[277,278,279],"thead",{},[280,281,282,287,290,293],"tr",{},[283,284,286],"th",{"align":285},"center","功能",[283,288,289],{"align":285},"說明",[283,291,292],{"align":285},"是否為必備",[283,294,295],{"align":285},"備註",[297,298,299,313,326,339,352,369,383,396,409,422,435,448],"tbody",{},[280,300,301,305,308,311],{},[302,303,304],"td",{"align":285},"short_name",[302,306,307],{"align":285},"應用程式的簡稱",[302,309,310],{"align":285},"Y",[302,312],{"align":285},[280,314,315,318,321,323],{},[302,316,317],{"align":285},"name",[302,319,320],{"align":285},"應用程式名稱",[302,322,310],{"align":285},[302,324,325],{"align":285},"若有應用程式簡稱將不會套用該選項",[280,327,328,331,334,336],{},[302,329,330],{"align":285},"icons",[302,332,333],{"align":285},"應用程式圖片",[302,335,310],{"align":285},[302,337,338],{"align":285},"此為陣列物件，通常 icons 會建議多出幾個尺寸，但是我這邊僅使用官方範例來出 icons，通常建議都用 png 圖檔",[280,340,341,344,347,349],{},[302,342,343],{"align":285},"start_url",[302,345,346],{"align":285},"應用程式首頁連結",[302,348,310],{"align":285},[302,350,351],{"align":285},"通常是 .\u002Findex.html",[280,353,354,357,360,362],{},[302,355,356],{"align":285},"background_color",[302,358,359],{"align":285},"應用程式背景顏色",[302,361,310],{"align":285},[302,363,364,368],{"align":285},[365,366,367],"del",{},"背景顏色就是背景顏色"," (被揍)",[280,370,371,374,377,380],{},[302,372,373],{"align":285},"display",[302,375,376],{"align":285},"應用程式顯示模式 共有 fullscreen、standalone、minimal-ui、browser",[302,378,379],{"align":285},"N",[302,381,382],{"align":285},"預設是 standalone，但是通常不會調整該選項，除非有特殊需求。",[280,384,385,388,391,393],{},[302,386,387],{"align":285},"scope",[302,389,390],{"align":285},"應用程式應用範圍",[302,392,379],{"align":285},[302,394,395],{"align":285},"這是一個比較少調整的設置。",[280,397,398,401,404,406],{},[302,399,400],{"align":285},"theme_color",[302,402,403],{"align":285},"應用程式主題顏色",[302,405,310],{"align":285},[302,407,408],{"align":285},"主題顏色大多套用於手機上方的標題欄以及視窗等。",[280,410,411,414,417,419],{},[302,412,413],{"align":285},"description",[302,415,416],{"align":285},"應用程式描述",[302,418,379],{"align":285},[302,420,421],{"align":285},"簡單來講就是對於這個 PWA 的簡易描述描述。",[280,423,424,427,430,432],{},[302,425,426],{"align":285},"dir",[302,428,429],{"align":285},"應用程式排列方向 共有 ltr(左至右)、rtl(右至左)、auto",[302,431,379],{"align":285},[302,433,434],{"align":285},"其實這個也是很少人會設置的選項，但是這邊一樣做個紀錄。",[280,436,437,440,443,445],{},[302,438,439],{"align":285},"lang",[302,441,442],{"align":285},"應用程式語系",[302,444,379],{"align":285},[302,446,447],{"align":285},"通常若沒有填入應用程式語系，PWA 是會抓取預設語系。",[280,449,450,453,456,458],{},[302,451,452],{"align":285},"orientation",[302,454,455],{"align":285},"螢幕顯示方向 any、natural、landscape、portrait、portrait-primary、portrait-secondary、landscape-primary、landscape-secondary",[302,457,379],{"align":285},[302,459,460],{"align":285},"這也是一個不太會設置的選項。",[16,462,463],{},"裡面比較大疑問的大概是 theme_color 剛好官方有提供範例圖片可以看，所謂的主題顏色就是圖片中藍色顏色",[16,465,466],{},[467,468],"img",{"alt":403,"src":469},"https:\u002F\u002Fi.imgur.com\u002Fsc2rDUJ.png",[16,471,472],{},"最後 PWA 裡面有一個地方滿值得一提的，也就是關於 APP 的啟動頁，這格啟動頁是由 manifest.json 中三個選項所結合而成",[474,475,476,479,481],"ul",{},[477,478,317],"li",{},[477,480,356],{},[477,482,330],{},[16,484,485],{},"所以只要設計好一個漂亮 iCons，啟動頁就會自動生成，完全不用自己搞唷~",[16,487,488],{},[467,489],{"alt":490,"src":491},"啟動頁","https:\u002F\u002Fdevelopers.google.com\u002Fweb\u002Ffundamentals\u002Fweb-app-manifest\u002Fimages\u002Fbackground-color.gif",[12,493,494],{"id":494},"參考文獻",[16,496,497],{},[36,498,501],{"href":499,"rel":500},"https:\u002F\u002Fdevelopers.google.com\u002Fweb\u002Ffundamentals\u002Fweb-app-manifest\u002F",[40],"The Web App Manifest",[16,503,504],{},[36,505,508],{"href":506,"rel":507},"https:\u002F\u002Fjonny-huang.github.io\u002Fangular\u002Ftraining\u002F19_pwa\u002F",[40],"PWA 偽裝術：manifest.json",[16,510,511],{},[36,512,22],{"href":513,"rel":514},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FManifest",[40],[516,517,518],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":49,"searchDepth":64,"depth":64,"links":520},[5