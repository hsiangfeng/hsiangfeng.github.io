[{"data":1,"prerenderedAt":1365},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210928\u002F4211341551\u002F":3,"page:\u002Fpython\u002F20210928\u002F4211341551\u002F":4,"alt:\u002Fpython\u002F20210928\u002F4211341551\u002F":3,"prev-next:\u002Fpython\u002F20210928\u002F4211341551\u002F":1341,"related:\u002Fpython\u002F20210928\u002F4211341551\u002F":1350},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F28\u002Flearning-python-from-javascript-27-pass-by-value-reference\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1324,"date":1325,"description":18,"extension":1326,"lang":1327,"meta":1328,"navigation":89,"path":1329,"readingMinutes":1330,"seo":1331,"standalone":1332,"stem":1333,"tags":1334,"tldr":1338,"updated":1338,"url":1339,"__hash__":1340},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-27-傳值-傳參考.md","從 JavaScript 角度學 Python(27) - 傳值？傳參考？","4211341551",{"type":9,"value":10,"toc":1315},"minimark",[11,15,19,22,25,108,111,142,145,148,211,250,260,321,331,338,341,344,347,436,439,445,448,451,454,529,538,544,547,590,593,596,644,647,708,711,717,720,723,757,764,801,804,851,854,857,916,922,997,1008,1015,1057,1060,1126,1129,1135,1139,1142,1152,1162,1165,1168,1196,1211,1217,1220,1226,1237,1243,1246,1249,1264,1267,1270,1273,1305,1311],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"已經快到鐵人賽的結尾了，但是我現在才想到我好像少講了一個東西，就是關於傳值與傳參考的部分，所以這一篇就來聊一下關於傳值與傳參考吧。",[12,20,21],{"id":21},"傳值",[16,23,24],{},"首先先簡單聊一下純粹的傳值，在 JavaScript 中我們知道原始型別是單純傳遞一個值給另一個變數，因此修改時並不會影響原有的變數：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Ray';\nvar b = a;\nb = 'QQ';\n\nconsole.log(a, b); \u002F\u002F Ray, QQ\n","js","",[33,34,35,58,71,84,91],"code",{"__ignoreMap":31},[36,37,40,44,48,51,55],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sWyjQ","var",[36,45,47],{"class":46},"sMAXC"," a ",[36,49,50],{"class":42},"=",[36,52,54],{"class":53},"sTRMh"," 'Ray'",[36,56,57],{"class":46},";\n",[36,59,61,63,66,68],{"class":38,"line":60},2,[36,62,43],{"class":42},[36,64,65],{"class":46}," b ",[36,67,50],{"class":42},[36,69,70],{"class":46}," a;\n",[36,72,74,77,79,82],{"class":38,"line":73},3,[36,75,76],{"class":46},"b ",[36,78,50],{"class":42},[36,80,81],{"class":53}," 'QQ'",[36,83,57],{"class":46},[36,85,87],{"class":38,"line":86},4,[36,88,90],{"emptyLinePlaceholder":89},true,"\n",[36,92,94,97,101,104],{"class":38,"line":93},5,[36,95,96],{"class":46},"console.",[36,98,100],{"class":99},"sj_SG","log",[36,102,103],{"class":46},"(a, b); ",[36,105,107],{"class":106},"sQrFR","\u002F\u002F Ray, QQ\n",[16,109,110],{},"那話題拉回到 Python 中，Python 與 JavaScript 也是相同的嗎？我們可以直接來看一次範例：",[26,112,116],{"className":113,"code":114,"language":115,"meta":31,"style":31},"language-py shiki shiki-themes github-dark-high-contrast","a = 'Ray'\nb = a\nb = 'QQ'\n\nprint(a, b) # Ray, QQ\n","py",[33,117,118,123,128,133,137],{"__ignoreMap":31},[36,119,120],{"class":38,"line":39},[36,121,122],{},"a = 'Ray'\n",[36,124,125],{"class":38,"line":60},[36,126,127],{},"b = a\n",[36,129,130],{"class":38,"line":73},[36,131,132],{},"b = 'QQ'\n",[36,134,135],{"class":38,"line":86},[36,136,90],{"emptyLinePlaceholder":89},[36,138,139],{"class":38,"line":93},[36,140,141],{},"print(a, b) # Ray, QQ\n",[16,143,144],{},"從結果來看，我們可以看到 Python 與 JavaScript 的結果是一樣的。",[16,146,147],{},"但是如果今天採用的是另一種方式來呈現的話結果會相同嗎？這邊就讓我們來看看另一種範例程式碼：",[26,149,151],{"className":113,"code":150,"language":115,"meta":31,"style":31},"def fn(x, y):\n  cache = 100\n  x = cache\n  y = x\n\nx = 10\ny = 20\n\nfn(x, y)\n\nprint(x, y) # 10, 20\n",[33,152,153,158,163,168,173,177,183,189,194,200,205],{"__ignoreMap":31},[36,154,155],{"class":38,"line":39},[36,156,157],{},"def fn(x, y):\n",[36,159,160],{"class":38,"line":60},[36,161,162],{},"  cache = 100\n",[36,164,165],{"class":38,"line":73},[36,166,167],{},"  x = cache\n",[36,169,170],{"class":38,"line":86},[36,171,172],{},"  y = x\n",[36,174,175],{"class":38,"line":93},[36,176,90],{"emptyLinePlaceholder":89},[36,178,180],{"class":38,"line":179},6,[36,181,182],{},"x = 10\n",[36,184,186],{"class":38,"line":185},7,[36,187,188],{},"y = 20\n",[36,190,192],{"class":38,"line":191},8,[36,193,90],{"emptyLinePlaceholder":89},[36,195,197],{"class":38,"line":196},9,[36,198,199],{},"fn(x, y)\n",[36,201,203],{"class":38,"line":202},10,[36,204,90],{"emptyLinePlaceholder":89},[36,206,208],{"class":38,"line":207},11,[36,209,210],{},"print(x, y) # 10, 20\n",[16,212,213,214,217,218,221,222,225,226,228,229,232,233,217,235,237,238,240,241,243,244,246,247,249],{},"我們可以看到在上面的範例程式碼中，我將全域的變數 ",[33,215,216],{},"x"," 與 ",[33,219,220],{},"y"," 傳入到 ",[33,223,224],{},"fn"," 函式內，接下來在 ",[33,227,224],{}," 中宣告一個 ",[33,230,231],{},"cache = 100"," 的變數，而後面我做了重新賦予 ",[33,234,216],{},[33,236,220],{}," 的行為，但是你會發現 ",[33,239,224],{}," 內的調整並不會影響全域變數的結果，這代表著什麼呢？代表著我們只是傳遞值 (",[33,242,216],{},", ",[33,245,220],{},") 給 ",[33,248,224],{}," 函式的參數使用，因此函式內部的變化它並不會影響原本的變數。",[16,251,252,253,256,257,259],{},"或許這個時候你會很聰明的想到我在「從 JavaScript 角度學 Python(6) - 變數作用域」章節中有介紹一個「",[33,254,255],{},"global","」的方式可以針對外部變數做一些ㄌ調整，但是基本上如果你在這邊使用 ",[33,258,255],{}," 方法的話是會出現錯誤的：",[26,261,263],{"className":113,"code":262,"language":115,"meta":31,"style":31},"def fn(x, y):\n  cache = 100\n  global x, y # SyntaxError: name 'x, y' is parameter and global\n  x = cache\n  y = x\n  \n\nx = 10\ny = 20\n\nfn(x, y)\n\nprint(x, y) # 10, 20\n",[33,264,265,269,273,278,282,286,291,295,299,303,307,311,316],{"__ignoreMap":31},[36,266,267],{"class":38,"line":39},[36,268,157],{},[36,270,271],{"class":38,"line":60},[36,272,162],{},[36,274,275],{"class":38,"line":73},[36,276,277],{},"  global x, y # SyntaxError: name 'x, y' is parameter and global\n",[36,279,280],{"class":38,"line":86},[36,281,167],{},[36,283,284],{"class":38,"line":93},[36,285,172],{},[36,287,288],{"class":38,"line":179},[36,289,290],{},"  \n",[36,292,293],{"class":38,"line":185},[36,294,90],{"emptyLinePlaceholder":89},[36,296,297],{"class":38,"line":191},[36,298,182],{},[36,300,301],{"class":38,"line":196},[36,302,188],{},[36,304,305],{"class":38,"line":202},[36,306,90],{"emptyLinePlaceholder":89},[36,308,309],{"class":38,"line":207},[36,310,199],{},[36,312,314],{"class":38,"line":313},12,[36,315,90],{"emptyLinePlaceholder":89},[36,317,319],{"class":38,"line":318},13,[36,320,210],{},[16,322,323,324,327,328,330],{},"而會出現「",[33,325,326],{},"SyntaxError: name 'x, y' is parameter and global","」這一段錯誤訊息的主要原因在於，函式的參數如果與 ",[33,329,255],{}," 指定的變數相同的話，是會無法正常運作的，因為它會不知道你到底是要使用哪一個參數還是變數唷~",[16,332,333],{},[334,335],"img",{"alt":336,"src":337},"你不能這樣玩唷~","https:\u002F\u002Fi.imgur.com\u002FrjpHeSm.gif",[16,339,340],{},"所以我們這邊可以大膽的推測...",[16,342,343],{},"「或許 Python 的數值型別、字串型別與布林型別會與 JavaScript 的原始型別類似？」",[16,345,346],{},"那麼關於這個推測我們可以試著實踐一次或許會更精準，透過前面幾個章節我們了解到容器型別類似於 JavaScript 的陣列與物件，所以這邊我們可以試著撰寫字串、布林與數值型別來測試看看：",[26,348,350],{"className":113,"code":349,"language":115,"meta":31,"style":31},"def fn(w, x, y, z):\n  w = False\n  x = 10\n  y = 1.1\n  z = 'Ray'\n  print(w, x, y, z) # False, 10, 1.1, Ray\n\n\nw = True # 布林\nx = 9.9 # 浮點數\ny = 'Ray' # 字串\nz = 10 # 整數\n\n\nfn(w, x, y, z)\n\nprint(w, x, y, z) # True, 9.9, Ray, 10\n",[33,351,352,357,362,367,372,377,382,386,390,395,400,405,410,414,419,425,430],{"__ignoreMap":31},[36,353,354],{"class":38,"line":39},[36,355,356],{},"def fn(w, x, y, z):\n",[36,358,359],{"class":38,"line":60},[36,360,361],{},"  w = False\n",[36,363,364],{"class":38,"line":73},[36,365,366],{},"  x = 10\n",[36,368,369],{"class":38,"line":86},[36,370,371],{},"  y = 1.1\n",[36,373,374],{"class":38,"line":93},[36,375,376],{},"  z = 'Ray'\n",[36,378,379],{"class":38,"line":179},[36,380,381],{},"  print(w, x, y, z) # False, 10, 1.1, Ray\n",[36,383,384],{"class":38,"line":185},[36,385,90],{"emptyLinePlaceholder":89},[36,387,388],{"class":38,"line":191},[36,389,90],{"emptyLinePlaceholder":89},[36,391,392],{"class":38,"line":196},[36,393,394],{},"w = True # 布林\n",[36,396,397],{"class":38,"line":202},[36,398,399],{},"x = 9.9 # 浮點數\n",[36,401,402],{"class":38,"line":207},[36,403,404],{},"y = 'Ray' # 字串\n",[36,406,407],{"class":38,"line":313},[36,408,409],{},"z = 10 # 整數\n",[36,411,412],{"class":38,"line":318},[36,413,90],{"emptyLinePlaceholder":89},[36,415,417],{"class":38,"line":416},14,[36,418,90],{"emptyLinePlaceholder":89},[36,420,422],{"class":38,"line":421},15,[36,423,424],{},"fn(w, x, y, z)\n",[36,426,428],{"class":38,"line":427},16,[36,429,90],{"emptyLinePlaceholder":89},[36,431,433],{"class":38,"line":432},17,[36,434,435],{},"print(w, x, y, z) # True, 9.9, Ray, 10\n",[16,437,438],{},"透過上面的結果來看，基本上 Python 的字串、布林與數值型別確實是與 JavaScript 的基本型別雷同，那字典與串列呢？別急，我們先接著下去看，但是這邊要注意我們是在講 Python 不是 JavaScript：",[16,440,441],{},[334,442],{"alt":443,"src":444},"是 Python 不是 JavaScript","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632155248094.png",[12,446,447],{"id":447},"傳參考",[16,449,450],{},"接下來聊一下剛剛沒有提到的字典與串列的部分，雖然我們知道 Python 的字典與串列就是對應著 JavaScript 的物件與陣列，但實際上運作模式會是一樣嗎？所以這邊也來快速聊一下這一塊。",[16,452,453],{},"首先我們先來一段 JavaScript 很常見的物件傳參考的基本範例程式碼：",[26,455,457],{"className":28,"code":456,"language":30,"meta":31,"style":31},"var b = {\n  name: 'Ray',\n};\n\nvar e = b;\n\ne.name = 'QQ';\nconsole.log(b.name); \u002F\u002F QQ\n",[33,458,459,470,481,486,490,502,506,517],{"__ignoreMap":31},[36,460,461,463,465,467],{"class":38,"line":39},[36,462,43],{"class":42},[36,464,65],{"class":46},[36,466,50],{"class":42},[36,468,469],{"class":46}," {\n",[36,471,472,475,478],{"class":38,"line":60},[36,473,474],{"class":46},"  name: ",[36,476,477],{"class":53},"'Ray'",[36,479,480],{"class":46},",\n",[36,482,483],{"class":38,"line":73},[36,484,485],{"class":46},"};\n",[36,487,488],{"class":38,"line":86},[36,489,90],{"emptyLinePlaceholder":89},[36,491,492,494,497,499],{"class":38,"line":93},[36,493,43],{"class":42},[36,495,496],{"class":46}," e ",[36,498,50],{"class":42},[36,500,501],{"class":46}," b;\n",[36,503,504],{"class":38,"line":179},[36,505,90],{"emptyLinePlaceholder":89},[36,507,508,511,513,515],{"class":38,"line":185},[36,509,510],{"class":46},"e.name ",[36,512,50],{"class":42},[36,514,81],{"class":53},[36,516,57],{"class":46},[36,518,519,521,523,526],{"class":38,"line":191},[36,520,96],{"class":46},[36,522,100],{"class":99},[36,524,525],{"class":46},"(b.name); ",[36,527,528],{"class":106},"\u002F\u002F QQ\n",[16,530,531,532,537],{},"上面的觀念我們都知道這是一個物件傳參考概念，如果對於這一段有興趣的話可以閱讀我這一篇文章「",[533,534,536],"a",{"href":535},"\u002Fjavascript\u002F20200815\u002F1875070167\u002F","JavaScript 核心觀念(27)-物件-物件參考觀念的實際運作模式","」會有更詳細的說明，因此這邊就不著墨了(笑)。",[16,539,540],{},[334,541],{"alt":542,"src":543},"被拐","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632212566603.png",[16,545,546],{},"前面講那麼多，那 Python 的狀況又如何呢？我們將上面的 JavaScript 範例程式碼直接改寫成 Python 版本試試看：",[26,548,550],{"className":113,"code":549,"language":115,"meta":31,"style":31},"b = {\n  'name': 'Ray'\n}\n\ne = b\n\ne['name'] = 'QQ'\nprint(b['name']) # QQ\n",[33,551,552,557,562,567,571,576,580,585],{"__ignoreMap":31},[36,553,554],{"class":38,"line":39},[36,555,556],{},"b = {\n",[36,558,559],{"class":38,"line":60},[36,560,561],{},"  'name': 'Ray'\n",[36,563,564],{"class":38,"line":73},[36,565,566],{},"}\n",[36,568,569],{"class":38,"line":86},[36,570,90],{"emptyLinePlaceholder":89},[36,572,573],{"class":38,"line":93},[36,574,575],{},"e = b\n",[36,577,578],{"class":38,"line":179},[36,579,90],{"emptyLinePlaceholder":89},[36,581,582],{"class":38,"line":185},[36,583,584],{},"e['name'] = 'QQ'\n",[36,586,587],{"class":38,"line":191},[36,588,589],{},"print(b['name']) # QQ\n",[16,591,592],{},"好吧...依照輸出的結果來看， Python 的字典跟 JavaScript 的物件傳參考狀況非常像沒有錯吧~",[16,594,595],{},"接下來讓我們看看另一個範例程式碼：",[26,597,599],{"className":113,"code":598,"language":115,"meta":31,"style":31},"def fn (x):\n  x['name'] = 'QQ'\n\nb = {\n  'name': 'Ray'\n}\n\nfn(b)\n\nprint(b['name']) # QQ\n",[33,600,601,606,611,615,619,623,627,631,636,640],{"__ignoreMap":31},[36,602,603],{"class":38,"line":39},[36,604,605],{},"def fn (x):\n",[36,607,608],{"class":38,"line":60},[36,609,610],{},"  x['name'] = 'QQ'\n",[36,612,613],{"class":38,"line":73},[36,614,90],{"emptyLinePlaceholder":89},[36,616,617],{"class":38,"line":86},[36,618,556],{},[36,620,621],{"class":38,"line":93},[36,622,561],{},[36,624,625],{"class":38,"line":179},[36,626,566],{},[36,628,629],{"class":38,"line":185},[36,630,90],{"emptyLinePlaceholder":89},[36,632,633],{"class":38,"line":191},[36,634,635],{},"fn(b)\n",[36,637,638],{"class":38,"line":196},[36,639,90],{"emptyLinePlaceholder":89},[36,641,642],{"class":38,"line":202},[36,643,589],{},[16,645,646],{},"上面這個範例程式碼確實沒有任何問題，感覺也是物件傳參考有非常大的關聯性，但是如果範例程式碼變成了以下，那麼結果會是怎樣呢？",[26,648,650],{"className":113,"code":649,"language":115,"meta":31,"style":31},"def fn (x):\n  x = {\n    'name': 'Ray'\n  }\n\n\nb = {\n  'name': 'Ray'\n}\n\nfn(b)\n\nprint(b['name']) # Ray\n",[33,651,652,656,661,666,671,675,679,683,687,691,695,699,703],{"__ignoreMap":31},[36,653,654],{"class":38,"line":39},[36,655,605],{},[36,657,658],{"class":38,"line":60},[36,659,660],{},"  x = {\n",[36,662,663],{"class":38,"line":73},[36,664,665],{},"    'name': 'Ray'\n",[36,667,668],{"class":38,"line":86},[36,669,670],{},"  }\n",[36,672,673],{"class":38,"line":93},[36,674,90],{"emptyLinePlaceholder":89},[36,676,677],{"class":38,"line":179},[36,678,90],{"emptyLinePlaceholder":89},[36,680,681],{"class":38,"line":185},[36,682,556],{},[36,684,685],{"class":38,"line":191},[36,686,561],{},[36,688,689],{"class":38,"line":196},[36,690,566],{},[36,692,693],{"class":38,"line":202},[36,694,90],{"emptyLinePlaceholder":89},[36,696,697],{"class":38,"line":207},[36,698,635],{},[36,700,701],{"class":38,"line":313},[36,702,90],{"emptyLinePlaceholder":89},[36,704,705],{"class":38,"line":318},[36,706,707],{},"print(b['name']) # Ray\n",[16,709,710],{},"疑？奇怪了，為什麼結果不一樣了？",[16,712,713],{},[334,714],{"alt":715,"src":716},"我頭痛了","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632215100722.png",[16,718,719],{},"好吧，這邊要講一下關於物件(字典)傳參考的時候會有一個很特別的地方，雖然我們知道 Python 的字典基本上與 JavaScript 非常雷同，因此再將字典賦予到變數時，其實是賦予一個記憶體空間位置，我知道這邊有點難懂，所以我想換個方式形容，我們試著把容器型別與數值型別、字串型別以生活化的角度去理解看看。",[16,721,722],{},"而這邊會用車子去當作舉例，因此數值型別與字串型別你可以把它想像成是車子內的某些東西，例如：輪胎、方向盤，又或者收音機等等，字典與串列的話則是一個僅有車殼的車子(連引擎都沒有)，所以透過這樣的舉例來講，可能就會像這樣：",[26,724,726],{"className":113,"code":725,"language":115,"meta":31,"style":31},"# 把字典看成一個車殼，裡面放著車子的東西\ncar = {\n  'steeringWheel': 1, # 方向盤\n  'wheels': 4, # 輪胎\n  'radio': 1, # 收音機\n}\n",[33,727,728,733,738,743,748,753],{"__ignoreMap":31},[36,729,730],{"class":38,"line":39},[36,731,732],{},"# 把字典看成一個車殼，裡面放著車子的東西\n",[36,734,735],{"class":38,"line":60},[36,736,737],{},"car = {\n",[36,739,740],{"class":38,"line":73},[36,741,742],{},"  'steeringWheel': 1, # 方向盤\n",[36,744,745],{"class":38,"line":86},[36,746,747],{},"  'wheels': 4, # 輪胎\n",[36,749,750],{"class":38,"line":93},[36,751,752],{},"  'radio': 1, # 收音機\n",[36,754,755],{"class":38,"line":179},[36,756,566],{},[16,758,759,760,763],{},"那麼當我將 ",[33,761,762],{},"car"," 字典賦予到另一個變數時，其實概念類似我把車子借給他人使用，例如我借來了一台車：",[26,765,767],{"className":113,"code":766,"language":115,"meta":31,"style":31},"car = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray = car\n",[33,768,769,773,778,783,788,792,796],{"__ignoreMap":31},[36,770,771],{"class":38,"line":39},[36,772,737],{},[36,774,775],{"class":38,"line":60},[36,776,777],{},"  'steeringWheel': 1,\n",[36,779,780],{"class":38,"line":73},[36,781,782],{},"  'wheels': 4,\n",[36,784,785],{"class":38,"line":86},[36,786,787],{},"  'radio': 1,\n",[36,789,790],{"class":38,"line":93},[36,791,566],{},[36,793,794],{"class":38,"line":179},[36,795,90],{"emptyLinePlaceholder":89},[36,797,798],{"class":38,"line":185},[36,799,800],{},"ray = car\n",[16,802,803],{},"所以當我對著車子有任何調整，可能拆掉一個輪胎，那就會影響到原本的車子，畢竟車子是借來的：",[26,805,807],{"className":113,"code":806,"language":115,"meta":31,"style":31},"car = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray = car\nray['wheels'] = 3\n\nprint(car['wheels']) # 3\n",[33,808,809,813,817,821,825,829,833,837,842,846],{"__ignoreMap":31},[36,810,811],{"class":38,"line":39},[36,812,737],{},[36,814,815],{"class":38,"line":60},[36,816,777],{},[36,818,819],{"class":38,"line":73},[36,820,782],{},[36,822,823],{"class":38,"line":86},[36,824,787],{},[36,826,827],{"class":38,"line":93},[36,828,566],{},[36,830,831],{"class":38,"line":179},[36,832,90],{"emptyLinePlaceholder":89},[36,834,835],{"class":38,"line":185},[36,836,800],{},[36,838,839],{"class":38,"line":191},[36,840,841],{},"ray['wheels'] = 3\n",[36,843,844],{"class":38,"line":196},[36,845,90],{"emptyLinePlaceholder":89},[36,847,848],{"class":38,"line":202},[36,849,850],{},"print(car['wheels']) # 3\n",[16,852,853],{},"那出借東西的行為就是 JavaScript 的物件傳參考，我只是借給你用而已的概念。",[16,855,856],{},"那麼有一種狀況下我們不會影響到原有的車子，也就是我後來終於有錢買自己的車子：",[26,858,860],{"className":113,"code":859,"language":115,"meta":31,"style":31},"car = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray = car \n\nray = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n",[33,861,862,866,870,874,878,882,886,891,895,900,904,908,912],{"__ignoreMap":31},[36,863,864],{"class":38,"line":39},[36,865,737],{},[36,867,868],{"class":38,"line":60},[36,869,777],{},[36,871,872],{"class":38,"line":73},[36,873,782],{},[36,875,876],{"class":38,"line":86},[36,877,787],{},[36,879,880],{"class":38,"line":93},[36,881,566],{},[36,883,884],{"class":38,"line":179},[36,885,90],{"emptyLinePlaceholder":89},[36,887,888],{"class":38,"line":185},[36,889,890],{},"ray = car \n",[36,892,893],{"class":38,"line":191},[36,894,90],{"emptyLinePlaceholder":89},[36,896,897],{"class":38,"line":196},[36,898,899],{},"ray = {\n",[36,901,902],{"class":38,"line":202},[36,903,777],{},[36,905,906],{"class":38,"line":207},[36,907,782],{},[36,909,910],{"class":38,"line":313},[36,911,787],{},[36,913,914],{"class":38,"line":318},[36,915,566],{},[16,917,918,919,921],{},"因為後來自己買了一台車子的關係，所以我就不再跟人家借車子，所以我接下來不管怎麼調整自己的車子都不會影響到原本 ",[33,920,762],{}," 變數：",[26,923,925],{"className":113,"code":924,"language":115,"meta":31,"style":31},"car = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray = car \n\nray = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray['radio'] = 0\n\nprint(car['radio']) # 1\n",[33,926,927,931,935,939,943,947,951,955,959,963,967,971,975,979,983,988,992],{"__ignoreMap":31},[36,928,929],{"class":38,"line":39},[36,930,737],{},[36,932,933],{"class":38,"line":60},[36,934,777],{},[36,936,937],{"class":38,"line":73},[36,938,782],{},[36,940,941],{"class":38,"line":86},[36,942,787],{},[36,944,945],{"class":38,"line":93},[36,946,566],{},[36,948,949],{"class":38,"line":179},[36,950,90],{"emptyLinePlaceholder":89},[36,952,953],{"class":38,"line":185},[36,954,890],{},[36,956,957],{"class":38,"line":191},[36,958,90],{"emptyLinePlaceholder":89},[36,960,961],{"class":38,"line":196},[36,962,899],{},[36,964,965],{"class":38,"line":202},[36,966,777],{},[36,968,969],{"class":38,"line":207},[36,970,782],{},[36,972,973],{"class":38,"line":313},[36,974,787],{},[36,976,977],{"class":38,"line":318},[36,978,566],{},[36,980,981],{"class":38,"line":416},[36,982,90],{"emptyLinePlaceholder":89},[36,984,985],{"class":38,"line":421},[36,986,987],{},"ray['radio'] = 0\n",[36,989,990],{"class":38,"line":427},[36,991,90],{"emptyLinePlaceholder":89},[36,993,994],{"class":38,"line":432},[36,995,996],{},"print(car['radio']) # 1\n",[16,998,999,1000,1003,1004,1007],{},"上面的舉例只是希望讀者在閱讀時可以比較好理解，因此只要你看到變數被重新賦予一個字典 or 物件，就代表他會重新指向到一個新的記憶體空間(空車殼)，如果這樣子還不好理解的話，以後你只要看到變數被重新賦予一個 ",[33,1001,1002],{},"{}"," or ",[33,1005,1006],{},"[]"," 就代表著它被重新指定了位址，因此就不會發生所謂的物件傳參考問題。",[16,1009,1010,1011,1014],{},"當然你也可以活用前面章節所學的 ",[33,1012,1013],{},"id"," 來查看彼此的記憶體空間是否相同：",[26,1016,1018],{"className":113,"code":1017,"language":115,"meta":31,"style":31},"car = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray = car\n\nprint(id(ray), id(car)) # 4463682048, 4463682048\n",[33,1019,1020,1024,1028,1032,1036,1040,1044,1048,1052],{"__ignoreMap":31},[36,1021,1022],{"class":38,"line":39},[36,1023,737],{},[36,1025,1026],{"class":38,"line":60},[36,1027,777],{},[36,1029,1030],{"class":38,"line":73},[36,1031,782],{},[36,1033,1034],{"class":38,"line":86},[36,1035,787],{},[36,1037,1038],{"class":38,"line":93},[36,1039,566],{},[36,1041,1042],{"class":38,"line":179},[36,1043,90],{"emptyLinePlaceholder":89},[36,1045,1046],{"class":38,"line":185},[36,1047,800],{},[36,1049,1050],{"class":38,"line":191},[36,1051,90],{"emptyLinePlaceholder":89},[36,1053,1054],{"class":38,"line":196},[36,1055,1056],{},"print(id(ray), id(car)) # 4463682048, 4463682048\n",[16,1058,1059],{},"如果是重新賦予的話，則是不同的記億體位置：",[26,1061,1063],{"className":113,"code":1062,"language":115,"meta":31,"style":31},"car = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nray = car \n\nray = {\n  'steeringWheel': 1,\n  'wheels': 4,\n  'radio': 1,\n}\n\nprint(id(ray), id(car)) # 4418249408 4418249216\n",[33,1064,1065,1069,1073,1077,1081,1085,1089,1093,1097,1101,1105,1109,1113,1117,1121],{"__ignoreMap":31},[36,1066,1067],{"class":38,"line":39},[36,1068,737],{},[36,1070,1071],{"class":38,"line":60},[36,1072,777],{},[36,1074,1075],{"class":38,"line":73},[36,1076,782],{},[36,1078,1079],{"class":38,"line":86},[36,1080,787],{},[36,1082,1083],{"class":38,"line":93},[36,1084,566],{},[36,1086,1087],{"class":38,"line":179},[36,1088,90],{"emptyLinePlaceholder":89},[36,1090,1091],{"class":38,"line":185},[36,1092,890],{},[36,1094,1095],{"class":38,"line":191},[36,1096,90],{"emptyLinePlaceholder":89},[36,1098,1099],{"class":38,"line":196},[36,1100,899],{},[36,1102,1103],{"class":38,"line":202},[36,1104,777],{},[36,1106,1107],{"class":38,"line":207},[36,1108,782],{},[36,1110,1111],{"class":38,"line":313},[36,1112,787],{},[36,1114,1115],{"class":38,"line":318},[36,1116,566],{},[36,1118,1119],{"class":38,"line":416},[36,1120,90],{"emptyLinePlaceholder":89},[36,1122,1123],{"class":38,"line":421},[36,1124,1125],{},"print(id(ray), id(car)) # 4418249408 4418249216\n",[16,1127,1128],{},"透過前面章節所學的某些技巧也可以幫助到你理解，因此前面章節所分享的觀念都是非常重要的唷~",[16,1130,1131],{},[334,1132],{"alt":1133,"src":1134},"老鐵記得三連","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632324725130.png",[12,1136,1138],{"id":1137},"call-by-xxx","call by xxx",[16,1140,1141],{},"最後其實你應該會發現我一直刻意閃過一些東西不講，例如...call by xxx or pass by xxx 什麼的，最主要原因是我自己對於 Python 沒有非常的熟悉，所以自己也不敢多講什麼，主要也是怕講錯。",[16,1143,1144,1145,1151],{},"但是如果真的硬要問我的話，我可能會依據 ",[533,1146,1150],{"href":1147,"rel":1148},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002F%E6%B1%82%E5%80%BC%E7%AD%96%E7%95%A5#%E4%BC%A0%E5%85%B1%E4%BA%AB%E5%AF%B9%E8%B1%A1%E8%B0%83%E7%94%A8",[1149],"nofollow","wiki"," 所說的來講，因為以 wiki 的描述來講，Python 是比較接近 Call by sharing",[1153,1154,1155],"blockquote",{},[16,1156,1157,1158,1161],{},"傳共享物件呼叫（Call by sharing）的方式由Barbara Liskov命名",[36,1159,1160],{},"1","，並被Python、Java（物件類型）、JavaScript、Scheme、OCaml等語言使用。",[16,1163,1164],{},"而這一點也剛好跟 JavaScript 非常像，因此我自己覺得你想把 Python 看成 JavaScript 似乎也可以？！",[16,1166,1167],{},"最後的最後也想聊個好玩的東西，也就是以下程式碼：",[26,1169,1171],{"className":113,"code":1170,"language":115,"meta":31,"style":31},"a = 'Ray'\nb = 'Ray'\n\nprint('a', a, id(a)) # a Ray 4351631984\nprint('b', b, id(b)) # b Ray 4351631984\n",[33,1172,1173,1177,1182,1186,1191],{"__ignoreMap":31},[36,1174,1175],{"class":38,"line":39},[36,1176,122],{},[36,1178,1179],{"class":38,"line":60},[36,1180,1181],{},"b = 'Ray'\n",[36,1183,1184],{"class":38,"line":73},[36,1185,90],{"emptyLinePlaceholder":89},[36,1187,1188],{"class":38,"line":86},[36,1189,1190],{},"print('a', a, id(a)) # a Ray 4351631984\n",[36,1192,1193],{"class":38,"line":93},[36,1194,1195],{},"print('b', b, id(b)) # b Ray 4351631984\n",[16,1197,1198,1199,1202,1203,1206,1207,1210],{},"上面你可以發現我並沒有 ",[33,1200,1201],{},"a = b","，但是兩者的記憶體位置卻是相同，因此代表著字串在建立時都是指向同一個記憶體位置，也因此才會導致 ",[33,1204,1205],{},"a == b"," 是一個 ",[33,1208,1209],{},"True","，而這一段我覺得可以理解下面這張圖：",[16,1212,1213],{},[334,1214],{"alt":1215,"src":1216},"記憶體空間","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F202109222350.png",[16,1218,1219],{},"但是如果重新賦予其他值的時候，就會是直接指向到另一個記憶體位置：",[16,1221,1222],{},[334,1223],{"alt":1224,"src":1225},"重新指向記憶體空間","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F202109222352.png",[16,1227,1228,1229,1003,1231,1233,1234,1236],{},"如果是字典的話，那麼也是類似，但是字典則是看到一個新的 ",[33,1230,1002],{},[33,1232,1006],{}," 才會重新指向，這邊就讓我偷懶一下用之前 「",[533,1235,536],{"href":535},"」的文章圖片偷懶一下：",[16,1238,1239],{},[334,1240],{"alt":1241,"src":1242},"物件參考觀念的實際運作模式","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-16%2000.05.38.png",[16,1244,1245],{},"那今天也差不多介紹到這邊就告一個段落囉~",[12,1247,1248],{"id":1248},"參考文獻",[1250,1251,1252,1260],"ul",{},[1253,1254,1255],"li",{},[533,1256,1259],{"href":1257,"rel":1258},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002F%E6%B1%82%E5%80%BC%E7%AD%96%E7%95%A5",[1149],"求值策略",[1253,1261,1262],{},[533,1263,536],{"href":535},[12,1265,1266],{"id":1266},"作者的話",[16,1268,1269],{},"中秋節那段時間因為回老家團圓的關係，所以訊號一直都很差，幾乎只能打電話不能上網的等級，所以中秋節的晚上我都只能站在馬路正中央收發訊息，收發完就要快點閃離馬路，不然我現在應該不會在這邊寫文章了...",[12,1271,1272],{"id":1272},"關於兔兔們",[1250,1274,1275,1282,1290,1298],{},[1253,1276,1277],{},[533,1278,1281],{"href":1279,"rel":1280},"https:\u002F\u002Ftailwindcss.tw",[1149],"Tailwind CSS 臺灣官網",[1253,1283,1284,1289],{},[533,1285,1288],{"href":1286,"rel":1287},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[1149],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[1253,1291,1292,1297],{},[533,1293,1296],{"href":1294,"rel":1295},"https:\u002F\u002F