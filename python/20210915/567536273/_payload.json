圍內。')\n  elif 30 >= bmiNum \u003C 35:\n    print('你目前的 BMI 是：', bmiNum, '介於中度範圍內。')\n  elif bmiNum >= 35:\n    print('你目前的 BMI 是：', bmiNum, '介於重度範圍內。')\n  else:\n    print('計算錯誤。')\n\nprint(bmi(68, 175)) # 你目前的 BMI 是： 22.2 介於過重範圍內。\nprint(bmi(95, 185)) # 你目前的 BMI 是： 27.76 介於中度範圍內。\n","py","",[34,35,36,44,50,56,62,68,75,81,86,92,98,104,110,116,122,128,134,140,146,152,158,164,170,175,181],"code",{"__ignoreMap":32},[37,38,41],"span",{"class":39,"line":40},"line",1,[37,42,43],{},"def bmi (kg, cm):\n",[37,45,47],{"class":39,"line":46},2,[37,48,49],{},"  if kg \u003C= 0:\n",[37,51,53],{"class":39,"line":52},3,[37,54,55],{},"    return print('體重輸入不正確')\n",[37,57,59],{"class":39,"line":58},4,[37,60,61],{},"  if cm \u003C= 0:\n",[37,63,65],{"class":39,"line":64},5,[37,66,67],{},"    return print('身高輸入不正確')\n",[37,69,71],{"class":39,"line":70},6,[37,72,74],{"emptyLinePlaceholder":73},true,"\n",[37,76,78],{"class":39,"line":77},7,[37,79,80],{},"  bmiNum = round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2)\n",[37,82,84],{"class":39,"line":83},8,[37,85,74],{"emptyLinePlaceholder":73},[37,87,89],{"class":39,"line":88},9,[37,90,91],{},"  if bmiNum \u003C 18.5:\n",[37,93,95],{"class":39,"line":94},10,[37,96,97],{},"    print('你目前的 BMI 是：', bmiNum, '介於過輕範圍內。')\n",[37,99,101],{"class":39,"line":100},11,[37,102,103],{},"  elif 18.5 >= bmiNum \u003C 24:\n",[37,105,107],{"class":39,"line":106},12,[37,108,109],{},"    print('你目前的 BMI 是：', bmiNum, '介於正常範圍內。')\n",[37,111,113],{"class":39,"line":112},13,[37,114,115],{},"  elif 24 >= bmiNum \u003C 27:\n",[37,117,119],{"class":39,"line":118},14,[37,120,121],{},"    print('你目前的 BMI 是：', bmiNum, '介於過重範圍內。')\n",[37,123,125],{"class":39,"line":124},15,[37,126,127],{},"  elif 27 >= bmiNum \u003C 30:\n",[37,129,131],{"class":39,"line":130},16,[37,132,133],{},"    print('你目前的 BMI 是：', bmiNum, '介於輕度範圍內。')\n",[37,135,137],{"class":39,"line":136},17,[37,138,139],{},"  elif 30 >= bmiNum \u003C 35:\n",[37,141,143],{"class":39,"line":142},18,[37,144,145],{},"    print('你目前的 BMI 是：', bmiNum, '介於中度範圍內。')\n",[37,147,149],{"class":39,"line":148},19,[37,150,151],{},"  elif bmiNum >= 35:\n",[37,153,155],{"class":39,"line":154},20,[37,156,157],{},"    print('你目前的 BMI 是：', bmiNum, '介於重度範圍內。')\n",[37,159,161],{"class":39,"line":160},21,[37,162,163],{},"  else:\n",[37,165,167],{"class":39,"line":166},22,[37,168,169],{},"    print('計算錯誤。')\n",[37,171,173],{"class":39,"line":172},23,[37,174,74],{"emptyLinePlaceholder":73},[37,176,178],{"class":39,"line":177},24,[37,179,180],{},"print(bmi(68, 175)) # 你目前的 BMI 是： 22.2 介於過重範圍內。\n",[37,182,184],{"class":39,"line":183},25,[37,185,186],{},"print(bmi(95, 185)) # 你目前的 BMI 是： 27.76 介於中度範圍內。\n",[16,188,189],{},"接下來我們會將上面的程式碼加入一些小功能",[16,191,192],{},[193,194],"img",{"alt":195,"src":196},"小功能","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630827199758.png",[16,198,199],{},"(上面這張圖真好用。)",[16,201,202],{},"所以這邊我們先來聊一下使用者故事吧。",[12,204,206],{"id":205},"bmi-使用者故事","BMI 使用者故事",[208,209,210,214,217],"ul",{},[211,212,213],"li",{},"使用者可以透過終端機輸入身高與體重，而必須是身高優先輸入接下來才是體重。",[211,215,216],{},"輸出結果之前會先出現 Loading 讀取中約五秒。",[211,218,219,220],{},"五秒之後會輸出結果顯示 BMI 值與目前 BMI 介於哪個範圍內。\n",[208,221,222],{},[211,223,224],{},"例如：你目前的 BMI 是： 22.2 介於過重範圍內。",[16,226,227],{},"最後在列一個進階一點的東西好了",[208,229,230],{},[211,231,232,233],{},"輸出的結果必須依據以下範圍輸出相關的文字顏色\n",[208,234,235,238,241,244,247,250],{},[211,236,237],{},"例如：「你目前的 BMI 是： 22.2 介於過重範圍內」的這句話的過重必須是橘色。",[211,239,240],{},"過輕 - 黃色",[211,242,243],{},"正常 - 綠色",[211,245,246],{},"輕度 - 黃色",[211,248,249],{},"中度 - 橘色",[211,251,252],{},"重度 - 紅色",[16,254,255],{},"那麼看完上方使用者故事之後就準備來實作吧。",[16,257,258],{},"往下看之前你也可以先試著自己製作看看，如果沒有想法的話，再往下參考我的作法哩。",[12,260,261],{"id":261},"使用者自定義輸入身高與體重",[16,263,264],{},"剛好這邊的技巧在前一個章節已經有講到，想必記憶非常深刻，所以我們這邊會需要宣告身高與體重這兩個變數，但是這邊要注意使用者故事有講到一件事情：",[16,266,267],{},"「使用者可以透過終端機輸入身高與體重，而必須是身高優先輸入接下來才是體重。」",[16,269,270,271,274,275,278,279,282],{},"因此這邊我們可以知道我們將會使用 ",[34,272,273],{},"input"," 函式，接下來另一個問題是，使用者所輸入的值都會是字串，因此這邊應該使用正整數？還是浮點數呢？通常來講我們在量身高與體重的時候都會有小數點，因此這邊會建議使用 ",[34,276,277],{},"float()"," 包覆 ",[34,280,281],{},"input()"," 函式：",[27,284,286],{"className":29,"code":285,"language":31,"meta":32,"style":32},"cm = float(input('請輸入您的身高：'))\nkg = float(input('請輸入您的體重：'))\n",[34,287,288,293],{"__ignoreMap":32},[37,289,290],{"class":39,"line":40},[37,291,292],{},"cm = float(input('請輸入您的身高：'))\n",[37,294,295],{"class":39,"line":46},[37,296,297],{},"kg = float(input('請輸入您的體重：'))\n",[16,299,300],{},"那麼第一條使用者故事這邊算是完成了。",[12,302,304],{"id":303},"loading-效果","Loading 效果",[16,306,307],{},"接下來是關於終端機上呈現 Loading 的效果，這一個效果在使用者故事上有講到要等五秒",[16,309,310],{},"「輸出結果之前會先出現 Loading 讀取中約五秒。」",[16,312,313,314,317,318,321],{},"這個功能的關鍵重點技術在於 ",[34,315,316],{},"for loop"," 與 ",[34,319,320],{},"print","，因此可能會需要跑五次迴圈：",[27,323,325],{"className":29,"code":324,"language":31,"meta":32,"style":32},"for i in range(5):\n  print('Loading')\n",[34,326,327,332],{"__ignoreMap":32},[37,328,329],{"class":39,"line":40},[37,330,331],{},"for i in range(5):\n",[37,333,334],{"class":39,"line":46},[37,335,336],{},"  print('Loading')\n",[16,338,339,340,343,344,347,348,350,351,354,355,357,358,360,361,364],{},"基本上上面的程式碼結果就會是跑五次 ",[34,341,342],{},"Loading","，但是可能有點不好看，所以我們可以稍微調整一下變成 ",[34,345,346],{},"Loading.....","，那麼因此要做到這個效果我們就必須使用 ",[34,349,320],{}," 的 ",[34,352,353],{},"end"," 參數，這是什麼意思呢？我們可以看到是五個點點，因此我們可以先將 ",[34,356,342],{}," 文字輸出，接下來的點點點都是用迴圈輸出，那麼預設情況下 ",[34,359,320],{}," 是 ",[34,362,363],{},"\\n"," 換行，因此我們要改成無換行模式：",[27,366,368],{"className":29,"code":367,"language":31,"meta":32,"style":32},"print('Loading', end='')\nfor i in range(5):\n  print('.', end='')\n",[34,369,370,375,379],{"__ignoreMap":32},[37,371,372],{"class":39,"line":40},[37,373,374],{},"print('Loading', end='')\n",[37,376,377],{"class":39,"line":46},[37,378,331],{},[37,380,381],{"class":39,"line":52},[37,382,383],{},"  print('.', end='')\n",[16,385,386,387,389,390,393,394,397,398,400,401,404,405,407,408,411],{},"上面的結果基本上已經非常接近我們要的效果 ",[34,388,346],{},"，接下來就是我們要如何做到點點點是一秒一個點的方式，那麼由於 Python 內建是沒有時間相關處理的函式，因此這邊就必須額外引入 Python 的 ",[34,391,392],{},"time"," 模組(",[34,395,396],{},"import time",")，而 ",[34,399,392],{}," 底下有一個 ",[34,402,403],{},"sleep"," 函式，這個函式主要用途是讓程式碼暫停你要停止的秒數，所以這一段 ",[34,406,403],{}," 補在 ",[34,409,410],{},"print('.', end='')"," 結尾處就可以了：",[27,413,415],{"className":29,"code":414,"language":31,"meta":32,"style":32},"import time\n\nprint('Loading', end='')\nfor i in range(5):\n  print('.', end='')\n  time.sleep(1) # 讓程式碼睡一秒\n",[34,416,417,422,426,430,434,438],{"__ignoreMap":32},[37,418,419],{"class":39,"line":40},[37,420,421],{},"import time\n",[37,423,424],{"class":39,"line":46},[37,425,74],{"emptyLinePlaceholder":73},[37,427,428],{"class":39,"line":52},[37,429,374],{},[37,431,432],{"class":39,"line":58},[37,433,331],{},[37,435,436],{"class":39,"line":64},[37,437,383],{},[37,439,440],{"class":39,"line":70},[37,441,442],{},"  time.sleep(1) # 讓程式碼睡一秒\n",[16,444,445,446,448,449,451,452,455,456,360,458,461,462,465],{},"這時候你應該會發現程式碼沒有即時地出現，當它出現的時候已經是一個完整的 ",[34,447,346],{}," 而不是一個點點點出現，這邊問題主要是出在 ",[34,450,320],{}," 參數中有一個 ",[34,453,454],{},"flush"," 導致的，預設 ",[34,457,454],{},[34,459,460],{},"False","，而這個參數會先將預期要輸出的結果放到記憶體中等待迴圈全部跑完再一次輸出，如果改完 ",[34,463,464],{},"True"," 的話就會變成不讓它將結果放到記憶體中而是直接輸出：",[27,467,469],{"className":29,"code":468,"language":31,"meta":32,"style":32},"import time\n\nprint('Loading', end='')\nfor i in range(5):\n  print('.', end='', flush=True)\n  time.sleep(1) # 讓程式碼睡一秒\n",[34,470,471,475,479,483,487,492],{"__ignoreMap":32},[37,472,473],{"class":39,"line":40},[37,474,421],{},[37,476,477],{"class":39,"line":46},[37,478,74],{"emptyLinePlaceholder":73},[37,480,481],{"class":39,"line":52},[37,482,374],{},[37,484,485],{"class":39,"line":58},[37,486,331],{},[37,488,489],{"class":39,"line":64},[37,490,491],{},"  print('.', end='', flush=True)\n",[37,493,494],{"class":39,"line":70},[37,495,442],{},[16,497,498,499,501],{},"所以 ",[34,500,454],{}," 其實是一個很特別的屬性唷~",[12,503,505],{"id":504},"輸出-bmi-結果","輸出 BMI 結果",[16,507,508,509,317,511,513],{},"這邊先整理一下程式碼，先將上面 ",[34,510,273],{},[34,512,342],{}," 程式碼都整合之後再來看一下：",[27,515,517],{"className":29,"code":516,"language":31,"meta":32,"style":32},"import time\n\ncm = float(input('請輸入您的身高：'))\nkg = float(input('請輸入您的體重：'))\n\nprint('Loading', end='')\nfor i in range(5):\n  print('.', end='', flush=True)\n  time.sleep(1) # 讓程式碼睡一秒\n",[34,518,519,523,527,531,535,539,543,547,551],{"__ignoreMap":32},[37,520,521],{"class":39,"line":40},[37,522,421],{},[37,524,525],{"class":39,"line":46},[37,526,74],{"emptyLinePlaceholder":73},[37,528,529],{"class":39,"line":52},[37,530,292],{},[37,532,533],{"class":39,"line":58},[37,534,297],{},[37,536,537],{"class":39,"line":64},[37,538,74],{"emptyLinePlaceholder":73},[37,540,541],{"class":39,"line":70},[37,542,374],{},[37,544,545],{"class":39,"line":77},[37,546,331],{},[37,548,549],{"class":39,"line":83},[37,550,491],{},[37,552,553],{"class":39,"line":88},[37,554,442],{},[16,556,557],{},"那麼其實 BMI 計算這邊我就偷懶一下，直接將先前的寫好的計算程式碼直接拉進來微調就好了：",[27,559,561],{"className":29,"code":560,"language":31,"meta":32,"style":32},"import time\n\ncm = float(input('請輸入您的身高：'))\nkg = float(input('請輸入您的體重：'))\n\ndef bmi (kg, cm):\n  if kg \u003C= 0:\n    return print('體重輸入不正確')\n  if cm \u003C= 0:\n    return print('身高輸入不正確')\n\n  bmiNum = round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2)\n\n  if bmiNum \u003C 18.5:\n    print('你目前的 BMI 是：', bmiNum, '介於過輕範圍內。')\n  elif 18.5 >= bmiNum \u003C 24:\n    print('你目前的 BMI 是：', bmiNum, '介於正常範圍內。')\n  elif 24 >= bmiNum \u003C 27:\n    print('你目前的 BMI 是：', bmiNum, '介於過重範圍內。')\n  elif 27 >= bmiNum \u003C 30:\n    print('你目前的 BMI 是：', bmiNum, '介於輕度範圍內。')\n  elif 30 >= bmiNum \u003C 35:\n    print('你目前的 BMI 是：', bmiNum, '介於中度範圍內。')\n  elif bmiNum >= 35:\n    print('你目前的 BMI 是：', bmiNum, '介於重度範圍內。')\n  else:\n    print('計算錯誤。')\n\nprint('Loading', end='')\nfor i in range(5):\n  print('.', end='', flush=True)\n  time.sleep(1)\n\nbmi(kg, cm)\n",[3