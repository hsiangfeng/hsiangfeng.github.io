"line":113},[55,577,441],{"class":76},[55,579,498],{"class":61},[55,581,447],{"class":76},[55,583,450],{"class":61},[55,585,586],{"class":76},"...",[55,588,589],{"class":61},"a, ",[55,591,586],{"class":76},[55,593,594],{"class":61},"b];\n",[55,596,597,599,601,603],{"class":57,"line":135},[55,598,62],{"class":61},[55,600,66],{"class":65},[55,602,518],{"class":61},[55,604,521],{"class":86},[16,606,607],{},"如果你用加號運算子就會是另一種結果：",[46,609,611],{"className":48,"code":610,"language":50,"meta":51,"style":51},"var a = [1, 2, 3];\nvar b = [4, 5, 6];\nvar c = a + b;\nconsole.log(c); \u002F\u002F \"1,2,34,5,6\"\n",[26,612,613,635,657,672],{"__ignoreMap":51},[55,614,615,617,619,621,623,625,627,629,631,633],{"class":57,"line":58},[55,616,441],{"class":76},[55,618,444],{"class":61},[55,620,447],{"class":76},[55,622,450],{"class":61},[55,624,73],{"class":72},[55,626,455],{"class":61},[55,628,99],{"class":72},[55,630,455],{"class":61},[55,632,462],{"class":72},[55,634,465],{"class":61},[55,636,637,639,641,643,645,647,649,651,653,655],{"class":57,"line":90},[55,638,441],{"class":76},[55,640,472],{"class":61},[55,642,447],{"class":76},[55,644,450],{"class":61},[55,646,479],{"class":72},[55,648,455],{"class":61},[55,650,484],{"class":72},[55,652,455],{"class":61},[55,654,489],{"class":72},[55,656,465],{"class":61},[55,658,659,661,663,665,667,669],{"class":57,"line":113},[55,660,441],{"class":76},[55,662,498],{"class":61},[55,664,447],{"class":76},[55,666,444],{"class":61},[55,668,28],{"class":76},[55,670,671],{"class":61}," b;\n",[55,673,674,676,678,680],{"class":57,"line":135},[55,675,62],{"class":61},[55,677,66],{"class":65},[55,679,518],{"class":61},[55,681,682],{"class":86},"\u002F\u002F \"1,2,34,5,6\"\n",[16,684,685,686,690],{},"至於原因的話，可以詳見我先前寫的 ",[291,687,689],{"href":688},"\u002Fjavascript\u002F20200628\u002F4021116713\u002F","筆記"," 有提到此觀念，所以這邊就不多述了。",[16,692,693,694,697],{},"那麼 Python 呢？Python 就比較特別一點，Python 可以使用 ",[411,695,696],{},"加號運算子"," 快速達到這個陣列合併這個需求：",[46,699,701],{"className":160,"code":700,"language":162,"meta":51,"style":51},"a = [1, 2 ,3]\nb = [4, 5, 6]\nc = a + b\nprint(c) # [1, 2, 3, 4, 5, 6]\n",[26,702,703,708,713,718],{"__ignoreMap":51},[55,704,705],{"class":57,"line":58},[55,706,707],{},"a = [1, 2 ,3]\n",[55,709,710],{"class":57,"line":90},[55,711,712],{},"b = [4, 5, 6]\n",[55,714,715],{"class":57,"line":113},[55,716,717],{},"c = a + b\n",[55,719,720],{"class":57,"line":135},[55,721,722],{},"print(c) # [1, 2, 3, 4, 5, 6]\n",[16,724,725],{},"超簡單的對吧！",[16,727,728,729,732,733,735],{},"這邊也簡單提一下另一種合併陣列的方式，也就是前一章節所提到的 ",[26,730,731],{},"extend()","，但是這邊要注意 ",[26,734,731],{}," 會修改原有的陣列，因此並不會回傳結果到新的變數上，這一點一定要注意一下：",[46,737,739],{"className":160,"code":738,"language":162,"meta":51,"style":51},"a = [1, 2 ,3]\nb = [4, 5, 6]\nc = a.extend(b)\nprint(c) # None\nprint(a) # [1, 2, 3, 4, 5, 6]\n",[26,740,741,745,749,754,759],{"__ignoreMap":51},[55,742,743],{"class":57,"line":58},[55,744,707],{},[55,746,747],{"class":57,"line":90},[55,748,712],{},[55,750,751],{"class":57,"line":113},[55,752,753],{},"c = a.extend(b)\n",[55,755,756],{"class":57,"line":135},[55,757,758],{},"print(c) # None\n",[55,760,762],{"class":57,"line":761},5,[55,763,764],{},"print(a) # [1, 2, 3, 4, 5, 6]\n",[16,766,767,768,771],{},"最後這邊還有另一種更簡短加號運算子寫法，但是它與 ",[26,769,770],{},"extend"," 的效果是一樣的，它是修改原始的串列在賦予回去：",[16,773,774],{},"哦對了！Python 還有一些好玩的地方，例如你可以使用乘法運算子讓字串加倍：",[46,776,778],{"className":160,"code":777,"language":162,"meta":51,"style":51},"print('Ray' * 4) # RayRayRayRay\n",[26,779,780],{"__ignoreMap":51},[55,781,782],{"class":57,"line":58},[55,783,777],{},[16,785,786],{},"甚至是串列與元組的加倍也可以：",[46,788,790],{"className":160,"code":789,"language":162,"meta":51,"style":51},"print(('https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F') * 4) # ('https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F')\n\n# 元組\nprint(['https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F'] * 4) # ['https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F']\n",[26,791,792,797,803,808],{"__ignoreMap":51},[55,793,794],{"class":57,"line":58},[55,795,796],{},"print(('https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F') * 4) # ('https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F')\n",[55,798,799],{"class":57,"line":90},[55,800,802],{"emptyLinePlaceholder":801},true,"\n",[55,804,805],{"class":57,"line":113},[55,806,807],{},"# 元組\n",[55,809,810],{"class":57,"line":135},[55,811,812],{},"print(['https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F'] * 4) # ['https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F', 'https:\u002F\u002Fwww.facebook.com\u002Fisraynotarray', '\u002F']\n",[16,814,815],{},"那麼在四則運算中，其實還有一些比較進階一點的用法，例如次方：",[46,817,819],{"className":160,"code":818,"language":162,"meta":51,"style":51},"print(10 ** 2) # 100\nprint(12 ** 2) # 144\n",[26,820,821,826],{"__ignoreMap":51},[55,822,823],{"class":57,"line":58},[55,824,825],{},"print(10 ** 2) # 100\n",[55,827,828],{"class":57,"line":90},[55,829,830],{},"print(12 ** 2) # 144\n",[16,832,833,834,837,838,841,842,845,846,849],{},"其他還有常見的運算子，例如：大於(",[26,835,836],{},">",")、小於(",[26,839,840],{},"\u003C",")、大於等於(",[26,843,844],{},">=",")、小於等於(",[26,847,848],{},"\u003C=",")等等，這邊就只是列出四則運算多部份而已。",[12,851,852],{"id":852},"運算子的優先性與相依性問題",[16,854,855,856,860],{},"最後我想聊一個在 JavaScript 面試考題很常出現的問題，在 JavaScript 我們知道有所謂的優先性與相依性的觀念，如果你不清楚的話，我會建議可以參考這一篇 ",[291,857,859],{"href":858},"\u002Fjavascript\u002F20200628\u002F713590185\u002F","JavaScript 核心觀念(16)-運算子、型別與文法-優先性及相依性"," 文章。",[16,862,863,864,867,868,871],{},"那麼以 JavaScript 中很經典的題目就是 ",[26,865,866],{},"console.log(1 \u003C 2 \u003C 3); \u002F\u002F true"," 但是反之若變成了 ",[26,869,870],{},"console.log(3 > 2 > 1); \u002F\u002F false"," 結果就不同了。",[16,873,874],{},"所以這邊也想探討看看 Python 也會有這個問題嗎？其實我們可以實際試試看：",[46,876,878],{"className":160,"code":877,"language":162,"meta":51,"style":51},"print(1 \u003C 2 \u003C 3) # True\nprint(3 > 2 > 1) # True\n",[26,879,880,885],{"__ignoreMap":51},[55,881,882],{"class":57,"line":58},[55,883,884],{},"print(1 \u003C 2 \u003C 3) # True\n",[55,886,887],{"class":57,"line":90},[55,888,889],{},"print(3 > 2 > 1) # True\n",[16,891,892,893,896],{},"可以看到結果都是 ",[26,894,895],{},"True","，這樣代表 Python 沒有優先性與相依性的問題嗎？",[16,898,899],{},"其實是有的。",[16,901,902,903,908],{},"在 ",[291,904,907],{"href":905,"rel":906},"https:\u002F\u002Fdocs.python.org\u002Fzh-tw\u002F3\u002Freference\u002Fexpressions.html#operator-precedence",[295],"Python 文件"," 中有講到這句話",[910,911,912],"blockquote",{},[16,913,914],{},"请注意比较、成员检测和标识号检测均为相同优先级，并具有如 比较运算 一节所描述的从左至右串连特性。",[16,916,917],{},"因此你也可以在上面連結中看到底下這一張圖，最上方優先性最高，最下方則是優先性最低：",[16,919,920],{},[194,921],{"alt":922,"src":923},"運算子的優先序","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-11%2022.20.06.png",[16,925,926,927,930],{},"所以前面的範例 ",[26,928,929],{},"print(3 > 2 > 1) # True"," 範例程式碼它到底是怎麼運作的呢？",[16,932,933],{},"我們可以依照官方文件的解釋來推敲一二：",[910,935,936],{},[16,937,938],{},"例如 x \u003C y \u003C= z 等价于 x \u003C y and y \u003C= z，除了 y 只被求值一次（但在两种写法下当 x \u003C y 值为假时 z 都不会被求值）。",[16,940,941,942,945,946,949,950,953,954,957,958,960],{},"透過上面的解釋，我們可以得知範例程式碼在運作的模式其實是 ",[26,943,944],{},"3 > 2"," 與 ",[26,947,948],{},"2 > 1","，這邊要注意中間是 ",[26,951,952],{},"&"," 符號，代表著兩邊若有一邊是 ",[26,955,956],{},"False"," 就會整個回傳 ",[26,959,956],{},"，例如：",[46,962,964],{"className":160,"code":963,"language":162,"meta":51,"style":51},"print(3 > 2 > 4) # False\n",[26,965,966],{"__ignoreMap":51},[55,967,968],{"class":57,"line":58},[55,969,963],{},[16,971,972,973,976],{},"如果用比較白話一點方式來看的話，結果就會像是 ",[26,974,975],{},"3 > 2 & 2 > 4","。",[16,978,979],{},"那我們今天運算子的章節就先到這邊結束囉~",[12,981,982],{"id":982},"參考文獻",[984,985,986,994,1000],"ul",{},[987,988,989],"li",{},[291,990,993],{"href":991,"rel":992},"https:\u002F\u002Fdocs.python.org\u002Fzh-tw\u002F3\u002Freference\u002Fexpressions.html#comparisons",[295],"比较运算",[987,995,996],{},[291,997,999],{"href":905,"rel":998},[295],"运算符优先级",[987,1001,1002],{},[291,1003,296],{"href":293,"rel":1004},[295],[12,1006,1007],{"id":1007},"作者的話",[16,1009,1010],{},"上網找到了一篇「絕對不會失敗的溏心蛋」，結果實作之後還是失敗了 Orz，實在太過不熟...但是不得不說有機雞蛋的蛋腥味真的還好呢！",[12,1012,1013],{"id":1013},"關於兔兔們",[984,1015,1016,1023,1031,1039],{},[987,1017,1018],{},[291,1019,1022],{"href":1020,"rel":1021},"https:\u002F\u002Ftailwindcss.tw",[295],"Tailwind CSS 臺灣官網",[987,1024,1025,1030],{},[291,1026,1029],{"href":1027,"rel":1028},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[295],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[987,1032,1033,1038],{},[291,1034,1037],{"href":1035,"rel":1036},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[295],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[987,1040,1041],{},[291,1042,1045],{"href":1043,"rel":1044},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[295],"兔兔教大本營",[16,1047,1048],{},[194,1049],{"alt":1050,"src":1051},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[1053,1054,1055],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sCcAr, html 