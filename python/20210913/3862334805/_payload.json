[{"data":1,"prerenderedAt":1107},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210913\u002F3862334805\u002F":3,"page:\u002Fpython\u002F20210913\u002F3862334805\u002F":4,"alt:\u002Fpython\u002F20210913\u002F3862334805\u002F":3,"prev-next:\u002Fpython\u002F20210913\u002F3862334805\u002F":1085,"related:\u002Fpython\u002F20210913\u002F3862334805\u002F":1094},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F13\u002Flearn-python-from-javascript-12-operators\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1068,"date":1069,"description":1070,"extension":1071,"lang":1072,"meta":1073,"navigation":801,"path":1074,"readingMinutes":484,"seo":1075,"standalone":1076,"stem":1077,"tags":1078,"tldr":1082,"updated":1082,"url":1083,"__hash__":1084},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-12-運算子.md","從 JavaScript 角度學 Python(12) - 運算子","3862334805",{"type":9,"value":10,"toc":1056},"minimark",[11,15,19,22,42,45,155,158,185,188,191,198,201,204,208,211,226,229,232,246,249,255,270,273,287,298,301,304,310,315,322,331,337,352,355,375,378,398,404,419,422,425,432,522,525,605,608,683,691,698,723,726,736,765,772,775,784,787,813,816,831,850,853,861,872,875,890,897,900,909,915,918,924,931,934,939,961,970,977,980,983,1005,1008,1011,1014,1046,1052],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"運算子是一個非常常用的方法，因此在基礎觀念中也是絕對閃不了的。",[12,20,21],{"id":21},"運算子",[16,23,24,25,29,30,33,34,37,38,41],{},"最基本的運算子不外乎就是 ",[26,27,28],"code",{},"+"," (加)、",[26,31,32],{},"-"," (減)、",[26,35,36],{},"*"," (乘)、",[26,39,40],{},"\u002F"," (除) 這幾個運算子，而這幾個運算子又稱之為算數運算子，在 JavaScript 中的寫法也不會與 Python 有太大的差異。",[16,43,44],{},"JavaScript：",[46,47,52],"pre",{"className":48,"code":49,"language":50,"meta":51,"style":51},"language-js shiki shiki-themes github-dark-high-contrast","console.log(1 + 1); \u002F\u002F 2\nconsole.log(2 * 2); \u002F\u002F 4\nconsole.log(8 - 2); \u002F\u002F 6\nconsole.log(16 \u002F 2); \u002F\u002F 8\n","js","",[26,53,54,88,111,133],{"__ignoreMap":51},[55,56,59,63,67,70,74,78,81,84],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"sMAXC","console.",[55,64,66],{"class":65},"sj_SG","log",[55,68,69],{"class":61},"(",[55,71,73],{"class":72},"sCcAr","1",[55,75,77],{"class":76},"sWyjQ"," +",[55,79,80],{"class":72}," 1",[55,82,83],{"class":61},"); ",[55,85,87],{"class":86},"sQrFR","\u002F\u002F 2\n",[55,89,91,93,95,97,100,103,106,108],{"class":57,"line":90},2,[55,92,62],{"class":61},[55,94,66],{"class":65},[55,96,69],{"class":61},[55,98,99],{"class":72},"2",[55,101,102],{"class":76}," *",[55,104,105],{"class":72}," 2",[55,107,83],{"class":61},[55,109,110],{"class":86},"\u002F\u002F 4\n",[55,112,114,116,118,120,123,126,128,130],{"class":57,"line":113},3,[55,115,62],{"class":61},[55,117,66],{"class":65},[55,119,69],{"class":61},[55,121,122],{"class":72},"8",[55,124,125],{"class":76}," -",[55,127,105],{"class":72},[55,129,83],{"class":61},[55,131,132],{"class":86},"\u002F\u002F 6\n",[55,134,136,138,140,142,145,148,150,152],{"class":57,"line":135},4,[55,137,62],{"class":61},[55,139,66],{"class":65},[55,141,69],{"class":61},[55,143,144],{"class":72},"16",[55,146,147],{"class":76}," \u002F",[55,149,105],{"class":72},[55,151,83],{"class":61},[55,153,154],{"class":86},"\u002F\u002F 8\n",[16,156,157],{},"Python：",[46,159,163],{"className":160,"code":161,"language":162,"meta":51,"style":51},"language-py shiki shiki-themes github-dark-high-contrast","print(1 + 1) # 2\nprint(2 * 2) # 4\nprint(8 - 2) # 6\nprint(16 \u002F 2) # 8.0\n","py",[26,164,165,170,175,180],{"__ignoreMap":51},[55,166,167],{"class":57,"line":58},[55,168,169],{},"print(1 + 1) # 2\n",[55,171,172],{"class":57,"line":90},[55,173,174],{},"print(2 * 2) # 4\n",[55,176,177],{"class":57,"line":113},[55,178,179],{},"print(8 - 2) # 6\n",[55,181,182],{"class":57,"line":135},[55,183,184],{},"print(16 \u002F 2) # 8.0\n",[16,186,187],{},"而上面又稱之為四則運算，但是唯獨除法你可以看到 Python 是輸出一個浮點數(float)。",[16,189,190],{},"疑？你注意到了嗎？Python 的除法竟然輸出一個浮點數",[16,192,193],{},[194,195],"img",{"alt":196,"src":197},"WT...","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631017732503.png",[16,199,200],{},"如果你寫過 Python2 的人可能會更 WT...",[16,202,203],{},"所以這邊先讓我插入一個小片段說明一下 Python2 與 Python3 之間的差異。",[12,205,207],{"id":206},"python2-與-python3-的除法運算子比較","Python2 與 Python3 的除法運算子比較",[16,209,210],{},"這是一個比較特別的的地方，在原本的 Python2 的除法會是一個整數：",[46,212,214],{"className":160,"code":213,"language":162,"meta":51,"style":51},"# Python2\nprint(16 \u002F 2) # 8\n",[26,215,216,221],{"__ignoreMap":51},[55,217,218],{"class":57,"line":58},[55,219,220],{},"# Python2\n",[55,222,223],{"class":57,"line":90},[55,224,225],{},"print(16 \u002F 2) # 8\n",[16,227,228],{},"雖然看起來沒有什麼太大問題，但是如果你要做較精準的系統開發時，其實這就會有問題，因為 Python2 的除法會無條件捨去小數點，因此 Python2 的又稱之為 floor division 或 integer division（整數除法？應該是這樣翻，有錯的話再跟我說一下）。",[16,230,231],{},"那就如同前面所言，如果我們要做比較精準處理時，就會有一些問題：",[46,233,235],{"className":160,"code":234,"language":162,"meta":51,"style":51},"# Python2\nprint(16 \u002F 3 == 16.0 \u002F 3.0) # False\n",[26,236,237,241],{"__ignoreMap":51},[55,238,239],{"class":57,"line":58},[55,240,220],{},[55,242,243],{"class":57,"line":90},[55,244,245],{},"print(16 \u002F 3 == 16.0 \u002F 3.0) # False\n",[16,247,248],{},"嚇到了嗎？如果沒有嚇到的話，我倒是嚇到了，畢竟這兩者應該是相同的才對，這個原因是因為 Python2 的除法運算子本身具有兩種能力，也就是 Floating point division 與 integer division 的能力，只要你針對數字加上小數點就會被轉換成浮點數除法。",[16,250,251,252,254],{},"那麼為了解決這個問題，Python3 之後將 ",[26,253,40],{}," 運算子只保留 Floating point division 的能力也就是浮點數除法，所以在 Python3 結果就會變成以下：",[46,256,258],{"className":160,"code":257,"language":162,"meta":51,"style":51},"# Python3\nprint(16 \u002F 3) # 5.333333333333333\n",[26,259,260,265],{"__ignoreMap":51},[55,261,262],{"class":57,"line":58},[55,263,264],{},"# Python3\n",[55,266,267],{"class":57,"line":90},[55,268,269],{},"print(16 \u002F 3) # 5.333333333333333\n",[16,271,272],{},"那麼因為這個修正的關係，我們在做較精準的計算上就可以比較安全：",[46,274,276],{"className":160,"code":275,"language":162,"meta":51,"style":51},"# Python3\nprint(16 \u002F 3 == 16.0 \u002F 3.0) # True\n",[26,277,278,282],{"__ignoreMap":51},[55,279,280],{"class":57,"line":58},[55,281,264],{},[55,283,284],{"class":57,"line":90},[55,285,286],{},"print(16 \u002F 3 == 16.0 \u002F 3.0) # True\n",[16,288,289,290,297],{},"如果你想更深入了解的話，建議你可以閱讀這一篇 「",[291,292,296],"a",{"href":293,"rel":294},"https:\u002F\u002Fwww.python.org\u002Fdev\u002Fpeps\u002Fpep-0238\u002F",[295],"nofollow","PEP 238 -- Changing the Division Operator","」官方文件。",[16,299,300],{},"好吧，這時候你應該會想說「如果我就是想要整數除法的話，該怎麼做呢？」",[16,302,303],{},"所以就讓我們繼續接著看下去吧~",[16,305,306],{},[194,307],{"alt":308,"src":309},"讓我們接著看下去","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F9446703ab8eced2faa7f9505e5c1ed15.png",[311,312,314],"h3",{"id":313},"operator","\u002F\u002F operator",[16,316,317,318,321],{},"由於 Python3 的修正關係，因此如果你依然想要做到整數除法的話，你可以使用 ",[26,319,320],{},"\u002F\u002F"," 運算子：",[46,323,325],{"className":160,"code":324,"language":162,"meta":51,"style":51},"print(16 \u002F\u002F 3) # 5\n",[26,326,327],{"__ignoreMap":51},[55,328,329],{"class":57,"line":58},[55,330,324],{},[16,332,333,334,336],{},"雖然 ",[26,335,320],{}," 運算子可以做到原本 Python2 類似的整數除法效果：",[46,338,340],{"className":160,"code":339,"language":162,"meta":51,"style":51},"print(16 \u002F\u002F 2) # 8\nprint(type(16 \u002F\u002F 2)) # int\n",[26,341,342,347],{"__ignoreMap":51},[55,343,344],{"class":57,"line":58},[55,345,346],{},"print(16 \u002F\u002F 2) # 8\n",[55,348,349],{"class":57,"line":90},[55,350,351],{},"print(type(16 \u002F\u002F 2)) # int\n",[16,353,354],{},"但是這邊問題來了，你可以試著思考一下以下程式碼結果為何：",[46,356,358],{"className":160,"code":357,"language":162,"meta":51,"style":51},"print(100 \u002F 3, type(100 \u002F 3)) # ?, ?\nprint(100 \u002F\u002F 3, type(100 \u002F\u002F 3)) # ?, ?\nprint(100. \u002F\u002F 3, type(100. \u002F\u002F 3)) # ?, ?\n",[26,359,360,365,370],{"__ignoreMap":51},[55,361,362],{"class":57,"line":58},[55,363,364],{},"print(100 \u002F 3, type(100 \u002F 3)) # ?, ?\n",[55,366,367],{"class":57,"line":90},[55,368,369],{},"print(100 \u002F\u002F 3, type(100 \u002F\u002F 3)) # ?, ?\n",[55,371,372],{"class":57,"line":113},[55,373,374],{},"print(100. \u002F\u002F 3, type(100. \u002F\u002F 3)) # ?, ?\n",[16,376,377],{},"緊張刺激了嗎？讓我們來看看結果吧！",[46,379,381],{"className":160,"code":380,"language":162,"meta":51,"style":51},"print(100 \u002F 3, type(100 \u002F 3)) # 33.333333333333336, float\nprint(100 \u002F\u002F 3, type(100 \u002F\u002F 3)) # 33, int\nprint(100. \u002F\u002F 3, type(100. \u002F\u002F 3)) # 33.0, float\n",[26,382,383,388,393],{"__ignoreMap":51},[55,384,385],{"class":57,"line":58},[55,386,387],{},"print(100 \u002F 3, type(100 \u002F 3)) # 33.333333333333336, float\n",[55,389,390],{"class":57,"line":90},[55,391,392],{},"print(100 \u002F\u002F 3, type(100 \u002F\u002F 3)) # 33, int\n",[55,394,395],{"class":57,"line":113},[55,396,397],{},"print(100. \u002F\u002F 3, type(100. \u002F\u002F 3)) # 33.0, float\n",[16,399,400],{},[194,401],{"alt":402,"src":403},"盔甲中箭","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1629620892000.png",[16,405,406,407,409,410,414,415,418],{},"簡單來講 ",[26,408,320],{}," 具備與 Python2 相同的能力，同時具有",[411,412,413],"strong",{},"整數除法","與",[411,416,417],{},"浮點數除法","的能力，所以在使用上就要多加小心。",[12,420,421],{"id":421},"合併串列",[16,423,424],{},"這邊也額外提一下關於加號運算子的部分，加號運算子其實滿特別的。",[16,426,427,428,431],{},"為什麼這樣講呢？舉例來講如果你想把兩個陣列合併的話在 JavaScript 中最簡單的就是使用 ",[26,429,430],{},"concat()"," 函式：",[46,433,435],{"className":48,"code":434,"language":50,"meta":51,"style":51},"var a = [1, 2, 3];\nvar b = [4, 5, 6];\nvar c = a.concat(b);\nconsole.log(c); \u002F\u002F [ 1, 2, 3, 4, 5, 6 ]\n",[26,436,437,466,492,510],{"__ignoreMap":51},[55,438,439,442,445,448,451,453,456,458,460,463],{"class":57,"line":58},[55,440,441],{"class":76},"var",[55,443,444],{"class":61}," a ",[55,446,447],{"cl