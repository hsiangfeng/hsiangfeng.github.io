[{"data":1,"prerenderedAt":1252},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210907\u002F3189637583\u002F":3,"page:\u002Fpython\u002F20210907\u002F3189637583\u002F":4,"alt:\u002Fpython\u002F20210907\u002F3189637583\u002F":3,"prev-next:\u002Fpython\u002F20210907\u002F3189637583\u002F":1228,"related:\u002Fpython\u002F20210907\u002F3189637583\u002F":1237},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F07\u002Fpython-from-js-06-variable-scope\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1211,"date":1212,"description":18,"extension":1213,"lang":1214,"meta":1215,"navigation":114,"path":1216,"readingMinutes":1217,"seo":1218,"standalone":1219,"stem":1220,"tags":1221,"tldr":1225,"updated":1225,"url":1226,"__hash__":1227},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-6-變數作用域.md","從 JavaScript 角度學 Python(6) - 變數作用域","3189637583",{"type":9,"value":10,"toc":1203},"minimark",[11,15,19,22,25,45,55,190,193,256,273,320,323,349,352,384,390,399,402,434,437,440,545,548,640,647,656,659,707,718,722,732,752,755,761,764,801,814,884,898,966,969,975,1051,1079,1142,1145,1151,1154,1157,1160,1193,1199],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇介紹了函式與變數，那麼接下來要來回頭補充一下關於前面所沒聊到的變數作用域。",[12,20,21],{"id":21},"變數作用域",[16,23,24],{},"首先先讓我們回顧一下 JavaScript 的變數作用域部分，在 JavaScript 中有三種宣告變數的方式，分別為：",[26,27,28,35,40],"ul",{},[29,30,31],"li",{},[32,33,34],"code",{},"var",[29,36,37],{},[32,38,39],{},"let",[29,41,42],{},[32,43,44],{},"const",[16,46,47,48,50,51,54],{},"我們都知道這三種宣告變數的方式與它所屬的變數作用域都是不同的，例如： ",[32,49,34],{}," 的作用域是以函式 (",[32,52,53],{},"function",") 作為區分，因此如果不是在函式內宣告的話，就很容易影響到全域環境，也就是所謂的全域污染：",[56,57,62],"pre",{"className":58,"code":59,"language":60,"meta":61,"style":61},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","if(true) {\n  var myName = 'Ray';\n}\n\nconsole.log(myName); \u002F\u002F Ray\n\nfunction fn () {\n  var qq = 'Ray';\n}\nfn();\nconsole.log(qq); \u002F\u002F Uncaught ReferenceError: qq is not defined\n","js","",[32,63,64,84,103,109,116,133,138,149,163,168,177],{"__ignoreMap":61},[65,66,69,73,77,81],"span",{"class":67,"line":68},"line",1,[65,70,72],{"class":71},"sOudu","if",[65,74,76],{"class":75},"s8XSl","(",[65,78,80],{"class":79},"stw71","true",[65,82,83],{"class":75},") {\n",[65,85,87,90,93,96,100],{"class":67,"line":86},2,[65,88,89],{"class":71},"  var",[65,91,92],{"class":75}," myName ",[65,94,95],{"class":71},"=",[65,97,99],{"class":98},"sWayO"," 'Ray'",[65,101,102],{"class":75},";\n",[65,104,106],{"class":67,"line":105},3,[65,107,108],{"class":75},"}\n",[65,110,112],{"class":67,"line":111},4,[65,113,115],{"emptyLinePlaceholder":114},true,"\n",[65,117,119,122,126,129],{"class":67,"line":118},5,[65,120,121],{"class":75},"console.",[65,123,125],{"class":124},"scAaK","log",[65,127,128],{"class":75},"(myName); ",[65,130,132],{"class":131},"sGBqm","\u002F\u002F Ray\n",[65,134,136],{"class":67,"line":135},6,[65,137,115],{"emptyLinePlaceholder":114},[65,139,141,143,146],{"class":67,"line":140},7,[65,142,53],{"class":71},[65,144,145],{"class":124}," fn",[65,147,148],{"class":75}," () {\n",[65,150,152,154,157,159,161],{"class":67,"line":151},8,[65,153,89],{"class":71},[65,155,156],{"class":75}," qq ",[65,158,95],{"class":71},[65,160,99],{"class":98},[65,162,102],{"class":75},[65,164,166],{"class":67,"line":165},9,[65,167,108],{"class":75},[65,169,171,174],{"class":67,"line":170},10,[65,172,173],{"class":124},"fn",[65,175,176],{"class":75},"();\n",[65,178,180,182,184,187],{"class":67,"line":179},11,[65,181,121],{"class":75},[65,183,125],{"class":124},[65,185,186],{"class":75},"(qq); ",[65,188,189],{"class":131},"\u002F\u002F Uncaught ReferenceError: qq is not defined\n",[16,191,192],{},"那麼全域污染會有什麼下場呢？最明顯就是不小心變數互相覆蓋的問題：",[56,194,196],{"className":58,"code":195,"language":60,"meta":61,"style":61},"var myName = 'Ray';\n\nif(true) {\n  var myName = 'qq';\n}\n\nconsole.log(myName); \u002F\u002F qq\n",[32,197,198,210,214,224,237,241,245],{"__ignoreMap":61},[65,199,200,202,204,206,208],{"class":67,"line":68},[65,201,34],{"class":71},[65,203,92],{"class":75},[65,205,95],{"class":71},[65,207,99],{"class":98},[65,209,102],{"class":75},[65,211,212],{"class":67,"line":86},[65,213,115],{"emptyLinePlaceholder":114},[65,215,216,218,220,222],{"class":67,"line":105},[65,217,72],{"class":71},[65,219,76],{"class":75},[65,221,80],{"class":79},[65,223,83],{"class":75},[65,225,226,228,230,232,235],{"class":67,"line":111},[65,227,89],{"class":71},[65,229,92],{"class":75},[65,231,95],{"class":71},[65,233,234],{"class":98}," 'qq'",[65,236,102],{"class":75},[65,238,239],{"class":67,"line":118},[65,240,108],{"class":75},[65,242,243],{"class":67,"line":135},[65,244,115],{"emptyLinePlaceholder":114},[65,246,247,249,251,253],{"class":67,"line":140},[65,248,121],{"class":75},[65,250,125],{"class":124},[65,252,128],{"class":75},[65,254,255],{"class":131},"\u002F\u002F qq\n",[16,257,258,259,261,262,264,265,268,269,272],{},"而 ",[32,260,39],{}," 與 ",[32,263,44],{}," 則是以區塊 (block) 作為區分，什麼是區塊呢？只要你看到 ",[32,266,267],{},"{"," 、 ",[32,270,271],{},"}"," 包起來的就是一個區塊、一個 block：",[56,274,276],{"className":58,"code":275,"language":60,"meta":61,"style":61},"if(true) {\n  let myName = 'Ray';\n}\n\nconsole.log(myName); \u002F\u002F Uncaught ReferenceError: myName is not defined\n",[32,277,278,288,301,305,309],{"__ignoreMap":61},[65,279,280,282,284,286],{"class":67,"line":68},[65,281,72],{"class":71},[65,283,76],{"class":75},[65,285,80],{"class":79},[65,287,83],{"class":75},[65,289,290,293,295,297,299],{"class":67,"line":86},[65,291,292],{"class":71},"  let",[65,294,92],{"class":75},[65,296,95],{"class":71},[65,298,99],{"class":98},[65,300,102],{"class":75},[65,302,303],{"class":67,"line":105},[65,304,108],{"class":75},[65,306,307],{"class":67,"line":111},[65,308,115],{"emptyLinePlaceholder":114},[65,310,311,313,315,317],{"class":67,"line":118},[65,312,121],{"class":75},[65,314,125],{"class":124},[65,316,128],{"class":75},[65,318,319],{"class":131},"\u002F\u002F Uncaught ReferenceError: myName is not defined\n",[16,321,322],{},"因此當我們在閱讀程式碼時，我們是可以透過宣告變數的關鍵字來了解該變數是屬於哪一種變數作用域，那 Python 呢？Python 又如何呢？我們可以先試著將上面程式碼改成 Python 版本試試看：",[56,324,328],{"className":325,"code":326,"language":327,"meta":61,"style":61},"language-py shiki shiki-themes github-light github-light github-dark-high-contrast","if True:\n  myName = 'Ray'\n\nprint('myName:', myName) # myName: Ray\n","py",[32,329,330,335,340,344],{"__ignoreMap":61},[65,331,332],{"class":67,"line":68},[65,333,334],{},"if True:\n",[65,336,337],{"class":67,"line":86},[65,338,339],{},"  myName = 'Ray'\n",[65,341,342],{"class":67,"line":105},[65,343,115],{"emptyLinePlaceholder":114},[65,345,346],{"class":67,"line":111},[65,347,348],{},"print('myName:', myName) # myName: Ray\n",[16,350,351],{},"首先我們可以發現 Python 並不是以 Block 作為變數作用域的，那麼會不會是以函式當作作用域呢？這邊我們也可以實際驗證一下其結果：",[56,353,355],{"className":325,"code":354,"language":327,"meta":61,"style":61},"def fn():\n  myName = 'Ray'\n\nfn()\n\nprint('myName:', myName) # NameError: name 'myName' is not defined\n",[32,356,357,362,366,370,375,379],{"__ignoreMap":61},[65,358,359],{"class":67,"line":68},[65,360,361],{},"def fn():\n",[65,363,364],{"class":67,"line":86},[65,365,339],{},[65,367,368],{"class":67,"line":105},[65,369,115],{"emptyLinePlaceholder":114},[65,371,372],{"class":67,"line":111},[65,373,374],{},"fn()\n",[65,376,377],{"class":67,"line":118},[65,378,115],{"emptyLinePlaceholder":114},[65,380,381],{"class":67,"line":135},[65,382,383],{},"print('myName:', myName) # NameError: name 'myName' is not defined\n",[16,385,386,387,389],{},"答案是...\n是的，Python 在變數宣告上是以 ",[32,388,53],{}," 為作用域。",[16,391,392,393,395,396,398],{},"透過上面的範例我們可以了解到 Python 的變數類似於 JavaScript 的 ",[32,394,34],{}," 變數而不是 ",[32,397,39],{}," 變數，但這邊要注意 Python 並沒有提升的概念唷。",[16,400,401],{},"因此我們也可以知道一個不小心是有可能發生污染事件的：",[56,403,405],{"className":325,"code":404,"language":327,"meta":61,"style":61},"myName = 'Ray'\n\nif True:\n  myName = 'qq'\n\nprint(myName) # qq\n",[32,406,407,412,416,420,425,429],{"__ignoreMap":61},[65,408,409],{"class":67,"line":68},[65,410,411],{},"myName = 'Ray'\n",[65,413,414],{"class":67,"line":86},[65,415,115],{"emptyLinePlaceholder":114},[65,417,418],{"class":67,"line":105},[65,419,334],{},[65,421,422],{"class":67,"line":111},[65,423,424],{},"  myName = 'qq'\n",[65,426,427],{"class":67,"line":118},[65,428,115],{"emptyLinePlaceholder":114},[65,430,431],{"class":67,"line":135},[65,432,433],{},"print(myName) # qq\n",[12,435,436],{"id":436},"範圍鍊",[16,438,439],{},"接下來是關於範圍鍊的部分，JavaScript 有一個觀念是關於範圍鍊，那麼什麼是範圍鏈呢？簡單來講就是，假使這個變數不存在於這個函式時，它會往外層去尋找這個變數或是函式是否存在，而且是一直一直一直往上尋找：",[56,441,443],{"className":58,"code":442,"language":60,"meta":61,"style":61},"var myName = 'Ray';\n\nfunction fn1() {\n  function fn2() {\n    function fn3() {\n      console.log('myName:', myName); \u002F\u002F myName: Ray\n    }\n    fn3();\n  }\n  fn2();\n}\nfn1();\n",[32,444,445,457,461,471,481,491,509,514,521,526,533,537],{"__ignoreMap":61},[65,446,447,449,451,453,455],{"class":67,"line":68},[65,448,34],{"class":71},[65,450,92],{"class":75},[65,452,95],{"class":71},[65,454,99],{"class":98},[65,456,102],{"class":75},[65,458,459],{"class":67,"line":86},[65,460,115],{"emptyLinePlaceholder":114},[65,462,463,465,468],{"class":67,"line":105},[65,464,53],{"class":71},[65,466,467],{"class":124}," fn1",[65,469,470],{"class":75},"() {\n",[65,472,473,476,479],{"class":67,"line":111},[65,474,475],{"class":71},"  function",[65,477,478],{"class":124}," fn2",[65,480,470],{"class":75},[65,482,483,486,489],{"class":67,"line":118},[65,484,485],{"class":71},"    function",[65,487,488],{"class":124}," fn3",[65,490,470],{"class":75},[65,492,493,496,498,500,503,506],{"class":67,"line":135},[65,494,495],{"class":75},"      console.",[65,497,125],{"class":124},[65,499,76],{"class":75},[65,501,502],{"class":98},"'myName:'",[65,504,505],{"class":75},", myName); ",[65,507,508],{"class":131},"\u002F\u002F myName: Ray\n",[65,510,511],{"class":67,"line":140},[65,512,513],{"class":75},"    }\n",[65,515,516,519],{"class":67,"line":151},[65,517,518],{"class":124},"    fn3",[65,520,176],{"class":75},[65,522,523],{"class":67,"line":165},[65,524,525],{"class":75},"  }\n",[65,527,528,531],{"class":67,"line":170},[65,529,530],{"class":124},"  fn2",[65,532,176],{"class":75},[65,534,535],{"class":67,"line":179},[65,536,108],{"class":75},[65,538,540,543],{"class":67,"line":539},12,[65,541,542],{"class":124},"fn1",[65,544,176],{"class":75},[16,546,547],{},"又或者是這一種類型的範例程式碼：",[56,549,551],{"className":58,"code":550,"language":60,"meta":61,"style":61},"var value = 1; \u002F\u002F 全域變數\nfunction fu1() {\n  console.log(value); \u002F\u002F 1\n}\nfunction fu2() {\n  var value = 2; \u002F\u002F 區域變數\n  fu1();\n}\nfu2();\n",[32,552,553,571,580,593,597,606,622,629,633],{"__ignoreMap":61},[65,554,555,557,560,562,565,568],{"class":67,"line":68},[65,556,34],{"class":71},[65,558,559],{"class":75}," value ",[65,561,95],{"class":71},[65,563,564],{"class":79}," 1",[65,566,567],{"class":75},"; ",[65,569,570],{"class":131},"\u002F\u002F 全域變數\n",[65,572,573,575,578],{"class":67,"line":86},[65,574,53],{"class":71},[65,576,577],{"class":124}," fu1",[65,579,470],{"class":75},[65,581,582,585,587,590],{"class":67,"line":105},[65,583,584],{"class":75},"  console.",[65,586,125],{"class":124},[65,588,589],{"class":75},"(value); ",[65,591,592],{"class":131},"\u002F\u002F 1\n",[65,594,595],{"class":67,"line":111},[65,596,108],{"class":75},[65,598,599,601,604],{"class":67,"line":118},[65,600,53],{"class":71},[65,602,603],{"class":124}," fu2",[65,605,470],{"class":75},[65,607,608,610,612,614,617,619],{"class":67,"line":135},[65,609,89],{"class":71},[65,611,559],{"class":75},[65,613,95],{"class":71},[65,615,616],{"class":79}," 2",[65,618,567],{"class":75},[65,620,621],{"class":131},"\u002F\u002F 區域變數\n",[65,623,624,627],{"class":67,"line":140},[65,625,626],{"class":124},"  fu1",[65,628,176],{"class":75},[65,630,631],{"class":67,"line":151},[65,632,108],{"class":75},[65,634,635,638],{"class":67,"line":165},[65,636,637],{"class":124},"fu2",[65,639,176],{"class":75},[16,641,642],{},[643,644],"img",{"alt":645,"src":646},"尋找過程","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E7%AF%84%E5%9C%8D%E9%8D%8A.gif",[16,648,649,650,655],{},"因此當函式本身若沒有相對應的變數或函式時，它就會自動往外層去尋找，而這就是 JavaScript 所謂的範圍鍊概念，如果對於範圍鍊不熟悉的話，可詳見 ",[651,652,654],"a",{"href":653},"\u002Fjavascript\u002F20200502\u002F1231063032\u002F","此篇"," 文章。",[16,657,658],{},"現在就讓我們拉回到 Python，Python 也會有相同概念嗎？我們先將前面其中一個範例程式碼直接改寫成 Python 來試試看：",[56,660,662],{"className":325,"code":661,"language":327,"meta":61,"style":61},"value = 1\ndef fu1():\n  print(value) # 1\n\ndef fu2():\n  value = 2\n  fu1()\n\nfu2()\n",[32,663,664,669,674,679,683,688,693,698,702],{"__ignoreMap":61},[65,665,666],{"class":67,"line":68},[65,667,668],{},"value = 1\n",[65,670,671],{"class":67,"line":86},[65,672,673],{},"def fu1():\n",[65,675,676],{"class":67,"line":105},[65,677,678],{},"  print(value) # 1\n",[65,680,681],{"class":67,"line":111},[65,682,115],{"emptyLinePlaceholder":114},[65,684,685],{"class":67,"line":118},[65,686,687],{},"def fu2():\n",[65,689,690],{"class":67,"line":135},[65,691,692],{},"  value = 2\n",[65,694,695],{"class":67,"line":140},[65,696,697],{},"  fu1()\n",[65,699,700],{"class":67,"line":151},[65,701,115],{"emptyLinePlaceholder":114},[65,703,704],{"class":67,"line":165},[65,705,706],{},"fu2()\n",[16,708,709,710,713,714,717],{},"從結果論來講，我們可以看到 ",[32,711,712],{},"print"," 輸出的結果依然是 ",[32,715,716],{},"1"," 而不是找不到這個變數，因此 Python 在變數的尋找上是與 JavaScript 非常相像的，所以你要說 Python 有沒有範圍鍊得概念呢？我想是有的。",[12,719,721],{"id":720},"nonlocal-與-global","nonlocal 與 global",[16,723,724,725,261,728,731],{},"最後的結尾處我想聊一下關於 ",[32,726,727],{},"nonlocal",[32,729,730],{},"global"," 這兩個很特別的東西，首先先讓我們看一小段 Python 範例，也就是非常巢狀的巢狀函式：",[56,733,735],{"className":325,"code":734,"language":327,"meta":61,"style":61},"def fn1():\n  def fn2():\n    def fn3():\n",[32,736,737,742,747],{"__ignoreMap":61},[65,738,739],{"class":67,"line":68},[65,740,741],{},"def fn1():\n",[65,743,744],{"class":67,"line":86},[65,745,746],{},"  def fn2():\n",[65,748,749],{"class":67,"line":105},[65,750,751],{},"    def fn3():\n",[16,753,754],{},"而我們在實際開發時單字量可能很少，例如我這個英文很差的人永遠都只有那幾個單字",[16,756,757],{},[643,758],{"alt":759,"src":760},"我就爛","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630592004466.png",[16,762,763],{},"回歸到 Python 的部分，剛剛有提到往往我們開發系統時可能會寫得很長很多，所以變數名稱就會有很高的機率重複，例如就像這樣：",[56,765,767],{"className":325,"code":766,"language":327,"meta":61,"style":61},"a = 'Ray'\ndef fn1():\n  a = 'AA'\n  def fn2():\n    a = 'BB'\n    def fn3():\n      a = 'CC'\n",[32,768,769,774,778,783,787,792,796],{"__ignoreMap":61},[65,770,771],{"class":67,"line":68},[65,772,773],{},"a = 'Ray'\n",[65,775,776],{"class":67,"line":86},[65,777,741],{},[65,779,780],{"class":67,"line":105},[65,781,782],{},"  a = 'AA'\n",[65,784,785],{"class":67,"line":111},[65,786,746],{},[65,788,789],{"class":67,"line":118},[65,790,791],{},"    a = 'BB'\n",[65,793,794],{"class":67,"line":135},[65,795,751],{},[65,797,798],{"class":67,"line":140},[65,799,800],{},"      a = 'CC'\n",[16,802,803,804,807,808,810,811,813],{},"雖然以結論來講上面程式碼看起來是沒有什麼問題的，畢竟每一個函式都有一個自己的變數，但是如果今天我們希望 ",[32,805,806],{},"fn3"," 的 ",[32,809,651],{}," 是重新賦予 global 的變數 ",[32,812,651],{}," 呢？",[56,815,817],{"className":325,"code":816,"language":327,"meta":61,"style":61},"a = 'Ray'\ndef fn1():\n  a = 'AA'\n  print('fn1', a) # AA\n  def fn2():\n    a = 'BB'\n    print('fn2', a) # BB\n    def fn3():\n      a = 'CC'\n      print('fn3', a) # CC\n    fn3()\n  fn2()\nfn1()\nprint('global', a) # Ray\n",[32,818,819,823,827,831,836,840,844,849,853,857,862,867,872,878],{"__ignoreMap":61},[65,820,821],{"class":67,"line":68},[65,822,773],{},[65,824,825],{"class":67,"line":86},[65,826,741],{},[65,828,829],{"class":67,"line":105},[65,830,782],{},[65,832,833],{"class":67,"line":111},[65,834,835],{},"  print('fn1', a) # AA\n",[65,837,838],{"class":67,"line":118},[65,839,746],{},[65,841,842],{"class":67,"line":135},[65,843,791],{},[65,845,846],{"class":67,"line":140},[65,847,848],{},"    print('fn2', a) # BB\n",[65,850,851],{"class":67,"line":151},[65,852,751],{},[65,854,855],{"class":67,"line":165},[65,856,800],{},[65,858,859],{"class":67,"line":170},[65,860,861],{},"      print('fn3', a) # CC\n",[65,863,864],{"class":67,"line":179},[65,865,866],{},"    fn3()\n",[65,868,869],{"class":67,"line":539},[65,870,871],{},"  fn2()\n",[65,873,875],{"class":67,"line":874},13,[65,876,877],{},"fn1()\n",[65,879,881],{"class":67,"line":880},14,[65,882,883],{},"print('global', a) # Ray\n",[16,885,886,887,889,890,893,894,897],{},"發現了嗎？由於我們在每個函式內重新宣告了一個變數都是 ",[32,888,651],{},"，所以 Python 認為我們是要宣告一個新的變數而不是賦予到 ",[32,891,892],{},"global a"," 中，因此這時候我們就可以使用 Python 所提供的 ",[32,895,896],{},"global 變數名稱"," 語法告知 Python：「嘿！我這個變數是 Global 的哦！你不要建立一個區域變數！」：",[56,899,901],{"className":325,"code":900,"language":327,"meta":61,"style":61},"a = 'Ray'\ndef fn1():\n  a = 'AA'\n  print('fn1', a) # AA\n  def fn2():\n    a = 'BB'\n    print('fn2', a) # BB\n    def fn3():\n      global a\n      a = 'CC'\n      print('fn3', a) # CC\n    fn3()\n  fn2()\nfn1()\nprint('global', a) # 被 fn3 重新賦予導致覆蓋成 CC\n",[32,902,903,907,911,915,919,923,927,931,935,940,944,948,952,956,960],{"__ignoreMap":61},[65,904,905],{"class":67,"line":68},[65,906,773],{},[65,908,909],{"class":67,"line":86},[65,910,741],{},[65,912,913],{"class":67,"line":105},[65,914,782],{},[65,916,917],{"class":67,"line":111},[65,918,835],{},[65,920,921],{"class":67,"line":118},[65,922,746],{},[65,924,925],{"class":67,"line":135},[65,926,791],{},[65,928,929],{"class":67,"line":140},[65,930,848],{},[65,932,933],{"class":67,"line":151},[65,934,751],{},[65,936,937],{"class":67,"line":165},[65,938,939],{},"      global a\n",[65,941,942],{"class":67,"line":170},[65,943,800],{},[65,945,946],{"class":67,"line":179},[65,947,861],{},[65,949,950],{"class":67,"line":539},[65,951,866],{},[65,953,954],{"class":67,"line":874},[65,955,871],{},[65,957,958],{"class":67,"line":880},[65,959,877],{},[65,961,963],{"class":67,"line":962},15,[65,964,965],{},"print('global', a) # 被 fn3 重新賦予導致覆蓋成 CC\n",[16,967,968],{},"那麼這樣就可以解決我們作用域的問題，畢竟就如同前面所言 Python 並沒有變數宣告的語法，因此 Python 必須透過其他的方式去告知它這個變數不是重新定義，而是直接取用外層。",[16,970,971,972,974],{},"反之如果你想取用的是函式內的變數，那麼也是一樣，只是在此所使用的是 ",[32,973,727],{},"：",[56,976,978],{"className":325,"code":977,"language":327,"meta":61,"style":61},"a = 'Ray'\ndef fn1():\n  a = 'AA'\n  print('fn1', a) # fn1：AA\n  def fn2():\n    a = 'BB'\n    print('fn2 取代前：', a) # fn2 取代前：BB\n    def fn3():\n      nonlocal a\n      a = 'CC'\n      print('fn3', a)\n    fn3()\n    print('fn2 取代前：', a) # 被更改成 CC\n  fn2()\nfn1()\nprint('global', a) # Global Ray\n",[32,979,980,984,988,992,997,1001,1005,1010,1014,1019,1023,1028,1032,1037,1041,1045],{"__ignoreMap":61},[65,981,982],{"class":67,"line":68},[65,983,773],{},[65,985,986],{"class":67,"line":86},[65,987,741],{},[65,989,990],{"class":67,"line":105},[65,991,782],{},[65,993,994],{"class":67,"line":111},[65,995,996],{},"  print('fn1', a) # fn1：AA\n",[65,998,999],{"class":67,"line":118},[65,1000,746],{},[65,1002,1003],{"class":67,"line":135},[65,1004,791],{},[65,1006,1007],{"class":67,"line":140},[65,1008,1009],{},"    print('fn2 取代前：', a) # fn2 取代前：BB\n",[65,1011,1012],{"class":67,"line":151},[65,1013,751],{},[65,1015,1016],{"class":67,"line":165},[65,1017,1018],{},"      nonlocal a\n",[65,1020,1021],{"class":67,"line":170},[65,1022,800],{},[65,1024,1025],{"class":67,"line":179},[65,1026,1027],{},"      print('fn3', a)\n",[65,1029,1030],{"class":67,"line":539},[65,1031,866],{},[65,1033,1034],{"class":67,"line":874},[65,1035,1036],{},"    print('fn2 取代前：', a) # 被更改成 CC\n",[65,1038,1039],{"class":67,"line":880},[65,1040,871],{},[65,1042,1043],{"class":67,"line":962},[65,1044,877],{},[65,1046,1048],{"class":67,"line":1047},16,[65,1049,1050],{},"print('global', a) # Global Ray\n",[16,1052,1053,1054,807,1056,1058,1059,807,1061,1063,1064,1067,1068,1070,1071,1073,1074,807,1076,1078],{},"那麼這時候你可能會想說為什麼 ",[32,1055,542],{},[32,1057,651],{}," 不會受到影響呢？你可以利用範圍鍊的概念去思考，當 ",[32,1060,806],{},[32,1062,651],{}," 像外層尋找時，會優先找到 ",[32,1065,1066],{},"fn2"," 的  ",[32,1069,651],{}," 因此它就會停止向上了，所以假設如果 ",[32,1072,1066],{}," 的 a 若不存在的話，",[32,1075,806],{},[32,1077,651],{}," 變數就會一直往上尋找，這一點觀點我們也可以嘗試驗證：",[56,1080,1082],{"className":325,"code":1081,"language":327,"meta":61,"style":61},"a = 'Ray'\ndef fn1():\n  a = 'AA'\n  print('fn1 取代前：', a) # fn1：AA\n  def fn2():\n    def fn3():\n      nonlocal a\n      a = 'CC'\n      print('fn3', a) # CC\n    fn3()\n  fn2()\n  print('fn1 取代後：', a) # fn1：CC\nfn1()\nprint('global', a) # Global Ray\n",[32,1083,1084,1088,1092,1096,1101,1105,1109,1113,1117,1121,1125,1129,1134,1138],{"__ignoreMap":61},[65,1085,1086],{"class":67,"line":68},[65,1087,773],{},[65,1089,1090],{"class":67,"line":86},[65,1091,741],{},[65,1093,1094],{"class":67,"line":105},[65,1095,782],{},[65,1097,1098],{"class":67,"line":111},[65,1099,1100],{},"  print('fn1 取代前：', a) # fn1：AA\n",[65,1102,1103],{"class":67,"line":118},[65,1104,746],{},[65,1106,1107],{"class":67,"line":135},[65,1108,751],{},[65,1110,1111],{"class":67,"line":140},[65,1112,1018],{},[65,1114,1115],{"class":67,"line":151},[65,1116,800],{},[65,1118,1119],{"class":67,"line":165},[65,1120,861],{},[65,1122,1123],{"class":67,"line":170},[65,1124,866],{},[65,1126,1127],{"class":67,"line":179},[65,1128,871],{},[65,1130,1131],{"class":67,"line":539},[65,1132,1133],{},"  print('fn1 取代後：', a) # fn1：CC\n",[65,1135,1136],{"class":67,"line":874},[65,1137,877],{},[65,1139,1140],{"class":67,"line":880},[65,1141,1050],{},[16,1143,1144],{},"透過一個實際的案例來講，我們也可以再次體會到 JavaScript 的範圍鍊觀念是可以套用在 Python 上來看的，不知道有沒有讓已經快燒壞大腦的你有一點明瞭了呢？",[16,1146,1147],{},[643,1148],{"alt":1149,"src":1150},"No!No!No!No!","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%