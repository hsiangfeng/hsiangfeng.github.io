[{"data":1,"prerenderedAt":683},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210917\u002F1454523800\u002F":3,"page:\u002Fpython\u002F20210917\u002F1454523800\u002F":4,"alt:\u002Fpython\u002F20210917\u002F1454523800\u002F":3,"prev-next:\u002Fpython\u002F20210917\u002F1454523800\u002F":659,"related:\u002Fpython\u002F20210917\u002F1454523800\u002F":668},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F17\u002Fpython-16-pip\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":641,"date":642,"description":18,"extension":643,"lang":644,"meta":645,"navigation":646,"path":647,"readingMinutes":648,"seo":649,"standalone":650,"stem":651,"tags":652,"tldr":656,"updated":656,"url":657,"__hash__":658},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-16-pip.md","從 JavaScript 角度學 Python(16) - pip","1454523800",{"type":9,"value":10,"toc":624},"minimark",[11,15,19,22,28,36,45,48,59,75,82,89,92,98,102,112,212,215,224,228,231,240,246,257,260,263,266,269,278,285,290,293,299,302,305,313,316,325,330,333,343,348,354,358,370,379,382,391,394,401,410,416,426,429,434,440,449,454,457,460,469,475,478,484,493,500,516,519,522,525,528,537,541,552,559,562,573,576,579,582,614,620],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面章節我們學習了許多 Python 的基礎語法，所以接下來我想額外介紹 pip，pip 在實際開發上來講也很常使用到。",[12,20,21],{"id":21},"pip3",[23,24,25],"blockquote",{},[16,26,27],{},"有些人是 pip or pip3，以下都會是簡稱 pip3 代表 Python3 避免混淆。",[16,29,30,31,35],{},"那麼 pip3 是什麼呢？pip3 簡單來講它是一個",[32,33,34],"strong",{},"軟體包管理系統","，如果將鏡頭轉來到 JavaScript 來講的話，只要你有使用過 Vue Cli、Webpack、Gulp 等等工具，那麼你就會使用 npm 來安裝套件，所以你也可以將 pip3 想像成 npm (Ruby 我記得是 gem，如果有錯的話請幫糾正。)。",[16,37,38,39,44],{},"(如果你對 npm 指令不熟悉的話，可以閱讀",[40,41,43],"a",{"href":42},"\u002Fnodejs\u002F20190626\u002F1317979814\u002F","此篇","文章快速了解一下，避免後面講的都不熟悉。)",[16,46,47],{},"而這個 pip3 可以說是非常非常的重要，畢竟我們在開發的時候，時常會需要安裝第三方套件(非官方內建套件)，以 npm 來講它會在我們安裝 Node.js 的時候一併安裝，那麼 Python 呢？Python 基本上也是一樣的，其中 Python3 與 Python 2.7.9~2.8.0(印象) 就會內建安裝 pip3。",[16,49,50,51,54,55,58],{},"那麼該如何驗證自己電腦有 pip3 呢？只需要輸入以下指令就可以查驗(由於本篇是 Python3，因此要輸入 ",[52,53,21],"code",{},"，若是有特別調整過的可能是 ",[52,56,57],{},"pip",")：",[60,61,66],"pre",{"className":62,"code":63,"language":64,"meta":65,"style":65},"language-cmd shiki shiki-themes github-light github-light github-dark-high-contrast","pip3 --version\n","cmd","",[52,67,68],{"__ignoreMap":65},[69,70,73],"span",{"class":71,"line":72},"line",1,[69,74,63],{},[16,76,77,78,81],{},"較舊的版本(例如: Python 2.x)是 ",[52,79,80],{},"pip --version","。",[16,83,84],{},[85,86],"img",{"alt":87,"src":88},"pip3 版本","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2011.44.33.png",[16,90,91],{},"而這就是最簡單辨別自己電腦有無安裝 pip3 軟體包管理系統的方式，夠簡單了吧？恭喜你又學會一個東西了：",[16,93,94],{},[85,95],{"alt":96,"src":97},"恭喜你安裝成功了！","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631253553328.png",[12,99,101],{"id":100},"pip3-常用指令","pip3 常用指令",[16,103,104,105,108,109,111],{},"雖然我們可以透過在終端機輸入 ",[52,106,107],{},"pip3 --help"," 查看全部的 ",[52,110,21],{}," 指令，但是認真來講我們真的會用到這麼多嗎？不，不會就連我 npm 會用的指令也就那幾個而已，所以這邊我稍微整理出一些常用的指令表格：",[113,114,115,129],"table",{},[116,117,118],"thead",{},[119,120,121,126],"tr",{},[122,123,125],"th",{"align":124},"center","說明",[122,127,128],{},"指令",[130,131,132,143,153,163,173,189,199],"tbody",{},[119,133,134,138],{},[135,136,137],"td",{"align":124},"安裝套件",[135,139,140],{},[52,141,142],{},"pip3 install  [ package-name ]",[119,144,145,148],{},[135,146,147],{"align":124},"移除套件",[135,149,150],{},[52,151,152],{},"pip3 uninstall  [ package-name ]",[119,154,155,158],{},[135,156,157],{"align":124},"已經安裝的套件列表",[135,159,160],{},[52,161,162],{},"pip3 list",[119,164,165,168],{},[135,166,167],{"align":124},"輸出已經安裝的套件資訊",[135,169,170],{},[52,171,172],{},"pip3 freeze",[119,174,175,178],{},[135,176,177],{"align":124},"pip3 指令說明列表",[135,179,180,183,184,183,187],{},[52,181,182],{},"pip3 help","  |  ",[52,185,186],{},"pip3 -h",[52,188,107],{},[119,190,191,194],{},[135,192,193],{"align":124},"搜尋套件",[135,195,196],{},[52,197,198],{},"pip3 search [ package-name ]",[119,200,201,204],{},[135,202,203],{"align":124},"pip3 版本資訊",[135,205,206,183,209],{},[52,207,208],{},"pip3 --version",[52,210,211],{},"pip -V",[16,213,214],{},"接下來就實際來玩一下這些指令。",[16,216,217,218,220,221,223],{},"(貼心提醒：以上若發現 ",[52,219,21],{}," 無法使用的話，請改用 ",[52,222,57],{},")",[225,226,227],"h3",{"id":227},"install",[16,229,230],{},"安裝套件的時候，pip3 會將套件安裝到我們自己的電腦上，因此當你安裝了這個套件，整台電腦就可以一直使用，這邊舉例先安裝一套套件叫做 「pytube」，這是一個下載 Youtube 影片跟音樂的套件，所以這邊就先試著安裝一下：",[60,232,234],{"className":62,"code":233,"language":64,"meta":65,"style":65},"pip3 install pytube\n",[52,235,236],{"__ignoreMap":65},[69,237,238],{"class":71,"line":72},[69,239,233],{},[16,241,242],{},[85,243],{"alt":244,"src":245},"pytube","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2012.42.33.png",[16,247,248,249,252,253,256],{},"oh，對了，如果你嘗試輸入 ",[52,250,251],{},"pip3 i pytube"," 是會出現 ",[52,254,255],{},"ERROR: unknown command \"i\""," 錯誤的唷。",[16,258,259],{},"這邊或許會有一些人想說，難道 pip3 安裝套件的時候沒有區分 global 與 local 嗎？",[16,261,262],{},"沒錯，以當前文章介紹進度來講是的，沒有區分，但是後面章節會介紹如何只安裝在 local。",[225,264,265],{"id":265},"uninstall",[16,267,268],{},"有安裝當然就有移除，移除指令相對比較單純：",[60,270,272],{"className":62,"code":271,"language":64,"meta":65,"style":65},"pip3 uninstall pytube\n",[52,273,274],{"__ignoreMap":65},[69,275,276],{"class":71,"line":72},[69,277,271],{},[16,279,280,281,284],{},"基本上刪除套件時，會再三確認你是否要刪除以及告知你即將刪除的套件路徑，接下來輸入 ",[52,282,283],{},"y"," 就可以了：",[16,286,287],{},[85,288],{"alt":265,"src":289},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2012.58.44.png",[16,291,292],{},"多一個確認行為我個人是滿喜歡的，不然有時候自己會粗手指不小心誤按或者腦殘打錯：",[16,294,295],{},[85,296],{"alt":297,"src":298},"打錯指令的我","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631254117058.png",[225,300,301],{"id":301},"list",[16,303,304],{},"如果你依照上面步驟操作下來的話，基本上剛剛安裝的 pytube 套件已經被移除了，所以為了呈現 list 效果會建議在安裝回來唷~",[60,306,307],{"className":62,"code":233,"language":64,"meta":65,"style":65},[52,308,309],{"__ignoreMap":65},[69,310,311],{"class":71,"line":72},[69,312,233],{},[16,314,315],{},"如果你沒有移除套件的話，那麼就可以直接輸入以下指令來查看當前已經安裝的 Python 套件：",[60,317,319],{"className":62,"code":318,"language":64,"meta":65,"style":65},"pip3 list\n",[52,320,321],{"__ignoreMap":65},[69,322,323],{"class":71,"line":72},[69,324,318],{},[16,326,327],{},[85,328],{"alt":301,"src":329},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2013.04.51.png",[225,331,332],{"id":332},"freeze",[16,334,335,336,339,340,342],{},"freeze 比較特別一點，認真講起來的話...你可以把它想想成 ",[52,337,338],{},"npm init"," 生出來的 package.json，主要會紀錄我們當前電腦所安裝的套件，如果你只是單純的輸入 ",[52,341,172],{}," 就可以看到它會列出你本地安裝的套件：",[16,344,345],{},[85,346],{"alt":332,"src":347},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2013.54.08.png",[16,349,350,351,353],{},"你會看到它與 ",[52,352,162],{}," 有那麼一點不同：",[16,355,356],{},[85,357],{"alt":301,"src":329},[16,359,360,361,363,364,366,367,369],{},"所以代表著 ",[52,362,172],{}," 主要是輸出我們當前安裝的套件與版本，而這個資訊將會用於還原套件用，剛才有講到 ",[52,365,172],{}," 類似 ",[52,368,338],{}," 生出來的 package.json，但是你輸入之後你會發現資料夾並不會發生任何狀況，因此你必須這樣輸入才正確：",[60,371,373],{"className":62,"code":372,"language":64,"meta":65,"style":65},"pip3 freeze | tee requirements.txt\n",[52,374,375],{"__ignoreMap":65},[69,376,377],{"class":71,"line":72},[69,378,372],{},[16,380,381],{},"或者是",[60,383,385],{"className":62,"code":384,"language":64,"meta":65,"style":65},"pip3 freeze > requirements.txt\n",[52,386,387],{"__ignoreMap":65},[69,388,389],{"class":71,"line":72},[69,390,384],{},[16,392,393],{},"上面兩個指令的意思都是將當前安裝的套件資訊寫入到 requirements.txt，因此就算你要打 qqqqq.txt 也是可以，但是這邊建議使用 requirements 就好。",[16,395,396,397,400],{},"完成了套件紀錄之後，當我們拿到一個 Python 要還原開發環境時該怎麼還原呢？以 JavaScript 環境來講，你只需要輸入 ",[52,398,399],{},"npm install","，就可以還原了，而 Python 的話，你要輸入以下指令才可以還原套件：",[60,402,404],{"className":62,"code":403,"language":64,"meta":65,"style":65},"pip3 install -r requirements.txt\n",[52,405,406],{"__ignoreMap":65},[69,407,408],{"class":71,"line":72},[69,409,403],{},[16,411,412],{},[85,413],{"alt":414,"src":415},"還原套件","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2014.00.24.png",[16,417,418,419,422,423,425],{},"因此 ",[52,420,421],{},"pip3 freeze > requirements.txt"," 指令會比較常用於系統開發告一個段落後才使用，與 ",[52,424,338],{}," 使用時機是相反的，一個是一開始就要初始化專案，一個是偏向開發告一個段落後才使用。",[225,427,428],{"id":428},"help",[16,430,431,433],{},[52,432,428],{}," 指令還需要介紹嗎？但是為了充字數，我覺得我還是簡單寫一下好了。",[16,435,436],{},[85,437],{"alt":438,"src":439},"充字數","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631254560897.png",[16,441,442,443,445,446,448],{},"很多時候我們並不會記得指令，甚至會懶得上網搜尋，這時候就可以直接輸入 ",[52,444,182],{}," 來查看 ",[52,447,21],{}," 有哪些指令以及說明：",[16,450,451],{},[85,452],{"alt":428,"src":453},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2014.06.40.png",[225,455,456],{"id":456},"search",[16,458,459],{},"search 這個功能其實一直都非常的很好用，本身 npm 也有，你可以試著輸入以下指令了解：",[60,461,463],{"className":62,"code":462,"language":64,"meta":65,"style":65},"npm search vue\n",[52,464,465],{"__ignoreMap":65},[69,466,467],{"class":71,"line":72},[69,468,462],{},[16,470,471],{},[85,472],{"alt":473,"src":474},"vue 相關","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-17%2014.09.40.png",[16,476,477],{},"只是我想你應該很少用，因為我就根本沒用過：",[16,479,480],{},[85,481],{"alt":482,"src":483},"我沒用過","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631254698474.png",[16,485,486,487,81],{},"鏡頭拉回 Python，本身 Python 也有相同功能，而用法與我們在 npm 是相同的，但可惜的是 Python 目前已經永久禁用該功能了，詳情可見",[40,488,492],{"href":489,"rel":490},"https:\u002F\u002Fstatus.python.org\u002F",[491],"nofollow","官方說明",[16,494,495,496,499],{},"所以基本上你輸入 ",[52,497,498],{},"pip3 search pytube"," 是會出現以下訊息的：",[60,501,503],{"className":62,"code":502,"language":64,"meta":65,"style":65},"ERROR: XMLRPC request failed [code: -32500]\nRuntimeError: PyPI's XMLRPC API is currently disabled due to unmanageable load and will be deprecated in the near future. See https:\u002F\u002Fstatus.python.org\u002F for more information.\n",[52,504,505,510],{"__ignoreMap":65},[69,506,507],{"class":71,"line":72},[69,508,509],{},"ERROR: XMLRPC request failed [code: -32500]\n",[69,511,513],{"class":71,"line":512},2,[69,514,515],{},"RuntimeError: PyPI's XMLRPC API is currently disabled due to unmanageable load and will be deprecated in the near future. See https:\u002F\u002Fstatus.python.org\u002F for more information.\n",[16,517,518],{},"算是滿可惜的一點。",[225,520,521],{"id":521},"version",[16,523,524],{},"雖然一開始有講過了，但是這邊還是在講一次。",[16,526,527],{},"查看自己當前的 pip3 版本號是非常重要的：",[60,529,531],{"className":62,"code":530,"language":64,"meta":65,"style":65},"pip3 -V\n",[52,532,533],{"__ignoreMap":65},[69,534,535],{"class":71,"line":72},[69,536,530],{},[16,538,539],{},[85,540],{"alt":87,"src":88},[16,542,543,544,547,548,551],{},"請注意大小寫的 ",[52,545,546],{},"v"," 與 ",[52,549,550],{},"V"," 是不同的唷。",[16,553,554,555,81],{},"為什麼重要呢？因為有時候我們要回報套件 Bug 給作者時，是會建議附上版本號，主要是讓作者還原開發狀況，這樣子也會比較好抓出問題，如果你只回報問題而沒告知更多更詳細的細節等，那可能就是屬於",[40,556,558],{"href":557},"\u002Flearnexp\u002F20200112\u002F1752686187\u002F","欠人教訓的提問",[12,560,561],{"id":561},"參考文獻",[563,564,565],"ul",{},[566,567,568],"li",{},[40,569,572],{"href":570,"rel":571},"https:\u002F\u002Fdocs.python.org\u002Fzh-tw\u002F3\u002Ftutorial\u002Fvenv.html",[491],"虛擬環境與套件",[12,574,575],{"id":575},"作者的話",[16,577,578],{},"太好了，狗狗結紮後醫生打電話過來說牠很健康，一下子就醒來了，但是水跟飼料完全不喝，我想應該是太過緊張害怕導致。",[12,580,581],{"id":581},"關於兔兔們",[563,583,584,591,599,607],{},[566,585,586],{},[40,587,590],{"href":588,"rel":589},"https:\u002F\u002Ftailwindcss.tw",[491],"Tailwind CSS 臺灣官網",[566,592,593,598],{},[40,594,597],{"href":595,"rel":596},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[491],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[566,600,601,606],{},[40,602,605],{"href":603,"rel":604},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[491],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[566,608,609],{},[40,610,613],{"href":611,"rel":612},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[491],"兔兔教大本營",[16,615,616],{},[85,617],{"alt":618,"src":619},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[621,622,623],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki