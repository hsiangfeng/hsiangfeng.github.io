},[177,514,515],{},"print(lis.index('y')) # 2\n",[177,517,518],{"class":179,"line":320},[177,519,520],{},"print(lis) # ['r', 'a', 'y']\n",[157,522,523],{"id":523},"reversed",[16,525,526,528,529,531,532,535],{},[33,527,523],{}," 與 ",[33,530,65],{}," 非常的像，但是它不會影響原有的串列，因此反轉後會回傳一個新的串列，但請注意要使用 ",[33,533,534],{},"list"," 重新轉換。",[168,537,539],{"className":170,"code":538,"language":172,"meta":173,"style":173},"lis = ['A', 'B', 'C', 'D', 'E', 'F']\nprint(list(reversed(lis))) # ['F', 'E', 'D', 'C', 'B', 'A']\nprint(lis) # ['A', 'B', 'C', 'D', 'E', 'F']\n",[33,540,541,545,550],{"__ignoreMap":173},[177,542,543],{"class":179,"line":180},[177,544,367],{},[177,546,547],{"class":179,"line":186},[177,548,549],{},"print(list(reversed(lis))) # ['F', 'E', 'D', 'C', 'B', 'A']\n",[177,551,552],{"class":179,"line":192},[177,553,554],{},"print(lis) # ['A', 'B', 'C', 'D', 'E', 'F']\n",[157,556,557],{"id":557},"sorted",[16,559,560,528,562,564],{},[33,561,557],{},[33,563,60],{}," 也非常類似，但是它並不會影響到原有的串列。",[168,566,568],{"className":170,"code":567,"language":172,"meta":173,"style":173},"lis = [14, 30, 35, 42, 5, 16, 70, 98, 19, 100]\nprint(sorted(lis)) # [5, 14, 16, 19, 30, 35, 42, 70, 98, 100]\nprint(lis) # [14, 30, 35, 42, 5, 16, 70, 98, 19, 100]\n",[33,569,570,574,579],{"__ignoreMap":173},[177,571,572],{"class":179,"line":180},[177,573,340],{},[177,575,576],{"class":179,"line":186},[177,577,578],{},"print(sorted(lis)) # [5, 14, 16, 19, 30, 35, 42, 70, 98, 100]\n",[177,580,581],{"class":179,"line":192},[177,582,583],{},"print(lis) # [14, 30, 35, 42, 5, 16, 70, 98, 19, 100]\n",[157,585,534],{"id":534},[16,587,588,590],{},[33,589,534],{}," 雖然可以拿來做轉換，但是它也可以拿來拷貝一份新的陣列。",[16,592,593,594,597,598,600,601,603],{},"在看範例之前，我想先補充一下，下面範例我有使用一個很特別的方法叫做 ",[33,595,596],{},"id()","，這個方法可以回傳記憶體的位置，而會在前面提到這個是因為我們會使用 ",[33,599,534],{}," 拷貝一份串列出來，為了驗證兩者串列的不同才會使用 ",[33,602,596],{},"。",[168,605,607],{"className":170,"code":606,"language":172,"meta":173,"style":173},"lisA = [14, 30, 35, 42, 5, 16, 70, 98, 19, 100]\nl