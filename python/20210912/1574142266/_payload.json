[30,77,78],{},[33,79,80],{},"reduce",[30,82,83],{},[33,84,85],{},"reduceRight",[30,87,88],{},[33,89,90],{},"indexOf",[30,92,93],{},[33,94,95],{},"lastindexOf",[30,97,98],{},[33,99,100],{},"some",[30,102,103],{},[33,104,105],{},"every",[30,107,108],{},[33,109,110],{},"forEach",[30,112,113],{},[33,114,115],{},"map",[30,117,118],{},[33,119,120],{},"filter",[30,122,123],{},[33,124,125],{},"slice",[30,127,128],{},[33,129,130],{},"concat",[16,132,133],{},"那麼 Python 呢？也會有這些類似 JavaScript 一樣多的陣列操作方法嗎？基本上是有的，而這邊我也盡可能依據兩種模式來分類：",[27,135,136,139],{},[30,137,138],{},"可能會因為操作而影響原有串列的方法",[30,140,141],{},"不會影響原有串列的方法",[16,143,144],{},"底下也會搭配簡短的說明與範例來呈現。",[16,146,147],{},"所以這一篇相對會輕鬆一點，主要有點類似了解一下這些操作方法怎麼使用，如果這邊有遺漏或者寫錯就多多見諒(因為實在太多啦~~~)。",[16,149,150],{},"我粗估算了一下我列出來的數量也剛剛好與 JavaScript 相同都是二十種，而這一篇我就不會放上任何迷因圖哩。",[12,152,138],{"id":138},[16,154,155],{},"基本上這邊的分類有可能會因為你的操作而導致原始串列的改變，所以在使用上就要多加注意一下，否則你有可能會寫出 Bug。",[157,158,159],"h3",{"id":159},"insert",[16,161,162,163,166],{},"將資料往特定索引位置塞入，請注意第一個參數是索引位置，第二個則是要塞入的內容，除此之外，所以位置是以 ",[33,164,165],{},"0"," 當作起始點唷。",[168,169,174],"pre",{"className":170,"code":171,"language":172,"meta":173,"style":173},"language-py shiki shiki-themes github-dark-high-contrast","lis = ['A', 'B', 'C']\nlis.insert(1, 'Q')\nprint(lis) # ['A', 'Q', 'B', 'C']\n","py","",[33,175,176,184,190],{"__ignoreMap":173},[177,178,181],"span",{"class":179,"line":180},"line",1,[177,182,183],{},"lis = ['A', 'B', 'C']\n",[177,185,187],{"class":179,"line":186},2,[177,188,189],{},"lis.insert(1, 'Q')\n",[177,191,193],{"class":179,"line":192},3,[177,194,195],{},"print(lis) # ['A', 'Q', 'B', 'C']\n",[157,197,198],{"id":198},"append",[16,200,201,203,204,206,207,209],{},[33,202,198],{}," 與 JavaScript 的 ",[33,205,50],{}," 方法有 87% 像，因此你也可以把它理解成 ",[33,208,50],{}," 語法，因為它會在串列的最後一個插入資料。",[168,211,213],{"className":170,"code":212,"language":172,"meta":173,"style":173},"lis = ['A', 'B', 'C']\nlis.append('Q')\nprint(lis) # ['A', 'B', 'C', Q]\n",[33,214,215,219,224],{"__ignoreMap":173},[177,216,217],{"class":179,"line":180},[177,218,183],{},[177,220,221],{"class":179,"line":186},[177,222,223],{},"lis.append('Q')\n",[177,225,226],{"class":179,"line":192},[177,227,228],{},"print(lis) # ['A', 'B', 'C', Q]\n",[157,230,45],{"id":45},[16,232,233,235],{},[33,234,45],{}," 會將串列最後一筆給取出來：",[168,237,239],{"className":170,"code":238,"language":172,"meta":173,"style":173},"lis = ['A', 'B', 'C']\nprint(lis.pop()) # C\nprint(lis) # ['A', 'B']\n",[33,240,241,245,250],{"__ignoreMap":173},[177,242,243],{"class":179,"line":180},[177,244,183],{},[177,246,247],{"class":179,"line":186},[177,248,249],{},"print(lis.pop()) # C\n",[177,251,252],{"class":179,"line":192},[177,253,254],{},"print(lis) # ['A', 'B']\n",[16,256,257],{},"但是如果你傳入索引位置的話，則會變成指定取出：",[168,259,261],{"className":170,"code":260,"language":172,"meta":173,"style":173},"lis = ['A', 'B', 'C']\nprint(lis.pop(1)) # B\nprint(lis) # ['A', 'C']\n",[33,262,263,267,272],{"__ignoreMap":173},[177,264,265],{"class":179,"line":180},[177,266,183],{},[177,268,269],{"class":179,"line":186},[177,270,271],{},"print(lis.pop(1)) # B\n",[177,273,274],{"class":179,"line":192},[177,275,276],{},"print(lis) # ['A', 'C']\n",[157,278,279],{"id":279},"extend",[16,281,282,284],{},[33,283,279],{}," 在翻譯上是擴展、延長的意思，所以它的概念類似於串列相加的概念。",[168,286,288],{"className":170,"code":287,"language":172,"meta":173,"style":173},"lisA = ['A', 'B', 'C']\nlisB = ['D', 'E', 'F']\nlisA.extend(lisB)\n\nprint(lisA) # ['A', 'B', 'C', 'D', 'E', 'F']\nprint(lisB) # ['D', 'E', 'F']\n",[33,289,290,295,300,305,312,318],{"__ignoreMap":173},[177,291,292],{"class":179,"line":180},[177,293,294],{},"lisA = ['A', 'B', 'C']\n",[177,296,297],{"class":179,"line":186},[177,298,299],{},"lisB = ['D', 'E', 'F']\n",[177,301,302],{"class":179,"line":192},[177,303,304],{},"lisA.extend(lisB)\n",[177,306,308],{"class":179,"line":307},4,[177,309,311],{"emptyLinePlaceholder":310},true,"\n",[177,313,315],{"class":179,"line":314},5,[177,316,317],{},"print(lisA) # ['A', 'B', 'C', 'D', 'E', 'F']\n",[177,319,321],{"class":179,"line":320},6,[177,322,323],{},"print(lisB) # ['D', 'E', 'F']\n",[157,325,60],{"id":60},[16,327,328,330],{},[33,329,60],{}," 非常的簡單，就是將串列中的內容作排序，基本上而排序的方式則是會依據 ASCII 去排序。",[168,332,334],{"className":170,"code":333,"language":172,"meta":173,"style":173},"lis = [14, 30, 35, 42, 5, 16, 70, 98, 19, 100]\nlis.sort()\nprint(lis) # [5, 14, 16, 19, 30, 35, 42, 70, 98, 100]\n",[33,335,336,341,346],{"__ignoreMap":173},[177,337,338],{"class":179,"line":180},[177,339,340],{},"lis = [14, 30, 35, 42, 5, 16, 70, 98, 19, 100]\n",[177,342,343],{"class":179,"line":186},[177,344,345],{},"lis.sort()\n",[177,347,348],{"class":179,"line":192},[177,349,350],{},"print(lis) # [5, 14, 16, 19, 30, 35, 42, 70, 98, 100]\n",[157,352,65],{"id":65},[16,354,355,357],{},[33,356,65],{}," 應該不用太多的說明了，就是反轉串列的意思。",[168,359,361],{"className":170,"code":360,"language":172,"meta":173,"style":173},"lis = ['A', 'B', 'C', 'D', 'E', 'F']\nlis.reverse()\nprint(lis) # ['F', 'E', 'D', 'C', 'B', 'A']\n",[33,362,363,368,373],{"__ignoreMap":173},[177,364,365],{"class":179,"line":180},[177,366,367],{},"lis = ['A', 'B', 'C', 'D', 'E', 'F']\n",[177,369,370],{"class":179,"line":186},[177,371,372],{},"lis.reverse()\n",[177,374,375],{"class":179,"line":192},[177,376,377],{},"print(lis) # ['F', 'E', 'D', 'C', 'B', 'A']\n",[157,379,380],{"id":380},"remove",[16,382,383,385],{},[33,384,380],{}," 在運作上是採用內容的方式去刪除，假設如果你只知道該內容是什麼，但不知道索引位置，那就可以使用該方法。",[168,387,389],{"className":170,"code":388,"language":172,"meta":173,"style":173},"lis = ['A', 'B', 'C', 'D', 'E', 'F']\nlis.remove('D')\nprint(lis) # ['A', 'B', 'C', 'E', 'F']\n",[33,390,391,395,400],{"__ignoreMap":173},[177,392,393],{"class":179,"line":180},[177,394,367],{},[177,396,397],{"class":179,"line":186},[177,398,399],{},"lis.remove('D')\n",[177,401,402],{"class":179,"line":192},[177,403,404],{},"print(lis) # ['A', 'B', 'C', 'E', 'F']\n",[157,406,407],{"id":407},"clear",[16,409,410],{},"clear 非常的乾脆，就是直接清空串列。",[168,412,414],{"className":170,"code":413,"lan