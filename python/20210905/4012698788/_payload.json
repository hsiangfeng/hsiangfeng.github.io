[{"data":1,"prerenderedAt":1250},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210905\u002F4012698788\u002F":3,"page:\u002Fpython\u002F20210905\u002F4012698788\u002F":4,"alt:\u002Fpython\u002F20210905\u002F4012698788\u002F":3,"prev-next:\u002Fpython\u002F20210905\u002F4012698788\u002F":1226,"related:\u002Fpython\u002F20210905\u002F4012698788\u002F":1235},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F05\u002Fjs-to-python-04-types-and-variables\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1210,"date":1211,"description":18,"extension":1212,"lang":1213,"meta":1214,"navigation":558,"path":1215,"readingMinutes":1216,"seo":1217,"standalone":1218,"stem":1219,"tags":1220,"tldr":1223,"updated":1223,"url":1224,"__hash__":1225},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-4-型別與變數.md","從 JavaScript 角度學 Python(4) - 型別與變數","4012698788",{"type":9,"value":10,"toc":1201},"minimark",[11,15,19,22,25,32,35,38,94,97,112,120,129,132,143,146,149,152,188,194,197,212,309,318,333,344,352,383,389,392,403,413,428,437,446,457,473,476,479,495,644,656,659,684,687,701,712,757,776,779,785,788,794,797,807,897,907,916,938,941,944,950,953,977,987,1014,1030,1033,1036,1042,1046,1049,1060,1066,1069,1080,1098,1101,1136,1143,1149,1152,1155,1158,1191,1197],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"oh！終於要開始學習寫 Python 了呢！(被揍)，都混了三天，我如果再不開始寫 Python 的話，我想應該一推人準備退訂閱了，但是在開始學習之前，我們會先從最基礎的型別開始學習，那麼這邊也會盡可能使用 JavaScript 兩者語法上的差異去做比較與學習唷。",[12,20,21],{"id":21},"型別",[16,23,24],{},"一開始我們先來簡單了解一下關於 Python 型別的部分...",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"你良心不痛嗎！！","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630760904885.png",[16,33,34],{},"哎，別這樣說，雖然我很想再多偷懶個幾篇，但是我想是差不多開始認識 Python 怎麼寫，但是要開始寫之前總要先學基礎對吧？",[16,36,37],{},"所以在前面我們先快速複習一下 JavaScript 中有哪些原始型別：",[39,40,41,58,73,88,91],"ul",{},[42,43,44,45],"li",{},"String - 字串\n",[39,46,47,53],{},[42,48,49],{},[50,51,52],"code",{},"'這是一個字串'",[42,54,55],{},[50,56,57],{},"\"這也是一個字串\"",[42,59,60,61],{},"Boolean - 布林\n",[39,62,63,68],{},[42,64,65],{},[50,66,67],{},"true",[42,69,70],{},[50,71,72],{},"false",[42,74,75,76],{},"Number - 數字\n",[39,77,78,83],{},[42,79,80],{},[50,81,82],{},"100000",[42,84,85],{},[50,86,87],{},"3.141592653",[42,89,90],{},"Undefined - 未定義",[42,92,93],{},"Null - 空值",[16,95,96],{},"以及後來新增的：",[39,98,99,109],{},[42,100,101,102],{},"Bigint - 整數數值\n",[39,103,104],{},[42,105,106],{},[50,107,108],{},"9007199254740991n",[42,110,111],{},"Symbol - Symbol",[16,113,114,115,119],{},"這些之外的我們通通稱之為",[116,117,118],"strong",{},"物件型別","，所以通常會看到人家講原始型別與物件型別。",[16,121,122,123,128],{},"如果你對於 JavaScript 的型別觀念還不是那麼熟悉的話，那麼我建議你可以閱讀我先前寫的「",[124,125,127],"a",{"href":126},"\u002Fjavascript\u002F20200621\u002F3684249269\u002F","JavaScript 核心觀念(14)-運算子、型別與文法-原始型別及物件型別","」文章會有更詳細的說明唷！",[16,130,131],{},"那麼 Python 呢？Python 的型別主要區分為三大類：",[39,133,134,137,140],{},[42,135,136],{},"數值型別",[42,138,139],{},"字串型別",[42,141,142],{},"容器型別",[16,144,145],{},"很特別吧？竟然直接區分成三種型別，尤其是容器型別更是特別。",[16,147,148],{},"一開始我們先來聊聊比較接近 JavaScript 型別的「數值型別」與「字串型別」，而容器型別我們在別的章節再來聊吧！",[16,150,151],{},"不可否認 Python 與 JavaScript 在型別定義上確實是比較不一樣，所以就讓我們先來看看「數值型別」與「字串型別」，雖然是講數值型別與字串型別，但是實際上這兩個型別底下還會再細分相關的型別：",[39,153,154,177],{},[42,155,156,157],{},"數值型別\n",[39,158,159,165,171],{},[42,160,161,164],{},[50,162,163],{},"int"," - 整數",[42,166,167,170],{},[50,168,169],{},"floats"," - 浮點數",[42,172,173,176],{},[50,174,175],{},"boolean"," - 布林",[42,178,179,180],{},"字串型別\n",[39,181,182],{},[42,183,184,187],{},[50,185,186],{},"string"," - 就是字串你還想怎樣？",[16,189,190],{},[28,191],{"alt":192,"src":193},"今天很嗆哦","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E4%BB%8A%E5%A4%A9%E5%BE%88%E5%97%86%E6%98%AF%E5%90%A7.jpg",[16,195,196],{},"(前面開玩笑的。)",[16,198,199,200,203,204,207,208,211],{},"字串型別與 JavaScript String 型別並沒有任何差異，但是我們可以看到最明顯的差異是在於「數值型別」，在 JavaScript 中不論是 ",[50,201,202],{},"var num = 1.23456;"," 或者是 ",[50,205,206],{},"var num2 = 123;","，我們都是通通歸類為 ",[50,209,210],{},"Number"," 型別，當然我們也可以驗證一下：",[213,214,219],"pre",{"className":215,"code":216,"language":217,"meta":218,"style":218},"language-js shiki shiki-themes github-dark-high-contrast","var num = 1.23456;\nvar num2 = 123;\nconsole.log('Number', typeof(num)); \u002F\u002F Number number\nconsole.log('Number', typeof(num2)); \u002F\u002F Number number\n","js","",[50,220,221,244,259,289],{"__ignoreMap":218},[222,223,226,230,234,237,241],"span",{"class":224,"line":225},"line",1,[222,227,229],{"class":228},"sWyjQ","var",[222,231,233],{"class":232},"sMAXC"," num ",[222,235,236],{"class":228},"=",[222,238,240],{"class":239},"sCcAr"," 1.23456",[222,242,243],{"class":232},";\n",[222,245,247,249,252,254,257],{"class":224,"line":246},2,[222,248,229],{"class":228},[222,250,251],{"class":232}," num2 ",[222,253,236],{"class":228},[222,255,256],{"class":239}," 123",[222,258,243],{"class":232},[222,260,262,265,269,272,276,279,282,285],{"class":224,"line":261},3,[222,263,264],{"class":232},"console.",[222,266,268],{"class":267},"sj_SG","log",[222,270,271],{"class":232},"(",[222,273,275],{"class":274},"sTRMh","'Number'",[222,277,278],{"class":232},", ",[222,280,281],{"class":228},"typeof",[222,283,284],{"class":232},"(num)); ",[222,286,288],{"class":287},"sQrFR","\u002F\u002F Number number\n",[222,290,292,294,296,298,300,302,304,307],{"class":224,"line":291},4,[222,293,264],{"class":232},[222,295,268],{"class":267},[222,297,271],{"class":232},[222,299,275],{"class":274},[222,301,278],{"class":232},[222,303,281],{"class":228},[222,305,306],{"class":232},"(num2)); ",[222,308,288],{"class":287},[16,310,311,312,314,315,317],{},"只是在 Python 中卻有區分出 ",[50,313,163],{}," 型別與 ",[50,316,169],{}," 型別，這兩者型別如何辨識呢？只需要看它有沒有小數點就對了。",[16,319,320,321,323,324,326,327,329,330,332],{},"若有小數點的話就是浮點數，所以 ",[50,322,202],{}," 在 Python 中其實是浮點數(",[50,325,169],{},")，而 ",[50,328,206],{}," 則是整數(",[50,331,163],{},")。",[16,334,335,336,339,340,343],{},"那...JavaScript 中的 ",[50,337,338],{},"Undefined"," 與 ",[50,341,342],{},"Null"," 呢？Python 也存在嗎？",[16,345,346,348,349,351],{},[50,347,338],{}," 就不說了，畢竟這是 JavaScript 的特殊型別，只要你有在變數宣告之前呼叫過變數的話，一定很常看到 ",[50,350,338],{}," (這部分又牽扯到提升就不提了。)：",[213,353,355],{"className":215,"code":354,"language":217,"meta":218,"style":218},"console.log(myName); \u002F\u002F undefined\nvar myName = 'Ray';\n",[50,356,357,369],{"__ignoreMap":218},[222,358,359,361,363,366],{"class":224,"line":225},[222,360,264],{"class":232},[222,362,268],{"class":267},[222,364,365],{"class":232},"(myName); ",[222,367,368],{"class":287},"\u002F\u002F undefined\n",[222,370,371,373,376,378,381],{"class":224,"line":246},[222,372,229],{"class":228},[222,374,375],{"class":232}," myName ",[222,377,236],{"class":228},[222,379,380],{"class":274}," 'Ray'",[222,382,243],{"class":232},[16,384,385,386,388],{},"但是 ",[50,387,342],{}," 這個型別也不存在於 Python 中，所以如果你若輸入以下語法是會出現錯誤的，那這邊我們就來簡單寫一點點的 Python 來驗證看看：",[16,390,391],{},"(注意，Python 不用加上結尾分號)",[213,393,397],{"className":394,"code":395,"language":396,"meta":218,"style":218},"language-py shiki shiki-themes github-dark-high-contrast","hello = Null # name 'Null' is not defined\n","py",[50,398,399],{"__ignoreMap":218},[222,400,401],{"class":224,"line":225},[222,402,395],{},[16,404,405,406,409,410,412],{},"取而代之的是 Python 所使用的是 ",[50,407,408],{},"None","，這邊要注意 ",[50,411,408],{}," 顯示出來會是一個 Nonetype：",[213,414,416],{"className":394,"code":415,"language":396,"meta":218,"style":218},"hello = None\ntype(hello) # \u003Cclass 'NoneType'>\n",[50,417,418,423],{"__ignoreMap":218},[222,419,420],{"class":224,"line":225},[222,421,422],{},"hello = None\n",[222,424,425],{"class":224,"line":246},[222,426,427],{},"type(hello) # \u003Cclass 'NoneType'>\n",[16,429,271,430,433,434,436],{},[50,431,432],{},"type"," 的語法與 JavaScript 的 ",[50,435,281],{}," 相同，主要是查看型別用。)",[16,438,439,440,442,443,445],{},"所以可以把 JavaScript 的 ",[50,441,342],{}," 想像成是 Python 的 ",[50,444,408],{},"。",[16,447,448,449,452,453,456],{},"除此之外 ",[50,450,451],{},"\u003Cclass 'NoneType'>"," 這一段的意思是在講這個變數是 NoneType 類型，如果是一個字串的話，就會是 ",[50,454,455],{},"\u003Cclass 'str'>"," 也就是字串類型概念，而 None 這也是屬於 Python 的特殊型別。",[16,458,459,460,463,464,466,467,469,470,472],{},"題外話一下在 Python 2.x 則是顯示 ",[50,461,462],{},"\u003Ctype 'str'>","，只是在 Python 3.x 改成了 ",[50,465,455],{}," 而已，所以不論是 ",[50,468,455],{}," 還是 ",[50,471,462],{}," 都是代表著當前變數是什麼型別的意思。",[12,474,475],{"id":475},"變數",[16,477,478],{},"變數可以說是所有程式語言最基礎最重要的起手式，因為我們會很常需要使用變數儲存資料，如果以 JavaScript 作為舉例就是儲存 AJAX 回來的資料最為常見。",[16,480,481,482,484,485,339,488,491,492,494],{},"這邊以 JavaScript 作為起手式，當我們在建立變數時，通常都會使用 ",[50,483,229],{}," 或者 ES6 語法 ",[50,486,487],{},"let",[50,489,490],{},"const","，以下這邊就先以 ",[50,493,229],{}," 作為舉例：",[213,496,498],{"className":215,"code":497,"language":217,"meta":218,"style":218},"var myNameTest = 'Ray';\nvar numTest = 1;\nvar num2Test = 3.14\nvar boolTest = true;\n\nconsole.log('String', typeof(myNameTest)); \u002F\u002F String string\nconsole.log('Number', typeof(numTest)); \u002F\u002F Number number\nconsole.log('Number', typeof(num2Test)); \u002F\u002F Number number\nconsole.log('Boolean', typeof(boolTest)); \u002F\u002F Boolean boolean\n",[50,499,500,513,527,539,553,560,582,602,622],{"__ignoreMap":218},[222,501,502,504,507,509,511],{"class":224,"line":225},[222,503,229],{"class":228},[222,505,506],{"class":232}," myNameTest ",[222,508,236],{"class":228},[222,510,380],{"class":274},[222,512,243],{"class":232},[222,514,515,517,520,522,525],{"class":224,"line":246},[222,516,229],{"class":228},[222,518,519],{"class":232}," numTest ",[222,521,236],{"class":228},[222,523,524],{"class":239}," 1",[222,526,243],{"class":232},[222,528,529,531,534,536],{"class":224,"line":261},[222,530,229],{"class":228},[222,532,533],{"class":232}," num2Test ",[222,535,236],{"class":228},[222,537,538],{"class":239}," 3.14\n",[222,540,541,543,546,548,551],{"class":224,"line":291},[222,542,229],{"class":228},[222,544,545],{"class":232}," boolTest ",[222,547,236],{"class":228},[222,549,550],{"class":239}," true",[222,552,243],{"class":232},[222,554,556],{"class":224,"line":555},5,[222,557,559],{"emptyLinePlaceholder":558},true,"\n",[222,561,563,565,567,569,572,574,576,579],{"class":224,"line":562},6,[222,564,264],{"class":232},[222,566,268],{"class":267},[222,568,271],{"class":232},[222,570,571],{"class":274},"'String'",[222,573,278],{"class":232},[222,575,281],{"class":228},[222,577,578],{"class":232},"(myNameTest)); ",[222,580,581],{"class":287},"\u002F\u002F String string\n",[222,583,585,587,589,591,593,595,597,600],{"class":224,"line":584},7,[222,586,264],{"class":232},[222,588,268],{"class":267},[222,590,271],{"class":232},[222,592,275],{"class":274},[222,594,278],{"class":232},[222,596,281],{"class":228},[222,598,599],{"class":232},"(numTest)); ",[222,601,288],{"class":287},[222,603,605,607,609,611,613,615,617,620],{"class":224,"line":604},8,[222,606,264],{"class":232},[222,608,268],{"class":267},[222,610,271],{"class":232},[222,612,275],{"class":274},[222,614,278],{"class":232},[222,616,281],{"class":228},[222,618,619],{"class":232},"(num2Test)); ",[222,621,288],{"class":287},[222,623,625,627,629,631,634,636,638,641],{"class":224,"line":624},9,[222,626,264],{"class":232},[222,628,268],{"class":267},[222,630,271],{"class":232},[222,632,633],{"class":274},"'Boolean'",[222,635,278],{"class":232},[222,637,281],{"class":228},[222,639,640],{"class":232},"(boolTest)); ",[222,642,643],{"class":287},"\u002F\u002F Boolean boolean\n",[16,645,646,647,649,650,652,653,655],{},"Python 在宣告變數上與 JavaScript 是有一點點的不同，在 Python 中我們可以不使用任何的變數宣告關鍵字 (",[50,648,229],{},"、",[50,651,487],{}," or ",[50,654,490],{},") 來宣告變數，只需要直接撰寫變數名稱並賦予值或結果就可以了。",[16,657,658],{},"底下這邊就以上方示範的 JavaScript 範例直接改寫成 Python 結構：",[213,660,662],{"className":394,"code":661,"language":396,"meta":218,"style":218},"myNameTest = 'Ray'\nnumTest = 1\nnum2Test = 3.14\nboolTest = True\n",[50,663,664,669,674,679],{"__ignoreMap":218},[222,665,666],{"class":224,"line":225},[222,667,668],{},"myNameTest = 'Ray'\n",[222,670,671],{"class":224,"line":246},[222,672,673],{},"numTest = 1\n",[222,675,676],{"class":224,"line":261},[222,677,678],{},"num2Test = 3.14\n",[222,680,681],{"class":224,"line":291},[222,682,683],{},"boolTest = True\n",[16,685,686],{},"這邊你應該會注意到 Python 的 Boolean 是採用首字大寫的方式撰寫，這個與 JavaScript Boolean 全小寫完全不同，這是一個小細節要注意一下：",[213,688,690],{"className":394,"code":689,"language":396,"meta":218,"style":218},"boolTest = True\nboolTest = False\n",[50,691,692,696],{"__ignoreMap":218},[222,693,694],{"class":224,"line":225},[222,695,683],{},[222,697,698],{"class":224,"line":246},[222,699,700],{},"boolTest = False\n",[16,702,703,704,707,708,711],{},"通常我們在撰寫 JavaScript 的時候，我們可以使用 ",[50,705,706],{},"console.log"," 輸出結果，而 Python 則是使用 ",[50,709,710],{},"print()"," 函式輸出結果：",[213,713,715],{"className":394,"code":714,"language":396,"meta":218,"style":218},"myNameTest = 'Ray'\nnumTest = 1\nnum2Test = 3.14\nboolTest = True\n\nprint('String', type(myNameTest))\nprint('Number', type(numTest))\nprint('Float', type(num2Test))\nprint('Boolean', type(boolTest))\n",[50,716,717,721,725,729,733,737,742,747,752],{"__ignoreMap":218},[222,718,719],{"class":224,"line":225},[222,720,668],{},[222,722,723],{"class":224,"line":246},[222,724,673],{},[222,726,727],{"class":224,"line":261},[222,728,678],{},[222,730,731],{"class":224,"line":291},[222,732,683],{},[222,734,735],{"class":224,"line":555},[222,736,559],{"emptyLinePlaceholder":558},[222,738,739],{"class":224,"line":562},[222,740,741],{},"print('String', type(myNameTest))\n",[222,743,744],{"class":224,"line":584},[222,745,746],{},"print('Number', type(numTest))\n",[222,748,749],{"class":224,"line":604},[222,750,751],{},"print('Float', type(num2Test))\n",[222,753,754],{"class":224,"line":624},[222,755,756],{},"print('Boolean', type(boolTest))\n",[16,758,759,760,763,764,649,767,770,771,775],{},"(題外話一下 ",[50,761,762],{},"console.xxx"," 還有很多種，例如：",[50,765,766],{},"console.dir",[50,768,769],{},"console.table"," 等等，如果你不熟悉的話，可以閱讀我這一篇筆記 「",[124,772,774],{"href":773},"\u002Fjavascript\u002F20200313\u002F3743352418\u002F","淺談 JavaScript 中的 Debug 神器 Console","」 了解一下。)",[16,777,778],{},"最後讓我們稍微透過一張圖一起比較一下兩者語法差異：",[16,780,781],{},[28,782],{"alt":783,"src":784},"比較","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-19%2015.44.31.png",[16,786,787],{},"將兩種程式語言放在一起之後應該會有人覺得 Python 的語法確實簡潔相當多，可能會萌生我該學 JavaScript 還是 Python 的錯覺，那我就會這樣給你一張圖：",[16,789,790],{},[28,791],{"alt":792,"src":793},"從 JavaScript 角度學 Python","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1624089047400.png",[12,795,796],{"id":796},"重新賦值",[16,798,799,800,802,803,806],{},"接下來我們來聊聊 ",[116,801,796],{}," 這個行為，在 JavaScript 中會依據你的宣告方式的不同，而決定你這個變數是否可以被 ",[116,804,805],{},"再次重新賦值","，因此讓我們看一下 JavaScript 宣告範例：",[213,808,810],{"className":215,"code":809,"language":217,"meta":218,"style":218},"var myName = 'Ray';\nmyName = 'Ray'; \u002F\u002F 可以被重新賦值\nlet sayHi = 'Hello Ray';\nsayHi = 'Ray Hello'; \u002F\u002F 可以被重新賦值\nconst isRay = 'not Array';\nisRay = 'is Array'; \u002F\u002F 無法被重新賦值\n",[50,811,812,824,839,853,867,882],{"__ignoreMap":218},[222,813,814,816,818,820,822],{"class":224,"line":225},[222,815,229],{"class":228},[222,817,375],{"class":232},[222,819,236],{"class":228},[222,821,380],{"class":274},[222,823,243],{"class":232},[222,825,826,829,831,833,836],{"class":224,"line":246},[222,827,828],{"class":232},"myName ",[222,830,236],{"class":228},[222,832,380],{"class":274},[222,834,835],{"class":232},"; ",[222,837,838],{"class":287},"\u002F\u002F 可以被重新賦值\n",[222,840,841,843,846,848,851],{"class":224,"line":261},[222,842,487],{"class":228},[222,844,845],{"class":232}," sayHi ",[222,847,236],{"class":228},[222,849,850],{"class":274}," 'Hello Ray'",[222,852,243],{"class":232},[222,854,855,858,860,863,865],{"class":224,"line":291},[222,856,857],{"class":232},"sayHi ",[222,859,236],{"class":228},[222,861,862],{"class":274}," 'Ray Hello'",[222,864,835],{"class":232},[222,866,838],{"class":287},[222,868,869,871,874,877,880],{"class":224,"line":555},[222,870,490],{"class":228},[222,872,873],{"class":239}," isRay",[222,875,876],{"class":228}," =",[222,878,879],{"class":274}," 'not Array'",[222,881,243],{"class":232},[222,883,884,887,889,892,894],{"class":224,"line":562},[222,885,886],{"class":232},"isRay ",[222,888,236],{"class":228},[222,890,891],{"class":274}," 'is Array'",[222,893,835],{"class":232},[222,895,896],{"class":287},"\u002F\u002F 無法被重新賦值\n",[16,898,899,901,902,906],{},[50,900,229],{}," 與 ES6 語法又有些許不同，因此這邊不著墨在 JavaScript 宣告變數上，若想再深入了解可以閱讀我先前寫「",[124,903,905],{"href":904},"\u002Fjavascript\u002F20200425\u002F539985371\u002F","淺談 var 與 let 的差異以及有無宣告變數的差異","」這一篇。",[16,908,909,910,912,913,915],{},"回到宣告變數的部分，使用 ",[50,911,487],{}," 宣告的變數，若再一次使用 ",[50,914,487],{}," 關鍵字重新宣告變數，是會出現錯誤的：",[213,917,919],{"className":215,"code":918,"language":217,"meta":218,"style":218},"let myName;\nlet myName; \u002F\u002F Uncaught SyntaxError: redeclaration of let myName\n",[50,920,921,928],{"__ignoreMap":218},[222,922,923,925],{"class":224,"line":225},[222,924,487],{"class":228},[222,926,927],{"class":232}," myName;\n",[222,929,930,932,935],{"class":224,"line":246},[222,931,487],{"class":228},[222,933,934],{"class":232}," myName; ",[222,936,937],{"class":287},"\u002F\u002F Uncaught SyntaxError: redeclaration of let myName\n",[16,939,940],{},"除此之外 JavaScript 的變數宣告又會因為宣告方式的不同而有作用域以及提升的問題，已經頭暈了嗎？不用擔心，這邊不會繼續著墨 JavaScript 的部分。",[16,942,943],{},"那麼 Python 呢？Python 會有這個問題嗎？",[16,945,946],{},[28,947],{"alt":948,"src":949},"讓我們繼續看下去","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F202007072218.jpg",[16,951,952],{},"接下來的觀念可能會與你在學 JavaScript 的觀念有一點衝突，主要原因是出在我們前面有講過 Python 在宣告變數時，是不用使用關鍵字來宣告的，因此就算你這樣子寫，也不會出現錯誤：",[213,954,956],{"className":394,"code":955,"language":396,"meta":218,"style":218},"myNameTest = 'Ray'\nprint(myNameTest) # 'Ray'\nmyNameTest = 123\nprint(myNameTest) # 123\n",[50,957,958,962,967,972],{"__ignoreMap":218},[222,959,960],{"class":224,"line":225},[222,961,668],{},[222,963,964],{"class":224,"line":246},[222,965,966],{},"print(myNameTest) # 'Ray'\n",[222,968,969],{"class":224,"line":261},[222,970,971],{},"myNameTest = 123\n",[222,973,974],{"class":224,"line":291},[222,975,976],{},"print(myNameTest) # 123\n",[16,978,979,980,983,984,986],{},"為什麼會這樣呢？對於 Python 來講 ",[116,981,982],{},"你並沒有重新宣告變數，而是告訴變數重新指向到新的值而已","，這也就是為什麼並不會出現錯誤的原因，所以你也可以把它想像成 Python 是使用了 ",[50,985,487],{}," 作為宣告，為什麼這樣說呢？因為如果你在變數宣告之前就先呼叫了這個變數是會出現錯誤的：",[213,988,990],{"className":394,"code":989,"language":396,"meta":218,"style":218},"print(myNameTest) # NameError: name 'myNameTest' is not defined\nmyNameTest = 'Ray'\nprint(myNameTest)\nmyNameTest = 123\nprint(myNameTest)\n",[50,991,992,997,1001,1006,1010],{"__ignoreMap":218},[222,993,994],{"class":224,"line":225},[222,995,996],{},"print(myNameTest) # NameError: name 'myNameTest' is not defined\n",[222,998,999],{"class":224,"line":246},[222,1000,668],{},[222,1002,1003],{"class":224,"line":261},[222,1004,1005],{},"print(myNameTest)\n",[222,1007,1008],{"class":224,"line":291},[222,1009,971],{},[222,1011,1012],{"class":224,"line":555},[222,1013,1005],{},[16,1015,1016,1017,649,1019,1021,1022,1026,1027,1029],{},"概念是不是很很像 ",[50,1018,487],{},[50,1020,490],{}," 的暫時性死區概念呢(若不清楚暫時性死區可詳見 ",[124,1023,1025],{"href":1024},"\u002Fjavascript\u002F20210718\u002F956160363\u002F","此篇"," 筆記)？這就是為什麼我會說可以把它想像成 ",[50,1028,487],{}," 了。那你可能會問說 Python 會有 Hoisting 嗎？我想是沒有的。",[16,1031,1032],{},"畢竟提升 (Hoisting) 這個行為是 JavaScript 獨特的運作模式。",[16,1034,1035],{},"最後是關於作用域的部分，關於作用域我打算下一次再來分享，看到現在的你有沒有感覺到 JavaScript 與 Python 各自美好之處呢？",[16,1037,1038],{},[28,1039],{"alt":1040,"src":1041},"混亂","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1624090358032.png",[12,1043,1045],{"id":1044},"執行-python","執行 Python",[16,1047,1048],{},"接下來相信會有人疑惑該如何輸入上面這些程式碼，基本上有兩種方式",[16,1050,1051,1052,1055,1056,1059],{},"第一種是打開終端機，然後輸入 ",[50,1053,1054],{},"python"," 就會進入 Python 編譯器，概念就跟我們在終端機輸入 ",[50,1057,1058],{},"node"," 一樣：",[16,1061,1062],{},[28,1063],{"alt":1064,"src":1065},"Python 輸入模式","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E6%88%AA%E5%9C%96%202021-06-15%2020.31.30.png",[16,1067,1068],{},"(上圖出現 Python 2.7 可忽略)",[16,1070,1071,1072,1075,1076,1079],{},"這邊退出終端機模式可以輸入 ",[50,1073,1074],{},"exit()"," 、 ",[50,1077,1078],{},"quit()"," 等指令退出，或者是依據作業系統的組合按鈕來退出 Python 模式：",[39,1081,1082,1090],{},[42,1083,1084,1085],{},"Window\n",[39,1086,1087],{},[42,1088,1089],{},"CTRL + D",[42,1091,1092,1093],{},"Mac\n",[39,1094,1095],{},[42,1096,1097],{},"Control + D",[16,1099,1100],{},"第二種方式則是透過編輯器，這邊我是使用 VSCode 建立一個檔案叫做 ch1.py，然後貼入下方內容：",[213,1102,1104],{"className":394,"code":1103,"language":396,"meta":218,"style":218},"# 字串 string\nmyName = 'Ray'\nblogUrl = '\u002F'\n# 輸出\nprint('字串 string', myName) # 字串 string Ray\nprint('字串 string', blogUrl) # 字串 string \u002F\n",[50,1105,1106,1111,1116,1121,1126,1131],{"__ignoreMap":218},[222,1107,1108],{"class":224,"line":225},[222,1109,1110],{},"# 字串 string\n",[222,1112,1113],{"class":224,"line":246},[222,1114,1115],{},"myName = 'Ray'\n",[222,1117,1118],{"class":224,"line":261},[222,1119,1120],{},"blogUrl = '\u002F'\n",[222,1122,1123],{"class":224,"line":291},[222,1124,1125],{},"# 輸出\n",[222,1127,1128],{"class":224,"line":555},[222,1129,1130],{},"print('字串 string', myName) # 字串 string Ray\n",[222,1132,1133],{"class":224,"line":562},[222,1134,1135],{},"print('字串 string', blogUrl) # 字串 string \u002F\n",[16,1137,1138,1139,1142],{},"接下來透過 VSCode 直接執行 ",[50,1140,1141],{},".py"," 就可以看到結果囉",[16,1144,1145],{},[28,1146],{"alt":1147,"src":1148},"在終端機執行 Python 檔案","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u0