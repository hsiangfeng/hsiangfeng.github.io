們拉回到 Python 中，如果想要寫出跟上面 JavaScript 的閉包我們又給如何撰寫呢？讓我們看一下將上面程式碼改成 Python 的話會是長什麼樣子呢？：",[29,299,301],{"className":31,"code":300,"language":33,"meta":34,"style":34},"def count():\n  icash = 1000\n  def reduce(price):\n    nonlocal icash\n    icash = icash - price\n  return reduce\n\nray = count()\nray(100) # 900\nray(200) # 700\n",[36,302,303,308,313,318,323,328,333,337,342,347],{"__ignoreMap":34},[39,304,305],{"class":41,"line":42},[39,306,307],{},"def count():\n",[39,309,310],{"class":41,"line":48},[39,311,312],{},"  icash = 1000\n",[39,314,315],{"class":41,"line":55},[39,316,317],{},"  def reduce(price):\n",[39,319,320],{"class":41,"line":61},[39,321,322],{},"    nonlocal icash\n",[39,324,325],{"class":41,"line":67},[39,326,327],{},"    icash = icash - price\n",[39,329,330],{"class":41,"line":72},[39,331,332],{},"  return reduce\n",[39,334,335],{"class":41,"line":224},[39,336,52],{"emptyLinePlaceholder":51},[39,338,339],{"class":41,"line":230},[39,340,341],{},"ray = count()\n",[39,343,344],{"class":41,"line":246},[39,345,346],{},"ray(100) # 900\n",[39,348,349],{"class":41,"line":265},[39,350,351],{},"ray(200) # 700\n",[16,353,354],{},"oh！這邊你可千萬不要這樣子寫：",[29,356,358],{"className":31,"code":357,"language":33,"meta":34,"style":34},"def count():\n  icash = 1000\n  return def (price):\n    nonlocal icash\n    icash = icash - price\n\nray = count()\nray(100) # 900\nray(200) # 700\n",[36,359,360,364,368,373,377,381,385,389,393],{"__ignoreMap":34},[39,361,362],{"class":41,"line":42},[39,363,307],{},[39,365,366],{"class":41,"line":48},[39,367,312],{},[39,369,370],{"class":41,"line":55},[39,371,372],{},"  return def (price):\n",[39,374,375],{"class":41,"line":61},[39,376,322],{},[39,378,379],{"class":41,"line":67},[39,380,327],{},[39,382,383],{"class":41,"line":72},[39,384,52],{"emptyLinePlaceholder":51},[39,386,387],{"class":41,"line":224},[39,388,341],{},[39,390,391],{"class":41,"line":230},[39,392,346],{},[39,394,395],{"class":41,"line":246},[39,396,351],{},[16,398,399,400,40