4,"line":177},[92,516,152],{"emptyLinePlaceholder":151},[92,518,519],{"class":94,"line":186},[92,520,218],{"class":98},[92,522,523,525,527,529,531,533],{"class":94,"line":200},[92,524,468],{"class":351},[92,526,471],{"class":105},[92,528,226],{"class":109},[92,530,113],{"class":105},[92,532,231],{"class":116},[92,534,174],{"class":105},[92,536,537,539],{"class":94,"line":205},[92,538,180],{"class":105},[92,540,183],{"class":116},[92,542,543],{"class":94,"line":210},[92,544,145],{"class":105},[92,546,547],{"class":94,"line":215},[92,548,152],{"emptyLinePlaceholder":151},[92,550,551],{"class":94,"line":221},[92,552,274],{"class":98},[92,554,555,557,559,561,563,565],{"class":94,"line":236},[92,556,468],{"class":351},[92,558,471],{"class":105},[92,560,282],{"class":109},[92,562,113],{"class":105},[92,564,287],{"class":116},[92,566,480],{"class":105},[16,568,569],{},"雖然我們也可以不使用 axios 套件，直接使用瀏覽器所提供的 Fetch API or XMLHttpRequest 等 Web APIs 達到 AJAX 請求，但實際上來講我們在開發時，還是比較常使用 axios 套件，所以前面也是快速提一下 axios 套件的各種寫法，等一下才會覺得 Python 的部分會比較親民。",[12,571,573],{"id":572},"requests","Requests",[16,575,576],{},"前面講了那麼多，那麼 Python 呢？Python 有辦法本身有提供類似 Fetch API 或者是 XMLHttpRequest 等 Web APIs 嗎？答案是沒有的。",[16,578,579],{},"因此我們必須使用一個套件叫做 Requests 套件，透過使用 Requests 套件我們就可以達到一樣的 AJAX 行為，只是在安裝之前請務必注意 Requests 套件在 Python2 與 Python3 的安裝是不太一樣，下面也提供安裝指令給你參考：",[83,581,585],{"className":582,"code":583,"language":584,"meta":88,"style":88},"language-cmd shiki shiki-themes github-dark-high-contrast","\u002F\u002F Python 2.x\npip install requests\n\n\u002F\u002F Python 3.x\npip3 install requests2\n","cmd",[37,586,587,592,597,601,606],{"__ignoreMap":88},[92,588,589],{"class":94,"line":95},[92,590,591],{},"\u002F\u002F Python 2.x\n",[92,593,594],{"class":94,"line":102},[92,595,596],{},"pip install requests\n",[92,598,599],{"class":94,"line":136},[92,600,152],{"emptyLinePlaceholder":151},[92,602,603],{"class":94,"line":142},[92,604,605],{},"\u002F\u002F Python 3.x\n",[92,607,608],{"class":94,"line":148},[92,609,610],{},"pip3 install requests2\n",[16,612,613],{},"基本上 Requests 套件使用的方式非常簡單，所以這邊就直接來看一個基礎範例寫法比較快：",[83,615,619],{"className":616,"code":617,"language":618,"meta":88,"style":88},"language-py shiki shiki-themes github-dark-high-contrast","import requests\n\nr = requests.get('https:\u002F\u002Fwww.google.com\u002F')\n","py",[37,620,621,626,630],{"__ignoreMap":88},[92,622,623],{"class":94,"line":95},[92,624,625],{},"import requests\n",[92,627,628],{"class":94,"line":102},[92,629,152],{"emptyLinePlaceholder":151},[92,631,632],{"class":94,"line":136},[92,633,634],{},"r = requests.get('https:\u002F\u002Fwww.google.com\u002F')\n",[16,636,637,638,641,642,644,645,648],{},"不論你安裝的是 ",[37,639,640],{},"requests2"," 還是 ",[37,643,572],{},"，在引入模組時一率都是使用 ",[37,646,647],{},"import requests"," 即可。",[16,650,651,652,654],{},"看完上面範例有沒有頓時覺得超級像 ",[37,653,39],{}," 的寫法呢？感覺就只是單純換個單字罷了，沒有錯就是這麼簡單。",[16,656,657,658,661,662],{},"只是如果你直接 ",[37,659,660],{},"print(r)"," 出來你會發現，並不是你預期的 Get 內容，你可能會看到一串字串也就是 ",[37,663,664],{},"\u003CResponse [200]>",[16,666,667],{},[29,668],{"alt":669,"src":670},"被 Response 200 嚇到的我","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631800972830.png",[16,672,673],{},"所以正確來講你如果想看到內容的話，就要額外處理一下唷～",[16,675,676,677,683],{},"那該怎麼處理呢？這邊就讓我們直接閱讀 ",[59,678,682],{"href":679,"rel":680},"https:\u002F\u002Fdocs.python-requests.org\u002Fen\u002Flatest\u002F",[681],"nofollow","requests 官方文件"," 的寫法來試試看：",[83,685,687],{"className":616,"code":686,"language":618,"meta":88,"style":88},"import requests\n\nr = requests.get('https:\u002F\u002Fwww.google.com\u002F')\nprint(r.status_code) # 200\nprint(r.headers['content-type']) # text\u002Fhtml; charset=ISO-8859-1\nprint(r.encoding) # ISO-8859-1\nprint(r.text) # \u003C!doctype html>\u003Chtml itemscope=\"\" ...\nprint(r.json()) # 這個會出現錯誤是因為請求的是一個 HTML 檔案，否則通常會像是官方文件所寫的 JSON 格式\n",[37,688,689,693,697,701,706,711,716,721],{"__ignoreMap":88},[92,690,691],{"cla