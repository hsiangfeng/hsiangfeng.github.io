47,48,43],"code",{"__ignoreMap":45},[16,50,51],{},"很好，相信你看到這邊你已經非常興奮的知道怎麼做了。",[16,53,54],{},[55,56,57],"del",{},"所以這一篇就到這邊結束",[16,59,60],{},"前面開玩笑的，怎麼可能就這樣結束呢？所以一開始前面就先以平易近人的簡易 JavaScript BMI 計算來寫一遍，畢竟我們是從 JavaScript 角度學 Python 你說是吧？",[16,62,63],{},"(運作邏輯與程式碼這邊就不再著墨說明。)",[39,65,69],{"className":66,"code":67,"language":68,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F 身高 175 體重 68\n((68 \u002F ((175 ** 2) \u002F 100)) * 100).toFixed(2); \u002F\u002F 22.20\n\u002F\u002F 身高 178 體重 75\n((75 \u002F ((178 ** 2) \u002F 100)) * 100).toFixed(2); \u002F\u002F 23.67\n\u002F\u002F 身高 161 體重 45\n((45 \u002F ((161 ** 2) \u002F 100)) * 100).toFixed(2); \u002F\u002F 17.36\n","js",[47,70,71,80,143,149,193,199],{"__ignoreMap":45},[72,73,76],"span",{"class":74,"line":75},"line",1,[72,77,79],{"class":78},"sQrFR","\u002F\u002F 身高 175 體重 68\n",[72,81,83,87,91,95,98,101,104,107,110,113,116,119,122,124,127,131,134,137,140],{"class":74,"line":82},2,[72,84,86],{"class":85},"sMAXC","((",[72,88,90],{"class":89},"sCcAr","68",[72,92,94],{"class":93},"sWyjQ"," \u002F",[72,96,97],{"class":85}," ((",[72,99,100],{"class":89},"175",[72,102,103],{"class":93}," **",[72,105,106],{"class":89}," 2",[72,108,109],{"class":85},") ",[72,111,112],{"class":93},"\u002F",[72,114,115],{"class":89}," 100",[72,117,118],{"class":85},")) ",[72,120,121],{"class":93},"*",[72,123,115],{"class":89},[72,125,126],{"class":85},").",[72,128,130],{"class":129},"sj_SG","toFixed",[72,132,133],{"class":85},"(",[72,135,136],{"class":89},"2",[72,138,139],{"class":85},"); ",[72,141,142],{"class":78},"\u002F\u002F 22.20\n",[72,144,146],{"class":74,"line":145},3,[72,147,148],{"class":78},"\u002F\u002F 身高 178 體重 75\n",[72,150,152,154,157,159,161,164,166,168,170,172,174,176,178,180,182,184,186,188,190],{"class":74,"line":151},4,[72,153,86],{"class":85},[72,155,156],{"class":89},"75",[72,158,94],{"class":93},[72,160,97],{"class":85},[72,162,163],{"class":89},"178",[72,165,103],{"class":93},