02F 100) * 100, 2)) # 17.36\n",[16,502,503,504,506,507,509],{},"要注意 ",[47,505,479],{}," 函式若是沒有傳入 ",[47,508,472],{}," 參數的話，預設是會直接將小數點全部四捨五入：",[39,511,513],{"className":404,"code":512,"language":406,"meta":45,"style":45},"print(round(68 \u002F ((175 ** 2) \u002F 100) * 100)) # 22\nprint(round(75 \u002F ((178 ** 2) \u002F 100) * 100)) # 24\nprint(round(45 \u002F ((161 ** 2) \u002F 100) * 100)) # 17\n",[47,514,515,520,525],{"__ignoreMap":45},[72,516,517],{"class":74,"line":75},[72,518,519],{},"print(round(68 \u002F ((175 ** 2) \u002F 100) * 100)) # 22\n",[72,521,522],{"class":74,"line":82},[72,523,524],{},"print(round(75 \u002F ((178 ** 2) \u002F 100) * 100)) # 24\n",[72,526,527],{"class":74,"line":145},[72,528,529],{},"print(round(45 \u002F ((161 ** 2) \u002F 100) * 100)) # 17\n",[16,531,532,533,535,536,538],{},"那麼透過上面程式碼我們也可以得知基本上也是除了 ",[247,534,253],{},"、",[247,537,249],{}," 之外都不會有任何變動，所以搭配函式之後我們可以這樣寫：",[39,540,542],{"className":404,"code":541,"language":406,"meta":45,"style":45},"def bmi (kg, cm):\n  print('BMI 計算結果：', round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2))\n\nbmi(68, 175) # BMI 計算結果：22.2\nbmi(75, 178) # BMI 計算結果：23.67\nbmi(45, 161) # BMI 計算結果：17.36\n",[47,543,544,549,554,558,563,568],{"__ignoreMap":45},[72,545,546],{"class":74,"line":75},[72,547,548],{},"def bmi (kg, cm):\n",[72,550,551],{"class":74,"line":82},[72,552,553],{},"  print('BMI 計算結果：', round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2))\n",[72,555,556],{"class":74,"line":145},[72,557,344],{"emptyLinePlaceholder":343},[72,559,560],{"class":74,"line":151},[72,561,562],{},"bmi(68, 175) # BMI 計算結果：22.2\n",[72,564,565],{"class":74,"line":195},[72,566,567],{},"bmi(75, 178) # BMI 計算結果：23.67\n",[72,569,570],{"class":74,"line":201},[72,571,572],{},"bmi(45, 161) # BMI 計算結果：17.36\n",[16,574,575,576,579],{},"除此之外你也可以試著挑戰使用前面所學的 ",[47,577,578],{},"lambda"," 改寫程式碼，讓整體程式碼更短更簡潔：",[39,581,583],{"className":404,"code":582,"language":406,"meta":45,"style":45},"bmi = lambda kg, cm: print('BMI 計算結果：', round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2))\nbmi(68, 175) # BMI 計算結果：22.2\nbmi(75, 178) # BMI 計算結果：23.67\nbmi(45, 161) # BMI 計算結果：17.36\n",[47,584,585,590,594,598],{"__ignoreMap":45},[72,586,587],{"class":74,"line":75},[72,588,589],{},"bmi = lambda kg, cm: print('BMI 計算結果：', round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2))\n",[72,591,592],{"class":74,"line":82},[72,593,562],{},[72,595,596],{"class":74,"line":145},[72,597,567],{},[72,599,600],{"class":74,"line":151},[72,601,572],{},[16,603,604,605,607,608,610],{},"嘗試使用 ",[47,606,578],{}," 之後有沒有很想把全部程式碼改用 ",[47,609,578],{}," 呢？",[16,612,613],{},[28,614],{"alt":578,"src":615},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631106655368.png",[16,617,618,619,626],{},"當然如果你不想使用 BMI 計算當作練習的話也可以考慮使用別的，例如：匯率、單位計算等等，假設你很沒有想法的話，我個人推薦 ",[620,621,625],"a",{"href":622,"rel":623},"https:\u002F\u002Fcalculator.0123456789.tw\u002F",[624],"nofollow","這個網站"," 的計算機，任何一個你都可以去撈出來試著研究製作練習看看。",[12,628,629],{"id":629},"字串組合",[16,631,632],{},"這邊也額外聊一下關於字串相加的部分，為什麼會講到這個呢？主要原因是每個人製作作業呈現的方式不一定，而這邊可能會遇到一些小雷點，所以就順便聊一下關於字串組合的部分。",[16,634,635,636,250,639,642],{},"在前一篇我們已經遇到一個雷點是關於 ",[247,637,638],{},"整數",[247,640,641],{},"字串"," 相加的雷點，那麼在早期我們在寫 JavaScript 中主要都是使用加號運算子達到字串相加的需求，而這又稱之為字串連結 or 字串相加：",[39,644,646],{"className":66,"code":645,"language":68,"meta":45,"style":45},"console.log('第'+ day +'天');\n",[47,647,648],{"__ignoreMap":45},[72,649,650,653,655,657,660,663,666,668,671],{"class":74,"line":75},[72,651,652],{"class":85},"console.",[72,654,291],{"class":129},[72,656,133],{"class":85},[72,658,659],{"class":296},"'第'",[72,661,662],{"class":93},"+",[72,664,665],{"class":85}," day ",[72,667,662],{"class":93},[72,669,670],{"class":296},"'天'",[72,672,673],{"class":85},");\n",[16,675,676],{},"而在 ES6 之後出了一個非常非常方便的語法叫做樣板字面值 (Template literals) 的新語法，在開發上組合字串時是非常方便的，尤其是組合 DOM 的時候：",[39,678,680],{"className":66,"code":679,"language":68,"meta":45,"style":45},"console.log(`第${day}天`);\n",[47,681,682],{"__ignoreMap":45},[72,683,684,686,688,690,693,696,699],{"class":74,"line":75},[72,685,652],{"class":85},[72,687,291],{"class":129},[72,689,133],{"class":85},[72,691,692],{"class":296},"`第${",[72,694,695],{"class":85},"day",[72,697,698],{"class":296},"}天`",[72,700,673],{"class":85},[16,702,703,704,707],{},"那麼 Python 呢？前面我們已經嘗試過所謂的字串連結，如果傳入的不是相同型別，例如：整數 (",[47,705,706],{},"int",") 那麼就必須做型別轉換：",[39,709,711],{"className":404,"code":710,"language":406,"meta":45,"style":45},"day = 1\nprint('第'+ str(day) +'天')\n",[47,712,713,718],{"__ignoreMap":45},[72,714,715],{"class":74,"line":75},[72,716,717],{},"day = 1\n",[72,719,720],{"class":74,"line":82},[72,721,722],{},"print('第'+ str(day) +'天')\n",[16,724,725,726,535,729,250,732,734,735,738],{},"而這種字串相加的方式其實非常麻煩，你必須一直輸入 ",[47,727,728],{},"'",[47,730,731],{},"\"",[47,733,662],{}," 等符號，那...Python 也有跟 JavaScript 一樣類似的樣板字面值 (Template literals) 語法嗎？嚴格說起來是有的，只是在 Python 中稱之為「 ",[247,736,737],{},"字串格式化(String formatting)"," 」：",[39,740,742],{"className":404,"code":741,"language":406,"meta":45,"style":45},"day = 1\nprint(f'第{day}天')\n",[47,743,744,748],{"__ignoreMap":45},[72,745,746],{"class":74,"line":75},[72,747,717],{},[72,749,750],{"class":74,"line":82},[72,751,752],{},"print(f'第{day}天')\n",[16,754,755,756,759],{},"不知道你有沒有注意到一件事情，上面的字串格式化範例我並沒有使用 ",[47,757,758],{},"str()"," 做型別轉換，但是上面範例確實是不會出現錯誤的，因為字串格式化會自己幫你傳入的任何東西都轉換為 String 型別。",[16,761,762],{},"你有沒有感覺到字串格式化方便方便超多！",[16,764,765],{},[28,766],{"alt":737,"src":767},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630829514249.png",[16,769,770,771,774,775,778,779,782],{},"主要使用的方式是在字串最前方加上一個小寫 ",[47,772,773],{},"f"," or 大寫 ",[47,776,777],{},"F","，接著使用 ",[47,780,781],{},"{}"," 插入要組合的表達式(expression)，例如像是變數也可以：",[39,784,785],{"className":404,"code":741,"language":406,"meta":45,"style":45},[47,786,787,791],{"__ignoreMap":45},[72,788,789],{"class":74,"line":75},[72,790,717],{},[72,792,793],{"class":74,"line":82},[72,794,752],{},[16,796,797,798,800,801,803],{},"剛剛也有提到 ",[47,799,781],{}," 內只接受表達式，所以 ",[47,802,578],{}," 也是可以的，只是要記得用類似 IIFE 寫法：",[39,805,807],{"className":404,"code":806,"language":406,"meta":45,"style":45},"print(f'我叫做{ (lambda name: name)(\"Ray\") }，你好')\n",[47,808,809],{"__ignoreMap":45},[72,810,811],{"class":74,"line":75},[72,812,806],{},[16,814,815],{},"所以上一篇函式的程式碼我們可以改成這樣：",[39,817,819],{"className":404,"code":818,"language":406,"meta":45,"style":45},"def fn(day):\n  print(f'第{day}天')\n  print('起床')\n  print('刷牙')\n  print('運動')\n  print('中午吃飯')\n  print('午睡')\n  print('下午運動')\n  print('晚上吃飯')\n  print('晚上洗澡')\n  print('睡覺')\n  print('---------')\n\nfn(1)\n",[47,820,821,826,831,836,841,846,851,856,862,868,874,880,886,891],{"__ignoreMap":45},[72,822,823],{"class":74,"line":75},[72,824,825],{},"def fn(day):\n",[72,827,828],{"class":74,"line":82},[72,829,830],{},"  print(f'第{day}天')\n",[72,832,833],{"class":74,"line":145},[72,834,835],{},"  print('起床')\n",[72,837,838],{"class":74,"line":151},[72,839,840],{},"  print('刷牙')\n",[72,842,843],{"class":74,"line":195},[72,844,845],{},"  print('運動')\n",[72,847,848],{"class":74,"line":201},[72,849,850],{},"  print('中午吃飯')\n",[72,852,853],{"class":74,"line":381},[72,854,855],{},"  print('午睡')\n",[72,857,859],{"class":74,"line":858},8,[72,860,861],{},"  print('下午運動')\n",[72,863,865],{"class":74,"line":864},9,[72,866,867],{},"  print('晚上吃飯')\n",[72,869,871],{"class":74,"line":870},10,[72,872,873],{},"  print('晚上洗澡')\n",[72,875,877],{"class":74,"line":876},11,[72,878,879],{},"  print('睡覺')\n",[72,881,883],{"class":74,"line":882},12,[72,884,885],{},"  print('---------')\n",[72,887,889],{"class":74,"line":888},13,[72,890,344],{"emptyLinePlaceholder":343},[72,892,894],{"class":74,"line":893},14,[72,895,896],{},"fn(1)\n",[16,898,899],{},"相較之下使用字串格式化會比使用字串連結較簡潔好寫而且也不用，最後也附上 JavaScript 與 Python 兩者都改成相同的 BMI 計算語法比較：",[16,901,902],{},[28,903],{"alt":904,"src":905},"BMI 計算","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-20%2013.08.59.png",[16,907,908],{},"最後就讓我們使用迷因結束今天的回合吧：",[16,910,911],{},[28,912],{"alt":913,"src":914},"Python 讚","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1624166036317.png",[12,916,918],{"id":917},"優化-bmi-計算","優化 BMI 計算",[16,920,921],{},"最後的最後，算是簡單優化一下 BMI 計算功能而已，延續上方的 BMI 練習題目，我們可以試著在 BMI 中增加判斷式，例如：",[459,923,924,927],{},[462,925,926],{},"傳入的參數不可以小於 0，當若小於任一參數小於 0 的時候，就要中斷程式碼並輸出訊息",[462,928,929],{},"可以判斷體重過輕、正常與過重，並輸出訊息",[39,931,933],{"className":404,"code":932,"language":406,"meta":45,"style":45},"def bmi (kg, cm):\n  if kg \u003C= 0:\n    return print('體重輸入不正確')\n  if cm \u003C= 0:\n    return print('身高輸入不正確')\n\n  bmiNum = round((kg \u002F ((cm ** 2) \u002F 100)) * 100, 2)\n\n  if bmiNum \u003C 18.5:\n    print(f'你目前的 BMI 是：{bmiNum}，介於過輕範圍內。')\n  elif 18.5 >= bmiNum \u003C 24:\n    print(f'你目前的 BMI 是：{bmiNum}，介於正常範圍內。')\n  elif 24 >= bmiNum \u003C 27:\n    print(f'你目前的 BMI 是：{bmiNum}，介於過重範圍內。')\n  elif 27 >= bmiNum \u003C 30:\n    print(f'你目前的 BMI 是：{bmiNum}，介於輕度範圍內。')\n  elif 30 >= bmiNum \u003C 35:\n    print(f'你目前的 BMI 是：{bmiNum}，介於中度範圍內。')\n  elif bmiNum >= 35:\n    print(f'你目前的 BMI 是：{bmiNum}，介於中度範圍內。')\n  else:\n    print('計算錯誤。')\n\nbmi(68, 175) # 你目前的 BMI 是： 22.2 介於過重範圍內。\nbmi(95, 185) # 你目前的 BMI 是： 27.76 介於中度範圍內。\n",[47,934,935,939,944,949,954,959,963,968,972,977,982,987,992,997,1002,1008,1014,1020,1026,1032,1037,1043,1049,1054,1060],{"__ignoreMap":45},[72,936,937],{"class":74,"line":75},[72,938,548],{},[72,940,941],{"class":74,"line":82},[72,942,943],{},"  if kg \u003C= 0:\n",[72,945,946],{"class":74,"line":145},[72,947,948],{},"    return print('體重輸入不正確')\n",[72,950,951],{"class":74,"line":151},[72,952,953],{},"  if cm \u003C= 0:\n",[72,955,956],{"class":74,"line":195},[72,957,958],{},"  