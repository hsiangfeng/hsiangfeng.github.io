8,"meta":56,"style":56},"f = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(read)\n",[58,764,765,770,775,779],{"__ignoreMap":56},[61,766,767],{"class":63,"line":64},[61,768,769],{},"f = open('example.json', 'r')\n",[61,771,772],{"class":63,"line":71},[61,773,774],{},"read = f.read()\n",[61,776,777],{"class":63,"line":88},[61,778,361],{},[61,780,781],{"class":63,"line":97},[61,782,783],{},"print(read)\n",[16,785,786,787,790],{},"但是如果你要拿 JSON 格式的資料做一些處理的話，就必須使用 JSON 模組來轉換成 Python 可以讀的型別，否則 ",[58,788,789],{},"f.read()"," 出來的檔案型別會是一個 str(字串)：",[52,792,794],{"className":186,"code":793,"language":188,"meta":56,"style":56},"f = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(type(read)) # str\n",[58,795,796,800,804,808],{"__ignoreMap":56},[61,797,798],{"class":63,"line":64},[61,799,769],{},[61,801,802],{"class":63,"line":71},[61,803,774],{},[61,805,806],{"class":63,"line":88},[61,807,361],{},[61,809,810],{"class":63,"line":97},[61,811,812],{},"print(type(read)) # str\n",[16,814,815],{},"那你可能會想說這樣會有什麼問題嗎？通常我們將 JSON 讀取後，可能會需要使用它某個欄位的屬性，那麼如果不透過 JSON 模組處理的話，你是無法取得特定屬性的，畢竟一整個都是一個 str 型別：",[52,817,819],{"className":186,"code":818,"language":188,"meta":56,"style":56},"f = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(type(read))\nprint(read['name']) # TypeError: string indices must be integers\n",[58,820,821,825,829,833,838],{"__ignoreMap":56},[61,822,823],{"class":63,"line":64},[61,824,769],{},[61,826,827],{"class":63,"line":71},[61,828,774],{},[61,830,831],{"class":63,"line":88},[61,832,361],{},[61,834,835],{"class":63,"line":97},[61,836,837],{},"print(type(read))\n",[61,839,840],{"class":63,"line":103},[61,841,842],{},"print(read['name']) # TypeError: string indices must be integers\n",[16,844,845],{},"因此當你取得 JSON 格式後，請記得使用 JSON 模組轉換成 Python 可以讀懂的型別：",[52,847,849],{"className":186,"code":848,"language":188,"meta":56,"style":56},"import json\n\nf = open('example.json', 'r')\nread = f.read()\nf.close()\nprint(type(read))\ndata = json.loads(read)\nprint(data['name']) # Ray\n",[58,850,851,855,859,863,867,871,875,880],{"__ignoreMap":56},[61,852,853],{"class":63,"line":64},[61,854,640],{},[61,856,857],{"class":63,"line":71},[61,858,275],{"emptyLinePlaceholder":274},[61,860,861],{"class":63,"line":88},[61,862,769],{},[61,864,865],{"class":63,"line":97},[61,866,774],{},[61,868,869],{"class":63,"line":103},[61,870,361],{},[61,872,873],{"class":63,"line":117},[61,874,837],{},[61,876,877],{"class":63,"line":128},[61,878,879],{},"data = json.loads(read)\n",[61,881,882],{"class":63,"line":134},[61,883,884],{},"print(data['name']) # Ray\n",[16,886,887],{},"所以其實可以發現 JSON 格式的資料，不管是在 JavaScript 還是 Python 中都是必須額外處理的唷。",[12,889,890],{"id":890},"作者的話",[16,892,893],{},"因為家裡的人說喜歡我做的花雕醉雞...所以又跑去買了新的酒回來，但是這次打算嘗試製作紹興醉雞試試看，或許味道也不錯？！",[12,895,896],{"id":896},"關於兔兔們",[898,899,900,909,917,925],"ul",{},[901,902,903],"li",{},[27,904,908],{"href":905,"rel":906},"https:\u002F\u002Ftailwindcss.tw",[907],"nofollow","Tailwind CSS 臺灣官網",[901,910,911,916],{},[27,912,915],{"href":913,"rel":914},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[907],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[901,918,919,924],{},[27,920,923],{"href":921,"rel":922},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[907],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[901,926,927],{},[27,928,931],{"href":929,"rel":930},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[907],"兔兔教大本營",[16,933,934],{},[38,935],{"alt":936,"src":937},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[939,940,941],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);backgrou