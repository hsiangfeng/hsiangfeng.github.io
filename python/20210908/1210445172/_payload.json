');\n}\n","js","",[26,60,61,84,91,99,119,131,145],{"__ignoreMap":58},[62,63,66,70,74,77,81],"span",{"class":64,"line":65},"line",1,[62,67,69],{"class":68},"sWyjQ","var",[62,71,73],{"class":72},"sMAXC"," now ",[62,75,76],{"class":68},"=",[62,78,80],{"class":79},"sCcAr"," true",[62,82,83],{"class":72},";\n",[62,85,87],{"class":64,"line":86},2,[62,88,90],{"emptyLinePlaceholder":89},true,"\n",[62,92,94,96],{"class":64,"line":93},3,[62,95,35],{"class":68},[62,97,98],{"class":72},"(now) {\n",[62,100,102,105,109,112,116],{"class":64,"line":101},4,[62,103,104],{"class":72},"  console.",[62,106,108],{"class":107},"sj_SG","log",[62,110,111],{"class":72},"(",[62,113,115],{"class":114},"sTRMh","'天氣好棒！'",[62,117,118],{"class":72},");\n",[62,120,122,125,128],{"class":64,"line":121},5,[62,123,124],{"class":72},"} ",[62,126,127],{"class":68},"else",[62,129,130],{"class":72}," {\n",[62,132,134,136,138,140,143],{"class":64,"line":133},6,[62,135,104],{"class":72},[62,137,108],{"class":107},[62,139,111],{"class":72},[62,141,142],{"class":114},"'天氣好差！'",[62,144,118],{"class":72},[62,146,148],{"class":64,"line":147},7,[62,149,150],{"class":72},"}\n",[16,152,153,154,156,157,159],{},"上面是一個非常簡單的 JavaScript ",[26,155,39],{}," 條件式判斷，若希望條件多一點的話，則是使用 ",[26,158,43],{},"：",[53,161,163],{"className":55,"code":162,"language":57,"meta":58,"style":58},"var myName = 'Ray';\n\nif(myName === 'QQ') {\n  console.log('哈囉 QQ');\n} else if (myName === 'Ray') {\n  console.log('哈囉 Ray');\n} else if(myName === 'Hello') {\n  console.log('哈囉');\n} else {\n  console.log('都不熟');\n}\n",[26,164,165,179,183,199,212,230,243,260,274,283,297],{"__ignoreMap":58},[62,166,167,169,172,174,177],{"class":64,"line":65},[62,168,69],{"class":68},[62,170,171],{"class":72}," myName ",[62,173,76],{"class":68},[62,175,176],{"class":114}," 'Ray'",[62,178,83],{"class":72},[62,180,181],{"class":64,"line":86},[62,182,90],{"emptyLinePlaceholder":89},[62,184,185,187,190,193,196],{"class":64,"line":93},[62,186,35],{"class":68},[62,188,189],