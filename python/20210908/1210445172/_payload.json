':\n    print('哈囉 Ray')\n",[26,428,429,433,437,442,447,452,457],{"__ignoreMap":58},[62,430,431],{"class":64,"line":65},[62,432,367],{},[62,434,435],{"class":64,"line":86},[62,436,90],{"emptyLinePlaceholder":89},[62,438,439],{"class":64,"line":93},[62,440,441],{},"match myName:\n",[62,443,444],{"class":64,"line":101},[62,445,446],{},"  case 'QQ':\n",[62,448,449],{"class":64,"line":121},[62,450,451],{},"    print('哈囉 QQ')\n",[62,453,454],{"class":64,"line":133},[62,455,456],{},"  case 'Ray':\n",[62,458,459],{"class":64,"line":147},[62,460,461],{},"    print('哈囉 Ray')\n",[16,463,464,465,472],{},"剩下對於 match 有興趣的話，可以閱讀 ",[466,467,471],"a",{"href":468,"rel":469},"https:\u002F\u002Fdocs.python.org\u002Fzh-tw\u002F3.10\u002Ftutorial\u002Fcontrolflow.html#match-statements",[470],"nofollow","官方"," 文件。",[16,474,475,476,478,479,482,483,485],{},"對了，Python 的 ",[26,477,39],{}," 在做條件判斷時，並不需要使用 ",[26,480,481],{},"()"," 包覆，但是如果你使用 ",[26,484,481],{}," 也是可以：",[53,487,489],{"className":310,"code":488,"language":312,"meta":58,"style":58},"now = True\nif (now):\n  print('天氣好棒！')\nelse:\n  print('天氣好差！')\n",[26,490,491,495,500,504,508],{"__ignoreMap":58},[62,492,493],{"class":64,"line":65},[62,494,319],{},[62,496,497],{"class":64,"line":86},[62,498,499],{},"if (now):\n",[62,501,502],{"class":64,"line":93},[62,503,329],{},[62,505,506],{"class":64,"line":101},[62,507,334],{},[62,509,510],{"class":64,"line":121},[62,511,339],{},[16,513,514,515,517,518,520,521,524,525,159],{},"那麼為什麼不會出錯呢？最主要是 ",[26,516,35],{}," 的條件只接受表達式，剛好 ",[26,519,481],{}," 會優先執行後回傳裡面的內容，因此才不會出現錯誤，並不是代表著兩種寫法都可以這一點可以稍微注意一下，你不信？你可以試著輸入以下程式碼，看它會出現 ",[26,522,523],{},"(1)"," 還是 ",[26,526,527],{},"1",[53,529,531],{"className":310,"code":530,"language":312,"meta":58,"style":58},"print((1))\n",[26,532,533],{"__ignoreMap":58},[62,534,535],{"class":64,"line":65},[62,536,530],{},[16,538,539],{},"你嘗試了嗎？我覺得應該沒有。",[16,541,542],{},[543,544],"img",{"alt":545,"src":546},"我早就知道了","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002F