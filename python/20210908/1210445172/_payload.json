Name":310,"code":1114,"language":312,"meta":58,"style":58},"i = 0\nstatus = True\n\nwhile status:\n  i += 1\n  print('Hello Ray' + str(i))\n  if i >= 0:\n    status = False\n",[26,1116,1117,1121,1126,1130,1135,1139,1143,1148],{"__ignoreMap":58},[62,1118,1119],{"class":64,"line":65},[62,1120,1086],{},[62,1122,1123],{"class":64,"line":86},[62,1124,1125],{},"status = True\n",[62,1127,1128],{"class":64,"line":93},[62,1129,90],{"emptyLinePlaceholder":89},[62,1131,1132],{"class":64,"line":101},[62,1133,1134],{},"while status:\n",[62,1136,1137],{"class":64,"line":121},[62,1138,1096],{},[62,1140,1141],{"class":64,"line":133},[62,1142,1101],{},[62,1144,1145],{"class":64,"line":147},[62,1146,1147],{},"  if i >= 0:\n",[62,1149,1150],{"class":64,"line":262},[62,1151,1152],{},"    status = False\n",[16,1154,1155,1156,1158],{},"透過上述寫法我們就可以很簡單的達到與原本 ",[26,1157,867],{}," 類似的寫法，也就是不管條件語法必定會執行一次這件事情。",[16,1160,1161],{},"但是請務必要小心下面這種沒有結束條件的寫法，是很容易出現死迴圈的：",[53,1163,1165],{"className":310,"code":1164,"language":312,"meta":58,"style":58},"i = 0\nwhile True:\n  print(i)\n  i += 1\n",[26,1166,1167,1171,1176,1180],{"__ignoreMap":58},[62,1168,1169],{"class":64,"line":65},[62,1170,1086],{},[62,1172,1173],{"class":64,"line":86},[62,1174,1175],{},"while True:\n",[62,1177,1178],{"class":64,"line":93},[62,1179,692],{},[62,1181,1182],{"class":64,"line":101},[62,1183,1096],{},[16,1185,1186],{},"這種寫法上要格外小心，在此建議不要當 7474 團（去死去死團）拿自己電腦冒險 QQ",[12,1188,1190],{"id":1189},"九九乘法表-python-答案","九九乘法表 Python 答案",[16,1192,1193],{},"基本上就是用兩個迴圈就可以做到了：",[53,1195,1197],{"className":310,"code":1196,"language":312,"meta":58,"style":58},"for i in range(2, 10):\n  for j in range(2, 10):\n    print(str(i) + 'x' + str(j) + '=' + str(i*j))\n",[26,1198,1199,1204,1209],{"__ignoreMap":58},[62,1200,1201],{"class":64,"line":65},[62,1202,1203],{},"for i in range(2, 10):\n",[62,1205,1206],{"class":64,"line":86},[62,1207,1208],{},"  for j in range(2, 10):\n",[62,1210,1211],{"class":64,"line":93},[62,1212,1213],{},"    print(str(i) + 'x' + str(j) + '=' + str(i*j))\n",[16,1215,1216],{},"而上方寫法又稱之為「Nested For Loop」，也就是巢狀迴圈，通常在初學時滿容易混亂的。",[16,1218,1219],{},"這邊也簡單描述一下運作邏輯，第一層的 for loop 在執行時，第二層 for loop 會跑九次(0~9)，第二層 for loop 跑完之後記憶體會被釋放掉，然後再跑第一層 for loop，以此類推。",[12,1221,1222],{"id":1222},"作者的話",[16,1224,1225],{},"稍微嘗試了一下將雞肉捲起來做花雕醉雞，身邊親人與朋友吃完之後都說不輸給外面賣的，看來我替自己的未來找到第二片春天了...",[12,1227,1228],{"id":1228},"參考文獻",[700,1230,1231],{},[703,1232,1233],{},[466,1234,422],{"href":468,"rel":1235},[470],[12,1237,1238],{"id":1238},"關於兔兔們",[700,1240,1241,1248,1256,1264],{},[703,1242,1243],{},[466,1244,1247],{"href":1245,"rel":1246},"https:\u002F\u002Ftailwindcss.tw",[470],"Tailwind CSS 臺灣官網",[703,1249,1250,1255],{},[466,1251,1254],{"href":1252,"rel":1253},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[470],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[703,1257,1258,1263],{},[466,1259,1262],{"href":1260,"rel":1261},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[470],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[703,1265,1266],{},[466,1267,1270],{"href":1268,"rel":1269},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[470],"兔兔教大本營",[16,1272,1273],{},[543,1274],{"alt":1275,"src":1276},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[1278,1279,1280],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);backgr