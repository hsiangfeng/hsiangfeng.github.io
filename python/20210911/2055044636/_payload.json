,308],{},"}\n",[54,310,311],{"class":56,"line":119},[54,312,153],{"emptyLinePlaceholder":152},[54,314,315],{"class":56,"line":137},[54,316,317],{},"print(dis.keys()) # dict_keys(['myName', 'a', 'b'])\n",[54,319,320],{"class":56,"line":143},[54,321,322],{},"print(dis.values()) # dict_values(['Ray', '1', '2'])\n",[16,324,325,326,29,329,332,333,335,336,338],{},"看到 ",[26,327,328],{},"dict_keys",[26,330,331],{},"dict_values","，不用太害怕，它只是告訴你這是字典的 ",[26,334,167],{}," 與 ",[26,337,260],{}," 而已。",[16,340,341,342,345],{},"但是這邊要注意，如果你直接使用 ",[26,343,344],{},"dis.keys()[0]"," 取值是會出現錯誤的：",[45,347,349],{"className":279,"code":348,"language":281,"meta":50,"style":50},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(dis.keys()[0]) # TypeError: 'dict_keys' object is not subscriptable\n",[26,350,351,355,359,363,367,371,375],{"__ignoreMap":50},[54,352,353],{"class":56,"line":57},[54,354,288],{},[54,356,357],{"class":56,"line":74},[54,358,293],{},[54,360,361],{"class":56,"line":87},[54,362,298],{},[54,364,365],{"class":56,"line":98},[54,366,303],{},[54,368,369],{"class":56,"line":109},[54,370,308],{},[54,372,373],{"class":56,"line":119},[54,374,153],{"emptyLinePlaceholder":152},[54,376,377],{"class":56,"line":137},[54,378,379],{},"print(dis.keys()[0]) # TypeError: 'dict_keys' object is not subscriptable\n",[16,381,382],{},"有沒有覺得自己好像被陰了一下？",[16,384,385],{},[386,387],"img",{"alt":388,"src":389},"我腦袋好混亂啊","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1629614745660.png",[16,391,392,393,29,395,397,398,401],{},"畢竟我們在 JavaScript 中使用 ",[26,394,28],{},[26,396,32],{}," 之後就可以直接執行一些陣列操作方法，但是在 Python 是必須額外處理的，因此你必須使用 ",[26,399,400],{},"list()"," 將它轉換成串列，這樣子才能夠正確的取值：",[45,403,405],{"className":279,"code":404,"language":281,"meta":50,"style":50},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(list(dis.keys())[0]) # myName\nprint(list(dis.values())[0]) # Ray\n",[26,406,407,4