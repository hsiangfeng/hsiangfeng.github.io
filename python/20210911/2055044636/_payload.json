[{"data":1,"prerenderedAt":1211},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210911\u002F2055044636\u002F":3,"page:\u002Fpython\u002F20210911\u002F2055044636\u002F":4,"alt:\u002Fpython\u002F20210911\u002F2055044636\u002F":3,"prev-next:\u002Fpython\u002F20210911\u002F2055044636\u002F":1187,"related:\u002Fpython\u002F20210911\u002F2055044636\u002F":1196},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F11\u002Fjs-to-python-10-container-types-part-2\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1170,"date":1171,"description":18,"extension":1172,"lang":1173,"meta":1174,"navigation":152,"path":1175,"readingMinutes":1176,"seo":1177,"standalone":1178,"stem":1179,"tags":1180,"tldr":1184,"updated":1184,"url":1185,"__hash__":1186},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-10-容器型別-下.md","從 JavaScript 角度學 Python(10) - 容器型別(下)","2055044636",{"type":9,"value":10,"toc":1160},"minimark",[11,15,19,22,38,44,175,181,266,269,277,323,339,346,380,383,390,402,441,455,518,529,532,535,605,611,622,637,640,659,662,682,691,725,731,779,783,789,804,807,842,845,879,882,920,927,931,946,991,1005,1039,1050,1056,1105,1108,1111,1114,1150,1156],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇我們聊了一些字典有趣的取值方式，所以接下來我想接著繼續聊關於字典的部分。",[12,20,21],{"id":21},"字典取值",[16,23,24,25,29,30,33,34,37],{},"在 JavaScript 中我們時常會使用到兩個很好用的 ES6 語法取出物件屬性名稱與物件屬性值，沒有錯，就是 ",[26,27,28],"code",{},"Object.keys()","、",[26,31,32],{},"Object.values()","，而這兩個語法都有異曲同工之處，底層實作會將物件中的屬性名稱與值使用 ",[26,35,36],{},"for...in"," 全部跑過一次並回傳其結果，而回傳的結果會是一個陣列。",[16,39,40,41,43],{},"以 ",[26,42,28],{}," 來講就是回傳物件的屬性：",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"language-js shiki shiki-themes github-dark-high-contrast","var obj = {\n  myName: 'Ray',\n  a: '1',\n  b: '2',\n  fn() {\n    console.log('123')\n  }\n};\n\nconsole.log(Object.keys(obj)); \u002F\u002F  [ \"myName\", \"a\", \"b\", \"fn\" ]\n","js","",[26,52,53,72,85,96,107,117,135,141,147,154],{"__ignore