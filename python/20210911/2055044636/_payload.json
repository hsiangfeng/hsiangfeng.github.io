\", \"2\" ] ]\n",[16,519,520,521,523,524,528],{},"但是在講 ",[26,522,446],{}," 方法之前，先讓我跳來講另一個前面沒有講到的東西東西也就是 ",[525,526,527],"strong",{},"元組(Tuple)","。",[12,530,527],{"id":531},"元組tuple",[16,533,534],{},"元組很特別，它是一個類似串列的容器，看到這邊可能有些寫過 TypeScript 的人會很興奮，畢竟 TypeScript 中也有一個叫做元組的型別：",[45,536,540],{"className":537,"code":538,"language":539,"meta":50,"style":50},"language-ts shiki shiki-themes github-dark-high-contrast","const a: [string, number];\na = ['Ray', 1];\nconsole.log(a[0]); \u002F\u002F Ray\n","ts",[26,541,542,569,587],{"__ignoreMap":50},[54,543,544,547,551,554,557,560,563,566],{"class":56,"line":57},[54,545,546],{"class":60},"const",[54,548,550],{"class":549},"sCcAr"," a",[54,552,553],{"class":60},":",[54,555,556],{"class":64}," [",[54,558,559],{"class":549},"string",[54,561,562],{"class":64},", ",[54,564,565],{"class":549},"number",[54,567,568],{"class":64},"];\n",[54,570,571,574,576,578,580,582,585],{"class":56,"line":74},[54,572,573],{"class":64},"a ",[54,575,68],{"class":60},[54,577,556],{"class":64},[54,579,81],{"class":80},[54,581,562],{"class":64},[54,583,584],{"class":549},"1",[54,586,568],{"class":64},[54,588,589,591,593,596,599,602],{"class":56,"line":87},[54,590,159],{"class":64},[54,592,125],{"class":112},[54,594,595],{"class":64},"(a[",[54,597,598],{"class":549},"0",[54,600,601],{"class":64},"]); ",[54,603,604],{"class":173},"\u002F\u002F Ray\n",[16,606,607],{},[386,608],{"alt":609,"src":610},"我好興奮啊","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1629614887290.png",[16,612,613,614,617,618,621],{},"但是在 Python 的元組宣告方式是使用括號 ",[26,615,616],{},"()"," 來宣告，除此之外它還有一個特性，元組是 ",[525,619,620],{},"read only"," (唯讀) 的，當你宣告了這個元組之後你就無法再更改它，但取值的方式與串列沒有差異：",[45,623,625],{"className":279,"code":624,"language":281,"meta":50,"style":50},"tpe = (1, 2, 3)\nprint(tpe[0]) # 1\n",[26,626,627,632],{"__ignoreMap":50},[54,628,629],{"class":56,"line":57},[54,630,631],{},"tpe = (1, 2, 3)\n",[54,633,634],{"class":56,"line":74},[54,635,636],{},"print(tpe[0]) # 1\n",[16,638,639],{},"只要你做出了修改值的行為就會出現錯誤：",[45,641,643],{"className":279,"code":642,"language":281,"meta":50,"style":50},"tpe = (1, 2, 3)\ntpe[0] = 10 # TypeError: 'tuple' object does not support item assignment\nprint(tpe[0])\n",[26,644,645,649,654],{"__ignoreMap":50},[54,646,647],{"class":56,"line":57},[54,648,631],{},[54,650,651],{"class":56,"line":74},[54,652,653],{},"tpe[0] = 10 # TypeError: 'tuple' object does not support item assignment\n",[54,655,656],{"class":56,"line":87},[54,657,658],{},"print(tpe[0])\n",[16,660,661],{},"所以如果你有需要修改的需求，那麼還是會建議你使用串列就好：",[45,663,665],{"className":279,"code":664,"language":281,"meta":50,"style":50},"tpe = [1, 2, 3]\ntpe[0] = 10\nprint(tpe) # [10, 2, 3]\n",[26,666,667,672,677],{"__ignoreMap":50},[54,668,669],{"class":56,"line":57},[54,670,671],{},"tpe = [1, 2, 3]\n",[54,673,674],{"class":56,"line":74},[54,675,676],{},"tpe[0] = 10\n",[54,678,679],{"class":56,"line":87},[54,680,681],{},"print(tpe) # [10, 2, 3]\n",[16,683,684,685,687,688,690],{},"回到 ",[26,686,446],{}," 的部分，為什麼要先講元組呢？因為使用 ",[26,689,446],{}," 取出來的字典會是一個元組：",[45,692,694],{"className":279,"code":693,"language":281,"meta":50,"style":50},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint(list(dis.items())) # [('myName', 'Ray'), ('a', '1'), ('b', '2')]\n",[26,695,696,700,704,708,712,716,720],{"__ignoreMap":50},[54,697,698],{"class":56,"line":57},[54,699,288],{},[54,701,702],{"class":56,"line":74},[54,703,293],{},[54,705,706],{"class":56,"line":87},[54,707,298],{},[54,709,710],{"class":56,"line":98},[54,711,303],{},[54,713,714],{"class":56,"line":109},[54,715,308],{},[54,717,718],{"class":56,"line":119},[54,719,153],{"emptyLinePlaceholder":152},[54,721,722],{"class":56,"line":137},[54,723,724],{},"print(list(dis.items())) # [('myName', 'Ray'), ('a', '1'), ('b', '2')]\n",[16,726,727,728,730],{},"這就是為什麼要先拉過來介紹元組了，因為使用 ",[26,729,446],{}," 取出來的串列都會是唯讀不可修改：",[45,732,734],{"className":279,"code":733,"language":281,"meta":50,"style":50},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\nprint(list(dis.items())) # [('myName', 'Ray'), ('a', '1'), ('b', '2')]\nprint(list(dis.items())[0]) # ('myName', 'Ray')\nprint(list(dis.items())[0][1]) # 'Ray'\n\nlist(dis.items())[0][1] = 'Ray2' # TypeError: 'tuple' object does not support item assignment\n",[26,735,736,740,744,748,752,756,760,765,770,774],{"__ignoreMap":50},[54,737,738],{"class":56,"line":57},[54,739,288],{},[54,741,742],{"class":56,"line":74},[54,743,293],{},[54,745,746],{"class":56,"line":87},[54,747,298],{},[54,749,750],{"class":56,"line":98},[54,751,303],{},[54,753,754],{"class":56,"line":109},[54,755,308],{},[54,757,758],{"class":56,"line":119},[54,759,724],{},[54,761,762],{"class":56,"line":137},[54,763,764],{},"print(list(dis.items())[0]) # ('myName', 'Ray')\n",[54,766,767],{"class":56,"line":143},[54,768,769],{},"print(list(dis.items())[0][1]) # 'Ray'\n",[54,771,772],{"class":56,"line":149},[54,773,153],{"emptyLinePlaceholder":152},[54,775,776],{"class":56,"line":156},[54,777,778],{},"list(dis.items())[0][1] = 'Ray2' # TypeError: 'tuple' object does not support item assignment\n",[780,781,782],"h3",{"id":782},"元組中的字典",[16,784,785,786,788],{},"雖然我們前面有說明到元祖本身是 ",[525,787,620],{}," (唯讀):",[45,790,792],{"className":279,"code":791,"language":281,"meta":50,"style":50},"tup = (1, 2, 3)\ntup[0] = 1 # TypeError: 'tuple' object does not support item assignment\n",[26,793,794,799],{"__ignoreMap":50},[54,795,796],{"class":56,"line":57},[54,797,798],{},"tup = (1, 2, 3)\n",[54,800,801],{"class":56,"line":74},[54,802,803],{},"tup[0] = 1 # TypeError: 'tuple' object does not support item assignment\n",[16,805,806],{},"可是如果今天修改的是元組內的字典屬性可以不可以呢？答案基本上是可以的：",[45,808,810],{"className":279,"code":809,"language":281,"meta":50,"style":50},"tup = ({\n  'myName1': 'Ray1'\n},{\n  'myName2': 'Ray2'\n})\ntup[0]['myName1'] = 'QQ'\n",[26,811,812,817,822,827,832,837],{"__ignoreMap":50},[54,813,814],{"class":56,"line":57},[54,815,816],{},"tup = ({\n",[54,818,819],{"class":56,"line":74},[54,820,821],{},"  'myName1': 'Ray1'\n",[54,823,824],{"class":56,"line":87},[54,825,826],{},"},{\n",[54,828,829],{"class":56,"line":98},[54,830,831],{},"  'myName2': 'Ray2'\n",[54,833,834],{"class":56,"line":109},[54,835,836],{},"})\n",[54,838,839],{"class":56,"line":119},[54,840,841],{},"tup[0]['myName1'] = 'QQ'\n",[16,843,844],{},"那麼這是為什麼？主要原因是我們是修改的字典中的屬性，並不是修改本身元組所指向的字典記憶點位置，因此就可以修改字典的值，甚至是新增另一個屬性也可以：",[45,846,848],{"className":279,"code":847,"language":281,"meta":50,"style":50},"tup = ({\n  'myName1': 'Ray1'\n},{\n  'myName2': 'Ray2'\n})\ntup[0]['myName1'] = 'QQ'\ntup[0]['blog'] = '是 Ray 不是 Array - Ray Blog'\n",[26,849,850,854,858,862,866,870,874],{"__ignoreMap":50},[54,851,852],{"class":56,"line":57},[54,853,816],{},[54,855,856],{"class":56,"line":74},[54,857,821],{},[54,859,860],{"class":56,"line":87},[54,861,826],{},[54,863,864],{"class":56,"line":98},[54,865,831],{},[54,867,868],{"class":56,"line":109},[54,869,836],{},[54,871,872],{"class":56,"line":119},[54,873,841],{},[54,875,876],{"class":56,"line":137},[54,877,878],{},"tup[0]['blog'] = '是 Ray 不是 Array - Ray Blog'\n",[16,880,881],{},"除非你今天是重新指向給它新的字典位置才會出現錯誤：",[45,883,885],{"className":279,"code":884,"language":281,"meta":50,"style":50},"tup = ({\n  'myName1': 'Ray1'\n},{\n  'myName2': 'Ray2'\n})\ntup[0]['myName1'] = 'QQ'\ntup[0]['blog'] = '是 Ray 不是 Array - Ray Blog'\ntup[0] = {} # TypeError: 'tuple' object does not support item assignment\n",[26,886,887,891,895,899,903,907,911,915],{"__ignoreMap":50},[54,888,889],{"class":56,"line":57},[54,890,816],{},[54,892,893],{"class":56,"line":74},[54,894,821],{},[54,896,897],{"class":56,"line":87},[54,898,826],{},[54,900,901],{"class":56,"line":98},[54,902,831],{},[54,904,905],{"class":56,"line":109},[54,906,836],{},[54,908,909],{"class":56,"line":119},[54,910,841],{},[54,912,913],{"class":56,"line":137},[54,914,878],{},[54,916,917],{"class":56,"line":143},[54,918,919],{},"tup[0] = {} # TypeError: 'tuple' object does not support item assignment\n",[16,921,922,923,926],{},"而這邊的概念就 JavaScript 中的 ",[26,924,925],{},"const obj = {};"," 的概念是非常雷同的唷。",[12,928,930],{"id":929},"in-運算子","in 運算子",[16,932,933,934,937,938,941,942,945],{},"最後額外補充聊一下 ",[26,935,936],{},"in"," 運算子，基本上這個運算子的概念就如同 JavaScript 的 ",[26,939,940],{},"Object.hasOwnProperty"," 方法，",[26,943,944],{},"hasOwnProperty"," 可以用於尋找該屬性是否存在於這個物件中：",[45,947,949],{"className":47,"code":948,"language":49,"meta":50,"style":50},"var obj = {\n  myName: 'Ray',\n}\nobj.hasOwnProperty('myName'); \u002F\u002F true\n",[26,950,951,961,969,973],{"__ignoreMap":50},[54,952,953,955,957,959],{"class":56,"line":57},[54,954,61],{"class":60},[54,956,65],{"class":64},[54,958,68],{"class":60},[54,960,71],{"class":64},[54,962,963,965,967],{"class":56,"line":74},[54,964,77],{"class":64},[54,966,81],{"class":80},[54,968,84],{"class":64},[54,970,971],{"class":56,"line":87},[54,972,308],{"class":64},[54,974,975,978,980,982,985,988],{"class":56,"line":98},[54,976,977],{"class":64},"obj.",[54,979,944],{"class":112},[54,981,128],{"class":64},[54,983,984],{"class":80},"'myName'",[54,986,987],{"class":64},"); ",[54,989,990],{"class":173},"\u002F\u002F true\n",[16,992,993,994,996,997,1000,1001,1004],{},"而 Python 中的 ",[26,995,936],{}," 運算子也是一樣的存在，如果存在就會回傳 ",[26,998,999],{},"True","，如果不存在就是 ",[26,1002,1003],{},"False","，但是這個運算子的寫法是屬性在前，字典在後：",[45,1006,1008],{"className":279,"code":1007,"language":281,"meta":50,"style":50},"dis = {\n  'myName': 'Ray',\n  'a': '1',\n  'b': '2',\n}\n\nprint('myName' in dis) # True\n",[26,1009,1010,1014,1018,1022,1026,1030,1034],{"__ignoreMap":50},[54,1011,1012],{"class":56,"line":57},[54,1013,288],{},[54,1015,1016],{"class":56,"line":74},[54,1017,293],{},[54,1019,1020],{"class":56,"line":87},[54,1021,298],{},[54,1023,1024],{"class":56,"line":98},[54,1025,303],{},[54,1027,1028],{"class":56,"line":109},[54,1029,308],{},[54,1031,1032],{"class":56,"line":119},[54,1033,153],{"emptyLinePlaceholder":152},[54,1035,1036],{"cla