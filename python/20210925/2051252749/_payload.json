：",[32,550,554],{"className":551,"code":552,"language":553,"meta":37,"style":37},"language-py shiki shiki-themes github-light github-light github-dark-high-contrast","class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n","py",[39,555,556,561,566],{"__ignoreMap":37},[42,557,558],{"class":44,"line":45},[42,559,560],{},"class Father:\n",[42,562,563],{"class":44,"line":67},[42,564,565],{},"  def __init__(self, pupil):\n",[42,567,568],{"class":44,"line":97},[42,569,570],{},"    self.pupil = pupil or '藍色'\n",[16,572,573],{},"好，那接下來繼承該如何寫呢？",[16,575,576],{},[536,577],{"alt":578,"src":579},"絕對是用 extends","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630050076486.png",[16,581,582,583,586],{},"不，絕對不是使用 ",[39,584,585],{},"extends"," 語法。",[16,588,589],{},[536,590],{"alt":591,"src":592},"哈哈哈哈哈","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630050170140.png",[16,594,595,596,598,599,601],{},"Python 的繼承語法非常簡潔，只需要在 ",[39,597,335],{}," 名稱後方加上括號並傳入要繼承的 ",[39,600,335],{}," 名稱就可以了：",[32,603,605],{"className":551,"code":604,"language":553,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  pass\n",[39,606,607,611,615,619,623,628],{"__ignoreMap":37},[42,608,609],{"class":44,"line":45},[42,610,560],{},[42,612,613],{"class":44,"line":67},[42,614,565],{},[42,616,617],{"class":44,"line":97},[42,618,570],{},[42,620,621],{"class":44,"line":103},[42,622,107],{"emptyLinePlaceholder":106},[42,624,625],{"class":44,"line":110},[42,626,627],{},"class Son(Father):\n",[42,629,630],{"class":44,"line":125},[42,631,632],{},"  pass\n",[16,634,635,636,639],{},"有沒有發現非常簡單呢？如果你不知道我寫 ",[39,637,638],{},"pass"," 的用途的話，建議你可以往前一篇看這邊就不解釋了。",[16,641,642,643,645],{},"那麼接下來讓我們直接補完 ",[39,644,171],{}," 的內容再繼續往下介紹：",[32,647,649],{"className":551,"code":648,"language":553,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  def __init__(self, name):\n    self.name = name\n\n  def eyeColor(self):\n    print(this.name + ' 眼睛顏色是：' + this.pupil)\n",[39,650,651,655,659,663,667,671,676,681,685,690],{"__ignoreMap":37},[42,652,653],{"class":44,"line":45},[42,654,560],{},[42,656,657],{"class":44,"line":67},[42,658,565],{},[42,660,661],{"class":44,"line":97},[42,662,570],{},[42,664,665],{"class":44,"line":103},[42,666,107],{"emptyLinePlaceholder":106},[42,668,669],{"class":44,"line":110},[42,670,627],{},[42,672,673],{"class":44,"line":125},[42,674,675],{},"  def __init__(self, name):\n",[42,677,678],{"class":44,"line":142},[42,679,680],{},"    self.name = name\n",[42,682,683],{"class":44,"line":158},[42,684,107],{"emptyLinePlaceholder":106},[42,686,687],{"class":44,"line":163},[42,688,689],{},"  def eyeColor(self):\n",[42,691,692],{"class":44,"line":168},[42,693,694],{},"    print(this.name + ' 眼睛顏色是：' + this.pupil)\n",[16,696,697,698,700,701,704,705,708,709,711,712,714,715,717],{},"這時候不用急著實例化 ",[39,699,171],{},"，基本上這一段是會出現一段錯誤訊息，也就是「",[39,702,703],{},"AttributeError: 'Son' object has no attribute 'pupil'","」的錯誤訊息，主要原因是因為當我們在子類別中使用 ",[39,706,707],{},"__init__"," 方法時，是會覆蓋原有父類別的繼承 ",[39,710,707],{},"，所以這邊我們必須重新將 ",[39,713,191],{}," 重新繼承回來，而重新繼承寫法其實有兩種，第一種就是是使用 ",[39,716,707],{},"：",[32,719,721],{"className":551,"code":720,"language":553,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  def __init__(self, name):\n    Father.__init__(self, '')\n    self.name = name\n\n  def eyeColor(self):\n    print(self.name + ' 眼睛顏色是：' + self.pupil)\n\nray = Son('Ray')\nray.eyeColor() # Ray 眼睛顏色是：藍色\n",[39,722,723,727,731,735,739,743,747,752,756,760,764,769,773,778],{"__ignoreMap":37},[42,724,725],{"class":44,"line":45},[42,726,560],{},[42,728,729],{"class":44,"line":67},[42,730,565],{},[42,732,733],{"class":44,"line":97},[42,734,570],{},[42,736,737],{"class":44,"line":103},[42,738,107],{"emptyLinePlaceholder":106},[42,740,741],{"class":44,"line":110},[42,742,627],{},[42,744,745],{"class":44,"line":125},[42,746,675],{},[42,748,749],{"class":44,"line":142},[42,750,751],{},"    Father.__init__(self, '')\n",[42,753,754],{"class":44,"line":158},[42,755,680],{},[42,757,758],{"class":44,"line":163},[42,759,107],{"emptyLinePlaceholder":106},[42,761,762],{"class":44,"line":168},[42,763,689],{},[42,765,766],{"class":44,"line":200},[42,767,768],{},"    print(self.name + ' 眼睛顏色是：' + self.pupil)\n",[42,770,771],{"class":44,"line":219},[42,772,107],{"emptyLinePlaceholder":106},[42,774,775],{"class":44,"line":224},[42,776,777],{},"ray = Son('Ray')\n",[42,779,780],{"class":44,"line":246},[42,781,782],{},"ray.eyeColor() # Ray 眼睛顏色是：藍色\n",[16,784,785],{},"這樣子上面這一段範例程式碼，就可正常的運作囉~",[16,787,788,789,792],{},"那另一種方式則是使用 ",[39,790,791],{},"super"," 的函式重新繼承：",[32,794,796],{"className":551,"code":795,"language":553,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  def __init__(self, name):\n    super().__init__('')\n    self.name = name\n\n  def eyeColor(self):\n    print(self.name + ' 眼睛顏色是：' + self.pupil)\n\nray = Son('Ray')\nray.eyeColor() # Ray 眼睛顏色是：藍色\n",[39,797,798,802,806,810,814,818,822,827,831,835,839,843,847,851],{"__ignoreMap":37},[42,799,800],{"class":44,"line":45},[42,801,560],{},[42,803,804],{"class":44,"line":67},[42,805,565],{},[42,807,808],{"class":44,"line":97},[42,809,570],{},[42,811,812],{"class":44,"line":103},[42,813,107],{"emptyLinePlaceholder":106},[42,815,816],{"class":44,"line":110},[42,817,627],{},[42,819,820],{"class":44,"line":125},[42,821,675],{},[42,823,824],{"class":44,"line":142},[42,825,826],{},"    super().__init__('')\n",[42,828,829],{"class":44,"line":158},[42,830,680],{},[42,832,833],{"class":44,"line":163},[42,834,107],{"emptyLinePlaceholder":106},[42,836,837],{"class":44,"line":168},[42,838,689],{},[42,840,841],{"class":44,"line":200},[42,842,768],{},[42,844,845],{"class":44,"line":219},[42,846,107],{"emptyLinePlaceholder":106},[42,848,849],{"class":44,"line":224},[42,850,777],{},[42,852,853],{"class":44,"line":246},[42,854,782],{},[16,856,857,858,860],{},"使用 ",[39,859,791],{}," 函式的好處在於，你不用去撰寫父類別的名稱，它會自動去尋找你所傳入的副類別名稱，然後自動重新繼承父類別的屬性與函式。",[16,862,863,864,866],{},"那你看到這邊之後有沒有覺得 Python 與 JavaScript 的 ",[39,865,335],{}," 是不是有相似之處呢？",[16,868,869],{},[536,870],{"alt":871,"src":872},"這是 JavaScript 嗎？","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1624117447047.png",[16,874,875,876,878],{},"那這一篇也算是到這邊結束了，主要是補完前一章節關於 ",[39,877,335],{}," 的部分。",[12,880,881],{"id":881},"作者的話",[16,883,884],{},"因為工作的關係，自己時常很忙比較少在打掃家中，所以很仰賴小瓦機器人掃跟拖地，但是最近在幫小瓦機器人清理集塵盒的時候...",[16,886,887],{},"不小心把集塵盒捏爆了...囧",[12,889,890],{"id":890},"關於兔兔們",[892,893,894,903,911,919],"ul",{},[895,896,897],"li",{},[325,898,902],{"href":899,"rel":900},"https:\u002F\u002Ftailwindcss.tw",[901],"nofollow","Tailwind CSS 臺灣官網",[895,904,905,910],{},[325,906,909],{"href":907,"rel":908},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[901],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[895,912,913,918],{},[325,914,917],{"href":915,"rel":916},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[901],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[895,920,921],{},[325,922,925],{"href":923,"rel":924},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[901],"兔兔教大本營",[16,927,928],{},[536,929],{"alt":930,"src":931},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[933,934,935],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shi