language":551,"meta":37,"style":37},"language-py shiki shiki-themes github-dark-high-contrast","class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n","py",[39,553,554,559,564],{"__ignoreMap":37},[42,555,556],{"class":44,"line":45},[42,557,558],{},"class Father:\n",[42,560,561],{"class":44,"line":67},[42,562,563],{},"  def __init__(self, pupil):\n",[42,565,566],{"class":44,"line":97},[42,567,568],{},"    self.pupil = pupil or '藍色'\n",[16,570,571],{},"好，那接下來繼承該如何寫呢？",[16,573,574],{},[534,575],{"alt":576,"src":577},"絕對是用 extends","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630050076486.png",[16,579,580,581,584],{},"不，絕對不是使用 ",[39,582,583],{},"extends"," 語法。",[16,586,587],{},[534,588],{"alt":589,"src":590},"哈哈哈哈哈","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1630050170140.png",[16,592,593,594,596,597,599],{},"Python 的繼承語法非常簡潔，只需要在 ",[39,595,335],{}," 名稱後方加上括號並傳入要繼承的 ",[39,598,335],{}," 名稱就可以了：",[32,601,603],{"className":549,"code":602,"language":551,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  pass\n",[39,604,605,609,613,617,621,626],{"__ignoreMap":37},[42,606,607],{"class":44,"line":45},[42,608,558],{},[42,610,611],{"class":44,"line":67},[42,612,563],{},[42,614,615],{"class":44,"line":97},[42,616,568],{},[42,618,619],{"class":44,"line":103},[42,620,107],{"emptyLinePlaceholder":106},[42,622,623],{"class":44,"line":110},[42,624,625],{},"class Son(Father):\n",[42,627,628],{"class":44,"line":125},[42,629,630],{},"  pass\n",[16,632,633,634,637],{},"有沒有發現非常簡單呢？如果你不知道我寫 ",[39,635,636],{},"pass"," 的用途的話，建議你可以往前一篇看這邊就不解釋了。",[16,639,640,641,643],{},"那麼接下來讓我們直接補完 ",[39,642,171],{}," 的內容再繼續往下介紹：",[32,645,647],{"className":549,"code":646,"language":551,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  def __init__(self, name):\n    self.name = name\n\n  def eyeColor(self):\n    print(this.name + ' 眼睛顏色是：' + this.pupil)\n",[39,648,649,653,657,661,665,669,674,679,683,688],{"__ignoreMap":37},[42,650,651],{"class":44,"line":45},[42,652,558],{},[42,654,655],{"class":44,"line":67},[42,656,563],{},[42,658,659],{"class":44,"line":97},[42,660,568],{},[42,662,663],{"class":44,"line":103},[42,664,107],{"emptyLinePlaceholder":106},[42,666,667],{"class":44,"line":110},[42,668,625],{},[42,670,671],{"class":44,"line":125},[42,672,673],{},"  def __init__(self, name):\n",[42,675,676],{"class":44,"line":142},[42,677,678],{},"    self.name = name\n",[42,680,681],{"class":44,"line":158},[42,682,107],{"emptyLinePlaceholder":106},[42,684,685],{"class":44,"line":163},[42,686,687],{},"  def eyeColor(self):\n",[42,689,690],{"class":44,"line":168},[42,691,692],{},"    print(this.name + ' 眼睛顏色是：' + this.pupil)\n",[16,694,695,696,698,699,702,703,706,707,709,710,712,713,715],{},"這時候不用急著實例化 ",[39,697,171],{},"，基本上這一段是會出現一段錯誤訊息，也就是「",[39,700,701],{},"AttributeError: 'Son' object has no attribute 'pupil'","」的錯誤訊息，主要原因是因為當我們在子類別中使用 ",[39,704,705],{},"__init__"," 方法時，是會覆蓋原有父類別的繼承 ",[39,708,705],{},"，所以這邊我們必須重新將 ",[39,711,191],{}," 重新繼承回來，而重新繼承寫法其實有兩種，第一種就是是使用 ",[39,714,705],{},"：",[32,717,719],{"className":549,"code":718,"language":551,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  def __init__(self, name):\n    Father.__init__(self, '')\n    self.name = name\n\n  def eyeColor(self):\n    print(self.name + ' 眼睛顏色是：' + self.pupil)\n\nray = Son('Ray')\nray.eyeColor() # Ray 眼睛顏色是：藍色\n",[39,720,721,725,729,733,737,741,745,750,754,758,762,767,771,776],{"__ignoreMap":37},[42,722,723],{"class":44,"line":45},[42,724,558],{},[42,726,727],{"class":44,"line":67},[42,728,563],{},[42,730,731],{"class":44,"line":97},[42,732,568],{},[42,734,735],{"class":44,"line":103},[42,736,107],{"emptyLinePlaceholder":106},[42,738,739],{"class":44,"line":110},[42,740,625],{},[42,742,743],{"class":44,"line":125},[42,744,673],{},[42,746,747],{"class":44,"line":142},[42,748,749],{},"    Father.__init__(self, '')\n",[42,751,752],{"class":44,"line":158},[42,753,678],{},[42,755,756],{"class":44,"line":163},[42,757,107],{"emptyLinePlaceholder":106},[42,759,760],{"class":44,"line":168},[42,761,687],{},[42,763,764],{"class":44,"line":200},[42,765,766],{},"    print(self.name + ' 眼睛顏色是：' + self.pupil)\n",[42,768,769],{"class":44,"line":219},[42,770,107],{"emptyLinePlaceholder":106},[42,772,773],{"class":44,"line":224},[42,774,775],{},"ray = Son('Ray')\n",[42,777,778],{"class":44,"line":246},[42,779,780],{},"ray.eyeColor() # Ray 眼睛顏色是：藍色\n",[16,782,783],{},"這樣子上面這一段範例程式碼，就可正常的運作囉~",[16,785,786,787,790],{},"那另一種方式則是使用 ",[39,788,789],{},"super"," 的函式重新繼承：",[32,792,794],{"className":549,"code":793,"language":551,"meta":37,"style":37},"class Father:\n  def __init__(self, pupil):\n    self.pupil = pupil or '藍色'\n\nclass Son(Father):\n  def __init__(self, name):\n    super().__init__('')\n    self.name = name\n\n  def eyeColor(self):\n    print(self.name + ' 眼睛顏色是：' + self.pupil)\n\nray = Son('Ray')\nray.eyeColor() # Ray 眼睛顏色是：藍色\n",[39,795,796,800,804,808,812,816,820,825,829,833,837,841,845,849],{"__ignoreMap":37},[42,797,798],{"class":44,"line":45},[42,799,558],{},[42,801,802],{"class":44,"line":67},[42,803,563],{},[42,805,806],{"class":44,"line":97},[42,807,568],{},[42,809,810],{"class":44,"line":103},[42,811,107],{"emptyLinePlaceholder":106},[42,813,814],{"class":44,"line":110},[42,815,625],{},[42,817,818],{"class":44,"line":125},[42,819,673],{},[42,821,822],{"class":44,"line":142},[42,823,824],{},"    super().__init__('')\n",[42,826,827],{"class":44,"line":158},[42,828,678],{},[42,830,831],{"class":44,"line":163},[42,832,107],{"emptyLinePlaceholder":106},[42,834,835],{"class":44,"line":168},[42,836,687],{},[42,838,839],{"class":44,"line":200},[42,840,766],{},[42,842,843],{"class":44,"line":219},[42,844,107],{"emptyLinePlaceholder":106},[42,846,847],{"class":44,"line":224},[42,848,775],{},[42,850,851],{"class":44,"line":246},[42,852,780],{},[16,854,855,856,858],{},"使用 ",[39,857,789],{}," 函式的好處在於，你不用去撰寫父類別的名稱，它會自動去尋找你所傳入的副類別名稱，然後自動重新繼承父類別的屬性與函式。",[16,860,861,862,864],{},"那你看到這邊之後有沒有覺得 Python 與 JavaScript 的 ",[39,863,335],{}," 是不是有相似之處呢？",[16,866,867],{},[534,868],{"alt":869,"src":870},"這是 JavaScript 嗎？","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1624117447047.png",[16,872,873,874,876],{},"那這一篇也算是到這邊結束了，主要是補完前一章節關於 ",[39,875,335],{}," 的部分。",[12,878,879],{"id":879},"作者的話",[16,881,882],{},"因為工作的關係，自己時常很忙比較少在打掃家中，所以很仰賴小瓦機器人掃跟拖地，但是最近在幫小瓦機器人清理集塵盒的時候...",[16,884,885],{},"不小心把集塵盒捏爆了...囧",[12,887,888],{"id":888},"關於兔兔們",[890,891,892,901,909,917],"ul",{},[893,894,895],"li",{},[325,896,900],{"href":897,"rel":898},"https:\u002F\u002Ftailwindcss.tw",[899],"nofollow","Tailwind CSS 臺灣官網",[893,902,903,908],{},[325,904,907],{"href":905,"rel":906},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[899],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[893,910,911,916],{},[325,912,915],{"href":913,"rel":914},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[899],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[893,918,919],{},[325,920,923],{"href":921,"rel":922},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[899],"兔兔教大本營",[16,925,926],{},[534,927],{"alt":928,"src":929},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[931,932,933],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default