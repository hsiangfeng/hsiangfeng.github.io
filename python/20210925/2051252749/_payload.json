[{"data":1,"prerenderedAt":982},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210925\u002F2051252749\u002F":3,"page:\u002Fpython\u002F20210925\u002F2051252749\u002F":4,"alt:\u002Fpython\u002F20210925\u002F2051252749\u002F":3,"prev-next:\u002Fpython\u002F20210925\u002F2051252749\u002F":958,"related:\u002Fpython\u002F20210925\u002F2051252749\u002F":967},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F25\u002Fpython-from-js-perspective-24-inheritance\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":941,"date":942,"description":18,"extension":943,"lang":944,"meta":945,"navigation":106,"path":946,"readingMinutes":947,"seo":948,"standalone":949,"stem":950,"tags":951,"tldr":955,"updated":955,"url":956,"__hash__":957},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-24-繼承.md","從 JavaScript 角度學 Python(24) - 繼承","2051252749",{"type":9,"value":10,"toc":934},"minimark",[11,15,19,22,25,28,31,321,330,337,511,531,538,541,544,547,569,572,578,585,591,600,631,638,644,693,716,781,784,791,853,859,865,871,877,880,883,886,889,924,930],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇已經提前預告接下來將會講繼承了，所以這一篇當然就是會介紹繼承啦~(廢話)",[12,20,21],{"id":21},"繼承的概念",[16,23,24],{},"繼承是什麼呢？JavaScript 有嗎？JavaScript 是有的哦。",[16,26,27],{},"那麼簡單來講繼承的概念，假設是用人的角度來形容的話，你可以把它想像成有一個爸爸，然後他會有一個兒子(廢話)，然後這個兒子會有爸爸的一些生物特徵，例如：可以爸爸眼睛瞳孔顏色是藍色的，所以兒子繼承下來的瞳孔顏色也就會是藍色的。",[16,29,30],{},"所以前面我們就簡單寫一個 JavaScript 的繼承版本稍微參考一下：",[32,33,38],"pre",{"className":34,"code":35,"language":36,"meta":37,"style":37},"language-js shiki shiki-themes github-dark-high-contrast","function Father(pupil) {\n  this.pupil = pupil || '藍色'; \u002F\u002F 瞳孔顏色\n}\n\nfunction Son(name) {\n  Father.call(this);\n  this.name = name; \u002F\u002F 兒子的名字\n}\n\nSon.prototype = Object.create(Father.prototype);\nSon.prototype.constructor = Son;\n\nSon.prototype.eyeColor = function() {\n  console.log(this.name + ' 眼睛顏色是：' + this.pupil);\n}\n\nconst ray = new Son('Ray');\nray.eyeColor(); \u002F\u002F Ray 眼睛顏色是：藍色\n","js",