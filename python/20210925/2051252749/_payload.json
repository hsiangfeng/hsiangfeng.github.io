[{"data":1,"prerenderedAt":984},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210925\u002F2051252749\u002F":3,"page:\u002Fpython\u002F20210925\u002F2051252749\u002F":4,"alt:\u002Fpython\u002F20210925\u002F2051252749\u002F":3,"prev-next:\u002Fpython\u002F20210925\u002F2051252749\u002F":960,"related:\u002Fpython\u002F20210925\u002F2051252749\u002F":969},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F25\u002Fpython-from-js-perspective-24-inheritance\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":943,"date":944,"description":18,"extension":945,"lang":946,"meta":947,"navigation":106,"path":948,"readingMinutes":949,"seo":950,"standalone":951,"stem":952,"tags":953,"tldr":957,"updated":957,"url":958,"__hash__":959},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-24-繼承.md","從 JavaScript 角度學 Python(24) - 繼承","2051252749",{"type":9,"value":10,"toc":936},"minimark",[11,15,19,22,25,28,31,321,330,337,513,533,540,543,546,549,571,574,580,587,593,602,633,640,646,695,718,783,786,793,855,861,867,873,879,882,885,888,891,926,932],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇已經提前預告接下來將會講繼承了，所以這一篇當然就是會介紹繼承啦~(廢話)",[12,20,21],{"id":21},"繼承的概念",[16,23,24],{},"繼承是什麼呢？JavaScript 有嗎？JavaScript 是有的哦。",[16,26,27],{},"那麼簡單來講繼承的概念，假設是用人的角度來形容的話，你可以把它想像成有一個爸爸，然後他會有一個兒子(廢話)，然後這個兒子會有爸爸的一些生物特徵，例如：可以爸爸眼睛瞳孔顏色是藍色的，所以兒子繼承下來的瞳孔顏色也就會是藍色的。",[16,29,30],{},"所以前面我們就簡單寫一個 JavaScript 的繼承版本稍微參考一下：",[32,33,38],"pre",{"className":34,"code":35,"language":36,"meta":37,"style":37},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","function Father(pupil) {\n  this.pupil = pupil || '藍色'; \u002F\u002F 瞳孔顏色\n}\n\nfunction Son(name) {\n  Father.call(this);\n  this.name = name; \u002F\u002F 兒子的名字\n}\n\nSon.prototype = Object.create(Father.prototype);\nSon.prototype.constructor = Son;\n\nSon.prototype.eyeColor = function() {\n  console.log(this.name + ' 眼睛顏色是：' + this.pupil);\n}\n\nconst ray = new Son('Ray');\nray.eyeColor(); \u002F\u002F Ray 眼睛顏色是：藍色\n","js","",[39,40,41,65,95,101,108,123,140,156,161,166,198,217,222,244,274,279,284,307],"code",{"__ignoreMap":37},[42,43,46,50,54,58,62],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sOudu","function",[42,51,53],{"class":52},"scAaK"," Father",[42,55,57],{"class":56},"s8XSl","(",[42,59,61],{"class":60},"syBk-","pupil",[42,63,64],{"class":56},") {\n",[42,66,68,72,75,78,81,84,88,91],{"class":44,"line":67},2,[42,69,71],{"class":70},"stw71","  this",[42,73,74],{"class":56},".pupil ",[42,76,77],{"class":48},"=",[42,79,80],{"class":56}," pupil ",[42,82,83],{"class":48},"||",[42,85,87],{"class":86},"sWayO"," '藍色'",[42,89,90],{"class":56},"; ",[42,92,94],{"class":93},"sGBqm","\u002F\u002F 瞳孔顏色\n",[42,96,98],{"class":44,"line":97},3,[42,99,100],{"class":56},"}\n",[42,102,104],{"class":44,"line":103},4,[42,105,107],{"emptyLinePlaceholder":106},true,"\n",[42,109,111,113,116,118,121],{"class":44,"line":110},5,[42,112,49],{"class":48},[42,114,115],{"class":52}," Son",[42,117,57],{"class":56},[42,119,120],{"class":60},"name",[42,122,64],{"class":56},[42,124,126,129,132,134,137],{"class":44,"line":125},6,[42,127,128],{"class":56},"  Father.",[42,130,131],{"class":52},"call",[42,133,57],{"class":56},[42,135,136],{"class":70},"this",[42,138,139],{"class":56},");\n",[42,141,143,145,148,150,153],{"class":44,"line":142},7,[42,144,71],{"class":70},[42,146,147],{"class":56},".name ",[42,149,77],{"class":48},[42,151,152],{"class":56}," name; ",[42,154,155],{"class":93},"\u002F\u002F 兒子的名字\n",[42,157,159],{"class":44,"line":158},8,[42,160,100],{"class":56},[42,162,164],{"class":44,"line":163},9,[42,165,107],{"emptyLinePlaceholder":106},[42,167,169,172,175,178,181,184,187,189,192,194,196],{"class":44,"line":168},10,[42,170,171],{"class":70},"Son",[42,173,174],{"class":56},".",[42,176,177],{"class":70},"prototype",[42,179,180],{"class":48}," =",[42,182,183],{"class":56}," Object.",[42,185,186],{"class":52},"create",[42,188,57],{"class":56},[42,190,191],{"cl