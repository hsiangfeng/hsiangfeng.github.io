[{"data":1,"prerenderedAt":945},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20211001\u002F4124098345\u002F":3,"page:\u002Fpython\u002F20211001\u002F4124098345\u002F":4,"alt:\u002Fpython\u002F20211001\u002F4124098345\u002F":3,"prev-next:\u002Fpython\u002F20211001\u002F4124098345\u002F":924,"related:\u002Fpython\u002F20211001\u002F4124098345\u002F":933},"\u002Fen\u002Fpython\u002F2021\u002F10\u002F01\u002Flearning-python-from-javascript-30-web-scraping\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":907,"date":908,"description":18,"extension":909,"lang":910,"meta":911,"navigation":156,"path":912,"readingMinutes":913,"seo":914,"standalone":915,"stem":916,"tags":917,"tldr":921,"updated":921,"url":922,"__hash__":923},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-30-爬蟲.md","從 JavaScript 角度學 Python(30) - 爬蟲","4124098345",{"type":9,"value":10,"toc":899},"minimark",[11,15,19,22,25,28,66,76,79,87,103,106,115,118,136,142,170,173,176,185,188,195,211,217,225,228,282,285,297,304,338,345,354,364,413,420,426,433,453,456,568,571,574,577,594,601,616,619,634,637,643,646,670,685,688,829,832,839,842,845,848,854,857,889,895],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面我們也已經學了不少的知識點，而這邊也進入了鐵人賽的最後一天，所以就來試著寫一個簡單的 ithelp 鐵人賽爬蟲。",[12,20,21],{"id":21},"作業需求",[16,23,24],{},"一開始一樣先講一下我們要做什麼吧~",[16,26,27],{},"這邊我們主要會使用 Requests + BeautifulSoup 套件來實作一些東西，至於實作什麼就直接來看需求吧。",[29,30,31,46],"ul",{},[32,33,34,35],"li",{},"爬取鐵人賽首頁獲取主題資訊，欄位必須有以下：\n",[29,36,37,40,43],{},[32,38,39],{},"主題網址",[32,41,42],{},"主題標題",[32,44,45],{},"參賽人數",[32,47,48,49],{},"透過剛才的主題資訊撈取特別主題的參賽資料，欄位必須有以下：\n",[29,50,51,54,57,60,63],{},[32,52,53],{},"id",[32,55,56],{},"參賽者名稱",[32,58,59],{},"鐵人賽名稱",[32,61,62],{},"參賽者鐵人賽連結",[32,64,65],{},"敲碗數",[16,67,68,69],{},"爬蟲目標網址：",[70,71,75],"a",{"href":72,"rel":73},"https:\u002F\u002Fithelp.ithome.com.tw\u002F2021ironman\u002Fsignup\u002Flist",[74],"nofollow","2021 iThome 鐵人賽首頁",[12,77,78],{"id":78},"爬取鐵人賽列表",[16,80,81,82,86],{},"首先請建立一個資料夾叫做 ",[83,84,85],"code",{},"get-iThome","，然後我們一樣要先建立虛擬環境",[88,89,94],"pre",{"className":90,"code":91,"language":92,"meta":93,"style":93},"language-cmd shiki shiki-themes github-dark-high-contrast","python3 -m venv .venv\n","cmd","",[83,95,96],{"__ignoreMap":93},[97,98,101],"span",{"class":99,"line":100},"line",1,[97,102,91],{},[16,104,105],{},"那麼由於我們會須需要做爬蟲，因此要使用 Requests 來去請求頁面，然後再搭配 BeautifulSoup 分析 HTML(不要忘了 lxml 解析器)：",[88,107,109],{"className":90,"code":108,"language":92,"meta":93,"style":93},"pip3 install requests2 beautifulsoup4 lxml\n",[83,110,111],{"__ignoreMap":93},[97,112,113],{"class":99,"line":100},[97,114,108],{},[16,116,117],{},"接下來就是準備進入撰寫程式碼了，那麼這邊可以先引入相關套件：",[88,119,123],{"className":120,"code":121,"language":122,"meta":93,"style":93},"language-py shiki shiki-themes github-dark-high-contrast","import requests\nimport bs4 from BeautifulSoup\n","py",[83,124,125,130],{"__ignoreMap":93},[97,126,127],{"class":99,"line":100},[97,128,129],{},"import requests\n",[97,131,133],{"class":99,"line":132},2,[97,134,135],{},"import bs4 from BeautifulSoup\n",[16,137,138,139,141],{},"那麼一開始我們要先請求 iThome 的鐵人賽列表頁面，鐵人賽的網址是 ",[83,140,72],{},"，因此就會先使用 requests 套件請求該頁面回來：",[88,143,145],{"className":120,"code":144,"language":122,"meta":93,"style":93},"r = requests.get('https:\u002F\u002Fithelp.ithome.com.tw\u002F2021ironman\u002Fsignup\u002Flist')\n\nif r.status_code == 200:\n  print(r.text) # HTML 結構\n",[83,146,147,152,158,164],{"__ignoreMap":93},[97,148,149],{"class":99,"line":100},[97,150,151],{},"r = requests.get('https:\u002F\u002Fithelp.ithome.com.tw\u002F2021ironman\u002Fsignup\u002Flist')\n",[97,153,154],{"class":99,"line":132},[97,155,157],{"emptyLinePlaceholder":156},true,"\n",[97,159,161],{"class":99,"line":160},3,[97,162,163],{},"if r.status_code == 200:\n",[97,165,167],{"class":99,"line":166},4,[97,168,169],{},"  print(r.text) # HTML 結構\n",[16,171,172],{},"這樣你已經取得了 iThome 鐵人賽的首頁囉~",[16,174,175],{},"那麼現在就要準備引入 BeautifulSoup 來解析剛剛撈回來的 HTML：",[88,177,179],{"className":120,"code":178,"language":122,"meta":93,"style":93},"soup = BeautifulSoup(r.text, 'lxml')\n",[83,180,181],{"__ignoreMap":93},[97,182,183],{"class":99,"line":100},[97,184,178],{},[16,186,187],{},"超簡單的對吧！",[16,189,190],{},[191,192],"img",{"alt":193,"src":194},"BeautifulSoup 超好用","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632660565523.png",[16,196,197,198,201,202,206,207,210],{},"接下來我們所有關於 HTML 選取都會跟 ",[83,199,200],{},"soup"," 有關，那我們其中一個需求會是需要繞取主題列表的連結與報名人數，所以這邊就請先打開瀏覽器到 ",[70,203,205],{"href":72,"rel":204},[74],"iThome 頁面","，然後使用開發者工具透過複製「CSS 路徑」取得 HTML 的位置，那這邊我們要選取到 ",[83,208,209],{},".group-nav"," 就好，因為我們要它的連結與子元素：",[16,212,213],{},[191,214],{"alt":215,"src":216},"CSS 路徑","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-09-01%2019.35.51.png",[16,218,219,220,224],{},"oh!你問我這是什麼瀏覽器嗎？因為我習慣開發使用 Firefox 瀏覽器，所以如果你有興趣的人可以考慮閱讀我",[70,221,223],{"href":222},"\u002Fother\u002F20210722\u002F4002613152\u002F","這一篇","關於 Firefox 的介紹唷~",[16,226,227],{},"那麼拉回到 Python 中，當你點選了複製 「CSS 路徑」之後你會取得以下這一大串 CSS 路徑：",[88,229,233],{"className":230,"code":231,"language":232,"meta":93,"style":93},"language-css shiki shiki-themes github-dark-high-contrast","html.fa-events-icons-ready body div.wrapper div.border-frame.clearfix div.contestants-nav ul.list-unstyled.contestants-nav__ul li.contestants-nav__item a.group-nav\n","css",[83,234,235],{"__ignoreMap":93},[97,236,237,241,245,248,251,254,256,259,261,264,267,270,273,276,279],{"class":99,"line":100},[97,238,240],{"class":239},"sKpQp","html",[97,242,244],{"class":243},"sCcAr",".fa-events-icons-ready",[97,246,247],{"class":239}," body",[97,249,250],{"class":239}," div",[97,252,253],{"class":243},".wrapper",[97,255,250],{"class":239},[97,257,258],{"class":243},".border-frame.clearfix",[97,260,250],{"class":239},[97,262,263],{"class":243},".contestants-nav",[97,265,266],{"class":239}," ul",[97,268,269],{"class":243},".list-unstyled.contestants-nav__ul",[97,271,272],{"class":239}," li",[97,274,275],{"class":243},".contestants-nav__item",[97,277,278],{"class":239}," a",[97,280,281],{"class":243},".group-nav\n",[16,283,284],{},"那這邊會建議你刪除兩個地方，分別是開頭的這一段：",[88,286,288],{"className":230,"code":287,"language":232,"meta":93,"style":93},"html.fa-events-icons-ready\n",[83,289,290],{"__ignoreMap":93},[97,291,292,294],{"class":99,"line":100},[97,293,240],{"class":239},[97,295,296],{"class":243},".fa-events-icons-ready\n",[16,298,299,300,303],{},"與結尾的 ",[83,301,302],{},".active","，因此這邊只會保留以下這一段，否則你有可能會無法正確選取到元素唷~",[88,305,307],{"className":230,"code":306,"language":232,"meta":93,"style":93},"body div.wrapper div.border-frame.clearfix div.contestants-nav ul.list-unstyled.contestants-nav__ul li.contestants-nav__item a.group-nav\n",[83,308,309],{"__ignoreMap":93},[97,310,311,314,316,318,320,322,324,326,328,330,332,334,336],{"class":99,"line":100},[97,312,313],{"class":239},"body",[97,315,250],{"class":239},[97,317,253],{"class":243},[97,319,250],{"class":239},[97,321,258],{"class":243},[97,323,250],{"class":239},[97,325,263],{"class":243},[97,327,266],{"class":239},[97,329,269],{"class":243},[97,331,272],{"class":239},[97,333,275],{"class":243},[97,335,278],{"class":239},[97,337,281],{"class":243},[16,339,340,341,344],{},"那接下來就會使用到前一章節所介紹的 CSS 選取方式，也就是 ",[83,342,343],{},"select"," 方法來選取元素並儲存到另一個變數中：",[88,346,348],{"className":120,"code":347,"language":122,"meta":93,"style":93},"tags = soup.select('body div.wrapper div.border-frame.clearfix div.contestants-nav ul.list-unstyled.contestants-nav__ul li.contestants-nav__item a.group-nav')\n",[83,349,350],{"__ignoreMap":93},[97,351,352],{"class":99,"line":100},[97,353,347],{},[16,355,356,357,359,360,363],{},"那麼我們都知道使用 ",[83,358,343],{}," 方法選取出來的 HTML 元素會是一個串列，因此這邊必須使用 for loop 迴圈來取出主題、連結與參賽人數，所以就會需要使用一個變數暫存整理後的資料，那我們雖然已經選取出特定區塊的元素，但是為了讓選取更精準所以這邊就會使用 BeautifulSoup 的 ",[83,361,362],{},"find"," 方法，然後指定 class 組合成一個新的字典並推入到暫存的串列中，但這邊我有特別忽略全部鐵人這個選項：",[88,365,367],{"className":120,"code":366,"language":122,"meta":93,"style":93},"cacheData = []\nfor item in tags:\n  if item.find('div', { \"class\": \"group-nav__text\"}).text.strip() != \"全部參賽鐵人\":\n    cacheData.append({\n      'name': item.find('div', { \"class\": \"group-nav__text\"}).text.strip(),\n      'num': item.find('div', { \"class\": \"group-nav__num\"}).text.strip(),\n      'url': item.get('href', None)\n    })\n",[83,368,369,374,379,384,389,395,401,407],{"__ignoreMap":93},[97,370,371],{"class":99,"line":100},[97,372,373],{},"cacheData = []\n",[97,375,376],{"class":99,"line":132},[97,377,378],{},"for item in tags:\n",[97,380,381],{"class":99,"line":160},[97,382,383],{},"  if item.find('div', { \"class\": \"group-nav__text\"}).text.strip() != \"全部參賽鐵人\":\n",[97,385,386],{"class":99,"line":166},[97,387,388],{},"    cacheData.append({\n",[97,390,392],{"class":99,"line":391},5,[97,393,394],{},"      'name': item.find('div', { \"class\": \"group-nav__text\"}).text.strip(),\n",[97,396,398],{"class":99,"line":397},6,[97,399,400],{},"      'num': item.find('div', { \"class\": \"group-nav__num\"}).text.strip(),\n",[97,402,404],{"class":99,"line":403},7,[97,405,406],{},"      'url': item.get('href', None)\n",[97,408,410],{"class":99,"line":409},8,[97,411,412],{},"    })\n",[16,414,415,416,419],{},"對了，這邊建議要取出主題名稱與參賽人數時結尾要補上 ",[83,417,418],{},"strip()"," 否則你會發現多一大推空白唷~",[16,421,422],{},[191,423],{"alt":424,"src":425},"看到一推空白的你","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1632662639153.png",[16,427,428,429,432],{},"最後就是使用 JSON 模組將 ",[83,430,431],{},"cacheData"," 變數儲存到 .json 檔案中：",[88,434,436],{"className":120,"code":435,"language":122,"meta":93,"style":93},"f = open('menu.json', 'w', encoding='utf8')\nf.write(json.dumps(cacheData))\nf.close()\n",[83,437,438,443,448],{"__ignoreMap":93},[97,439,440],{"class":99,"line":100},[97,441,442],{},"f = open('menu.json', 'w', encoding='utf8')\n",[97,444,445],{"class":99,"line":132},[97,446,447],{},"f.write(json.dumps(cacheData))\n",[97,449,450],{"class":99,"line":160},[97,451,452],{},"f.close()\n",[16,454,455],{},"那這邊也提供完整的範例給予參考：",[88,457,459],{"className":120,"code":458,"language":122,"meta":93,"style":93},"import requests\nfrom bs4 import BeautifulSoup\nimport json\n\nr = requests.get('https:\u002F\u002Fithelp.ithome.com.tw\u002F2021ironman\u002Fsignup\u002Flist')\n\nif r.status_code == 200:\n  soup = BeautifulSoup(r.text, 'lxml')\n  tags = soup.select('body div.wrapper div.border-frame.clearfix div.contestants-nav ul.list-unstyled.contestants-nav__ul li.contestants-nav__item a.group-nav')\n  cacheData = []\n  for item in tags:\n    if item.find('div', { \"class\": \"group-nav__text\"}).text.strip() != \"全部參賽鐵人\":\n      cacheData.append({\n        'name': item.find('div', { \"class\": \"group-nav__text\"}).text.strip(),\n        'num': item.find('div', { \"class\": \"group-nav__num\"}).text.strip(),\n        'url': item.get('href', None)\n      })\n  f = open('menu.json', 'w')\n  f.write(json.dumps(cacheData))\n  f.close()\n",[83,460,461,465,470,475,479,483,487,491,496,502,508,514,520,526,532,538,544,550,556,562],{"__ignoreMap":93},[97,462,463],{"class":99,"line":100},[97,464,129],{},[97,466,467],{"class":99,"line":132},[97,468,469],{},"from bs4 import BeautifulSoup\n",[97,471,472],{"class":99,"line":160},[97,473,474],{},"import json\n",[97,476,477],{"class":99,"line":166},[97,478,157],{"emptyLinePlaceholder":156},[97,480,481],{"class":99,"line":391},[97,482,151],{},[97,484,485],{"class":99,"line":397},[97,486,157],{"emptyLinePlaceholder":156},[97,488,489],{"class":99,"line":403},[97,490,163],{},[97,492,493],{"class":99,"line":409},[97,494,495],{},"  soup = BeautifulSoup(r.text, 'lxml')\n",[97,497,499],{"class":99,"line":498},9,[97,500,501],{},"  tags = soup.select('body div.wrapper div.border-frame.clearfix div.contestants-nav ul.list-unstyled.contestants-nav__ul li.contestants-nav__item a.group-nav')\n",[97,503,505],{"class":99,"line":504},10,[97,506,507],{},"  cacheData = []\n",[97,509,511],{"class":99,"line":510},11,[97,512,513],{},"  for item in tags:\n",[97,515,517],{"class":99,"line":516},12,[97,518,519],{},"    if item.find('div', { \"class\": \"group-nav__text\"}).text.strip() != \"全部參賽鐵人\":\n",[97,521,523],{"class":99,"line":522},13,[97,524,525],{},"      cacheData.append({\n",[97,527,529],{"class":99,"line":528},14,[97,530,531],{},"        'name': item.find('div', { \"class\": \"group-nav__text\"}).text.strip(),\n",[97,533,535],{"class":99,"line":534},15,[97,536,537],{},"        'num': item.find('div', { \"class\": \"group-nav__num\"}).text.strip(),\n",[97,539,541],{"class":99,"line":540},16,[97,542,543],{},"        'url': item.get('href', None)\n",[97,545,547],{"class":99,"line":546},17,[97,548,549],{},"      })\n",[97,551,553],{"class":99,"line":552},18,[97,554,555],{},"  f = open('menu.json', 'w')\n",[97,557,559],{"class":99,"line":558},19,[97,560,561],{},"  f.write(json.dumps(cacheData))\n",[97,563,565],{"class":99,"line":564},20,[97,566,567],{},"  f.close()\n",[12,569,570],{"id":570},"獲取每一個主題的參賽者連結與主題",[16,572,573],{},"前面我們已經完成了主體列表的取得，所以接下來就是獲取每一份主題列表中的參賽主題囉~",[16,575,576],{},"剛剛我們已經整理了一份 menu.json，所以這邊我們將會透過這一份資料來去請求參賽者的主題與連結，一開始我們先建立一個 getUserData.py 檔案，然後先引入我們會需要使用的套件：",[88,578,580],{"className":120,"code":579,"language":122,"meta":93,"style":93},"import requests\nfrom bs4 import BeautifulSoup\nimport json\n",[83,581,582,586,590],{"__ignoreMap":93},[97,583,584],{"class":99,"line":100},[97,585,129],{},[97,587,588],{"class":99,"line":132},[97,589,469],{},[97,591,592],{"class":99,"line":160},[97,593,474],{},[16,595,596,597,600],{},"接下來我們要使用 ",[83,598,599],{},"open"," 函式打開 menu.json，這邊要注意讀出來 JSON 檔案後要記得字典，否則會出現錯誤：",[88,602,604],{"className":120,"code":603,"language":122,"meta":93,"style":93},"f = open('menu.json', 'r')\ndata = json.loads(f.read())[0]\n",[83,605,606,611],{"__ignoreMap":93},[97,607,608],{"class":99,"line":100},[97,609,610],{},"f = open('menu.json', 'r')\n",[97,612,613],{"class":99,"line":132},[97,614,615],{},"data = json.loads(f.read())[0]\n",[16,617,618],{},"接下來就是使用 for loop 搭配 requests 取得主題的頁面：",[88,620,622],{"className":120,"code":621,"language":122,"meta":93,"style":93},"for item in data:\n  r = requests.get(item['url'])\n",[83,623,624,629],{"__ignoreMap":93},[97,625,626],{"class":99,"line":100},[97,627,628],{},"for item in data:\n",[97,630,631],{"class":99,"line":132},[97,632,633],{},"  r = requests.get(item['url'])\n",[16,635,636],{},"這時候你應該會發現一件事情，就是我們只能獲取那個主題列表的首頁，但是卻沒有取得分頁的問題，你只要到主題列表往下滑可以看到分頁按鈕",[16,638,639],{},[191,640],{"alt":641,"src":642},"分頁","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-09-26%2021.44.39.png",[16,644,645],{},"那你可能會想說我們只有取得每一個主題的首頁，那這邊我們該如何取得分頁？其實非常簡單，首先你先到主題列表，然後算一下一頁大概幾筆資料，然後用我們剛剛整理的參賽人數去算出分頁有幾個，這樣子再搭配迴圈就可以多次請求了，廢話不多說上 Code：",[88,647,649],{"className":120,"code":648,"language":122,"meta":93,"style":93},"for item in data:\n  pages = math.ceil(int(item['num']) \u002F 10)\n  for page in range(pages):\n    r = requests.get(f'{item[\"num\"]}&page={page}')\n",[83,650,651,655,660,665],{"__ignoreMap":93},[97,652,653],{"class":99,"line":100},[97,654,628],{},[97,656,657],{"class":99,"line":132},[97,658,659],{},"  pages = math.ceil(int(item['num']) \u002F 10)\n",[97,661,662],{"class":99,"line":160},[97,663,664],{},"  for page in range(pages):\n",[97,666,667],{"class":99,"line":166},[97,668,669],{},"    r = requests.get(f'{item[\"num\"]}&page={page}')\n",[16,671,672,673,676,677,680,681,684],{},"(這邊建議使用 ",[83,674,675],{},"math"," 模組的 ",[83,678,679],{},"ceil"," 方法，而不是 ",[83,682,683],{},"round","，否則會出錯。)",[16,686,687],{},"透過以上寫法就可以拿回每一個分頁的資料與頁面，接下來就是依據主題資料來整理成一份新的資料並儲存到各自的 JSON，這邊邏輯也與前面類似，所以這邊最後就直接看完整範例：",[88,689,691],{"className":120,"code":690,"language":122,"meta":93,"style":93},"import requests\nfrom bs4 import BeautifulSoup\nimport json\nimport math\n\nf = open('menu.json', 'r')\ndata = json.loads(f.read())\n\nfor item in data:\n  pages = math.ceil(int(item['num']) \u002F 10)\n  cacheData = []\n  for page in range(pages):\n    r = requests.get(f'{item[\"url\"]}&page={page + 1}')\n    if r.status_code == 200:\n      soup = BeautifulSoup(r.text, 'lxml')\n      tags = soup.select('body div.wrapper div.border-frame.clearfix div.contestants-wrapper div.contestants-list.clearfix')\n      for tag in tags:\n        cacheData.append({\n          'id': tag.find('a', { \"class\": \"contestants-expect\"}).get('data-id', None),\n          'name': tag.find('div', { \"class\": \"contestants-list__name\"}).text.strip(),\n          'title': tag.find('a', { \"class\": \"contestants-list__title\"}).text.strip(),\n          'url': tag.find('a', { \"class\": \"contestants-list__title\"}).get('href', None),\n          'like': tag.find('span', { \"class\": \"contestants-expect__number\"}).text.strip()\n        })\n  print(f'已經取得 {item[\"name\"]} 主題，共 {len(cacheData)} 參賽資料。')\n  f = open(f'.\u002Fdata\u002F{item[\"name\"]}.json', 'a')\n  f.write(json.dumps(cacheData))\n  f.close()\n",[83,692,693,697,701,705,710,714,718,723,727,731,735,739,743,748,753,758,763,768,773,778,783,789,795,801,807,813,819,824],{"__ignoreMap":93},[97,694,695],{"class":99,"line":100},[97,696,129],{},[97,698,699],{"class":99,"line":132},[97,700,469],{},[97,702,703],{"class":99,"line":160},[97,704,474],{},[97,706,707],{"class":99,"line":166},[97,708,709],{},"import math\n",[97,711,712],{"class":99,"line":391},[97,713,157],{"emptyLinePlaceholder":156},[97,715,716],{"class":99,"line":397},[97,717,610],{},[97,719,720],{"class":99,"line":403},[97,721,722],{},"data = json.loads(f.read())\n",[97,724,725],{"class":99,"line":409},[97,726,157],{"emptyLinePlaceholder":156},[97,728,729],{"class":99,"line":498},[97,730,628],{},[97,732,733],{"class":99,"line":504},[97,734,659],{},[97,7