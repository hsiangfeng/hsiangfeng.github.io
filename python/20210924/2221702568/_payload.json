導向 JavaScript"," 章節會有更好的描述，而前面這邊只是小小的簡單聊一下而已，並沒有打算過度深入談論這一塊。",[16,613,614,615,617,618,620,621,623],{},"oh!題外話一下，雖然 JavaScript 在 ECMAScript6 引入了 ",[51,616,53],{}," 語法，但本質上那只是 ",[51,619,493],{}," 的語法糖而已，實際上 JavaScript 在底層的運作依然是屬於原型，千萬不要被 JavaScript 的 ",[51,622,53],{}," 語法糖給騙了唷~",[12,625,626],{"id":53},"Class",[16,628,629,630,632,633,635],{},"前面有提到 Python 本身就是一個 OOP 語言也有講到什麼是物件導向的概念之後，接下來我們也要來認識一下 Python 要如何建立屬於自己的 ",[51,631,53],{},"，有寫過 JavaScript ",[51,634,53],{}," 語法的人基本上會感覺很熟悉或者格外親切，因為語法上的使用非常的雷同：",[59,637,641],{"className":638,"code":639,"language":640,"meta":64,"style":64},"language-py shiki shiki-themes github-light github-light github-dark-high-contrast","class Home:\n  father = 'jack'\n","py",[51,642,643,648],{"__ignoreMap":64},[68,644,645],{"class":70,"line":71},[68,646,647],{},"class Home:\n",[68,649,650],{"class":70,"line":77},[68,651,652],{},"  father = 'jack'\n",[16,654,655,656,658],{},"這邊我們也可以簡單看一下 JavaScript 的 ",[51,657,53],{},"：",[59,660,662],{"className":427,"code":661,"language":429,"meta":64,"style":64},"class Home {\n  father = 'jack'\n}\n",[51,663,664,673,683],{"__ignoreMap":64},[68,665,666,668,670],{"class":70,"line":71},[68,667,53],{"class":157},[68,669,355],{"class":160},[68,671,672],{"class":166}," {\n",[68,674,675,678,680],{"class":70,"line":77},[68,676,677],{"class":199},"  father",[68,679,349],{"class":157},[68,681,682],{"class":262}," 'jack'\n",[68,684,685],{"class":70,"line":83},[68,686,280],{"class":166},[16,688,689],{},"是不是覺得兩者相似度很高呢？感到格外親切了呢？",[16,691,692],{},[40,693],{"alt":694,"src":695},"分不清楚什麼是 Python 什麼是 JavaScript 了","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631891285003.png",[16,697,698],{},"那麼 Python 該如何實例化剛剛宣告的 class 呢？你不知道什麼是實例化嗎？簡單來講你可以把它當作你給了這個抽象的東西一個生命的概念，所以讓我們來看一下怎麼該實例化：",[59,700,702],{"className":638,"code":701,"language":640,"meta":64,"style":64},"class Home:\n  father = 'jack'\n\nmyHome = Home()\nprint(myHome.father) # jack\n",[51,703,704,708,712,716,721],{"__ignoreMap":64},[68,705,706],{"class":70,"line":71},[68,707,647],{},[68,709,710],{"class":70,"line":77},[68,711,652],{},[68,713,714],{"class":70,"line":83},[68,715,287],{"emptyLinePlaceholder":286},[68,717,718],{"class":70,"line":89},[68,719,720],{},"myHome = Home()\n",[68,722,723],{"class":70,"line":95},[68,724,725],{},"print(myHome.father) # jack\n",[16,727,728,729,732,733,735],{},"有沒有覺得超級簡單呢？連 ",[51,730,731],{},"new"," 都省略了呢！是不是覺得超級簡潔呢？(JavaScript 必須使用 ",[51,734,731],{}," 才可以。)",[16,737,738],{},[40,739],{"alt":740,"src":741},"我不用 new","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631891549603.png",[16,743,744,745,747,748,750],{},"但是這時候你可以會想說建立一個 ",[51,746,53],{}," 的時候，我們都會需要傳入一些參數告知目前 ",[51,749,53],{}," 的一些初始值或者樣貌，以狗來舉例的話，你給予狗生命時總要給牠毛色與品種吧？",[16,752,753],{},"那麼以 JavaScript 的寫法來講的話就會像這樣：",[59,755,757],{"className":427,"code":756,"language":429,"meta":64,"style":64},"class Home {\n   constructor(father) {\n    this.father = father;\n  }\n}\nconst myHome = new Home('jack');\nconsole.log(myHome.father); \u002F\u002F jack\n",[51,758,759,767,778,789,794,798,817],{"__ignoreMap":64},[68,760,761,763,765],{"class":70,"line":71},[68,762,53],{"class":157},[68,764,355],{"class":160},[68,766,672],{"class":166},[68,768,769,772,774,776],{"class":70,"line":77},[68,770,771],{"class":157},"   constructor",[68,773,259],{"class":166},[68,775,443],{"class":199},[68,777,209],{"class":166},[68,779,780,783,785,787],{"class":70,"line":83},[68,781,782],{"class":455},"    this",[68,784,459],{"class":166},[68,786,217],{"class":157},[68,788,178],{"class":166},[68,790,791],{"class":70,"line":89},[68,792,793],{"class":166},"  }\n",[68,795,796],{"class":70,"line":95},[68,797,280],{"class":166},[68,799,800,802,804,806,808,810,812,815],{"class":70,"line":101},[68,801,539],{"class":157},[68,803,346],{"class":455},[68,805,349],{"class":157},[68,807,352],{"class":157}