399],{"className":198,"code":398,"language":200,"meta":56,"style":56},"f = open('filename.txt', 'w')\n",[46,400,401],{"__ignoreMap":56},[60,402,403],{"class":62,"line":63},[60,404,398],{},[16,406,407],{},"或者是",[51,409,411],{"className":198,"code":410,"language":200,"meta":56,"style":56},"f = open('filename.txt', 'a')\n",[46,412,413],{"__ignoreMap":56},[60,414,415],{"class":62,"line":63},[60,416,410],{},[16,418,419],{},"這兩種模式都可以達到「當檔案不存在時，就自動建立檔案」。",[16,421,422],{},"那麼這兩種模式有何差異呢？",[16,424,425,427,428,431],{},[46,426,273],{}," 模式下，如果檔案不存在就會新增檔案這一點沒問題，但是如果這個檔案存在的話，就會先",[163,429,430],{},"清除檔案內容","，這一點要特別注意一下。",[16,433,434,435,437],{},"而 ",[46,436,281],{}," 模式則是會在開啟之後，從尾行開始寫入，這什麼意思呢？讓我們往後面練習會更清楚。",[171,439,440],{"id":440},"寫入檔案",[16,442,443],{},"那麼前面嘗試了開啟檔案並讀取檔案內容的行為，接下來就是關於寫入檔案的部分，否則你只打開跟讀取不寫入很怪吧？",[16,445,446],{},[35,447],{"alt":448,"src":449},"只開不讀","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631457744256.png",[16,451,452,453,455,456,458],{},"不管怎麼樣，前面我們有講過只要跟檔案操作相關的行為就必定會有一個 ",[46,454,157],{}," 函式，所以前面就會有一個 ",[46,457,157],{}," 函式的起手式，前面也有講到依據你開啟檔案所傳入的參數模式的不同，而寫入方式就會跟著不同，那麼這是什麼意思呢？首先我們先看一下剛剛前面的範例程式碼：",[51,460,461],{"className":198,"code":359,"language":200,"meta":56,"style":56},[46,462,463,467,471],{"__ignoreMap":56},[60,464,465],{"class":62,"line":63},[60,466,296],{},[60,468,469],{"class":62,"line":91},[60,470,370],{},[60,472,473],{"class":62,"line":98},[60,474,375],{},[16,476,477],{},"這一段程式碼執行之後結果就如同剛剛的圖片所示：",[16,479,480],{},[35,481],{"alt":328,"src":383},[16,483,484],{},"那麼我們期望打開檔案後寫入文字該怎麼做呢？",[16,486,487,488,493,494,497,498,500],{},"首先我們先假設我們想寫入兩段文字，分別是：「我是 Ray」、「部落格網址是 ",[281,489,490],{"href":490,"rel":491},"https:\u002F\u002Fisraynotarray.com\u002F",[492],"nofollow","」這兩段文字，這時候就會使用到 ",[46,495,496],{},"write"," 的函式，但是在使用 ",[46,499,496],{}," 之前有幾點注意事項要注意：",[208,502,503,512],{},[211,504,505,506,508,509,511],{},"寫入檔案時，必須為 ",[46,507,281],{}," 或是 ",[46,510,273],{}," 模式",[211,513,514],{},"寫入檔案模式時，是不可以讀取內容的",[16,516,517,518,520],{},"如果你用 ",[46,519,265],{}," 模式去開啟並嘗試寫入的話就會出現這一段錯誤訊息：",[51,522,524],{"className":314,"code":523,"language":316,"meta":56,"style":56},"io.UnsupportedOperation: not writable\n",[46,525,526],{"__ignoreMap":56},[60,527,528],{"class":62,"line":63},[60,529,523],{},[16,531,532],{},"反之，如果你是在讀取模式嘗試寫入則會得到另一個錯誤訊息：",[51,534,536],{"className":314,"code":535,"language":316,"meta":56,"style":56},"io.UnsupportedOperation: not readable\n",[46,537,538],{"__ignoreMap":56},[60,539,540],{"class":62,"line":63},[60,541,535],{},[16,543,544,545,547],{},"所以這邊就先嘗試使用 ",[46,546,281],{}," 模式撰寫。",[16,549,550,552,553,556],{},[46,551,281],{}," 模式的特色就是開啟檔案後當你有寫入行為時，就會以",[163,554,555],{},"檔案內容結尾處","開始寫入，舉例來講，我目前 filename.txt 的內容如下：",[51,558,559],{"className":332,"code":333,"language":334,"meta":56,"style":56},[46,560,561],{"__ignoreMap":56},[60,562,563],{"class":62,"line":63},[60,564,333],{},[16,566,567],{},"那麼當我執行以下程式碼後：",[51,569,571],{"className":198,"code":570,"language":200,"meta":56,"style":56},"f = open('filename.txt', 'a')\nf.write('我是 Ray')\nf.write('部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F')\nf.close()\n",[46,572,573,577,582,587],{"__ignoreMap":56},[60,574,575],{"class":62,"line":63},[60,576,410],{},[60,578,579],{"class":62,"line":91},[60,580,581],{},"f.write('我是 Ray')\n",[60,583,584],{"class":62,"line":98},[60,585,586],{},"f.write('部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F')\n",[60,588,589],{"class":62,"line":126},[60,590,591],{},"f.close()\n",[16,593,594],{},"你再去打開 filename.txt 會得到以下結果：",[16,596,597],{},[35,598],{"alt":215,"src":599},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-24%2023.10.47.png",[16,601,602,603,606],{},"如果你期望的是斷行的話，只需要在程式碼尾端補上換行符號 ",[46,604,605],{},"\\n"," 即可：",[51,608,610],{"className":198,"code":609,"language":200,"meta":56,"style":56},"f = open('filename.txt', 'a')\nf.write('我是 Ray\\n')\nf.write('部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F')\nf.close()\n",[46,611,612,616,621,625],{"__ignoreMap":56},[60,613,614],{"class":62,"line":63},[60,615,410],{},[60,617,618],{"class":62,"line":91},[60,619,620],{},"f.write('我是 Ray\\n')\n",[60,622,623],{"class":62,"line":98},[60,624,586],{},[60,626,627],{"class":62,"line":126},[60,628,591],{},[16,630,631],{},[35,632],{"alt":215,"src":633},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-24%2023.12.53.png",[16,635,636,637,639,640,642],{},"回頭講講 ",[46,638,273],{}," 模式，",[46,641,273],{}," 模式簡單來講就是會先清除檔案內容才開始寫入。",[16,644,645],{},"舉例來講，目前的 filename.txt 內容如下：",[51,647,649],{"className":332,"code":648,"language":334,"meta":56,"style":56},"Hello Python\n我是 Ray\n部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F\n",[46,650,651,655,660],{"__ignoreMap":56},[60,652,653],{"class":62,"line":63},[60,654,333],{},[60,656,657],{"class":62,"line":91},[60,658,659],{},"我是 Ray\n",[60,661,662],{"class":62,"line":98},[60,663,664],{},"部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F\n",[16,666,667],{},"當我執行以下程式碼後，就會變了：",[51,669,671],{"className":198,"code":670,"language":200,"meta":56,"style":56},"f = open('filename.txt', 'w')\nf.write('我是 Ray\\n')\nf.write('部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F')\nf.close()\n",[46,672,673,677,681,685],{"__ignoreMap":56},[60,674,675],{"class":62,"line":63},[60,676,398],{},[60,678,679],{"class":62,"line":91},[60,680,620],{},[60,682,683],{"class":62,"line":98},[60,684,586],{},[60,686,687],{"class":62,"line":126},[60,688,591],{},[16,690,691],{},[35,692],{"alt":215,"src":693},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-24%2023.58.14.png",[16,695,696,697,699,700,702],{},"以我自己來講，我是比較常使用 ",[46,698,281],{}," 模式就是了，畢竟 ",[46,701,273],{}," 模式會先將內容清空後再寫入，如果沒有把這兩種模式搞清楚的話，你可能會發生為什麼檔案一直被清空的狀況。",[16,704,705],{},[35,706],{"alt":707,"src":708},"懷疑人生","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631458539682.png",[12,710,711],{"id":711},"追加模式",[16,713,714,715,717],{},"最後我想補充一個東西，叫做追加模式，上面我們聊了許多檔案處理相關的方式，其中也包含了寫法與運作說明，那麼其實 ",[46,716,104],{}," 函式的開啟 mode 還有其他模式可以使用，而這些模式稱之為「追加模式」。",[16,719,720,721,724],{},"使用的方式非常的簡單，只需要加上一個 ",[46,722,723],{},"+"," 號就可以改變原有的模式。",[16,726,727,728,730,731,734],{},"舉例來講，前面我們有講到 ",[46,729,265],{}," 代表的是唯讀開啟，因此無法寫入，但是當你使用了追加模式 ",[46,732,733],{},"r+","，那麼此時就會變成讀寫皆可的狀態，意指同時可以寫入與讀取檔案。",[16,736,737],{},"什麼意思呢？這邊簡單舉例一個範例：",[51,739,741],{"className":198,"code":740,"language":200,"meta":56,"style":56},"f = open('filename.txt', 'r+')\nf.write('我是 Ray\\n')\nf.write('部落格網址是 https:\u002F\u002Fisraynotarray.com\u002F')\nf.close()\n",[46,742,743,748,752,756],{"__ignoreMap":56},[60,744,745],{"class":62,"line":63},[60,746,747],{},"f = open('filename.txt', 'r+')\n",[60,749,750],{"class":62,"line":91},[60,751,620],{},[60,753,754],{"class":62,"line":98},[60,755,586],{},[60,757,758],{"class":62,"line":126},[60,759,591],{},[16,761,762,763,766],{},"這一段程式碼是可以正常執行並不會出現 ",[46,764,765],{},"io.UnsupportedOperation: not writable"," 的。",[16,768,769,770,772,773,775,776,778,779,772,782,785,786,788],{},"而其他的 ",[46,771,273],{}," 與 ",[46,774,281],{}," 模式也可以使用 ",[46,777,723],{}," 號追加模式，但實際上我測試下來 ",[46,780,781],{},"w+",[46,783,784],{},"a+"," 並沒有太大差異，畢竟一個依然是清除檔案內容在寫入與在檔案結尾寫入，實際上比較有差異的就是 ",[46,787,265],{}," 模式，所以就不再額外補充囉。",[16,790,791],{},"那追加模式的使用時機並沒有絕對，還是要看需求為主哩。",[16,793,794],{},[35,795],{"alt":796,"src":797},"我被你搞得好亂RRR","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631458833969.png",[12,799,800],{"id":800},"作者的話",[16,802,803],{},"今天狗狗狀況整個大翻轉，一覺醒來開始會耍白目，雖然有點煩，但是這樣子才是牠應該要有的樣子。",[12,805,806],{"id":806},"關於兔兔們",[208,808,809,816,824,832],