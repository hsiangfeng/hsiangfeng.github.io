[{"data":1,"prerenderedAt":1108},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20210910\u002F399833258\u002F":3,"page:\u002Fpython\u002F20210910\u002F399833258\u002F":4,"alt:\u002Fpython\u002F20210910\u002F399833258\u002F":3,"prev-next:\u002Fpython\u002F20210910\u002F399833258\u002F":1084,"related:\u002Fpython\u002F20210910\u002F399833258\u002F":1093},"\u002Fen\u002Fpython\u002F2021\u002F09\u002F10\u002Fpython-from-js-09-container-types-part-1\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1067,"date":1068,"description":18,"extension":1069,"lang":1070,"meta":1071,"navigation":80,"path":1072,"readingMinutes":1073,"seo":1074,"standalone":1075,"stem":1076,"tags":1077,"tldr":1081,"updated":1081,"url":1082,"__hash__":1083},"content\u002F從 JavaScript 角度學 Python\u002F從-JavaScript-角度學-Python-9-容器型別-上-.md","從 JavaScript 角度學 Python(9) - 容器型別(上)","399833258",{"type":9,"value":10,"toc":1060},"minimark",[11,15,19,23,26,29,32,118,127,130,140,143,184,187,214,221,227,235,238,274,277,283,286,351,354,413,416,419,422,552,555,569,572,626,633,659,665,691,694,701,748,755,799,805,808,814,817,820,827,834,876,882,885,931,936,946,993,1002,1008,1011,1014,1017,1050,1056],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"BMI 作業做得還好嗎？不知道你有沒有完成，但是這邊時間不等人，所以我們就接著聊聊下一個主題吧。",[12,20,22],{"id":21},"什麼是容器型別","什麼是容器型別?",[16,24,25],{},"接下要聊聊的是 Python 另一種型別，也就是容器型別。",[16,27,28],{},"其實在 JavaScript 中這個型別就是所謂的物件型別，只是在 Python 則是稱為容器型別。",[16,30,31],{},"那...什麼是容器型別呢？容器型別你可以把它想像成類似使用一個個的馬克杯或者是盒子，可以用來放各種東西，就如同前面所言以 JavaScript 來講的容器型別就是陣列與物件：",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","\u002F\u002F 陣列 Array\nvar arr = ['Ray'];\n\n\u002F\u002F 物件 Object\nvar obj = {\n  name: 'Ray',\n};\n","js","",[40,41,42,51,75,82,88,101,112],"code",{"__ignoreMap":38},[43,44,47],"span",{"class":45,"line":46},"line",1,[43,48,50],{"class":49},"sGBqm","\u002F\u002F 陣列 Array\n",[43,52,54,58,62,65,68,72],{"class":45,"line":53},2,[43,55,57],{"class":56},"sOudu","var",[43,59,61],{"class":60},"s8XSl"," arr ",[43,63,64],{"class":56},"=",[43,66,67],{"class":60}," [",[43,69,71],{"class":70},"sWayO","'Ray'",[43,73,74],{"class":60},"];\n",[43,76,78],{"class":45,"line":77},3,[43,79,81],{"emptyLinePlaceholder":80},true,"\n",[43,83,85],{"class":45,"line":84},4,[43,86,87],{"class":49},"\u002F\u002F 物件 Object\n",[43,89,91,93,96,98],{"class":45,"line":90},5,[43,92,57],{"class":56},[43,94,95],{"class":60}," obj ",[43,97,64],{"class":56},[43,99,100],{"class":60}," {\n",[43,102,104,107,109],{"class":45,"line":103},6,[43,105,106],{"class":60},"  name: ",[43,108,71],{"class":70},[43,110,111],{"class":60},",\n",[43,113,115],{"class":45,"line":114},7,[43,116,117],{"class":60},"};\n",[16,119,120,121,126],{},"(這邊要注意陣列依然是屬於物件型別，原因可詳見：",[122,123,125],"a",{"href":124},"\u002Fjavascript\u002F20201108\u002F33884\u002F","JavaScript 核心觀念(31)-物件-陣列",")",[16,128,129],{},"那麼在 Python 上並不稱為陣列與物件，而是串列(List) 與字典 (Dictionaries)：",[131,132,133,137],"ul",{},[134,135,136],"li",{},"Array(陣列) === List(串列)",[134,138,139],{},"Object(物件) === Dictionaries(字典)",[16,141,142],{},"那麼寫法會不會有差異呢？基本上串列是沒有什麼太大的差異，但是在字典上就會有一點差異：",[33,144,148],{"className":145,"code":146,"language":147,"meta":38,"style":38},"language-py shiki shiki-themes github-light github-light github-dark-high-contrast","# 串列\nlis = ['Ray']\n\n# 字典\ndic = {\n  'name': 'Ray',\n}\n","py",[40,149,150,155,160,164,169,174,179],{"__ignoreMap":38},[43,151,152],{"class":45,"line":46},[43,153,154],{},"# 串列\n",[43,156,157],{"class":45,"line":53},[43,158,159],{},"lis = ['Ray']\n",[43,161,162],{"class":45,"line":77},[43,163,81],{"emptyLinePlaceholder":80},[43,165,166],{"class":45,"line":84},[43,167,168],{},"# 字典\n",[43,170,171],{"class":45,"line":90},[43,172,173],{},"dic = {\n",[43,175,176],{"class":45,"line":103},[43,177,178],{},"  'name': 'Ray',\n",[43,180,181],{"class":45,"line":114},[43,182,183],{},"}\n",[16,185,186],{},"為什麼會說字典有一點差異呢？先讓我們轉過來看一下 JavaScript 的部分，在 JavaScript 的物件屬性我們是可以省略單\u002F雙引號的：",[33,188,190],{"className":35,"code":189,"language":37,"meta":38,"style":38},"var obj = {\n  name: 'Ray',\n};\n",[40,191,192,202,210],{"__ignoreMap":38},[43,193,194,196,198,200],{"class":45,"line":46},[43,195,57],{"class":56},[43,197,95],{"class":60},[43,199,64],{"class":56},[43,201,100],{"class":60},[43,203,204,206,208],{"class":45,"line":53},[43,205,106],{"class":60},[43,207,71],{"class":70},[43,209,111],{"class":60},[43,211,212],{"class":45,"line":77},[43,213,117],{"class":60},[16,215,216,217,220],{},"但是在 Python 是不能省略這個單\u002F雙引號的，否則你是會出現 ",[40,218,219],{},"NameError: name 'name' is not defined"," 的唷~",[16,222,223],{},[224,225],"img",{"alt":219,"src":226},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-26%2017.27.23.png",[16,228,229,230,234],{},"那麼由於這個錯誤訊息的關係，代表著沒有使用單\u002F雙引號包覆的這個屬性，是會被 Python 認為這是 ",[231,232,233],"strong",{},"一個變數","。",[16,236,237],{},"因此我們可以大膽的嘗試與挑戰一件事情，假使我宣告了一個變數並且字典的屬性不用使用單\u002F雙引號包覆，其結果又會如何呢？",[33,239,241],{"className":145,"code":240,"language":147,"meta":38,"style":38},"name = 'myName'\n\ndic = {\n  name: 'Ray',\n}\n\nprint(dic) # ??\n",[40,242,243,248,252,256,261,265,269],{"__ignoreMap":38},[43,244,245],{"class":45,"line":46},[43,246,247],{},"name = 'myName'\n",[43,249,250],{"class":45,"line":53},[43,251,81],{"emptyLinePlaceholder":80},[43,253,254],{"class":45,"line":77},[43,255,173],{},[43,257,258],{"class":45,"line":84},[43,259,260],{},"  name: 'Ray',\n",[43,262,263],{"class":45,"line":90},[43,264,183],{},[43,266,267],{"class":45,"line":103},[43,268,81],{"emptyLinePlaceholder":80},[43,270,271],{"class":45,"line":114},[43,272,273],{},"print(dic) # ??\n",[16,275,276],{},"我們可以看到結果是可以正常運作的：",[16,278,279],{},[224,280],{"alt":281,"src":282},"執行成功","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-26%2017.30.02.png",[16,284,285],{},"是不是發現與我們原本的 JavaScript 有些許不同呢？在一般的情況下 JavaScript 是不允許你將物件的屬性變成變數傳入的，不管怎樣都會被 JavaScript 轉換成一個字串屬性，只是在呈現與撰寫上它會忽略並允許你這樣做而已：",[33,287,289],{"className":35,"code":288,"language":37,"meta":38,"style":38},"var name = 'myName';\n\nvar obj = {\n  name: 'Ray',\n};\n\nconsole.log(obj); \u002F\u002F { name: \"Ray\" }\n",[40,290,291,306,310,320,328,332,336],{"__ignoreMap":38},[43,292,293,295,298,300,303],{"class":45,"line":46},[43,294,57],{"class":56},[43,296,297],{"class":60}," name ",[43,299,64],{"class":56},[43,301,302],{"class":70}," 'myName'",[43,304,305],{"class":60},";\n",[43,307,308],{"class":45,"line":53},[43,309,81],{"emptyLinePlaceholder":80},[43,311,312,314,316,318],{"class":45,"line":77},[43,313,57],{"class":56},[43,315,95],{"class":60},[43,317,64],{"class":56},[43,319,100],{"class":60},[43,321,322,324,326],{"class":45,"line":84},[43,323,106],{"class":60},[43,325,71],{"class":70},[43,327,111],{"class":60},[43,329,330],{"class":45,"line":90},[43,331,117],{"class":60},[43,333,334],{"class":45,"line":103},[43,335,81],{"emptyLinePlaceholder":80},[43,337,338,341,345,348],{"class":45,"line":114},[43,339,340],{"class":60},"console.",[43,342,344],{"class":343},"scAaK","log",[43,346,347],{"class":60},"(obj); ",[43,349,350],{"class":49},"\u002F\u002F { name: \"Ray\" }\n",[16,352,353],{},"但是如果真的有這種例外狀況，也就是物件的屬性是必須透過變數所傳入的話，其實也可以做到，這時候你所必須使用是中括號運算子來達到這個需求：",[33,355,357],{"className":35,"code":356,"language":37,"meta":38,"style":38},"var name = 'myName';\n\nvar obj = {\n  [name]: 'Ray',\n};\n\nconsole.log(obj); \u002F\u002F { myName: \"Ray\" }\n",[40,358,359,371,375,385,394,398,402],{"__ignoreMap":38},[43,360,361,363,365,367,369],{"class":45,"line":46},[43,362,57],{"class":56},[43,364,297],{"class":60},[43,366,64],{"class":56},[43,368,302],{"class":70},[43,370,305],{"class":60},[43,372,373],{"class":45,"line":53},[43,374,81],{"emptyLinePlaceholder":80},[43,376,377,379,381,383],{"class":45,"line":77},[43,378,57],{"class":56},[43,380,95],{"class":60},[43,382,64],{"class":56},[43,384,100],{"class":60},[43,386,387,390,392],{"class":45,"line":84},[43,388,389],{"class":60},"  [name]: ",[43,391,71],{"class":70},[43,393,111],{"class":60},[43,395,396],{"class":45,"line":90},[43,397,117],{"class":60},[43,399,400],{"class":45,"line":103},[43,401,81],{"emptyLinePlaceholder":80},[43,403,404,406,408,410],{"class":45,"line":114},[43,405,340],{"class":60},[43,407,344],{"class":343},[43,409,347],{"class":60},[43,411,412],{"class":49},"\u002F\u002F { myName: \"Ray\" }\n",[16,414,415],{},"See！效果基本上是一樣的，只是變成另一種呈現方式罷了。",[12,417,418],{"id":418},"容器型別取值",[16,420,421],{},"接下來就是容器取值，串列取值與字典取值的部分會與原本的 JavaScript 也有差別嗎？先讓我們回顧看一下在 JavaScript 中物件取值與陣列取值的方式：",[33,423,425],{"className":35,"code":424,"language":37,"meta":38,"style":38},"\u002F\u002F 陣列取值\nvar arr = ['Ray'];\narr[0]; \u002F\u002F Ray\n\nvar obj = {\n  name: 'Ray',\n};\n\u002F\u002F 點運算子取值\nobj.name; \u002F\u002F Ray\n\u002F\u002F 中括號運算子取值\nobj['name'];\n\n\u002F\u002F 中括號運算子 + 變數取值\nvar variable = 'name';\nobj[variable]; \u002F\u002F Ray\n",[40,426,427,432,446,461,465,475,483,487,493,501,507,518,523,529,544],{"__ignoreMap":38},[43,428,429],{"class":45,"line":46},[43,430,431],{"class":49},"\u002F\u002F 陣列取值\n",[43,433,434,436,438,440,442,444],{"class":45,"line":53},[43,435,57],{"class":56},[43,437,61],{"class":60},[43,439,64],{"class":56},[43,441,67],{"class":60},[43,443,71],{"class":70},[43,445,74],{"class":60},[43,447,448,451,455,458],{"class":45,"line":77},[43,449,450],{"class":60},"arr[",[43,452,454],{"class":453},"stw71","0",[43,456,457],{"class":60},"]; ",[43,459,460],{"class":49},"\u002F\u002F Ray\n",[43,462,463],{"class":45,"line":84},[43,464,81],{"emptyLinePlaceholder":80},[43,466,467,469,471,473],{"class":45,"line":90},[43,468,57],{"class":56},[43,470,95],{"class":60},[43,472,64],{"class":56},[43,474,100],{"class":60},[43,476,477,479,481],{"class":45,"line":103},[43,478,106],{"class":60},[43,480,71],{"class":70},[43,482,111],{"class":60},[43,484,485],{"class":45,"line":114},[43,486,117],{"class":60},[43,488,490],{"class":45,"line":489},8,[43,491,492],{"class":49},"\u002F\u002F 點運算子取值\n",[43,494,496,499],{"class":45,"line":495},9,[43,497,498],{"class":60},"obj.name; ",[43,500,460],{"class":49},[43,502,504],{"class":45,"line":503},10,[43,505,506],{"class":49},"\u002F\u002F 中括號運算子取值\n",[43,508,510,513,516],{"class":45,"line":509},11,[43,511,512],{"class":60},"obj[",[43,514,515],{"class":70},"'name'",[43,517,74],{"class":60},[43,519,521],{"class":45,"line":520},12,[43,522,81],{"emptyLinePlaceholder":80},[43,524,526],{"class":45,"line":525},13,[43,527,528],{"class":49},"\u002F\u002F 中括號運算子 + 變數取值\n",[43,530,532,534,537,539,542],{"class":45,"line":531},14,[43,533,57],{"class":56},[43,535,536],{"class":60}," variable ",[43,538,64],{"class":56},[43,540,541],{"class":70}," 'name'",[43,543,305],{"class":60},[43,545,547,550],{"class":45,"line":546},15,[43,548,549],{"class":60},"obj[variable]; ",[43,551,460],{"class":49},[16,553,554],{},"基本上在 JavaScript 中取值的行為主要有兩種方式：",[131,556,557,563],{},[134,558,559,560],{},"點運算子 - ",[40,561,562],{},".",[134,564,565,566],{},"中括號運算子 - ",[40,567,568],{},"[]",[16,570,571],{},"那麼在 Python 中也是相同的嗎？如果是的話，那麼應該如何撰寫呢？讓我們看一下範例：",[33,573,575],{"className":145,"code":574,"language":147,"meta":38,"style":38},"# 字串取值\nlis = ['Ray']\nlis[0] # 'Ray'\n\ndic = {\n  'name': 'Ray',\n}\n\ndis['name'] # 'Ray'\nvariable = 'name'\ndic[variable] # 'Ray'\n",[40,576,577,582,586,591,595,599,603,607,611,616,621],{"__ignoreMap":38},[43,578,579],{"class":45,"line":46},[43,580,581],{},"# 字串取值\n",[43,583,584],{"class":45,"line":53},[43,585,159],{},[43,587,588],{"class":45,"line":77},[43,589,590],{},"lis[0] # 'Ray'\n",[43,592,593],{"class":45,"line":84},[43,594,81],{"emptyLinePlaceholder":80},[43,596,597],{"class":45,"line":90},[43,598,173],{},[43,600,601],{"class":45,"line":103},[43,602,178],{},[43,604,605],{"class":45,"line":114},[43,606,183],{},[43,608,609],{"class":45,"line":489},[43,610,81],{"emptyLinePlaceholder":80},[43,612,613],{"class":45,"line":495},[43,614,615],{},"dis['name'] # 'Ray'\n",[43,617,618],{"class":45,"line":503},[43,619,620],{},"variable = 'name'\n",[43,622,623],{"class":45,"line":509},[43,624,625],{},"dic[variable] # 'Ray'\n",[16,627,628,629,632],{},"你可以發現上面範例我並沒有使用點運算子來取值，原因是因為 Python 無法像 JavaScript 一樣使用點運算子的方式取值，但是 Python 有一些滿特別且好玩的函式方法可以取值，例如 ",[40,630,631],{},"get()","：",[33,634,636],{"className":145,"code":635,"language":147,"meta":38,"style":38},"dic = {\n  'name': 'Ray',\n}\n\ndic.get('name', 'N\u002FA') # 'Ray'\n",[40,637,638,642,646,650,654],{"__ignoreMap":38},[43,639,640],{"class":45,"line":46},[43,641,173],{},[43,643,644],{"class":45,"line":53},[43,645,178],{},[43,647,648],{"class":45,"line":77},[43,649,183],{},[43,651,652],{"class":45,"line":84},[43,653,81],{"emptyLinePlaceholder":80},[43,655,656],{"class":45,"line":90},[43,657,658],{},"dic.get('name', 'N\u002FA') # 'Ray'\n",[16,660,661,662,664],{},"那這個 ",[40,663,631],{}," 語法有何用途呢？主要可以傳入兩個參數，第一個參數是你預計要取值的屬性名稱，第二個則是如果沒有這個屬性名稱存在時要回傳什麼東西給你，舉例來講：",[33,666,668],{"className":145,"code":667,"language":147,"meta":38,"style":38},"dic = {\n  'name': 'Ray',\n}\n\ndic.get('qq', 'no key') # 'no key'\n",[40,669,670,674,678,682,686],{"__ignoreMap":38},[43,671,672],{"class":45,"line":46},[43,673,173],{},[43,675,676],{"class":45,"line":53},[43,677,178],{},[43,679,680],{"class":45,"line":77},[43,681,183],{},[43,683,684],{"class":45,"line":84},[43,685,81],{"emptyLinePlaceholder":80},[43,687,688],{"class":45,"line":90},[43,689,690],{},"dic.get('qq', 'no key') # 'no key'\n",[16,692,693],{},"我們可以發現這種取值方式可以避免當字典的屬性不存在時的錯誤，而且可以客製化錯誤訊息，是不是相當棒呢？",[16,695,696,697,700],{},"等等，這邊好像一直都沒有提到字典屬性不存在會發生什麼事情對吧？JavaScript 中若我們取一個不存在的物件屬性時，會出現 ",[40,698,699],{},"undefined","，並且還可以繼續執行：",[33,702,704],{"className":35,"code":703,"language":37,"meta":38,"style":38},"var obj = {};\n\nconsole.log(obj.myName); \u002F\u002F undefined\nconsole.log('我執行囉');\n",[40,705,706,717,721,733],{"__ignoreMap":38},[43,707,708,710,712,714],{"class":45,"line":46},[43,709,57],{"class":56},[43,711,95],{"class":60},[43,713,64],{"class":56},[43,715,716],{"class":60}," {};\n",[43,718,719],{"class":45,"line":53},[43,720,81],{"emptyLinePlaceholder":80},[43,722,723,725,727,730],{"class":45,"line":77},[43,724,340],{"class":60},[43,726,344],{"class":343},[43,728,729],{"class":60},"(obj.myName); ",[43,731,732],{"class":49},"\u002F\u002F undefined\n",[43,734,735,737,739,742,745],{"class":45,"line":84},[43,736,340],{"class":60},[43,738,344],{"class":343},[43,740,741],{"class":60},"(",[43,743,744],{"class":70},"'我執行囉'",[43,746,747],{"class":60},");\n",[16,749,750,751,754],{},"但是在 Python 中則會直接中斷程式碼出現 ",[40,752,753],{},"'KeyError: xxx'"," 的錯誤訊息：",[33,756,758],{"className":145,"code":757,"language":147,"meta":38,"style":38},"name = 'myName'\n\ndic = {\n  name: 'Ray',\n}\n\nprint(dic[name])\nprint(dic['qq'])\nprint('我不能執行了')\n",[40,759,760,764,768,772,776,780,784,789,794],{"__ignoreMap":38},[43,761,762],{"class":45,"line":46},[43,763,247],{},[43,765,766],{"class":45,"line":53},[43,767,81],{"emptyLinePlaceholder":80},[43,769,770],{"class":45,"line":77},[43,771,173],{},[43,773,774],{"class":45,"line":84},[43,775,260],{},[43,777,778],{"class":45,"line":90},[43,779,183],{},[43,781,782],{"class":45,"line":103},[43,783,81],{"emptyLinePlaceholder":80},[43,785,786],{"class":45,"line":114},[43,787,788],{},"print(dic[name])\n",[43,790,791],{"class":45,"line":489},[43,792,793],{},"print(dic['qq'])\n",[43,795,796],{"class":45,"line":495},[43,797,798],{},"print('我不能執行了')\n",[16,800,801],{},[224,802],{"alt":803,"src":804},"KeyError","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-26%2020.46.12.png",[16,806,807],{},"好吧，這時候你可能壓力大了，難不成我每次都要先寫好屬性名稱嗎？",[16,809,810],{},[224,811],{"alt":812,"src":813},"壓力大","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-26%2021.06.32.png",[16,815,816],{},"難道沒有一種方式是「當這個值不存在時，就寫入一個預設屬性與值」的方式嗎？",[16,818,819],{},"答案是有的！",[16,821,822,823,826],{},"這時候就要使用 ",[40,824,825],{},"setdefault()"," 這個函式方法，主要也是兩個參數，第一個參數是要設定\u002F取得的屬性名稱，第二個參數則是如果這個屬性不存在時，要預設寫入的值。",[16,828,829,830,833],{},"舉例來講，假使今天這個屬性不存在時，必須出現「",[40,831,832],{},"這是一段話","」：",[33,835,837],{"className":145,"code":836,"language":147,"meta":38,"style":38},"name = 'myName'\n\ndic = {\n  name: 'Ray',\n}\n\nprint(dic[name])\nprint(dic.setdefault('qq', '這是一段話'))\nprint('我不能執行了')\n",[40,838,839,843,847,851,855,859,863,867,872],{"__ignoreMap":38},[43,840,841],{"class":45,"line":46},[43,842,247],{},[43,844,845],{"class":45,"line":53},[43,846,81],{"emptyLinePlaceholder":80},[43,848,849],{"class":45,"line":77},[43,850,173],{},[43,852,853],{"class":45,"line":84},[43,854,260],{},[43,856,857],{"class":45,"line":90},[43,858,183],{},[43,860,861],{"class":45,"line":103},[43,862,81],{"emptyLinePlaceholder":80},[43,864,865],{"class":45,"line":114},[43,866,788],{},[43,868,869],{"class":45,"line":489},[43,870,871],{},"print(dic.setdefault('qq', '這是一段話'))\n",[43,873,874],{"class":45,"line":495},[43,875,798],{},[16,877,878],{},[224,879],{"alt":880,"src":881},"setdefault","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-26%2020.50.59.png",[16,883,884],{},"反之，如果這個屬性已經存在於字典中，那麼它就會走原本本身的值，而不會被覆蓋：",[33,886,888],{"className":145,"code":887,"language":147,"meta":38,"style":38},"name = 'myName'\n\ndic = {\n  name: 'Ray',\n  'qq': '我已經存在囉'\n}\n\nprint(dic[name])\nprint(dic.setdefault('qq', '這是一段話'))\nprint('我不能執行了')\n",[40,889,890,894,898,902,906,911,915,919,923,927],{"__ignoreMap":38},[43,891,892],{"class":45,"line":46},[43,893,247],{},[43,895,896],{"class":45,"line":53},[43,897,81],{"emptyLinePlaceholder":80},[43,899,900],{"class":45,"line":77},[43,901,173],{},[43,903,904],{"class":45,"line":84},[43,905,260],{},[43,907,908],{"class":45,"line":90},[43,909,910],{},"  'qq': '我已經存在囉'\n",[43,912,913],{"class":45,"line":103},[43,914,183],{},[43,916,917],{"class":45,"line":114},[43,918,81],{"emptyLinePlaceholder":80},[43,920,921],{"class":45,"line":489},[43,922,788],{},[43,924,925],{"class":45,"line":495},[43,926,871],{},[43,928,929],{"class":45,"line":503},[43,930,798],{},[16,932,933],{},[224,934],{"alt":880,"src":935},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-06-26%2020.52.34.png",[16,937,938,939,941,942,945],{},"掌握 ",[40,940,880],{}," 之後你也可以用這個方式去針對 ",[40,943,944],{},"qq"," 增加一個字典，也就是巢狀物件的概念：",[33,947,949],{"className":145,"code":948,"language":147,"meta":38,"style":38},"name = 'myName'\n\ndic = {\n  name: 'Ray',\n}\n\nprint(dic[name])\nprint(dic.setdefault('qq', {}))\nprint(dic['qq'].setdefault('sayHi', 'Hello Ray')) # 也可以寫成 dic.setdefault('qq', {}).setdefault('sayHi', 'Hello Ray')\nprint('我不能執行了')\n",[40,950,951,955,959,963,967,971,975,979,984,989],{"__ignoreMap":38},[43,952,953],{"class":45,"line":46},[43,954,247],{},[43,956,957],{"class":45,"line":53},[43,958,81],{"emptyLinePlaceholder":80},[43,960,961],{"class":45,"line":77},[43,962,173],{},[43,964,965],{"class":45,"line":84},[43,966,260],{},[43,968,969],{"class":45,"line":90},[43,970,183],{},[43,972,973],{"class":45,"line":103},[43,974,81],{"emptyLinePlaceholder":80},[43,976,977],{"class":45,"line":114},[43,978,788],{},[43,980,981],{"class":45,"line":489},[43,982,983],{},"print(dic.setdefault('qq', {}))\n",[43,985,986],{"class":45,"line":495},[43,987,988],{},"print(dic['qq'].setdefault('sayHi', 'Hello Ray')) # 也可以寫成 dic.setdefault('qq', {}).setdefault('sayHi', 'Hello Ray')\n",[43,990,991],{"class":45,"line":503},[43,992,798],{},[16,994,995,996,998,999,1001],{},"相信你已經深深了解到 ",[40,997,631],{}," 與 ",[40,1000,825],{}," 兩者美妙之處，那該選擇哪一個使用就留給你思考囉~",[16,1003,1004],{},[224,1005],{"alt":1006,"src":1007},"我該如何選擇","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1629121235164.png",[12,1009,1010],{"id":1010},"作者的話",[16,1012,1013],{},"有朋友問我的花雕醉雞卷是如何製作的，所以就順便分享一下材料，基本上就是 200cc 花雕酒、100cc 米酒(我是天味米酒，你可以考慮紅標米酒)、適量的白胡椒就這麼簡單的材料而已，如果你想加入當歸那些也是可以。",[12,1015,1016],{"id":1016},"關於兔兔們",[131,1018,1019,1027,1035,1043],{},[134,1020,1021],{},[122,1022,1026],{"href":1023,"rel":1024},"https:\u002F\u002Ftailwindcss.tw",[1025],"nofollow","Tailwind CSS 臺灣官網",[134,1028,1029,1034],{},[122,1030,1033],{"href":1031,"rel":1032},"https:\u002F\u002Fwww.facebook.com\u002Ftailwindcss.tw",[1025],"Tailwind CSS 臺灣"," (臉書粉絲專頁)",[134,1036,1037,1042],{},[122,1038,1041],{"href":1039,"rel":1040},"https:\u002F\u002Fwww.facebook.com\u002Fgroups\u002Ftailwindcss.taiwan",[1025],"兔兔教 × Tailwind CSS Taiwan"," (臉書社群)",[134,1044,1045],{},[122,1046,1049],{"href":1047,"rel":1048},"https:\u002F\u002Fwww.facebook.com\u002Flalarabbits-%E5%85%94%E5%85%94%E6%95%99%E5%A4%A7%E6%9C%AC%E7%87%9F-102150975410839\u002F",[1025],"兔兔教大本營",[16,1051,1052],{},[224,1053],{"alt":1054,"src":1055},"兔法無邊","https:\u002F\u002Fi.imgur.com\u002FPwE2UE9.jpg",[1057,1058,1059],"style",{},"html pre.shiki code .sGBqm, html code.shiki .sGBqm{--shiki-light:#6A737D;--shiki-default:#6A737D;--shiki-dark:#BDC4CC}html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shi