o Charles!')\n","py",[27,288,289,294,299,304,308,313,318,323,327,332,337,342,347,353,359,365,370,376,382],{"__ignoreMap":37},[41,290,291],{"class":43,"line":44},[41,292,293],{},"# ch1.py\n",[41,295,296],{"class":43,"line":51},[41,297,298],{},"print(1 + 2)\n",[41,300,301],{"class":43,"line":65},[41,302,303],{},"print(f'Hello Ray!')\n",[41,305,306],{"class":43,"line":79},[41,307,213],{"emptyLinePlaceholder":212},[41,309,310],{"class":43,"line":98},[41,311,312],{},"# ch2.py\n",[41,314,315],{"class":43,"line":107},[41,316,317],{},"print(10 + 23)\n",[41,319,320],{"class":43,"line":118},[41,321,322],{},"print(f'Hello Mike!')\n",[41,324,325],{"class":43,"line":124},[41,326,213],{"emptyLinePlaceholder":212},[41,328,329],{"class":43,"line":134},[41,330,331],{},"# ch3.py\n",[41,333,334],{"class":43,"line":141},[41,335,336],{},"print(12 + 6)\n",[41,338,339],{"class":43,"line":167},[41,340,341],{},"print(f'Hello Ming!')\n",[41,343,345],{"class":43,"line":344},12,[41,346,213],{"emptyLinePlaceholder":212},[41,348,350],{"class":43,"line":349},13,[41,351,352],{},"# ch4.py\n",[41,354,356],{"class":43,"line":355},14,[41,357,358],{},"print(105+ 9)\n",[41,360,362],{"class":43,"line":361},15,[41,363,364],{},"print(f'Hello Jack!')\n",[41,366,368],{"class":43,"line":367},16,[41,369,213],{"emptyLinePlaceholder":212},[41,371,373],{"class":43,"line":372},17,[41,374,375],{},"# ch5.py\n",[41,377,379],{"class":43,"line":378},18,[41,380,381],{},"print(189 + 256)\n",[41,383,385],{"class":43,"line":384},19,[41,386,387],{},"print(f'Hello Charles!')\n",[16,389,390],{},"看起來是不是好像沒有什麼了不起的對吧？那麼你試想一下，當我們如果要使用的的頁面高達 100 頁，那麼勢必你可能要寫相同的程式碼 100 次，當然你也有可能想說，好像也還好一直複製貼上就好了，假設今天你已經複製貼完 100 頁了，然後隔天老闆跟你說要你把 Hello 改成中文是不是又要改一百次？或許你可能會想說：「哼哼，我用取代功能就好了！」，對你真棒！",[16,392,393],{},[394,395],"img",{"alt":396,"src":397},"你真棒","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F1631196405626.png",[16,399,400],{},"阿不是，上面的迷因只是開玩笑而已。",[16