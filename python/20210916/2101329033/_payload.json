"(a wrapper around the executable code for the function).  This\n",[41,1331,1333],{"class":43,"line":1332},24,[41,1334,1335],{},"function object contains a reference to the current global namespace\n",[16,1337,1338],{},"那如果用於我們的模組也可以有類似的效果，但是就不會出現這麼詳細的介紹了：",[32,1340,1342],{"className":284,"code":1341,"language":286,"meta":37,"style":37},"# module.py\ndef add(a, b):\n  return int(a + b)\n\ndef sayHi(name):\n  return f'Hello {name}!'\n\ndic = {\n  'myName': 'Ray',\n}\n\n# example.py\nimport module\n\nprint(help(module))\n",[27,1343,1344,1348,1352,1356,1360,1364,1368,1372,1376,1380,1384,1388,1392,1396,1400],{"__ignoreMap":37},[41,1345,1346],{"class":43,"line":44},[41,1347,648],{},[41,1349,1350],{"class":43,"line":51},[41,1351,653],{},[41,1353,1354],{"class":43,"line":65},[41,1355,658],{},[41,1357,1358],{"class":43,"line":79},[41,1359,213],{"emptyLinePlaceholder":212},[41,1361,1362],{"class":43,"line":98},[41,1363,667],{},[41,1365,1366],{"class":43,"line":107},[41,1367,672],{},[41,1369,1370],{"class":43,"line":118},[41,1371,213],{"emptyLinePlaceholder":212},[41,1373,1374],{"class":43,"line":124},[41,1375,776],{},[41,1377,1378],{"class":43,"line":134},[41,1379,781],{},[41,1381,1382],{"class":43,"line":141},[41,1383,786],{},[41,1385,1386],{"class":43,"line":167},[41,1387,213],{"emptyLinePlaceholder":212},[41,1389,1390],{"class":43,"line":344},[41,1391,681],{},[41,1393,1394],{"class":43,"line":349},[41,1395,686],{},[41,1397,1398],{"class":43,"line":355},[41,1399,213],{"emptyLinePlaceholder":212},[41,1401,1402],{"class":43,"line":361},[41,1403,1404],{},"print(help(module))\n",[16,1406,1407],{},[394,1408],{"alt":1184,"src":1409},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FPython\u002F%E5%BE%9E%20JavaScript%20%E8%A7%92%E5%BA%A6%E5%AD%B8%20Python\u002F%E6%88%AA%E5%9C%96%202021-07-03%2021.34.50.png",[16,1411,1412,1413,1416],{},"這時候或許有人會問該如何像 ",[27,1414,1415],{},"help(def)"," 一樣可以出現說明，其實非常簡單使用註解就可以了：",[32,1418,1420],{"className":284,"code":1419,"language":286,"meta":37,"style":37},"# NAME: 這一行會成為模組的描述說明\n\n# FUNCTIONS: 非常簡單的計算，但回傳會是整數\ndef add(a, b):\n  return int(a + b)\n\n# FUNCTIONS: 這是一個跟人打招呼的方法\ndef sayHi(name):\n  # 註解說明必須放在 def 之前，放在 def 之內不會出現\n  return f'Hello {name}!'\n\n# DATA 類的不會出現註解說明\ndic = {\n  # 就算寫在這裡也一樣\n  'myName': 'Ray',\n}\n\n# example.py\nimport module\n\nprint(help(module))\n",[27,1421,1422,1427,1431,1436,1440,1444,1448,1453,1457,1462,1466,1470,1475,1479,1484,1488,1492,1496,1500,1504,1508],{"__ignoreMap":37},[41,1423,1424],{"class":43,"line":44},[41,1425,1426],{},"# NAME: 這一行會成為模組的描述說明\n",[41,1428,1429],{"class":43,"line":51},[41,1430,213],{"emptyLinePlaceholder":212},[41,1432,1433],{"class":43,"line":65},[41,1434,1435],{},"# FUNCTIONS: 非常簡單的計算，但回傳會是整數\n",[41,1437,1438],{"class":43,"line":79},[41,1439,653],{},[41,1441,1442],{"class":43,"line":98},[41,1443,658],{},[41,1445,1446],{"class":43,"line":107},[41,1447,213],{"emptyLinePlaceholder":212},[41,1449,1450],{"class":43,"line":118},[41,1451,1452],{},"# FUNCTIONS: 這是一個跟人打招呼的方法\n",[41,1454,1455],{"class":43,"line":124},[41,1456,667],{},[41,1458,1459],{"class":43,"line":134},[41,1460,1461],{},"  # 註解說明必須放在 def 之前，放在 def 之內不會出現\n",[41,1463,1464],{"class":43,"line":141},[41,1465,672],{},[41,1467,1468],{"class":43,"line":167},[41,1469,213],{"emptyLinePlaceholder":212},[41,1471,1472],{"class":43,"line":344},[41,1473,1474],{},"# DATA 類的不會出現註解說明\n",[41,1476,1477],{"class":43,"line":349},[41,1478,776],{},[41,1480,1481],{"class":43,"line":355},[41,1482,1483],{},"  # 就算寫在這裡也一樣\n",[41,1485,1486],{"class":43,"line":361},[41,1487,781],{},[41,1489,1490],{"class":43,"line":367},[41,1491,786],{},[41,1493,1494],{"class":43,"line":372},[41,1495,213],{"emptyLinePlaceholder":212},[41,1497,1498],{"class":43,"line":378},[41,1499,681],{},[41,1501,1502],{"class":43,"line":384},[41,1503,686],{},[41,1505,1506],{"class":43,"line":1309},[41,1507,213],{"emptyLinePlaceholder":212},[41,1509,1510],{"class":43,"line":1314},[41,1511,1404],{},[16,1513,1514,1515,1517,1518,1520,1521],{}