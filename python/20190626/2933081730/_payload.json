[{"data":1,"prerenderedAt":282},["ShallowReactive",2],{"header-locale:\u002Fpython\u002F20190626\u002F2933081730\u002F":3,"page:\u002Fpython\u002F20190626\u002F2933081730\u002F":4,"alt:\u002Fpython\u002F20190626\u002F2933081730\u002F":3,"prev-next:\u002Fpython\u002F20190626\u002F2933081730\u002F":258,"related:\u002Fpython\u002F20190626\u002F2933081730\u002F":267},"\u002Fen\u002Fpython\u002F2019\u002F06\u002F26\u002Fdrag-and-drop-video-cmd-python-subtitles\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":240,"date":241,"description":242,"extension":243,"lang":244,"meta":245,"navigation":246,"path":247,"readingMinutes":248,"seo":249,"standalone":250,"stem":251,"tags":252,"tldr":255,"updated":255,"url":256,"__hash__":257},"content\u002FPython\u002F拖曳影片到-CMD-圖示內透過-Python-生成影片字幕.md","拖曳影片檔案到 CMD 圖示內透過 Python 生成影片字幕","2933081730",{"type":9,"value":10,"toc":235},"minimark",[11,15,24,32,35,38,41,124,131,140,144,147,156,159,162,168,171,177,180,215,218,224,231],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,23],"p",{},"由於先前撰寫了",[20,21,22],"span",{},"使用 Python 替影片自動上字幕","的文章，後來自己在使用的時候每一次都要打開指令視窗輸入指令，對於金魚腦的我來講實在很不方便，所以這邊稍微製作 .bat 檔案，直接拖曳進去自動生成字幕。",[16,25,26,27],{},"如果想要透過 Python 生成字幕可以看我先前所撰寫的文章 ",[28,29,31],"a",{"href":30},"\u002Fpython\u002F20190531\u002F4077454772\u002F","使用 Python 替影片自動產生字幕 srt 檔",[12,33,34],{"id":34},"起手式",[16,36,37],{},"首先要製作這個 bat 檔案之前要先認識一些指令，否則會不知道該如何執行",[16,39,40],{},"CMD 我這邊會使用到的基礎指令認識",[42,43,48],"pre",{"className":44,"code":45,"language":46,"meta":47,"style":47},"language-cmd shiki shiki-themes github-dark-high-contrast","@echo off \u002F\u002F 開啟輸出\necho 無字尾名： %~n1\necho 有字尾名： %~nx1\necho 絕對路徑： %1\necho 短路徑名的絕對路徑： %~s1\necho 驅動器和路徑： %~dp1\necho 驅動器： %~d1\necho 路徑： %~p1\necho 檔案屬性： %~a1\necho 日期\u002F時間： %~t1\necho 檔案大小： %~z1\npause \u002F\u002F 按下隨意按鈕關閉視窗\n","cmd","",[49,50,51,58,64,70,76,82,88,94,100,106,112,118],"code",{"__ignoreMap":47},[20,52,55],{"class":53,"line":54},"line",1,[20,56,57],{},"@echo off \u002F\u002F 開啟輸出\n",[20,59,61],{"class":53,"line":60},2,[20,62,63],{},"echo 無字尾名： %~n1\n",[20,65,67],{"class":53,"line":66},3,[20,68,69],{},"echo 有字尾名： %~nx1\n",[20,71,73],{"class":53,"line":72},4,[20,74,75],{},"echo 絕對路徑： %1\n",[20,77,79],{"class":53,"line":78},5,[20,80,81],{},"echo 短路徑名的絕對路徑： %~s1\n",[20,83,85],{"class":53,"line":84},6,[20,86,87],{},"echo 驅動器和路徑： %~dp1\n",[20,89,91],{"class":53,"line":90},7,[20,92,93],{},"echo 驅動器： %~d1\n",[20,95,97],{"class":53,"line":96},8,[20,98,99],{},"echo 路徑： %~p1\n",[20,101,103],{"class":53,"line":102},9,[20,104,105],{},"echo 檔案屬性： %~a1\n",[20,107,109],{"class":53,"line":108},10,[20,110,111],{},"echo 日期\u002F時間： %~t1\n",[20,113,115],{"class":53,"line":114},11,[20,116,117],{},"echo 檔案大小： %~z1\n",[20,119,121],{"class":53,"line":120},12,[20,122,123],{},"pause \u002F\u002F 按下隨意按鈕關閉視窗\n",[16,125,126],{},[127,128],"img",{"alt":129,"src":130},"基礎指令認識","https:\u002F\u002Fi.imgur.com\u002FEfL2iO4.png",[16,132,133,134],{},"以上出處",[28,135,139],{"href":136,"rel":137},"https:\u002F\u002Fcodertw.com\u002F%E5%89%8D%E7%AB%AF%E9%96%8B%E7%99%BC\u002F388796\u002F",[138],"nofollow","通過拖曳獲取檔案資訊的 bat 程式碼分享",[12,141,143],{"id":142},"python-auto-sub-指令","Python auto sub 指令",[16,145,146],{},"原本指令是這樣子",[42,148,150],{"className":44,"code":149,"language":46,"meta":47,"style":47},"C:\\Python27\\python.exe C:\\Python27\\scripts\\autosub_app.py -S zh-TW -D zh-TW [影片路徑]\n",[49,151,152],{"__ignoreMap":47},[20,153,154],{"class":53,"line":54},[20,155,149],{},[16,157,158],{},"所以這邊建立一個檔案，名稱叫做 'autosub.bat'",[16,160,161],{},"然後尾段原本影片路徑的部分，寫 %1\n(千萬不要寫 %~s1，這會出現錯誤)",[16,163,164],{},[127,165],{"alt":166,"src":167},"Python auto sub","https:\u002F\u002Fi.imgur.com\u002FLpbbax6.png",[16,169,170],{},"這樣就可以將檔案拖曳到 autosub.bat 檔案上自動生成字幕哩~",[16,172,173],{},[127,174],{"alt":175,"src":176},"autosub.bat","https:\u002F\u002Fi.imgur.com\u002FaqAY1fj.png",[16,178,179],{},"我稍微針對裡面 .bat 優化了一下，內容大概是這樣子",[42,181,183],{"className":44,"code":182,"language":46,"meta":47,"style":47},"@echo off\necho 準備生成字幕...\necho 生成字幕的影片檔案名稱: %~nx1\nC:\\Python27\\python.exe C:\\Python27\\scripts\\autosub_app.py -S zh-TW -D zh-TW %1\necho 生成完成路徑: %~p1\npause\n",[49,184,185,190,195,200,205,210],{"__ignoreMap":47},[20,186,187],{"class":53,"line":54},[20,188,189],{},"@echo off\n",[20,191,192],{"class":53,"line":60},[20,193,194],{},"echo 準備生成字幕...\n",[20,196,197],{"class":53,"line":66},[20,198,199],{},"echo 生成字幕的影片檔案名稱: %~nx1\n",[20,201,202],{"class":53,"line":72},[20,203,204],{},"C:\\Python27\\python.exe C:\\Python27\\scripts\\autosub_app.py -S zh-TW -D zh-TW %1\n",[20,206,207],{"class":53,"line":78},[20,208,209],{},"echo 生成完成路徑: %~p1\n",[20,211,212],{"class":53,"line":84},[20,213,214],{},"pause\n",[16,216,217],{},"結果會像這樣子，比較直覺一點。",[16,219,220],{},[127,221],{"alt":222,"src":223},"CMD","https:\u002F\u002Fi.imgur.com\u002FlM41Cn2.png",[16,225,226,227,230],{},"如果希望可以生成完就自動關閉視窗的話，僅需要去除 ",[49,228,229],{},"pause"," 即可。",[232,233,234],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":47,"searchDepth":60,"depth":60,"links":236},[237,238,239],{"id":14,"depth":60,"text":14},{"id":34,"depth":60,"text":34},{"id":142,"depth":60,"text":143},"Python","2019-06-26 10:13:30","由於先前撰寫了[使用 Python 替影片自動上字幕]的文章，後來自己在使用的時候每一次都要打開指令視窗輸入指令，對於金魚腦的我來講實在很不方便，所以這邊稍微製作 .bat 檔案，直接拖曳進去自動生成字幕。","md","zh-Hant",{},true,"\u002Fpython\u002Fcmd-python","1",{"title":6,"description":242},false,"Python\u002F拖曳影片到-CMD-圖示內透過-Python-生成影片字幕",[240,253,254],"AI","字幕",null,"\u002Fpython\u002F20190626\u002F2933081730\u002F","E5B6mEDSsH_WKgKJxVYXqzZS9Fmv2CtVypQ2PG_3EfM",{"newer":259,"older":263},{"url":260,"t