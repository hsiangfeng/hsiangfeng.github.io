[{"data":1,"prerenderedAt":232},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20200723\u002F3866554212\u002F":3,"page:\u002Fother\u002F20200723\u002F3866554212\u002F":4,"alt:\u002Fother\u002F20200723\u002F3866554212\u002F":3,"prev-next:\u002Fother\u002F20200723\u002F3866554212\u002F":207,"related:\u002Fother\u002F20200723\u002F3866554212\u002F":216},"\u002Fen\u002Fmisc\u002F2020\u002F07\u002F23\u002Fclear-browser-hsts-https-localhost-redirect-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":186,"date":187,"description":188,"extension":189,"lang":190,"meta":191,"navigation":192,"path":193,"readingMinutes":194,"seo":195,"standalone":196,"stem":197,"tags":198,"tldr":204,"updated":204,"url":205,"__hash__":206},"content\u002F雜談\u002F解決-Chrome-Firefox-或-Edge-等瀏覽器強制跳轉-HTTPS-網址問題.md","解決 Chrome 、 Firefox 或 Edge 等瀏覽器強制跳轉 HTTPS 網址問題","3866554212",{"type":9,"value":10,"toc":173},"minimark",[11,15,19,22,30,46,52,55,65,80,86,89,92,95,98,103,110,116,122,125,131,135,145,149,160,163],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"身為一名網頁工程師在開發時，往往很常使用 localhost 或是 127.0.0.1 來開發，但是有時候我們會發生一些很奇怪的狀況，例如：瀏覽器一直強制你走 https 或是出現「這個網站無法提供安全連線」等問題，所以這一篇就來紀錄一下如何解決。",[12,20,21],{"id":21},"問題原因",[16,23,24,25,29],{},"以下我個人「",[26,27,28],"strong",{},"不太建議隨便嘗試","」，避免你發生不會處理的狀況，因此該篇建議你有遇到再使用。",[16,31,32,33,37,38,41,42,45],{},"首先你可以先試著在瀏覽器網址列上輸入 ",[34,35,36],"code",{},"https:\u002F\u002Flocalhost\u002F"," 或是開發常用的 ",[34,39,40],{},"https:\u002F\u002Flocalhost:8080"," 等等網址，接下來你應該就會看到 「localhost 拒絕連線」、「這個網站無法提供安全連線」、「localhost 傳送的回應無效」等錯誤訊息，並且下方錯誤代碼是「",[34,43,44],{},"ERR_SSL_PROTOCOL_ERROR","」，當你看到這個畫面時，首先恭喜你成功還原狀況了。",[16,47,48],{},[49,50],"img",{"alt":44,"src":51},"https:\u002F\u002Fi.imgur.com\u002FH8aXd9W.png",[16,53,54],{},"但是如果你看到的錯誤訊息是「ERR_CONNECTION_REFUSED」的話倒是還好，因為有可能只是你的伺服器忘記開啟而已。",[16,56,57,58,60,61,64],{},"因此如果是「",[34,59,44],{},"」的話，這會導致你在開發時，某些 GUI 工具無法進入，例如： ",[34,62,63],{},"vue ui","。",[16,66,67,68,71,72,75,76,79],{},"因為會出現「localhost 拒絕連線」、「這個網站無法提供安全連線」、「localhost 傳送的回應無效」這幾個錯誤訊息，而這個問題就是 ",[34,69,70],{},"https"," 在搞鬼，接下來你不管怎麼輸入非 https 的網址，例如： ",[34,73,74],{},"http:\u002F\u002Flocalhost\u002F","、",[34,77,78],{},"http:\u002F\u002Flocalhost:8080"," 你會發現永遠都是進入到 「這個網站無法提供安全連線」的畫面。",[16,81,82],{},[49,83],{"alt":84,"src":85},"這個網站無法提供安全連線","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202020-07-23%2014.08.31.png",[16,87,88],{},"這種狀況主要是出在瀏覽器的本身的一個機制，稱之為 HTTP Strict Transport Security。",[16,90,91],{},"簡單來講只要你曾經訪問過 https 的網站，那麼瀏覽器之後就會記憶在 https，因為 HTTP Strict Transport Security 又稱之為「HTTP 強制安全傳輸技術」，因此 localhost 或是 127.0.0.1 也是有可能發生的唷。",[12,93,94],{"id":94},"解決方式",[16,96,97],{},"那麼該怎麼解決呢？接下來我會列出一些常見的瀏覽器解決方式。",[99,100,102],"h3",{"id":101},"google-chrome","Google Chrome",[16,104,105,106,109],{},"首先開啟 Chrome 瀏覽器，並在網址列輸入 ",[34,107,108],{},"chrome:\u002F\u002Fnet-internals\u002F#hsts","，接下來下方有一個選項是「Delete domain security policies」，然後在底下輸入框輸入你要清除 https 的網域",[16,111,112],{},[49,113],{"alt":114,"src":115},"Delete domain security policies","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202020-07-23%2014.28.27.png",[16,117,118,119,121],{},"當你按下 「Delete」 之後你會發現好像什麼事情都沒發生一樣，這時候你再去輸入「",[34,120,74],{},"」你就會發現可以進入囉。",[16,123,124],{},"如果你不確定你的瀏覽器到底有沒有亂記憶 https 的話，可以透過「Query HSTS\u002FPKP domain」來查詢也可以",[16,126,127],{},[49,128],{"alt":129,"src":130},"Google","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202020-07-23%2014.29.21.png",[12,132,134],{"id":133},"microsoft-edge","Microsoft Edge",[16,136,137,138,140,141,144],{},"而身為包著 Chrome 核心的 Microsoft Edge 處理方式也很雷同，但瀏覽器上輸入稍微不太一樣，在 Chrome 是輸入 ",[34,139,108],{},"，可是在 Microsoft Edge 是輸入 ",[34,142,143],{},"edge:\u002F\u002Fnet-internals\u002F#hsts","，這邊操作方式與上面相同，因此就不截圖囉。",[12,146,148],{"id":147},"firefox","Firefox",[16,150,151,152,159],{},"Firefox 就簡單非常多，直接刪除歷史資料就可以了，詳細可以看",[153,154,158],"a",{"href":155,"rel":156},"https:\u002F\u002Fwww.thesslstore.com\u002Fblog\u002Fclear-hsts-settings-chrome-firefox\u002F",[157],"nofollow","這一篇","文章。",[12,161,162],{"id":162},"參考文獻",[164,165,166],"ul",{},[167,168,169],"li",{},[153,170,172],{"href":155,"rel":171},[157],"Re-Hashed: How to clear HSTS settings in Chrome and Firefox",{"title":174,"searchDepth":175,"depth":175,"links":176},"",2,[177,178,179,183,184,185],{"id":14,"depth":175,"text":14},{"id":21,"depth":175,"text":21},{"id":94,"depth":175,"text":94,"children":180},[181],{"id":101,"depth":182,"text":102},3,{"id":133,"depth":175,"text":134},{"id":147,"depth":175,"text":148},{"id":162,"depth":175,"text":162},"雜談","2020-07-23 13:56:29","身為一名網頁工程師在開發時，往往很常使用 localhost 或是 127.0.0.1 來開發，但是有時候我們會發生一些很奇怪的狀況，例如：瀏覽器一直強制你走 https 或是出現「這個網站無法提供安全連線 localhost 傳送的回應無效。」等問題，所以這一篇就來紀錄一下如何解決。","md","zh-Hant",{},true,"\u002Fchrome-firefox-edge-https","2",{"title":6,"description":188},false,"雜談\u002F解決-Chrome-Firefox-或-Edge-等瀏覽器強制跳轉-HTTPS-網址問題",[199,200,201,202,148,203],"障礙排除","瀏覽器","Chrome","Edge","localhost 拒絕連線",null,"\u002Fother\u002F20200723\u002F3866554212\u002F","PdGWtIEJLmkt5eO4kfSnbrxtHUBMrTZGp0zrCPuqf8Y",{"newer":208,"older":212},{"url":209,"title":210,"date":211},"\u002Fjavascript\u002F20200726\u002F2777973914\u002F","JavaScript 核心觀念(23)-物件-額外補充：變數及物件屬性的差異","2020-07-26 15:35:31",{"url":213,"title":214,"date":215},"\u002Fjavascript\u002F20200721\u002F1935618580\u002F","PixiJS V5 教學 (24) - AnimatedSprite","2020-07-21 20:49:21",[217,222,227],{"url":218,"title":219,"date":220,"readingMinutes":221},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":223,"title":224,"date":225,"readingMinutes":226},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":228,"title":229,"date":230,"readingMinutes":231},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784087365658]