[{"data":1,"prerenderedAt":107},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20210606\u002F3839486239\u002F":3,"page:\u002Fother\u002F20210606\u002F3839486239\u002F":4,"alt:\u002Fother\u002F20210606\u002F3839486239\u002F":3,"prev-next:\u002Fother\u002F20210606\u002F3839486239\u002F":82,"related:\u002Fother\u002F20210606\u002F3839486239\u002F":91},"\u002Fen\u002Fmisc\u002F2021\u002F06\u002F06\u002Fmac-windows-window-off-screen-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":66,"date":67,"description":18,"extension":68,"lang":69,"meta":70,"navigation":71,"path":72,"readingMinutes":73,"seo":74,"standalone":75,"stem":76,"tags":77,"tldr":79,"updated":79,"url":80,"__hash__":81},"content\u002F雜談\u002FMac-或是-Window-視窗跑出螢幕之外的解決方式.md","Mac 或是 Window 視窗跑出螢幕之外的解決方式","3839486239",{"type":9,"value":10,"toc":59},"minimark",[11,15,19,23,31,38,46,50,53],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近一直發生一種狀況，就是視窗跑出螢幕之外，所以這一篇紀錄一下解決方式。",[12,20,22],{"id":21},"window","Window",[16,24,25,26,30],{},"Window 算是非常好解決這個問題，基本上如果你的視窗，不論是 Chrome、Office 還是各式各樣的小框框，只要跑出螢幕範圍之外，你可以針對該視窗按下組合按鈕 ",[27,28,29],"code",{},"ALT + 空白鍵"," 這時候會跳出選取視窗(請務必先選取該視窗在按下組合鍵，否則你叫不出來的)",[16,32,33],{},[34,35],"img",{"alt":36,"src":37},"選取視窗","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202106062228.png",[16,39,40,41,45],{},"然後用方向鍵(上下左右)選取「移動」，切記當你選取移動之後",[42,43,44],"strong",{},"不要使用滑鼠去移動視窗","，當你選取移動之後，請任意按一下方向鍵來移動視窗，這時候就可以直接移動滑鼠移動出跑出螢幕範圍的視窗囉。",[12,47,49],{"id":48},"mac","Mac",[16,51,52],{},"Mac 就沒有選取視窗可以使用，因此最簡單的方式就是直接按下 Command + Q 兩次強制關閉重開畫面就會回到螢幕中，但是有些時候並不希望關閉視窗，所以可以點一下上方「視窗」 > 「縮放」，這樣子就可以解決了",[16,54,55],{},[34,56],{"alt":57,"src":58},"縮放","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-06-06%2022.34.05.png",{"title":60,"searchDepth":61,"depth":61,"links":62},"",2,[63,64,65],{"id":14,"depth":61,"text":14},{"id":21,"depth":61,"text":22},{"id":48,"depth":61,"text":49},"雜談","2021-06-06 22:13:12","md","zh