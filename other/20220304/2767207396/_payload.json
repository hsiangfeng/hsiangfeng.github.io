[{"data":1,"prerenderedAt":185},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220304\u002F2767207396\u002F":3,"page:\u002Fother\u002F20220304\u002F2767207396\u002F":4,"alt:\u002Fother\u002F20220304\u002F2767207396\u002F":3,"prev-next:\u002Fother\u002F20220304\u002F2767207396\u002F":160,"related:\u002Fother\u002F20220304\u002F2767207396\u002F":169},"\u002Fen\u002Fmisc\u002F2022\u002F03\u002F04\u002Fclear-line-link-preview-cache-with-page-poker\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":141,"date":142,"description":18,"extension":143,"lang":144,"meta":145,"navigation":146,"path":147,"readingMinutes":148,"seo":149,"standalone":150,"stem":151,"tags":152,"tldr":157,"updated":157,"url":158,"__hash__":159},"content\u002F雜談\u002F清除-LINE-的連結預覽緩存.md","清除 LINE 的連結預覽緩存","2767207396",{"type":9,"value":10,"toc":134},"minimark",[11,15,19,22,33,39,42,45,48,54,57,60,67,71,79,84,87,93,96,102,109,115,121,128],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"其實 LINE 使用率非常高，也有相當多的服務使用 LINE 作為分享的管道，可是我們會注意到開發好後的頁面一旦分享到 LINE 之後，要再次修改好像就只能等 LINE 自己清除緩存，所以這一篇就紀錄一下該如何解決這個問題。",[12,20,21],{"id":21},"連結預覽",[16,23,24,25,32],{},"其實連結預覽這件事情對於行銷人員來講非常非常重要，所以 Facebook 本身也有提供一個「",[26,27,31],"a",{"href":28,"rel":29},"https:\u002F\u002Fdevelopers.facebook.com\u002Ftools\u002Fdebug\u002F",[30],"nofollow","分享偵錯工具","」",[16,34,35],{},[36,37],"img",{"alt":31,"src":38},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2012.58.56.png",[16,40,41],{},"透過該工具我們可以知道自己的網站連結分享到社群時是什麼樣子，並且也可以要求臉書重新抓取，因此非常方便。",[16,43,44],{},"那 LINE 呢？LINE 也有這種工具嗎？其實早期沒有，所以你只能試著將連結往 LINE 那邊丟進而了解目前連結預覽狀況。",[16,46,47],{},"但是問題來了，當你的網站臨時需要更新連結預覽時，你會發現你不管怎麼更新或者重新丟連結，LINE 永遠都是保持舊的樣子",[16,49,50],{},[36,51],{"alt":52,"src":53},"舊的預覽連結","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.02.42.png",[16,55,56],{},"雖然過段時間就會自動更新成新版的預覽連結，但是對於行銷人來講，那三十分鐘可以說是黃金三十分鐘。",[16,58,59],{},"因此為了解決 LINE 緩存預覽連結的問題，我們可以使用 LINE 所提供的「Page Poker」服務",[16,61,62,63],{},"連結點我：",[26,64,65],{"href":65,"rel":66},"http:\u002F\u002Fpoker.line.naver.jp\u002F",[30],[12,68,70],{"id":69},"line-page-poker","LINE Page Poker",[16,72,73,74,78],{},"使用方式非常簡單，透過剛剛的連結進入到「",[26,75,77],{"href":65,"rel":76},[30],"Page Poker","」服務頁面，頁面很單調很正常",[16,80,81],{},[36,82],{"alt":77,"src":83},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.05.36.png",[16,85,86],{},"接下來將你想要清除緩存的網址放上去，並且選擇語系、地區跟勾選 Clear Cache",[16,88,89],{},[36,90],{"alt":91,"src":92},"Clear Cache","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.07.04.png",[16,94,95],{},"最後按下送出即可，接下來你在試著將連結丟到 LINE 上面就會是呈現新版的預覽連結囉",[16,97,98],{},[36,99],{"alt":100,"src":101},"新的預覽連結","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.07.58.png",[16,103,104,105,108],{},"除此之外 ",[26,106,77],{"href":65,"rel":107},[30]," 也可以看連結預覽狀況，就跟臉書的一樣",[16,110,111],{},[36,112],{"alt":113,"src":114},"LINE 連結預覽","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.08.59.png",[16,116,117],{},[36,118],{"alt":119,"src":120},"Facebook 連結預覽","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.09.13.png",[16,122,123,124,127],{},"ps. 如果你想清除 Facebook 連結預覽的緩存的話，也是使用 「",[26,125,31],{"href":28,"rel":126},[30],"」，然後按下再次抓取就可以了",[16,129,130],{},[36,131],{"alt":132,"src":133},"Facebook 連結預覽的緩存","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-03-04%2013.11.17.png",{"title":135,"searchDepth":136,"depth":136,"links":137},"",2,[138,139,140],{"id":14,"depth":136,"text":14},{"id":21,"depth":136,"text":21},{"id":69,"depth":136,"text":70},"雜談","2022-03-04 12:54:09","md","zh-Hant",{},true,"\u002Fline","1",{"title":6,"description":18},false,"雜談\u002F清除-LINE-的連結預覽緩