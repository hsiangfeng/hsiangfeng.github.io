[{"data":1,"prerenderedAt":203},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20190614\u002F1907905725\u002F":3,"page:\u002Fother\u002F20190614\u002F1907905725\u002F":4,"alt:\u002Fother\u002F20190614\u002F1907905725\u002F":3,"prev-next:\u002Fother\u002F20190614\u002F1907905725\u002F":178,"related:\u002Fother\u002F20190614\u002F1907905725\u002F":187},"\u002Fen\u002Fmisc\u002F2019\u002F06\u002F14\u002Fuser-story-for-frontend-development\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":161,"date":162,"description":18,"extension":163,"lang":164,"meta":165,"navigation":166,"path":167,"readingMinutes":168,"seo":169,"standalone":170,"stem":171,"tags":172,"tldr":175,"updated":175,"url":176,"__hash__":177},"content\u002F雜談\u002F前端開發的-User-Story.md","前端開發的 User Story","1907905725",{"type":9,"value":10,"toc":154},"minimark",[11,15,19,22,25,33,36,43,46,60,67,70,96,101,104,107,112,115,118,121,135,138,143,146,151],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"先前稍微瞭解過 User Story，但是這幾天實際 run 一次的時候卻發現一件很重要的事情，以往我在後端開發的時候都是以功能來考量...",[12,20,6],{"id":21},"前端開發的-user-story",[16,23,24],{},"這幾天跟著公司跑一次小型專案，第一次感覺到顛覆了我的想法，因為早期我在開發是屬於以功能面為優先的人，舉凡某某某功能要什麼樣的功能、會需要什麼資料庫欄位、然後可以做到怎樣...",[16,26,27,28,32],{},"但是實際討論一下之後才發現 User Story 的運作模式完全是反過來的，User Story 中文叫做使用者故事，過程中專案所看的角度並不是需要什麼功能而是",[29,30,31],"strong",{},"使用者需要什麼","，所以並不是先做功能，完全以使用者會需要哪些功能來討論為主，以人力銀行來舉例",[16,34,35],{},"User Story 會先列出一個簡單的一句話，然後無限延伸討論",[37,38,39],"ul",{},[40,41,42],"li",{},"求職者需要一個刊登履歷的地方",[16,44,45],{},"接下來依照這一句話開始推敲求職者可能會需要那些功能",[37,47,48,51,54,57],{},[40,49,50],{},"履歷撰寫",[40,52,53],{},"關閉特定產業找到我",[40,55,56],{},"求職者曝光",[40,58,59],{},"上傳作品\n...(剛開始真的不太習慣，想不到很多什麼東西)",[16,61,62],{},[63,64],"img",{"alt":65,"src":66},"Image","https:\u002F\u002Fi.imgur.com\u002FfrI2kGX.png",[16,68,69],{},"接下來再來討論求職者的履歷會需要那些欄位",[37,71,72,75,78,81,84,87,90,93],{},[40,73,74],{},"姓名",[40,76,77],{},"連絡電話",[40,79,80],{},"Email",[40,82,83],{},"居住地",[40,85,86],{},"求職地",[40,88,89],{},"專長",[40,91,92],{},"技能",[40,94,95],{},"應徵職缺\n...",[16,97,98],{},[63,99],{"alt":65,"src":100},"https:\u002F\u002Fi.imgur.com\u002FJZcwfiz.png",[16,102,103],{},"然後擬出刊登流程",[16,105,106],{},"填寫履歷 → 打開履歷狀態 → 曝光職缺",[16,108,109],{},[63,110],{"alt":65,"src":111},"https:\u002F\u002Fi.imgur.com\u002FhTQaiKr.png",[12,113,114],{"id":114},"後端開發",[16,116,117],{},"那後端開發呢?後端就有點不一樣思考邏輯",[16,119,120],{},"首先直接思考功能需要那些",[37,122,123,126,129,132],{},[40,124,125],{},"新增履歷",[40,127,128],{},"修改履歷",[40,130,131],{},"刪除履歷",[40,133,134],{},"履歷狀態",[16,136,137],{},"接下來就會考慮資料庫欄位會需要哪些",[16,139,140],{},[63,141],{"alt":65,"src":142},"https:\u002F\u002Fi.imgur.com\u002F3fhZS2N.png",[16,144,145],{},"然後針對每一個欄位可能的型別作定義(很久沒規劃資料庫了，大致上忘記了QQ)...",[16,147,148],{},[63,149],{"alt":65,"src":150},"https:\u002F\u002Fi.imgur.com\u002FWJ2Xpc3.png",[16,152,153],{},"先到這邊為止，因為對於 User Story 的開發模式並不是很熟悉，所以先記錄到這樣。",{"title":155,"searchDepth":156,"depth":156,"links":157},"",2,[158,159,160],{"id":14,"depth":156,"text":14},{"id":21,"depth":156,"text":6},{"id":114,"depth":156,"text":114},"雜談","2019-06-14 21:07:23","md","zh-Hant",{},true,"\u002Fuser-story","1",{"title":6,"description":18},false,"雜談\u002F前端開發的-User-Story",[173,174],"User story","User stories",null,"\u002Fother\u002F20190614\u002F1907905725\u002F","6wLSDXPX2LqoDJ1Obqrpg8OViNjXVwOxVCwFw73XgOw",{"newer":179,"older":183},{"url":180,"title":181,"date":182},"\u002Fgit\u002F20190614\u002F391412804\u002F","fatal: unable to access XXx The requested URL returned error: 403","2019-06-14 21:38:14",{"url":184,"title":185,"date":186},"\u002Fjavascript\u002F20190614\u002F4085828838\u002F","ES6 Template String 雙陣列處理方式","2019-06-14 20:11:14",[188,193,198],{"url":189,"title":190,"date":191,"readingMinutes":192},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":194,"title":195,"date":196,"readingMinutes":197},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":199,"title":200,"