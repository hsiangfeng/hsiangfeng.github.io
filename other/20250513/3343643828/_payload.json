trong",{},"Note","\n有的人會說 ",[27,52,17],{}," 或者是 ",[27,55,56],{},"cURL","，本篇統一稱為 ",[27,59,17],{},"。",[12,62,63,64],{},"許多的工具其實都可以看到它的身影，這邊舉例六角學院所提供的 ",[65,66,70],"a",{"href":67,"rel":68},"https:\u002F\u002Fhexschool.github.io\u002Fec-courses-api-swaggerDoc\u002F#\u002F",[69],"nofollow","Swagger API 文件",[12,72,73],{},[15,74],{"alt":75,"src":76},"Swagger API 測試工具","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002F20250514214238.png",[12,78,79],{},"底下可以看到有一段：",[81,82,87],"pre",{"className":83,"code":84,"language":85,"meta":86,"style":86},"language-bash shiki shiki-themes github-dark-high-contrast","curl -X 'POST' \\\n  'https:\u002F\u002Fec-course-api.hexschool.io\u002Fv2\u002Fadmin\u002Fsignin' \\\n  -H 'accept: application\u002Fjson' \\\n  -H 'Content-Type: application\u002Fjson' \\\n  -d '{\n  \"username\": \"example@test.com\",\n  \"password\": \"example\"\n}'\n","bash","",[27,88,89,109,117,128,138,147,153,159],{"__ignoreMap":86},[90,91,94,97,101,105],"span",{"class":92,"line":93},"line",1,[90,95,17],{"class":96},"s_sBn",[90,98,100],{"class":99},"sCcAr"," -X",[90,102,104],{"class":103},"sTRMh"," 'POST'",[90,106,108],{"class":107},"sWyjQ"," \\\n",[90,110,112,115],{"class":92,"line":111},2,[90,113,114],{"class":103},"  'https:\u002F\u002Fec-course-api.hexschool.io\u002Fv2\u002Fadmin\u002Fsignin'",[90,116,108],{"class":107},[90,118,120,123,126],{"class":92,"line":119},3,[90,121,122],{"class":99},"  -H",[90,124,125],{"class":103}," 'accept: application\u002Fjson'",[90,127,108],{"class":107},[90,129,131,133,136],{"class":92,"line":130},4,[90,132,122],{"class":99},[90,134,135],{"class":103}," 'Content-Type: application\u002Fjson'",[90,137,108],{"class":107},[90,139,141,144],{"class":92,"line":140},5,[90,142,143],{"class":99},"  -d",[90,145,146],{"class":103}," '{\n",[90,148,150],{"class":92,"line":149},6,[90,151,152],{"class":103},"  \"username\": \"example@test.com\",\n",[90,154,156],{"class":92,"line":155},7,[90,157,158],{"class":103},"  \"password\": \"example\"\n",[90,160,162],{"class":92,"line":161},8,[90,163,164],{"class":103},"}'\n",[12,166,167],{},"這段可以直接複製貼上到終端機使用",[12,169,170],{},[15,171],{"alt":172,"src":173},"終端機","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002F20250514214527.png",[12,175,176,177,182,183,186],{},"還有哪些地方可以看到它的身影呢？像是 ",[65,178,181],{"href":179,"rel":180},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20211207\u002F427026\u002F",[69],"Postman"," 這個 API 測試工具，當你在 Postman 測試完 API 後，點擊 ",[27,184,185],{},"Code"," 按鈕，就可以看到 curl 的語法了",[12,188,189],{},[15,190],{"alt":181,"src":191},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002F20250514214815.png",[12,193,194],{},"所以接下來我們就來認識一下 curl 該如何使用吧！",[20,196,198],{"id":197},"curl-語法","curl 語法",[12,200,201],{},"curl 的語法非常的簡單，如果你只是測試 GET API 的話，基本上只要這一行就可以了：",[81,203,205],{"className":83,"code":204,"language":85,"meta":86,"style":86},"curl [URL]\n",[27,206,207],{"__ignoreMap":86},[90,208,209,211],{"class":92,"line":93},[90,210,17],{"class":96},[90,212,214],{"class":213},"sMAXC"," [URL]\n",[12,216,217],{},"但實際上使用我們會需要傳遞一些參數，像是：",[219,220,221,225,228,231],"ul",{},[222,223,224],"li",{},"Post、Get、Put、Delete 等等的 HTTP 方法",[222,226,227],{},"Header 參數",[222,229,230],{},"Body 參數",[222,232,233],{},"其他的參數",[12,235,236,237,239],{},"所以通常 ",[27,238,17],{}," 的語法會是這樣的：",[81,241,243],{"className":83,"code":242,"language":85,"meta":86,"style":86},"curl [options] [URL]\n",[27,244,245],{"__ignoreMap":86},[90,246,247,249],{"class":92,"line":93},[90,248,17],{"class":96},[90,250,251],{"class":213}," [options] [URL]\n",[12,253,254,255,258,259,262],{},"這邊的 ",[27,256,257],{},"options"," 就是我們要傳遞的參數，",[27,260,261],{},"URL"," 就是我們要測試的網址，參數部分不用擔心，我們後面會用 CRUD 來介紹一輪。",[12,264,265,266,269,270,60],{},"那我這邊將會使用六角學院所提供的課程練習用 TodoList API 作為範例，API Path 是 ",[27,267,268],{},"https:\u002F\u002Ftodolist-api.hexschool.io\u002F","，這邊的 API 文件可以參考 ",[65,271,274],{"href":272,"rel":273},"https:\u002F\u002Ftodolist-api.hexschool.io\u002Fdoc\u002F",[69],"這裡",[42,276,277],{},[12,278,279,281],{},[47,280,49],{},"\n由於這是課程練習用，所以資料會在每日凌晨 1:15 清除。",[283,284,286],"h3",{"id":285},"註冊帳號post-userssign_up","註冊帳號（POST \u002Fusers\u002Fsign_up）",[12,288,289],{},"這邊我們會需要先註冊一個帳號，透過 API 文件我們可以知道註冊帳號需要傳遞那些參數",[81,291,295],{"className":292,"code":293,"language":294,"meta":86,"style":86},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"email\": \"example@gmail.com\",\n  \"password\": \"example\",\n  \"nickname\": \"example\"\n}\n","json",[27,296,297,302,317,329,339],{"__ignoreMap":86},[90,298,299],{"class":92,"line":93},[90,300,301],{"class":213},"{\n",[90,303,304,308,311,314],{"class":92,"line":111},[90,305,307],{"class":306},"sKpQp","  \"email\"",[90,309,310],{"class":213},": ",[90,312,313],{"class":103},"\"example@gmail.com\"",[90,315,316],{"class":213},",\n",[90,318,319,322,324,327],{"class":92,"line":119},[90,320,321],{"class":306},"  \"password\"",[90,323,310],{"class":213},[90,325,326],{"class":103},"\"example\"",[90,328,316],{"class":213},[90,330,331,334,336],{"class":92,"line":130},[90,332,333],{"class":306},"  \"nickname\"",[90,335,310],{"class":213},[90,337,338],{"class":103},"\"example\"\n",[90,340,341],{"class":92,"line":140},[90,342,343],{"class":213},"}\n",[12,345,346],{},"接著呢？我們該如何使用 curl 來呼叫這個 API 呢？",[12,348,349,350,353,354,356,357,360],{},"我們這邊將會使用一個 ",[27,351,352],{},"-X"," 參數來指定 HTTP 方法，這邊的 ",[27,355,352],{}," 參數後面接著我們要使用的 HTTP 方法，這邊我們要使用 ",[27,358,359],{},"POST"," 方法，所以我們就這樣寫：",[81,362,364],{"className":83,"code":363,"language":85,"meta":86,"style":86},"curl -X POST https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up\n",[27,365,366],{"__ignoreMap":86},[90,367,368,370,372,375],{"class":92,"line":93},[90,369,17],{"class":96},[90,371,100],{"class":99},[90,373,374],{"class":103}," POST",[90,376,377],{"class":103}," https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up\n",[12,379,380,381,384,385],{},"但這樣寫肯定太長，所以你可以把 ",[27,382,383],{},"-X P