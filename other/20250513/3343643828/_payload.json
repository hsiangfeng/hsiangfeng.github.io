[{"data":1,"prerenderedAt":1535},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20250513\u002F3343643828\u002F":3,"page:\u002Fother\u002F20250513\u002F3343643828\u002F":4,"alt:\u002Fother\u002F20250513\u002F3343643828\u002F":3,"prev-next:\u002Fother\u002F20250513\u002F3343643828\u002F":1511,"related:\u002Fother\u002F20250513\u002F3343643828\u002F":1520},"\u002Fen\u002Fmisc\u002F2025\u002F05\u002F13\u002Ftest-api-without-postman-using-curl\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1493,"date":1494,"description":1495,"extension":1496,"lang":1497,"meta":1498,"navigation":1499,"path":1500,"readingMinutes":1501,"seo":1502,"standalone":1503,"stem":1504,"tags":1505,"tldr":1508,"updated":1494,"url":1509,"__hash__":1510},"content\u002F雜談\u002F不！沒有-Postman-我該怎麼測-API，別怕-cURL-幫你搞定.md","不！沒有 Postman 我該怎麼測 API，別怕 curl 幫你搞定","3343643828",{"type":9,"value":10,"toc":1476},"minimark",[11,19,23,30,34,41,59,69,75,78,163,166,172,185,190,193,197,200,213,216,232,238,250,261,273,278,283,286,340,343,357,374,384,398,411,425,445,455,497,500,506,513,544,554,595,599,606,634,640,646,655,675,680,692,725,729,736,755,758,762,772,795,798,831,841,886,891,899,926,932,939,1031,1034,1038,1041,1089,1098,1102,1108,1138,1142,1151,1174,1176,1224,1227,1230,1237,1252,1257,1266,1269,1276,1293,1302,1306,1313,1330,1335,1341,1344,1347,1472],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"curl","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002FChatGPT%20Image%202025%E5%B9%B45%E6%9C%8814%E6%97%A5%20%E4%B8%8B%E5%8D%8811_01_19.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25,26,29],{},"有時候我們開發上並不方便使用 Postman 來測試 API，但也不方便安裝其他工具，可能就剛好在伺服器上（伺服器基本上都是沒有 GUI 的），那這時候就可以使用 ",[27,28,17],"code",{}," 來測試 API。",[20,31,33],{"id":32},"什麼是-curl","什麼是 curl",[12,35,36,37,40],{},"curl 全名為 ",[27,38,39],{},"Client URL","，這是一套網路協定工具，支援非常多種形式，舉凡...FTP、FTPS、HTTP、HTTPS 等等，幾乎所有的網路協定都可以使用 curl 來進行測試。",[42,43,46],"callout",{"title":44,"type":45},"Note","note",[12,47,48,49,51,52,55,56,58],{},"有的人會說 ",[27,50,17],{}," 或者是 ",[27,53,54],{},"cURL","，本篇統一稱為 ",[27,57,17],{},"。",[12,60,61,62],{},"許多的工具其實都可以看到它的身影，這邊舉例六角學院所提供的 ",[63,64,68],"a",{"href":65,"rel":66},"https:\u002F\u002Fhexschool.github.io\u002Fec-courses-api-swaggerDoc\u002F#\u002F",[67],"nofollow","Swagger API 文件",[12,70,71],{},[15,72],{"alt":73,"src":74},"Swagger API 測試工具","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002F20250514214238.png",[12,76,77],{},"底下可以看到有一段：",[79,80,85],"pre",{"className":81,"code":82,"language":83,"meta":84,"style":84},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","curl -X 'POST' \\\n  'https:\u002F\u002Fec-course-api.hexschool.io\u002Fv2\u002Fadmin\u002Fsignin' \\\n  -H 'accept: application\u002Fjson' \\\n  -H 'Content-Type: application\u002Fjson' \\\n  -d '{\n  \"username\": \"example@test.com\",\n  \"password\": \"example\"\n}'\n","bash","",[27,86,87,107,115,126,136,145,151,157],{"__ignoreMap":84},[88,89,92,95,99,103],"span",{"class":90,"line":91},"line",1,[88,93,17],{"class":94},"smYoP",[88,96,98],{"class":97},"stw71"," -X",[88,100,102],{"class":101},"sWayO"," 'POST'",[88,104,106],{"class":105},"sbsOT"," \\\n",[88,108,110,113],{"class":90,"line":109},2,[88,111,112],{"class":101},"  'https:\u002F\u002Fec-course-api.hexschool.io\u002Fv2\u002Fadmin\u002Fsignin'",[88,114,106],{"class":105},[88,116,118,121,124],{"class":90,"line":117},3,[88,119,120],{"class":97},"  -H",[88,122,123],{"class":101}," 'accept: application\u002Fjson'",[88,125,106],{"class":105},[88,127,129,131,134],{"class":90,"line":128},4,[88,130,120],{"class":97},[88,132,133],{"class":101}," 'Content-Type: application\u002Fjson'",[88,135,106],{"class":105},[88,137,139,142],{"class":90,"line":138},5,[88,140,141],{"class":97},"  -d",[88,143,144],{"class":101}," '{\n",[88,146,148],{"class":90,"line":147},6,[88,149,150],{"class":101},"  \"username\": \"example@test.com\",\n",[88,152,154],{"class":90,"line":153},7,[88,155,156],{"class":101},"  \"password\": \"example\"\n",[88,158,160],{"class":90,"line":159},8,[88,161,162],{"class":101},"}'\n",[12,164,165],{},"這段可以直接複製貼上到終端機使用",[12,167,168],{},[15,169],{"alt":170,"src":171},"終端機","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002F20250514214527.png",[12,173,174,175,180,181,184],{},"還有哪些地方可以看到它的身影呢？像是 ",[63,176,179],{"href":177,"rel":178},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20211207\u002F427026\u002F",[67],"Postman"," 這個 API 測試工具，當你在 Postman 測試完 API 後，點擊 ",[27,182,183],{},"Code"," 按鈕，就可以看到 curl 的語法了",[12,186,187],{},[15,188],{"alt":179,"src":189},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fcurl\u002F20250514214815.png",[12,191,192],{},"所以接下來我們就來認識一下 curl 該如何使用吧！",[20,194,196],{"id":195},"curl-語法","curl 語法",[12,198,199],{},"curl 的語法非常的簡單，如果你只是測試 GET API 的話，基本上只要這一行就可以了：",[79,201,203],{"className":81,"code":202,"language":83,"meta":84,"style":84},"curl [URL]\n",[27,204,205],{"__ignoreMap":84},[88,206,207,209],{"class":90,"line":91},[88,208,17],{"class":94},[88,210,212],{"class":211},"s8XSl"," [URL]\n",[12,214,215],{},"但實際上使用我們會需要傳遞一些參數，像是：",[217,218,219,223,226,229],"ul",{},[220,221,222],"li",{},"Post、Get、Put、Delete 等等的 HTTP 方法",[220,224,225],{},"Header 參數",[220,227,228],{},"Body 參數",[220,230,231],{},"其他的參數",[12,233,234,235,237],{},"所以通常 ",[27,236,17],{}," 的語法會是這樣的：",[79,239,241],{"className":81,"code":240,"language":83,"meta":84,"style":84},"curl [options] [URL]\n",[27,242,243],{"__ignoreMap":84},[88,244,245,247],{"class":90,"line":91},[88,246,17],{"class":94},[88,248,249],{"class":211}," [options] [URL]\n",[12,251,252,253,256,257,260],{},"這邊的 ",[27,254,255],{},"options"," 就是我們要傳遞的參數，",[27,258,259],{},"URL"," 就是我們要測試的網址，參數部分不用擔心，我們後面會用 CRUD 來介紹一輪。",[12,262,263,264,267,268,58],{},"那我這邊將會使用六角學院所提供的課程練習用 TodoList API 作為範例，API Path 是 ",[27,265,266],{},"https:\u002F\u002Ftodolist-api.hexschool.io\u002F","，這邊的 API 文件可以參考 ",[63,269,272],{"href":270,"rel":271},"https:\u002F\u002Ftodolist-api.hexschool.io\u002Fdoc\u002F",[67],"這裡",[42,274,275],{"title":44,"type":45},[12,276,277],{},"由於這是課程練習用，所以資料會在每日凌晨 1:15 清除。",[279,280,282],"h3",{"id":281},"註冊帳號post-userssign_up","註冊帳號（POST \u002Fusers\u002Fsign_up）",[12,284,285],{},"這邊我們會需要先註冊一個帳號，透過 API 文件我們可以知道註冊帳號需要傳遞那些參數",[79,287,291],{"className":288,"code":289,"language":290,"meta":84,"style":84},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  \"email\": \"example@gmail.com\",\n  \"password\": \"example\",\n  \"nickname\": \"example\"\n}\n","json",[27,292,293,298,313,325,335],{"__ignoreMap":84},[88,294,295],{"class":90,"line":91},[88,296,297],{"class":211},"{\n",[88,299,300,304,307,310],{"class":90,"line":109},[88,301,303],{"class":302},"sWTrB","  \"email\"",[88,305,306],{"class":211},": ",[88,308,309],{"class":101},"\"example@gmail.com\"",[88,311,312],{"class":211},",\n",[88,314,315,318,320,323],{"class":90,"line":117},[88,316,317],{"class":302},"  \"password\"",[88,319,306],{"class":211},[88,321,322],{"class":101},"\"example\"",[88,324,312],{"class":211},[88,326,327,330,332],{"class":90,"line":128},[88,328,329],{"class":302},"  \"nickname\"",[88,331,306],{"class":211},[88,333,334],{"class":101},"\"example\"\n",[88,336,337],{"class":90,"line":138},[88,338,339],{"class":211},"}\n",[12,341,342],{},"接著呢？我們該如何使用 curl 來呼叫這個 API 呢？",[12,344,345,346,349,350,352,353,356],{},"我們這邊將會使用一個 ",[27,347,348],{},"-X"," 參數來指定 HTTP 方法，這邊的 ",[27,351,348],{}," 參數後面接著我們要使用的 HTTP 方法，這邊我們要使用 ",[27,354,355],{},"POST"," 方法，所以我們就這樣寫：",[79,358,360],{"className":81,"code":359,"language":83,"meta":84,"style":84},"curl -X POST https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up\n",[27,361,362],{"__ignoreMap":84},[88,363,364,366,368,371],{"class":90,"line":91},[88,365,17],{"class":94},[88,367,98],{"class":97},[88,369,370],{"class":101}," POST",[88,372,373],{"class":101}," https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up\n",[12,375,376,377,380,381],{},"但這樣寫肯定太長，所以你可以把 ",[27,378,379],{},"-X POST"," 簡寫成 ",[27,382,383],{},"-XPOST",[79,385,387],{"className":81,"code":386,"language":83,"meta":84,"style":84},"curl -XPOST https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up\n",[27,388,389],{"__ignoreMap":84},[88,390,391,393,396],{"class":90,"line":91},[88,392,17],{"class":94},[88,394,395],{"class":97}," -XPOST",[88,397,373],{"class":101},[42,399,400],{"title":44,"type":45},[12,401,402,403,406,407,410],{},"請注意，必須要為大寫的 ",[27,404,405],{},"X","，小寫的 ",[27,408,409],{},"x"," 會變成另一種模式，也就是 Proxy 模式。",[12,412,413,414,417,418,420,421,424],{},"接著我們要告訴 Server 我們要傳遞的格式是一個 JSON 格式，這邊就要使用 ",[27,415,416],{},"-H"," 參數，這邊的 ",[27,419,416],{}," 參數後面接著我們要傳遞的 Header 參數，這邊我們要傳遞的 Header 參數是 ",[27,422,423],{},"Content-Type: application\u002Fjson","，所以我們就這樣寫：",[79,426,428],{"className":81,"code":427,"language":83,"meta":84,"style":84},"curl -XPOST https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up -H \"Content-Type: application\u002Fjson\"\n",[27,429,430],{"__ignoreMap":84},[88,431,432,434,436,439,442],{"class":90,"line":91},[88,433,17],{"class":94},[88,435,395],{"class":97},[88,437,438],{"class":101}," https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up",[88,440,441],{"class":97}," -H",[88,443,444],{"class":101}," \"Content-Type: application\u002Fjson\"\n",[12,446,447,448,451,452,454],{},"接著資料該如何傳遞呢？這邊我們可以使用 ",[27,449,450],{},"-d"," 參數來傳遞資料，這邊的 ",[27,453,450],{}," 參數後面接著我們要傳遞的資料，所以我們就這樣寫：",[79,456,458],{"className":81,"code":457,"language":83,"meta":84,"style":84},"curl -XPOST https:\u002F\u002Ftodolist-api.hexschool.io\u002Fusers\u002Fsign_up -H \"Content-Type: application\u002Fjson\" -d '{\n  \"email\": \"example@gmail.com\",\n  \"password\": \"example\",\n  \"nickname\": \"example\"\n}'\n",[27,459,460,478,483,488,493],{"__ignoreMap":84},[88,461,462,464,466,468,470,473,476],{"class":90,"line":91},[88,463,17],{"class":94},[88,465,395],{"class":97},[88,467,438],{"class":101},[88,469,441],{"clas