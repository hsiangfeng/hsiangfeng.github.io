[{"data":1,"prerenderedAt":291},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20211013\u002F4225269670\u002F":3,"page:\u002Fother\u002F20211013\u002F4225269670\u002F":4,"alt:\u002Fother\u002F20211013\u002F4225269670\u002F":3,"prev-next:\u002Fother\u002F20211013\u002F4225269670\u002F":266,"related:\u002Fother\u002F20211013\u002F4225269670\u002F":275},"\u002Fen\u002Fmisc\u002F2021\u002F10\u002F13\u002Fhow-to-find-your-discord-id\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":249,"date":250,"description":26,"extension":251,"lang":252,"meta":253,"navigation":254,"path":255,"readingMinutes":256,"seo":257,"standalone":258,"stem":259,"tags":260,"tldr":262,"updated":263,"url":264,"__hash__":265},"content\u002FDiscord\u002F一篇教你輕鬆取得自己的 Discord ID.md","一篇教你輕鬆取得自己的 Discord ID","4225269670",{"type":9,"value":10,"toc":237},"minimark",[11,20,24,27,31,39,47,50,53,60,67,70,99,102,105,108,112,119,124,135,140,155,160,163,166,172,178,184,190,195,201,204,210,216,222,228,234],[12,13,16],"callout",{"title":14,"type":15},"Note","note",[17,18,19],"p",{},"Discord ID 是你帳號的唯一識別碼，是一串永遠不會改變的數字。要查自己的 Discord ID，先到「使用者設定 → 進階」打開「開發者模式」，再到「我的帳號」點頭像旁的「⋯」就會出現「複製使用者 ID」。",[21,22,23],"h2",{"id":23},"前言",[17,25,26],{},"最近正在開發 Discord Bot 的時候發現，Discord 要取得個人的 User ID 有點麻煩且特別，而且時常會有人搞錯，所以特別來寫一篇介紹說明一下該如何正確取得，而這一篇也會包含手機版的取得方式。",[21,28,30],{"id":29},"discord-id-是什麼","Discord ID 是什麼？",[17,32,33,34,38],{},"首先我們要先來了解一下什麼事 Discord ID，簡單來講 Discord ID 是你的帳號",[35,36,37],"strong",{},"唯一識別碼","，這個 ID 是絕對不會改變的，所以有些服務會要求你去填寫並取得這個 Discord ID。",[17,40,41,42,46],{},"而通常來講 Discord ID 會是一串數字，以我自己的來講，我的會是 ",[43,44,45],"code",{},"300879849289940992","，這一串數字就是我的 Discord ID。",[21,48,49],{"id":49},"錯誤的取得方式",[17,51,52],{},"如果你是第一次使用 Discord 的話，你可能會誤會底下這兩個區塊的就是你的使用者 ID（箭頭所指處）",[17,54,55],{},[56,57],"img",{"alt":58,"src":59},"使用者","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426203841.png",[17,61,62,63,66],{},"這一串「",[35,64,65],{},"isray_notarray","」 並不是你的 Discord ID，僅僅只是你的使用者名稱而已。",[17,68,69],{},"在 Discord 中有三種東西，分別是：",[71,72,73,87,93],"ul",{},[74,75,76,79,80,83,84,86],"li",{},[35,77,78],{},"顯示名稱（Display Name）","：這是你在 Discord 上顯示的名稱，以我自己來講，我是設定為「",[43,81,82],{},"Ray ®","」，那你就會看到我的名稱是「",[43,85,82],{},"」。",[74,88,89,92],{},[35,90,91],{},"使用者名稱（Username）","：這是你在 Discord 上的使用者名稱，就只是一個名稱而已，只是方便你記憶可以快速 Tag 到你而已，這個名稱是可以改變的，所以並不準確。",[74,94,95,98],{},[35,96,97],{},"使用者 ID（User ID）","：這是你在 Discord 上的唯一識別碼，這個 ID 是絕對不會改變的，所以有些服務會要求你去填寫並取得這個 Discord ID。",[17,100,101],{},"接下來我將會介紹的是如何取得 Discord ID，這邊會分為兩個部分來說明，第一個是電腦版的 Discord 取得方式，第二個是手機版的 Discord 取得方式。",[21,103,104],{"id":104},"啟用開發者模式",[17,106,107],{},"不管你要在電腦版還是手機版取得 Discord ID，第一步都是要啟用開發者模式，這個模式可以讓你在 Discord 上看到一些額外的資訊，例如使用者 ID、頻道 ID 等等。",[109,110,111],"h3",{"id":111},"電腦版",[17,113,114,115,118],{},"請找到下方「",[35,116,117],{},"使用者設定","」的按鈕，並點擊它進入使用者設定畫面",[17,120,121],{},[56,122],{"alt":117,"src":123},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426204558.png",[17,125,126,127,130,131,134],{},"接著側邊欄找到「",[35,128,129],{},"進階","」的選項，並將「",[35,132,133],{},"開發者模式","」的選項打開",[17,136,137],{},[56,138],{"alt":133,"src":139},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426204726.png",[17,141,142,143,146,147,150,151,154],{},"接著回到「",[35,144,145],{},"我的帳號","」的頁面，你就可以發現你的名字旁邊多了「",[35,148,149],{},"點點點","」的選項，點它之後就可以看到「",[35,152,153],{},"複製使用者 ID","」的選項，點它就可以複製並取得你的使用者 ID 囉！",[17,156,157],{},[56,158],{"alt":153,"src":159},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426205018.png",[109,161,162],{"id":162},"手機版",[17,164,165],{},"手機版的 Discord 也是要啟用開發者模式，這邊以 iOS 為例，Android 的話應該也是差不多的。",[17,167,168,169,171],{},"請先打開手機，然後找到下方導航列點一下自己的頭像，進入「",[35,170,117],{},"」的頁面",[17,173,174],{},[56,175],{"alt":176,"src":177},"手機版使用者設定","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8658.jpg",[17,179,180,181,183],{},"接著往下滾動，找到「",[35,182,129],{},"」的選項",[17,185,186],{},[56,187],{"alt":188,"src":189},"手機版進階","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8660.PNG",[17,191,192,193,134],{},"然後將「",[35,194,133],{},[17,196,197],{},[56,198],{"alt":199,"src":200},"手機版開發者模式","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8661.PNG",[17,202,203],{},"接著頻道上，隨便找個地方發送訊息",[17,205,206],{},[56,207],{"alt":208,"src":209},"手機版發送訊息","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8662.jpg",[17,211,212,213,183],{},"接著點一下自己頭像，就會跳出一個選單，然後點擊「",[35,214,215],{},"...",[17,217,218],{},[56,219],{"alt":220,"src":221},"手機版選單","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8663.PNG",[17,223,224,225,227],{},"然後就可以看到「",[35,226,153],{},"」的選項，點它就可以複製你的使用者 ID 了",[17,229,230],{},[56,231],{"alt":232,"src":233},"手機版複製使用者 ID","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8664.PNG",[17,235,236],{},"以上就是 Discord ID 的取得方式，希望對你有幫助哩～",{"title":238,"searchDepth":239,"depth":239,"links":240},"",2,[241,242,243,244],{"id":23,"depth":239,"text":23},{"id":29,"depth":239,"text":30},{"id":49,"depth":239,"text":49},{"id":104,"depth":239,"text":104,"children":245},[246,248],{"id":111,"depth":247,"text":111},3,{"id":162,"depth":247,"text":162},"雜談","2021-10-13 13:12:46","md","zh-Hant",{},true,"\u002Fdiscord\u002Fdiscord-id","2",{"title":6,"description":26},false,"Discord\u002F一篇教你輕鬆取得自己的 Discord ID",[261,133,162],"Discord",null,"2026-05-12 09:00:00","\u002Fother\u002F20211013\u002F4225269670\u002F","9BpcagGlbiPBL4ArHyQ3WqCbsDO_8lgDEKf4-UGPDKU",{"newer":267,"older":271},{"url":268,"title":269,"date":270},"\u002Fnuxt\u002F20211022\u002F3508219327\u002F","Nuxt.js 2.x 實戰手冊(2) - Nuxt.js 架構認識","2021-10-22 21:11:08",{"url":272,"title":273,"date":274},"\u002Fnuxt\u002F20211011\u002F3406447097\u002F","Nuxt.js 2.x 實戰手冊(1) - Nuxt.js 與準備","2021-10-11 16:16:35",[27