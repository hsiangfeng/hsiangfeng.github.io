[{"data":1,"prerenderedAt":292},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20211013\u002F4225269670\u002F":3,"page:\u002Fother\u002F20211013\u002F4225269670\u002F":4,"alt:\u002Fother\u002F20211013\u002F4225269670\u002F":3,"prev-next:\u002Fother\u002F20211013\u002F4225269670\u002F":267,"related:\u002Fother\u002F20211013\u002F4225269670\u002F":276},"\u002Fen\u002Fmisc\u002F2021\u002F10\u002F13\u002Fhow-to-find-your-discord-id\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":250,"date":251,"description":28,"extension":252,"lang":253,"meta":254,"navigation":255,"path":256,"readingMinutes":257,"seo":258,"standalone":259,"stem":260,"tags":261,"tldr":263,"updated":264,"url":265,"__hash__":266},"content\u002FDiscord\u002F一篇教你輕鬆取得自己的 Discord ID.md","一篇教你輕鬆取得自己的 Discord ID","4225269670",{"type":9,"value":10,"toc":238},"minimark",[11,22,26,29,33,40,48,51,54,61,68,71,100,103,106,109,113,120,125,136,141,156,161,164,167,173,179,185,191,196,202,205,211,217,223,229,235],[12,13,14],"blockquote",{},[15,16,17,21],"p",{},[18,19,20],"strong",{},"Note","\nDiscord ID 是你帳號的唯一識別碼，是一串永遠不會改變的數字。要查自己的 Discord ID，先到「使用者設定 → 進階」打開「開發者模式」，再到「我的帳號」點頭像旁的「⋯」就會出現「複製使用者 ID」。",[23,24,25],"h2",{"id":25},"前言",[15,27,28],{},"最近正在開發 Discord Bot 的時候發現，Discord 要取得個人的 User ID 有點麻煩且特別，而且時常會有人搞錯，所以特別來寫一篇介紹說明一下該如何正確取得，而這一篇也會包含手機版的取得方式。",[23,30,32],{"id":31},"discord-id-是什麼","Discord ID 是什麼？",[15,34,35,36,39],{},"首先我們要先來了解一下什麼事 Discord ID，簡單來講 Discord ID 是你的帳號",[18,37,38],{},"唯一識別碼","，這個 ID 是絕對不會改變的，所以有些服務會要求你去填寫並取得這個 Discord ID。",[15,41,42,43,47],{},"而通常來講 Discord ID 會是一串數字，以我自己的來講，我的會是 ",[44,45,46],"code",{},"300879849289940992","，這一串數字就是我的 Discord ID。",[23,49,50],{"id":50},"錯誤的取得方式",[15,52,53],{},"如果你是第一次使用 Discord 的話，你可能會誤會底下這兩個區塊的就是你的使用者 ID（箭頭所指處）",[15,55,56],{},[57,58],"img",{"alt":59,"src":60},"使用者","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426203841.png",[15,62,63,64,67],{},"這一串「",[18,65,66],{},"isray_notarray","」 並不是你的 Discord ID，僅僅只是你的使用者名稱而已。",[15,69,70],{},"在 Discord 中有三種東西，分別是：",[72,73,74,88,94],"ul",{},[75,76,77,80,81,84,85,87],"li",{},[18,78,79],{},"顯示名稱（Display Name）","：這是你在 Discord 上顯示的名稱，以我自己來講，我是設定為「",[44,82,83],{},"Ray ®","」，那你就會看到我的名稱是「",[44,86,83],{},"」。",[75,89,90,93],{},[18,91,92],{},"使用者名稱（Username）","：這是你在 Discord 上的使用者名稱，就只是一個名稱而已，只是方便你記憶可以快速 Tag 到你而已，這個名稱是可以改變的，所以並不準確。",[75,95,96,99],{},[18,97,98],{},"使用者 ID（User ID）","：這是你在 Discord 上的唯一識別碼，這個 ID 是絕對不會改變的，所以有些服務會要求你去填寫並取得這個 Discord ID。",[15,101,102],{},"接下來我將會介紹的是如何取得 Discord ID，這邊會分為兩個部分來說明，第一個是電腦版的 Discord 取得方式，第二個是手機版的 Discord 取得方式。",[23,104,105],{"id":105},"啟用開發者模式",[15,107,108],{},"不管你要在電腦版還是手機版取得 Discord ID，第一步都是要啟用開發者模式，這個模式可以讓你在 Discord 上看到一些額外的資訊，例如使用者 ID、頻道 ID 等等。",[110,111,112],"h3",{"id":112},"電腦版",[15,114,115,116,119],{},"請找到下方「",[18,117,118],{},"使用者設定","」的按鈕，並點擊它進入使用者設定畫面",[15,121,122],{},[57,123],{"alt":118,"src":124},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426204558.png",[15,126,127,128,131,132,135],{},"接著側邊欄找到「",[18,129,130],{},"進階","」的選項，並將「",[18,133,134],{},"開發者模式","」的選項打開",[15,137,138],{},[57,139],{"alt":134,"src":140},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426204726.png",[15,142,143,144,147,148,151,152,155],{},"接著回到「",[18,145,146],{},"我的帳號","」的頁面，你就可以發現你的名字旁邊多了「",[18,149,150],{},"點點點","」的選項，點它之後就可以看到「",[18,153,154],{},"複製使用者 ID","」的選項，點它就可以複製並取得你的使用者 ID 囉！",[15,157,158],{},[57,159],{"alt":154,"src":160},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002F20250426205018.png",[110,162,163],{"id":163},"手機版",[15,165,166],{},"手機版的 Discord 也是要啟用開發者模式，這邊以 iOS 為例，Android 的話應該也是差不多的。",[15,168,169,170,172],{},"請先打開手機，然後找到下方導航列點一下自己的頭像，進入「",[18,171,118],{},"」的頁面",[15,174,175],{},[57,176],{"alt":177,"src":178},"手機版使用者設定","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8658.jpg",[15,180,181,182,184],{},"接著往下滾動，找到「",[18,183,130],{},"」的選項",[15,186,187],{},[57,188],{"alt":189,"src":190},"手機版進階","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8660.PNG",[15,192,193,194,135],{},"然後將「",[18,195,134],{},[15,197,198],{},[57,199],{"alt":200,"src":201},"手機版開發者模式","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8661.PNG",[15,203,204],{},"接著頻道上，隨便找個地方發送訊息",[15,206,207],{},[57,208],{"alt":209,"src":210},"手機版發送訊息","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8662.jpg",[15,212,213,214,184],{},"接著點一下自己頭像，就會跳出一個選單，然後點擊「",[18,215,216],{},"...",[15,218,219],{},[57,220],{"alt":221,"src":222},"手機版選單","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8663.PNG",[15,224,225,226,228],{},"然後就可以看到「",[18,227,154],{},"」的選項，點它就可以複製你的使用者 ID 了",[15,230,231],{},[57,232],{"alt":233,"src":234},"手機版複製使用者 ID","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fdiscord-id\u002FIMG_8664.PNG",[15,236,237],{},"以上就是 Discord ID 的取得方式，希望對你有幫助哩～",{"title":239,"searchDepth":240,"depth":240,"links":241},"",2,[242,243,244,245],{"id":25,"depth":240,"text":25},{"id":31,"depth":240,"text":32},{"id":50,"depth":240,"text":50},{"id":105,"depth":240,"text":105,"children":246},[247,249],{"id":112,"depth":248,"text":112},3,{"id":163,"depth":248,"text":163},"雜談","2021-10-13 13:12:46","md","zh-Hant",{},true,"\u002Fdiscord\u002Fdiscord-id","2",{"title":6,"description":28},false,"Discord\u002F一篇教你輕鬆取得自己的 Discord ID",[262,134,163],"Discord",null,"2026-05-12 09:00:00","\u002Fother\u002F20211013\u002F4225269670\u002F","p4-bAvxh7cDCJrfiSYzmd4cNegwoZuc_VBRA2xhQV8A",{"newer":268,"older":272},{"url":269,"title":270,"date":271},"\u002Fnuxt\u002F20211022\u002F3508219327\u002F","Nuxt.js 2.x 實戰手冊(2) - Nuxt.js 架構認識","2021-10-22 21:11:08",{"url":273,"title":274,"date":275},"\u002Fnuxt\u002F20211011\u002F3406447097\u002F","Nuxt.js 2.x 實戰手冊(1) - Nuxt.js 與準備","2021-10-11 16:16:35",[277,282,287],{"url":278,"title":279,"date":280,"readingMinutes":281},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":283,"title":284,"date":285,"readingMinutes":286},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":288,"title":289,"date":290,"readingMinutes":291},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784010304461]