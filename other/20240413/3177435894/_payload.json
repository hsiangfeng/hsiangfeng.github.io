[{"data":1,"prerenderedAt":1998},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20240413\u002F3177435894\u002F":3,"page:\u002Fother\u002F20240413\u002F3177435894\u002F":4,"alt:\u002Fother\u002F20240413\u002F3177435894\u002F":3,"prev-next:\u002Fother\u002F20240413\u002F3177435894\u002F":1973,"related:\u002Fother\u002F20240413\u002F3177435894\u002F":1982},"\u002Fen\u002Fmisc\u002F2024\u002F04\u002F13\u002Fmonorepo-vite-pnpm-vue3-setup\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1955,"date":1956,"description":1957,"extension":86,"lang":1958,"meta":1959,"navigation":1870,"path":1960,"readingMinutes":1961,"seo":1962,"standalone":1963,"stem":1964,"tags":1965,"tldr":1969,"updated":1970,"url":1971,"__hash__":1972},"content\u002F雜談\u002FMonorepo？來聊聊另一種專案管理架構吧！使用-Vite-pnpm-建立-Vue3-Monorepo.md","Monorepo？來聊聊另一種專案管理架構吧！使用 Vite+ pnpm 建立 Vue3 Monorepo","3177435894",{"type":9,"value":10,"toc":1943},"minimark",[11,22,26,29,33,36,39,44,47,68,75,78,81,225,228,231,242,245,251,254,258,261,264,550,553,556,562,566,569,572,578,581,584,590,593,596,602,605,608,626,629,633,636,668,679,690,693,697,700,739,742,753,756,780,783,804,807,813,816,822,833,990,1017,1020,1152,1168,1171,1186,1216,1219,1222,1432,1446,1577,1597,1600,1612,1618,1625,1643,1662,1666,1669,1686,1689,1702,1705,1711,1714,1782,1792,1795,1816,1819,1912,1915,1918,1927,1939],[12,13,14],"blockquote",{},[15,16,17,21],"p",{},[18,19,20],"strong",{},"Note","\nMonorepo 是「Mono（單一）+ Repo（Repository）」的縮寫，意思是把多個專案放在同一個 Git Repository 裡管理，跟「一個專案一個 Repo」的 Monolith 是相對概念。JavaScript 圈最常見的建立方式是 pnpm workspace 搭配 Vite。",[23,24,25],"h2",{"id":25},"前言",[15,27,28],{},"Monorepo 是什麼呢？而這個專案架構又與普通的專案架構有什麼不同呢？剛好最近有相關專案的需求，所以就寫這一篇記錄一下。",[23,30,32],{"id":31},"什麼是-monorepo","什麼是 Monorepo？",[15,34,35],{},"Monorepo 是什麼東西呢？首先這是多個單字的組合，分別是 Mono 與 Repo，Mono 代表單一的意思，而 Repo 則是 Repository 的縮寫，也就是說 Monorepo 代表的是單一的 Repository。",[15,37,38],{},"感覺滿難懂的吧？沒關係，讓我們先講講其他的專案架構，接著我們再來 Monorepo 吧！",[40,41,43],"h3",{"id":42},"monolith-repository單體儲存庫","Monolith Repository（單體儲存庫）",[15,45,46],{},"通常我們在開發專案的時候，都會歷經以下幾個步驟：",[48,49,50,54,62,65],"ul",{},[51,52,53],"li",{},"建立專案",[51,55,56,57,61],{},"初始化版本控制（",[58,59,60],"code",{},"git init","）",[51,63,64],{},"開發功能",[51,66,67],{},"提交變更到遠端儲存庫（GitHub、GitLab、Bitbucket 等）",[15,69,70],{},[71,72],"img",{"alt":73,"src":74},"Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002F%E6%88%AA%E5%9C%96%202024-04-13%2023.50.43.png",[15,76,77],{},"而這個專案就會獨立一個 Git Repository，也是我們最基本的專案架構，那麼這種架構又稱之為 Monolith Repository（後面僅稱 Monolith），也就是單一專案的 Repository。",[15,79,80],{},"那麼 Monolith 的專案架構可能長這樣：",[82,83,88],"pre",{"className":84,"code":85,"language":86,"meta":87,"style":87},"language-md shiki shiki-themes github-dark-high-contrast","- Repository\n  - .git\n  - README.md\n  - package.json\n  - src\n    - components\n      - Button\n      - Input\n      - ...\n    - pages\n      - index\n      - shopping\n      - admin\n      - ...\n  - public\n  - ...其他檔案\n","md","",[58,89,90,103,112,120,128,136,145,154,162,170,178,186,194,202,209,217],{"__ignoreMap":87},[91,92,95,99],"span",{"class":93,"line":94},"line",1,[91,96,98],{"class":97},"s_sBn","-",[91,100,102],{"class":101},"sMAXC"," Repository\n",[91,104,106,109],{"class":93,"line":105},2,[91,107,108],{"class":97},"  -",[91,110,111],{"class":101}," .git\n",[91,113,115,117],{"class":93,"line":114},3,[91,116,108],{"class":97},[91,118,119],{"class":101}," README.md\n",[91,121,123,125],{"class":93,"line":122},4,[91,124,108],{"class":97},[91,126,127],{"class":101}," package.json\n",[91,129,131,133],{"class":93,"line":130},5,[91,132,108],{"class":97},[91,134,135],{"class":101}," src\n",[91,137,139,142],{"class":93,"line":138},6,[91,140,141],{"class":97},"    -",[91,143,144],{"class":101}," components\n",[91,146,148,151],{"class":93,"line":147},7,[91,149,150],{"class":97},"      -",[91,152,153],{"class":101}," Button\n",[91,155,157,159],{"class":93,"line":156},8,[91,158,150],{"class":97},[91,160,161],{"class":101}," Input\n",[91,163,165,167],{"class":93,"line":164},9,[91,166,150],{"class":97},[91,168,169],{"class":101}," ...\n",[91,171,173,175],{"class":93,"line":172},10,[91,174,141],{"class":97},[91,176,177],{"class":101}," pages\n",[91,179,181,183],{"class":93,"line":180},11,[91,182,150],{"class":97},[91,184,185],{"class":101}," index\n",[91,187,189,191],{"class":93,"line":188},12,[91,190,150],{"class":97},[91,192,193],{"class":101}," shopping\n",[91,195,197,199],{"class":93,"line":196},13,[91,198,150],{"class":97},[91,200,201],{"class":101}," admin\n",[91,203,205,207],{"class":93,"line":204},14,[91,206,150],{"class":97},[91,208,169],{"class":101},[91,210,212,214],{"class":93,"line":211},15,[91,213,108],{"class":97},[91,215,216],{"class":101}," public\n",[91,218,220,222],{"class":93,"line":219},16,[91,221,108],{"class":97},[91,223,224],{"class":101}," ...其他檔案\n",[15,226,227],{},"透過上面架構我們可以看到會 Monolith 會是一個 Git 管理一整個專案。",[15,229,230],{},"雖然 Monolith 的架構非常方便也簡單，在做一些 MVP 專案是相當不錯的首選，可是也會有一些問題存在，當專案開始越來越大時，這個專案就會變得越來越難維護，為什麼呢？舉例來講，我們這個專案裡面可能有包含了以下幾個功能模組：",[48,232,233,236,239],{},[51,234,235],{},"前台首頁",[51,237,238],{},"前台購物頁面",[51,240,241],{},"後台管理\n...等等功能",[15,243,244],{},"開發以及部署的速度會隨著專案越來越龐大而變得越來越慢，就連一個小改動你都需要跑完一整個專案的編譯、測試、部署等等流程，而且只要一個地方出錯，這個專案就會跟你說一聲「掰掰」",[15,246,247],{},[71,248],{"alt":249,"src":250},"掰掰","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002Fim-leaving-leaving.gif",[15,252,253],{},"那麼為了解決這問題，我們就延伸出了另一個專案架構，也就是 Multi Repository。",[40,255,257],{"id":256},"multi-repository多個儲存庫","Multi Repository（多個儲存庫）",[15,259,260],{},"Multi Repository（後面簡稱 Multi）是什麼呢？簡單來講就是將原本的 Monolith 拆分成多個 Repository，也就是將原本的專案拆分成多個專案，每個專案都有自己的 Repository，這樣就可以讓每個專案獨立開發、獨立部署，這樣就可以解決 Monolith 的問題。",[15,262,263],{},"那麼這個專案架構就會從原本的 Monolith 變成以下的架構：",[82,265,267],{"className":84,"code":266,"language":86,"meta":87,"style":87},"- A Repository\n  - .git\n  - README.md\n  - package.json\n  - src\n    - components\n      - Button\n      - Input\n      - ...\n    - pages\n      - index\n      - ...\n  - public\n  - ...其他檔案\n- B Repository\n  - .git\n  - README.md\n  - package.json\n  - src\n    - components\n      - Button\n      - Input\n      - ...\n    - pages\n      - shopping\n      - ...\n  - public\n  - ...其他檔案\n- C Repository\n  - .git\n  - README.md\n  - package.json\n  - src\n    - components\n      - Button\n      - Input\n      - ...\n    - pages\n      - admin\n      - ...\n  - public\n  - ...其他檔案\n",[58,268,269,276,282,288,294,300,306,312,318,324,330,336,342,348,354,361,367,374,381,388,395,402,409,416,423,430,437,444,451,459,466,473,480,487,494,501,508,515,522,529,536,543],{"__ignoreMap":87},[91,270,271,273],{"class":93,"line":94},[91,272,98],{"class":97},[91,274,275],{"class":101}," A Repository\n",[91,277,278,280],{"class":93,"line":105},[91,279,108],{"class":97},[91,281,111],{"class":101},[91,283,284,286],{"class":93,"line":114},[91,285,108],{"class":97},[91,287,119],{"class":101},[91,289,290,292],{"class":93,"line":122},[91,291,108],{"class":97},[91,293,127],{"class":101},[91,295,296,298],{"class":93,"line":130},[91,297,108],{"class":97},[91,299,135],{"class":101},[91,301,302,304],{"class":93,"line":138},[91,303,141],{"class":97},[91,305,144],{"class":101},[91,307,308,310],{"class":93,"line":147},[91,309,150],{"class":97},[91,311,153],{"class":101},[91,313,314,316],{"class":93,"line":156},[91,315,150],{"class":97},[91,317,161],{"class":101},[91,319,320,322],{"class":93,"line":164},[91,321,150],{"class":97},[91,323,169],{"class":101},[91,325,326,328],{"class":93,"line":172},[91,327,141],{"class":97},[91,329,177],{"class":101},[91,331,332,334],{"class":93,"line":180},[91,333,150],{"class":97},[91,335,185],{"class":101},[91,337,338,340],{"class":93,"line":188},[91,339,150],{"class":97},[91,341,169],{"class":101},[91,343,344,346],{"class":93,"line":196},[91,345,108],{"class":97},[91,347,216],{"class":101},[91,349,350,352],{"class":93,"line":204},[91,351,108],{"class":97},[91,353,224],{"class":101},[91,355,356,358],{"class":93,"line":211},[91,357,98],{"class":97},[91,359,360],{"class":101}," B Repository\n",[91,362,363,365],{"class":93,"line":219},[91,364,108],{"class":97},[91,366,111],{"class":101},[91,368,370,372],{"class":93,"line":369},17,[91,371,108],{"class":97},[91,373,119],{"class":101},[91,375,377,379],{"class":93,"line":376},18,[91,378,108],{"class":97},[91,380,127],{"class":101},[91,382,384,386],{"class":93,"line":383},19,[91,385,108],{"class":97},[91,387,135],{"class":101},[91,389,391,393],{"class":93,"line":390},20,[91,392,141],{"class":97},[91,394,144],{"class":101},[91,396,398,400],{"class":93,"line":397},21,[91,399,150],{"class":97},[91,401,153],{"class":101},[91,403,405,407],{"class":93,"line":404},22,[91,406,150],{"class":97},[91,408,161],{"class":101},[91,410,412,414],{"class":93,"line":411},23,[91,413,150],{"class":97},[91,415,169],{"class":101},[91,417,419,421],{"class":93,"line":418},24,[91,420,141],{"class":97},[91,422,177],{"class":101},[91,424,426,428],{"class":93,"line":425},25,[91,427,150],{"class":97},[91,429,193],{"class":101},[91,431,433,435],{"class":93,"line":432},26,[91,434,150],{"class":97},[91,436,169],{"class":101},[91,438,440,442],{"class":93,"line":439},27,[91,441,108],{"class":97},[91,443,216],{"class":101},[91,445,447,449],{"class":93,"line":446},28,[91,448,108],{"class":97},[91,450,224],{"class":101},[91,452,454,456],{"class":93,"line":453},29,[91,455,98],{"class":97},[91,457,458],{"class":101}," C Repository\n",[91,460,462,464],{"class":93,"line":461},30,[91,463,108],{"class":97},[91,465,111],{"class":101},[91,467,469,471],{"class":93,"line":468},31,[91,470,108],{"class":97},[91,472,119],{"class":101},[91,474,476,478],{"class":93,"line":475},32,[91,477,108],{"class":97},[91,479,127],{"class":101},[91,481,483,485],{"class":93,"line":482},33,[91,484,108],{"class":97},[91,486,135],{"class":101},[91,488,490,492],{"class":93,"line":489},34,[91,491,141],{"class":97},[91,493,144],{"class":101},[91,495,497,499],{"class":93,"line":496},35,[91,498,150],{"class":97},[91,500,153],{"class":101},[91,502,504,506],{"class":93,"line":503},36,[91,505,150],{"class":97},[91,507,161],{"class":101},[91,509,511,513],{"class":93,"line":510},37,[91,512,150],{"class":97},[91,514,169],{"class":101},[91,516,518,520],{"class":93,"line":517},38,[91,519,141],{"class":97},[91,521,177],{"class":101},[91,523,525,527],{"class":93,"line":524},39,[91,526,150],{"class":97},[91,528,201],{"class":101},[91,530,532,534],{"class":93,"line":531},40,[91,533,150],{"class":97},[91,535,169],{"class":101},[91,537,539,541],{"class":93,"line":538},41,[91,540,108],{"class":97},[91,542,216],{"class":101},[91,544,546,548],{"class":93,"line":545},42,[91,547,108],{"class":97},[91,549,224],{"class":101},[15,551,552],{},"看起來這種專案架構是相當不錯的，讓我們解決了牽一髮而動全身的問題，而這個專案架構也會將功能模組各自拆分成一個專案，這樣就可以讓每個專案獨立開發、獨立部署，這樣就可以解決 Monolith 的問題。",[15,554,555],{},"但卻也有一些問題發生，我們在上面的例子中，我們可以看到 Button、Input 這兩個功能模組都是重複的，這樣就會造成重複開發的問題，而且當這兩個功能模組有一個地方出錯時，我們就需要到每個專案去修改，這樣就會造成維護上的困難，當然不只有這個問題存在，像是專案的 CI\u002FCD、套件的版本等等也就會變得更加難以維護 QAQ...",[15,557,558],{},[71,559],{"alt":560,"src":561},"崩潰","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002F202404140133.jpg",[40,563,565],{"id":564},"mono-repository單一儲存庫","Mono Repository（單一儲存庫）",[15,567,568],{},"那麼為了解決這個問題，所以又延伸出了另一個專案架構，也就是我們這一篇要說的重點 Monorepo 架構。",[15,570,571],{},"這時候應該有點混亂了，所以我決定畫圖來讓大家更加了解彼此的架構差異，首先是 Monolith：",[15,573,574],{},[71,575],{"alt":576,"src":577},"Monolith Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002FMonolith%20Repository.png",[15,579,580],{},"我們可以看到 Monolith 的專案架構是一個專案一個 Repository，裡面通常會包含了許多功能模組，這樣就會造成牽一髮而動全身的問題。",[15,582,583],{},"接下來是 Multi：",[15,585,586],{},[71,587],{"alt":588,"src":589},"Multi Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002FMulti%20Repository.png",[15,591,592],{},"我們可以看到 Multi 的專案架構是將原本的 Monolith 拆分成多個 Repository，這樣就可以讓每個專案獨立開發、獨立部署，這樣就可以解決 Monolith 的問題。",[15,594,595],{},"最後是 Mono Repository（後面簡稱 Monorepo）：",[15,597,598],{},[71,599],{"alt":600,"src":601},"Mono Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002FMono%20Repository.png",[15,603,604],{},"透過圖像我們可以看到原本 Multi 都是獨立的 Git 管理，但是在 Monorepo 中，我們可以看到所有的專案都是在同一個 Repository 中並且由一個 Git 管理，這樣就可以解決 Multi 的問題，讓我們可以將所有的專案都放在同一個 Repository 中，讓所有的專案共享相同的資源。",[15,606,607],{},"雖然 Monorepo 的架構解決了 Multi 的問題，但也有一些缺點，例如...",[48,609,610,617,620,623],{},[51,611,612,613,616],{},"專案肥大後 ",[58,614,615],{},"git clone"," 時會花費較多時間",[51,618,619],{},"共用的東西必須要規劃好，否則容易互相影響",[51,621,622],{},"由於 Monorepo 中的專案都是共用的，所以無法區分專案的權限",[51,624,625],{},"Git 儲存庫的大小會變得非常大",[15,627,628],{},"我們可以發現不論是哪一種專案架構，都有屬於他的優缺點，所以在選擇專案架構時，可以評估一下自己的專案需求，再來選擇適合的專案架構。",[23,630,632],{"id":631},"用-vite-實作一個-monorepo","用 Vite 實作一個 Monorepo",[15,634,635],{},"接下來我將會介紹如何使用 Vite + pnpm 建立一個 Vue3 的 Monorepo，首先請你先依照以下步驟準備好環境：",[82,637,641],{"className":638,"code":639,"language":640,"meta":87,"style":87},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir monorepo-example-pnpm-vue3\ncd monorepo-example-pnpm-vue3\npnpm init\n","bash",[58,642,643,652,660],{"__ignoreMap":87},[91,644,645,648],{"class":93,"line":94},[91,646,647],{"class":97},"mkdir",[91,649,651],{"class":650},"sTRMh"," monorepo-example-pnpm-vue3\n",[91,653,654,658],{"class":93,"line":105},[91,655,657],{"class":656},"sCcAr","cd",[91,659,651],{"class":650},[91,661,662,665],{"class":93,"line":114},[91,663,664],{"class":97},"pnpm",[91,666,667],{"class":650}," init\n",[15,669,670,671,678],{},"接下來我們要做一點特別的設定，在 pnpm 的 ",[672,673,677],"a",{"href":674,"rel":675},"https:\u002F\u002Fpnpm.io\u002Fzh\u002Fworkspaces",[676],"nofollow","工作空間（Workspace）"," 官方文件有說到一件事情，如果我們要建立 Monorepo 的話會需要在根目錄建立一個「pnpm-workspace.yaml」檔案，所以請你在這個專案底下建立一個「pnpm-workspace.yaml」檔案。",[12,680,681],{},[15,682,683,685,686,689],{},[18,684,20],{},"\npnpm-workspace.yaml 這個檔案主要是用來告訴 pnpm 這個專案是一個 Monorepo 專案，並且在你執行 ",[58,687,688],{},"pnpm install"," 時會自動安裝所有專案的相依套件",[15,691,692],{},"內容要寫什麼呢？這邊先讓我們回頭看一下 Monorepo 的圖：",[15,694,695],{},[71,696],{"alt":600,"src":601},[15,698,699],{},"我們可以看到一個 Git 底下會管理很多個專案，所以通常 Monorepo 的專案會長這樣：",[82,701,703],{"className":84,"code":702,"language":86,"meta":87,"style":87},"- Git\n  - pnpm-workspace.yaml\n  - package.json\n  - apps\n  - packages\n",[58,704,705,712,719,725,732],{"__ignoreMap":87},[91,706,707,709],{"class":93,"line":94},[91,708,98],{"class":97},[91,710,711],{"class":101}," Git\n",[91,713,714,716],{"class":93,"line":105},[91,715,108],{"class":97},[91,717,718],{"class":101}," pnpm-workspace.yaml\n",[91,720,721,723],{"class":93,"line":114},[91,722,108],{"class":97},[91,724,127],{"class":101},[91,726,727,729],{"class":93,"line":122},[91,728,108],{"class":97},[91,730,731],{"class":101}," apps\n",[91,733,734,736],{"class":93,"line":130},[91,735,108],{"class":97},[91,737,738],{"class":101}," packages\n",[15,740,741],{},"我們可以看到有一個 apps 資料夾，這個就是我們將會放置所有專案的地方，所以我們要在根目錄建立一個「apps」資料夾",[82,743,745],{"className":638,"code":744,"language":640,"meta":87,"style":87},"mkdir apps\n",[58,746,747],{"__ignoreMap":87},[91,748,749,751],{"class":93,"line":94},[91,750,647],{"class":97},[91,752,731],{"class":650},[15,754,755],{},"接著在「pnpm-workspace.yaml」檔案中寫入以下內容：",[82,757,761],{"className":758,"code":759,"language":760,"meta":87,"style":87},"language-yaml shiki shiki-themes github-dark-high-contrast","packages:\n  - apps\u002F*\n","yaml",[58,762,763,772],{"__ignoreMap":87},[91,764,765,769],{"class":93,"line":94},[91,766,768],{"class":767},"sKpQp","packages",[91,770,771],{"class":101},":\n",[91,773,774,777],{"class":93,"line":105},[91,775,776],{"class":101},"  - ",[91,778,779],{"class":650},"apps\u002F*\n",[15,781,782],{},"到這邊為止，已經將 Monorepo 的基本環境準備好了，接下來就是建立一個 Vue3 的專案，請你移動到「apps」資料夾中，並且建立一個 Vue3 的專案：",[82,784,786],{"className":638,"code":785,"language":640,"meta":87,"style":87},"cd apps\npnpm create vue@latest\n",[58,787,788,794],{"__ignoreMap":87},[91,789,790,792],{"class":93,"line":94},[91,791,657],{"class":656},[91,793,731],{"class":650},[91,795,796,798,801],{"class":93,"line":105},[91,797,664],{"class":97},[91,799,800],{"class":650}," create",[91,802,803],{"class":650}," vue@latest\n",[15,805,806],{},"這邊我就示範建立一個「shopping」的專案",[15,808,809],{},[71,810],{"alt":811,"src":812},"Vue Create","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002F%E6%88%AA%E5%9C%96%202024-04-15%2013.38.35.png",[15,814,815],{},"建立完成後，你專案應該會長這樣：",[15,817,818],{},[71,819],{"alt":820,"src":821},"專案當前結構","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fmonorepo\u002F%E6%88%AA%E5%9C%96%202024-04-15%2013.40.05.png",[15,823,824,825,828,829,832],{},"接下來要請你打開 apps\u002Fshopping 的專案，並且找到 package.json 將 ",[58,826,827],{},"name"," 屬性改成 ",[58,830,831],{},"@apps\u002Fshopping","，這樣才能讓 pnpm 知道這個專案是屬於 Monorepo 底下的專案。",[82,834,838],{"className":835,"code":836,"language":837,"meta":87,"style":87},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"name\": \"@apps\u002Fshopping\",\n  \"version\": \"0.1.0\",\n  \"private\": true,\n  \"scripts\": {\n    \"dev\": \"vite\",\n    \"build\": \"vite build\",\n    \"serve\": \"vite preview\"\n  },\n  \"dependencies\": {\n    \"vue\": \"^3.2.29\"\n  },\n  \"devDependencies\": {\n    \"@vitejs\u002Fplugin-vue\": \"^1.9.2\",\n    \"vite\": \"^2.7.13\"\n  }\n}\n","json",[58,839,840,845,859,871,883,891,903,915,925,930,937,947,951,958,970,980,985],{"__ignoreMap":87},[91,841,842],{"class":93,"line":94},[91,843,844],{"class":101},"{\n",[91,846,847,850,853,856],{"class":93,"line":105},[91,848,849],{"class":767},"  \"name\"",[91,851,852],{"class":101},": ",[91,854,855],{"class":650},"\"@apps\u002Fshopping\"",[91,857,858],{"class":101},",\n",[91,860,861,864,866,869],{"class":93,"line":114},[91,862,863],{"class":767},"  \"version\"",[91,865,852],{"class":101},[91,867,868],{"class":650},"\"0.1.0\"",[91,870,858],{"class":101},[91,872,873,876,878,881],{"class":93,"line":122},[91,874,875],{"class":767},"  \"private\"",