[{"data":1,"prerenderedAt":416},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20190924\u002F3446878284\u002F":3,"page:\u002Fother\u002F20190924\u002F3446878284\u002F":4,"alt:\u002Fother\u002F20190924\u002F3446878284\u002F":3,"prev-next:\u002Fother\u002F20190924\u002F3446878284\u002F":391,"related:\u002Fother\u002F20190924\u002F3446878284\u002F":400},"\u002Fen\u002Fmisc\u002F2019\u002F09\u002F24\u002Fcustomize-windows-terminal-with-oh-my-posh\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":374,"date":375,"description":18,"extension":376,"lang":377,"meta":378,"navigation":379,"path":380,"readingMinutes":381,"seo":382,"standalone":383,"stem":384,"tags":385,"tldr":388,"updated":388,"url":389,"__hash__":390},"content\u002F雜談\u002FWindow-終端機美化-Windows-Terminal.md","Window PowerShell美化(Windows Terminal)","3446878284",{"type":9,"value":10,"toc":358},"minimark",[11,15,19,22,25,32,35,38,43,51,57,63,67,70,76,79,85,92,101,105,108,111,127,134,138,141,150,156,159,166,172,175,186,193,215,218,230,234,237,242,245,256,259,263,271,277,283,288,292,295,301,308,313,316,321,324,330,333,345,348,354],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"身為一名工程師來講，最常接觸的就是 Cmd 介面，也就是所謂的終端機，那麼長久看同一個畫面也是會膩的，所以這一篇記錄一下該如何美化自己的 Terminal 吧。",[12,20,21],{"id":21},"操作環境",[16,23,24],{},"首先前面我先提供一下我目前的環境",[26,27,28],"ul",{},[29,30,31],"li",{},"Windows 10 1903 版",[16,33,34],{},"後面會有一個美化必須是 1903 版本的，所以這邊要注意一下。",[16,36,37],{},"另外我個人比較習慣使用 PowerShell，所以這一篇將會以 PowerShell 美化為主。",[39,40,42],"h3",{"id":41},"查看-windows-版本方法","查看 Windows 版本方法",[16,44,45,46,50],{},"於搜尋列輸入 ",[47,48,49],"code",{},"winver"," 即可查看版本 ↓",[16,52,53],{},[54,55],"img",{"alt":49,"src":56},"https:\u002F\u002Fi.imgur.com\u002FgFP7UBa.png",[16,58,59],{},[54,60],{"alt":61,"src":62},"Windows 版本","https:\u002F\u002Fi.imgur.com\u002F6C78BAf.png",[12,64,66],{"id":65},"增加類似-git-的提示條美化","增加類似 Git 的提示條美化",[16,68,69],{},"一般來講我們預設的 PowerShell 是這樣子 ↓",[16,71,72],{},[54,73],{"alt":74,"src":75},"PowerShell","https:\u002F\u002Fi.imgur.com\u002FxI70onO.png",[16,77,78],{},"所以接下來就會美化成像這樣子的提示條 ↓",[16,80,81],{},[54,82],{"alt":83,"src":84},"提示條","https:\u002F\u002Fi.imgur.com\u002Fmxj9VeZ.png",[16,86,87,88,91],{},"而這個美化條其實是這個套件 ",[47,89,90],{},"oh-my-posh","，接下來就要來替 PowerShell 加入這個套件囉~",[16,93,94],{},[95,96,100],"a",{"href":97,"rel":98},"https:\u002F\u002Fgithub.com\u002FJanDeDobbeleer\u002Foh-my-posh",[99],"nofollow","oh-my-posh GitHub",[12,102,104],{"id":103},"oh-my-posh-安裝","oh-my-posh 安裝",[39,106,107],{"id":107},"起始式",[16,109,110],{},"首先開啟 PowerShell 輸入以下指令：",[112,113,118],"pre",{"className":114,"code":115,"language":116,"meta":117,"style":117},"language-ps shiki shiki-themes github-dark-high-contrast","Install-Module posh-git -Scope CurrentUser\n","ps","",[47,119,120],{"__ignoreMap":117},[121,122,125],"span",{"class":123,"line":124},"line",1,[121,126,115],{},[16,128,129,130,133],{},"假設是第一次且沒安裝過的話 NuGet 會問你一推問題，全部輸入 ",[47,131,132],{},"Y"," 即可(我已安裝過就不附圖了)",[39,135,137],{"id":136},"安裝-oh-my-posh","安裝 oh-my-posh",[16,139,140],{},"接下來安裝 oh-my-posh 模組輸入以下指令：",[112,142,144],{"className":114,"code":143,"language":116,"meta":117,"style":117},"Install-Module oh-my-posh -Scope CurrentUser\n",[47,145,146],{"__ignoreMap":117},[121,147,148],{"class":123,"line":124},[121,149,143],{},[16,151,152,153,155],{},"過程一樣瘋狂 ",[47,154,132],{}," 就好了。",[39,157,158],{"id":158},"設置自動套用",[16,160,161,162,165],{},"接下來我們在 PowerShell 上面輸入 ",[47,163,164],{},"$profile"," 來顯示 PowerShell 自定義路徑 ↓",[16,167,168],{},[54,169],{"alt":170,"src":171},"profile","https:\u002F\u002Fi.imgur.com\u002F8Plz4sS.png",[16,173,174],{},"複製這一段路徑開啟資料夾",[112,176,180],{"className":177,"code":178,"language":179,"meta":117,"style":117},"language-cmd shiki shiki-themes github-dark-high-contrast","C:\\Users\\Hsiangfeng\\Documents\\WindowsPowerShell\\\n","cmd",[47,181,182],{"__ignoreMap":117},[121,183,184],{"class":123,"line":124},[121,185,178],{},[16,187,188,189,192],{},"打開資料夾後底下若沒有一個檔案叫 ",[47,190,191],{},"Microsoft.PowerShell_profile.ps1"," 那就新增一個，如果有的話就直接打開來，並內容填入以下：",[112,194,196],{"className":114,"code":195,"language":116,"meta":117,"style":117},"Import-Module posh-git\nImport-Module oh-my-posh\nSet-Theme Agnoster\n",[47,197,198,203,209],{"__ignoreMap":117},[121,199,200],{"class":123,"line":124},[121,201,202],{},"Import-Module posh-git\n",[121,204,206],{"class":123,"line":205},2,[121,207,208],{},"Import-Module oh-my-posh\n",[121,210,212],{"class":123,"line":211},3,[121,213,214],{},"Set-Theme Agnoster\n",[16,216,217],{},"這樣子每次啟動 PowerShell 就可以自動套入設置了~",[16,219,220,221,224,225],{},"另外如果你想換別種樣式的話只需要調整 ",[47,222,223],{},"Set-Theme"," 即可，樣式在官方 GitHub README 底下有提供 ",[95,226,229],{"href":227,"rel":228},"https:\u002F\u002Fgithub.com\u002FJanDeDobbeleer\u002Foh-my-posh#themes",[99],"oh-my-posh Themes",[12,231,233],{"id":232},"windows-terminal","Windows Terminal",[16,235,236],{},"接下來的美化就是我個人的最愛，Windows Terminal 是微軟在 2019 年釋出的新 cmd 介面，也就是我目前在使用的 ↓",[16,238,239],{},[54,240],{"alt":233,"src":241},"https:\u002F\u002Fi.imgur.com\u002F9DttRqa.png",[16,243,244],{},"但是在操作之前請務必確認以下幾點事項",[26,246,247,250,253],{},[29,248,249],{},"你必須是 Windows 10 作業系統(廢話)",[29,251,252],{},"版本號必須為 1903",[29,254,255],{},"可以搭配前面的 oh-my-posh",[16,257,258],{},"若以上沒有問題的話，就來安裝吧!",[39,260,262],{"id":261},"安裝-windows-terminal","安裝 Windows Terminal",[16,264,265,266,270],{},"新版的 Windows Terminal 是透過 Store 安裝的，所以只需要瀏覽器上點一下 ",[95,267,269],{"href":268},"ms-windows-store:\u002F\u002Fpdp\u002F?ProductId=9n0dx20hk701","這個網址"," 就會開啟 Store 商店囉~",[16,272,273],{},[54,274],{"alt":275,"src":276},"我已安裝","https:\u002F\u002Fi.imgur.com\u002FeeRMQpT.png",[16,278,279,280,282],{},"安裝完畢後在搜尋列輸入 ",[47,281,233],{}," 即可找到 (個人建議可以釘選在開始工具列上) ↓",[16,284,285],{},[54,286],{"alt":233,"src":287},"https:\u002F\u002Fi.imgur.com\u002FFeQuH7s.png",[12,289,291],{"id":290},"美化-windows-terminal","美化 Windows Terminal",[16,293,294],{},"開起來之後會與原本的 PowerShell 沒太大差異，所以這邊點一下上方倒箭頭，並點一下 Setting ↓",[16,296,297],{},[54,298],{"alt":299,"src":300},"Setting","https:\u002F\u002Fi.imgur.com\u002FRr5CMTx.png",[16,302,303,304,307],{},"接下來搜尋 ",[47,305,306],{},"profiles"," 你可以看到下面有三個物件，這三個物件各代表一個 CMD  ↓",[16,309,310],{},[54,311],{"alt":306,"src":312},"https:\u002F\u002Fi.imgur.com\u002FNOKHU7p.png",[16,314,315],{},"順序與這裡相同，所以以我這邊舉例要修改 PowerShell 來講我只需要專注第一個物件就好了 ↓",[16,317,318],{},[54,319],{"alt":306,"src":320},"https:\u002F\u002Fi.imgur.com\u002Fok0af8l.png",[16,322,323],{},"那以下我就直接提供我有修改的說明註解 ↓",[16,325,326],{},[54,327],{"alt":328,"src":329},"註解","https:\u002F\u002Fi.imgur.com\u002FGSpwjDv.png",[16,331,332],{},"這邊要注意兩件事情",[26,334,335,338],{},[29,336,337],{},"背景圖片的地方不可以有中文字，否則無法正常顯示背景圖片",[29,339,340,341,344],{},"字體建議修改，我個人是使用 ",[47,342,343],{},"Sarasa Term SC","，否則滿怪的",[16,346,347],{},"最後結果就會像這樣子美化成功 ↓",[16,349,350],{},[54,351],{"alt":352,"src":353},"美化成功","https:\u002F\u002Fi.imgur.com\u002FLhk3iVp.png",[355,356,357],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":117,"searchDepth":205,"depth":205,"links":359},[360,361,364,365,370,373],{"id":14,"depth":205,"text":14},{"id":21,"depth":205,"text":21,"children":362},[363],{"id":41,"depth":211,"text":42},{"id":65,"depth":205,"text":66},{"id":103,"depth":205,"text":104,"children":366},[367,368,369],{"id":107,"depth":211,"text":107},{"id":136,"depth":211,"text":137},{"id":158,"depth":211,"text":158},{"id":232,"depth":205,"text":233,"children":371},[372],{"id":261,"depth":211,"text":262},{"id":290,"depth":205,"text":291},"雜談","2019-09-24 13:53:52","md","zh-Hant",{},true,"\u002Fwindow-windows-terminal","2",{"title":6,"description":18},false,"雜談\u002FWindow-終端機美化-Windows-Terminal",[386,387],"軟體操作","Terminal"