[{"data":1,"prerenderedAt":792},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20211207\u002F427026\u002F":3,"page:\u002Fother\u002F20211207\u002F427026\u002F":4,"alt:\u002Fother\u002F20211207\u002F427026\u002F":3,"prev-next:\u002Fother\u002F20211207\u002F427026\u002F":768,"related:\u002Fother\u002F20211207\u002F427026\u002F":777},"\u002Fen\u002Fmisc\u002F2021\u002F12\u002F07\u002Fpostman-quick-start-guide\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":752,"date":753,"description":18,"extension":754,"lang":755,"meta":756,"navigation":427,"path":757,"readingMinutes":758,"seo":759,"standalone":760,"stem":761,"tags":762,"tldr":765,"updated":765,"url":766,"__hash__":767},"content\u002F雜談\u002F跟著我一起快速入門-Postman-吧！.md","跟著我一起快速入門 Postman 吧！","427026",{"type":9,"value":10,"toc":734},"minimark",[11,15,19,23,30,46,49,55,64,67,71,74,80,83,89,92,98,101,105,114,117,123,131,136,139,169,174,177,183,191,197,200,206,211,214,219,223,226,231,234,237,243,246,252,255,259,262,268,271,294,297,303,306,312,315,321,324,330,334,337,356,362,369,372,378,381,387,390,396,399,458,461,467,470,476,480,494,499,502,508,511,517,520,524,527,533,536,542,545,552,555,561,564,571,575,578,584,591,596,599,604,609,615,621,627,631,634,640,643,648,651,657,664,669,672,678,681,687,690,695,698,701,704,713,716,730],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"Postman 在開發上是非常常使用的工具，畢竟很多時候我們會先使用 Postman 測試 API 是否正常，否則實際接上 API 後才發現問題，那麼就會非常花時間在 debug 上，因此就誕生了這一篇 Postman 教學。",[12,20,22],{"id":21},"postman-安裝","Postman 安裝",[16,24,25],{},[26,27],"img",{"alt":28,"src":29},"Postman","https:\u002F\u002Fi.imgur.com\u002FJuGnaLc.png",[16,31,32,33,37,38,45],{},"開始 Postman 教學之前，請務必確認你電腦已經有「",[34,35,36],"strong",{},"安裝 Postman","」，若還沒安裝的話，請透過 ",[39,40,44],"a",{"href":41,"rel":42},"https:\u002F\u002Fwww.postman.com\u002F",[43],"nofollow","此連結"," 進入官網安裝 Postman。",[16,47,48],{},"進入到官網後，你可以在首頁找到下載的地方，請依據你的作業系統安裝",[16,50,51],{},[26,52],{"alt":53,"src":54},"下載 Postman","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2021_12_6_21_39.png",[16,56,57,58,63],{},"如果你找不到下載處的話，你可以透過這個 ",[39,59,62],{"href":60,"rel":61},"https:\u002F\u002Fwww.postman.com\u002Fdownloads\u002F",[43],"下載連結"," 進入也可以。",[16,65,66],{},"剩下的安裝過程我就不說明了，畢竟安裝真的沒有什麼好寫的。",[12,68,70],{"id":69},"postman-介面","Postman 介面",[16,72,73],{},"首先我們先來看一下 Postman 整體介面",[16,75,76],{},[26,77],{"alt":78,"src":79},"整體介面","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-06%2021.53.27.png",[16,81,82],{},"首先先看左側功能區",[16,84,85],{},[26,86],{"alt":87,"src":88},"左側功能區","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062223.png",[16,90,91],{},"而右側區塊主要是會隨著我們操作切換頁面",[16,93,94],{},[26,95],{"alt":96,"src":97},"Create request","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062226.png",[16,99,100],{},"認識基本介面後，我們就準備來學習 Postman，而這邊主要都是本地為主而不是 workspace，但是掌握後面知識之後就非常足夠囉。",[12,102,104],{"id":103},"新增請求-create-a-request","新增請求 (Create a request)",[16,106,107,108,113],{},"接下來我們試著用 ",[39,109,112],{"href":110,"rel":111},"https:\u002F\u002Frandomuser.me\u002F",[43],"randomuser"," 來模擬 Get API 的行為。",[16,115,116],{},"新增請求的方式很多，你可以點 「Get started」的 Create a request",[16,118,119],{},[26,120],{"alt":121,"src":122},"Create a request","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062234.png",[16,124,125,126,130],{},"或者點上方的「",[127,128,129],"code",{},"+","」新增一個請求頁面",[16,132,133],{},[26,134],{"alt":121,"src":135},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062235.png",[16,137,138],{},"如果你還是找不到，你可以使用快捷鍵開啟新增頁面",[140,141,142,157],"ul",{},[143,144,145,146],"li",{},"Mac\n",[140,147,148],{},[143,149,150,153,154],{},[127,151,152],{},"Command"," + ",[127,155,156],{},"N",[143,158,159,160],{},"Window\n",[140,161,162],{},[143,163,164,153,167],{},[127,165,166],{},"Ctrl",[127,168,156],{},[16,170,171],{},[26,172],{"alt":121,"src":173},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062238.png",[16,175,176],{},"當你新增一個請求後，你會進入到這個介面",[16,178,179],{},[26,180],{"alt":181,"src":182},"request view","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-06%2022.40.11.png",[16,184,185,186,190],{},"接下來上方有一個 Enter request URL 的欄位，填入 randomuser 的 API 網址「",[39,187,188],{"href":188,"rel":189},"https:\u002F\u002Frandomuser.me\u002Fapi\u002F",[43],"」，並點下 Send",[16,192,193],{},[26,194],{"alt":195,"src":196},"randomuser api","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062242.png",[16,198,199],{},"Send 之後，基本上你就可以看到 API 回傳的資料在下方給你了",[16,201,202],{},[26,203],{"alt":204,"src":205},"request data","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062245.png",[207,208,210],"h3",{"id":209},"authorization","Authorization",[16,212,213],{},"如果你預計要測試的 API 是需要傳入 Token 的話，你可以在頁面下方找到「Authorization」，裡面有一個 Type 可以切換讓你選擇你發起請求時要一起帶入的 Token",[16,215,216],{},[26,217],{"alt":210,"src":218},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071559.png",[207,220,222],{"id":221},"methods","Methods",[16,224,225],{},"而切換 Methods 方式也非常簡單，在 API Url 前面就是了",[16,227,228],{},[26,229],{"alt":222,"src":230},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071601.png",[207,232,233],{"id":233},"傳送資料",[16,235,236],{},"那如果想要新增、編輯資料呢？這邊雖然要看後端是怎麼接收你資料，但大多都是 JSON 格式去傳送，因此你可以切換到 Body",[16,238,239],{},[26,240],{"alt":241,"src":242},"Body","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071603.png",[16,244,245],{},"下方就依據你的需求調整傳送方式，例如你要傳送 JSON 的話就切換到 Raw 並在下拉選擇",[16,247,248],{},[26,249],{"alt":250,"src":251},"JSON","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071611.png",[16,253,254],{},"接下來你就可以塞入 JSON 內容了。",[12,256,258],{"id":257},"收藏請求-create-a-collection","收藏請求 (Create a collection)",[16,260,261],{},"接下來你可能會需要保留這個請求，因此你可以點一下「Save」",[16,263,264],{},[26,265],{"alt":266,"src":267},"Save","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062300.png",[16,269,270],{},"或是按下快捷鍵儲存",[140,272,273,284],{},[143,274,145,275],{},[140,276,277],{},[143,278,279,153,281],{},[127,280,152],{},[127,282,283],{},"S",[143,285,159,286],{},[140,287,288],{},[143,289,290,153,292],{},[127,291,166],{},[127,293,283],{},[16,295,296],{},"接下來你會發現你並沒有辦法儲存",[16,298,299],{},[26,300],{"alt":301,"src":302},"Not Save","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-06%2023.06.48.png",[16,304,305],{},"因為你必須要新增一個 Collection 才可以，因此你可以點一下「New Collection」or「Create a collection」，然後名字叫做「Random User Generator」的收藏資料夾",[16,307,308],{},[26,309],{"alt":310,"src":311},"Random User Generator","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062310.png",[16,313,314],{},"新增好後，你就可以發現你的「Save」不在是 Disable (禁止)狀態，在儲存之前記得重新命名一下 Request name，然後可以針對該 API 請求增加說明",[16,316,317],{},[26,318],{"alt":319,"src":320},"Save request","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112062314.png",[16,322,323],{},"新增成功之後，你就可以在左側 Collections 中看到剛剛新增的 API 囉",[16,325,326],{},[26,327],{"alt":328,"src":329},"API","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-06%2023.15.17.png",[12,331,333],{"id":332},"設置環境變數-environments","設置環境變數 (Environments)",[16,335,336],{},"實際開發上我們一定不只有一個 API，可能有二三十隻 API，這邊我用 randomuser 建立三個 Get API",[140,338,339,344,350],{},[143,340,341],{},[39,342,188],{"href":188,"rel":343},[43],[143,345,346],{},[39,347,348],{"href":348,"rel":349},"https:\u002F\u002Frandomuser.me\u002Fapi\u002F?results=100",[43],[143,351,352],{},[39,353,354],{"href":354,"rel":355},"https:\u002F\u002Frandomuser.me\u002Fapi\u002F?gender=female",[43],[16,357,358],{},[26,359],{"alt":360,"src":361},"randomuser API","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2014.33.52.png",[16,363,364,365,368],{},"我們可以看到 API 路徑中 ",[127,366,367],{},"https:\u002F\u002Frandomuser.me"," 都是相同的，當若有二三十隻 API 後來若要調整的話，就會格外麻煩，因此通常我們就會設置環境變數(Environment)。",[16,370,371],{},"這邊你先點一下左側功能列的 Environments 並找到 Create Environment",[16,373,374],{},[26,375],{"alt":376,"src":377},"Create Environment","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071437.png",[16,379,380],{},"點下 Create Environment 之後右側會跳出相關設定",[16,382,383],{},[26,384],{"alt":385,"src":386},"Create Environment Setting","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2014.39.09.png",[16,388,389],{},"接下來你可以依據下圖紅框填寫內容",[16,391,392],{},[26,393],{"alt":394,"src":395},"Setting","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071442.png",[16,397,398],{},"填寫完畢之後點一下左側 Collection 回到 RandomUser API，然後將原本的 API 路徑改成以下",[400,401,406],"pre",{"className":402,"code":403,"language":404,"meta":405,"style":405},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","\u002F\u002F 單一使用者\n{{API_URL}}\u002Fapi\n\n\u002F\u002F 取得 100 筆使用者資料\n{{API_URL}}\u002Fapi\u002F?results=100\n\n\u002F\u002F 取得女性使用者\n{{API_URL}}\u002Fapi\u002F?gender=female\n","txt","",[127,407,408,416,422,429,435,441,446,452],{"__ignoreMap":405},[409,410,413],"span",{"class":411,"line":412},"line",1,[409,414,415],{},"\u002F\u002F 單一使用者\n",[409,417,419],{"class":411,"line":418},2,[409,420,421],{},"{{API_URL}}\u002Fapi\n",[409,423,425],{"class":411,"line":424},3,[409,426,428],{"emptyLinePlaceholder":427},true,"\n",[409,430,432],{"class":411,"line":431},4,[409,433,434],{},"\u002F\u002F 取得 100 筆使用者資料\n",[409,436,438],{"class":411,"line":437},5,[409,439,440],{},"{{API_URL}}\u002Fapi\u002F?results=100\n",[409,442,444],{"class":411,"line":443},6,[409,445,428],{"emptyLinePlaceholder":427},[409,447,449],{"class":411,"line":448},7,[409,450,451],{},"\u002F\u002F 取得女性使用者\n",[409,453,455],{"class":411,"line":454},8,[409,456,457],{},"{{API_URL}}\u002Fapi\u002F?gender=female\n",[16,459,460],{},"調整好之後，記得將 Environment 改成我們剛剛新增的「randomuser Env」",[16,462,463],{},[26,464],{"alt":465,"src":466},"randomuser Env","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071449.png",[16,468,469],{},"接下來你就可以試戳 API 看看結果是否相同",[16,471,472],{},[26,473],{"alt":474,"src":475},"試戳","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2014.50.24.png",[12,477,479],{"id":478},"生成-api-程式碼-code-snippet","生成 API 程式碼 (Code snippet)",[16,481,482,483,486,487,486,490,493],{},"透過前面我們可以了解到 Postman 非常的方便，但它方便的地方並不只有這些，你還可以快速生成相關程式碼(如：",[127,484,485],{},"axios","、",[127,488,489],{},"fetch",[127,491,492],{},"$.ajax",")，你可以試著切換到任何 API 請求的頁面，然後點一下旁邊類似程式碼的圖示",[16,495,496],{},[26,497],{"alt":127,"src":498},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071454.png",[16,500,501],{},"打開 Code 之後你可以依據需求選取生成的 Code 片段",[16,503,504],{},[26,505],{"alt":506,"src":507},"Code snippet","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2014.56.17.png",[16,509,510],{},"例如 jQuery 版本",[16,512,513],{},[26,514],{"alt":515,"src":516},"jQuery","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2014.56.22.png",[16,518,519],{},"但是這邊要注意 Postman 所提供的範例程式碼一率都僅提供參考，請不要直接複製貼上到正式專案使用。",[12,521,523],{"id":522},"匯出-export","匯出 (Export)",[16,525,526],{},"如果你想要將 API 分享給別人的話也可以，找到你要匯出的 Collection，然後點一下選單後選擇 Export",[16,528,529],{},[26,530],{"alt":531,"src":532},"Export Collection","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071504.png",[16,534,535],{},"匯出時會問你要匯出的版本，基本上選擇預設的 recommended 就好",[16,537,538],{},[26,539],{"alt":540,"src":541},"recommended","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2015.04.50.png",[16,543,544],{},"這邊我也提供我剛匯出的 Collection 給大家下載，以便稍後的練習",[16,546,547],{},[39,548,551],{"href":549,"rel":550},"https:\u002F\u002Fraw.githubusercontent.com\u002Fhsiangfeng\u002FPostmanExample\u002Fmain\u002FRandom%20User%20Generator.postman_collection.json",[43],"Collection 下載",[16,553,554],{},"而 Environments 的匯出方法也是一樣，只是匯出的按鈕在左側",[16,556,557],{},[26,558],{"alt":559,"src":560},"Export Environments","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071523.png",[16,562,563],{},"底下也一樣提供 Environments 給大家下載練習",[16,565,566],{},[39,567,570],{"href":568,"rel":569},"https:\u002F\u002Fraw.githubusercontent.com\u002Fhsiangfeng\u002FPostmanExample\u002Fmain\u002Frandomuser%20env.postman_environment.json",[43],"Environments 下載",[12,572,574],{"id":573},"匯入-import","匯入 (Import)",[16,576,577],{},"不知道你有沒有下載前面的 Collection 了呢？若有的話基本上你應該會拿到一個「Random User Generator.postman_collection.json」的 json 檔案",[16,579,580],{},[26,581],{"alt":582,"src":583},"json","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2015.12.41.png",[16,585,586,587,590],{},"接下來打開你的 Postman 在上方有一個「",[127,588,589],{},"import","」按鈕",[16,592,593],{},[26,594],{"alt":589,"src":595},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071515.png",[16,597,598],{},"點一下它匯入你剛剛下載的 Collection",[16,600,601],{},[26,602],{"alt":589,"src":603},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2015.15.49.png",[16,605,606],{},[26,607],{"alt":589,"src":608},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2015.16.03.png",[16,610,611,612,614],{},"當你按下 ",[127,613,589],{}," 後就可以看到 Collection 有你剛剛匯入的東西了",[16,616,617],{},[26,618],{"alt":619,"src":620},"Collection","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2015.18.05.png",[16,622,623,624,626],{},"這邊要注意一下 Collection 匯出時，並不會匯出 Environments，因此如果你有設置 Environments 的話記得也要匯入，而匯入的方式流程是相同的，一樣找到 ",[127,625,589],{}," 按鈕並上傳 Environments JSON 檔案就可以囉。",[12,628,630],{"id":629},"自動-api-測試-auto-collection-test","自動 API 測試 (Auto Collection Test)",[16,632,633],{},"最後來教一個非常實用的功能，也就是自動 API 測試，有時候我們要大量測試 API 是不是全部回傳狀態碼 200 確保 API 是真的可以正常運作的，那麼每一個 API 頁面其實都可以寫一個 Test 測試",[16,635,636],{},[26,637],{"alt":638,"src":639},"API Test","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071533.png",[16,641,642],{},"但是一個一個寫測試太花時間，因此前面叫你建立 Collection 是有原因的，因為本身 Postman 是支援 Collection 大量測試，所以你可以點一下你要測試的 Collection",[16,644,645],{},[26,646],{"alt":619,"src":647},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071536.png",[16,649,650],{},"當你點了之後右側就會跳出該 Collection 的一些測試，找到「Test」選項",[16,652,653],{},[26,654],{"alt":655,"src":656},"Collection Test","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071538.png",[16,658,659,660,663],{},"然後在 Test 頁面上下方有一些快速的方法生成，而我們要測試所有 API 都是回傳 200，所以你可以找到「",[127,661,662],{},"Status code is 200","」把它新增到 Test 中，只需要點它一下 Postman 就會自動幫你生成了",[16,665,666],{},[26,667],{"alt":662,"src":668},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071540.png",[16,670,671],{},"新增完畢之後找到上方「Run」按鈕",[16,673,674],{},[26,675],{"alt":676,"src":677},"Run","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071541.png",[16,679,680],{},"接下來你會跳到準備執行的畫面，你可以依據該畫面選擇你要測試的 API，除此之外在測試之前請務必確定 ENV 的選擇是否正確，若沒有問題的話，接下來你就可以按下「Run Random User Generator」",[16,682,683],{},[26,684],{"alt":685,"src":686},"Run Random User Generator","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F202112071542.png",[16,688,689],{},"最後 Postman 就會輸出 API Test 的結果囉",[16,691,692],{},[26,693],{"alt":638,"src":694},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-12-07%2015.44.27.png",[16,696,697],{},"是不是非常方便呢？還不熟悉 Postman 的人也可以試著導入玩玩看哩。",[12,699,700],{"id":700},"後記",[16,702,703],{},"其實 Postman 還有相當多可以玩的東西，例如： Mock Server、Monitors 等等，而這一篇主要是介紹了常用的六到七成 Postman 重點，剩下的可以在自己透過官方文件了解。",[16,705,706,707,712],{},"最後也額外提一下，如果你不喜歡 Postman 的話也可以考慮另一套叫做 ",[39,708,711],{"href":709,"rel":710},"https:\u002F\u002Fhoppscotch.io\u002F",[43],"Hoppscotch"," 的工具(前身是 Postwoman)。",[12,714,715],{"id":715},"參考文獻",[140,717,718,725],{},[143,719,720],{},[39,721,724],{"href":722,"rel":723},"https:\u002F\u002Flearning.postman.com\u002Fdocs\u002Fgetting-started\u002Fintroduction\u002F",[43],"Postman Doc",[143,726,727],{},[39,728,711],{"href":709,"rel":729},[43],[731,732,733],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki