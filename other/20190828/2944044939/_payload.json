[{"data":1,"prerenderedAt":624},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20190828\u002F2944044939\u002F":3,"page:\u002Fother\u002F20190828\u002F2944044939\u002F":4,"alt:\u002Fother\u002F20190828\u002F2944044939\u002F":3,"prev-next:\u002Fother\u002F20190828\u002F2944044939\u002F":600,"related:\u002Fother\u002F20190828\u002F2944044939\u002F":609},"\u002Fen\u002Fmisc\u002F2019\u002F08\u002F28\u002Fslack-basics-for-beginners\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":583,"date":584,"description":585,"extension":586,"lang":587,"meta":588,"navigation":589,"path":590,"readingMinutes":591,"seo":592,"standalone":593,"stem":594,"tags":595,"tldr":597,"updated":597,"url":598,"__hash__":599},"content\u002F雜談\u002FSlack-基礎操作.md","Slack 基礎操作","2944044939",{"type":9,"value":10,"toc":556},"minimark",[11,15,19,23,29,32,35,39,42,45,51,54,60,63,69,72,78,81,87,91,94,100,117,128,131,139,147,155,158,164,171,177,184,189,192,197,200,206,218,224,230,233,244,250,253,256,261,264,284,287,293,300,305,309,316,322,327,331,334,338,341,346,349,356,361,367,370,373,376,379,382,389,394,401,406,409,412,417,420,426,431,434,440,444,451,457,460,463,469,472,475,482,485,490,496,499,504,510,514,517,523,529,532,539,547,550,553],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇來記錄一下 Slack 的基礎操作與介紹，稍微會有點長，最主要 Slack 是滿多公司很常使用的溝通工具，所以也是會建議學習使用。",[12,20,22],{"id":21},"slack","Slack",[16,24,25],{},[26,27],"img",{"alt":22,"src":28},"https:\u002F\u002Fi.imgur.com\u002FCN6Qmt2.png",[16,30,31],{},"Slack 其實是滿多公司使用的溝通工具，最主要它是一個團隊溝通工具，你可以把它當成一個 Line 使用，但是我個人覺得它比 Line 還好用，除了可以刪除剛剛發送的訊息之外，還能夠編輯剛剛發送的訊息。",[16,33,34],{},"它可以開啟一個團隊頻道，然後底下有子群組與私人群組，另外 Slack 是免費的，一般用戶使用免費版 Slack 就很足夠，很多公司都會使用該溝通軟體當作公司內部協調工具。",[12,36,38],{"id":37},"加入-slack","加入 Slack",[16,40,41],{},"這時候你可以自己建立一個 Slack 群組 or 使用別人建立好的 Slack 群，這邊我拿別人已經建立好的 Slac 群組當作範例。",[16,43,44],{},"通常對方會給你加入 Slack 的連結，當你點連結之後會開啟一個視窗問你的 Email，其實就是要確認你有沒有 Slack 帳號 ↓",[16,46,47],{},[26,48],{"alt":49,"src":50},"註冊 or 加入","https:\u002F\u002Fi.imgur.com\u002FbLxjkiL.png",[16,52,53],{},"如果你已經有註冊 Slack 就會直接加入頻道，如果是初次註冊 Slack 會把註冊信件寄到你的信箱 ↓",[16,55,56],{},[26,57],{"alt":58,"src":59},"初次註冊","https:\u002F\u002Fi.imgur.com\u002F04qmi0E.png",[16,61,62],{},"接下來只需要到信箱內找 Slack 信件確認註冊",[16,64,65],{},[26,66],{"alt":67,"src":68},"確認 Email","https:\u002F\u002Fi.imgur.com\u002F3bLa5Ek.png",[16,70,71],{},"當你點了確認 Email 後 Slack 會要求你輸入名稱 & 密碼，這是你將來加入任何一個 Slack 的預設名稱以及登入密碼(帳號就是你的 Email) ↓",[16,73,74],{},[26,75],{"alt":76,"src":77},"輸入相關資訊","https:\u002F\u002Fi.imgur.com\u002FRVYLaiX.png",[16,79,80],{},"輸入完畢就可以加入該 Slack 了 ↓",[16,82,83],{},[26,84],{"alt":85,"src":86},"注意這是網頁版 Slack","https:\u002F\u002Fi.imgur.com\u002FD0T6T52.png",[12,88,90],{"id":89},"下載-slack-軟體","下載 Slack 軟體",[16,92,93],{},"我個人在操作上會建議下載 Slack 軟體，因為如果你沒有安裝 Slack 軟體只使用網頁版的話，有很高的機會漏掉訊息。",[16,95,96],{},[26,97],{"alt":98,"src":99},"網頁版(六角分享團)","https:\u002F\u002Fi.imgur.com\u002FWqF6Q0c.png",[16,101,102,103,107,108,112,113,116],{},"通常網頁版上方會告知你 ",[104,105,106],"code",{},"We strongly recommend enabling desktop notifications if you'll be using Slack on this computer.","，意思是指 ",[109,110,111],"strong",{},"Slack 建議你開啟桌面版通知","，避免掉訊息，我個人建議按下 ",[104,114,115],{},"Enable notifications"," 開啟通知。",[16,118,119,120,127],{},"當然我個人還是建議下載 Slack 軟體，因為這樣子比較不會發生 miss 掉訊息的問題，首先先進入下載網站：",[121,122,126],"a",{"href":123,"rel":124},"https:\u002F\u002Fslack.com\u002Fintl\u002Fen-tw\u002Fdownloads\u002F",[125],"nofollow","下載連結","。",[16,129,130],{},"基本上 Slack 會自動跳到相對應的下載連結頁面，如果沒有可以點以下連結：",[16,132,133,134],{},"Window：",[121,135,138],{"href":136,"rel":137},"https:\u002F\u002Fslack.com\u002Fintl\u002Fen-tw\u002Fdownloads\u002Fwindows",[125],"Window 下載",[16,140,141,142],{},"MAC：",[121,143,146],{"href":144,"rel":145},"https:\u002F\u002Fslack.com\u002Fintl\u002Fen-tw\u002Fdownloads\u002Fmac",[125],"MAC 下載",[16,148,149,150],{},"Linux：",[121,151,154],{"href":152,"rel":153},"https:\u002F\u002Fslack.com\u002Fintl\u002Fen-tw\u002Fdownloads\u002Flinux",[125],"Linux 下載",[16,156,157],{},"下載完畢後開啟軟體你應該會看到空白頁面，並且要求你登入 ↓",[16,159,160],{},[26,161],{"alt":162,"src":163},"初始畫面","https:\u002F\u002Fi.imgur.com\u002FYWzDFZv.png",[16,165,166,167,170],{},"當你點擊 ",[104,168,169],{},"Sign In"," 後會開啟一個網頁視窗要求你輸入 Slack 群的地址 ↓",[16,172,173],{},[26,174],{"alt":175,"src":176},"Slack 地址","https:\u002F\u002Fi.imgur.com\u002FOCaPtfw.png",[16,178,179,180,183],{},"而這個 Slack 群的名稱其實就是一開始加入群的時候出現的 ",[104,181,182],{},"playSlackYa"," ↓",[16,185,186],{},[26,187],{"alt":182,"src":188},"https:\u002F\u002Fi.imgur.com\u002FRvWKwM2.png",[16,190,191],{},"接下來只要輸入名稱即可 ↓",[16,193,194],{},[26,195],{"alt":182,"src":196},"https:\u002F\u002Fi.imgur.com\u002FEtctOXD.png",[16,198,199],{},"然後你就會被導入到一個頁面要求你輸入帳號密碼 ↓",[16,201,202],{},[26,203],{"alt":204,"src":205},"輸入帳號密碼","https:\u002F\u002Fi.imgur.com\u002FXvDUPUb.png",[16,207,208,209,211,212,214,215,217],{},"登入後你應該會直接進入網頁版的 Slack (我不知道為什麼 Slack 會這樣跑)，接下來回到 Slack 軟體在點一次 ",[104,210,169],{},"，這時候就可以看到左上變成 ",[104,213,182],{}," 點一下它或是正下方的 ",[104,216,182],{},"，這樣就可以將該 Slack 群組加入至 Slack 軟體囉 ↓",[16,219,220],{},[26,221],{"alt":222,"src":223},"Slack 軟體","https:\u002F\u002Fi.imgur.com\u002FJC7p1MZ.png",[16,225,226],{},[26,227],{"alt":228,"src":229},"加入成功","https:\u002F\u002Fi.imgur.com\u002FtQyqlWv.png",[16,231,232],{},"過程我個人覺得稍微麻煩一點，但是操作過一次後就還好了。",[16,234,235,236,239,240,243],{},"未來如果要加入其他 Slack 基本上也是一樣的動作，如果想要將新的 Slack 頻道加入到自己現有的 Slack 軟體中，只需要點一下左上角的功能 → ",[104,237,238],{},"Window"," → ",[104,241,242],{},"Sign in to Another Workspace"," 然後重複上述動作就可以加入 ↓",[16,245,246],{},[26,247],{"alt":248,"src":249},"加入其他 Slack","https:\u002F\u002Fi.imgur.com\u002FGXSurPs.png",[12,251,252],{"id":252},"介面認識",[16,254,255],{},"首先先來認識一下基礎介面",[257,258,260],"h3",{"id":259},"channels-頻道","Channels (頻道)",[16,262,263],{},"首先左側是 Channels 也就是頻道，底下可細分為以下幾種",[265,266,267,276],"ul",{},[268,269,270,271],"li",{},"公開頻道\n",[265,272,273],{},[268,274,275],{},"任何人都可以加入的",[268,277,278,279],{},"私人頻道\n",[265,280,281],{},[268,282,283],{},"只有被邀請的人才可以看到",[16,285,286],{},"你可以點擊任一一個頻道切換過去聊天或是 LDS (喇低賽)",[16,288,289],{},[26,290],{"alt":291,"src":292},"Channels","https:\u002F\u002Fi.imgur.com\u002F4GdFQri.png",[16,294,295,296,299],{},"如果你想加入其他公開的頻道，只需要知道頻道名稱然後點一下 ",[104,297,298],{},"Add a channel"," 就可以加入，當然也可以自己建立頻道 ↓",[16,301,302],{},[26,303],{"alt":298,"src":304},"https:\u002F\u002Fi.imgur.com\u002Fv6hOh1O.png",[257,306,308],{"id":307},"direct-messages-發送訊息","Direct Messages (發送訊息)",[16,310,311,312,315],{},"其實就是 1 對 1 私訊，就這麼簡單，如果沒有在這個列表上的人，可以點一下 ",[104,313,314],{},"+"," 的符號來加入你要私訊的對象 ↓",[16,317,318],{},[26,319],{"alt":320,"src":321},"Direct Messages","https:\u002F\u002Fi.imgur.com\u002FPJ40DsC.png",[16,323,324],{},[26,325],{"alt":320,"src":326},"https:\u002F\u002Fi.imgur.com\u002FXbleHvk.png",[257,328,330],{"id":329},"app","APP",[16,332,333],{},"Slack 支援滿多加快工作開發的軟體給加入到該 Slack 群內，但是因為自己沒有使用過該功能就不多作介紹。",[257,335,337],{"id":336},"threads","Threads",[16,339,340],{},"Threads 這個功能算是我個人滿喜歡的功能之一，將某一位人的訊息給集中討論，後面會在介紹該如何做集中討論 ↓",[16,342,343],{},[26,344],{"alt":337,"src":345},"https:\u002F\u002Fi.imgur.com\u002FjOmY5wp.png",[257,347,348],{"id":348},"關閉該頻道通知",[16,350,351,352,355],{},"通常可能會有幾個頻道是屬於閒聊的頻道，如果你覺得太吵的話，其實可以關閉該通知頻道，只需要點一下左上的齒輪圖示，然後找到 ",[104,353,354],{},"Mute xxx"," 就可以了 ↓",[16,357,358],{},[26,359],{"alt":348,"src":360},"https:\u002F\u002Fi.imgur.com\u002FuxjgQPS.png",[16,362,363],{},[26,364],{"alt":365,"src":366},"頻道會出現一個靜音鈴鐺","https:\u002F\u002Fi.imgur.com\u002FlWuXzFO.png",[16,368,369],{},"另外 Slack 每天約九點還十點會自動將所有頻道靜音(個人覺得超棒的)。",[12,371,372],{"id":372},"基礎功能操作",[16,374,375],{},"接下來來認識一下基礎的功能操作。",[257,377,378],{"id":378},"編輯訊息",[16,380,381],{},"基本上前面我們了解可以切換到特定頻道發送訊息，那發送後如果發現訊息不妥時，是可以編輯與刪除的。",[16,383,384,385,388],{},"滑鼠只需要移動到需要編輯的訊息，就可以看到 ",[104,386,387],{},"．．．"," 這個按鈕就可以編輯訊息 ↓",[16,390,391],{},[26,392],{"alt":378,"src":393},"https:\u002F\u002Fi.imgur.com\u002FAEsWoVj.png",[16,395,396,397,400],{},"另外也可以按一下鍵盤箭頭 ",[104,398,399],{},"↑"," 得按鈕，它會自動將你剛剛發送的訊息進入編輯狀態 ↓",[16,402,403],{},[26,404],{"alt":378,"src":405},"https:\u002F\u002Fi.imgur.com\u002FEGPnYJi.png",[257,407,408],{"id":408},"刪除訊息",[16,410,411],{},"基本上刪除訊息的方式就與編輯差不多，刪除後對方是看不到你的訊息的 ↓",[16,413,414],{},[26,415],{"alt":408,"src":416},"https:\u002F\u002Fi.imgur.com\u002FgLoSZjL.png",[257,418,419],{"id":419},"集中討論",[16,421,422,423,183],{},"當你對某個人的話題需要集中討論時，可以移動過去到該對方的對話上，此時會出現 ",[104,424,425],{},"Start a thread",[16,427,428],{},[26,429],{"alt":425,"src":430},"https:\u002F\u002Fi.imgur.com\u002FVaqWRFr.png",[16,432,433],{},"這樣就可以在底下集中討論而不會出現洗頻的狀況，訊息也不會因此消失，Slack 會告知你該 Thread 有新的回應 ↓",[16,435,436],{},[26,437],{"alt":438,"src":439},"Thread","https:\u002F\u002Fi.imgur.com\u002FlmfnaAH.png",[257,441,443],{"id":442},"tag-標記","Tag (標記)",[16,445,446,447,450],{},"只要有使用過 LINE or Facebook 都知道該怎麼 Tag，只需要一個 ",[104,448,449],{},"@"," + 名稱就可以標記他人了，而被 Tag 的人也會收到通知 ↓",[16,452,453],{},[26,454],{"alt":455,"src":456},"Tag","https:\u002F\u002Fi.imgur.com\u002FxGEq9a9.png",[257,458,459],{"id":459},"表情符號",[16,461,462],{},"除了發送訊息可以加入表情符號之外，你也可以針對某人的對話發送出表情符號 ↓",[16,464,465],{},[26,466],{"alt":467,"src":468},"六角分享群好多怪怪的表情符號 XD","https:\u002F\u002Fi.imgur.com\u002FqoXw3NV.png",[257,470,471],{"id":471},"程式碼",[16,473,474],{},"另外 Slack 也支援你輸入程式碼區塊，主要有分為兩種模式",[265,476,477,479],{},[268,478,471],{},[268,480,481],{},"程式碼區塊",[16,483,484],{},"程式碼 ↓",[16,486,487],{},[26,488],{"alt":471,"src":489},"https:\u002F\u002Fi.imgur.com\u002FxJhsOuj.png",[16,491,492],{},[26,493],{"alt":494,"src":495},"撰寫方式兩個頓號包覆","https:\u002F\u002Fi.imgur.com\u002FBh7pMbZ.png",[16,497,498],{},"程式碼區塊  ↓",[16,500,501],{},[26,502],{"alt":481,"src":503},"https:\u002F\u002Fi.imgur.com\u002FlyXegev.png",[16,505,506],{},[26,507],{"alt":508,"src":509},"撰寫方式是上下用三個頓號包覆","https:\u002F\u002Fi.imgur.com\u002Fzoopoeo.png",[257,511,513],{"id":512},"md-語法","MD 語法",[16,515,516],{},"基本上 Slack 有支援基礎的 MD 語法，只要你會寫 MD 那麼你就非常熟悉 ↓",[16,518,519],{},[26,520],{"alt":521,"src":522},"MD 常見語法","https:\u002F\u002Fi.imgur.com\u002FV94KGsu.png",[16,524,525],{},[26,526],{"alt":527,"src":528},"對應寫法","https:\u002F\u002Fi.imgur.com\u002F9I2XxY4.png",[257,530,531],{"id":531},"其他功能",[16,533,534,535,538],{},"Slack 提供的功能滿多的，例如你也可以拖曳上傳檔案 or 直接 ",[104,536,537],{},"Ctrl + V"," 貼上截圖畫面等等，一時介紹不完。",[16,540,541,542,546],{},"Slack 繁體中文化可參考",[121,543,545],{"href":544},"\u002Fother\u002F20210408\u002F2677660062\u002F","這一篇","文章。",[12,548,549],{"id":549},"結尾",[16,551,552],{},"那麼以上是比較常見的基礎 Slack 操作，但是基本上不困難，而且你會發現使用 Slack 來溝通程式碼是真的滿方便的，因為我個人在使用 Line 與他人溝通程式碼時，往往會因為別人的訊息而刷掉訊息，完全連思考的機會都沒有 XD",[16,554,555],{},"最後感謝一下葉子幫我開 Slack 讓我截圖測試~~",{"title":557,"searchDepth":558,"depth":558,"links":559},"",2,[560,561,562,563,564,572,582],{"id":14,"depth":558,"text":14},{"id":21,"depth":558,"text":22},{"id":37,"depth":558,"text":38},{"id":89,"depth":558,"text":90},{"id":252,"depth":558,"text":252,"children":565},[566,568,569,570,571],{"id":259,"depth":567,"text":260},3,{"id":307,"depth":567,"text":308},{"id":329,"depth":567,"text":330},{"id":336,"depth":567,"text":337},{"id":348,"depth":567,"text":348},{"id":372,"depth":558,"text":372,"children":573},[574,575,576,577,578,579,580,581],{"id":378,"depth":567,"text":378},{"id":408,"depth":567,"text":408},{"id":419,"depth":567,"text":419},{"id":442,"depth":567,"text":443},{"id":459,"depth":567,"text":459},{"id":471,"depth":567,"text":471},{"id":512,"depth":567,"text":513},{"id":531,"depth":567,"text":531},{"id":549,"depth":558,"text":549},"雜談","2019-08-28 08:52:12","這一篇來記錄一下 Slack 的基礎操作與介紹，最主要 Slack 是滿多公司很常使用的溝通工具。","md","zh-Hant",{},true,"\u002Fslack","4",{"title":6,"description":585},false,"雜談\u002FSlack-基礎操作",[22,596],"軟體操作",null,"\u002Fother\u002F20190828\u002F2944044939\u002F","CvArFK6l5K396CxIaNLNUgahRYgELP1-ACU52tmDvOU",{"newer":601,"older":605},{"url":602,"title":603,"date":604},"\u002Fphp\u002F20190902\u002F536097622\u002F","Day1-從基礎學習 ThinkPHP-介紹","2019-09-02 11:28:58",{"url":606,"title":607,"date":608},"\u002Fvue\u002F20190821\u002F2073039643\u002F","Nuxt 出現 window or document undefined(window is not defined)","2019-08-21 11:23:55",[610,615,619],{"url":611,"title":612,"date":613,"readingMinutes":614},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":616,"title":617,"date":618,"readingMinutes":591},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00",{"url":620,"title":621,"date":622,"readingMinutes":623},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784011726235]