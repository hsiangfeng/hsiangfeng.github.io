;\nservice firebase.storage {\n  match \u002Fb\u002F{bucket}\u002Fo {\n    match \u002Fblog2\u002F{allPaths=**} {\n      allow read;\n    }\n  }\n}\n",[55,989,990,995,1000,1005,1010,1015,1019,1024],{"__ignoreMap":53},[58,991,992],{"class":60,"line":61},[58,993,994],{},"rules_version = '2';\n",[58,996,997],{"class":60,"line":67},[58,998,999],{},"service firebase.storage {\n",[58,1001,1002],{"class":60,"line":73},[58,1003,1004],{},"  match \u002Fb\u002F{bucket}\u002Fo {\n",[58,1006,1007],{"class":60,"line":351},[58,1008,1009],{},"    match \u002Fblog2\u002F{allPaths=**} {\n",[58,1011,1012],{"class":60,"line":367},[58,1013,1014],{},"      allow read;\n",[58,1016,1017],{"class":60,"line":377},[58,1018,600],{},[58,1020,1021],{"class":60,"line":385},[58,1022,1023],{},"  }\n",[58,1025,1026],{"class":60,"line":397},[58,1027,1028],{},"}\n",[12,1030,1031,1032,1035],{},"這邊只開放了 ",[55,1033,1034],{},"blog2\u002F"," 這個路徑的公開讀取權限，其他路徑完全不受影響。",[12,1037,1038],{},"你可能會擔心安全性的問題，但換個角度想，這些圖片本來就是公開的部落格文章在使用的，任何人都看得到。而且原本的 token 也是直接寫在網頁的 HTML 裡面，任何人打開開發者工具都能拿到，所以把圖片路徑改成公開讀取，實際上並沒有增加額外的安全風險。",[165,1040,1042],{"id":1041},"步驟五驗證","步驟五：驗證",[12,1044,1045],{},"打開瀏覽器，輸入以下格式的網址：",[48,1047,1049],{"className":50,"code":1048,"language":52,"meta":53,"style":53},"https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Fyour-folder\u002Fyour-image.png\n",[55,1050,1051],{"__ignoreMap":53},[58,1052,1053],{"class":60,"line":61},[58,1054,1048],{},[12,1056,1057],{},"如果看到圖片就代表設定成功了！",[19,1059,1060],{"id":1060},"更新圖片連結",[12,1062,1063],{},"設定完成後，接下來就是要把部落格中所有的 Firebase Storage 圖片連結替換成新的格式了。",[12,1065,1066],{},"原本的連結長這樣：",[48,1068,1070],{"className":50,"code":1069,"language":52,"meta":53,"style":53},"https:\u002F\u002Ffirebasestorage.googleapis.com\u002Fv0\u002Fb\u002FYOUR_PROJECT.appspot.com\u002Fo\u002Fblog2%2Ffolder%2Fimage.png?alt=media&token=xxx\n",[55,1071,1072],{"__ignoreMap":53},[58,1073,1074],{"class":60,"line":61},[58,1075,1069],{},[12,1077,1078],{},"替換成：",[48,1080,1082],{"className":50,"code":1081,"lan