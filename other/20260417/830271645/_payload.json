},[58,1266,1154],{"class":1153},[58,1268,1269,1272,1274,1276,1278,1280,1282,1284],{"class":60,"line":414},[58,1270,1271],{"class":315},"  while",[58,1273,1162],{"class":374},[58,1275,1165],{"class":315},[58,1277,1168],{"class":374},[58,1279,1171],{"class":361},[58,1281,1174],{"class":374},[58,1283,1177],{"class":345},[58,1285,1180],{"class":315},[58,1287,1288,1291,1293,1295,1298,1300,1302],{"class":60,"line":446},[58,1289,1290],{"class":1137},"    sed",[58,1292,1188],{"class":361},[58,1294,440],{"class":374},[58,1296,1297],{"class":374}," 's|\\(images\\.yourdomain\\.com\u002F[^)]*\\)%2F|\\1\u002F|g'",[58,1299,1196],{"class":374},[58,1301,1199],{"class":345},[58,1303,1202],{"class":374},[58,1305,1306],{"class":60,"line":473},[58,1307,1308],{"class":315},"  done\n",[58,1310,1311],{"class":60,"line":478},[58,1312,1207],{"class":315},[156,1314,1315],{"title":158,"type":159},[12,1316,1317,1318,1320,1321,1323,1324,1326],{},"第二步需要跑多次，因為 ",[55,1319,1119],{}," 一次只會替換一個 ",[55,1322,1109],{},"，跑迴圈可以確保所有的 ",[55,1325,1109],{}," 都被替換乾淨。另外如果你有多個 Firebase 專案的圖片，替換時要注意只替換目標專案的連結，避免誤改到其他專案的圖片 URL。",[164,1328,1330,1331,1333,1334],{"id":1329},"注意url-路徑要用-而不是-2f","注意：URL 路徑要用 ",[55,1332,1113],{}," 而不是 ",[55,1335,1109],{},[12,1337,1338],{},"這邊有一個很重要的眉角要提醒一下。",[12,1340,1341,1342,1344,1345,1350],{},"Firebase Storage 的 URL 格式是用 ",[55,1343,1109],{}," 來分隔路徑的（因為整個檔案路徑被當作一個 URL 區段），但在我們自己的子域名下，",[29,1346,1347,1348],{},"必須使用正常的 ",[55,1349,1113],{},"：",[48,1352,1354],{"className":50,"code":1353,"language":52,"meta":53,"style":53},"❌ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2%2Fai%2Fmy-post%2Fimage.png\n✅ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Fai\u002Fmy-post\u002Fimage.png\n",[55,1355,1356,1361],{"__ignoreMap":53},[58,1357,1358],{"class":60,"line":61},[58,1359,1360],{},"❌ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2%2Fai%2Fmy-post%2Fimage.png\n",[58,1362,1363],{"class":60,"line":67},[58,1364,1365],{},"✅ https:\u002F\u002Fimages.yourdomain.com\u002Fblog2\u002Fai\u002Fmy-post\u002Fimage.png\n",[12,1367,1368,1369,1371,1372,1374,1375,1377,1378,1381],{},"為什麼呢？因為 Cloudflare 在處理 ",[55,1370,1109],{}," 的時候會出現問題導致 404，而 Worker 內部會自動幫你把 ",[55,1373,1113],{}," 轉換成 Firebase 需要的 ",[55,1376,1109],{}," 格式（透過 ",[55,1379,1380],{},"encodeURIComponent","），所以你只需要用正常的路徑就好，不用自己去處理編碼的問題。",[19,1383,1385],{"id":1384},"上傳新圖片後怎麼取得-url","上傳新圖片後怎麼取得 URL？",[12,1387,1388],{},"那麼以後上傳新圖片的時候該怎麼取得 URL 呢？其實非常簡單，規則就是：",[48,1390,1392],{"className":50,"code":1391,"language":52,"meta":53,"style":53},"https:\u002F\u002Fimages.yourdomain.com\u002F + Firebase Storage 裡的路徑\n",[55,1393,1394],{"__ignoreMap":53},[58,1395,1396],{"class":60,"line":61},[58,1397,1391],{},[12,1399,1400,1401,1404],{},"舉例來說，你上傳了一張圖到 Firebase Storage 的 ",[55,1402,1403],{},"blog2\u002Fai\u002Fmy-post\u002Fscreenshot.png","，那麼 URL 就是：",[48,1406,1407],{"className":50,"code":194,"language":52,"meta":53,"style":53},[55,1408,1409],{"__ignoreMap":53},[58,1410,1411],{"class":60,"line":61},[58,1412,194],{},[12,1414,1415],{},"不需要再去拿什麼 token 了，直接拼路徑就好，是不是方便很多？",[19,1417,1418],{"id":1418},"快取的運作機制",[12,1420,1421],{},"最後來聊聊快取到底是怎麼運作的，讓你對這個方案更有信心。",[12,1423,1424],{},"我們在 Worker 中設定了兩個關鍵的 header：",[48,1426,1428],{"className":306,"code":1427,"language":308,"meta":53,"style":53},"headers.set('Cache-Control', 'public, max-age=31536000, immutable');\nheaders.set('CDN-Cache-Control', 'max-age=31536000');\n",[55,1429,1430,1447],{"__ignoreMap":53},[58,1431,1432,1435,1437,1439,1441,1443,1445],{"class":60,"line":61},[58,1433,1434],{"class":345},"headers.",[58,1436,783],{"class":331},[58,1438,335],{"class":345},[58,1440,788],{"class":374},[58,1442,395],{"class":345},[58,1444,793],{"class":374},[58,1446,796],{"class":345},[58,1448,1449,1451,1453,1455,1457,1459,1461],{"class":60,"line":67},[58,1450,1434],{"class":345},[58,1452,783],{"class":331},[58,1454,335],{"class":345},[58,1456,808],{"class":374},[58,1458,395],{"class":345},[58,1460,813],{"class":374},[58,1462,796],{"class":345},[12,1464,1465,1466,1350],{},"這其實建立了",[29,1467,1468],{},"兩層快取",[164,1470,1472],{"id":1471},"第一層cloudflare-cdn-邊緣節點快取","第一層：Cloudflare CDN 邊緣節點快取",[12,1474,1475,1478,1479,1482],{},[55,1476,1477],{},"CDN-Cache-Control"," 會告訴 Cloudflare 的邊緣節點：「這個檔案可以快取一年。」當第一個使用者請求圖片時，Cloudflare 會去 Firebase 拿圖片，然後存一份在離使用者最近的邊緣節點上。之後不管是誰再請求同一張圖片，Cloudflare 都直接從邊緣節點回傳，",[29,1480,1481],{},"不經過 Worker，也不打 Firebase","。",[164,1484,1486],{"id":1485},"第二層瀏覽器本地快取","第二層：瀏覽器本地快取",[12,1488,1489,1492,1493,1482],{},[55,1490,1491],{},"Cache-Control: public, max-age=31536000, immutable"," 則是告訴瀏覽器：「這個檔案可以存在本地一年，而且不會變。」所以同一個使用者再次造訪同一篇文章時，瀏覽器會直接用本地的快取，",[29,1494,1495],{},"連 Cloudflare 都不用打",[164,1497,1498],{"id":1498},"整體流程",[12,1500,1501],{},[29,1502,1503],{},"第一次請求（冷快取）：",[48,1505,1507],{"className":50,"code":1506,"language":52,"meta":53,"style":53},"使用者 → Cloudflare 邊緣節點（沒快取）→ Worker → Firebase Storage\n                ↓\n        存一份在邊緣節點 + 回傳給使用者\n",[55,1508,1509,1514,1519],{"__ignoreMap":53},[58,1510,1511],{"class":60,"line":61},[58,1512,1513],{},"使用者 → Cloudflare 邊緣節點（沒快取）→ Worker → Firebase Storage\n",[58,1515,1516],{"class":60,"line":67},[58,1517,1518],{},"                ↓\n",[58,1520,1521],{"class":60,"line":73},[58,1522,1523],{},"        存一份在邊緣節點 + 回傳給使用者\n",[12,1525,1526],{},[29,1527,1528],{},"第二次請求（CDN 快取命中）：",[48,1530,1532],{"className":50,"code":1531,"language":52,"meta":53,"style":53},"使用者 → Cloudflare 邊緣節點（有快取）→ 直接回傳\n",[55,1533,1534],{"__ignoreMap":53},[58,1535,1536],{"class":60,"line":61},[58,1537,1531],{},[12,1539,1540],{},[29,1541,1542],{},"同一使用者再次造訪（瀏覽器快取命中）：",[48,1544,1546],{"className":50,"code":1545,"language":52,"meta":53,"style":53},"使用者 → 瀏覽器本地快取 → 直接顯示\n",[55,1547,1548],{"__ignoreMap":53},[58,1549,1550],{"class":60,"line":61},[58,1551,1545],{},[12,1553,1554,1555,1558],{},"因為部落格的圖片上傳後幾乎不會修改，所以設定一年的快取時間加上 ",[55,1556,1557],{},"immutable"," 是完全合理的。",[19,1560,1561],{"id":1561},"結論",[12,1563,1564],{},"透過 Cloudflare Workers 搭配 CDN 快取，我們可以在不花一毛錢的情況下，大幅降低 Firebase Storage 的流量消耗，整個設定過程大概也不需要花太多時間，但帶來的效益卻是長期的。",[12,1566,1567],{},"最後整理一下這個方案的優點：",[1569,1570,1571,1576,1582,1588,1593],"ul",{},[221,1572,1573,1575],{},[29,1574,31],{},"：不需要信用卡，不需要付費方案",[221,1577,1578,1581],{},[29,1579,1580],{},"全球加速","：Cloudflare 在全球有超過 300 個邊緣節點，圖片從離使用者最近的節點回傳",[221,1583,1584,1587],{},[29,1585,1586],{},"減少流量","：快取命中後完全不打 Firebase，流量歸零",[221,1589,1590,1592],{},[29,1591,920],{},"：可以限制只有你的網站能存取，防止盜連",[221,1594,1595,1598],{},[29,1596,1597],{},"更短的 URL","：從一長串的 Firebase URL 變成乾淨的子域名格式",[12,1600,1601],{},"如果你也有在用 Firebase Storage 來存放圖片，非常推薦試試看這個方案哩～",[1603,1604,1605],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html 