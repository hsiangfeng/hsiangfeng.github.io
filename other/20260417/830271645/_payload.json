373,1113],{}," 轉換成 Firebase 需要的 ",[55,1376,1109],{}," 格式（透過 ",[55,1379,1380],{},"encodeURIComponent","），所以你只需要用正常的路徑就好，不用自己去處理編碼的問題。",[19,1383,1385],{"id":1384},"上傳新圖片後怎麼取得-url","上傳新圖片後怎麼取得 URL？",[12,1387,1388],{},"那麼以後上傳新圖片的時候該怎麼取得 URL 呢？其實非常簡單，規則就是：",[48,1390,1392],{"className":50,"code":1391,"language":52,"meta":53,"style":53},"https:\u002F\u002Fimages.yourdomain.com\u002F + Firebase Storage 裡的路徑\n",[55,1393,1394],{"__ignoreMap":53},[58,1395,1396],{"class":60,"line":61},[58,1397,1391],{},[12,1399,1400,1401,1404],{},"舉例來說，你上傳了一張圖到 Firebase Storage 的 ",[55,1402,1403],{},"blog2\u002Fai\u002Fmy-post\u002Fscreenshot.png","，那麼 URL 就是：",[48,1406,1407],{"className":50,"code":195,"language":52,"meta":53,"style":53},[55,1408,1409],{"__ignoreMap":53},[58,1410,1411],{"class":60,"line":61},[58,1412,195],{},[12,1414,1415],{},"不需要再去拿什麼 token 了，直接拼路徑就好，是不是方便很多？",[19,1417,1418],{"id":1418},"快取的運作機制",[12,1420,1421],{},"最後來聊聊快取到底是怎麼運作的，讓你對這個方案更有信心。",[12,1423,1424],{},"我們在 Worker 中設定了兩個關鍵的 header：",[48,1426,1428],{"className":309,"code":1427,"language":311,"meta":53,"style":53},"headers.set('Cache-Control', 'public, max-age=31536000, immutable');\nheaders.set('CDN-Cache-Control', 'max-age=31536000');\n",[55,1429,1430,1447],{"__ignoreMap":53},[58,1431,1432,1435,1437,1439,1441,1443,1445],{"class":60,"line":61},[58,1433,1434],{"class":341},"headers.",[58,1436,781],{"class":334},[58,1438,426],{"class":341},[58,1440,786],{"class":370},[58,1442,391],{"class":341},[58,1444,791],{"class":370},[58,1446,794],{"class":341},[58,1448,1449,1451,1453,1455,1457,1459,1461],{"class":60,"line":67},[58,1450,1434],{"class":341},[58,1452,781],{"class":334},[58,1454,426],{"class":341},[58,1456,806],{"class":370},[58,1458,391],{"class":341},[58,1460,811],{"class":370},[58,1462,794],{"class":341},[12,1464,1465,1466,1350],{},"這其實建立了",[29,1467,1468],{},"兩層快取",[165,1470,1472],{"id":1471},"第一層cloudflare-cdn-邊緣節點快取","第一層：Cloudflare CDN 邊緣節點快取",[12,1474,1475,1478,1479,1482],{},[55,1476,1477],{},"CDN-Cache-Control"," 會告訴 Cloudflare 的邊緣節點：「這個檔案可以快取一年。」當第一個使用者請求圖片時，Cloudflare 會去 Firebase 拿圖片，然後存一份在離使用者最近的邊緣節點上。之後不管是誰再請求同一張圖片，Cloudflare 都直接從邊緣節點回傳，",[29,1480,1481],{},"不經過 Worker，也不打 Firebase","。",[165,1484,1486],{"id":1485},"第二層瀏覽器本地快取","第二層：瀏覽器本地快取",[12,1488,1489,1492,1493,1482],{},[55,1490,1491],{},"Cache-Control: public, max-age=31536000, immutable"," 則是告訴瀏覽器：「這個檔案可以存在本地一年，而且不會變。」所以同一個使用者再次造訪同一篇文章時，瀏覽器會直接用本地的快取，",[29,1494,1495],{},"連 Cloudflare 都不用打",[165,1497,1498],{"id":1498},"整體流程",[12,1500,1501],{},[29,1502,1503],{},"第一次請求（冷快取）：",[48,1505,1507],{"className":50,"code":1506,"language":52,"meta":53,"style":53},"使用者 → Cloudflare 邊緣節點（沒快取）→ Worker → Firebase Storage\n                ↓\n        存一份在邊緣節點 + 回傳給使用者\n",[55,1508,1509,1514,1519],{"__ignoreMap":53},[58,1510,1511],{"class":60,"line":61},[58,1512,1513],{},"使用者 → Cloudflare 邊緣節點（沒快取）→ Worker → Firebase Storage\n",[58,1515,1516],{"class":60,"line":67},[58,1517,1518],{},"                ↓\n",[58,1520,1521],{"class":60,"line":73},[58,1522,1523],{},"        存一份在邊緣節點 + 回傳給使用者\n",[12,1525,1526],{},[29,1527,1528],{},"第二次請求（CDN 快取命中）：",[48,1530,1532],{"className":50,"code":1531,"language":52,"meta":53,"style":53},"使用者 → Cloudflare 邊緣節點（有快取）→ 直接回傳\n",[55,1533,1534],{"__ignoreMap":53},[58,1535,1536],{"class":60,"line":61},[58,1537,1531],{},[12,1539,1540],{},[29,1541,1542],{},"同一使用者再次造訪（瀏覽器快取命中）：",[48,1544,1546],{"className":50,"code":1545,"language":52,"meta":53,"style":53},"使用者 → 瀏覽器本地快取 → 直接顯示\n",[55,1547,1548],{"__ignoreMap":53},[58,1549,1550],{"class":60,"line":61},[58,1551,1545],{},[12,1553,1554,1555,1558],{},"因為部落格的圖片上傳後幾乎不會修改，所以設定一年的快取時間加上 ",[55,1556,1557],{},"immutable"," 是完全合理的。",[19,1560,1561],{"id":1561},"結論",[12,1563,1564],{},"透過 Cloudflare Workers 搭配 CDN 快取，我們可以在不花一毛錢的情況下，大幅降低 Firebase Storage 的流量消耗，整個設定過程大概也不需要花太多時間，但帶來的效益卻是長期的。",[12,1566,1567],{},"最後整理一下這個方案的優點：",[1569,1570,1571,1576,1582,1588,1593],"ul",{},[222,1572,1573,1575],{},[29,1574,31],{},"：不需要信用卡，不需要付費方案",[222,1577,1578,1581],{},[29,1579,1580],{},"全球加速","：Cloudflare 在全球有超過 300 個邊緣節點，圖片從離使用者最近的節點回傳",[222,1583,1584,1587],{},[29,1585,1586],{},"減少流量","：快取命中後完全不打 Firebase，流量歸零",[222,1589,1590,1592],{},[29,1591,920],{},"：可以限制只有你的網站能存取，防止盜連",[222,1594,1595,1598],{},[29,1596,1597],{},"更短的 URL","：從一長串的 Firebase URL 變成乾淨的子域名格式",[12,1600,1601],{},"如果你也有在用 Firebase Storage 來存放圖片，非常推薦試試看這個方案哩～",[1603,1604,1605],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":53,"searchDepth":67,"depth":67,"links":1607},[1608,1609,1610,1613,1614,1622,1626,1627,1632],{"id":21,"depth":67,"text":21},{"id":39,"depth":67,"text":40},{"id":86,"depth":67,"text":87,"children":1611},[1612],{"id":167,"depth":73,"text":167},{"id":177,"depth":67,"text":178},{"id":207,"depth":67,"text":207,"children":1615},[1616,1617,1618,1619,1620,1621],{"id":213,"depth":73,"text":214},{"id":265,"depth":73,"text":266},{"id":909,"depth":73,"text":910},{"id":946,"depth":73,"text":947},{"id":977,"depth":73,"text":978},{"id":1041,"depth":73,"text":1042},{"id":1060,"depth":67,"text":1060,"children":1623},[1624],{"id":1329,"depth":73,"text":1625},"注意：URL 路徑要用 \u002F 而不是 %2F",{"id":1384,"depth":67,"text":1385},{"id":1418,"depth":67,"text":1418,"children":1628},[1629,1630,1631],{"id":1471,"depth":73,"text":1472},{"id":1485,"depth":73,"text":1486},{"id":1498,"depth":73,"text":1498},{"id":1561,"depth":67,"text":1561},"雜談","2026-04-17 10:00:00","如果你跟我一樣使用 Firebase Storage 來存放部落格的圖片，那你應該多少會有一個煩惱，那就是流量費用，每當有人造訪你的文章圖片就會從 Firebase Storage 下載一次，這些流量全部都算在你的 Firebase 帳單上，所以這篇文章就來聊聊如何用 Cloudflare Workers 搭配自訂子域名來快取圖片，而且整個方案完全免費、不需要信用卡。","md","zh-Hant",{},"\u002Fcloudflare-workers-firebase-storage","6",{"title":6,"description":1635},false,"雜談\u002F用-Cloudflare-Workers-快取-Firebase-Storage-圖片，完全免費降低流量費用",[231,1645,1646,1647,35],"Firebase","CDN","Cache",null,"\u002Fother\u002F20260417\u002F830271645\u002F","u0aWLvNdgxUdaRaeBRmZBBzZkMqrldzEXHS5ohmxZoE",{"newer":1652,"older":1656},{"url":1653,"title":1654,"date":1655},"\u002Fother\u002F20260420\u002F913443764\u002F","從 Firebase Storage 搬家到 Cloudflare R2，完整遷移紀錄","2026-04-20 23:00:00",{"url":1657,"title":1658,"date":1659},"\u002Fai\u002F20260412\u002F1749382056\u002F","想自己跑 LLM？搞懂模型參數與量化讓你不再選錯模型","2026-04-12 23:30:00",[1661,1666,1671],{"url":1662,"title":1663,"date":1664,"readingMinutes":1665},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":1667,"title":1668,"date":1669,"readingMinutes":1670},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":1672,"title":1673,"date":1674,"readingMinutes":1675},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784012804689]