[{"data":1,"prerenderedAt":454},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20210603\u002F2683176705\u002F":3,"page:\u002Fother\u002F20210603\u002F2683176705\u002F":4,"alt:\u002Fother\u002F20210603\u002F2683176705\u002F":3,"prev-next:\u002Fother\u002F20210603\u002F2683176705\u002F":429,"related:\u002Fother\u002F20210603\u002F2683176705\u002F":438},"\u002Fen\u002Fmisc\u002F2021\u002F06\u002F03\u002Fmac-zsh-command-not-found-npm-nvm-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":409,"date":410,"description":411,"extension":412,"lang":413,"meta":414,"navigation":415,"path":416,"readingMinutes":417,"seo":418,"standalone":419,"stem":420,"tags":421,"tldr":425,"updated":426,"url":427,"__hash__":428},"content\u002F雜談\u002F解決-Mac-輸入指令出現-zsh-command-not-found-xxx-問題.md","解決 Mac 輸入指令出現 zsh: command not found: xxx 問題","2683176705",{"type":9,"value":10,"toc":393},"minimark",[11,15,23,26,29,39,45,74,77,80,83,99,106,109,124,127,132,135,144,157,160,163,167,170,179,182,185,194,204,211,214,220,224,227,236,247,251,257,266,269,278,281,290,293,297,300,309,312,315,318,321,324,333,336,352,368,375,378,389],[12,13,14],"h2",{"id":14},"前言",[16,17,18,22],"p",{},[19,20,21],"code",{},"zsh: command not found: xxx"," 這個錯誤訊息我發現滿多人會遇到的，所以這一篇就來紀錄一下如何解決這個問題。",[12,24,25],{"id":25},"問題描述",[16,27,28],{},"首先我先來描述一下狀況，目前手上遇到的狀況有兩種，所以我也會針對這兩種狀況來進行說明與解決，分別是：",[30,31,32,36],"ul",{},[33,34,35],"li",{},"有安裝並使用 nvm 的狀況",[33,37,38],{},"沒有安裝 nvm，直接安裝 Node.js 的狀況",[16,40,41,42,44],{},"而這些都是發生在使用了 zsh 之後導致的，只要你輸入任何指令都會出現 ",[19,43,21],{}," 的錯誤訊息，如...",[46,47,52],"pre",{"className":48,"code":49,"language":50,"meta":51,"style":51},"language-cmd shiki shiki-themes github-dark-high-contrast","zsh: command not found: hexo\nzsh: command not found: vue-cli\n...\n","cmd","",[19,53,54,62,68],{"__ignoreMap":51},[55,56,59],"span",{"class":57,"line":58},"line",1,[55,60,61],{},"zsh: command not found: hexo\n",[55,63,65],{"class":57,"line":64},2,[55,66,67],{},"zsh: command not found: vue-cli\n",[55,69,71],{"class":57,"line":70},3,[55,72,73],{},"...\n",[16,75,76],{},"所以就讓我們一個一個來解決吧！",[12,78,35],{"id":79},"有安裝並使用-nvm-的狀況",[16,81,82],{},"通常來講，我們在實戰開發上都會使用 nvm 來管理我們的 Node.js 版本，透過 nvm 可以很方便且快速的切換 Node.js 版本，並且安裝的套件也不會互相干擾，但是有時候會發生以下問題",[46,84,85],{"className":48,"code":49,"language":50,"meta":51,"style":51},[19,86,87,91,95],{"__ignoreMap":51},[55,88,89],{"class":57,"line":58},[55,90,61],{},[55,92,93],{"class":57,"line":64},[55,94,67],{},[55,96,97],{"class":57,"line":70},[55,98,73],{},[16,100,101,102,105],{},"只是你會發現 ",[19,103,104],{},"nvm"," 卻是正常的(WT...)",[16,107,108],{},"如果運氣好，你可能會在終端機上看到以下訊息：",[46,110,112],{"className":48,"code":111,"language":50,"meta":51,"style":51},"nvm is not compatible with the npm config \"prefix\" option: currently set to \"\u002FUsers\u002Fray\u002F.npm-global\"\nRun `nvm use --delete-prefix v14.15.1 --silent` to unset it.\n",[19,113,114,119],{"__ignoreMap":51},[55,115,116],{"class":57,"line":58},[55,117,118],{},"nvm is not compatible with the npm config \"prefix\" option: currently set to \"\u002FUsers\u002Fray\u002F.npm-global\"\n",[55,120,121],{"class":57,"line":64},[55,122,123],{},"Run `nvm use --delete-prefix v14.15.1 --silent` to unset it.\n",[16,125,126],{},"這樣就比較好解決問題，因為這段錯誤訊息就是在跟你說，你的 npm 設定的前綴路徑跟 nvm 不相容，所以你必須要先解決這個問題，才能夠正常使用 nvm，接下來就來一個一個步驟處理吧～",[128,129,131],"h3",{"id":130},"步驟一移除-npm-前綴路徑","步驟一：移除 npm 前綴路徑",[16,133,134],{},"首先我們要先移除 npm 的前綴路徑，這樣才能夠讓 nvm 正常運作，所以請輸入以下指令",[46,136,138],{"className":48,"code":137,"language":50,"meta":51,"style":51},"nvm use --delete-prefix vxx.xx.xx --silent\n",[19,139,140],{"__ignoreMap":51},[55,141,142],{"class":57,"line":58},[55,143,137],{},[145,146,147],"blockquote",{},[16,148,149,153,154],{},[150,151,152],"strong",{},"Note","\nxx 代表的是你的 Node.js 版本，因此我目前假設使用 v14.15.1 就是輸入以下\n",[19,155,156],{},"nvm use --delete-prefix v14.15.1 --silent",[16,158,159],{},"這個指令主要用途是，先切換到你指定的 Node.js 版本，然後刪除 npm 的前綴路徑，這樣就可以讓 nvm 正常運作了。",[16,161,162],{},"到這邊你可以先嘗試輸入一些指令，看看是否已經正常運作了，如果還是沒有的話，那就繼續往下走～",[128,164,166],{"id":165},"步驟二重新設置-npm-的前綴路徑","步驟二：重新設置 npm 的前綴路徑",[16,168,169],{},"接下來我們要重新設置 npm 的前綴路徑，這樣才能夠讓 npm 正常運作，所以請輸入以下指令",[46,171,173],{"className":48,"code":172,"language":50,"meta":51,"style":51},"npm config delete prefix\n",[19,174,175],{"__ignoreMap":51},[55,176,177],{"class":57,"line":58},[55,178,172],{},[16,180,181],{},"這個指令是在幫我們刪除儲存在 npm 設定檔中的前綴路徑，讓它恢復到預設路徑（也就是 .npm-global）。",[16,183,184],{},"移除完畢後，我們要重新設置 npm 的前綴路徑，所以請輸入以下指令",[46,186,188],{"className":48,"code":187,"language":50,"meta":51,"style":51},"npm config set prefix $NVM_DIR\u002Fversions\u002Fnode\u002Fvxx.xx.x\n",[19,189,190],{"__ignoreMap":51},[55,191,192],{"class":57,"line":58},[55,193,187],{},[145,195,196],{},[16,197,198,200,201],{},[150,199,152],{},"\nvxx.xx.x 請依據你使用的 Node 版本調整，因此我的就是如下\n",[19,202,203],{},"npm config set prefix $NVM_DIR\u002Fversions\u002Fnode\u002Fv14.15.1",[16,205,206,207,210],{},"理論上來講，到這邊你應該就解決了無法使用特定指令的問題了，也不會再出現 ",[19,208,209],{},"nvm is not compatible with the npm config \"prefix\""," 警告哩～",[12,212,38],{"id":213},"沒有安裝-nvm直接安裝-nodejs-的狀況",[16,215,216,217,219],{},"理論上來說，如果你輸入 npm 指令都正常，但在你安裝特定 Global 套件時出現 ",[19,218,21],{}," 的錯誤訊息，那就代表你的 zsh 環境變數沒有設定好，所以你需要手動設定一下。",[128,221,223],{"id":222},"步驟一確認-zshrc-路徑","步驟一：確認 .zshrc 路徑",[16,225,226],{},"首先我們要先確認一下 zsh 的環境變數是否有設定正確，請幫我輸入以下指令找到你的 zsh 設定檔路徑",[46,228,230],{"className":48,"code":229,"language":50,"meta":51,"style":51},"echo $ZDOTDIR\u002F.zshrc\n",[19,231,232],{"__ignoreMap":51},[55,233,234],{"class":57,"line":58},[55,235,229],{},[16,237,238,239,242,243,246],{},"如果 ",[19,240,241],{},"$ZDOTDIR"," 是空的，那你應該會看到 ",[19,244,245],{},"~\u002F.zshrc"," 這個路徑，這就是你的 zsh 設定檔路徑。",[128,248,250],{"id":249},"步驟二確認-zshrc-內容","步驟二：確認 .zshrc 內容",[16,252,253,254,256],{},"接下來要請你依照剛剛找到的路徑，打開你的 zsh 設定檔，如果輸出的路徑是 ",[19,255,245],{},"，那就請輸入以下指令",[46,258,260],{"className":48,"code":259,"language":50,"meta":51,"style":51},"cat ~\u002F.zshrc\n",[19,261,262],{"__ignoreMap":51},[55,263,264],{"class":57,"line":58},[55,265,259],{},[16,267,268],{},"這時候你的終端機應該會噴出一些內容，幫我找看看有沒有以下內容",[46,270,272],{"className":48,"code":271,"language":50,"meta":51,"style":51},"export PATH=\"$PATH:'`npm config get prefix`'\u002Fbin\"\n",[19,273,274],{"__ignoreMap":51},[55,275,276],{"class":57,"line":58},[55,277,271],{},[16,279,280],{},"如果有的話，那就代表你的 zsh 環境變數設定正確，那可能是 npm 有快取問題，只需要輸入以下指令即可",[46,282,284],{"className":48,"code":283,"language":50,"meta":51,"style":51},"npm cache clean --force\n",[19,285,286],{"__ignoreMap":51},[55,287,288],{"class":57,"line":58},[55,289,283],{},[16,291,292],{},"這個指令是在幫我們清除 npm 快取，讓它重新下載，有時候這階段就解決了。",[128,294,296],{"id":295},"步驟三手動設定-zsh-環境變數","步驟三：手動設定 zsh 環境變數",[16,298,299],{},"那找不到呢？該怎麼辦？其實就是手動設定一下 zsh 環境變數，所以請打開終端機，輸入以下指令",[46,301,303],{"className":48,"code":302,"language":50,"meta":51,"style":51},"echo 'export PATH=\"$PATH:'`npm config get prefix`'\u002Fbin\"' >> ~\u002F.zshrc\n",[19,304,305],{"__ignoreMap":51},[55,306,307],{"class":57,"line":58},[55,308,302],{},[16,310,311],{},"這段指令的意思是，我們要將 npm 的前綴路徑加入到 zsh 環境變數中，這樣才能夠讓你的 zsh 正常運作。",[16,313,314],{},"理論上到這一步之後，你的問題應該就解決了囉～",[12,316,317],{"id":317},"提醒",[16,319,320],{},"不論你是做哪一個步驟，請務必記得重新開啟終端機，讓設定檔生效，否則你的設定是不會生效的。",[16,322,323],{},"或者你也可以輸入以下指令，讓設定檔立即生效",[46,325,327],{"className":48,"code":326,"language":50,"meta":51,"style":51},"source ~\u002F.zshrc\n",[19,328,329],{"__ignoreMap":51},[55,330,331],{"class":57,"line":58},[55,332,326],{},[12,334,335],{"id":335},"結語",[16,337,338,339,341,342,345,346,348,349,351],{},"那什麼會發生這些問題呢？如果是 ",[19,340,104],{}," 的話，可能是因為更新 Node.js 版本時，",[19,343,344],{},"npm"," 的前綴路徑沒有被正確的更新，所以導致 ",[19,347,104],{}," 與 ",[19,350,344],{}," 之間的衝突導致的，",[16,353,354,355,357,358,361,362,364,365,367],{},"但如果是直接安裝 Node.js 的話，可能是因為 ",[19,356,344],{}," 的前綴路徑沒有被正確的設定到 ",[19,359,360],{},"zsh"," 環境變數中，所以導致 ",[19,363,360],{}," 無法正常使用 ",[19,366,344],{}," 的指令，通常這部分是出在權限不足或是忘記設定的問題。",[16,369,370,371,374],{},"當然也有一種狀況可能是 Mac 權限不足，如果是權限不足導致無法安裝全域套件，那就需要使用 ",[19,372,373],{},"sudo"," 來執行指令，所以這部分還是需要看錯誤訊息以及狀況來判斷該如何處理哩。",[12,376,377],{"id":377},"參考文獻",[30,379,380],{},[33,381,382],{},[383,384,388],"a",{"href":385,"rel":386},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F34718528\u002Fnvm-is-not-compatible-with-the-npm-config-prefix-option",[387],"nofollow","nvm is not compatible with the npm config “prefix” option",[390,391,392],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":51,"searchDepth":64,"depth":64,"links":394},[395,396,397,401,406,407,408],{"id":14,"depth":64,"text":14},{"id":25,"depth":64,"text":25},{"id":79,"depth":64,"text":35,"children":398},[399,400],{"id":130,"depth":70,"text":131},{"id":165,"depth":70,"text":166},{"id":213,"depth":64,"text":38,"children":402},[403,404,405],{"id":222,"depth":70,"text":223},{"id":249,"depth":70,"text":250},{"id":295,"depth":70,"text":296},{"id":317,"depth":64,"text":317},{"id":335,"depth":64,"text":335},{"id":377,"depth":64,"text":377},"雜談","2021-06-03 09:53:17","zsh: command not found: xxx' 這個錯誤訊息我發現滿多人會遇到的，所以這一篇就來紀錄一下如何解決這個問題。","md","zh-Hant",{},true,"\u002Fmac-zsh-command-not-found-xxx","3",{"title":6,"description":411},false,"雜談\u002F解決-Mac-輸入指令出現-zsh-command-not-found-xxx-問題",[422,423,424,360],"Mac","障礙排除","Terminal",null,"2024-03-03 16:20:00","\u002Fother\u002F20210603\u002F2683176705\u002F","Denod1Vw1Baa5i8NNjv34f_ikkTK5cv3yUxz9DUTKFQ",{"newer":430,"older":434},{"url":431,"title":432,"date":433},"\u002Fjavascript\u002F20210606\u002F118774217\u002F","JavaScript 核心觀念(56)- 物件屬性延伸章節：屬性的特徵 - 屬性列舉與原型的關係","2021-06-06 14:21:44",{"url":435,"title":436,"date":437},"\u002Fother\u002F20210530\u002F1324443947\u002F","攸關 SEO 的三大核心指標 LCP、FID、CLS","2021-05-30 22:20:27",[439,444,449],{"url":440,"title":441,"date":442,"readingMinutes":443},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":445,"title":446,"date":447,"readingMinutes":448},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":450,"title":451,"date":452,"readingMinutes":453},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784013091882]