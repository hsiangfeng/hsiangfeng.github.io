[{"data":1,"prerenderedAt":319},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20250114\u002F4149194649\u002F":3,"page:\u002Fother\u002F20250114\u002F4149194649\u002F":4,"alt:\u002Fother\u002F20250114\u002F4149194649\u002F":3,"prev-next:\u002Fother\u002F20250114\u002F4149194649\u002F":294,"related:\u002Fother\u002F20250114\u002F4149194649\u002F":303},"\u002Fen\u002Fmisc\u002F2025\u002F01\u002F14\u002Fraycast-extensions-i-recommend\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":274,"date":275,"description":276,"extension":277,"lang":278,"meta":279,"navigation":280,"path":281,"readingMinutes":282,"seo":283,"standalone":284,"stem":285,"tags":286,"tldr":291,"updated":275,"url":292,"__hash__":293},"content\u002F雜談\u002F關於我推的-Raycast-擴充套件，強化你的-Raycast！.md","關於我推的 Raycast 擴充套件，強化你的 Raycast！","4149194649",{"type":9,"value":10,"toc":258},"minimark",[11,15,19,23,33,36,41,44,52,55,58,65,72,78,82,85,88,94,99,104,108,111,117,122,127,131,134,140,145,150,154,157,163,168,173,177,180,186,191,196,200,209,212,218,223,227,236,239,245,250,255],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前陣子有朋友看到我開啟專案以及操作速度非常之快，同為使用 Raycast 朋友就很好奇我是不是有私藏什麼超好用套件，所以這邊就來分享一下我推薦的 Raycast 擴充套件，讓你的工作流程更強大！",[12,20,22],{"id":21},"raycast-套件推薦","Raycast 套件推薦",[16,24,25,26],{},"那麼 Raycast 我先前已經有寫文章介紹過，所以這邊就不再贅述，如果你還不知道 Raycast 是什麼，可以參考我之前的文章：",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20230412\u002F77568631\u002F",[31],"nofollow","來吧！用 Raycast 取代 Mac 內建 Spotlight 吧！",[16,34,35],{},"那麼底下除了簡單說明一下這些套件之外，我也會附上下載連結以及我的使用心得 Alias（快捷鍵） 給你參考哩",[37,38,40],"h3",{"id":39},"raycast-tinypng","Raycast - TinyPNG",[16,42,43],{},"身為前端開發者，應該對於 TinyPNG 都不陌生，畢竟是一個非常老牌的圖片壓縮網站，而這個 Raycast 擴充套件就是可以讓你直接在 Raycast 上使用 TinyPNG 的服務，讓你可以更快速的壓縮圖片！",[16,45,46,47],{},"但是要使用之前你必須要先去申請 TinyPNG Token 而申請的教學文章你可以參考我先前的文章：",[27,48,51],{"href":49,"rel":50},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20221225\u002F1867465275\u002F#%E5%A3%93%E7%B8%AE%E5%9C%96%E7%89%87-TinyPNG",[31],"一步一步帶你用 Node.js 上傳檔案到 Firebase Storage 之 壓縮圖片(TinyPNG)",[16,53,54],{},"你只需要觀看「壓縮圖片(TinyPNG)」章節即可。",[16,56,57],{},"那麼一個月有 500 次圖片壓縮的機會，應該對於一般使用者來說是非常足夠的～",[16,59,60,61],{},"下載連結：",[27,62,40],{"href":63,"rel":64},"https:\u002F\u002Fwww.raycast.com\u002Fkawamataryo\u002Ftinypng",[31],[16,66,67,68],{},"Alias：",[69,70,71],"code",{},"tinypng",[16,73,74],{},[75,76],"img",{"alt":40,"src":77},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.22.12.png",[37,79,81],{"id":80},"raycast-kill-process","Raycast - Kill Process",[16,83,84],{},"Kill Process 是一款專門殺除卡在 Mac 上的 Process 的 Raycast 擴充套件，如果你很常遇到「Mac Port xxx is already in use」這種情況，那麼這個套件就非常適合你！",[16,86,87],{},"你可以快速的找到卡住的 Process 並且殺除，讓被卡住的 Port 釋放出來。",[16,89,60,90],{},[27,91,81],{"href":92,"rel":93},"https:\u002F\u002Fwww.raycast.com\u002Frolandleth\u002Fkill-process",[31],[16,95,67,96],{},[69,97,98],{},"kill",[16,100,101],{},[75,102],{"alt":81,"src":103},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.21.54.png",[37,105,107],{"id":106},"raycast-visual-studio-code","Raycast - Visual Studio Code",[16,109,110],{},"這是我工作以及下班有超過 8 成都必定會使用的套件，以往我們再開啟專案都需要透過 Finder 找到專案資料夾，然後再開啟 Visual Studio Code，但是你可以直接透過這個專案直接搜尋關鍵字，就可以直接開啟專案，非常方便！",[16,112,60,113],{},[27,114,107],{"href":115,"rel":116},"https:\u002F\u002Fwww.raycast.com\u002Fthomas\u002Fvisual-studio-code",[31],[16,118,67,119],{},[69,120,121],{},"code .",[16,123,124],{},[75,125],{"alt":107,"src":126},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.22.18.png",[37,128,130],{"id":129},"raycast-google-translate","Raycast - Google Translate",[16,132,133],{},"超級無敵懶得每次都要打開瀏覽器搜尋「Google 翻譯」，現在你可以直接透過 Raycast 來使用 Google 翻譯服務",[16,135,60,136],{},[27,137,130],{"href":138,"rel":139},"https:\u002F\u002Fwww.raycast.com\u002Fgebeto\u002Ftranslate",[31],[16,141,67,142],{},[69,143,144],{},"gt",[16,146,147],{},[75,148],{"alt":130,"src":149},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.21.45.png",[37,151,153],{"id":152},"raycast-speedtest","Raycast - Speedtest",[16,155,156],{},"網路不順？不知道是不是網路問題？通常我們都要打開瀏覽器搜尋「Speedtest」，而這個套件基本上就是幫你把網路速度測試工具放到 Raycast 上",[16,158,60,159],{},[27,160,153],{"href":161,"rel":162},"https:\u002F\u002Fwww.raycast.com\u002Fgebeto\u002Fspeedtest",[31],[16,164,67,165],{},[69,166,167],{},"speed",[16,169,170],{},[75,171],{"alt":153,"src":172},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.22.08.png",[37,174,176],{"id":175},"raycast-format-json","Raycast - Format JSON",[16,178,179],{},"身為前端開發者一定對於 JSON 不陌生，但是有時候會拿到一些非常雜亂的 JSON，這時候你就可以透過這個套件來幫你格式化 JSON，讓你可以更加清楚的看到 JSON 的結構～",[16,181,60,182],{},[27,183,176],{"href":184,"rel":185},"https:\u002F\u002Fwww.raycast.com\u002Fdestiner\u002Fjson-format",[31],[16,187,67,188],{},[69,189,190],{},"json",[16,192,193],{},[75,194],{"alt":176,"src":195},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.21.34.png",[37,197,199],{"id":198},"raycast-base64","Raycast - Base64",[16,201,202,203,208],{},"Base64 如果你不熟悉的話，我非常推薦你要閱讀我這一篇文章",[27,204,207],{"href":205,"rel":206},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20231022\u002F2787463355\u002F",[31],"加密是什麼呢？為什麼要加密？關於加密的基本觀念","，我希望你在使用之前要先知道 Base64 並不是拿來加密用，而是一種編碼方式。",[16,210,211],{},"使用這個套件好處在於可以快速幫助我們將文字轉換成 Base64 編碼或者是將 Base64 編碼轉換成文字",[16,213,60,214],{},[27,215,199],{"href":216,"rel":217},"https:\u002F\u002Fwww.raycast.com\u002FDanielSinclair\u002Fbase64",[31],[16,219,220],{},[75,221],{"alt":199,"src":222},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.20.51.png",[37,224,226],{"id":225},"raycast-jwt-decoder","Raycast - JWT Decoder",[16,228,229,230,235],{},"JWT 是一種非常常見的 Token 驗證方式，而這個 JWT 是可以反向解析的，如果你好奇這運作過程，可以參考",[27,231,234],{"href":232,"rel":233},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20231013\u002F3280561145\u002F",[31],"Day29-關於 JWT 驗證","，這一篇文章我將會詳解 JWT 的運作方式",[16,237,238],{},"那麼這個套件目的就是幫我們將 JWT Token 解析成 JSON 格式，讓我們可以更加清楚的看到 Token 的內容與格式等",[16,240,60,241],{},[27,242,226],{"href":243,"rel":244},"https:\u002F\u002Fwww.raycast.com\u002Fgdsmith\u002Fjwt-decoder",[31],[16,246,67,247],{},[69,248,249],{},"jwt",[16,251,252],{},[75,253],{"alt":226,"src":254},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fother\u002Fraycast-extension\u002F%E6%88%AA%E5%9C%96%202025-01-14%2010.22.53.png",[16,256,257],{},"那麼以上就是我有使用且推薦的 Raycast 擴充套件，希望這些擴充套件可以大大提升你的工作效率唷～",{"title":259,"searchDepth":260,"depth":260,"links":261},"",2,[262,263],{"id":14,"depth":260,"text":14},{"id":21,"depth":260,"text":22,"children":264},[265,267,268,269,270,271,272,273],{"id":39,"depth":266,"text":40},3,{"id":80,"depth":266,"text":81},{"id":106,"depth":266,"text":107},{"id":129,"depth":266,"text":130},{"id":152,"depth":266,"text":153},{"id":175,"depth":266,"text":176},{"id":198,"depth":266,"text":199},{"id":225,"depth":266,"text":226},"雜談","2025-01-14 10:00:04","Raycast 也用一段時間了，但有沒有套件可以讓它更強？這一篇分享我自己長期掛在 Raycast 上的擴充套件：TinyPNG 圖片壓縮、 Kill Process、Visual Studio Code 專案開啟、Google Translate、Format JSON、Base64、 JWT 解碼通通一次到位。","md","zh-Hant",{},true,"\u002Fraycast-raycast","3",{"title":6,"description":276},false,"雜談\u002F關於我推的-Raycast-擴充套件，強化你的-Raycast！",[287,288,289,290],"Raycast","Spotlight","Mac","生產力工具",null,"\u002Fother\u002F20250114\u002F4149194649\u002F","uBtk8S-yxI4CKEP8dseTSkg-pOr7YuGRQzaAXK4El3Y",{"newer":295,"older":299},{"url":296,"title":297,"date":298},"\u002Falgorithm\u002F20250204\u002F3664816602\u002F","FizzBuzz for JavaScript","2025-02-04 21:18:55",{"url":300,"title":301,"date":302},"\u002Fjavascript\u002F20250106\u002F2580294921\u002F","關於 JavaScript 中 5 種物件取值方式","2025-01-06 21:17:12",[304,309,314],{"url":305,"title":306,"date":307,"readingMinutes":308},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":310,"title":311,"date":312,"readingMinutes":313},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":315,"title":316,"date":317,"readingMinutes":318},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784020396676]