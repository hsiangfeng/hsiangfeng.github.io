,{"class":87},[48,530,385],{"class":384},[48,532,413],{"class":87},[48,534,385],{"class":384},[48,536,418],{"class":87},[48,538,385],{"class":384},[48,540,423],{"class":87},[48,542,385],{"class":384},[48,544,388],{"class":87},[48,546,341],{"class":62},[48,548,352],{"class":173},[48,550,341],{"class":62},[48,552,398],{"class":87},[48,554,385],{"class":384},[48,556,388],{"class":87},[48,558,237],{"class":58},[48,560,561],{"class":50,"line":69},[48,562,208],{"emptyLinePlaceholder":207},[48,564,565,568,570,572,574,576],{"class":50,"line":81},[48,566,567],{"class":62},"return",[48,569,455],{"class":58},[48,571,458],{"class":87},[48,573,461],{"class":58},[48,575,464],{"class":87},[48,577,578],{"class":58},": GMTString };\n",[16,580,581],{},"而這兩段就是關鍵處，首先將打開 Postman，然後填入要測試的 API Url，這邊以參考範例的為主：",[38,583,587],{"className":584,"code":585,"language":586,"meta":43,"style":43},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","https:\u002F\u002Fptx.transportdata.tw\u002FMOTC\u002Fv2\u002FRail\u002FTRA\u002FStation?$top=10&$format=JSON\n","txt",[45,588,589],{"__ignoreMap":43},[48,590,591],{"class":50,"line":51},[48,592,585],{},[16,594,595],{},[596,597],"img",{"alt":598,"src":599},"API Url","https:\u002F\u002Fi.imgur.com\u002FY2I9QSJ.png",[601,602,604],"h3",{"id":603},"headers","Headers",[16,606,607],{},"接下來切換到 Headers 頁籤，然後新增兩個屬性分別是：",[609,610,611,617],"ul",{},[612,613,614],"li",{},[45,615,616],{},"Authorization",[612,618,619],{},[45,620,621],{},"X-Date",[16,623,624],{},[596,625],{"alt":604,"src":626},"https:\u002F\u002Fi.imgur.com\u002FmoU3vmH.png",[16,628,629],{},"然後依照個別填入以下內容",[631,632,616],"h4",{"id":633},"authorization",[38,635,637],{"className":584,"code":636,"language":586,"meta":43,"style":43},"hmac username=\"{{AppID}}\", algorithm=\"hmac-sha1\", headers=\"x-date\", signature=\"{{hmac}}\"\n",[45,638,639],{"__ignoreMap":43},[48,640,641],{"class":50,"line":51},[48,642,636],{},[631,644,621],{"id":418},[38,646,648],{"className":584,"code":647,"language":586,"meta":43,"style":43},"{{GMTString}}\n",[45,649,650],{"__ignoreMap":43},[48,651,652],{"class":50,"line":51},[48,653,647],{},[16,655,656],{},"以上都填寫完畢後就要來做一個很特別的設定，也就是我們要寫 script。",[601,658,660],{"id":659},"pre-request-script","Pre-request Script",[16,662,663],{},"那麼由於範例程式碼使用的是 jsSHA 套件，而 Postman 本身是沒有這個套件，所以這邊就必須自己撰寫一些程式碼來引入 jsSHA 套件，而 Postman 是允許你可以寫一些自己的程式碼，所以這邊我們會使用 jsSHA 的 CDN：",[38,665,667],{"className":584,"code":666,"language":586,"meta":43,"style":43},"https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002FjsSHA\u002F3.2.0\u002Fsha.js\n",[45,668,669],{"__ignoreMap":43},[48,670,671],{"class":50,"line":51},[48,672,666],{},[16,674,675,676,679,680,683],{},"接下來 Postman 中有一個方法是可以在發送出請求前先執行裡面的程式碼，執行完畢後才真的送出 AJAX，也就是 ",[45,677,678],{},"pm.sendRequest","，引入之後要在 ",[45,681,682],{},"res"," 中使用立即函式執行取回來的 CDN 檔案，這樣才可以正常使用，所以依據範例程式碼調整後結果就會變成以下：",[38,685,687],{"className":40,"code":686,"language":42,"meta":43,"style":43},"pm.sendRequest('https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002FjsSHA\u002F3.2.0\u002Fsha.js', (err, res) => {\n    (new Function(res.text()))();\n\n    var AppID = 'FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF';\n    var AppKey = 'FFFFFFFF-FFFF-FFFF-FFFF-FFFFFFFFFFFF';\n\n    var GMTString = new Date().toGMTString();\n    var ShaObj = new jsSHA('SHA-1', 'TEXT');\n    ShaObj.setHMACKey(AppKey, 'TEXT');\n    ShaObj.update('x-date: ' + GMTString);\n    var HMAC = ShaObj.getHMAC('B64');\n\n    \u002F\u002F 設定 Postman 全域變數\n    pm.globals.set(\"AppID\", AppID);\n    pm.globals.set(\"HMAC\", HMAC);\n    pm.globals.set(\"GMTString\", GMTString);\n});\n",[45,688,689,721,740,744,756,768,772,790,812,824,838,856,860,865,881,899,913],{"__ignoreMap":43},[48,690,691,694,697,699,702,705,708,710,712,715,718],{"class":50,"line":51},[48,692,693],{"class":58},"pm.",[48,695,696],{"class":54},"sendRequest",[48,698,59],{"class":58},[48,700,701],{"class":87},"'https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002FjsSHA\u002F3.2.0\u00