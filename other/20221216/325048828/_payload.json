[{"data":1,"prerenderedAt":445},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20221216\u002F325048828\u002F":3,"page:\u002Fother\u002F20221216\u002F325048828\u002F":4,"alt:\u002Fother\u002F20221216\u002F325048828\u002F":3,"prev-next:\u002Fother\u002F20221216\u002F325048828\u002F":420,"related:\u002Fother\u002F20221216\u002F325048828\u002F":429},"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fhomebrew-brew-command-not-found-zsh-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":401,"date":402,"description":403,"extension":404,"lang":405,"meta":406,"navigation":407,"path":408,"readingMinutes":409,"seo":410,"standalone":411,"stem":412,"tags":413,"tldr":417,"updated":402,"url":418,"__hash__":419},"content\u002F雜談\u002FHomebrew-zsh-command-not-found-brew-解決方式.md","Homebrew zsh: command not found: brew 解決方式","325048828",{"type":9,"value":10,"toc":395},"minimark",[11,15,19,22,30,61,68,86,93,99,102,105,132,135,161,164,170,175,263,266,288,299,336,352,355,374,377,380,391],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"某一天要安裝某個軟體時，卻出現「zsh: command not found: brew install」的錯誤，所以這一篇記錄一下問題。",[12,20,21],{"id":21},"問題紀錄",[16,23,24,25,29],{},"某一天當我輸入 ",[26,27,28],"code",{},"brew install flyctl"," 時，卻出現以下錯誤：",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-bash shiki shiki-themes github-dark-high-contrast","zsh: command not found: brew install flyctl\n","bash","",[26,38,39],{"__ignoreMap":36},[40,41,44,48,52,55,58],"span",{"class":42,"line":43},"line",1,[40,45,47],{"class":46},"s_sBn","zsh:",[40,49,51],{"class":50},"sTRMh"," command",[40,53,54],{"class":50}," not",[40,56,57],{"class":50}," found:",[40,59,60],{"class":50}," brew install flyctl\n",[16,62,63,64,67],{},"接著我在嘗試輸入 ",[26,65,66],{},"brew list"," 卻又出現以下錯誤：",[31,69,71],{"className":33,"code":70,"language":35,"meta":36,"style":36},"zsh: command not found: brew list\n",[26,72,73],{"__ignoreMap":36},[40,74,75,77,79,81,83],{"class":42,"line":43},[40,76,47],{"class":46},[40,78,51],{"class":50},[40,80,54],{"class":50},[40,82,57],{"class":50},[40,84,85],{"class":50}," brew list\n",[16,87,88,89,92],{},"但是這段時間我也沒做過什麼事情，所以我在嘗試輸入 ",[26,90,91],{},"brew"," 之後，卻可以出現列表，所以這狀況真的滿詭異的",[16,94,95],{},[96,97],"img",{"alt":91,"src":98},"https:\u002F\u002Fi.imgur.com\u002FfRcqilN.png",[12,100,101],{"id":101},"解決方式",[16,103,104],{},"一開始我有懷疑是不是環境變數跑掉，也就是這一段",[31,106,108],{"className":33,"code":107,"language":35,"meta":36,"style":36},"export PATH=\"\u002Fusr\u002Flocal\u002Fbin:$PATH\"\n",[26,109,110],{"__ignoreMap":36},[40,111,112,116,120,123,126,129],{"class":42,"line":43},[40,113,115],{"class":114},"sWyjQ","export",[40,117,119],{"class":118},"sMAXC"," PATH",[40,121,122],{"class":114},"=",[40,124,125],{"class":50},"\"\u002Fusr\u002Flocal\u002Fbin:",[40,127,128],{"class":118},"$PATH",[40,130,131],{"class":50},"\"\n",[16,133,134],{},"首先我第一直覺是先重新安裝 Homebrew，所以我輸入以下指令：",[31,136,138],{"className":33,"code":137,"language":35,"meta":36,"style":36},"\u002Fbin\u002Fbash -c \"$(curl -fsSL https:\u002F\u002Fraw.githubusercontent.com\u002FHomebrew\u002Finstall\u002FHEAD\u002Finstall.sh)\"\n",[26,139,140],{"__ignoreMap":36},[40,141,142,145,149,152,155,158],{"class":42,"line":43},[40,143,144],{"class":46},"\u002Fbin\u002Fbash",[40,146,148],{"class":147},"sCcAr"," -c",[40,150,151],{"class":50}," \"$(",[40,153,154],{"class":46},"curl",[40,156,157],{"class":147}," -fsSL",[40,159,160],{"class":50}," https:\u002F\u002Fraw.githubusercontent.com\u002FHomebrew\u002Finstall\u002FHEAD\u002Finstall.sh)\"\n",[16,162,163],{},"(不得不說，這個 Homebrew 的安裝過程有夠慢的。)",[16,165,166,167,169],{},"安裝好之後，又嘗試出入 ",[26,168,28],{},"，結果還是一樣，所以我稍微認真看一下提示訊息發現這一段，",[16,171,172],{},[96,173],{"alt":91,"src":174},"https:\u002F\u002Fi.imgur.com\u002FA9ozPdN.png",[31,176,178],{"className":33,"code":177,"language":35,"meta":36,"style":36},"- Run these three commands in your terminal to add Homebrew to your PATH:\n    echo '# Set PATH, MANPATH, etc., for Homebrew.' >> \u002FUsers\u002Frayxu\u002F.zprofile\n    echo 'eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"' >> \u002FUsers\u002Frayxu\u002F.zprofile\n    eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"\n",[26,179,180,222,237,249],{"__ignoreMap":36},[40,181,182,185,188,191,194,197,200,203,206,209,212,215,217,219],{"class":42,"line":43},[40,183,184],{"class":46},"-",[40,186,187],{"class":50}," Run",[40,189,190],{"class":50}," these",[40,192,193],{"class":50}," three",[40,195,196],{"class":50}," commands",[40,198,199],{"class":50}," in",[40,201,202],{"class":50}," your",[40,204,205],{"class":50}," terminal",[40,207,208],{"class":50}," to",[40,210,211],{"class":50}," add",[40,213,214],{"class":50}," Homebrew",[40,216,208],{"class":50},[40,218,202],{"class":50},[40,220,221],{"class":50}," PATH:\n",[40,223,225,228,231,234],{"class":42,"line":224},2,[40,226,227],{"class":147},"    echo",[40,229,230],{"class":50}," '# Set PATH, MANPATH, etc., for Homebrew.'",[40,232,233],{"class":114}," >>",[40,235,236],{"class":50}," \u002FUsers\u002Frayxu\u002F.zprofile\n",[40,238,240,242,245,247],{"class":42,"line":239},3,[40,241,227],{"class":147},[40,243,244],{"class":50}," 'eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"'",[40,246,233],{"class":114},[40,248,236],{"class":50},[40,250,252,255,257,260],{"class":42,"line":251},4,[40,253,254],{"class":147},"    eval",[40,256,151],{"class":50},[40,258,259],{"class":46},"\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew",[40,261,262],{"class":50}," shellenv)\"\n",[16,264,265],{},"這三段其實在測試 Homebrew 的環境變數，其實也就是以下",[31,267,269],{"className":33,"code":268,"language":35,"meta":36,"style":36},"# Set PATH, MANPATH, etc., for Homebrew.\neval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"\n",[26,270,271,277],{"__ignoreMap":36},[40,272,273],{"class":42,"line":43},[40,274,276],{"class":275},"sQrFR","# Set PATH, MANPATH, etc., for Homebrew.\n",[40,278,279,282,284,286],{"class":42,"line":224},[40,280,281],{"class":147},"eval",[40,283,151],{"class":50},[40,285,259],{"class":46},[40,287,262],{"class":50},[16,289,290,291,294,295,298],{},"而它預設是指向到 ",[26,292,293],{},".zprofile","，但我是使用 zsh，所以我就改成 ",[26,296,297],{},".zshrc","，所以我就輸入以下指令：",[31,300,302],{"className":33,"code":301,"language":35,"meta":36,"style":36},"echo '# Set PATH, MANPATH, etc., for Homebrew.' >> \u002FUsers\u002Frayxu\u002F.zshrc\necho 'eval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"' >> \u002FUsers\u002Frayxu\u002F.zshrc\neval \"$(\u002Fopt\u002Fhomebrew\u002Fbin\u002Fbrew shellenv)\"\n",[26,303,304,316,326],{"__ignoreMap":36},[40,305,306,309,311,313],{"class":42,"line":43},[40,307,308],{"class":147},"echo",[40,310,230],{"class":50},[40,312,233],{"class":114},[40,314,315],{"class":50}," \u002FUsers\u002Frayxu\u002F.zshrc\n",[40,317,318,320,322,324],{"class":42,"line":224},[40,319,308],{"class":147},[40,321,244],{"class":50},[40,323,233],{"class":114},[40,325,315],{"class":50},[40,327,328,330,332,334],{"class":42,"line":239},[40,329,281],{"class":147},[40,331,151],{"class":50},[40,333,259],{"class":46},[40,335,262],{"class":50},[16,337,338,339,341,342,345,346,348,349,351],{},"接著重開終端機再輸入一次 ",[26,340,28],{},"，結果還是一樣，所以我在繞了一下官方文件看到 ",[26,343,344],{},"brew install wget","，所以嘗試安裝一下，結果 ",[26,347,344],{}," 是可以運作的，接著跑完這個指令後，我再去輸入 ",[26,350,28],{},"，結果就可以正常安裝了。",[16,353,354],{},"那麼這個原因是為什麼呢？主要原因是出在安裝套件時，會需要一些基本套件，如：",[356,357,358,362,365,368,371],"ul",{},[359,360,361],"li",{},"gettext",[359,363,364],{},"libunistring",[359,366,367],{},"libidn2",[359,369,370],{},"ca-certificates",[359,372,373],{},"openssl@1.1",[16,375,376],{},"但不知道為什麼我的 wget 消失了，所以才會導致安裝套件時出現錯誤，因為安裝套件的時候會需要用到 wget，所以才會無法正常安裝。",[12,378,379],{"id":379},"參考文獻",[356,381,382],{},[359,383,384],{},[385,386,390],"a",{"href":387,"rel":388},"https:\u002F\u002Fbrew.sh\u002Findex_zh-tw",[389],"nofollow","Homebrew",[392,393,394],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-def