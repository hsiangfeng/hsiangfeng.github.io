[{"data":1,"prerenderedAt":560},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20221216\u002F786812101\u002F":3,"page:\u002Fother\u002F20221216\u002F786812101\u002F":4,"alt:\u002Fother\u002F20221216\u002F786812101\u002F":3,"prev-next:\u002Fother\u002F20221216\u002F786812101\u002F":535,"related:\u002Fother\u002F20221216\u002F786812101\u002F":544},"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":517,"date":518,"description":18,"extension":519,"lang":520,"meta":521,"navigation":257,"path":522,"readingMinutes":523,"seo":524,"standalone":525,"stem":526,"tags":527,"tldr":531,"updated":532,"url":533,"__hash__":534},"content\u002F雜談\u002F將你的-Node-js-部署到-fly-io-吧！.md","將你的 Node.js 部署到 fly.io 吧！","786812101",{"type":9,"value":10,"toc":503},"minimark",[11,15,19,23,29,38,41,49,57,61,69,72,90,93,99,102,107,115,118,143,147,168,172,188,191,194,210,213,216,219,233,236,292,295,298,301,313,316,361,367,374,381,387,390,456,459,468,473,480,485,488,491,499],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇算是記錄一下將 Express 部署到 fly.io 的心得記錄，畢竟自從 Heroku 不再免費之後，就只好多玩一下其他平台，而這一篇 fly.io 就是其中一個。",[12,20,22],{"id":21},"flyio","Fly.io",[16,24,25],{},[26,27],"img",{"alt":22,"src":28},"https:\u002F\u002Fi.imgur.com\u002FoxshkHr.png",[16,30,31,32,37],{},"Fly.io 是什麼呢？簡單來講與我先前分享的「",[33,34,36],"a",{"href":35},"\u002Fother\u002F20221213\u002F3036227586\u002F","關於從 Heroku 跳到 Render 這件事情","」文章所提 Render 非常相似，都是可以讓你快速部署你的後端應用程式的平台，那麼為什麼還要額外特別介紹呢？主要原因是它的操作方式與 Render 是不太一樣的，所以才會額外記錄這一篇。",[16,39,40],{},"那麼就準備開始吧。",[16,42,43,44],{},"本篇範例程式碼放在這邊：",[33,45,46],{"href":46,"rel":47},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002F2022-express-example",[48],"nofollow",[50,51,54],"callout",{"title":52,"type":53},"Danger","danger",[16,55,56],{},"fly.io 經過網友回報，目前需要新增信用卡才可以使用唷~",[12,58,60],{"id":59},"安裝-flyctl","安裝 Flyctl",[16,62,63,64,68],{},"開始之前，請記得先去 ",[33,65,22],{"href":66,"rel":67},"https:\u002F\u002Ffly.io\u002F",[48]," 註冊一個帳號，並登入唷。",[16,70,71],{},"Flyctl 是由 Fly.io 所出的 CLI 工具，可以讓你快速的部署你的應用程式，而它的安裝方式也非常簡單，只要在你的終端機輸入以下指令即可：",[73,74,79],"pre",{"className":75,"code":76,"language":77,"meta":78,"style":78},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","brew install flyctl\n","bash","",[80,81,82],"code",{"__ignoreMap":78},[83,84,87],"span",{"class":85,"line":86},"line",1,[83,88,76],{"class":89},"smYoP",[16,91,92],{},"那麼這一段指令哪裡來呢？其實在你進入官方網站時，首頁就會自動依據你的作業系統給予相對應的安裝指令了",[16,94,95],{},[26,96],{"alt":97,"src":98},"安裝指令","https:\u002F\u002Fi.imgur.com\u002FG9w7UcZ.png",[16,100,101],{},"當然我這邊也一樣提供兩個作業系統的 Flyctl 安裝指令：",[103,104,106],"h3",{"id":105},"macos","macOS",[73,108,109],{"className":75,"code":76,"language":77,"meta":78,"style":78},[80,110,111],{"__ignoreMap":78},[83,112,113],{"class":85,"line":86},[83,114,76],{"class":89},[16,116,117],{},"若沒有 Homebrew 的話，則可以改用 Curl",[73,119,121],{"className":75,"code":120,"language":77,"meta":78,"style":78},"curl -L https:\u002F\u002Ffly.io\u002Finstall.sh | sh\n",[80,122,123],{"__ignoreMap":78},[83,124,125,128,132,136,140],{"class":85,"line":86},[83,126,127],{"class":89},"curl",[83,129,131],{"class":130},"stw71"," -L",[83,133,135],{"class":134},"sWayO"," https:\u002F\u002Ffly.io\u002Finstall.sh",[83,137,139],{"class":138},"sOudu"," |",[83,141,142],{"class":89}," sh\n",[103,144,146],{"id":145},"windows","Windows",[73,148,150],{"className":75,"code":149,"language":77,"meta":78,"style":78},"iwr https:\u002F\u002Ffly.io\u002Finstall.ps1 -useb | iex\n",[80,151,152],{"__ignoreMap":78},[83,153,154,157,160,163,165],{"class":85,"line":86},[83,155,156],{"class":89},"iwr",[83,158,159],{"class":134}," https:\u002F\u002Ffly.io\u002Finstall.ps1",[83,161,162],{"class":130}," -useb",[83,164,139],{"class":138},[83,166,167],{"class":89}," iex\n",[103,169,171],{"id":170},"linux","Linux",[73,173,174],{"className":75,"code":120,"language":77,"meta":78,"style":78},[80,175,176],{"__ignoreMap":78},[83,177,178,180,182,184,186],{"class":85,"line":86},[83,179,127],{"class":89},[83,181,131],{"class":130},[83,183,135],{"class":134},[83,185,139],{"class":138},[83,187,142],{"class":89},[12,189,190],{"id":190},"註冊帳號",[16,192,193],{},"雖然前面有提醒過，但相信還是有人會忘記，所以這邊也額外說明一下 Fly.io 本身提供兩種註冊帳號方式，一種就是透過官方網站，另一種則是在終端機上輸入以下指令",[73,195,197],{"className":75,"code":196,"language":77,"meta":78,"style":78},"flyctl auth signup\n",[80,198,199],{"__ignoreMap":78},[83,200,201,204,207],{"class":85,"line":86},[83,202,203],{"class":89},"flyctl",[83,205,206],{"class":134}," auth",[83,208,209],{"class":134}," signup\n",[16,211,212],{},"輸入完之後，就會開啟一個瀏覽器，然後你就可以依據流程註冊帳號了。",[12,214,215],{"id":215},"登入帳號",[16,217,218],{},"登入帳號的方式也是非常簡單，只要在終端機輸入以下指令即可：",[73,220,222],{"className":75,"code":221,"language":77,"meta":78,"style":78},"flyctl auth login\n",[80,223,224],{"__ignoreMap":78},[83,225,226,228,230],{"class":85,"line":86},[83,227,203],{"class":89},[83,229,206],{"class":134},[83,231,232],{"class":134}," login\n",[16,234,235],{},"輸入後一樣會開啟一個瀏覽器，然後你就可以選擇帳號登入，登入成功後終端機會出現以下訊息",[73,237,239],{"className":75,"code":238,"language":77,"meta":78,"style":78},"Opening https:\u002F\u002Ffly.io\u002Fapp\u002Fauth\u002Fcli\u002F ...\n\nWaiting for session... Done\nsuccessfully logged in as example@gmail.com\n",[80,240,241,252,259,274],{"__ignoreMap":78},[83,242,243,246,249],{"class":85,"line":86},[83,244,245],{"class":89},"Opening",[83,247,248],{"class":134}," https:\u002F\u002Ffly.io\u002Fapp\u002Fauth\u002Fcli\u002F",[83,250,251],{"class":134}," ...\n",[83,253,255],{"class":85,"line":254},2,[83,256,258],{"emptyLinePlaceholder":257},true,"\n",[83,260,262,265,268,271],{"class":85,"line":261},3,[83,263,264],{"class":89},"Waiting",[83,266,267],{"class":134}," for",[83,269,270],{"class":134}," session...",[83,272,273],{"class":134}," Done\n",[83,275,277,280,283,286,289],{"class":85,"line":276},4,[83,278,279],{"class":89},"successfully",[83,281,282],{"class":134}," logged",[83,284,285],{"class":134}," in",[83,287,288],{"class":134}," as",[83,290,291],{"class":134}," example@gmail.com\n",[16,293,294],{},"這樣就代表你已經成功登入了。",[12,296,297],{"id":297},"部署專案",[16,299,300],{},"接下來該怎麼部署專案呢？請在你的專案底下輸入以下指令",[73,302,304],{"className":75,"code":303,"language":77,"meta":78,"style":78},"flyctl launch\n",[80,305,306],{"__ignoreMap":78},[83,307,308,310],{"class":85,"line":86},[83,309,203],{"class":89},[83,311,312],{"class":134}," launch\n",[16,314,315],{},"輸入後，你會發現 flyctl 非常聰明的幫你辨別出你使用的語言，接著終端機會有幾個選項要求你選擇",[317,318,319,328,339,351],"ul",{},[320,321,322,323],"li",{},"Choose an app name (leave blank to generate one)\n",[317,324,325],{},[320,326,327],{},"這邊可以自己輸入一個名稱，或是直接按 Enter 來讓 Flyctl 自動產生一個名稱",[320,329,330,331],{},"Choose a region for deployment\n",[317,332,333],{},[320,334,335,336],{},"選擇你要將機器部署的地方，這邊我選擇的是 ",[80,337,338],{},"sin",[320,340,341,342],{},"Would you like to set up a Postgresql database now?\n",[317,343,344],{},[320,345,346,347,350],{},"這邊我選擇 ",[80,348,349],{},"n","，因為我不需要資料庫",[320,352,353,354],{},"Would you like to set up an Upstash Redis database now?\n",[317,355,356],{},[320,357,358,359],{},"一樣是 ",[80,360,349],{},[16,362,363],{},[26,364],{"alt":365,"src":366},"launch","https:\u002F\u002Fi.imgur.com\u002FyKpN1vO.png",[16,368,369,370,373],{},"接著你會看到你的專案底下生成了一個 ",[80,371,372],{},"fly.toml"," 的檔案，這個檔案就是 Flyctl 的設定檔，裡面會有你的專案名稱、部署地點、以及你的專案資料夾等等資訊，如果你有興趣的話，可以再深入了解。",[16,375,376,377,380],{},"接著輸入 ",[80,378,379],{},"flyctl deploy"," 你的專案就會部署到 Fly.io 上了。",[16,382,383],{},[26,384],{"alt":385,"src":386},"deploy","https:\u002F\u002Fi.imgur.com\u002F2byO36L.png",[16,388,389],{},"接著你只要看到以下訊息，就代表部署完畢了",[73,391,393],{"className":75,"code":392,"language":77,"meta":78,"style":78},"...\n...\n...\n\n 1 desired, 1 placed, 1 healthy, 0 unhealthy\n--> v0 deployed successfully\n",[80,394,395,400,404,408,412,437],{"__ignoreMap":78},[83,396,397],{"class":85,"line":86},[83,398,399],{"class":130},"...\n",[83,401,402],{"class":85,"line":254},[83,403,399],{"class":130},[83,405,406],{"class":85,"line":261},[83,407,399],{"class":130},[83,409,410],{"class":85,"line":276},[83,411,258],{"emptyLinePlaceholder":257},[83,413,415,418,421,423,426,428,431,434],{"class":85,"line":414},5,[83,416,417],{"class":89}," 1",[83,419,420],{"class":134}," desired,",[83,422,417],{"class":130},[83,424,425],{"class":134}," placed,",[83,427,417],{"class":130},[83,429,430],{"class":134}," healthy,",[83,432,433],{"class":130}," 0",[83,435,436],{"class":134}," unhealthy\n",[83,438,440,443,447,450,453],{"class":85,"line":439},6,[83,441,442],{"class":89},"--",[83,444,446],{"class":445},"s8XSl","> ",[83,448,449],{"class":134},"v0",[83,451,452],{"class":134}," deployed",[83,454,455],{"class":134}," successfully\n",[12,457,458],{"id":458},"查看部署狀態",[16,460,461,462,467],{},"那麼我們該怎麼看部署狀況呢？有兩種方式，第一種進入到 Fly.io 的網站從 ",[33,463,466],{"href":464,"rel":465},"https:\u002F\u002Ffly.io\u002Fdashboard\u002Fpersonal",[48],"Dashboard"," 上查看",[16,469,470],{},[26,471],{"alt":466,"src":472},"https:\u002F\u002Fi.imgur.com\u002FPmvM563.png",[16,474,475,476,479],{},"第二種方式則是透過指令，只需要在終端機輸入 ",[80,477,478],{},"flyctl status","，你就可以看到你的專案部署狀態，而圖片中紅色箭頭所指的地方，就是你的專案網址",[16,481,482],{},[26,483],{"alt":478,"src":484},"https:\u002F\u002Fi.imgur.com\u002FVeVnRuw.png",[16,486,487],{},"基本上到目前為止你的 Node.js 專案就部署上去了。",[12,489,490],{"id":490},"參考文獻",[317,492,493],{},[320,494,495],{},[33,496,22],{"href":497,"rel":498},"https:\u002F\u002Ffly.io\u002Fdocs\u002Flanguages-and-frameworks\u002Fnode\u002F",[48],[500,501,502],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-li