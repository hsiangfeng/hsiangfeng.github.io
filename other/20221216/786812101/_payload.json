[{"data":1,"prerenderedAt":562},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20221216\u002F786812101\u002F":3,"page:\u002Fother\u002F20221216\u002F786812101\u002F":4,"alt:\u002Fother\u002F20221216\u002F786812101\u002F":3,"prev-next:\u002Fother\u002F20221216\u002F786812101\u002F":537,"related:\u002Fother\u002F20221216\u002F786812101\u002F":546},"\u002Fen\u002Fmisc\u002F2022\u002F12\u002F16\u002Fdeploy-nodejs-to-fly-io-with-flyctl\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":519,"date":520,"description":18,"extension":521,"lang":522,"meta":523,"navigation":259,"path":524,"readingMinutes":525,"seo":526,"standalone":527,"stem":528,"tags":529,"tldr":533,"updated":534,"url":535,"__hash__":536},"content\u002F雜談\u002F將你的-Node-js-部署到-fly-io-吧！.md","將你的 Node.js 部署到 fly.io 吧！","786812101",{"type":9,"value":10,"toc":505},"minimark",[11,15,19,23,29,38,41,49,59,63,71,74,92,95,101,104,109,117,120,145,149,170,174,190,193,196,212,215,218,221,235,238,294,297,300,303,315,318,363,369,376,383,389,392,458,461,470,475,482,487,490,493,501],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇算是記錄一下將 Express 部署到 fly.io 的心得記錄，畢竟自從 Heroku 不再免費之後，就只好多玩一下其他平台，而這一篇 fly.io 就是其中一個。",[12,20,22],{"id":21},"flyio","Fly.io",[16,24,25],{},[26,27],"img",{"alt":22,"src":28},"https:\u002F\u002Fi.imgur.com\u002FoxshkHr.png",[16,30,31,32,37],{},"Fly.io 是什麼呢？簡單來講與我先前分享的「",[33,34,36],"a",{"href":35},"\u002Fother\u002F20221213\u002F3036227586\u002F","關於從 Heroku 跳到 Render 這件事情","」文章所提 Render 非常相似，都是可以讓你快速部署你的後端應用程式的平台，那麼為什麼還要額外特別介紹呢？主要原因是它的操作方式與 Render 是不太一樣的，所以才會額外記錄這一篇。",[16,39,40],{},"那麼就準備開始吧。",[16,42,43,44],{},"本篇範例程式碼放在這邊：",[33,45,46],{"href":46,"rel":47},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002F2022-express-example",[48],"nofollow",[50,51,52],"blockquote",{},[16,53,54,58],{},[55,56,57],"strong",{},"Danger","\nfly.io 經過網友回報，目前需要新增信用卡才可以使用唷~",[12,60,62],{"id":61},"安裝-flyctl","安裝 Flyctl",[16,64,65,66,70],{},"開始之前，請記得先去 ",[33,67,22],{"href":68,"rel":69},"https:\u002F\u002Ffly.io\u002F",[48]," 註冊一個帳號，並登入唷。",[16,72,73],{},"Flyctl 是由 Fly.io 所出的 CLI 工具，可以讓你快速的部署你的應用程式，而它的安裝方式也非常簡單，只要在你的終端機輸入以下指令即可：",[75,76,81],"pre",{"className":77,"code":78,"language":79,"meta":80,"style":80},"language-bash shiki shiki-themes github-dark-high-contrast","brew install flyctl\n","bash","",[82,83,84],"code",{"__ignoreMap":80},[85,86,89],"span",{"class":87,"line":88},"line",1,[85,90,78],{"class":91},"s_sBn",[16,93,94],{},"那麼這一段指令哪裡來呢？其實在你進入官方網站時，首頁就會自動依據你的作業系統給予相對應的安裝指令了",[16,96,97],{},[26,98],{"alt":99,"src":100},"安裝指令","https:\u002F\u002Fi.imgur.com\u002FG9w7UcZ.png",[16,102,103],{},"當然我這邊也一樣提供兩個作業系統的 Flyctl 安裝指令：",[105,106,108],"h3",{"id":107},"macos","macOS",[75,110,111],{"className":77,"code":78,"language":79,"meta":80,"style":80},[82,112,113],{"__ignoreMap":80},[85,114,115],{"class":87,"line":88},[85,116,78],{"class":91},[16,118,119],{},"若沒有 Homebrew 的話，則可以改用 Curl",[75,121,123],{"className":77,"code":122,"language":79,"meta":80,"style":80},"curl -L https:\u002F\u002Ffly.io\u002Finstall.sh | sh\n",[82,124,125],{"__ignoreMap":80},[85,126,127,130,134,138,142],{"class":87,"line":88},[85,128,129],{"class":91},"curl",[85,131,133],{"class":132},"sCcAr"," -L",[85,135,137],{"class":136},"sTRMh"," https:\u002F\u002Ffly.io\u002Finstall.sh",[85,139,141],{"class":140},"sWyjQ"," |",[85,143,144],{"class":91}," sh\n",[105,146,148],{"id":147},"windows","Windows",[75,150,152],{"className":77,"code":151,"language":79,"meta":80,"style":80},"iwr https:\u002F\u002Ffly.io\u002Finstall.ps1 -useb | iex\n",[82,153,154],{"__ignoreMap":80},[85,155,156,159,162,165,167],{"class":87,"line":88},[85,157,158],{"class":91},"iwr",[85,160,161],{"class":136}," https:\u002F\u002Ffly.io\u002Finstall.ps1",[85,163,164],{"class":132}," -useb",[85,166,141],{"class":140},[85,168,169],{"class":91}," iex\n",[105,171,173],{"id":172},"linux","Linux",[75,175,176],{"className":77,"code":122,"language":79,"meta":80,"style":80},[82,177,178],{"__ignoreMap":80},[85,179,180,182,184,186,188],{"class":87,"line":88},[85,181,129],{"class":91},[85,183,133],{"class":132},[85,185,137],{"class":136},[85,187,141],{"class":140},[85,189,144],{"class":91},[12,191,192],{"id":192},"註冊帳號",[16,194,195],{},"雖然前面有提醒過，但相信還是有人會忘記，所以這邊也額外說明一下 Fly.io 本身提供兩種註冊帳號方式，一種就是透過官方網站，另一種則是在終端機上輸入以下指令",[75,197,199],{"className":77,"code":198,"language":79,"meta":80,"style":80},"flyctl auth signup\n",[82,200,201],{"__ignoreMap":80},[85,202,203,206,209],{"class":87,"line":88},[85,204,205],{"class":91},"flyctl",[85,207,208],{"class":136}," auth",[85,210,211],{"class":136}," signup\n",[16,213,214],{},"輸入完之後，就會開啟一個瀏覽器，然後你就可以依據流程註冊帳號了。",[12,216,217],{"id":217},"登入帳號",[16,219,220],{},"登入帳號的方式也是非常簡單，只要在終端機輸入以下指令即可：",[75,222,224],{"className":77,"code":223,"language":79,"meta":80,"style":80},"flyctl auth login\n",[82,225,226],{"__ignoreMap":80},[85,227,228,230,232],{"class":87,"line":88},[85,229,205],{"class":91},[85,231,208],{"class":136},[85,233,234],{"class":136}," login\n",[16,236,237],{},"輸入後一樣會開啟一個瀏覽器，然後你就可以選擇帳號登入，登入成功後終端機會出現以下訊息",[75,239,241],{"className":77,"code":240,"language":79,"meta":80,"style":80},"Opening https:\u002F\u002Ffly.io\u002Fapp\u002Fauth\u002Fcli\u002F ...\n\nWaiting for session... Done\nsuccessfully logged in as example@gmail.com\n",[82,242,243,254,261,276],{"__ignoreMap":80},[85,244,245,248,251],{"class":87,"line":88},[85,246,247],{"class":91},"Opening",[85,249,250],{"class":136}," https:\u002F\u002Ffly.io\u002Fapp\u002Fauth\u002Fcli\u002F",[85,252,253],{"class":136}," ...\n",[85,255,257],{"class":87,"line":256},2,[85,258,260],{"emptyLinePlaceholder":259},true,"\n",[85,262,264,267,270,273],{"class":87,"line":263},3,[85,265,266],{"class":91},"Waiting",[85,268,269],{"class":136}," for",[85,271,272],{"class":136}," session...",[85,274,275],{"class":136}," Done\n",[85,277,279,282,285,288,291],{"class":87,"line":278},4,[85,280,281],{"class":91},"successfully",[85,283,284],{"class":136}," logged",[85,286,287],{"class":136}," in",[85,289,290],{"class":136}," as",[85,292,293],{"class":136}," example@gmail.com\n",[16,295,296],{},"這樣就代表你已經成功登入了。",[12,298,299],{"id":299},"部署專案",[16,301,302],{},"接下來該怎麼部署專案呢？請在你的專案底下輸入以下指令",[75,304,306],{"className":77,"code":305,"language":79,"meta":80,"style":80},"flyctl launch\n",[82,307,308],{"__ignoreMap":80},[85,309,310,312],{"class":87,"line":88},[85,311,205],{"class":91},[85,313,314],{"class":136}," launch\n",[16,316,317],{},"輸入後，你會發現 flyctl 非常聰明的幫你辨別出你使用的語言，接著終端機會有幾個選項要求你選擇",[319,320,321,330,341,353],"ul",{},[322,323,324,325],"li",{},"Choose an app name (leave blank to generate one)\n",[319,326,327],{},[322,328,329],{},"這邊可以自己輸入一個名稱，或是直接按 Enter 來讓 Flyctl 自動產生一個名稱",[322,331,332,333],{},"Choose a region for deployment\n",[319,334,335],{},[322,336,337,338],{},"選擇你要將機器部署的地方，這邊我選擇的是 ",[82,339,340],{},"sin",[322,342,343,344],{},"Would you like to set up a Postgresql database now?\n",[319,345,346],{},[322,347,348,349,352],{},"這邊我選擇 ",[82,350,351],{},"n","，因為我不需要資料庫",[322,354,355,356],{},"Would you like to set up an Upstash Redis database now?\n",[319,357,358],{},[322,359,360,361],{},"一樣是 ",[82,362,351],{},[16,364,365],{},[26,366],{"alt":367,"src":368},"launch","https:\u002F\u002Fi.imgur.com\u002FyKpN1vO.png",[16,370,371,372,375],{},"接著你會看到你的專案底下生成了一個 ",[82,373,374],{},"fly.toml"," 的檔案，這個檔案就是 Flyctl 的設定檔，裡面會有你的專案名稱、部署地點、以及你的專案資料夾等等資訊，如果你有興趣的話，可以再深入了解。",[16,377,378,379,382],{},"接著輸入 ",[82,380,381],{},"flyctl deploy"," 你的專案就會部署到 Fly.io 上了。",[16,384,385],{},[26,386],{"alt":387,"src":388},"deploy","https:\u002F\u002Fi.imgur.com\u002F2byO36L.png",[16,390,391],{},"接著你只要看到以下訊息，就代表部署完畢了",[75,393,395],{"className":77,"code":394,"language":79,"meta":80,"style":80},"...\n...\n...\n\n 1 desired, 1 placed, 1 healthy, 0 unhealthy\n--> v0 deployed successfully\n",[82,396,397,402,406,410,414,439],{"__ignoreMap":80},[85,398,399],{"class":87,"line":88},[85,400,401],{"class":132},"...\n",[85,403,404],{"class":87,"line":256},[85,405,401],{"class":132},[85,407,408],{"class":87,"line":263},[85,409,401],{"class":132},[85,411,412],{"class":87,"line":278},[85,413,260],{"emptyLinePlaceholder":259},[85,415,417,420,423,425,428,430,433,436],{"class":87,"line":416},5,[85,418,419],{"class":91}," 1",[85,421,422],{"class":136}," desired,",[85,424,419],{"class":132},[85,426,427],{"class":136}," placed,",[85,429,419],{"class":132},[85,431,432],{"class":136}," healthy,",[85,434,435],{"class":132}," 0",[85,437,438],{"class":136}," unhealthy\n",[85,440,442,445,449,452,455],{"class":87,"line":441},6,[85,443,444],{"class":91},"--",[85,446,448],{"class":447},"sMAXC","> ",[85,450,451],{"class":136},"v0",[85,453,454],{"class":136}," deployed",[85,456,457],{"class":136}," successfully\n",[12,459,460],{"id":460},"查看部署狀態",[16,462,463,464,469],{},"那麼我們該怎麼看部署狀況呢？有兩種方式，第一種進入到 Fly.io 的網站從 ",[33,465,468],{"href":466,"rel":467},"https:\u002F\u002Ffly.io\u002Fdashboard\u002Fpersonal",[48],"Dashboard"," 上查看",[16,471,472],{},[26,473],{"alt":468,"src":474},"https:\u002F\u002Fi.imgur.com\u002FPmvM563.png",[16,476,477,478,481],{},"第二種方式則是透過指令，只需要在終端機輸入 ",[82,479,480],{},"flyctl status","，你就可以看到你的專案部署狀態，而圖片中紅色箭頭所指的地方，就是你的專案網址",[16,483,484],{},[26,485],{"alt":480,"src":486},"https:\u002F\u002Fi.imgur.com\u002FVeVnRuw.png",[16,488,489],{},"基本上到目前為止你的 Node.js 專案就部署上去了。",[12,491,492],{"id":492},"參考文獻",[319,494,495],{},[322,496,497],{},[33,498,22],{"href":499,"rel":500},"https:\u002F\u002Ffly.io\u002Fdocs\u002Flanguages-and-frameworks\u002Fnode\u002F",[48],[502,503,504],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}",{"title":80,"searchDepth":256,"depth":256,"links":506},[507,508,509,514,515,516,517,518],{"id":14,"depth":256,"text":14},{"id":21,"depth":256,"text":22},{"id":61,"depth":256,"text":62,"children":510},[511,512,513],{"id":107,"depth":263,"text":108},{"id":147,"depth":263,"text":148},{"id":172,"depth":263,"text":173},{"id":192,"depth":256,"text":192},{"id":217,"depth":256,"text":217},{"id":299,"depth":256,"text":299},{"id":460,"depth":256,"text":460},{"id":492,"depth":256,"text":492},"雜談","2022-12-16 21:06:54","md","zh-Hant",{},"\u002Fnode-js-fly-io","2",{"title":6,"description":18},false,"雜談\u002F將你的-Node-js-部署到-fly-io-吧！",[530,531,532],"Node.js","Express","fly.io",null,"2023-02-13 15:30:00","\u002Fother\u002F20221216\u002F786812101\u002F","pAMWuOWosxTR0KdKOeH27eUgflPinDMwnye-s30AmP4",{"newer":538,"older":542},{"url":539,"title":540,"date":541},"\u002Fother\u002F20221216\u002F325048828\u002F","Homebrew zsh: command not found: brew 解決方式","2022-12-16 21:19:14",{"url":543,"title":544,"date":545},"\u002Fgsap\u002F20221216\u002F3838160668\u002F","(9)前端好好玩用 GSAP 做一個特效 - Eases","2022-12-16 21:04:00",[547,552,557],{"url":548,"title":549,"date":550,"readingMinutes":551},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":553,"title":554,"date":555,"readingMinutes":556},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":558,"title":559,"date":560,"readingMinutes":561},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784020396228]