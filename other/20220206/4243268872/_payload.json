[{"data":1,"prerenderedAt":160},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220206\u002F4243268872\u002F":3,"page:\u002Fother\u002F20220206\u002F4243268872\u002F":4,"alt:\u002Fother\u002F20220206\u002F4243268872\u002F":3,"prev-next:\u002Fother\u002F20220206\u002F4243268872\u002F":135,"related:\u002Fother\u002F20220206\u002F4243268872\u002F":144},"\u002Fen\u002Fmisc\u002F2022\u002F02\u002F06\u002Fhow-to-clear-terminal-screen\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":116,"date":117,"description":18,"extension":118,"lang":119,"meta":120,"navigation":121,"path":122,"readingMinutes":123,"seo":124,"standalone":125,"stem":126,"tags":127,"tldr":131,"updated":132,"url":133,"__hash__":134},"content\u002F雜談\u002F清除終端機-Terminal-上的內容.md","清除終端機(Terminal)上的內容","4243268872",{"type":9,"value":10,"toc":110},"minimark",[11,15,19,22,25,32,38,41,70,75,85,88,107],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"不論是在 Mac 或是 Windows 開發，我們一定很常使用終端機(Terminal)或是命令提示字元，而往往畫面就會非常多資訊看了很阿雜，所以紀錄一下有哪些方式可以清除終端機畫面。",[12,20,21],{"id":21},"清空終端機",[16,23,24],{},"首先我們終端機畫面上可能一大推資訊",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"Mac","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-06%2021.05.38.png",[16,33,34],{},[28,35],{"alt":36,"src":37},"Windows","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F2022-02-06_21-11-46.png",[16,39,40],{},"雖然不影響操作跟使用，但是看多了就是覺得煩，你可以試著輸入以下指令來清空畫面",[42,43,44,56],"ul",{},[45,46,47,48],"li",{},"Mac\n",[42,49,50],{},[45,51,52],{},[53,54,55],"code",{},"clear",[45,57,58,59],{},"Windows\n",[42,60,61,65],{},[45,62,63],{},[53,64,55],{},[45,66,67],{},[53,68,69],{},"cls",[16,71,72],{},[28,73],{"alt":30,"src":74},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F2022-02-06%2021.07.30.png",[76,77,78],"blockquote",{},[16,79,80,84],{},[81,82,83],"strong",{},"Note","\n透過輸入指令的方式並不會真的清除終端機的內容，只是將畫面往上移動，所以如果你往上滑的話，還是可以看到之前的內容。",[16,86,87],{},"但是這邊其實還有另一招方式可以快速清除終端機的內容，也就是按下組合鍵",[42,89,90,100],{},[45,91,47,92],{},[42,93,94,97],{},[45,95,96],{},"Command + K",[45,98,99],{},"Control + L",[45,101,58,102],{},[42,103,104],{},[45,105,106],{},"Ctrl + L (早期似乎是 Ctrl+ K)",[16,108,109],{},"以上是清除終端機內容的簡單方式。",{"title":111,"searchDepth":112,"depth":112,"links":113},"",2,[114,115],{"id":14,"depth":112,"text":14},{"id":21,"depth":112,"text":21},"雜談","2022-02-06 20:52:22","md","zh-Hant",{},true,"\u002Fterminal","1",{"title":6,"description":18},false,"雜談\u002F清除終端機-Terminal-上的內容",[128,129,130,36,30],"Terminal","終端機","命令提示字元",null,"2023-07-30 11:02:58","\u002Fother\u002F20220206\u002F4243268872\u002F","CCEDO_qkAZlB5xjp4lVWXf5NA3BVjpW8Q-whoy95t28",{"newer":136,"older":140},{"url":137,"title":138,"date":139},"\u002Fother\u002F20220207\u002F2089611734\u002F","Discord 2FA 怎麼開？二階段驗證設定步驟，保護帳號不被盜","2022-02-07 10:20:01",{"url":141,"title":142,"date":143},"\u002Fother\u002F20220202\u002F3414775100\u002F","Udemy 小技巧 - 英文字幕轉中文(同步翻譯)","2022-02-02 22:41:09",[145,150,155],{"url":146,"title":147,"date":148,"readingMinutes":149},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":151,"title":152,"date":153,"readingMinutes":154},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":156,"title":157,"date":158,"readingMinutes":159},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784011726850]