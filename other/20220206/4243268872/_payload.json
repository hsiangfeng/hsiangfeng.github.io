[{"data":1,"prerenderedAt":158},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220206\u002F4243268872\u002F":3,"page:\u002Fother\u002F20220206\u002F4243268872\u002F":4,"alt:\u002Fother\u002F20220206\u002F4243268872\u002F":3,"prev-next:\u002Fother\u002F20220206\u002F4243268872\u002F":133,"related:\u002Fother\u002F20220206\u002F4243268872\u002F":142},"\u002Fen\u002Fmisc\u002F2022\u002F02\u002F06\u002Fhow-to-clear-terminal-screen\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":114,"date":115,"description":18,"extension":116,"lang":117,"meta":118,"navigation":119,"path":120,"readingMinutes":121,"seo":122,"standalone":123,"stem":124,"tags":125,"tldr":129,"updated":130,"url":131,"__hash__":132},"content\u002F雜談\u002F清除終端機-Terminal-上的內容.md","清除終端機(Terminal)上的內容","4243268872",{"type":9,"value":10,"toc":108},"minimark",[11,15,19,22,25,32,38,41,70,75,83,86,105],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"不論是在 Mac 或是 Windows 開發，我們一定很常使用終端機(Terminal)或是命令提示字元，而往往畫面就會非常多資訊看了很阿雜，所以紀錄一下有哪些方式可以清除終端機畫面。",[12,20,21],{"id":21},"清空終端機",[16,23,24],{},"首先我們終端機畫面上可能一大推資訊",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"Mac","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-06%2021.05.38.png",[16,33,34],{},[28,35],{"alt":36,"src":37},"Windows","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F2022-02-06_21-11-46.png",[16,39,40],{},"雖然不影響操作跟使用，但是看多了就是覺得煩，你可以試著輸入以下指令來清空畫面",[42,43,44,56],"ul",{},[45,46,47,48],"li",{},"Mac\n",[42,49,50],{},[45,51,52],{},[53,54,55],"code",{},"clear",[45,57,58,59],{},"Windows\n",[42,60,61,65],{},[45,62,63],{},[53,64,55],{},[45,66,67],{},[53,68,69],{},"cls",[16,71,72],{},[28,73],{"alt":30,"src":74},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F2022-02-06%2021.07.30.png",[76,77,80],"callout",{"title":78,"type":79},"Note","note",[16,81,82],{},"透過輸入指令的方式並不會真的清除終端機的內容，只是將畫面往上移動，所以如果你往上滑的話，還是可以看到之前的內容。",[16,84,85],{},"但是這邊其實還有另一招方式可以快速清除終端機的內容，也就是按下組合鍵",[42,87,88,98],{},[45,89,47,90],{},[42,91,92,95],{},[45,93,94],{},"Command + K",[45,96,97],{},"Control + L",[45,99,58,100],{},[42,101,102],{},[45,103,104],{},"Ctrl + L (早期似乎是 Ctrl+ K)",[16,106,107],{},"以上是清除終端機內容的簡單方式。",{"title":109,"searchDepth":110,"depth":110,"links":111},"",2,[112,113],{"id":14,"depth":110,"text":14},{"id":21,"depth":110,"text":21},"雜談","2022-02-06 20:52:22","md","zh-Hant",{},true,"\u002Fterminal","1",{"title":6,"description":18},false,"雜談\u002F清除終端機-Terminal-上的內容",[126,127,128,36,30],"Terminal","終端機","命令提示字元",null,"2023-07-30 11:02:58","\u002Fother\u002F20220206\u002F4243268872\u002F","0WowVBMzKrGNWG4gkb0i-j2nPLE1tqjdOO6AG7hH6Ts",{"newer":134,"older":138},{"url":135,"title":136,"date":137},"\u002Fother\u002F20220207\u002F2089611734\u002F","Discord 2FA 怎麼開？二階段驗證設定步驟，保護帳號不被盜","2022-02-07 10:20:01",{"url":139,"title":140,"date":141},"\u002Fother\u002F20220202\u002F3414775100\u002F","Udemy 小技巧 - 英文字幕轉中文(同步翻譯)","2022-02-02 22:41:09",[143,148,153],{"url":144,"title":145,"date":146,"readingMinutes":147},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":149,"title":150,"date":151,"readingMinutes":152},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":154,"title":155,"date":156,"readingMinutes":157},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784087366439]