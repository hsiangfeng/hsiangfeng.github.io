[{"data":1,"prerenderedAt":754},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220104\u002F255997626\u002F":3,"page:\u002Fother\u002F20220104\u002F255997626\u002F":4,"alt:\u002Fother\u002F20220104\u002F255997626\u002F":3,"prev-next:\u002Fother\u002F20220104\u002F255997626\u002F":729,"related:\u002Fother\u002F20220104\u002F255997626\u002F":738},"\u002Fen\u002Fmisc\u002F2022\u002F01\u002F04\u002Fcommon-http-status-codes-2xx-4xx-5xx\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":713,"date":714,"description":18,"extension":715,"lang":716,"meta":717,"navigation":620,"path":718,"readingMinutes":719,"seo":720,"standalone":721,"stem":722,"tags":723,"tldr":726,"updated":726,"url":727,"__hash__":728},"content\u002F雜談\u002F常見的-HTTP-Status-Code-2xx、4xx、5xx.md","常見的 HTTP Status Code 2xx、4xx、5xx","255997626",{"type":9,"value":10,"toc":693},"minimark",[11,15,19,23,26,29,48,60,63,66,73,76,90,165,174,180,183,186,191,194,254,269,273,276,333,336,339,342,346,355,359,368,371,375,390,393,397,410,416,424,430,433,489,495,498,501,505,511,516,519,666,670,676,679,689],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"只要你有在上網，那麼你就一定會看到這個 HTTP Status Code，如果你未來想要邁向後端工程師，那麼 HTTP Status Code 你就不能不了解，因此就讓我們來認識哪些是常見的 HTTP Status Code 吧。",[12,20,22],{"id":21},"http-狀態碼http-status-code","HTTP 狀態碼(HTTP Status Code)",[16,24,25],{},"首先這一篇不會全部都說明，因為 HTTP Status Code 實在太多情境也很多，因此只會列出一些常見、基本的 HTTP Status Code，只要能夠掌握這八成的基本 HTTP Status Code，那麼對於自己開發上也可以加快 debug。",[16,27,28],{},"HTTP 狀態碼可區分為五大類：",[30,31,32,36,39,42,45],"ul",{},[33,34,35],"li",{},"1xx 消息",[33,37,38],{},"2xx 成功",[33,40,41],{},"3xx 重新導向",[33,43,44],{},"4xx 客戶端錯誤",[33,46,47],{},"5xx 伺服器錯誤",[16,49,50,51,55,56,59],{},"基本上你只要看到前面的數字，你就可以辨別出當前的狀況，例如...只要你看到 ",[52,53,54],"code",{},"5xx"," 就代表一定跟後端有關，如果是 ",[52,57,58],{},"4xx"," 那就會是使用者 or 開發者在串接資料上有錯等等。",[16,61,62],{},"如果你不想記太多東西的話，那只要知道上面五大類就好，剩下的部分通通靠查的，因此底下只會列出非常常見的 HTTP Status Code 而已唷。",[16,64,65],{},"反正你最常見的一定是 404。",[16,67,68],{},[69,70],"img",{"alt":71,"src":72},"啊，啊，啊，這是一個不存在的頁面~","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002FrjpHeSm.gif",[12,74,38],{"id":75},"_2xx-成功",[16,77,78,79,82,83,86,87,89],{},"看到 ",[52,80,81],{},"2xx"," 就非常的簡單，因為你在做網頁任何操作時，最常見的就是 ",[52,84,85],{},"200","許多開發上在預設設置上都會是 ",[52,88,85],{},"，以 Express.js 來講就算你只寫以下",[91,92,97],"pre",{"className":93,"code":94,"language":95,"meta":96,"style":96},"language-js shiki shiki-themes github-dark-high-contrast","router.get('\u002F', (req, res) => {\n  res.send('True');\n})\n","js","",[52,98,99,142,159],{"__ignoreMap":96},[100,101,104,108,112,115,119,122,126,129,132,135,139],"span",{"class":102,"line":103},"line",1,[100,105,107],{"class":106},"sMAXC","router.",[100,109,111],{"class":110},"sj_SG","get",[100,113,114],{"class":106},"(",[100,116,118],{"class":117},"sTRMh","'\u002F'",[100,120,121],{"class":106},", (",[100,123,125],{"class":124},"s_sBn","req",[100,127,128],{"class":106},", ",[100,130,131],{"class":124},"res",[100,133,134],{"class":106},") ",[100,136,138],{"class":137},"sWyjQ","=>",[100,140,141],{"class":106}," {\n",[100,143,145,148,151,153,156],{"class":102,"line":144},2,[100,146,147],{"class":106},"  res.",[100,149,150],{"class":110},"send",[100,152,114],{"class":106},[100,154,155],{"class":117},"'True'",[100,157,158],{"class":106},");\n",[100,160,162],{"class":102,"line":161},3,[100,163,164],{"class":106},"})\n",[16,166,167,168,170,171,173],{},"只要使用者可以正常取得路徑該資源，一率都會預設回傳 ",[52,169,85],{},"，因此 ",[52,172,85],{}," 是非常常見的狀態碼。",[16,175,176,177,179],{},"所以 ",[52,178,85],{}," 我們可以簡單結論一下就是「你成功拿到資源、成功取得頁面」的意思。",[12,181,41],{"id":182},"_3xx-重新導向",[16,184,185],{},"3xx 狀態碼中最常用的就是 301 Moved Permanently 與 302 Found",[187,188,190],"h3",{"id":189},"_301-moved-permanently","301 Moved Permanently",[16,192,193],{},"通常來講我們在開發到一定階段之後，可能某些頁面會做調整，那 301 就是在告知瀏覽器這個頁面已經永久改到某處，因此 Express.js 可能就會寫成以下",[91,195,197],{"className":93,"code":196,"language":95,"meta":96,"style":96},"router.get('\u002F', (req, res) => {\n  res.status(301).redirect('http:\u002F\u002Fyourotherdomain.com')\n})\n",[52,198,199,223,250],{"__ignoreMap":96},[100,200,201,203,205,207,209,211,213,215,217,219,221],{"class":102,"line":103},[100,202,107],{"class":106},[100,204,111],{"class":110},[100,206,114],{"class":106},[100,208,118],{"class":117},[100,210,121],{"class":106},[100,212,125],{"class":124},[100,214,128],{"class":106},[100,216,131],{"class":124},[100,218,134],{"class":106},[100,220,138],{"class":137},[100,222,141],{"class":106},[100,224,225,227,230,232,236,239,242,244,247],{"class":102,"line":144},[100,226,147],{"class":106},[100,228,229],{"class":110},"status",[100,231,114],{"class":106},[100,233,235],{"class":234},"sCcAr","301",[100,237,238],{"class":106},").",[100,240,241],{"class":110},"redirect",[100,243,114],{"class":106},[100,245,246],{"class":117},"'http:\u002F\u002Fyourotherdomain.com'",[100,248,249],{"class":106},")\n",[100,251,252],{"class":102,"line":161},[100,253,164],{"class":106},[16,255,256,257,260,261,264,265,268],{},"例如你在輸入 ",[52,258,259],{},"www.google.com"," 的時候會被導向到沒有 ",[52,262,263],{},"www"," 的 ",[52,266,267],{},"google.com"," 網域。",[187,270,272],{"id":271},"_302-found","302 Found",[16,274,275],{},"但如果今天只是暫時性調整位置呢？那就一樣的做法",[91,277,279],{"className":93,"code":278,"language":95,"meta":96,"style":96},"router.get('\u002F', (req, res) => {\n  res.status(302).sendFile(__dirname, 'newPage.html');\n})\n",[52,280,281,305,329],{"__ignoreMap":96},[100,282,283,285,287,289,291,293,295,297,299,301,303],{"class":102,"line":103},[100,284,107],{"class":106},[100,286,111],{"class":110},[100,288,114],{"class":106},[100,290,118],{"class":117},[100,292,121],{"class":106},[100,294,125],{"class":124},[100,296,128],{"class":106},[100,298,131],{"class":124},[100,300,134],{"class":106},[100,302,138],{"class":137},[100,304,141],{"class":106},[100,306,307,309,311,313,316,318,321,324,327],{"class":102,"line":144},[100,308,147],{"class":106},[100,310,229],{"class":110},[100,312,114],{"class":106},[100,314,315],{"class":234},"302",[100,317,238],{"class":106},[100,319,320],{"class":110},"sendFile",[100,322,323],{"class":106},"(__dirname, ",[100,325,326],{"class":117},"'newPage.html'",[100,328,158],{"class":106},[100,330,331],{"class":102,"line":161},[100,332,164],{"class":106},[16,334,335],{},"只是這個頁面只是暫時的而已。",[12,337,44],{"id":338},"_4xx-客戶端錯誤",[16,340,341],{},"4xx 的狀態碼狀況就非常非常多了，多到你受不了。",[187,343,345],{"id":344},"_400-bad-request","400 Bad Request",[16,347,348,351,352,354],{},[52,349,350],{},"400"," 的狀況多到很難舉例，簡單來講就是如果你給了一些錯誤的格式，可能你應該要給一個 JSON 格式，但你卻給了 Array，又或者是檔案太大這也是歸類於 ",[52,353,350],{},"。",[187,356,358],{"id":357},"_401-unauthorized","401 Unauthorized",[16,360,361,364,365,367],{},[52,362,363],{},"401"," 這個狀態碼比較常見於需要驗證的頁面，例如後台管理介面，你如果沒有提供一些身份認證(Token) 等，那麼就會收到這個 Status Code，而 ",[52,366,363],{}," 也包含著拒絕你的意思。",[16,369,370],{},"因此你可以這樣理解「因為你還沒有提供資料給我認證，所以我拒絕給你東西」，真要濃縮的話，就是「尚未登入」的意思。",[187,372,374],{"id":373},"_403-forbidden","403 Forbidden",[16,376,377,380,381,383,384,386,387,389],{},[52,378,379],{},"403"," 與 ",[52,382,363],{}," 有一點相似，但是 ",[52,385,379],{}," 類似於「我拒絕你」、「類似黑名單」的意思，我拒絕你訪問 or 取得資料，例如你只有產品列表的讀取權限，但你卻在嘗試讀取訂單列表的資料，那麼就會得到 ",[52,388,379],{}," 的狀態碼。",[16,391,392],{},"換個方向來理解的話，那就是「小明對你告白，但你拒絕他並封鎖他」的意思(好悲傷)。",[187,394,396],{"id":395},"_404-not-found","404 Not Found",[16,398,399,400,403,404,409],{},"不得不說只要你有在上網，或多或少一定會遇到 ",[52,401,402],{},"404"," 這個錯誤，而這個狀態碼最常見於「找不到這個資源、路徑或頁面」等，如果你點這個",[405,406,408],"a",{"href":407},"\u002F1","網址","你就會進入到我製作的 404 頁面",[16,411,412],{},[69,413],{"alt":414,"src":415},"404 Error","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-01-04%2010.29.35.png",[16,417,418,419,423],{},"因此 404 可以說是你最基本最常見的 HTTP Status Code，而這個頁面也對於 SEO 來講非常重要，因為要告知使用者",[420,421,422],"strong",{},"沒有這個頁面","，所以你應該會看到很多很精緻的 404 頁面",[16,425,426],{},[69,427],{"alt":428,"src":429},"找不到網頁","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-01-04%2010.34.00.png",[16,431,432],{},"若是套用在串接 AJAX 上，那麼就是你輸入錯的 API Url 導致找不到資源，而 Express.js 本身也會幫你預設好這一段",[91,434,436],{"className":93,"code":435,"language":95,"meta":96,"style":96},"app.use(function(req, res, next) {\n  next(createError(404));\n});\n",[52,437,438,467,484],{"__ignoreMap":96},[100,439,440,443,446,448,451,453,455,457,459,461,464],{"class":102,"line":103},[100,441,442],{"class":106},"app.",[100,444,445],{"class":110},"use",[100,447,114],{"class":106},[100,449,450],{"class":137},"function",[100,452,114],{"class":106},[100,454,125],{"class":124},[100,456,128],{"class":106},[100,458,131],{"class":124},[100,460,128],{"class":106},[100,462,463],{"class":124},"next",[100,465,466],{"class":106},") {\n",[100,468,469,472,474,477,479,481],{"class":102,"line":144},[100,470,471],{"class":110},"  next",[100,473,114],{"class":106},[100,475,476],{"class":110},"createError",[100,478,114],{"class":106},[100,480,402],{"class":234},[100,482,483],{"class":106},"));\n",[100,485,486],{"class":102,"line":161},[100,487,488],{"class":106},"});\n",[16,490,491,492,494],{},"簡單來講 ",[52,493,402],{}," 所代表得意思就是「找不到這個頁面、找不到這個路徑 or 找不到這個資源」的意思。",[12,496,47],{"id":497},"_5xx-伺服器錯誤",[16,499,500],{},"基本上如果你是一名前端工程師的話，看到 5xx 開頭的錯誤就有 6~7 成可以丟給後端來處理，因為這方面的錯誤訊息大多都跟伺服器有相關。",[187,502,504],{"id":503},"_500-internal-server-error","500 Internal Server Error",[16,506,507,510],{},[52,508,509],{},"500"," 是一個非常萬用的錯誤碼，你在網路上可能也會逛著逛著就遇到這個狀態，可能是剛剛好伺服器發生了一些無可避免的錯誤導致伺服器無法給相對應的一些資訊。",[16,512,513],{},[69,514],{"alt":504,"src":515},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-01-04%2010.53.42.png",[16,517,518],{},"而這一段也是 Express.js 預設就會幫你寫好的",[91,520,522],{"className":93,"code":521,"language":95,"meta":96,"style":96},"\u002F\u002F error handler\napp.use((err, req, res, next) => {\n  \u002F\u002F set locals, only providing error in development\n  res.locals.message = err.message;\n  res.locals.error = req.app.get('env') === 'development' ? err : {};\n\n  \u002F\u002F render the error page\n  res.status(err.status || 500);\n  res.render(