[{"data":1,"prerenderedAt":225},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20200122\u002F3909813080\u002F":3,"page:\u002Fother\u002F20200122\u002F3909813080\u002F":4,"alt:\u002Fother\u002F20200122\u002F3909813080\u002F":3,"prev-next:\u002Fother\u002F20200122\u002F3909813080\u002F":200,"related:\u002Fother\u002F20200122\u002F3909813080\u002F":209},"\u002Fen\u002Fmisc\u002F2020\u002F01\u002F22\u002Fnotes-on-switching-from-windows-10-to-macos\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":183,"date":184,"description":18,"extension":185,"lang":186,"meta":187,"navigation":188,"path":189,"readingMinutes":190,"seo":191,"standalone":192,"stem":193,"tags":194,"tldr":197,"updated":197,"url":198,"__hash__":199},"content\u002F雜談\u002FWindows-10-轉到-Mac-OS-X-的一些細節.md","Windows 10 轉到 Mac OS X 的一些細節","3909813080",{"type":9,"value":10,"toc":172},"minimark",[11,15,19,22,25,86,89,96,102,108,111,114,121,132,142,145,148,151,154,157,160,163,166,169],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近開發環境轉到 Mac OS X 上，所以這一篇就稍微紀錄一下 Mac 與 Windows 轉移之痛 Q_Q",[12,20,21],{"id":21},"鍵盤不同",[16,23,24],{},"首先最大不同就是以往的 Alt、Ctrl 會稍微有點不同，Mac 系統上面的這兩個按鈕所代表的稍稍不太一樣，更不用說切換輸入法的部分。",[26,27,28,42],"table",{},[29,30,31],"thead",{},[32,33,34,39],"tr",{},[35,36,38],"th",{"align":37},"center","Windows",[35,40,41],{"align":37},"Mac",[43,44,45,54,62,70,78],"tbody",{},[32,46,47,51],{},[48,49,50],"td",{"align":37},"Ctrl",[48,52,53],{"align":37},"Control ⌃",[32,55,56,59],{},[48,57,58],{"align":37},"Alt",[48,60,61],{"align":37},"Option ⌥",[32,63,64,67],{},[48,65,66],{"align":37},"Windown",[48,68,69],{"align":37},"Command ⌘",[32,71,72,75],{},[48,73,74],{"align":37},"Shift",[48,76,77],{"align":37},"Shift ⇧",[32,79,80,83],{},[48,81,82],{"align":37},"Caps Lock",[48,84,85],{"align":37},"Caps Lock ⇪",[12,87,88],{"id":88},"切換輸入法",[16,90,91,92,95],{},"Windows 10 的切換中央文輸入法是按 ",[93,94,74],"code",{}," (預設狀況下)。",[16,97,98,99,101],{},"而 Mac 切換輸入法是在一個箭頭按鈕的上方的按鈕(",[93,100,85],{},")來切換中英文輸入法。",[16,103,104,105,107],{},"此外比較特別的是中文輸入法時若按著 ",[93,106,74],{}," 出現的標點符號皆為全形，關於這一點我還真必須習慣一下。",[12,109,110],{"id":110},"輸入法",[16,112,113],{},"另外 Mac 的預設輸入法在選字是後選字的方式，意指選字的標點閃爍符號要在後面，關於這一點我也超不習慣，通常我在 Windows 系統選字是前選字(很難截圖到，所以就自己體驗囉~)。",[16,115,116,117,120],{},"基本上輸入法在中文輸入按住 ",[93,118,119],{},"Caps Lock 鍵 ⇪"," 的時候會是小寫英文，例如：「ａｂｃｄ」",[16,122,123,124,126,127,131],{},"而 ",[93,125,77],{}," 則會是大寫英文，例如：「ＡＢＣＤ」，但是這邊你會發現一件事情",[128,129,130],"strong",{},"都是全形的","，所以如果你想要打半形英文的話，那就要切換成英文。",[16,133,134,135,137,138,141],{},"至於標點符到的部分基本上都是 ",[93,136,77],{}," + ",[93,139,140],{},"標點符號"," 就可以了\b。",[12,143,144],{"id":144},"觸碰版手指操作",[16,146,147],{},"基本上如果有使用過 Windows 10 的筆電的話，對於 Mac 的觸碰版操作是不會覺得差異到哪裡去，因為會有 87 像，像是三指滑動虛擬桌面、兩指移動滾輪畫面以及縮放等等。",[16,149,150],{},"除了開啟網頁是上下頁可以使用雙指切換之外，基本上沒有太大的差異。",[16,152,153],{},"其他的部分則可以在「系統偏好設定」\b\b\b\b\b→ 「觸碰式軌跡板」這邊會有很多手勢教學。",[16,155,156],{},"只是在滾輪上會跟 Windows 稍微有點不太一樣，Windows 滾輪若向下滾則畫面會向下，但 Mac 是相反的。",[16,158,159],{},"所以基本上我傾向使用觸碰板來操作畢竟比較符合人體操作行為 XD",[12,161,162],{"id":162},"操作相關",[16,164,165],{},"其他操作相關按鈕也稍微有點不太一樣，舉例來講 複製、剪下以及貼上在 Windows 系統的快捷鍵是 Ctrl + X、C、V 等，但在 Mac 則是 Command + C、X、V 等。",[12,167,168],{"id":168},"最後",[16,170,171],{},"最後這邊後續應該會撰寫一些如何美化自己的 Terminal 的文章。",{"title":173,"searchDepth":174,"depth":174,"links":175},"",2,[176,177,178,179,180,181,182],{"id":14,"depth":174,"text":14},{"id":21,"depth":174,"text":21},{"id":88,"depth":174,"text":88},{"id":110,"depth":174,"text":110},{"id":144,"depth":174,"text":144},{"id":162,"depth":174,"text":162},{"id":168,"depth":174,"text":168},"雜談","2020-01-22 09:22:13","md","zh-Hant",{},true,"\u002Fwindows-10-mac-os-x","2",{"title":6,"description":18},false,"雜談\u002FWindows-10-轉到-Mac-OS-X-的一些細節",[41,195,196],"Windows 10","作業系統",null,"\u002Fother\u002F20200122\u002F3909813080\u002F","BNDMeYfJ_LRgCB3fwCNQ2gFB_BdTN6oSaJ97eqbLiJs",{"newer":201,"older":205},{"url":202,"title":203,"date":204},"\u002Fother\u002F20200123\u002F1105303313\u002F","Mac OS 終端機美化看這一篇就夠了！(Mac OS Terminal)","2020-01-23 00:01:10",{"url":206,"title":207,"date":208},"\u002Fjavascript\u002F20200117\u002F3217748743\u002F","JavaScript 的 if 跟 switch 效能","2020-01-17 13:28:36",[210,215,220],{"url":211,"title":212,"date":213,"readingMinutes":214},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":216,"title":217,"date":218,"readingMinutes":219},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":221,"title":222,"date":223,"readingMinutes":224},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784013091526]