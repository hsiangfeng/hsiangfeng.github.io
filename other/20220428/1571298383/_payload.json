[{"data":1,"prerenderedAt":881},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220428\u002F1571298383\u002F":3,"page:\u002Fother\u002F20220428\u002F1571298383\u002F":4,"alt:\u002Fother\u002F20220428\u002F1571298383\u002F":3,"prev-next:\u002Fother\u002F20220428\u002F1571298383\u002F":857,"related:\u002Fother\u002F20220428\u002F1571298383\u002F":866},"\u002Fen\u002Fmisc\u002F2022\u002F04\u002F28\u002Fdiscord-beginners-complete-guide\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":836,"date":837,"description":838,"extension":205,"lang":839,"meta":840,"navigation":399,"path":841,"readingMinutes":842,"seo":843,"standalone":844,"stem":845,"tags":846,"tldr":853,"updated":854,"url":855,"__hash__":856},"content\u002FDiscord\u002FDiscord 新手教學：從入門到上手完整指南.md","Discord 新手教學：從入門到上手完整指南","1571298383",{"type":9,"value":10,"toc":803},"minimark",[11,22,26,29,33,39,42,45,48,51,54,59,62,68,71,74,80,83,89,100,103,106,109,120,130,135,140,145,150,155,161,164,167,172,175,180,183,196,200,218,223,226,243,248,253,256,265,270,273,283,288,291,307,312,315,331,336,339,348,353,356,365,370,373,384,407,412,415,418,433,438,441,444,449,452,457,463,466,469,478,483,486,493,500,503,506,509,512,515,518,524,527,530,533,539,547,550,556,561,564,567,570,575,578,584,587,590,593,598,601,608,611,615,622,628,633,636,642,652,662,725,728,731,734,737,740,745,748,751,756,759,764,767,773,777,787,791,799],[12,13,14],"blockquote",{},[15,16,17,21],"p",{},[18,19,20],"strong",{},"Note","\nDiscord 是專為社群設計的溝通軟體，跟 Slack 比起來歷史訊息可永久保存、討論串功能強大，免費版的功能豐富度對社群更友善。第一次進伺服器只看得到少數頻道是正常的，多數頻道要靠身份組才會解鎖。",[23,24,25],"h2",{"id":25},"前言",[15,27,28],{},"Discord 現今越來越紅，也越來越多技術社群使用，但是由於 Discord 功能非常多且強大，所以對於初學者來講相對很困難，因此就寫了一篇 Discord 新手教學文章，涵蓋身份組、頻道圖示、討論串、Markdown 語法、搜尋功能等基礎操作，希望能幫助你快速上手 Discord。",[23,30,32],{"id":31},"discord","Discord",[15,34,35],{},[36,37],"img",{"alt":32,"src":38},"https:\u002F\u002Fi.imgur.com\u002FS36k5Od.png",[15,40,41],{},"Discord 本身是專為社群所設計的社交溝通軟體，早期主要是針對遊戲玩家為主，後來陸續更新許多功能，所以也可以讓很多人使用，舉凡技術人士、教育、商業等使用。",[15,43,44],{},"後來越來越多技術人士使用主要原因是 Discord 更新了討論串（Thread）功能，而這個功能非常強大，在社群討論的使用情境上甚至不輸 Slack（另一款溝通軟體，常見於企業）。",[15,46,47],{},"除此之外 Discord 並沒有限制歷史訊息，簡單來講就是你的歷史訊息可以永久保存。雖然 Slack 在 2022 年 9 月後已開放免費版查看完整歷史訊息，但 Discord 在免費功能的豐富度上仍然對社群使用者更加友好。",[15,49,50],{},"以下這邊我會以六角學院的伺服器來做一些 Discord 教學介紹。",[23,52,53],{"id":53},"身份組",[15,55,56],{},[36,57],{"alt":53,"src":58},"https:\u002F\u002Fi.imgur.com\u002FYn6XBx9.png",[15,60,61],{},"Discord 主要是以身份組來管理使用者的，因此如果你第一次進入到一些新的伺服器的話，通常你可能是看不太到什麼頻道的，例如六角學院的伺服器",[15,63,64],{},[36,65],{"alt":66,"src":67},"六角學院伺服器","https:\u002F\u002Fi.imgur.com\u002FQ4zKEK6.png",[15,69,70],{},"我們可以看到畫面上只有六角學院、綜合頻道、活動頻道與語音聊天頻道到類別，但實際上六角學院有這麼少分類嗎？不，實際上是非常多的，但你必須持有特定身份組才能夠看到特定頻道分類。",[15,72,73],{},"有些頻道會採用可以讓使用者自助領取身份組，以六角學院來講就會有一個「自助領取身份組」，當你進入到該頻道時，你就會看到有一個類似 Discord 機器人的訊息，此時你只要點下方表情符號你就可以獲取相對應身份組",[15,75,76],{},[36,77],{"alt":78,"src":79},"自助領取身份組","https:\u002F\u002Fi.imgur.com\u002Fw7N3ByH.png",[15,81,82],{},"舉例來講當我點了 「切版系列課程村民」 表情符號後，你就可以在左側列表看到相關頻道解鎖了",[15,84,85],{},[36,86],{"alt":87,"src":88},"相關頻道解鎖","https:\u002F\u002Fi.imgur.com\u002Fu25RIte.png",[15,90,91,92,99],{},"那麼如果你的伺服器想要加入這種自助領取身份組的話，你可以參考使用 ",[93,94,98],"a",{"href":95,"rel":96},"https:\u002F\u002Fmee6.xyz\u002F",[97],"nofollow","Mee6"," 這個 Discord Bot 還滿好用的。",[23,101,102],{"id":102},"頻道圖示",[15,104,105],{},"接下來我們來認識一下頻道的圖示",[15,107,108],{},"只需要點一下「左側的頻道」，右側主畫面就會自動切換過去，然後這時候你就可以開始聊天囉~",[15,110,111,112,115,116,119],{},"但需注意部分頻道",[18,113,114],{},"僅限觀看","而不能聊天，這類型頻道大多都是屬於「",[18,117,118],{},"公告頻道","」，基本上你可以透過頻道前面的小圖示了解",[121,122,123,127],"ul",{},[124,125,126],"li",{},"大聲公 ⇒ 公告頻道",[124,128,129],{},"井字號 ⇒ 文字聊天",[15,131,132],{},[36,133],{"alt":102,"src":134},"https:\u002F\u002Fi.imgur.com\u002FbhTlxU1.png",[121,136,137],{},[124,138,139],{},"喇叭 ⇒ 語音聊天",[15,141,142],{},[36,143],{"alt":102,"src":144},"https:\u002F\u002Fi.imgur.com\u002FaEXyM8q.png",[121,146,147],{},[124,148,149],{},"書本 ⇒ 伺服器公佈欄",[15,151,152],{},[36,153],{"alt":102,"src":154},"https:\u002F\u002Fi.imgur.com\u002FJHHe983.png",[15,156,157,160],{},[18,158,159],{},"(圖示前面若有鎖頭，代表該頻道屬於私人頻道，必須持有特定身份組才能看到的",")",[23,162,163],{"id":163},"頻道說明",[15,165,166],{},"每一個頻道都有屬於它的用途，如果管理員有針對該頻道新增說明的話，你可以透過頻道上方了解觀看頻道說明",[15,168,169],{},[36,170],{"alt":163,"src":171},"https:\u002F\u002Fi.imgur.com\u002F0MhZA2X.png",[15,173,174],{},"點擊後就會跳出該頻道的說明",[15,176,177],{},[36,178],{"alt":163,"src":179},"https:\u002F\u002Fi.imgur.com\u002FfGeQE7d.png",[23,181,182],{"id":182},"聊天輸入功能",[15,184,185,186,191,192,195],{},"Discord 本身支援 Markdown 語法，若你不熟悉 Markdown 可詳見「",[93,187,190],{"href":188,"rel":189},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20191111\u002F1875438261\u002F",[97],"Markdown 基礎與入門教學手冊","」，但需注意 Discord 本身只支援「",[18,193,194],{},"部分","」Markdown 語法。",[197,198,199],"h3",{"id":199},"粗體",[201,202,207],"pre",{"className":203,"code":204,"language":205,"meta":206,"style":206},"language-md shiki shiki-themes github-dark-high-contrast","**粗體**\n","md","",[208,209,210],"code",{"__ignoreMap":206},[211,212,215],"span",{"class":213,"line":214},"line",1,[211,216,204],{"class":217},"sXSG1",[15,219,220],{},[36,221],{"alt":199,"src":222},"https:\u002F\u002Fi.imgur.com\u002FarhAwgl.png",[197,224,225],{"id":225},"斜體",[201,227,229],{"className":203,"code":228,"language":205,"meta":206,"style":206},"_斜體_\n*斜體*\n",[208,230,231,237],{"__ignoreMap":206},[211,232,233],{"class":213,"line":214},[211,234,236],{"class":235},"sz7Oa","_斜體_\n",[211,238,240],{"class":213,"line":239},2,[211,241,242],{"class":235},"*斜體*\n",[15,244,245],{},[36,246],{"alt":225,"src":247},"https:\u002F\u002Fi.imgur.com\u002FOCSTb9t.png",[15,249,250],{},[36,251],{"alt":225,"src":252},"https:\u002F\u002Fi.imgur.com\u002FHOKkqaK.png",[197,254,255],{"id":255},"下底線",[201,257,259],{"className":203,"code":258,"language":205,"meta":206,"style":206},"__下底線__\n",[208,260,261],{"__ignoreMap":206},[211,262,263],{"class":213,"line":214},[211,264,258],{"class":217},[15,266,267],{},[36,268],{"alt":255,"src":269},"https:\u002F\u002Fi.imgur.com\u002FU6GOio8.png",[197,271,272],{"id":272},"刪除線",[201,274,276],{"className":203,"code":275,"language":205,"meta":206,"style":206},"~~刪除線~~\n",[208,277,278],{"__ignoreMap":206},[211,279,280],{"class":213,"line":214},[211,281,275],{"class":282},"sOn-i",[15,284,285],{},[36,286],{"alt":272,"src":287},"https:\u002F\u002Fi.imgur.com\u002FtfDvtf5.png",[197,289,290],{"id":290},"粗斜體",[201,292,294],{"className":203,"code":293,"language":205,"meta":206,"style":206},"***粗斜體***\n",[208,295,296],{"__ignoreMap":206},[211,297,298,301,304],{"class":213,"line":214},[211,299,300],{"class":217},"**",[211,302,303],{"class":235},"*粗斜體*",[211,305,306],{"class":217},"**\n",[15,308,309],{},[36,310],{"alt":290,"src":311},"https:\u002F\u002Fi.imgur.com\u002FXmfntGr.png",[197,313,314],{"id":314},"底線加斜體",[201,316,318],{"className":203,"code":317,"language":205,"meta":206,"style":206},"__*底線加斜體*__\n",[208,319,320],{"__ignoreMap":206},[211,321,322,325,328],{"class":213,"line":214},[211,323,324],{"class":217},"__",[211,326,327],{"class":235},"*底線加斜體*",[211,329,330],{"class":217},"__\n",[15,332,333],{},[36,334],{"alt":314,"src":335},"https:\u002F\u002Fi.imgur.com\u002FC3N5TmR.png",[197,337,338],{"id":338},"底線加粗體",[201,340,342],{"className":203,"code":341,"language":205,"meta":206,"style":206},"__**底線加粗體**__\n",[208,343,344],{"__ignoreMap":206},[211,345,346],{"class":213,"line":214},[211,347,341],{"class":217},[15,349,350],{},[36,351],{"alt":338,"src":352},"https:\u002F\u002Fi.imgur.com\u002FbzS82Vi.png",[197,354,355],{"id":355},"底線加粗斜體",[201,357,359],{"className":203,"code":358,"language":205,"meta":206,"style":206},"__***底線加粗斜體***__\n",[208,360,361],{"__ignoreMap":206},[211,362,363],{"class":213,"line":214},[211,364,358],{"class":217},[15,366,367],{},[36,368],{"alt":355,"src":369},"https:\u002F\u002Fi.imgur.com\u002F8HJ3Q1E.png",[197,371,372],{"id":372},"引用文字",[15,374,375,376,379,380,383],{},"若是想使用引用文字，那麼則是使用「",[208,377,378],{},">","」、「",[208,381,382],{},">>>","」",[201,385,387],{"className":203,"code":386,"language":205,"meta":206,"style":206},"> 這是一段話\n\n>>> 這是二段話\n",[208,388,389,395,401],{"__ignoreMap":206},[211,390,391],{"class":213,"line":214},[211,392,394],{"class":393},"sKpQp","> 這是一段話\n",[211,396,397],{"class":213,"line":239},[211,398,400],{"emptyLinePlaceholder":399},true,"\n",[211,402,404],{"class":213,"line":403},3,[211,405,406],{"class":393},">>> 這是二段話\n",[15,408,409],{},[36,410],{"alt":372,"src":411},"https:\u002F\u002Fi.imgur.com\u002F6WdEkIe.png",[197,413,414],{"id":414},"程式碼片段",[15,416,417],{},"如果文字中夾雜程式碼的話，可以使用頓號(esc 下方的「```」按鍵)包覆程式碼",[201,419,421],{"className":203,"code":420,"language":205,"meta":206,"style":206},"各位同學好，這是我的程式碼 `var myName = \"Ray\";`\n",[208,422,423],{"__ignoreMap":206},[211,424,425,429],{"class":213,"line":214},[211,426,428],{"class":427},"sMAXC","各位同學好，這是我的程式碼 ",[211,430,432],{"class":431},"sCcAr","`var myName = \"Ray\";`\n",[15,434,435],{},[36,436],{"alt":414,"src":437},"https:\u002F\u002Fi.imgur.com\u002FmMyIpXa.png",[197,439,440],{"id":440},"程式碼區塊",[15,442,443],{},"程式碼區塊非常適合作為貼上大量程式碼的功能，而且 Discord 也有支援程式碼高亮，只需要使用三個頓號，然後在後方補上高亮的程式碼語言就可以囉",[15,445,446],{},[36,447],{"alt":440,"src":448},"https:\u002F\u002Fi.imgur.com\u002FCjR23pi.png",[15,450,451],{},"以下是沒有使用高亮的狀況",[15,453,454],{},[36,455],{"alt":440,"src":456},"https:\u002F\u002Fi.imgur.com\u002FrsL7Nx4.png",[15,458,459],{},[460,461,462],"del",{},"（雖然閱讀上沒有太大差異，但是高亮就是爽）",[197,464,465],{"id":465},"防暴雷訊息",[15,467,468],{},"防爆雷格式是一個很特別的功能，你只需要使用「||」包覆文字後即可使用",[201,470,472],{"className":203,"code":471,"language":205,"meta":206,"style":206},"||防爆雷||\n",[208,473,474],{"__ignoreMap":206},[211,475,476],{"class":213,"line":214},[211,477,471],{"class":427},[15,479,480],{},[36,481],{"alt":465,"src":482},"https:\u002F\u002Fi.imgur.com\u002FQmoGNT4.png",[15,484,485],{},"送出後使用者並不會直接在畫面上看到訊息，而是必須透過點擊顯示",[15,487,488,489],{},"(點擊前)\n",[36,490],{"alt":491,"src":492},"點擊前","https:\u002F\u002Fi.imgur.com\u002FqyjFrXe.png",[15,494,495,496],{},"(點擊後)\n",[36,497],{"alt":498,"src":499},"點擊後","https:\u002F\u002Fi.imgur.com\u002FUnqhjrn.png",[23,501,502],{"id":502},"討論串",[15,504,505],{},"接下來就是 Discord 最重要的功能之一，也就是討論串！",[15,507,508],{},"Discord 本身也支援跟 Slack 一樣的 thread 功能，而且可以永久保存。",[15,510,511],{},"開啟討論串的方式有兩種",[197,513,514],{"id":514},"對話建立討論串",[15,516,517],{},"對話方式建立討論串是最簡單的，只需要發送任何一句話，然後將滑鼠移動過去到該訊息上，就可以看到「建立討論串」的功能按鈕",[15,519,520],{},[36,521],{"alt":522,"src":523},"對話建立","https:\u002F\u002Fi.imgur.com\u002FXoS62EU.png",[15,525,526],{},"建立時請輸入討論串標題與存檔時間。",[15,528,529],{},"(存檔意思是指：該討論串結束時間，關閉後將會儲存起來並不會呈現在左側列表)",[197,531,532],{"id":532},"指令建立討論串",[15,534,535,536,383],{},"只需要在底下輸入框輸入「",[208,537,538],{},"\u002Fthread",[121,540,541,544],{},[124,542,543],{},"討論名稱",[124,545,546],{},"討論內文",[15,548,549],{},"輸入完畢後即可開啟討論串，並於畫面上看到該訊息",[15,551,552],{},[36,553],{"alt":554,"src":555},"指令建立","https:\u002F\u002Fi.imgur.com\u002FHkUbSRq.png",[15,557,558],{},[36,559],{"alt":554,"src":560},"https:\u002F\u002Fi.imgur.com\u002FmG6FNus.png",[15,562,563],{},"那麼討論串有什麼意義呢？如果你想要集中討論特定事物時就可以使用討論串，透過使用討論串你可以避免過度干擾他人，盡可能讓想跟你討論相同主題的人加入就好。",[197,565,566],{"id":566},"加入討論串",[15,568,569],{},"加入他人討論串方式非常簡單，只需要針對該討論串發送訊息 or 互動等就會被加入到該討論串內，而加入到該討論串後你可以在左側列表看到該討論串",[15,571,572],{},[36,573],{"alt":566,"src":574},"https:\u002F\u002Fi.imgur.com\u002FL4I7Znu.png",[15,576,577],{},"當討論結束時，你也可以透過討論串中的更多離開該討論串 or 編輯討論串等功能",[15,579,580],{},[36,581],{"alt":582,"src":583},"離開討論串","https:\u002F\u002Fi.imgur.com\u002FbdFUqpP.png",[15,585,586],{},"或者你也可以乾脆等討論串時間到自動封存，離開討論串 or 討論串到期(意指存檔)後就不會再收到與裡面互動的任何訊息。",[197,588,589],{"id":589},"查看討論串",[15,591,592],{},"如果想了解當前頻道有哪些有趣的討論，可以點頻道上方井字號即可查看還在討論中以及已經存檔的歷史討論串",[15,594,595],{},[36,596],{"alt":589,"src":597},"https:\u002F\u002Fi.imgur.com\u002FCtI8gIw.png",[197,599,600],{"id":600},"討論串建立注意事項",[15,602,603,604,607],{},"討論串在建立時，討論串名稱建議以",[18,605,606],{},"內容關鍵字","來命名。",[15,609,610],{},"建議不要貼入內容這會導致文字內容過大而不好閱讀，除此之外討論串名稱也有文字上限限制，因此建議不要將內容當作標題名稱來建立，而這也會大大影響 Discord 搜尋唷。",[23,612,614],{"id":613},"tag","Tag",[15,616,617,618,621],{},"你可以在文字輸入框中按下「",[208,619,620],{},"@"," + 名稱」即可通知有權限觀看該頻道的相關人員",[15,623,624],{},[36,625],{"alt":626,"src":627},"Tag 使用者","https:\u002F\u002Fi.imgur.com\u002FiSTFg47.png",[15,629,630],{},[460,631,632],{},"(若在討論串內 Tag 人也可以將他強制加入討論，僅限能觀看該頻道的人）",[15,634,635],{},"甚至你也可以針對身份組 tag 呼叫唷~",[15,637,638],{},[36,639],{"alt":640,"src":641},"針對身份組","https:\u002F\u002Fi.imgur.com\u002Fq8tN08V.png",[15,643,644,645,648,649,651],{},"預設來講，初始使用者都是只有 ",[208,646,647],{},"@everyone"," 身份，但通常 ",[208,650,647],{}," 這個功能是會被伺服器管理員關閉的，因為會過度干擾。",[15,653,654,655,657,658,661],{},"除了 ",[208,656,647],{}," 還有 ",[208,659,660],{},"@here","，兩者的差異如下：",[663,664,665,684],"table",{},[666,667,668],"thead",{},[669,670,671,675,678,681],"tr",{},[672,673,674],"th",{},"指令",[672,676,677],{},"通知對象",[672,679,680],{},"是否需要在線",[672,682,683],{},"常見用途",[685,686,687,706],"tbody",{},[669,688,689,694,700,703],{},[690,691,692],"td",{},[208,693,647],{},[690,695,696,697],{},"該頻道中的",[18,698,699],{},"所有成員",[690,701,702],{},"不需要，離線也會收到通知",[690,704,705],{},"重要公告、全體通知",[669,707,708,712,719,722],{},[690,709,710],{},[208,711,660],{},[690,713,714,715,718],{},"該頻道中",[18,716,717],{},"目前在線上","的成員",[690,720,721],{},"需要，僅通知在線者",[690,723,724],{},"即時討論、臨時揪人",[15,726,727],{},"兩者通常都會被伺服器管理員限制使用權限，避免成員過度干擾他人。",[23,729,730],{"id":730},"表情符號",[732,733],"hr",{},[15,735,736],{},"Discord 會依據伺服器提供相對應的表情符號，但是「動態 emoji」是必須成為 Discord 付費會員（如 Discord Nitro 或 Nitro Basic）才可以使用的。",[15,738,739],{},"非 Discord 會員僅限使用靜態 emoji。",[15,741,742],{},[18,743,744],{},"ps.請不要相信所謂的免費 Nitro、Classic 會員連結，這會讓你的帳戶被不肖人士盜取。",[23,746,747],{"id":747},"搜尋",[15,749,750],{},"Discord 也有提供搜尋功能，而該搜尋就是針對此伺服器頻道的搜尋，位置就在伺服器上方",[15,752,753],{},[36,754],{"alt":747,"src":755},"https:\u002F\u002Fi.imgur.com\u002FixM9ArO.png",[15,757,758],{},"Discord 的搜尋功能非常強大，它可以搜尋歷史訊息、內容以及使用者等等。",[15,760,761],{},[36,762],{"alt":747,"src":763},"https:\u002F\u002Fi.imgur.com\u002FXA0LM9U.png",[15,765,766],{},"ps. 討論串搜尋功能則是搜尋討論串標題為主。",[15,768,769],{},[36,770],{"alt":771,"src":772},"討論串搜尋","https:\u002F\u002Fi.imgur.com\u002FUBki0Uk.png",[23,774,776],{"id":775},"discord-通知調整","Discord 通知調整",[15,778,779,780,786],{},"部分 Mac 使用者可能會收不到 Discord 的通知或是想關閉伺服器的通知訊息，因此建議可以參考「",[18,781,782],{},[93,783,785],{"href":784},"\u002Fother\u002F20211103\u002F3995044243\u002F","Mac 開啟 Discord 通知與調整頻道通知","」文章的設定。",[23,788,790],{"id":789},"discord-其他教學","Discord 其他教學",[15,792,793,794,798],{},"Discord 功能相當多且相當強大，若想了解其他部分的話可",[93,795,797],{"href":796},"\u002Fother\u002F20211030\u002F2067528825\u002F","詳見","此文章。",[800,801,802],"style",{},"html pre.shiki code .sXSG1, html code.shiki .sXSG1{--shiki-default:#F0F3F6;--shiki-default-font-weight:bold}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sz7Oa, html code.shiki .sz7Oa{--shiki-default:#F0F3F6;--shiki-default-font-style:italic}html pre.shiki code .sOn-i, html code.shiki .sOn-i{--shiki-default:#F0F3F6;--shiki-default-text-decoration:line-through}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":206,"searchDepth":239,"depth":239,"links":804},[805,806,807,808,809,810,824,831,832,833,834,835],{"id":25,"depth":239,"text":25},{"id":31,"depth":239,"text":32},{"id":53,"depth":239,"text":53},{"id":102,"depth":239,"text":102},{"id":163,"depth":239,"text":163},{"id":182,"depth":239,"text":182,"children":811},[812,813,814,815,816,817,818,819,820,821,822,823],{"id":199,"depth":403,"text":199},{"id":225,"depth":403,"text":225},{"id":255,"depth":403,"text":255},{"id":272,"depth":403,"text":272},{"id":290,"depth":403,"text":