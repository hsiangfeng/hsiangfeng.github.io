[{"data":1,"prerenderedAt":601},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220928\u002F1377668819\u002F":3,"page:\u002Fother\u002F20220928\u002F1377668819\u002F":4,"alt:\u002Fother\u002F20220928\u002F1377668819\u002F":3,"prev-next:\u002Fother\u002F20220928\u002F1377668819\u002F":576,"related:\u002Fother\u002F20220928\u002F1377668819\u002F":585},"\u002Fen\u002Fmisc\u002F2022\u002F09\u002F28\u002Fvite-plugin-vue-export-helper-github-pages-404-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":557,"date":558,"description":559,"extension":560,"lang":561,"meta":562,"navigation":151,"path":563,"readingMinutes":564,"seo":565,"standalone":566,"stem":567,"tags":568,"tldr":573,"updated":573,"url":574,"__hash__":575},"content\u002F雜談\u002F關於-Vite-部署到-GitHub-Pages-卻找不到-plugin-vue-export-helper-問題.md","關於 Vite 部署到 GitHub Pages 卻找不到 _plugin-vue_export-helper 問題","1377668819",{"type":9,"value":10,"toc":551},"minimark",[11,15,24,27,34,40,43,46,53,56,63,73,79,88,91,524,530,533,547],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,23],"p",{},"最近發現 vite 編譯之後部署到 GitHub Pages 會突然無法正常運作的問題發生，然後發現是 ",[20,21,22],"code",{},"_plugin-vue_export-helper"," 在搞鬼，所以這一篇記錄一下。",[12,25,26],{"id":26},"事發原因",[16,28,29,30,33],{},"當部署到 vite 執行 ",[20,31,32],{},"npm run build"," 之後接著部署到 GitHub Pages 卻會一直出現",[35,36,37],"blockquote",{},[16,38,39],{},"TypeError: error loading dynamically imported module\n來源為「\u002Fassets\u002F_plugin-vue_export-helper.cdc0426e.js」的模組載入失敗。",[16,41,42],{},"然後畫面就會整個都是空白的，因此接著這邊記錄一下解決方式。",[12,44,45],{"id":45},"解決方式",[16,47,48,49,52],{},"首先一開始我以為是路徑出現問題，所以嘗試瀏覽器 URL 輸入其他檔案的路徑，發現是可以正常載入的，所以就開始檢查 ",[20,50,51],{},"_plugin-vue_export-helper.cdc0426e.js"," 這個檔案。",[16,54,55],{},"唯獨這個檔案不管怎麼樣讀取就是會 404",[16,57,58],{},[59,60],"img",{"alt":61,"src":62},"404","https:\u002F\u002Fi.imgur.com\u002F57qRC5h.png",[16,64,65,66],{},"接著就丟上網路查了一下 「_plugin-vue_export-helper」，所以就查到了這一篇文章 ",[67,68,72],"a",{"href":69,"rel":70},"https:\u002F\u002Fgithub.com\u002Fvitejs\u002Fvite\u002Fissues\u002F9119",[71],"nofollow","_plugin-vue_export-helper js file cant not be access with Github Pages(404)",[16,74,75,76,78],{},"然後 ",[20,77,22],{}," 這個檔案命名規則上在某些環境下會有問題，所以這邊就要把這個檔案改名，而 vite 底層本身是使用 rollup 去編譯的，因此這邊就要去修改 rollup 的設定。",[16,80,81,82,87],{},"所以這邊可以翻到這個檔案 ",[67,83,86],{"href":84,"rel":85},"https:\u002F\u002Fgithub.com\u002Frollup\u002Frollup\u002Fblob\u002Fmaster\u002Fsrc\u002Futils\u002FsanitizeFileName.ts",[71],"sanitizeFileName.ts","，這個檔案是用來處理檔案名稱的，所以這邊就要去修改這個檔案的設定，但我們不可能直接去修改這個檔案，因為這個檔案是在 node_modules 底下，所以這邊就要去修改 vite 的設定。",[16,89,90],{},"首先打開 vite.config.js 這個檔案，然後加入以下設定",[92,93,98],"pre",{"className":94,"code":95,"language":96,"meta":97,"style":97},"language-js shiki shiki-themes github-dark-high-contrast","import { defineConfig } from 'vite'\nimport vue from '@vitejs\u002Fplugin-vue'\nimport path from 'path'\n\n\u002F\u002F eslint-disable-next-line no-control-regex\nconst INVALID_CHAR_REGEX = \u002F[\\x00-\\x1F\\x7F\u003C>*#\"{}|^[\\]`;?:&=+$,]\u002Fg;\nconst DRIVE_LETTER_REGEX = \u002F^[a-z]:\u002Fi;\n\nexport default defineConfig({\n  plugins: [vue()],\n  resolve: {\n    alias: {\n      \"@\": fileURLToPath(new URL(\".\u002Fsrc\", import.meta.url)),\n    },\n  },\n  build: {\n    rollupOptions: {\n      output: {\n        \u002F\u002F https:\u002F\u002Fgithub.com\u002Frollup\u002Frollup\u002Fblob\u002Fmaster\u002Fsrc\u002Futils\u002FsanitizeFileName.ts\n        sanitizeFileName(name) {\n          const match = DRIVE_LETTER_REGEX.exec(name);\n          const driveLetter = match ? match[0] : '';\n          \u002F\u002F substr 是被淘汰語法，因此要改 slice\n          return (\n            driveLetter +\n            name.slice(driveLetter.length).replace(INVALID_CHAR_REGEX, \"\")\n          );\n        },\n      },\n    },\n  },\n});\n","js","",[20,99,100,120,133,146,153,160,207,233,238,255,270,276,282,322,328,336,342,348,354,360,374,395,428,434,443,452,486,492,498,504,509,516],{"__ignoreMap":97},[101,102,105,109,113,116],"span",{"class":103,"line":1