[{"data":1,"prerenderedAt":135},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20210930\u002F3267246146\u002F":3,"page:\u002Fother\u002F20210930\u002F3267246146\u002F":4,"alt:\u002Fother\u002F20210930\u002F3267246146\u002F":3,"prev-next:\u002Fother\u002F20210930\u002F3267246146\u002F":110,"related:\u002Fother\u002F20210930\u002F3267246146\u002F":119},"\u002Fen\u002Fmisc\u002F2021\u002F09\u002F30\u002Fchange-chrome-devtools-language\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":93,"date":94,"description":18,"extension":95,"lang":96,"meta":97,"navigation":98,"path":99,"readingMinutes":100,"seo":101,"standalone":102,"stem":103,"tags":104,"tldr":107,"updated":107,"url":108,"__hash__":109},"content\u002F雜談\u002F將-Chrome-網頁開發者工具-Chrome-DevTool-中文化.md","將 Chrome 網頁開發者工具 (Chrome DevTool) 中文化","3267246146",{"type":9,"value":10,"toc":86},"minimark",[11,15,19,23,26,33,36,39,45,48,54,57,63,66,72,76,79],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"不喜歡英文嗎？不用怕，這一篇教你怎麼把 Chrome 的網頁開發者工具 (Chrome DevTool) 中文化。",[12,20,22],{"id":21},"chrome-網頁開發者工具-chrome-devtool","Chrome 網頁開發者工具 (Chrome DevTool)",[16,24,25],{},"Chrome 的網頁開發者工具一直以來都是以英文版為主",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"Chrome DevTool","https:\u002F\u002Fi.imgur.com\u002FR7HTEhq.png",[16,34,35],{},"後來大概在 94.x 左右就支援了中文化，所以這邊也紀錄一下如何中文化 Chrome DevTool 吧！",[16,37,38],{},"打開開發者工具後點一下「齒輪」進入設定頁面",[16,40,41],{},[29,42],{"alt":43,"src":44},"Setting","https:\u002F\u002Fi.imgur.com\u002FtG2O0Vq.png",[16,46,47],{},"接下來進入「Preferences」然後找到「Language」 將它改成「Chinese(Taiwan) - 中文(台灣)」",[16,49,50],{},[29,51],{"alt":52,"src":53},"Chinese(Taiwan) - 中文(台灣)","https:\u002F\u002Fi.imgur.com\u002FGFWeNnO.png",[16,55,56],{},"接下來關掉該視窗，回到原本的開發者工具，點一下上方的「Reload DevTools」",[16,58,59],{},[29,60],{"alt":61,"src":62},"Reload DevTools","https:\u002F\u002Fi.imgur.com\u002FUBVtvWu.png",[16,64,65],{},"最後就可以看到期待許久的 Chrome 網頁開發者工具中文化啦(撒花)",[16,67,68],{},[29,69],{"alt":70,"src":71},"Chrome 網頁開發者工具中文化","https:\u002F\u002Fi.imgur.com\u002F2LdisRO.png",[12,73,75],{"id":74},"firefox-網頁開發者工具-firefox-devtool","Firefox 網頁開發者工具 (Firefox DevTool)",[16,77,78],{},"至於 Firefox 呢？Firefox 本身就是中文化了，所以一直都沒有差異，可以詳見我之前介紹的這一篇唷~",[16,80,81],{},[82,83,85],"a",{"href":84},"\u002Fother\u002F20210722\u002F4002613152\u002F","使用 Firefox 瀏覽器當作前端開發的特色與優勢",{"title":87,"searchDepth":88,"depth":88,"links":89},"",2,[90,91,92],{"id":14,"depth":88,"text":14},{"id":21,"depth":88,"text":22},{"id":74,"depth":88,"text":75},"雜談","2021-09-30 23:56:35","md","zh-Hant",{},true,"\u002Fchrome-chrome-devtool","1",{"title":6,"description":18},false,"雜談\u002F將-Chrome-網頁開發者工具-Chrome-DevTool-中文化",[105,31,106],"Chrome","中文化",null,"\u002Fother\u002F20210930\u002F3267246146\u002F","28mrW_-14gG_uuNvUb-rlhBXRWO6PIXEjUuK8pXqcyc",{"newer":111,"older":115},{"url":112,"title":113,"date":114},"\u002Fpython\u002F20211001\u002F4124098345\u002F","從 JavaScript 角度學 Python(30) - 爬蟲","2021-10-01 00:00:10",{"url":116,"title":117,"date":118},"\u002Fpython\u002F20210930\u002F691102834\u002F","從 JavaScript 角度學 Python(29) - BeautifulSoup","2021-09-30 00:00:10",[120,125,130],{"url":121,"title":122,"date":123,"readingMinutes":124},"\u002Fother\u002F20260710\u002F2193411838\u002F","關於我做了百日挑戰「增肌減脂」這個有趣的實驗","2026-07-10 09:53:56","16",{"url":126,"title":127,"date":128,"readingMinutes":129},"\u002Fother\u002F20260623\u002F2826413095\u002F","Mac 系統監控工具就推薦用 Stats！一款免費又開源，還能看 CPU、GPU、溫度、網速的軟體","2026-06-23 10:00:00","4",{"url":131,"title":132,"date":133,"readingMinutes":134},"\u002Fother\u002F20260526\u002F2846301957\u002F","寫部落格能月入幾萬美金嗎？聊聊 Google AdSense 真實收益與計算方式","2026-05-26 21:00:00","5",1784020395676]