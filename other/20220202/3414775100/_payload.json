[{"data":1,"prerenderedAt":380},["ShallowReactive",2],{"header-locale:\u002Fother\u002F20220202\u002F3414775100\u002F":3,"page:\u002Fother\u002F20220202\u002F3414775100\u002F":4,"alt:\u002Fother\u002F20220202\u002F3414775100\u002F":3,"prev-next:\u002Fother\u002F20220202\u002F3414775100\u002F":355,"related:\u002Fother\u002F20220202\u002F3414775100\u002F":364},"\u002Fen\u002Fmisc\u002F2022\u002F02\u002F02\u002Fudemy-translate-subtitles-in-real-time-with-js\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":338,"date":339,"description":18,"extension":340,"lang":341,"meta":342,"navigation":253,"path":343,"readingMinutes":344,"seo":345,"standalone":346,"stem":347,"tags":348,"tldr":352,"updated":352,"url":353,"__hash__":354},"content\u002F雜談\u002FUdemy-小技巧-英文字幕轉中文-同步翻譯.md","Udemy 小技巧 - 英文字幕轉中文(同步翻譯)","3414775100",{"type":9,"value":10,"toc":330},"minimark",[11,15,19,23,34,37,44,47,53,56,62,65,71,74,80,83,89,98,101,107,110,277,283,286,292,297,300,303,306,313,316,326],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"Udemy 可以說是很多人上課的首選，上面相當多便宜又大碗的課程，但是大多都是英語教學，因此對於英文不好的人是一個困擾，雖然可以使用翻譯工具將聽打的部分轉成中文，但播放時底下卻又是英文，因此寫一篇紀錄一下如何影音底下字幕也同步翻譯成中文。",[12,20,22],{"id":21},"udemy-字幕自動翻譯成中文","Udemy 字幕自動翻譯成中文",[16,24,25,26,33],{},"首先是關於 Udemy 課程的翻譯部分，只要你安裝任何一套翻譯工具都可以，舉例來講我在 Firefox 上使用的是 ",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Faddons.mozilla.org\u002Fzh-TW\u002Ffirefox\u002Faddon\u002Ftraduzir-paginas-web\u002F",[31],"nofollow","網頁翻譯器"," 這個擴充套件。",[16,35,36],{},"接下來就是進入 Udemy 選擇你要翻譯的課程，切記請選擇有字幕的課程",[16,38,39],{},[40,41],"img",{"alt":42,"src":43},"選擇字幕","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.46.19.png",[16,45,46],{},"接下來打開「字幕聽打」",[16,48,49],{},[40,50],{"alt":51,"src":52},"字幕聽打","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.47.55.png",[16,54,55],{},"此時旁邊就會跳出字幕聽打的介面",[16,57,58],{},[40,59],{"alt":60,"src":61},"字幕聽打介面","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.48.33.png",[16,63,64],{},"這時候請使用你的擴充套件，翻譯一下字幕聽打",[16,66,67],{},[40,68],{"alt":69,"src":70},"翻譯","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.49.30.png",[16,72,73],{},"這時候字幕聽打就會轉成中文的形式，就連影音底下字幕都會變成中文",[16,75,76],{},[40,77],{"alt":78,"src":79},"中文","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.50.38.png",[16,81,82],{},"但是只要你一播放，你會發現底下影音文字又變成英文了...",[16,84,85],{},[40,86],{"alt":87,"src":88},"變成英文","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.52.40.png",[16,90,91,92,97],{},"雖然可以看右側翻譯的字幕來解決，但是相當麻煩畢竟還是習慣看下方，因此我上網找到一篇",[27,93,96],{"href":94,"rel":95},"https:\u002F\u002Falexmasyukov.medium.com\u002Fhow-translated-subtitles-on-udemy-any-course-with-javascript-c4acaa37d47",[31],"文章","可以解決這個問題(但後方我有稍微重寫一下，因為一直噴錯很礙眼)",[16,99,100],{},"首先請點一下字幕，進入字幕設定並顯示在下方(這樣設置會比較穩定)",[16,102,103],{},[40,104],{"alt":105,"src":106},"顯示在下方","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202022-02-02%2022.56.23.png",[16,108,109],{},"接下來按下 F12 或者檢測進入開發者工具中，然後切換到 console (控制台)，並貼入下方程式碼",[111,112,117],"pre",{"className":113,"code":114,"language":115,"meta":116,"style":116},"language-js shiki shiki-themes github-dark-high-contrast","function autoTranslate() {\n  \n  const subtitle = document.querySelector('.well--container--2edq4 span');\n  const translate = document.querySelector('p[data-purpose=\"transcript-cue-active\"] span');\n  \n  if(translate && subtitle && subtitle.innerText !== translate.innerText) {\n    subtitle.innerText = translate.innerText;\n  }\n}\n\nconst s = setInterval(autoTranslate, 200);\n","js","",[118,119,120,137,143,172,193,198,224,236,242,248,255],"code",{"__ignoreMap":116},[121,122,125,129,133],"span",{"class":123,"line":124},"line",1,[121,126,12