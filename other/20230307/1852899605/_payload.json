130,441,443],{"class":132,"line":442},56,[130,444,251],{"class":136},[130,446,448],{"class":132,"line":447},57,[130,449,168],{"emptyLinePlaceholder":167},[130,451,453],{"class":132,"line":452},58,[130,454,455],{"class":136},"# 名稱：刪除一個 Todo\n",[130,457,459],{"class":132,"line":458},59,[130,460,366],{"class":136},[130,462,464],{"class":132,"line":463},60,[130,465,466],{"class":136},"## API Methods：DELETE\n",[130,468,470],{"class":132,"line":469},61,[130,471,155],{"class":136},[130,473,475],{"class":132,"line":474},62,[130,476,161],{"class":136},[130,478,480],{"class":132,"line":479},63,[130,481,168],{"emptyLinePlaceholder":167},[130,483,485],{"class":132,"line":484},64,[130,486,290],{"class":174},[130,488,490],{"class":132,"line":489},65,[130,491,492],{"class":174},"  \"message\": \"刪除成功\"\n",[130,494,496],{"class":132,"line":495},66,[130,497,308],{"class":174},[12,499,500],{},"接下來我們就準備來操作 Mockoon 吧！",[502,503,505],"h3",{"id":504},"建立-mockoon-環境","建立 Mockoon 環境",[12,507,508],{},"接著我們打開 Mockoon，並且點擊「Create a new environment」",[12,510,511],{},[15,512],{"alt":513,"src":514},"Create a new environment","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2016.33.49.png",[12,516,517],{},"並且輸入環境名稱，例如：Todolist-example，選擇要放置的路徑，並且按下「Create」",[12,519,520],{},[15,521],{"alt":522,"src":523},"Todolist-example","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2016.34.11.png",[12,525,526],{},"Mockoon 側邊欄應該就會看到剛剛新增的環境",[12,528,529],{},[15,530],{"alt":522,"src":531},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2016.35.48.png",[12,533,534,535,538],{},"這邊稍微提醒一下，底下應該有看到一段「",[127,536,537],{},"localhost:3001","」，這個就是我們 Mock 出來的 API Url 位置，如果不喜歡也沒關係，這是可以自己修改的，這邊就先暫定這樣。",[540,541,542],"h4",{"id":542},"匯出環境",[12,544,545],{},"後續如果你想把你自己建立好的 Mock 環境給別人，你是可以透過右鍵「Show in folder」來找到檔案的，因為建立環境時，其實它是建立一個 JSON 檔案，只需要將 JSON 提供給他人即可",[12,547,548],{},[15,549],{"alt":550,"src":551},"匯出","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F202303071751.jpg",[540,553,554],{"id":554},"匯入環境",[12,556,557],{},"拿到這一份 JSON 的人，只需要點一下上方資料夾按鈕「Open an environment」，然後把 JSON 丟進去就可以匯入囉！",[12,559,560],{},[15,561],{"alt":562,"src":563},"匯入","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.52.01.png",[502,565,567],{"id":566},"建立-mock-api","建立 Mock API",[12,569,570],{},"接下來點一下側邊欄的「TodoList-example」，這時候你應該會看到下圖的畫面",[12,572,573],{},[15,574],{"alt":575,"src":576},"TodoList-example","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2016.42.38.png",[12,578,579],{},"接下來點一下上方箭頭，你可以建立三種東西",[581,582,583,587,590],"ul",{},[584,585,586],"li",{},"CRUD Route",[584,588,589],{},"HTTP Route",[584,591,592],{},"Folder",[12,594,595],{},"第一個是 CRUD Route，這個是可以快速建立 CRUD 的 API，第二個是 HTTP Route，這個是可以自己自訂 API 的，第三個是 Folder，這個是可以幫你分類的，例如：我們可以把 TodoList 的 API 都放在一個資料夾裡面，這樣比較好管理。",[12,597,598],{},"而這邊我們主要是挑選 HTTP Route，所以就選擇 HTTP Route，接著右側就要讓你來填寫 API 的資訊了",[12,600,601],{},[15,602],{"alt":603,"src":604},"API 資訊","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2016.51.26.png",[12,606,607],{},"這邊我也提供欄位翻譯，並順便填寫相關欄位",[12,609,610],{},[15,611],{"alt":612,"src":613},"翻譯","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F202303071700.jpg",[12,615,616],{},"依照 API 文件填寫的話，你應該會看到下圖的畫面",[12,618,619],{},[15,620],{"alt":603,"src":621},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.04.23.png",[12,623,624],{},"這樣子你就建立完一個 API 了，其他的 API 就讓你自己試著去建立看看，如果都建立完畢的話，你應該會在 Route 列表看到這幾隻 API",[12,626,627],{},[15,628],{"alt":629,"src":630},"Route List","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.18.42.png",[540,632,634],{"id":633},"多個-response","多個 Response",[12,636,637],{},"Mockoon 也可以讓你建立多個 Response，這樣子你就可以測試不同的狀況了，例如：你可以建立一個 200 的 Response，然後再建立一個 500 的 Response，這樣子你就可以測試不同的狀況，只需要點一下這邊就可以建立了",[12,639,640],{},[15,641],{"alt":634,"src":642},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.54.32.png",[502,644,646],{"id":645},"啟動-mock-api","啟動 Mock API",[12,648,649],{},"接下來就是準備啟動 Mock API 了，啟動按鈕位置在這邊",[12,651,652],{},[15,653],{"alt":654,"src":655},"啟動按鈕","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.25.26.png",[12,657,658],{},"但啟動之前我們要來做一些修改，因為 Mockoon 本身是模擬後端的概念，所以我們要去改一些設定，否則你的前端在串接時會發生一些問題",[540,660,662],{"id":661},"調整-port","調整 Port",[12,664,665],{},"首先先找到「TodoList-example」，然後點一下右側的「Setting」按鈕",[12,667,668],{},[15,669],{"alt":670,"src":671},"Setting","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.32.11.png",[12,673,674],{},"因為考慮到你可能不喜歡目前的 3001 Port，所以我們要先把 Port 改成 3000，基本上改完啟動就可以立刻吃到這個 Port 了",[12,676,677],{},[15,678],{"alt":679,"src":680},"Port","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.34.57.png",[540,682,684],{"id":683},"設置-cors","設置 CORS",[12,686,687],{},"接下來點一下上方 Headers 欄位，然後點一下旁邊的「Add CORS header」按鈕",[12,689,690],{},[15,691],{"alt":692,"src":693},"CORS","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.36.46.png",[12,695,696],{},"你點下去後 Mockoon 就會自動幫你帶入 CORS 相關的設定",[12,698,699],{},[15,700],{"alt":692,"src":701},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002Fmockoon\u002F%E6%88%AA%E5%9C%96%202023-03-07%2017.37.59.png",[12,703,704],{},"接下來你就可以安心啟動 Mockoon，並可以在本地嘗試串接 API 了",[540,706,708],{"id":707},"串接-api-與查看-log","串接 API 與查看 Log",[12,710,711],{},"底下我也提供 Fetch 的範例程式碼，你可以直接複製貼上到你的本地專案或是打開瀏覽器，貼在 Console 裡面，看看是否有正確的回傳資料",[120,713,717],{"className":714,"code":715,"language":716,"meta":125,"style":125},"language-js shiki shiki-themes github-dark-high-contrast","const getTodoList = async () => {\n  const response = await fetch('http:\u002F\u002Flocalhost:3000\u002Fapi\u002Fv1\u002Ftodos', {\n    method: 'GET',\n  });\n  const data = await response.json();\n  return data;\n};\n\ngetTodoList().then((data) => {\n  console.log(data);\n});\n","js",[127,718,719,744,771,782,787,807,815,820,824,849,860],{"__ignoreMap":125},[130,720,721,725,729,732,735,738,741],{"class":132,"line":133},[130,722,724],{"class":723},"sWyjQ","const",[130,726,728],{"class":727},"sj_SG"," getTodoList",[130,730,731],{"class":723}," =",[130,733,734],{"class":723}," async",[130,736,737],{"class":174}," () ",[130,739,740],{"class":723},"=>",[130,742,743],{"class":174}," {\n",[130,745,746,749,753,755,758,761,764,768],{"class":132,"line":140},[130,747,748],{"class":723},"  const",[130,750,752],{"class":751},"sCcAr"," response",[130,754,731],{"class":723},[130,756,757],{"class":723}," await",[130,759,760],{"class":727}," fetch",[130,762,763],{"class":174},"(",[130,765,767],{"class":766},"sTRMh","'http:\u002F\u002Flocalhost:3000\u002Fapi\u002Fv1\u002Ftodos'",[130,769,770],{"class":174},", {\n",[130,772,773,776,779],{"class":132,"line":146},[130,774,775],{"class":174},"    method: ",[130,777,778],{"class":766},"'GET'",[130,780,781],{"class":174},",\n",[130,783,784],{"class":132,"line":152},[130,785,786],{"class":174},"  });\n",[130,788,789,791,794,796,798,801,804],{"class":132,"line":158},[130,790,748],{"class":723},[130,792,793],{"class":751}," data",[130,795,731],{"class":723},[130,797,757],{"class":723},[130,799,800],{"class":174}," response.",[130,802,803],{"class":727},"json",[130,805,806],{"class":174},"();\n",[130,808,809,812],{"class":132,"line":164},[130,810,811],