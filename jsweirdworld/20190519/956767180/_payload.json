37,303,44],{"class":43},[37,305,306],{"class":47}," c ",[37,308,51],{"class":43},[37,310,311],{"class":47}," { greeting: ",[37,313,315],{"class":314},"sTRMh","'hi'",[37,317,318],{"class":47}," };\n",[37,320,321,323],{"class":39,"line":61},[37,322,44],{"class":43},[37,324,325],{"class":47}," d;\n",[37,327,328,331,333],{"class":39,"line":72},[37,329,330],{"class":47},"d ",[37,332,51],{"class":43},[37,334,335],{"class":47}," c;\n",[16,337,338,339,342,343,345,346,349],{},"當執行程式碼時會發生什麼事情?",[34,340,341],{},"d","會知道它後面帶入的是一個物件 (Object)，所以並不會建立新的記憶體位址，而是直接讓 ",[34,344,341],{}," 指向與 ",[34,347,348],{},"c"," 相同的記憶體位址，雖然輸出時可以看到相同的東西，但是在記憶體指向是相同的，所以如果這樣做 ↓",[27,351,353],{"className":29,"code":352,"language":31,"meta":32,"style":32},"var c = { greeting: 'hi' };\nvar d;\nd = c;\nc.greeting = 'hello';\n\nconsole.log(c.greeting);\nconsole.log(d.greeting);\n",[34,354,355,369,375,383,395,399,408],{"__ignoreMap":32},[37,356,357,359,361,363,365,367],{"class":39,"line":40},[37,358,44],{"class":43},[37,360,306],{"class":47},[37,362,51],{"class":43},[37,364,311],{"class":47},[37,366,315],{"class":314},[37,368,318],{"class":47},[37,370,371,373],{"class":39,"line":61},[37,372,44],{"class":43},[37,374,325],{"class":47},[37,376,377,379,381],{"class":39,"line":72},[37,378,330],{"class":47},[37,380,51],{"class":43},[37,382,335],{"class":47},[37,384,385,388,390,393],{"class":39,"line":85},[37,386,387],{"class":47},"c.greeting ",[37,389,51],{"class":43},[37,391,392],{"class":314}," 'hello'",[37,394,58],{"class":47},[37,396,397],{"class":39,"line":244},[37,398,178],{"emptyLinePlaceholder":177},[37,400,401,403,405],{"class":39,"line":257},[37,402,75],{"class":47},[37,404,79],{"class":78},[37,406,407],{"class":47},"(c.greeting);\n",[37,409,410,412,414],{"class":39,"line":266},[37,411,75],{"class":47},[37,413,79],{"class":78},[37,415,416],{"class":47},"(d.greeting);\n",[16,418,419,420,422],{},"我們可以看到 ",[34,421,341],{}," 也跟著變了。",[16,424,425],{},[109,426],{"alt":133,"src":427},"https:\u002F\u002Fi.imgur.com\u002FQicw0Wn.png",[16,429,430,431,434],{},"這就是所謂的傳參考 (by reference，而 ",[34,432,433],{},"c.greeting = 'hello';"," 這過程稱之為 mutate。",[16,436,437],{},[109,438],{"alt":133,"src":439},"https:\u002F\u002Fi.imgur.com\u002FHpkw6lw.png",[16,441,442],{},"所以當等號運算子知道你要改變某個值的時候，它就會去改變 (mutate)。",[16,444,445,446,448],{},"mutate 就是改變某個東西的意思，當我們說 I mutate my object，就是代表著我要改變它 (Object)，所以我們可以知道一件事情，不論我們在哪一行做修改，都會導致 ",[34,447,341],{}," 被改變，原因是它們都是指向同一個記憶體。",[280,450,452],{"height":282,"style":283,"scrolling":284,"title":133,"src":451,"frameBorder":284,"allowTransparency":286,"allowFullScreen":286},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FBeVaJX\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FBeVaJX\u002F'>by reference\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,454,455],{"id":455},"例外狀況",[16,457,458],{},"這邊還需要知道一件事情，等號運算子可以設定一個新記憶體空間，當若我們是使用這種方式去修改的話 ↓",[27,460,462],{"className":29,"code":461,"language":31,"meta":32,"style":32},"var c = { greeting: 'hi' };\nvar d;\nd = c;\nc = { greeting: 'hello' };\n\nconsole.log(c);\nconsole.log(d);\n",[34,463,464,478,484,492,506,510,519],{"__ignoreMap":32},[37,465,466,468,470,472,474,476],{"class":39,"line":40},[37,467,44],{"class":43},[37,469,306],{"class":47},[37,471,51],{"class":43},[37,473,311],{"class":47},[37,475,315],{"class":314},[37,477,318],{"class":47},[37,479,480,482],{"class":39,"line":61},[37,481,44],{"class":43},[37,483,325],{"class":47},[37,485,486,488,490],{"class":39,"line":72},[37,487,330],{"class":47},[37,489,51],{"class":43},[37,491,335],{"class":47},[37,493,494,497,499,501,504],{"class":39,"line":85},[37,495,496],{"class":47},"c ",[37,498,51],{"class":43},[37,500,311],{"class":47},[37,502,503],{"class":314},"'hello'",[37,505,318],{"class":47},[37,507,508],{"class":39,"line":24