lass":47},"console.",[37,77,79],{"class":78},"sj_SG","log",[37,81,82],{"class":47},"(a);\n",[37,84,86,88,90],{"class":39,"line":85},4,[37,87,75],{"class":47},[37,89,79],{"class":78},[37,91,92],{"class":47},"(b);\n",[16,94,95,98,99,102,103,105],{},[34,96,97],{},"b"," 會去尋找 ",[34,100,101],{},"a"," 的記憶體位址，然後複製填上相同的值到 ",[34,104,97],{}," 並得到新的記憶體位址，而這個過程就是傳值 (by value)",[16,107,108],{},[109,110],"img",{"alt":111,"src":112},"by value","https:\u002F\u002Fi.imgur.com\u002FzcNW7gc.png",[12,114,116],{"id":115},"傳參考-by-reference","傳參考 (by reference)",[16,118,119,120,122,123,125,126,128],{},"這邊要講的這個東西就比較常見了，如果在 JavaScript 中有一個物件，當設定變數為一個物件一樣可以取的一個記憶體位址，但當 ",[34,121,97],{}," 等於 ",[34,124,101],{}," 的意思其實是我們試著讓這兩個東西一樣，所以 ",[34,127,97],{}," 並不會得到新的記憶體位址，而這就是傳參考 (by reference)。",[16,130,131],{},[109,132],{"alt":133,"src":134},"by reference","https:\u002F\u002Fi.imgur.com\u002FB09t5JT.png",[136,137,138],"blockquote",{},[16,139,140],{},"所有物件都是傳參考 (by reference)特性。",[12,142,144],{"id":143},"範例傳值-by-value","範例傳值 (by value)",[16,146,147],{},"這邊先來看看傳值 (by value) 的範例 ↓",[27,149,151],{"className":29,"code":150,"language":31,"meta":32,"style":32},"var a = 3;\nvar b;\n\nb = a;\n",[34,152,153,166,173,179],{"__ignoreMap":32},[37,154,155,157,159,161,164],{"class":39,"line":40},[37,156,44],{"class":43},[37,158,48],{"class":47},[37,160,51],{"class":43},[37,162,163],{"class":54}," 3",[37,165,58],{"class":47},[37,167,168,170],{"class":39,"line":61},[37,169,44],{"class":43},[37,171,172],{"class":47}," b;\n",[37,174,175],{"class":39,"line":72},[37,176,178],{"emptyLinePlaceholder":177},true,"\n",[37,180,181,183,185],{"class":39,"line":85},[37,182,64],{"class":47},[37,184,51],{"class":43},[37,186,69],{"class":47},[16,188,189,190,193,194,197,198,200,201,203,204,206],{},"這邊要記得一個重點，只要不是物件，那就是在",[191,192,22],"strong",{}," 因為 ",[34,195,196],{},"3"," 是一個純值一個數值，所以 ",[34,199,97],{}," 會 copy ",[34,202,101],{}," 的值並且建立一個新記憶體位址，所以若我們這樣做並不會影響到 ",[34,205,97],{}," ↓",[27,208,210],{"className":29,"code":209,"language":