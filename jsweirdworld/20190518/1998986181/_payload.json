[{"data":1,"prerenderedAt":853},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190518\u002F1998986181\u002F":3,"page:\u002Fjsweirdworld\u002F20190518\u002F1998986181\u002F":4,"alt:\u002Fjsweirdworld\u002F20190518\u002F1998986181\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190518\u002F1998986181\u002F":829,"related:\u002Fjsweirdworld\u002F20190518\u002F1998986181\u002F":838},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F18\u002Fjs-weird-world-27-function-statements-vs-expressions\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":814,"date":815,"description":18,"extension":816,"lang":817,"meta":818,"navigation":303,"path":819,"readingMinutes":105,"seo":820,"standalone":821,"stem":822,"tags":823,"tldr":826,"updated":826,"url":827,"__hash__":828},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-27-函數陳述句與函數表示式.md","[JS奇怪的世界]No.27 函數陳述句與函數表示式","1998986181",{"type":9,"value":10,"toc":806},"minimark",[11,15,19,23,30,40,43,66,77,80,100,117,123,127,130,177,183,221,224,234,237,240,274,281,287,331,334,337,373,376,379,382,394,397,400,487,493,499,506,509,520,563,566,571,582,585,631,646,655,660,663,727,733,791,794,802],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"上一章節我們已經明白函數就是物件，接下來課程將利用這個觀念讓我們做一些有趣又強大的事情，但是開始前我們必須瞭解函數陳述句與函數表示式的差異。",[12,20,22],{"id":21},"表示式-expressions","表示式 (Expressions)",[16,24,25],{},[26,27],"img",{"alt":28,"src":29},"Expressions","https:\u002F\u002Fi.imgur.com\u002F9VZEr7V.png",[16,31,32,39],{},[33,34,22,35,38],"strong",{},[33,36,37],{},"的意思是說，輸入之後能夠直接回傳值的一串程式，簡單來講就是","只要我們輸入那一大串程式碼之後能夠直接回傳值，那它就是一個表示式","。",[16,41,42],{},"所以我們來看一下範例程式碼。",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-js shiki shiki-themes github-dark-high-contrast","var a\n","js","",[51,52,53],"code",{"__ignoreMap":49},[54,55,58,62],"span",{"class":56,"line":57},"line",1,[54,59,61],{"class":60},"sWyjQ","var",[54,63,65],{"class":64},"sMAXC"," a\n",[16,67,68,69,72,73,76],{},"就這樣，接下來我們就可以開啟瀏覽器在 F12 開發者工具中輸入 ",[51,70,71],{},"console.log(a)","，可以看到 ",[51,74,75],{},"a"," 目前儲存在記憶體中。",[16,78,79],{},"那表示式到底是什麼?表示式會回傳一個值，所以當我們這樣打",[44,81,83],{"className":46,"code":82,"language":48,"meta":49,"style":49},"a = 3;\n",[51,84,85],{"__ignoreMap":49},[54,86,87,90,93,97],{"class":56,"line":57},[54,88,89],{"class":64},"a ",[54,91,92],{"class":60},"=",[54,94,96],{"class":95},"sCcAr"," 3",[54,98,99],{"class":64},";\n",[16,101,102,103,106,107,109,110,113,114,39],{},"記得中間這是一個等號運算子，它會將 ",[51,104,105],{},"3"," 賦予至 ",[51,108,75],{},"，然後再回傳一個值，所以我們就會出現一個值，那就是 3，而這行為就是表示式，所以其實前面 ",[51,111,112],{},"var a"," 是有回傳值的，那個值就是 ",[51,115,116],{},"undefined",[16,118,119],{},[26,120],{"alt":121,"src":122},"等號運算子","https:\u002F\u002Fi.imgur.com\u002FxVhuw2H.png",[12,124,126],{"id":125},"陳述句-statements","陳述句 (Statements)",[16,128,129],{},"那陳述句呢?讓我們看看這個範例程式 ↓",[44,131,133],{"className":46,"code":132,"language":48,"meta":49,"style":49},"if (a === 3) {\n console.log('Hello');\n}\n",[51,134,135,151,171],{"__ignoreMap":49},[54,136,137,140,143,146,148],{"class":56,"line":57},[54,138,139],{"class":60},"if",[54,141,142],{"class":64}," (a ",[54,144,145],{"class":60},"===",[54,147,96],{"class":95},[54,149,150],{"class":64},") {\n",[54,152,154,157,161,164,168],{"class":56,"line":153},2,[54,155,156],{"class":64}," console.",[54,158,160],{"class":159},"sj_SG","log",[54,162,163],{"class":64},"(",[54,165,167],{"class":166},"sTRMh","'Hello'",[54,169,170],{"class":64},");\n",[54,172,174],{"class":56,"line":173},3,[54,175,176],{"class":64},"}\n",[16,178,179,182],{},[51,180,181],{},"a === 3"," 其實也是一個表示式，因為它也可以直接回傳值(當條件為 true 或 false)，但 if 這個指令就不一樣了，它是一個陳述句，它不會直接回傳一個值，所以我們也不能把它設置為一個變數。",[44,184,186],{"className":46,"code":185,"language":48,"meta":49,"style":49},"var b = if (a === 3) {\n  console.log('Hello');\n}\n",[51,187,188,208,217],{"__ignoreMap":49},[54,189,190,192,195,197,200,202,204,206],{"class":56,"line":57},[54,191,61],{"class":60},[54,193,194],{"class":64}," b ",[54,196,92],{"class":60},[54,198,199],{"class":159}," if",[54,201,142],{"class":64},[54,203,145],{"class":60},[54,205,96],{"class":95},[54,207,150],{"class":64},[54,209,210,213,215],{"class":56,"line":153},[54,211,212],{"class":64},"  console.log(",[54,214,167],{"class":166},[54,216,170],{"class":64},[54,218,219],{"class":56,"line":173},[54,220,176],{"class":64},[16,222,223],{},"這邊我們可以瞭解到一件觀念",[225,226,227,231],"ul",{},[228,229,230],"li",{},"函數表達式 會直接回傳值。",[228,232,233],{},"函數陳述句 不會回傳值，而是做其他事情。",[12,235,236],{"id":236},"函數陳述句",[16,238,239],{},"在 JavaScript 中我們都知道函數是一個物件，而函數裡面也有函數陳述句與函數表示式，這兩個東西非常的強大，首先我們先來做一個函數陳述句 ↓",[44,241,243],{"className":46,"code":242,"language":48,"meta":49,"style":49},"function greet() {\n console.log('hi');\n};\n",[51,244,245,256,269],{"__ignoreMap":49},[54,246,247,250,253],{"class":56,"line":57},[54,248,249],{"class":60},"function",[54,251,252],{"class":159}," greet",[54,254,255],{"class":64},"() {\n",[54,257,258,260,262,264,267],{"class":56,"line":153},[54,259,156],{"class":64},[54,261,160],{"class":159},[54,263,163],{"class":64},[54,265,266],{"class":166},"'hi'",[54,268,170],{"class":64},[54,270,271],{"class":56,"line":173},[54,272,273],{"class":64},"};\n",[16,275,276,277,280],{},"當它被執行時並不會回傳任何值(此處執行並不是 ",[51,278,279],{},"greet()","，而是在講全域環境建立)，函數陳述句的特色就是通過 hoisting 特性，先儲存進記憶體中，直到你執行這個函數函數。",[16,282,283,284,39],{},"在前面章節有講過變數及函數有提升特性，所以可以在函數陳述句之前呼叫 ",[51,285,286],{},"greet",[44,288,290],{"className":46,"code":289,"language":48,"meta":49,"style":49},"greet();\n\nfunction greet() {\n console.log('hi');\n};\n",[51,291,292,299,305,313,326],{"__ignoreMap":49},[54,293,294,296],{"class":56,"line":57},[54,295,286],{"class":159},[54,297,298],{"class":64},"();\n",[54,300,301],{"class":56,"line":153},[54,302,304],{"emptyLinePlaceholder":303},true,"\n",[54,306,307,309,311],{"class":56,"line":173},[54,308,249],{"class":60},[54,310,252],{"class":159},[54,312,255],{"class":64},[54,314,316,318,320,322,324],{"class":56,"line":315},4,[54,317,156],{"class":64},[54,319,160],{"class":159},[54,321,163],{"class":64},[54,323,266],{"class":166},[54,325,170],{"class":64},[54,327,329],{"class":56,"line":328},5,[54,330,273],{"class":64},[12,332,333],{"id":333},"函數表示式",[16,335,336],{},"接下來就是函數表示式。",[44,338,340],{"className":46,"code":339,"language":48,"meta":49,"style":49},"var anonymousGreet = function() {\n console.log('hi');\n};\n",[51,341,342,357,369],{"__ignoreMap":49},[54,343,344,346,349,352,355],{"class":56,"line":57},[54,345,61],{"class":60},[54,347,348],{"class":159}," anonymousGreet",[54,350,351],{"class":60}," =",[54,353,354],{"class":60}," function",[54,356,255],{"class":64},[54,358,359,361,363,365,367],{"class":56,"line":153},[54,360,156],{"class":64},[54,362,160],{"class":159},[54,364,163],{"class":64},[54,366,266],{"class":166},[54,368,170],{"class":64},[54,370,371],{"class":56,"line":173},[54,372,273],{"class":64},[16,374,375],{},"看到這邊要注意一個觀念「函數就是物件」(附帶一提這也是人家講的匿名函數。)",[16,377,378],{},"(匿名函數就是沒有名稱的函數。)",[16,380,381],{},"那該如何觸發這個函數表示式?",[44,383,385],{"className":46,"code":384,"language":48,"meta":49,"style":49},"anonymousGreet();\n",[51,386,387],{"__ignoreMap":49},[54,388,389,392],{"class":56,"line":57},[54,390,391],{"class":159},"anonymousGreet",[54,393,298],{"class":64},[16,395,396],{},"這就是函數表達式，感覺與函數陳述句很像吧。",[16,398,399],{},"讓我們整合一下兩個程式碼 ↓",[44,401,403],{"className":46,"code":402,"language":48,"meta":49,"style":49},"greet();\n\nfunction greet() {\n console.log('hi');\n};\n\nvar anonymousGreet = function() {\n console.log('hi');\n};\n\nanonymousGreet();\n",[51,404,405,411,415,423,435,439,444,457,470,475,480],{"__ignoreMap":49},[54,406,407,409],{"class":56,"line":57},[54,408,286],{"class":159},[54,410,298],{"class":64},[54,412,413],{"class":56,"line":153},[54,414,304],{"emptyLinePlaceholder":303},[54,416,417,419,421],{"class":56,"line":173},[54,418,249],{"class":60},[54,420,252],{"class":159},[54,422,255],{"class":64},[54,424,425,427,429,431,433],{"class":56,"line":315},[54,426,156],{"class":64},[54,428,160],{"class":159},[54,430,163],{"class":64},[54,432,266],{"class":166},[54,434,170],{"class":64},[54,436,437],{"class":56,"line":328},[54,438,273],{"class":64},[54,440,442],{"class":56,"line":441},6,[54,443,304],{"emptyLinePlaceholder":303},[54,445,447,449,451,453,455],{"class":56,"line":446},7,[54,448,61],{"class":60},[54,450,348],{"class":159},[54,452,351],{"class":60},[54,454,354],{"class":60},[54,456,255],{"class":64},[54,458,460,462,464,466,468],{"class":56,"line":459},8,[54,461,156],{"class":64},[54,463,160],{"class":159},[54,465,163],{"class":64},[54,467,266],{"class":166},[54,469,170],{"class":64},[54,471,473],{"class":56,"line":472},9,[54,474,273],{"class":64},[54,476,478],{"class":56,"line":477},10,[54,479,304],{"emptyLinePlaceholder":303},[54,481,483,485],{"class":56,"line":482},11,[54,484,391],{"class":159},[54,486,298],{"class":64},[16,488,489,490,492],{},"相信你一定會發現這兩者差異並不大，但我們存在 ",[51,491,391],{}," 中的匿名函數，只要加上括號就可以觸發函數。",[494,495,496],"blockquote",{},[16,497,498],{},"匿名函數就是一個表示式",[16,500,501,502,505],{},"而函數陳述句與函數表示式最大差異在於，函數陳述句僅僅只是將函數存入記憶體，它只是知道",[54,503,504],{},"oh!這裡有一個函數","，然後透過 hoisting 提升到最前面儲存至記憶體內就沒了。",[16,507,508],{},"但函數陳述句則是不一樣，它並不會因為 hoisting 提升到最前面，只有變數會被提升，陳述句則在原本地方",[16,510,511,512,515,516,519],{},"所以如果將 ",[51,513,514],{},"anonymousGreet()"," 移至 ",[51,517,518],{},"var anonymousGreet"," 之前會發生什麼事情?",[44,521,523],{"className":46,"code":522,"language":48,"meta":49,"style":49},"anonymousGreet()\nvar anonymousGreet = function greet () {\n console.log('hi');\n};\n",[51,524,525,532,547,559],{"__ignoreMap":49},[54,526,527,529],{"class":56,"line":57},[54,528,391],{"class":159},[54,530,531],{"class":64},"()\n",[54,533,534,536,538,540,542,544],{"class":56,"line":153},[54,535,61],{"class":60},[54,537,348],{"class":159},[54,539,351],{"class":60},[54,541,354],{"class":60},[54,543,252],{"class":159},[54,545,546],{"class":64}," () {\n",[54,548,549,551,553,555,557],{"class":56,"line":173},[54,550,156],{"class":64},[54,552,160],{"class":159},[54,554,163],{"class":64},[54,556,266],{"class":166},[54,558,170],{"class":64},[54,560,561],{"class":56,"line":315},[54,562,273],{"class":64},[16,564,565],{},"這時候我們要去想一下，當執行環境被創造時哪兩個東西會被提升，變數與函數然後提升，那結果會是什麼?",[16,567,568],{},[26,569],{"alt":391,"src":570},"https:\u002F\u002Fi.imgur.com\u002FyxRkc1r.png",[16,572,573,574,577,578,581],{},"我們會得到 ",[51,575,576],{},"TypeError: anonymousGreet is not a function","，而不是 ",[51,579,580],{},"hi","，",[16,583,584],{},"所以實際將程式碼解開來看就會像這樣 ↓",[44,586,588],{"className":46,"code":587,"language":48,"meta":49,"style":49},"var anonymousGreet;\nanonymousGreet()\nanonymousGreet = function greet () {\n console.log('hi');\n};\n",[51,589,590,597,603,615,627],{"__ignoreMap":49},[54,591,592,594],{"class":56,"line":57},[54,593,61],{"class":60},[54,595,596],{"class":64}," anonymousGreet;\n",[54,598,599,601],{"class":56,"line":153},[54,600,391],{"class":159},[54,602,531],{"class":64},[54,604,605,607,609,611,613],{"class":56,"line":173},[54,606,391],{"class":159},[54,608,351],{"class":60},[54,610,354],{"class":60},[54,612,252],{"class":159},[54,614,546],{"class":64},[54,616,617,619,621,623,625],{"class":56,"line":315},[54,618,156],{"class":64},[54,620,160],{"class":159},[54,622,163],{"class":64},[54,624,266],{"class":166},[54,626,170],{"class":64},[54,628,629],{"class":56,"line":328},[54,630,273],{"class":64},[16,632,633,634,636,637,639,640,642,643,645],{},"這就是為什麼會顯示 ",[51,635,576],{},"，因為變數 ",[51,638,391],{}," 被提升到最前面且賦予 ",[51,641,116],{},"，那 ",[51,644,116],{}," 本身是不能夠執行，所以才會出現錯誤。",[16,647,648,649,581,652,654],{},"除非直到 ",[51,650,651],{},"anonymousGreet =",[51,653,391],{}," 才會被正確的被重新設定，所以我們又得知一個結論。",[494,656,657],{},[16,658,659],{},"函數表示式並不會被提升",[16,661,662],{},"這邊我們在一次要強調函數就是物件，所以可以這樣玩",[44,664,666],{"className":46,"code":665,"language":48,"meta":49,"style":49},"function log(a){\n console.log(a);\n}\n\nlog(function() {\n console.log('hi');\n})\n",[51,667,668,683,692,696,700,710,722],{"__ignoreMap":49},[54,669,670,672,675,677,680],{"class":56,"line":57},[54,671,249],{"class":60},[54,673,674],{"class":159}," log",[54,676,163],