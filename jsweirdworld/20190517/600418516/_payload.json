:85},true,"\n",[30,88,90,93,95,98],{"class":32,"line":89},5,[30,91,92],{"class":40},"green",[30,94,45],{"class":44},[30,96,97],{"class":66},"'Tom'",[30,99,100],{"class":44},");\n",[16,102,103,104,107],{},"大家都知道會出現 ",[27,105,106],{},"Hello Tom"," 的字樣，好，課程這邊暫停一下，這邊我就開始思考，如果不帶入參數會怎麼樣?",[20,109,111],{"className":22,"code":110,"language":24,"meta":25,"style":25},"function green(name) {\n console.log('Hello' + name);\n}\n\ngreen();\n",[27,112,113,125,139,143,147],{"__ignoreMap":25},[30,114,115,117,119,121,123],{"class":32,"line":33},[30,116,37],{"class":36},[30,118,41],{"class":40},[30,120,45],{"class":44},[30,122,49],{"class":48},[30,124,52],{"class":44},[30,126,127,129,131,133,135,137],{"class":32,"line":55},[30,128,58],{"class":44},[30,130,61],{"class":40},[30,132,45],{"class":44},[30,134,67],{"class":66},[30,136,70],{"class":36},[30,138,73],{"class":44},[30,140,141],{"class":32,"line":76},[30,142,79],{"class":44},[30,144,145],{"class":32,"line":82},[30,146,86],{"emptyLinePlaceholder":85},[30,148,149,151],{"class":32,"line":89},[30,150,92],{"class":40},[30,152,153],{"class":44},"();\n",[16,155,156],{},"結果會出現什麼?",[16,158,159],{},[160,161],"img",{"alt":162,"src":163},"undefined","https:\u002F\u002Fi.imgur.com\u002Fo4JwYY0.png",[16,165,166],{},"undefined!",[16,168,169,170,173,174,176],{},"所以若沒有傳入參數， avaScript 就會替我們帶入預設值 Undefined，所以我們可以理解成寫在函數的這一段 ",[27,171,172],{},"green(name)"," 中的 ",[27,175,49],{}," 其實是一個變數。",[16,178,179,180,184],{},"另外課程也有講到 JavaScript 原本是無法替函數參數設置預設值，這是 ",[181,182,183],"strong",{},"ES6"," 才新增的，所以當如果我們沒有帶入參數時可以使用 ES6的預設值來替參數預設值 ↓",[20,186,188],{"className":22,"code":187,"language":24,"meta":25,"style":25},"function green(name = 'jack') {\n console.log('Hello' + name);\n}\n\ngreen();\n",[27,189,190,208,222,226,230],{"__ignoreMap":25},[30,191,192,194,196,198,200,203,206],{"class":32,"line":33},[30,193,37],{"class":36},[30,195,41],{"class":40},[30,197,45],{"class":44},[30,199,49],{"class":48},[30,201,202],{"class":36}," =",[30,204,205],{"class":66}," 'ja