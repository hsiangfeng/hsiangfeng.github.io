[{"data":1,"prerenderedAt":673},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190517\u002F4033482277\u002F":3,"page:\u002Fjsweirdworld\u002F20190517\u002F4033482277\u002F":4,"alt:\u002Fjsweirdworld\u002F20190517\u002F4033482277\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190517\u002F4033482277\u002F":649,"related:\u002Fjsweirdworld\u002F20190517\u002F4033482277\u002F":658},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F17\u002Fjsweirdworld-22-objects-and-the-dot\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":632,"date":633,"description":18,"extension":634,"lang":635,"meta":636,"navigation":637,"path":638,"readingMinutes":639,"seo":640,"standalone":641,"stem":642,"tags":643,"tldr":646,"updated":646,"url":647,"__hash__":648},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-22-物件與「點」.md","[JS奇怪的世界]No.22 物件與「點」","4033482277",{"type":9,"value":10,"toc":627},"minimark",[11,15,19,23,26,33,36,41,44,80,87,129,136,224,229,232,310,316,328,392,395,401,407,413,416,485,488,491,567,573,590,605,611,614,623],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來是一個新的章節，物件與函數，許多課程都會將 JavaScript 中的這兩個東西當成不同的主題在教導，但這其實是一個天大的錯誤，why? 在其他的程式語言裡面這兩者確實是不同的主題，但 JavaScript 世界中這兩者就非常的有相關。",[12,20,22],{"id":21},"物件與點","物件與「點」",[16,24,25],{},"前面章節有講過物件，(object)是一群「名稱\u002F值」的組合，就像這樣 ↓",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"object","https:\u002F\u002Fi.imgur.com\u002FR6q5QAb.png",[16,34,35],{},"那為了方便解說所以我們來試著用不同的觀點來看物件吧，物件裡面通常可以有值、有物件及函數，就像這樣 ↓",[16,37,38],{},[29,39],{"alt":31,"src":40},"https:\u002F\u002Fi.imgur.com\u002FtMzl2ae.png",[16,42,43],{},"但在物件裡面的函數，通常都被稱為方法(methods)，那一般物件會如何找尋函數與物件 or 值呢?來看一下範例 ↓",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","var person = new Object();\n","js","",[52,53,54],"code",{"__ignoreMap":50},[55,56,59,63,67,70,73,77],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"sOudu","var",[55,64,66],{"class":65},"s8XSl"," person ",[55,68,69],{"class":61},"=",[55,71,72],{"class":61}," new",[55,74,76],{"class":75},"scAaK"," Object",[55,78,79],{"class":65},"();\n",[16,81,82,83,86],{},"課程上先使用了 ",[52,84,85],{},"new"," 這個方法來建立一個新物件，接下來在記憶體就會知道它是一個物件，那該如何寫入資料呢?使用中括號運算子 ↓",[45,88,90],{"className":47,"code":89,"language":49,"meta":50,"style":50},"person['fistname'] = 'Tony';\nperson['lastname'] = 'Alicea';\n",[52,91,92,112],{"__ignoreMap":50},[55,93,94,97,101,104,106,109],{"class":57,"line":58},[55,95,96],{"class":65},"person[",[55,98,100],{"class":99},"sWayO","'fistname'",[55,102,103],{"class":65},"] ",[55,105,69],{"class":61},[55,107,108],{"class":99}," 'Tony'",[55,110,111],{"class":65},";\n",[55,113,115,117,120,122,124,127],{"class":57,"line":114},2,[55,116,96],{"class":65},[55,118,119],{"class":99},"'lastname'",[55,121,103],{"class":65},[55,123,69],{"class":61},[55,125,126],{"class":99}," 'Alicea'",[55,128,111],{"class":65},[16,130,131,132,135],{},"這樣寫物件就可以參考它記憶體的位子寫入，這時候我們可以試著輸出 ",[52,133,134],{},"person"," 看看 ↓",[45,137,139],{"className":47,"code":138,"language":49,"meta":50,"style":50},"var person = new Object();\nperson['fistname'] = 'Tony';\nperson['lastname'] = 'Alicea';\nconsole.log(person);\nconsole.log(person['fistname']);\nconsole.log(person['lastname']);\n",[52,140,141,155,169,184,196,211],{"__ignoreMap":50},[55,142,143,145,147,149,151,153],{"class":57,"line":58},[55,144,62],{"class":61},[55,146,66],{"class":65},[55,148,69],{"class":61},[55,150,72],{"class":61},[55,152,76],{"class":75},[55,154,79],{"class":65},[55,156,157,159,161,163,165,167],{"class":57,"line":114},[55,158,96],{"class":65},[55,160,100],{"class":99},[55,162,103],{"class":65},[55,164,69],{"class":61},[55,166,108],{"class":99},[55,168,111],{"class":65},[55,170,172,174,176,178,180,182],{"class":57,"line":171},3,[55,173,96],{"class":65},[55,175,119],{"class":99},[55,177,103],{"class":65},[55,179,69],{"class":61},[55,181,126],{"class":99},[55,183,111],{"class":65},[55,185,187,190,