 (Number)，而 ",[27,210,115],{}," 轉成數字代表著什麼?就是 ",[202,213,214],{},"0","。",[20,217,219],{"className":22,"code":218,"language":24,"meta":25,"style":25},"console.log(0 \u003C 1);\n",[27,220,221],{"__ignoreMap":25},[30,222,223,225,227,229,231,233,235],{"class":32,"line":33},[30,224,37],{"class":36},[30,226,41],{"class":40},[30,228,44],{"class":36},[30,230,214],{"class":47},[30,232,52],{"class":51},[30,234,107],{"class":47},[30,236,63],{"class":36},[16,238,239],{},"這也就是為什麼會輸出 true 的原因。",[241,242,243,247],"ul",{},[244,245,246],"li",{},"0 代表 false",[244,248,249],{},"1 代表 true",[16,251,252,253,256],{},"以人的角度來講 ",[27,254,255],{},"console.log(3 \u003C 2 \u003C 1);","，絕對是錯的，但在 JavaScript 中是合理正確的。",[16,258,259],{},"所以我們回到一開始的範例來分析。",[20,261,262],{"className":22,"code":23,"language":24,"meta":25,"style":25},[27,263,264],{"__ignoreMap":25},[30,265,266,268,270,272,274,276,278,280,282],{"class":32,"line":33},[30,267,37],{"class":36},[30,269,41],{"class":40},[30,271,44],{"class":36},[30,273,48],{"class":47},[30,275,52],{"class":51},[30,277,55],{"class":47},[30,279,52],{"class":51},[30,281,60],{"class":47},[30,283,63],{"class":36},[16,285,286,287,290,291,73,293,295,296,298],{},"剛剛有講到小於運算子是左相依性，所以會優先判定 ",[27,288,289],{},"1 \u003C 2","，",[27,292,48],{},[27,294,76],{},"，答案是 ",[27,297,69],{},"，此時程式又變成了這樣。",[20,300,302],{"className":22,"code":301,"language":24,"meta":25,"style":25},"console.log(true \u003C 3);\n",[27,303,304],{"__ignoreMap":25},[30,305,306,308,310,312,314,316,318],{"class":32,"line":33},[30,307,37],{"class":36},[30,309,41],{"class":40},[30,311,44],{"class":36},[30,313,69],{"class":47},[30,315,52],{"class":51},[30,317,60],{"class":47},[30,319,63],{"class":36},[16,321,322],{},"在經過 JavaScript 的強制轉型後程式碼就又會變成這樣子。",[20,324,326],{"className":22,"code":325,"language":24,"meta":25,"style":25},"console.log(1 \u003C 3);\n",[27,327,328],{"__ignoreMap":25},[30,329,330,332,334,336,338,340,342],{"class":32,"line":33},[30,331,37],{"class":36},[30,333,41],{"class":40},[30,335,44],{"class":36},[30,337,48],{"class":47},[30,339,52],{"class":51},[30,341,60],{"class":47},[30,343,63],{"class":36},[16,345,346,73,348,350,351,215],{},[27,347,48],{},[27,349,79],{}," ，沒錯，所以是 ",[27,352,69],{},[16,354,355],{},"有時候我們可以透過強轉型別語法來將字串的數字變成數值就像這樣",[20,357,359],{"className":22,"code":358,"language":24,"meta":25,"style":25},"Number('1');\n",[27,360,361],{"__ignoreMap":25},[30,362,363,366,368,372],{"class":32,"line":33},[30,364,365],{"class":40},"Number",[30,367,44],{"class":36},[30,369,371],{"class":370},"sTRMh","'1'",[30,373,63],{"class":36},[16,375,376],{},"但是如果我們強轉的字串不是數值呢?",[20,378,380],{"className":22,"code":379,"language":24,"meta":25,"style":25},"Number('哈囉');\n",[27,381,382],{"__ignoreMap":25},[30,383,384,386,388,391],{"class":32,"line":33},[30,385,365],{"class":40},[30,387,44],{"class":36},[30,389,390],{"class":370},"'哈囉'",[30,392,63],{"class":36},[16,394,395],{},[120,396],{"alt":397,"src":398},"不是數值","https:\u002F\u002Fi.imgur.com\u002FSpeaR0wh.png",[16,400,401,402,405],{},"我們會得到一個特別的東西，「NaN」，NaN 表示",[30,403,404],{},"不是數字"," (Not a Number)。",[16,407,408],{},"課程中也有轉換 Undefined 及 Null。",[20,410,412],{"className":22,"code":411,"language":24,"meta":25,"style":25},"Number(undefined);\n",[27,413,414],{"__ignoreMap":25},[30,415,416,418,420,423],{"class":32,"line":33},[30,417,365],{"class":40},[30,419,44],{"class":36},[30,421,422],{"class":47},"undefined",[30,424,63],{"class":36},[16,426,427],{},"只會得到 NaN (我們也可以由這邊知道 undefined 其實是一個值，特殊的關鍵字)。",[16,429,430],{},"那 Null 呢?",[20,432,434],{"className":22,"code":433,"language":24,"meta":25,"style":25},"Number(Null);\n",[27,435,436],{"__ignoreMap":25},[30,437,438,440],{"class":32,"line":33},[30,439,365],{"class":40},[30,441,442],{"class":36},"(Null);\n",[16,444,445],{},"JavaScript 則將 Null 定義為 0。",[16,447,448],{},"我們可以知道強轉型別是很危險的事情，所以沒事不要去做強轉。",[450,451,456],"iframe",{"height":452,"style":453,"scrolling":454,"title":14,"src":455,"frameBorder":454,"allowTransparency":69,"allowFullScreen":69},265,"width: 100%;","no","\u002F\u002F