[{"data":1,"prerenderedAt":352},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F":3,"page:\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F":4,"alt:\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F":328,"related:\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F":337},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F16\u002Fjs-weird-world-12-async-callbacks\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":312,"date":313,"description":18,"extension":314,"lang":315,"meta":316,"navigation":165,"path":317,"readingMinutes":318,"seo":319,"standalone":320,"stem":321,"tags":322,"tldr":325,"updated":325,"url":326,"__hash__":327},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-12-關於非同步回呼.md","[JS奇怪的世界]No.12 關於非同步回呼","3421234703",{"type":9,"value":10,"toc":307},"minimark",[11,15,19,22,28,36,39,42,49,52,252,267,273,283,288,291,294,303],[12,13,14],"h2",{"id":14},"關於非同步回呼",[16,17,18],"p",{},"前面某一章節我有講過 JavaScipt 的同步執行，想必你也聽過很多所謂的非同步，但非同步是什麼?",[12,20,21],{"id":21},"非同步",[16,23,24],{},[25,26],"img",{"alt":21,"src":27},"https:\u002F\u002Fi.imgur.com\u002FVAerC1Xh.png",[16,29,30,31,35],{},"非同步的意思是說",[32,33,34],"strong",{},"在一個時間點內一個正在執行中的程式又開始執行另一個程式","的意思，聽起來很像繞口令吧?我們前面有講過 JavaScript 它是一次執行一行程式碼，那 JavaScript 又該如何處理非同步事件呢?",[16,37,38],{},"首先我們已經了解了執行堆還有執行環境，那當函數執行完畢後就會離開執行堆(釋放)，而 JavaScript 等待的過程中在 JavaScript 引擎稱為事件佇列 (event queue)，而這裡面的事件、事件通知，都是即將可能要發生的。",[16,40,41],{},"所以當執行堆全部都執行完畢後 JavaScript 就會開始注意事件佇列(event queue)，舉例 click 事件，JavaScript 會注意到它是否會觸發某些函數，如果會就會把函數丟入執行堆中，當事件一發生就會開始創造執行環境給這個函數，然後這個事件就結束並釋放，接下來就會輪到下一個事件佇列(舉例 HTTP Request)以此類推...",[16,43,44,45,48],{},"但是要注意",[32,46,47],{},"事件佇列只會在執行堆為空","的時候才會執行事件佇列(event queue)，那這真的是非同步嗎?不，還是同步執行，JavaScript 還是一樣一行一行的執行程式碼。",[16,50,51],{},"讓我們這邊來看課程的程式範例 ↓",[53,54,59],"pre",{"className":55,"code":56,"language":57,"meta":58,"style":58},"language-js shiki shiki-themes github-dark-high-contrast","function waitThreeSceonds() {\n var ms = 3000 + new Date().getTime();\n while(new Date() \u003C ms){}\n console.log('finished function');\n}\n\nfunction clickHandler() {\n console.log('click event!');\n}\n\ndocument.addEventListener('click', clickHandler);\n\nwaitThreeSceonds()\n\nconsole.log('finished execution');\n","js","",[60,61,62,79,113,136,154,160,167,177,191,196,201,218,223,232,237],"code",{"__ignoreMap":58},[63,64,67,71,75],"span",{"class":65,"line":66},"line",1,[63,68,70],{"class":69},"sWyjQ","function",[63,72,74],{"class":73},"sj_SG"," waitThreeSceonds",[63,76,78],{"class":77},"sMAXC","() {\n",[63,80,82,85,88,91,95,98,101,104,107,110],{"class":65,"line":81},2,[63,83,84],{"class":69}," var",[63,86,87],{"class":77}," ms ",[63,89,90],{"class":69},"=",[63,92,94],{"class":93},"sCcAr"," 3000",[63,96,97],{"class":69}," +",[63,99,100],{"class":69}," new",[63,102,103],{"class":73}," Date",[63,105,106],{"class":77},"().",[63,108,109],{"class":73},"getTime",[63,111,112],{"class":77},"();\n",[63,114,116,119,122,125,127,130,133],{"class":65,"line":115},3,[63,117,118],{"class":69}," while",[63,120,121],{"class":77},"(",[63,123,124],{"class":69},"new",[63,126,103],{"class":73},[63,128,129],{"class":77},"() ",[63,131,132],{"class":69},"\u003C",[63,134,135],{"class":77}," ms){}\n",[63,137,139,142,145,147,151],{"class":65,"line":138},4,[63,140,141],{"class":77}," console.",[63,143,144],{"class":73},"log",[63,146,121],{"class":77},[63,148,150],{"class":149},"sTRMh","'finished function'",[63,152,153],{"class":77},");\n",[63,155,157],{"class":65,"line":156},5,[63,158,159],{"class":77},"}\n",[63,161,163],{"class":65,"line":162},6,[63,164,166],{"emptyLinePlaceholder":165},true,"\n",[63,168,170,172,175],{"class":65,"line":169},7,[63,171,70],{"class":69},[63,173,174],{"class":73}," clickHandler",[63,176,78],{"class":77},[63,178,180,182,184,186,189],{"class":65,"line":179},8,[63,181,141],{"class":77},[63,183,144],{"class":73},[63,185,121],{"class":77},[63,187,188],{"class":149},"'click event!'",[63,190,153],{"class":77},[63,192,194],{"class":65,"line":193},9,[63,195,159],{"class":77},[63,197,199],{"class":65,"line":198},10,[63,200,166],{"emptyLinePlaceholder":165},[63,202,204,207,210,212,215],{"class":65,"line":203},11,[63,205,206],{"class":77},"document.",[63,208,209],{"class":73},"addEventListener",[63,211,121],{"class":77},[63,213,214],{"class":149},"'click'",[63,216,217],{"class":77},", clickHandler);\n",[63,219,221],{"class":65,"line":220},12,[63,222,166],{"emptyLinePlaceholder":165},[63,224,226,229],{"class":65,"line":225},13,[63,227,228],{"class":73},"waitThreeSceonds",[63,230,231],{"class":77},"()\n",[63,233,235],{"class":65,"line":234},14,[63,236,166],{"emptyLinePlaceholder":165},[63,238,240,243,245,247,250],{"class":65,"line":239},15,[63,241,242],{"class":77},"console.",[63,244,144],{"class":73},[63,246,121],{"class":77},[63,248,249],{"class":149},"'finished execution'",[63,251,153],{"class":77},[16,253,254,255,258,259,262,263,266],{},"依照這範例我們可以發現 ",[60,256,257],{},"console.log('finished execution');"," 會立刻出現，然後過一段時間才會出現 ",[60,260,261],{},"console.log('finished function');","，接下來當我們點擊畫面時就會出現 ",[60,264,265],{},"console.log('click event!');","，注意到了嗎? JavaScript 會先執行完畢應該要執行的函數再來執行下一行程式碼，所以會像這樣子。",[16,268,269],{},[25,270],{"alt":271,"src":272},"事件佇列","https:\u002F\u002Fi.imgur.com\u002FhqF27idh.png",[16,274,275,276,278,279,282],{},"所以我們可以一執行這個函數後立刻點擊畫面你會發現 ",[60,277,265],{}," 並沒有出現，它會等到 ",[60,280,281],{},"waitThreeSceonds()"," 執行完畢才出現。",[16,284,285],{},[25,286],{"alt":271,"src":287},"https:\u002F\u002Fi.imgur.com\u002FnLmjU3lh.png",[16,289,290],{},"由此可知 JavaScript 會等候執行堆清空後再去執行下一個事件，而過程中它會將事件儲存在事件佇列(event queue)，所以執行時間的長短將會看事件佇列來決定，這也是就是 JavaScript 如何處理同步與非同步的方式。",[12,292,293],{"id":293},"圖源",[16,295,296],{},[297,298,302],"a",{"href":299,"rel":300},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[301],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",[304,305,306],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--sh