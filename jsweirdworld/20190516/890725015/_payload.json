[{"data":1,"prerenderedAt":211},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F":3,"page:\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F":4,"alt:\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F":187,"related:\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F":196},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F16\u002Fjs-weird-world-14-primitive-values\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":170,"date":171,"description":24,"extension":172,"lang":173,"meta":174,"navigation":175,"path":176,"readingMinutes":177,"seo":178,"standalone":179,"stem":180,"tags":181,"tldr":184,"updated":184,"url":185,"__hash__":186},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-14-純值.md","[JS奇怪的世界]No.14 純值","890725015",{"type":9,"value":10,"toc":158},"minimark",[11,15,22,25,28,31,35,38,49,56,65,69,82,92,96,100,103,110,114,117,121,125,128,132,136,139,143,146,149],[12,13,14],"h2",{"id":14},"純值",[16,17,18],"p",{},[19,20],"img",{"alt":14,"src":21},"https:\u002F\u002Fi.imgur.com\u002FHFn5EJEh.png",[16,23,24],{},"前面已經針對 JavaScript 的型別做的一個簡易的介紹，而這章節課程將針對 JavaScript 動態型別瞭解以及其優缺點深入瞭解。",[16,26,27],{},"首先純值是什麼?純值是一個資料的型別的意思，代表著一個值，而不是物件(注意物件是名稱\u002F值的組合)。",[16,29,30],{},"那 JavaScript 總共有六種型別。",[12,32,34],{"id":33},"undefined","Undefined",[16,36,37],{},"前面其實已經對 Undefined 這個特殊關鍵字講了無數次，所以我們對於這個關鍵字一定已經有一定的了解程度，而 Undefined 代表什麼意思呢?",[39,40,41],"blockquote",{},[16,42,43,44,48],{},"Undefined 的意思是說表示這個值",[45,46,47],"strong",{},"還沒有被賦予值","的意思。",[16,50,51,52,55],{},"這是 JavaScript 給所有",[45,53,54],{},"變數的初始值","，所以這邊再一次強調千萬不要給變數設置 Undefined，因為 JavaScript 是與允許這麼做的，而且這會導致 debug 上的困難。",[57,58,64],"iframe",{"height":59,"style":60,"scrolling":61,"title":34,"src":62,"frameBorder":61,"allowTransparency":63,"allowFullScreen":63},265,"width: 100%;","no","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FmYLLOe\u002F?height=265&theme-id=0&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FmYLLOe\u002F'>Undefined\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,66,68],{"id":67},"null","Null",[16,70,71,72,75,76,78,79,81],{},"Null 與 Undefined 一樣，所代表的意思都是不存在，但是一般來講你是可以對變數設成 ",[73,74,67],"code",{}," 的，所以你在實際開發環境下，你是可以使用 ",[73,77,67],{}," 來設值而不是使用 ",[73,80,33],{},"。",[83,84,85,89],"ul",{},[86,87,88],"li",{},"Null 在語意上的意思是空",[86,90,91],{},"undefined 是變數還沒有被賦值的意思",[57,93,95],{"height":59,"style":60,"scrolling":61,"title":68,"src":94,"frameBorder":61,"allowTransparency":63,"allowFullScreen":63},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FBexxpQ\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FBexxpQ\u002F'>Null\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,97,99],{"id":98},"boolean","Boolean",[16,101,102],{},"這個一定非常多人都很熟悉所以就不多作介紹。",[83,104,105,107],{},[86,106,63],{},[86,108,109],{},"false",[12,111,113],{"id":112},"number","Number",[16,115,116],{},"在 JavaScript 中只有一個數字型別，那就是 Number，其它的程式語言可能還有整數、浮點數等等，但在 JavaScript 就只有 Number 而 Number 其實是一個 Float (浮點數)，所以它可以接受有小數點。",[57,118,120],{"height":59,"style":60,"scrolling":61,"title":113,"src":119,"frameBorder":61,"allowTransparency":63,"allowFullScreen":63},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FMdGGmG\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FMdGGmG\u002F'>Number\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,122,124],{"id":123},"string","String",[16,126,127],{},"那接下來這東西也很常見，也就是字串，簡單來說就是使用單雙引號所包覆的東西就是一個字串。",[57,129,131],{"height":59,"style":60,"scrolling":61,"title":124,"src":130,"frameBorder":61,"allowTransparency":63,"allowFullScreen":63},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FmYLLwV\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FmYLLwV\u002F'>String\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,133,135],{"id":134},"symbol","Symbol",[16,137,138],{},"這一個就比較特別了，這個叫符號，主要於 ES6 所支援，但基本上不常見，而且必須透過 Symbol 函數來生成，所以是比較特別的東西。",[57,140,142],{"height":59,"style":60,"scrolling":61,"title":135,"src":141,"frameBorder":61,"allowTransparency":63,"allowFullScreen":63},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FVOxxzY\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FVOxxzY\u002F'>Symbol\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[16,144,145],{},"上面就是 JavaScript 主要的六種型別(純值)。",[12,147,148],{"id":148},"圖源",[16,150,151],{},[152,153,157],"a",{"href":154,"rel":155},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[156],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",{"title":159,"searchDepth":160,"depth":160,"links":161},"",2,[162,163,164,165,166,167,168,169],{"id":14,"depth":160,"text":14},{"id":33,"depth":160,"text":34},{"id":67,"depth":160,"text":68},{"id":98,"depth":160,"text":99},{"id":112,"depth":160,"text":113},{"id":123,"depth":160,"text":124},{"id":134,"depth":160,"text":135},{"id":148,"depth":160,"text":148},"克服JS奇怪的部分系列","2019-05-16 19:30:35","md","zh-Hant",{},true,"\u002Fjav