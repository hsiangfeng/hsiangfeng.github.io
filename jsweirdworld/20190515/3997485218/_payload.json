[{"data":1,"prerenderedAt":428},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F":3,"page:\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F":4,"alt:\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F":404,"related:\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F":413},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-08-function-invocation-execution-stack\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":387,"date":388,"description":389,"extension":390,"lang":391,"meta":392,"navigation":100,"path":393,"readingMinutes":394,"seo":395,"standalone":396,"stem":397,"tags":398,"tldr":401,"updated":401,"url":402,"__hash__":403},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-8-函數呼叫與執行堆.md","[JS奇怪的世界]No.8 函數呼叫與執行堆","3997485218",{"type":9,"value":10,"toc":383},"minimark",[11,16,24,36,39,110,113,142,145,180,198,204,207,214,228,231,301,310,316,332,365,368,371,379],[12,13,15],"h2",{"id":14},"invocation-函數呼叫","invocation (函數呼叫)",[17,18,19],"p",{},[20,21],"img",{"alt":22,"src":23},"圖片","https:\u002F\u002Fi.imgur.com\u002F2xGWsYS.png",[17,25,26,27,31,32,35],{},"invocation 又稱函數呼叫，這是一個非常重要的觀念，所以當人家講 ",[28,29,30],"strong",{},"invocation function or function invocation","，其實就是在講",[28,33,34],{},"執行這個函數","，而我們是透過**括號()**來執行函數。",[17,37,38],{},"課程有提供了一個基礎範例，幫助我們理解觀念 ↓",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","function b() {\n}\nfunction a() {\n b();\n}\n\na();\n","js","",[47,48,49,66,72,82,90,95,102],"code",{"__ignoreMap":45},[50,51,54,58,62],"span",{"class":52,"line":53},"line",1,[50,55,57],{"class":56},"sWyjQ","function",[50,59,61],{"class":60},"sj_SG"," b",[50,63,65],{"class":64},"sMAXC","() {\n",[50,67,69],{"class":52,"line":68},2,[50,70,71],{"class":64},"}\n",[50,73,75,77,80],{"class":52,"line":74},3,[50,76,57],{"class":56},[50,78,79],{"class":60}," a",[50,81,65],{"class":64},[50,83,85,87],{"class":52,"line":84},4,[50,86,61],{"class":60},[50,88,89],{"class":64},"();\n",[50,91,93],{"class":52,"line":92},5,[50,94,71],{"class":64},[50,96,98],{"class":52,"line":97},6,[50,99,101],{"emptyLinePlaceholder":100},true,"\n",[50,103,105,108],{"class":52,"line":104},7,[50,106,107],{"class":60},"a",[50,109,89],{"class":64},[17,111,112],{},"這時候我們可以思考一下 JavaScript 是如何運作的。",[114,115,116,123,126,129,139],"ol",{},[117,118,119,120],"li",{},"首先全域執行環境會被先建立，也就是 ",[47,121,122],{},"window",[117,124,125],{},"語法解析器開始分析我們的程式內容 f-u-c-t-....(逐字解析)",[117,127,128],{},"編譯器開始將我們所撰寫的程式轉換電腦可以看懂得指令",[117,130,131,132,134,135,138],{},"開始創造「全域執行環境」，這時候會建立 ",[47,133,122],{}," 及 ",[47,136,137],{},"this"," 等全域物件",[117,140,141],{},"再來就進入創造階段 (Hoisting) 開始創造我們的變數及函數",[17,143,144],{},"那函數都會優先被儲存在記憶體中，直到我們呼叫這些函數，它才會執行函數中的程式，所以在前面的範例 ↓",[40,146,148],{"className":42,"code":147,"language":44,"meta":45,"style":45},"function b() {\n}\nfunction a() {\n b();\n}\n",[47,149,150,158,162,170,176],{"__ignoreMap":45},[50,151,152,154,156],{"class":52,"line":53},[50,153,57],{"class":56},[50,155,61],{"class":60},[50,157,65],{"class":64},[50,159,160],{"class":52,"line":68},[50,161,71],{"class":64},[50,163,164,166,168],{"class":52,"line":74},[50,165,57],{"class":56},[50,167,79],{"class":60},[50,169,65],{"class":64},[50,171,172,174],{"class":52,"line":84},[50,173,61],{"class":60},[50,175,89],{"class":64},[50,177,178],{"class":52,"line":92},[50,179,71],{"class":64},[17,181,182,183,186,187,190,191,193,194,197],{},"這些時候",[28,184,185],{},"函數只是儲存在記憶體","中而已，直到它往下遇到我們所撰寫的 invocation，也就是 ",[47,188,189],{},"a()"," 時，才會開始執行函數並執行裡面的程式碼，那這邊稍微停止一下，當執行 ",[47,192,189],{}," 時候，其實產生了一個很奇妙的事情，",[28,195,196],{},"新的執行環境被創造了","，而這過程就是所謂的執行堆。",[17,199,200],{},[20,201],{"alt":202,"src":203},"執行堆","https:\u002F\u002Fi.imgur.com\u002FRF8tKTx.png",[17,205,206],{},"而執行堆就是一層一層疊上去的，那誰在最上面誰就是正在執行中的東西，所以我們每次在呼叫函數時，都是在建立新的執行環境，然後放進執行堆中。",[17,208,209,210,213],{},"而這個新的執行環境很特別，它有屬於自己的",[28,211,212],{},"全域執行環境","、記憶體以及函數等，而它也會歷經創造、提升等階段，然後逐行逐字的執行程式碼。",[17,215,216,217,220,221,223,224,227],{},"所以當執行 ",[47,218,219],{},"b()"," 的時候 ",[47,222,189],{}," 就會停止運作，然後創造新的執行環境，所以由此可知每一個函數都會建立一個",[28,225,226],{},"新的執行環境並且歷經創造等等階段","，而程式碼的執行順序也不會受到執行堆的問題而影響。",[17,229,230],{},"但若如果這樣子呢?",[40,232,234],{"className":42,"code":233,"language":44,"meta":45,"style":45},"function b() {\n var d;\n}\nfunction a() {\n b();\n var c;\n}\n\na();\nvar d;\n",[47,235,236,244,252,256,264,270,277,281,286,293],{"__ignoreMap":45},[50,237,238,240,242],{"class":52,"line":53},[50,239,57],{"class":56},[50,241,61],{"class":60},[50,243,65],{"class":64},[50,245,246,249],{"class":52,"line":68},[50,247,248],{"class":56}," var",[50,250,251],{"class":64}," d;\n",[50,253,254],{"class":52,"line":74},[50,255,71],{"class":64},[50,257,258,260,262],{"class":52,"line":84},[50,259,57],{"class":56},[50,261,79],{"class":60},[50,263,65],{"class":64},[50,265,266,268],{"class":52,"line":92},[50,267,61],{"class":60},[50,269,89],{"class":64},[50,271,272,274],{"class":52,"line":97},[50,273,248],{"class":56},[50,275,276],{"class":64}," c;\n",[50,278,279],{"class":52,"line":104},[50,280,71],{"class":64},[50,282,284],{"class":52,"line":283},8,[50,285,101],{"emptyLinePlaceholder":100},[50,287,289,291],{"class":52,"line":288},9,[50,290,107],{"class":60},[50,292,89],{"class":64},[50,294,296,299],{"class":52,"line":295},10,[50,297,298],{"class":56},"var",[50,300,251],{"class":64},[17,302,303,304,306,307,309],{},"首先我們會知道 ",[47,305,189],{}," 函數會被呼叫而 ",[47,308,189],{}," 就會變成目前正在執行中的程式。",[17,311,312],{},[20,313],{"alt":314,"src":315},"正在執行中的程式","https:\u002F\u002Fi.imgur.com\u002FSdFWf6c.png",[17,317,318,319,322,323,325,326,328,329,331],{},"但是首先最後一行的 ",[47,320,321],{},"var d"," 在 ",[47,324,189],{}," 的最後一行，因為函數 ",[47,327,189],{}," 還沒有執行完畢，所以不會被建立，主要原因是 JavaScript 是同步執行，並一次執行一行一個指令，所以它必須等函數 ",[47,330,189],{}," 執行完畢才會建立。",[17,333,334,335,337,338,340,341,343,344,346,347,349,350,353,354,356,357,360,361,364],{},"接下來 ",[47,336,189],{}," 函數執行過程中，它會呼叫 ",[47,339,219],{},"，然後 ",[47,342,219],{}," 就會開始建立自己的執行環境並且成為最上面的執行中的程式，然後在執行 ",[47,345,321],{},"，當 ",[47,348,219],{}," 執行完畢後 ",[47,351,352],{},"b"," 就會釋放掉(也就會離開執行堆)，這時候就會只剩下 ",[47,355,189],{}," 還在執行堆中，因為它還要創造變數 ",[47,358,359],{},"var c","，那它建立完畢之後呢?也是一樣會被釋放掉，這時候才會執行最後一行的 ",[47,362,363],{},"var d;","。",[17,366,367],{},"所以我們可以了解到每執行一個函數就會建立一個新的執行環境，然後逐行一行逐句逐字的同步執行，直到它執行完畢。",[12,369,370],{"id":370},"圖源",[17,372,373],{},[107,374,378],{"href":375,"rel":376},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[377],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",[380,381,382],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":45,"searchDepth":68,"depth":68,"links":384},[385,386],{"id":14,"depth":68,"text":15},{"id":370,"depth":68,"text":370},"克服JS奇怪的部分系列","2019-05-15 22:30:35","invocation 又稱函數呼叫，這是一個非常重要的觀念，所以當人家講 invocation function or function invocation，就是在講執行這個函數，而我們是透過括號()來執行的，這樣就是在呼叫 function。","md","zh-Hant",{},"\u002Fjavascript\u002Fjs-no-8","2",{"title":6,"description":389},false,"JavaScript 奇怪的部分\u002FJS奇怪的世界-No-8-函數呼叫與執行堆",[399,400],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分",null,"\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F","PwsIcSFVx_MqDeKpoc-_kJcq9Zx7WH6hJdYG2BbqRpI",{"newer":405,"older":409},{"url":406,"title":407,"date":408},"\u002Fhexo\u002F20190516\u002F2710757554\u002F","Ne