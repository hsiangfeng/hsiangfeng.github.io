[{"data":1,"prerenderedAt":331},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190515\u002F1050733096\u002F":3,"page:\u002Fjsweirdworld\u002F20190515\u002F1050733096\u002F":4,"alt:\u002Fjsweirdworld\u002F20190515\u002F1050733096\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190515\u002F1050733096\u002F":307,"related:\u002Fjsweirdworld\u002F20190515\u002F1050733096\u002F":316},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-03-global-environment-object\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":290,"date":291,"description":292,"extension":293,"lang":294,"meta":295,"navigation":179,"path":296,"readingMinutes":297,"seo":298,"standalone":299,"stem":300,"tags":301,"tldr":304,"updated":304,"url":305,"__hash__":306},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-3-全域環境與全域物件.md","[JS奇怪的世界]No.3 全域環境與全域物件","1050733096",{"type":9,"value":10,"toc":286},"minimark",[11,15,28,36,42,48,54,57,70,79,84,90,95,101,107,112,121,136,139,142,216,223,229,242,248,271,274,282],[12,13,14],"h2",{"id":14},"全域環境與全域物件",[16,17,18,19,23,24,27],"p",{},"「全域環境」的觀念與「執行環境」也有一定的關係，一般來講當程式一開始執行時，都是在「全域環境」下，而這環境也是別人所寫好的一個程式，一個 「Global」 而這個環境包裝著我們所準備執行的程式與",[20,21,22],"strong",{},"正在執行","的程式，一般來講我們還沒撰寫程式之前都會有一個叫做",[20,25,26],{},"預設執行環境","(基礎執行環境)的東西。",[16,29,30,31,35],{},"首先先開啟瀏覽器，並開啟開發者工具(通常 F12 就可以打開)然後試著在 console (控制台)頁面輸入 ",[32,33,34],"code",{},"window","，此時你應該會看到這個樣子。",[16,37,38],{},[39,40],"img",{"alt":34,"src":41},"https:\u002F\u002Fi.imgur.com\u002F1TT3F73.png",[16,43,44,45,47],{},"圖片上這些東西就是所謂的",[20,46,26],{},"，也就是所謂的「全域環境」也可以稱為「全域執行環境」。",[49,50,51],"blockquote",{},[16,52,53],{},"也因為它被稱為「全域」執行環境，所以它代表著我們可以在任何一個地方取用它並使用它。",[16,55,56],{},"那「全域執行環境」做了什麼?「全域執行環境」做了兩件事情 ↓",[58,59,60,64],"ul",{},[61,62,63],"li",{},"全域物件 (注意前面已經說過，物件只是名稱與值的配對)",[61,65,66,67],{},"非常特殊的變數 ",[32,68,69],{},"this",[16,71,72,73,75,76,78],{},"JavaScript 在",[20,74,26],{},"下替我們建立了這兩個神奇的東西，所以我們在前面 F12 輸入 ",[32,77,34],{}," 才可以看到很多東西。",[16,80,81],{},[39,82],{"alt":83,"src":41},"圖片",[16,85,86,87,89],{},"而 ",[32,88,34],{}," 就是一個物件，不相信?我在重打一次不展開內容給你看。",[16,91,92],{},[39,93],{"alt":34,"src":94},"https:\u002F\u002Fi.imgur.com\u002Fx532CyO.png",[16,96,97,98,100],{},"這樣可以知道 ",[32,99,34],{}," 就是一個物件，這是一個非常重要的基礎觀念。",[16,102,103,104,106],{},"那如果我打 ",[32,105,69],{}," 呢?",[16,108,109],{},[39,110],{"alt":69,"src":111},"https:\u002F\u002Fi.imgur.com\u002FAr94qBa.png",[16,113,114,115,117,118,120],{},"可以發現 ",[32,116,69],{}," 就是目前的「全域執行環境」 (",[32,119,34],{},")",[16,122,123,124,126,127,129,130,132,133,135],{},"所以 「全域執行環境」 與 「名稱\u002F值」 組合是有關係的，由上面這些範例我們可以知道 ",[32,125,69],{}," = ",[32,128,34],{},"，",[32,131,69],{}," 參照到 ",[32,134,34],{},"。",[16,137,138],{},"這一堂課也再一次強調不要把 JavaScript 想的太複雜，只要我們所撰寫的程式碼或變數不在函數 (function) 時，就是在「全域執行環境」。",[16,140,141],{},"那我們來驗證一下觀念吧!如果我們試著寫一些東西來看看會發生什麼事情 ↓",[143,144,149],"pre",{"className":145,"code":146,"language":147,"meta":148,"style":148},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Hello World!';\n\nfunction say(){\n var b = 'Tom';\n}\n","js","",[32,150,151,174,181,194,210],{"__ignoreMap":148},[152,153,156,160,164,167,171],"span",{"class":154,"line":155},"line",1,[152,157,159],{"class":158},"sWyjQ","var",[152,161,163],{"class":162},"sMAXC"," a ",[152,165,166],{"class":158},"=",[152,168,170],{"class":169},"sTRMh"," 'Hello World!'",[152,172,173],{"class":162},";\n",[152,175,177],{"class":154,"line":176},2,[152,178,180],{"emptyLinePlaceholder":179},true,"\n",[152,182,184,187,191],{"class":154,"line":183},3,[152,185,186],{"class":158},"function",[152,188,190],{"class":189},"sj_SG"," say",[152,192,193],{"class":162},"(){\n",[152,195,197,200,203,205,208],{"class":154,"line":196},4,[152,198,199],{"class":158}," var",[152,201,202],{"class":162}," b ",[152,204,166],{"class":158},[152,206,207],{"class":169}," 'Tom'",[152,209,173],{"class":162},[152,211,213],{"class":154,"line":212},5,[152,214,215],{"class":162},"}\n",[16,217,218,219,222],{},"輸入完之後我們來看看 ",[32,220,221],{},"a"," 被建立在哪裡。",[16,224,225],{}