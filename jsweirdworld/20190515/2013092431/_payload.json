[{"data":1,"prerenderedAt":97},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190515\u002F2013092431\u002F":3,"page:\u002Fjsweirdworld\u002F20190515\u002F2013092431\u002F":4,"alt:\u002Fjsweirdworld\u002F20190515\u002F2013092431\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190515\u002F2013092431\u002F":73,"related:\u002Fjsweirdworld\u002F20190515\u002F2013092431\u002F":82},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjsweirdworld-07-single-threaded-synchronous\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":55,"date":56,"description":57,"extension":58,"lang":59,"meta":60,"navigation":61,"path":62,"readingMinutes":63,"seo":64,"standalone":65,"stem":66,"tags":67,"tldr":70,"updated":70,"url":71,"__hash__":72},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-7-觀念小提醒-單執行緒與同步執行.md","[JS奇怪的世界]No.7 觀念小提醒-單執行緒與同步執行","2013092431",{"type":9,"value":10,"toc":48},"minimark",[11,15,22,25,28,33,36,39],[12,13,14],"h2",{"id":14},"單執行緒",[16,17,18],"p",{},[19,20],"img",{"alt":14,"src":21},"https:\u002F\u002Fi.imgur.com\u002Fgzj2xCK.png",[16,23,24],{},"單執行緒是個看起來很專業又複雜的術語，但簡單來講的話就是執行過程中一次只能執行一個指令，並且不能夠同時執行兩個指令，所以當你看到多執行緒與單執行緒你就可以瞭解差異，而且這單字其實也會出現在電腦硬體上唷。",[12,26,27],{"id":27},"同步執行",[16,29,30],{},[19,31],{"alt":27,"src":32},"https:\u002F\u002Fi.imgur.com\u002FStXnutN.png",[16,34,35],{},"同步執行的意思是說一次一個指令，而不是一次兩個指令甚至三個指令，而且是有一定的順序，那這也是最容易被誤解的關鍵字，當然這時候我們可能會第一直覺想到一個東西 asynchronous requests (非同步請求)，但是這章節只是提醒這兩個觀念，所以並不會特別講這個東西。",[12,37,38],{"id":38},"圖源",[16,40,41],{},[42,43,47],"a",{"href":44,"rel":45},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[46],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",{"title":49,"searchDepth":50,"depth":50,"links":51},"",2,[52,53,54],{"id":14,"depth":50,"text":14},{"id":27,"depth":50,"text":27},{"id":38,"depth":50,"text":38},"克服JS奇怪的部分系列","2019-05-15 22:00:35","單執行緒看起來是個很專業又複雜的術語，但簡單理解起來就是執行過程中只能一次執行一個指令，並不能同時執行兩個指令，所以當你看到多執行緒與單執行緒你就可以了解這差異了，而且這關鍵字也會出現在電腦硬體上。","md","zh-Hant",{},true,"\u002Fjavascript\u002Fjs-no-7","1",{"title":6,"description":57},false,"JavaScript 奇怪的部分\u002FJS奇怪的世界-No-7-觀念小提醒-單執行緒與同步執行",[68,69],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分",null,"\u002Fjsweirdworld\u002F20190515\u002F2013092431\u002F","rv8SzJpCjezTS2oIiiUqnBpZnbU4YONT8G6JNYGIBM4",{"newer":74,"older":78},{"url":75,"title":76,"date":77},"\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F","[JS奇怪的世界]No.8 函數呼叫與執行堆","2019-05-15 22:30:35",{"url":79,"title":80,"date":81},"\u002Fjsweirdworld\u002F20190515\u002F1176852332\u002F","[JS奇怪的世界]No.6 執行環境:程式執行","2019-05-15 21:57:35",[83,88,92],{"url":84,"title":85,"date":86,"readingMinutes":87},"\u002Fjsweirdworld\u002F20190527\u002F1292017914\u002F","[JS奇怪的世界]No.? 閉包番外篇","2019-05-27 13:50:04","3",{"url":89,"title":90,"date":91,"readingMinutes":63},"\u002Fjsweirdworld\u002F20190525\u002F3343743369\u002F","[JS奇怪的世界]No.68 JavaScript奇怪的部分","2019-05-25 16:36:00",{"url":93,"title":94,"date":95,"readingMinutes":96},"\u002Fjsweirdworld\u002F20190525\u002F1608378606\u002F","[JS奇怪的世界]No.67 增加jQuery的支援","2019-05-25 16:19:00","2",1784087357319]