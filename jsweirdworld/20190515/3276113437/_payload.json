[{"data":1,"prerenderedAt":326},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F":3,"page:\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F":4,"alt:\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F":303,"related:\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F":312},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F15\u002Fjs-weird-world-02-name-value-pairs-objects\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":285,"date":286,"description":287,"extension":288,"lang":289,"meta":290,"navigation":291,"path":292,"readingMinutes":293,"seo":294,"standalone":295,"stem":296,"tags":297,"tldr":300,"updated":300,"url":301,"__hash__":302},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-2-觀念小提醒-名稱 and 值配對與物件.md","[JS奇怪的世界]No.2 觀念小提醒:名稱 and 值配對與物件","3276113437",{"type":9,"value":10,"toc":280},"minimark",[11,16,24,27,30,63,66,69,85,92,109,112,117,120,123,155,165,168,174,177,255,258,264,267,276],[12,13,15],"h2",{"id":14},"名稱值-配對","名稱\u002F值 配對",[17,18,19],"p",{},[20,21],"img",{"alt":22,"src":23},"名稱\u002F值的組合","https:\u002F\u002Fi.imgur.com\u002FHPV57Gt.png",[17,25,26],{},"簡單來講一個名稱只會配對一個唯一的值，觀念就像一個變數只會配一個值，而值可以被定義值或是物件，所以一般狀況下名稱只會對上一個值。",[17,28,29],{},"舉例範例程式碼來講 ↓",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'hello';\n","js","",[38,39,40],"code",{"__ignoreMap":36},[41,42,45,49,53,56,60],"span",{"class":43,"line":44},"line",1,[41,46,48],{"class":47},"sWyjQ","var",[41,50,52],{"class":51},"sMAXC"," a ",[41,54,55],{"class":47},"=",[41,57,59],{"class":58},"sTRMh"," 'hello'",[41,61,62],{"class":51},";\n",[17,64,65],{},"而在這邊的觀念與「執行環境」也有關係，代表著正在執行中程式的名稱只會有一個，配對的值也只有一個，除非我們有去變動這個裡面的值。",[17,67,68],{},"例如現在正在執行中 ↓",[31,70,71],{"className":33,"code":34,"language":35,"meta":36,"style":36},[38,72,73],{"__ignoreMap":36},[41,74,75,77,79,81,83],{"class":43,"line":44},[41,76,48],{"class":47},[41,78,52],{"class":51},[41,80,55],{"class":47},[41,82,59],{"class":58},[41,84,62],{"class":51},[17,86,87,88,91],{},"然後我們要把值變成 ",[38,89,90],{},"'hello2'"," ↓",[31,93,95],{"className":33,"code":94,"language":35,"meta":36,"style":36},"a = 'hello2';\n",[38,96,97],{"__ignoreMap":36},[41,98,99,102,104,107],{"class":43,"line":44},[41,100,101],{"class":51},"a ",[41,103,55],{"class":47},[41,105,106],{"class":58}," 'hello2'",[41,108,62],{"class":51},[12,110,111],{"id":111},"物件",[17,113,114],{},[20,115],{"alt":111,"src":116},"https:\u002F\u002Fi.imgur.com\u002FGxj5WgC.png",[17,118,119],{},"物件這兩個字與 JavaScript 有非常大的關係，而物件本身也是一個名稱與值的配對組合。",[17,121,122],{},"舉例來講 ↓",[31,124,126],{"className":33,"code":125,"language":35,"meta":36,"style":36},"{\n name: 'Tom',\n}\n",[38,127,128,133,149],{"__ignoreMap":36},[41,129,130],{"class":43,"line":44},[41,131,132],{"class":51},"{\n",[41,134,136,140,143,146],{"class":43,"line":135},2,[41,137,139],{"class":138},"s_sBn"," name",[41,141,142],{"class":51},": ",[41,144,145],{"class":58},"'Tom'",[41,147,148],{"class":51},",\n",[41,150,152],{"class":43,"line":151},3,[41,153,154],{"class":51},"}\n",[17,156,157,160,161,164],{},[38,158,159],{},"name"," 就是一個名稱，",[38,162,163],{},"Tom","則是值。",[17,166,167],{},"物件在其他程式碼中有很多非常複雜的關係，但在 JavaScript 中不需要看得太複雜，在課程中也有相當不錯的範例我覺得不錯，物件就像這樣子。",[17,169,170],{},[20,171],{"alt":172,"src":173},"物件就是一個 name名稱","https:\u002F\u002Fi.imgur.com\u002FR6q5QAb.png",[17,175,176],{},"所以當我這樣寫你應該也能辨別出誰是名稱，而誰是值 ↓",[31,178,180],{"className":33,"code":179,"language":35,"meta":36,"style":36},"var a = {\n address: {\n  name:'tom',\n  ye: 3,\n  sweet: {\n   number: 100,\n  },\n },\n};\n",[38,181,182,193,198,208,220,226,237,243,249],{"__ignoreMap":36},[41,183,184,186,188,190],{"class":43,"line":44},[41,185,48],{"class":47},[41,187,52],{"class":51},[41,189,55],{"class":47},[41,191,192],{"class":51}," {\n",[41,194,195],{"class":43,"line":135},[41,196,197],{"class":51}," address: {\n",[41,199,200,203,206],{"class":43,"line":151},[41,201,202],{"class":51},"  name:",[41,204,205],{"class":58},"'tom'",[41,207,148],{"class":51},[41,209,211,214,218],{"class":43,"line":210},4,[41,212,213],{"class":51},"  ye: ",[41,215,217],{"class":216},"sCcAr","3",[41,219,148],{"class":51},[41,221,223],{"class":43,"line":222},5,[41,224,225],{"class":51},"  sweet: {\n",[41,227,229,232,235],{"class":43,"line":228},6,[41,230,231],{"class":51},"   number: ",[41,233,234],{"class":216},"100",[41,236,148],{"class":51},[41,238,240],{"class":43,"line":239},7,[41,241,242],{"class":51},"  },\n",[41,244,246],{"class":43,"line":245},8,[41,247,248],{"class":51}," },\n",[41,250,252],{"class":43,"line":251},9,[41,253,254],{"class":51},"};\n",[17,256,257],{},"簡單來講不要把 JavaScript 想的太複雜，簡單來看就好了，因為 JavaScript 就真的只是這樣。",[259,260,261],"blockquote",{},[17,262,263],{},"It's just that simple。",[12,265,266],{"id":266},"圖源",[17,268,269],{},[270,271,275],"a",{"href":272,"rel":273},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[274],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",[277,278,279],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":36,"searchDepth":135,"depth":135,"links":281},[282,283,284],{"id":14,"depth