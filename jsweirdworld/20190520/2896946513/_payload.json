.log(whattosay + ' ' + name);\n  }\n}\nvar sayHi = greet('Hi');\nconsole.log(sayHi);\nsayHi('Tony');\n",[33,323,324,336,348,364,368,372,388,398],{"__ignoreMap":31},[36,325,326,328,330,332,334],{"class":38,"line":39},[36,327,43],{"class":42},[36,329,47],{"class":46},[36,331,51],{"class":50},[36,333,55],{"class":54},[36,335,58],{"class":50},[36,337,338,340,342,344,346],{"class":38,"line":61},[36,339,64],{"class":42},[36,341,67],{"class":42},[36,343,51],{"class":50},[36,345,72],{"class":54},[36,347,58],{"class":50},[36,349,350,352,354,356,358,360,362],{"class":38,"line":77},[36,351,80],{"class":50},[36,353,83],{"class":46},[36,355,86],{"class":50},[36,357,89],{"class":42},[36,359,93],{"class":92},[36,361,96],{"class":42},[36,363,99],{"class":50},[36,365,366],{"class":38,"line":102},[36,367,105],{"class":50},[36,369,370],{"class":38,"line":108},[36,371,111],{"class":50},[36,373,374,376,378,380,382,384,386],{"class":38,"line":174},[36,375,275],{"class":42},[36,377,278],{"class":50},[36,379,281],{"class":42},[36,381,47],{"class":46},[36,383,51],{"class":50},[36,385,189],{"class":92},[36,387,198],{"class":50},[36,389,390,393,395],{"class":38,"line":181},[36,391,392],{"class":50},"console.",[36,394,83],{"class":46},[36,396,397],{"class":50},"(sayHi);\n",[36,399,401,403,405,407],{"class":38,"line":400},8,[36,402,294],{"class":46},[36,404,51],{"class":50},[36,406,299],{"class":92},[36,408,198],{"class":50},[16,410,411],{},[202,412],{"alt":294,"src":413},"https:\u002F\u002Fi.imgur.com\u002Fyz6Vdih.png",[16,415,416,417,419],{},"我們可以看到只有內部函數，但完全沒有看到 ",[33,418,55],{}," 的變數，那它到底是怎麼找到的?",[16,421,422,423,425,426,428],{},"首先當 ",[33,424,184],{}," 被執行時執行環境被建立，然後 ",[33,427,55],{}," 變數被傳入到環境內。",[16,430,431],{},[202,432],{"alt":184,"src":433},"https:\u002F\u002Fi.imgur.com\u002FE4WCefp.png",[16,435,436,437,439,440,442,443,445],{},"接下來當 ",[33,438,184],{}," 執行完畢後回傳了一個物件函數，所以 ",[33,441,184],{}," 就離開了執行堆並留下了 ",[33,444,55],{}," 的變數。",[16,447,448],{},[202,449],{"alt":55,"src":450},"https:\u002F\u002Fi.imgur.com\u002FPUgimZc.png",[16,452,453],{},"但是每一個執行環境都有屬於它自己的記憶體空間，所以若當執行環境消失了，記憶體空間會發生什麼事情呢?",[455,456,457],"blockquote",{},[16,458,459],{},"一般情況下會被清除，而這也稱之為垃圾回收 (Garbage collection)。",[16,461,462,463,466],{},"但是當執行環境結束時記憶體還是會存在那邊，雖然執行環境消失了，但變數一樣存在某處，然後就回到了全域環境狀況下，並開始執行 ",[33,464,465],{},"sayHi('Tony');","。",[16,468,469],{},[202,470],{"alt":294,"src":471},"https:\u002F\u002Fi.imgur.com\u002Fxbm7B7N.png",[16,473,474,475,477],{},"那這時候的 ",[33,476,465],{}," 是一個匿名函數，類似像這樣 ↓",[26,479,481],{"className":28,"code":480,"language":30,"meta":31,"style":31},"var sayHi = function(name) {\n  console.log(whattosay + ' ' + name);\n}\n",[33,482,483,501,518],{"__ignoreMap":31},[36,484,485,487,490,493,495,497,499],{"class":38,"line":39},[36,486,275],{"class":42},[36,488,489],{"class":46}," sayHi",[36,491,492],{"class":42}," =",[36,494,67],{"class":42},[36,496,51],{"class":50},[36,498,72],{"class":54},[36,500,58],{"class":50},[36,502,503,506,508,510,512,514,516],{"class":38,"line":61},[36,504,505],{"class":50},"  console.",[36,507,83],{"class":46},[36,509,86],{"class":50},[36,511,89],{"class":42},[36,513,93],{"class":92},[36,515,96],{"class":42},[36,517,99],{"class":50},[36,519,520],{"class":38,"line":77},[36,521,111],{"class":50},[16,523,524,525,528,529,531],{},"接下來當我們執行匿名函數後都知道會出現 ",[33,526,527],{},"console.log(whattosay + ' ' + name);","，但是我們會注意到裡面並沒有 ",[33,530,55],{}," 變數，所以 JavaScript 就會往外部環境去找，就是所謂的範圍鏈。",[16,533,534],{},[202,535],{"alt":536,"src":537},"範圍鏈","https:\u002F\u002Fi.imgur.com\u002FQfmSs2H.png",[16,539,540],{},"所以課程上有說明 JavaScript 為了避免我們找不到變數，所以會形成一個框框，將這一整個包住關起來，確保我們可以找的到東西。",[16,542,543],{},[202,544],{"alt":545,"src":546},"框框","https:\u002F\u002Fi.imgur.com\u002F6Tf0V6D.png",[16,548,549],{},"而這行為就是所謂的閉包。",[16,551,552],{},[202,553],{"alt":21,"src":554},"https:\u002F\u002Fi.imgur.com\u002Fn0JFpW3.png",[16,556,557],{},"而閉包只是 JavaScript 中的一個特色，確保我們找的到我們想要的東西而已，與我們何時呼叫函數並沒有任何直接關係。",[12,559,560],{"id":560},"圖源",[16,562,563],{},[564,565,569],"a",{"href":566,"rel":5