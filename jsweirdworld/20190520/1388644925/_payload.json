ine":86},[43,300,301],{"class":57},"console.",[43,303,67],{"class":53},[43,305,306],{"class":57},"(greetFunctionTwo);\n",[43,308,309],{"class":45,"line":93},[43,310,90],{"emptyLinePlaceholder":89},[43,312,314],{"class":45,"line":313},6,[43,315,317],{"class":316},"sQrFR","\u002F\u002F IIFE\n",[43,319,321,323,325,327,329,331,333],{"class":45,"line":320},7,[43,322,112],{"class":49},[43,324,115],{"class":53},[43,326,118],{"class":49},[43,328,121],{"class":49},[43,330,70],{"class":57},[43,332,214],{"class":213},[43,334,217],{"class":57},[43,336,338,340,342,344,346,348],{"class":45,"line":337},8,[43,339,64],{"class":57},[43,341,67],{"class":53},[43,343,70],{"class":57},[43,345,183],{"class":73},[43,347,231],{"class":49},[43,349,234],{"class":57},[43,351,353],{"class":45,"line":352},9,[43,354,190],{"class":57},[43,356,358],{"class":45,"line":357},10,[43,359,90],{"emptyLinePlaceholder":89},[43,361,363,365,367],{"class":45,"line":362},11,[43,364,301],{"class":57},[43,366,67],{"class":53},[43,368,369],{"class":57},"(greetFunction);\n",[16,371,372],{},[248,373],{"alt":148,"src":374},"https:\u002F\u002Fi.imgur.com\u002FPP8jvTk.png",[16,376,377],{},"我們可以發現不是使用 IIFE 會得到一整個函數，而 IIFE 直接會得到一個值，這也就是這兩者差異。",[16,379,380],{},"當然也有另一種撰寫方式。",[34,382,384],{"className":36,"code":383,"language":38,"meta":39,"style":39},"(function(name) {\n console.log('Hi' +  name)\n})('Jack');\n",[29,385,386,398,414],{"__ignoreMap":39},[43,387,388,390,392,394,396],{"class":45,"line":46},[43,389,70],{"class":57},[43,391,50],{"class":49},[43,393,70],{"class":57},[43,395,214],{"class":213},[43,397,217],{"class":57},[43,399,400,403,405,407,409,411],{"class":45,"line":61},[43,401,402],{"class":57}," console.",[43,404,67],{"class":53},[43,406,70],{"class":57},[43,408,183],{"class":73},[43,410,231],{"class":49},[43,412,413],{"class":57},"  name)\n",[43,415,416,419,421],{"class":45,"line":80},[43,417,418],{"class":57},"})(",[43,420,242],{"class":73},[43,422,77],{"class":57},[16,424,425],{},[248,426],{"alt":148,"src":427},"https:\u002F\u002Fi.imgur.com\u002FaURma5S.png",[16,429,430],{},"這也是人家講的匿名函數，我不需要名稱就可以直接執行的函數。",[16,432,433],{},"但若如果這樣呢?",[34,435,437],{"className":36,"code":436,"language":38,"meta":39,"style":39},"function(name) {\n console.log('Hi' +  name)\n}\n",[29,438,439,449,463],{"__ignoreMap":39},[43,440,441,443,445,447],{"class":45,"line":46},[43,442,50],{"class":49},[43,444,70],{"class":57},[43,446,214],{"class":213},[43,448,217],{"class":57},[43,450,451,453,455,457,459,461],{"class":45,"line":61},[43,452,402],{"class":57},[43,454,67],{"class":53},[43,456,70],{"class":57},[43,458,183],{"class":73},[43,460,231],{"class":49},[43,462,413],{"class":57},[43,464,465],{"class":45,"line":80},[43,466,83],{"class":57},[16,468,469],{},"你會得到一個錯誤。",[16,471,472],{},[248,473],{"alt":474,"src":475},"圖片","https:\u002F\u002Fi.imgur.com\u002FRMCJ23K.png",[16,477,478],{},"因為當語法解析器第一行解析到 f-u.... 就會一直解析，而它就會想說 「哦!這是一個函數陳述句，所以等一下應該會有一個名稱」，結果我們並沒有給予函數名稱，所以就會得到一個錯誤。",[16,480,481],{},"那如果不要讓語法解析器認為這是一個函數陳述句，那就要在函數陳述句外圍包上括號，當它解析到括號，它就會知道 「哦!這是一個函數表示式」，就像前面講的範例一樣。",[34,483,485],{"className":36,"code":484,"language":38,"meta":39,"style":39},"(function(name) {\n console.log('Hi' +  name)\n})\n",[29,486,487,499,513],{"__ignoreMap":39},[43,488,489,491,493,495,497],{"class":45,"line":46},[43,490,70],{"class":57},[43,492,50],{"class":49},[43,494,70],{"class":57},[43,496,214],{"class":213},[43,498,217],{"class":57},[43,500,501,503,505,507,509,511],{"class":45,"line":61},[43,502,402],{"class":57},[43,504,67],{"class":53},[43,506,70],{"class":57},[43,508,183],{"class":73},[43,510,231],{"class":49},[43,512,413],{"class":57},[43,514,515],{"class":45,"line":80},[43,516,517],{"class":57},"})\n",[16,519,520],{},"但是如果試著將這段程式碼貼上去執行會看到一個滿有趣的狀況。",[16,522,523],{},[248,524],{"alt":474,"src":525},"https:\u002F\u002Fi.imgur.com\u002FmBAkYrY.png",[16,527,528],{},"它直接回傳一個函數，所以如果我們要正確呼叫它就在最後加上括號，而括號內也可以帶上參數。",[34,530,532],{"className":36,"code":531,"language":38,"meta":39,"style":39},"(function(name) {\n console.lo