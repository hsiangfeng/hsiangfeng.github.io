[{"data":1,"prerenderedAt":231},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190521\u002F1329212743\u002F":3,"page:\u002Fjsweirdworld\u002F20190521\u002F1329212743\u002F":4,"alt:\u002Fjsweirdworld\u002F20190521\u002F1329212743\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190521\u002F1329212743\u002F":207,"related:\u002Fjsweirdworld\u002F20190521\u002F1329212743\u002F":216},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F21\u002Fjs-weird-world-48-everything-is-an-object\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":189,"date":190,"description":191,"extension":192,"lang":193,"meta":194,"navigation":195,"path":196,"readingMinutes":197,"seo":198,"standalone":199,"stem":200,"tags":201,"tldr":204,"updated":204,"url":205,"__hash__":206},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-48-所有東西都是物件(或純值).md","[JS奇怪的世界]No.48 所有東西都是物件(或純值)","1329212743",{"type":9,"value":10,"toc":184},"minimark",[11,15,19,22,26,29,89,95,102,105,110,116,121,124,129,135,140,143,148,151,157,160,165,168,171,180],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"現在我們知道物件原型，接著我們可以深入瞭解到一件事情 JavaScript 所有東西都是物件或是純值",[16,20,21],{},"數值、布林、字串、函數、陣列、物件他們都有原型，除了基本物件(base object)。",[12,23,25],{"id":24},"所有東西都是物件或純值","所有東西都是物件(或純值)",[16,27,28],{},"讓我們從範例來瞭解，接下將會利用這三個東西 物件、函數、陣列來講解為什麼所有東西都有原型。",[30,31,36],"pre",{"className":32,"code":33,"language":34,"meta":35,"style":35},"language-js shiki shiki-themes github-dark-high-contrast","var a = { };\nvar b = function() { };\nvar c = [];\n","js","",[37,38,39,58,76],"code",{"__ignoreMap":35},[40,41,44,48,52,55],"span",{"class":42,"line":43},"line",1,[40,45,47],{"class":46},"sWyjQ","var",[40,49,51],{"class":50},"sMAXC"," a ",[40,53,54],{"class":46},"=",[40,56,57],{"class":50}," { };\n",[40,59,61,63,67,70,73],{"class":42,"line":60},2,[40,62,47],{"class":46},[40,64,66],{"class":65},"sj_SG"," b",[40,68,69],{"class":46}," =",[40,71,72],{"class":46}," function",[40,74,75],{"class":50},"() { };\n",[40,77,79,81,84,86],{"class":42,"line":78},3,[40,80,47],{"class":46},[40,82,83],{"class":50}," c ",[40,85,54],{"class":46},[40,87,88],{"class":50}," [];\n",[16,90,91,92],{},"首先讓我們試著在瀏覽器輸入以上範例，然後再輸入 ",[37,93,94],{},"a.__proto__",[16,96,97],{},[98,99],"img",{"alt":100,"src":101},"Image","https:\u002F\u002Fi.imgur.com\u002FQLftT5u.png",[16,103,104],{},"我們會得到一個基本物件，這在原型鏈上非常底層，而這基本物件有屬性與方法。",[16,106,107],{},[98,108],{"alt":100,"src":109},"https:\u002F\u002Fi.imgur.com\u002FMg1ZB3g.png",[16,111,112,113],{},"那函數呢?我們試著輸入 ",[37,114,115],{},"b.__proto__",[16,117,118],{},[98,119],{"alt":100,"src":120},"https:\u002F\u002Fi.imgur.com\u002FpmQBFdh.png",[16,122,123],{},"這就是所有函數的原型，所有我們建立的函數都有這個原型，當然也有相關的屬性與方法(你會看到熟悉的 apply、call、bind)。",[16,125,126],{},[98,127],{"alt":100,"src":128},"https:\u002F\u002Fi.imgur.com\u002FiMaMKfa.png",[16,130,131,132],{},"接下來是陣列 ",[37,133,134],{},"c.__proto__",[16,136,137],{},[98,138],{"alt":100,"src":139},"https:\u002F\u002Fi.imgur.com\u002FsBamYwS.png",[16,141,142],{},"這就是一個原型陣列，我們也來看看它是否也有屬性與方法(這裡你也會看到許多熟悉的字眼)。",[16,144,145],{},[98,146],{"alt":100,"src":147},"https:\u002F\u002Fi.imgur.com\u002F75EshqI.png",[16,149,150],{},"所以由上面這三個範例我們可以知道一件事情。",[152,153,154],"blockquote",{},[16,155,156],{},"JavaScript 所有物件、所有陣列及所有函數都有原型。",[16,158,159],{},"那這邊在講一個好玩的問題，原型的原型是什麼?",[16,161,162],{},[98,163],{"alt":100,"src":164},"https:\u002F\u002Fi.imgur.com\u002Ful0CHwO.png",[16,166,167],{},"是原型，所以我們要記得，原型鏈最底下的東西就是原型物件。",[12,169,170],{"id":170},"圖源",[16,172,173],{},[174,175,179],"a",{"href":176,"rel":177},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[178],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",[181,182,183],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: v