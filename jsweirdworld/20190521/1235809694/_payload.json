[{"data":1,"prerenderedAt":134},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190521\u002F1235809694\u002F":3,"page:\u002Fjsweirdworld\u002F20190521\u002F1235809694\u002F":4,"alt:\u002Fjsweirdworld\u002F20190521\u002F1235809694\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190521\u002F1235809694\u002F":110,"related:\u002Fjsweirdworld\u002F20190521\u002F1235809694\u002F":119},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F21\u002Fjsweirdworld-46-classical-vs-prototypal-inheritance\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":92,"date":93,"description":94,"extension":95,"lang":96,"meta":97,"navigation":98,"path":99,"readingMinutes":100,"seo":101,"standalone":102,"stem":103,"tags":104,"tldr":107,"updated":107,"url":108,"__hash__":109},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-46-觀念小叮嚀-古典和原型繼承.md","[JS奇怪的世界]No.46 觀念小叮嚀:古典和原型繼承","1235809694",{"type":9,"value":10,"toc":86},"minimark",[11,15,23,26,29,32,48,51,54,65,68,74,77],[12,13,14],"h2",{"id":14},"古典和原型繼承",[16,17,18],"p",{},[19,20],"img",{"alt":21,"src":22},"圖片","https:\u002F\u002Fi.imgur.com\u002FTXOsIxM.png",[16,24,25],{},"繼承表示一個物件取用另一個物件屬性或方法，只要了解其簡單觀念就好了，許多人在解釋這區塊時常會用各種火車、汽車等等例子來做舉例，但講師認為直接講清楚會比較簡顯易懂。",[16,27,28],{},"那古典繼承和原型繼承是什麼呢?古典繼承在 C#、Java 裡都有，而且非常熱門。",[16,30,31],{},"而古典繼承裡面有非常多方法可以用",[33,34,35,39,42,45],"ul",{},[36,37,38],"li",{},"friend",[36,40,41],{},"protected",[36,43,44],{},"private",[36,46,47],{},"interface",[16,49,50],{},"但我們必須了解他才能夠知道該如何操作。",[16,52,53],{},"原型繼承呢?東西就簡單許多了",[33,55,56,59,62],{},[36,57,58],{},"彈性 (flexible)",[36,60,61],{},"可擴充性 (extensible)",[36,63,64],{},"簡單易懂 (east to understand)",[16,66,67],{},"古典和原型繼承各自都有他的好壞，所以並沒有一定，所以當有人在講繼承時，就是在講",[69,70,71],"blockquote",{},[16,72,73],{},"一個物件取用另一個物件屬性或方法",[12,75,76],{"id":76},"圖源",[16,78,79],{},[80,81,85],"a",{"href":82,"rel":83},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[84],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",{"title":87,"searchDepth":88,"depth":88,"links":89},"",2,[90,91],{"