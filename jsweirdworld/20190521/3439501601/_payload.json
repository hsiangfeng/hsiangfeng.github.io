\n\u002F\u002F 千萬不要使用這種方式在真正的專案開發上，這只是為了理解原型而已。\njohn.__proto__ = person;\nconsole.log(john.getFullName());\n",[29,318,319,329,337,345,355,373,377,381,385,395,403,411,415,422,437],{"__ignoreMap":163},[167,320,321,323,325,327],{"class":169,"line":170},[167,322,174],{"class":173},[167,324,178],{"class":177},[167,326,181],{"class":173},[167,328,184],{"class":177},[167,330,331,333,335],{"class":169,"line":187},[167,332,190],{"class":177},[167,334,194],{"class":193},[167,336,197],{"class":177},[167,338,339,341,343],{"class":169,"line":200},[167,340,203],{"class":177},[167,342,194],{"class":193},[167,344,197],{"class":177},[167,346,347,349,351,353],{"class":169,"line":210},[167,348,214],{"class":213},[167,350,217],{"class":177},[167,352,220],{"class":173},[167,354,223],{"class":177},[167,356,357,359,361,363,365,367,369,371],{"class":169,"line":226},[167,358,229],{"class":173},[167,360,233],{"class":232},[167,362,236],{"class":177},[167,364,239],{"class":173},[167,366,242],{"class":193},[167,368,245],{"class":173},[167,370,233],{"class":232},[167,372,250],{"class":177},[167,374,375],{"class":169,"line":253},[167,376,256],{"class":177},[167,378,379],{"class":169,"line":259},[167,380,262],{"class":177},[167,382,383],{"class":169,"line":265},[167,384,269],{"emptyLinePlaceholder":268},[167,386,387,389,391,393],{"class":169,"line":272},[167,388,174],{"class":173},[167,390,277],{"class":177},[167,392,181],{"class":173},[167,394,184],{"class":177},[167,396,397,399,401],{"class":169,"line":284},[167,398,190],{"class":177},[167,400,289],{"class":193},[167,402,197],{"class":177},[167,404,405,407,409],{"class":169,"line":294},[167,406,203],{"class":177},[167,408,299],{"class":193},[167,410,197],{"class":177},[167,412,413],{"class":169,"line":304},[167,414,262],{"class":177},[167,416,418],{"class":169,"line":417},13,[167,419,421],{"class":420},"sQrFR","\u002F\u002F 千萬不要使用這種方式在真正的專案開發上，這只是為了理解原型而已。\n",[167,423,425,428,431,434],{"class":169,"line":424},14,[167,426,427],{"class":177},"jo