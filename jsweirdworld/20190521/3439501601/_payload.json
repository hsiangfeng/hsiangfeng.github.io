[{"data":1,"prerenderedAt":749},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190521\u002F3439501601\u002F":3,"page:\u002Fjsweirdworld\u002F20190521\u002F3439501601\u002F":4,"alt:\u002Fjsweirdworld\u002F20190521\u002F3439501601\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190521\u002F3439501601\u002F":725,"related:\u002Fjsweirdworld\u002F20190521\u002F3439501601\u002F":734},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F21\u002Fjsweirdworld-47-understanding-prototypes\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":708,"date":709,"description":710,"extension":711,"lang":712,"meta":713,"navigation":268,"path":714,"readingMinutes":715,"seo":716,"standalone":717,"stem":718,"tags":719,"tldr":722,"updated":722,"url":723,"__hash__":724},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-47-瞭解原型.md","[JS奇怪的世界]No.47 瞭解原型","3439501601",{"type":9,"value":10,"toc":703},"minimark",[11,15,19,22,25,41,48,51,56,70,75,84,89,92,97,108,113,116,121,131,137,142,149,154,157,307,314,455,460,474,679,684,687,690,699],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"JavaScript 用了原型繼承，所以代表有個叫作原型（prototype）的概念。",[12,20,21],{"id":21},"瞭解原型",[16,23,24],{},"首先我們知道物件可以有屬性和方法，然後我們可以使用點運算子取得屬性或方法，JavaScript 中所有物件、函數，都有原型屬性，而這個屬性會參考到另一個屬性通常被稱為 proto。",[16,26,27,28,32,33,36,37,40],{},"假設今天我們有一個 ",[29,30,31],"code",{},"obj"," 的物件，底下有一個叫 ",[29,34,35],{},"prop1","，所以我們可以透過 ",[29,38,39],{},"obj.prop1"," 來取得。",[16,42,43],{},[44,45],"img",{"alt":46,"src":47},"圖片","https:\u002F\u002Fi.imgur.com\u002FGvbj9dX.png",[16,49,50],{},"JavaScript 中所有物件、函數，都有原型屬性。",[16,52,53],{},[44,54],{"alt":46,"src":55},"https:\u002F\u002Fi.imgur.com\u002FujtvRes.png",[16,57,58,59,62,63,65,66,69],{},"而這個屬性會參考到另一個物件，稱之為 proto，而 proto 也可以有屬性，例如 ",[29,60,61],{},"prop2","，所以當我們要取用 ",[29,64,61],{},"時就可以這樣寫 ",[29,67,68],{},"obj.prop2","。",[16,71,72],{},[44,73],{"alt":46,"src":74},"https:\u002F\u002Fi.imgur.com\u002FVq3wUOQ.png",[16,76,77,78,80,81,83],{},"而我們使用點運算子去取用 ",[29,79,31],{}," 中的 ",[29,82,61],{}," 時，會找不到，所以他會往原型裡面找。",[16,85,86],{},[44,87],{"alt":46,"src":88},"https:\u002F\u002Fi.imgur.com\u002FGGjQY6t.png",[16,90,91],{},"那原型物件也可以指向到另一個物件。",[16,93,94],{},[44,95],{"alt":46,"src":96},"https:\u002F\u002Fi.imgur.com\u002FoW5l7hH.png",[16,98,99,100,103,104,107],{},"每個物件都可以有自己的原型，當這個 proto 裡面有一個 ",[29,101,102],{},"prop3","，我們就可以用 ",[29,105,106],{},"obj.prop3"," 取得。",[16,109,110],{},[44,111],{"alt":46,"src":112},"https:\u002F\u002Fi.imgur.com\u002Fluirq2S.png",[16,114,115],{},"而這過程就像一個鏈子，所以又稱為原型鏈 (prototype chain)，但是不要把他跟範圍鏈搞混了，雖然很相似，可是範圍鏈是尋找可以取用的變數，但原型鏈是尋找屬性及方法。",[16,117,118],{},[44,119],{"alt":46,"src":120},"https:\u002F\u002Fi.imgur.com\u002FjLE3x65.png",[16,122,123,124,127,128,130],{},"而一般來講這 proto 是隱藏起來的，所以我們才不用這樣撰寫 ",[29,125,126],{},"obj.proto.proto.prop3","，只需要 ",[29,129,106],{}," 就好。",[16,132,133,134,136],{},"但是 JavaScript 中有一個很有趣的狀況，當若有第二個 ",[29,135,31],{}," 時，他可以指向同一個原型。",[16,138,139],{},[44,140],{"alt":46,"src":141},"https:\u002F\u002Fi.imgur.com\u002FwonD10e.png",[16,143,144,145,148],{},"所以當我們呼叫 ",[29,146,147],{},"obj2.prop2","，他一樣會回傳相同位子。",[16,150,151],{},[44,152],{"alt":46,"src":153},"https:\u002F\u002Fi.imgur.com\u002FNj43kat.png",[16,155,156],{},"而以上這些就是原型及原型鏈個概念，只需要想簡單一點只是有一個特別的參考到我們的物件而已，那接下來我們直接來看點範例。",[158,159,164],"pre",{"className":160,"code":161,"language":162,"meta":163,"style":163},"language-js shiki shiki-themes github-dark-high-contrast","var person = {\n  firstname: 'Default',\n  lastname: 'Default',\n  getFullName: function() {\n    return this.firstname + ' ' + this.lastname;\n  }\n}\n\nvar john = {\n  firstname: 'John',\n  lastname: 'Doe',\n}\n","js","",[29,165,166,185,198,208,224,251,257,263,270,282,292,302],{"__ignoreMap":163},[167,168,171,175,179,182],"span",{"class":169,"line":170},"line",1,[167,172,174],{"class":173},"sWyjQ","var",[167,176,178],{"class":177},"sMAXC"," person ",[167,180,181],{"class":173},"=",[167,183,184],{"class":177}," {\n",[167,186,188,191,195],{"class":169,"line":187},2,[167,189,190],{"class":177},"  