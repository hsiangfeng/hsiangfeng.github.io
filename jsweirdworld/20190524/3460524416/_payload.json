[{"data":1,"prerenderedAt":122},["ShallowReactive",2],{"header-locale:\u002Fjsweirdworld\u002F20190524\u002F3460524416\u002F":3,"page:\u002Fjsweirdworld\u002F20190524\u002F3460524416\u002F":4,"alt:\u002Fjsweirdworld\u002F20190524\u002F3460524416\u002F":3,"prev-next:\u002Fjsweirdworld\u002F20190524\u002F3460524416\u002F":98,"related:\u002Fjsweirdworld\u002F20190524\u002F3460524416\u002F":107},"\u002Fen\u002Fjsweirdworld\u002F2019\u002F05\u002F24\u002Fjs-weird-world-63-greetr-requirements\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":81,"date":82,"description":18,"extension":83,"lang":84,"meta":85,"navigation":86,"path":87,"readingMinutes":88,"seo":89,"standalone":90,"stem":91,"tags":92,"tldr":95,"updated":95,"url":96,"__hash__":97},"content\u002FJavaScript 奇怪的部分\u002FJS奇怪的世界-No-63-需求.md","[JS奇怪的世界]No.63 需求","3460524416",{"type":9,"value":10,"toc":74},"minimark",[11,15,19,22,25,28,35,59,62,65],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"在前面章節已經大致上瞭解 jQuery 之後當然就是要準備親手動手做做看自己的框架。",[12,20,21],{"id":21},"需求",[16,23,24],{},"首先我們可以利用已經學過的知識來打造自己的小框架，而這小框架也可以實際應用，可是起手應該要先命名一下自己的框架。",[16,26,27],{},"在這邊將會製作一個簡單、簡易的框架，所以也會跟課程一樣叫 GREETR，那功能要那些?",[16,29,30],{},[31,32],"img",{"alt":33,"src":34},"圖片","https:\u002F\u002Fi.imgur.com\u002FVxiKXDv.png",[36,37,38,42,45,48,51],"ul",{},[39,40,41],"li",{},"當登入的時候會出現一個 Hello。",[39,43,44],{},"若給予姓名就會給予一個正式的打招呼與非正式的打招呼。",[39,46,47],{},"支援英文及西班牙語。",[39,49,50],{},"可以重複使用。",[39,52,53,54,58],{},"最後雖然它叫做 GREETR，但在呼叫的時候是 ",[55,56,57],"code",{},"G$()","。",[16,60,61],{},"那 GREETR 必須支援 jQuery，雖然它會回傳問候語，但其實是回傳 jQuery，以上這些就是準備打照的需求。",[12,63,64],{"id":64},"圖源",[16,66,67],{},[68,69,73],"a",{"href":70,"rel":71},"https:\u002F\u002Fwww.udemy.com\u002Fjavascriptjs\u002F",[72],"nofollow","JavaScript 全攻略:克服 JS 奇怪的部分",{"title":75,"searchDepth":76,"depth":76,"links":77},"",2,[78,79,80],{"id":14,"depth":76,"text":14},{"id":21,"depth":76,"text":21},{"id":64,"depth":76,"text":64},"克服JS奇怪的部分系列","2019-05-24 21:30:00","md","zh-Hant",{},tru