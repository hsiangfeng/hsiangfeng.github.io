{"class":73},[30,295,77],{"class":69},[30,297,279],{"class":73},[30,299,300],{"class":69},"-",[30,302,303],{"class":73}," price;\n",[30,305,306],{"class":65,"line":115},[30,307,178],{"class":73},[30,309,310,312,315,317,320],{"class":65,"line":133},[30,311,70],{"class":69},[30,313,314],{"class":73}," count ",[30,316,77],{"class":69},[30,318,319],{"class":73}," myMoney; ",[30,321,323],{"class":322},"sQrFR","\u002F\u002F 計算後將結果儲存在 count 變數中\n",[30,325,326],{"class":65,"line":145},[30,327,328],{"class":322},"\u002F\u002F 小明花了 100$\n",[30,330,331,334,336,339],{"class":65,"line":169},[30,332,333],{"class":93},"count",[30,335,124],{"class":73},[30,337,338],{"class":284},"100",[30,340,130],{"class":73},[30,342,343],{"class":65,"line":175},[30,344,345],{"class":322},"\u002F\u002F 小美花了 50$\n",[30,347,349,351,353,356],{"class":65,"line":348},9,[30,350,333],{"class":93},[30,352,124],{"class":73},[30,354,355],{"class":284},"50",[30,357,130],{"class":73},[30,359,361],{"class":65,"line":360},10,[30,362,363],{"class":322},"\u002F\u002F 小王花了 700$\n",[30,365,367,369,371,374],{"class":65,"line":366},11,[30,368,333],{"class":93},[30,370,124],{"class":73},[30,372,373],{"class":284},"700",[30,375,130],{"class":73},[16,377,378],{},"我們會發現一件事情，結果與我們所想的並不一樣 ↓",[16,380,381],{},[200,382],{"alt":90,"src":383},"https:\u002F\u002Fi.imgur.com\u002FY8rH5ev.png",[16,385,386,387,390,391,394,395,398],{},"原因是出在每一次執行 ",[61,388,389],{},"count();"," 時，JavaScript 都會重新宣告一個新變數叫 ",[61,392,393],{},"money","，並且值是 ",[61,396,397],{},"1000","，雖然我們有將回傳的變數給做紀錄，但其實當函數執行完畢後，裡面的變數就跟著被釋放掉，所以如果這是我們所希望的結果那這個答案就沒有錯，可是今天我們的題目是大家共同持有 1000$，各自花了錢之後錢包會剩下 150$，所以這時候就要使用 closure 的技巧來解決這個問題，因為我們需要將變數結果給保留下來。",[54,400,402],{"className":56,"code":401,"language":58,"meta":59,"style":59},"function myMoney() {\n  var money = 1000;\n  return function(price) {\n    return money = money - price;\n  }\n}\n\nvar count = myMoney();\n\u002F\u002F 小明花了 100$\ncount(100);\n\u002F\u002F 小美花了 50$\ncount(50);\n\u002F\u002F 小王花了 700$\ncount(700);\n