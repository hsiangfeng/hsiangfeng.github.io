s","",[61,62,63,85,98,113,131,143,167,173],"code",{"__ignoreMap":59},[30,64,67,71,75,78,82],{"class":65,"line":66},"line",1,[30,68,70],{"class":69},"sWyjQ","var",[30,72,74],{"class":73},"sMAXC"," a ",[30,76,77],{"class":69},"=",[30,79,81],{"class":80},"sTRMh"," 'Window'",[30,83,84],{"class":73},";\n",[30,86,88,91,95],{"class":65,"line":87},2,[30,89,90],{"class":69},"function",[30,92,94],{"class":93},"sj_SG"," sayHi",[30,96,97],{"class":73}," (){\n",[30,99,101,104,106,108,111],{"class":65,"line":100},3,[30,102,103],{"class":69},"  var",[30,105,74],{"class":73},[30,107,77],{"class":69},[30,109,110],{"class":80}," 'Closure'",[30,112,84],{"class":73},[30,114,116,119,122,125,128],{"class":65,"line":115},4,[30,117,118],{"class":73},"  console.",[30,120,121],{"class":93},"log",[30,123,124],{"class":73},"(",[30,126,127],{"class":80},"'now is Function.'",[30,129,130],{"class":73},");\n",[30,132,134,137,140],{"class":65,"line":133},5,[30,135,136],{"class":69},"  return",[30,138,139],{"class":69}," function",[30,141,142],{"class":73}," () {\n",[30,144,146,149,151,153,156,159,162,164],{"class":65,"line":145},6,[30,147,148],{"class":73},"    console.",[30,150,121],{"class":93},[30,152,124],{"class":73},[30,154,155],{"class":80},"'Hello'",[30,157,158],{"class":69}," +",[30,160,161],{"class":80}," ' '",[30,163,158],{"class":69},[30,165,166],{"class":73}," a);\n",[30,168,170],{"class":65,"line":169},7,[30,171,172],{"class":73},"  }\n",[30,174,176],{"class":65,"line":175},8,[30,177,178],{"class":73},"}\n",[16,180,181,182,185,186,188,189,192,193,196],{},"那要執行的方式就是 ",[61,183,184],{},"sayHi()","，如果要執行閉包中的 ",[61,187,90],{}," 就是兩個括號 ",[61,190,191],{},"sayHi()()","，這邊會出現兩個 ",[61,194,195],{},"console"," 是正常的，我故意這麼做的 ↓",[16,198,199],{},[200,201],"img",{"alt":202,"src":203},"Closure","https:\u002F\u002Fi.imgur.com\u002FXgZvDPr.png",[205,206,212],"iframe",{"height":207,"style":208,"scrolling":209,"title":202,"src":210,"frameBorder":209,"allowTransparency":211,"allowFullScreen":211},265,"width