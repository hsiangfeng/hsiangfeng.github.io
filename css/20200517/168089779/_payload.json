獨立出來，舉例來講",[43,435,437],{"className":96,"code":436,"language":98,"meta":48,"style":48},".btn {\n  width: 20px;\n  height: 100px;\n  color: red;\n  background-color: red;\n}\n",[50,438,439,446,459,472,482,493],{"__ignoreMap":48},[53,440,441,444],{"class":55,"line":56},[53,442,443],{"class":67},".btn",[53,445,108],{"class":59},[53,447,448,450,452,455,457],{"class":55,"line":111},[53,449,129],{"class":67},[53,451,117],{"class":59},[53,453,454],{"class":67},"20",[53,456,138],{"class":137},[53,458,123],{"class":59},[53,460,461,463,465,468,470],{"class":55,"line":126},[53,462,146],{"class":67},[53,464,117],{"class":59},[53,466,467],{"class":67},"100",[53,469,138],{"class":137},[53,471,123],{"class":59},[53,473,474,476,478,480],{"class":55,"line":143},[53,475,114],{"class":67},[53,477,117],{"class":59},[53,479,178],{"class":67},[53,481,123],{"class":59},[53,483,484,487,489,491],{"class":55,"line":157},[53,485,486],{"class":67},"  background-color",[53,488,117],{"class":59},[53,490,178],{"class":67},[53,492,123],{"class":59},[53,494,495],{"class":55,"line":163},[53,496,160],{"class":59},[16,498,499],{},"我們會將樣式的 CSS 拉出來增加樣式的可用性",[43,501,503],{"className":96,"code":502,"language":98,"meta":48,"style":48},".btn-red {\n  color: red;\n  background-color: red;\n}\n\n.btn {\n  width: 20px;\n  height: 100px;\n}\n",[50,504,505,512,522,532,536,540,546,558,570],{"__ignoreMap":48},[53,506,507,510],{"class":55,"line":56},[53,508,509],{"class":67},".btn-red",[53,511,108],{"class":59},[53,513,514,516,518,520],{"class":55,"line":111},[53,515,114],{"class":67},[53,517,117],{"class":59},[53,519,178],{"class":67},[53,521,123],{"class":59},[53,523,524,526,528,530],{"class":55,"line":126},[53,525,486],{"class":67},[53,527,117],{"class":59},[53,529,178],{"class":67},[53,531,123],{"class":59},[53,533,534],{"class":55,"line":143},[53,535,160],{"class":59},[53,537,538],{"class":55,"line":157},[53,539,331],{"emptyLinePlaceholder":330},[53,541,542,544],{"class":55,"line":163},[53,543,443],{"class":67