立可套用於他處。",[16,433,434],{},"稍等一下，有沒有覺得與 SMACSS Module 很雷同？沒有錯，但在 OOCSS 中只有一個重點，只要你是樣式，就會被獨立出來，舉例來講",[43,436,438],{"className":96,"code":437,"language":98,"meta":48,"style":48},".btn {\n  width: 20px;\n  height: 100px;\n  color: red;\n  background-color: red;\n}\n",[50,439,440,447,460,473,483,494],{"__ignoreMap":48},[53,441,442,445],{"class":55,"line":56},[53,443,444],{"class":67},".btn",[53,446,108],{"class":59},[53,448,449,451,453,456,458],{"class":55,"line":111},[53,450,130],{"class":114},[53,452,118],{"class":59},[53,454,455],{"class":114},"20",[53,457,139],{"class":138},[53,459,124],{"class":59},[53,461,462,464,466,469,471],{"class":55,"line":127},[53,463,147],{"class":114},[53,465,118],{"class":59},[53,467,468],{"class":114},"100",[53,470,139],{"class":138},[53,472,124],{"class":59},[53,474,475,477,479,481],{"class":55,"line":144},[53,476,115],{"class":114},[53,478,118],{"class":59},[53,480,179],{"class":114},[53,482,124],{"class":59},[53,484,485,488,490,492],{"class":55,"line":158},[53,486,487],{"class":114},"  background-color",[53,489,118],{"class":59},[53,491,179],{"class":114},[53,493,124],{"class":59},[53,495,496],{"class":55,"line":164},[53,497,161],{"class":59},[16,499,500],{},"我們會將樣式的 CSS 拉出來增加樣式的可用性",[43,502,504],{"className":96,"code":503,"language":98,"meta":48,"style":48},".btn-red {\n  color: red;\n  background-color: red;\n}\n\n.btn {\n  width: 20px;\n  height: 100px;\n}\n",[50,505,506,513,523,533,537,541,547,559,571],{"__ignoreMap":48},[53,507,508,511],{"class":55,"line":56},[53,509,510],{"class":67},".btn-red",[53,512,108],{"class":59},[53,514,515,517,519,521],{"class":55,"line":111},[53,516,115],{"class":114},[53,518,118],{"class":59},[53,520,179],{"class":114},[53,522,124],{"class":59},[53,524,525,527,529,531],{"class":55,"line":127},[53,526,487],{"class":114},[53,528,118],{"class":59},[53,530,179],{"class":114},[53,532,124],{"class":59},[53,534,535],{"class":55,"line":144},[53,536,161],{"class":59},[53,538,539],{"class":55,"line":158},[53,540