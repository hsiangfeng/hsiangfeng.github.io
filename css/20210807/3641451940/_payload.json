[{"data":1,"prerenderedAt":1383},["ShallowReactive",2],{"header-locale:\u002Fcss\u002F20210807\u002F3641451940\u002F":3,"page:\u002Fcss\u002F20210807\u002F3641451940\u002F":4,"alt:\u002Fcss\u002F20210807\u002F3641451940\u002F":3,"prev-next:\u002Fcss\u002F20210807\u002F3641451940\u002F":1360,"related:\u002Fcss\u002F20210807\u002F3641451940\u002F":1369},"\u002Fen\u002Fcss\u002F2021\u002F08\u002F07\u002Freset-css-vs-normalize-css\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1345,"date":1346,"description":18,"extension":1347,"lang":1348,"meta":1349,"navigation":90,"path":1350,"readingMinutes":1351,"seo":1352,"standalone":1353,"stem":1354,"tags":1355,"tldr":1357,"updated":1357,"url":1358,"__hash__":1359},"content\u002FCSS\u002FReset-CSS-與-Normalize-css-差異.md","Reset CSS 與 Normalize.css 差異","3641451940",{"type":9,"value":10,"toc":1334},"minimark",[11,15,19,23,34,49,880,887,890,895,898,901,904,989,1008,1012,1015,1026,1034,1037,1047,1053,1121,1127,1169,1172,1175,1260,1262,1265,1274,1277,1281,1284,1287,1290,1293,1296,1299,1302,1305,1308,1311,1330],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"很久很久沒有寫跟 CSS 相關的文章了，所以這一篇就稍微寫一下 Reset CSS 跟 Normalize.css 的差異。",[12,20,22],{"id":21},"reset-css-meyerweb-css","Reset CSS (meyerweb CSS)",[16,24,25,26,33],{},"講 Reset CSS 或許你會沒有印象，但是如果我講 ",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Fmeyerweb.com\u002Feric\u002Ftools\u002Fcss\u002Freset\u002F",[31],"nofollow","meyerweb"," CSS 或許會比較有印象一點，那麼顧名思義這是一個重置 CSS 的 CSS 樣式表。",[16,35,36,37,41,42,44,45,48],{},"最知名的 Reset CSS 就是 meyerweb 的版本，那麼為什麼會需要重置 CSS 呢？最主要原因是每一個瀏覽器所使用的 HTML 預設樣式皆不同，或許你在 Firefox 上看到的 ",[38,39,40],"code",{},"table"," 標籤是有線條的，但是在 Chrome 卻又是無線條的，更不用說 IE、Edge 可能 ",[38,43,40],{}," 有 ",[38,46,47],{},"margin-top: 10px","(向上推擠 10 px) 等等狀況，那麼如果我們不統一全部瀏覽器樣式的話，屆時我們在製作前端畫面時就會顯得很痛苦，而 Eric A. Meyer 也就是撰寫 Reset CSS 的作者就整理了一份 Reset CSS",[50,51,56],"pre",{"className":52,"code":53,"language":54,"meta":55,"style":55},"language-css shiki shiki-themes github-ligh