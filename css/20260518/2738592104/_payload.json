[{"data":1,"prerenderedAt":756},["ShallowReactive",2],{"header-locale:\u002Fcss\u002F20260518\u002F2738592104\u002F":3,"page:\u002Fcss\u002F20260518\u002F2738592104\u002F":4,"alt:\u002Fcss\u002F20260518\u002F2738592104\u002F":3,"prev-next:\u002Fcss\u002F20260518\u002F2738592104\u002F":732,"related:\u002Fcss\u002F20260518\u002F2738592104\u002F":741},"\u002Fen\u002Fcss\u002F2026\u002F05\u002F18\u002Foverflow-scroll-no-scrollbar-macos-chrome-vs-windows\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":712,"date":713,"description":714,"extension":715,"lang":716,"meta":717,"navigation":349,"path":718,"readingMinutes":719,"seo":720,"standalone":721,"stem":722,"tags":723,"tldr":729,"updated":713,"url":730,"__hash__":731},"content\u002FCSS\u002F為什麼-overflow-scroll-看不到捲軸-macOS-跟-Windows-的-Chrome-差異.md","為什麼 CSS overflow: scroll 看不到捲軸？macOS 跟 Windows 的 Chrome 差異","2738592104",{"type":9,"value":10,"toc":695},"minimark",[11,18,22,34,38,44,55,62,75,81,86,91,151,166,170,181,184,188,191,197,200,206,209,222,225,229,232,238,241,245,248,256,270,467,470,473,486,490,503,578,599,605,625,629,636,639,648,651,662,665,671,680,691],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fcss\u002FChatGPT%20Image%202026%E5%B9%B45%E6%9C%8821%E6%97%A5%20%E4%B8%8A%E5%8D%8811_49_22.png",[19,20,21],"h2",{"id":21},"前言",[12,23,24,25,29,30,33],{},"相信很多寫 CSS 的人都有遇過這個情境，明明在自己的元素上加了 ",[26,27,28],"code",{},"overflow: scroll","，但打開 Chrome 卻看不到捲軸，傳給同事看，他那邊卻又跑出一條灰灰的捲軸，明明用的都是 Chrome，怎麼會有這種差異？這一篇就從 ",[26,31,32],{},"overflow"," 屬性是什麼開始講。",[19,35,37],{"id":36},"先聊聊-overflow-是什麼","先聊聊 overflow 是什麼",[12,39,40,41,43],{},"在分析問題之前，先稍微回顧一下 ",[26,42,32],{}," 這個屬性是什麼。",[12,45,46,47,49,50,54],{},"簡單來講，",[26,48,32],{}," 是用來決定",[51,52,53],"strong",{},"當一個元素裡面的內容超出它本身的寬高時，要怎麼處理那一段超出的部分","，這個屬性算是 CSS 裡面非常基本但又非常常用的東西。",[12,56,57,58,61],{},"舉個例子，假設我有一個寬 200px、高 100px 的 ",[26,59,60],{},"div","，但裡面塞了一段超長的文字 or 一張比 200px 還寬的圖片，這時候畫面就會發生兩件事：",[63,64,65,69,72],"ul",{},[66,67,68],"li",{},"內容直接跑出（溢出）容器到外面去",[66,70,71],{},"內容被切掉，看不到後面那一段",[66,73,74],{},"出現捲軸，讓使用者自己滾動",[12,76,77,78,80],{},"那這要怎麼解決呢？那就要來講講 ",[26,79,32],{}," 了。",[82,83,85],"h3",{"id":84},"overflow-的四個常見屬性","overflow 的四個常見屬性",[12,87,88,90],{},[26,89,32],{}," 屬性有四個比較常用的屬性，這邊用一張表格快速看一下：",[92,93,94,107],"table",{},[95,96,97],"thead",{},[98,99,100,104],"tr",{},[101,102,103],"th",{},"屬性",[101,105,106],{},"用途",[108,109,110,121,131,141],"tbody",{},[98,111,112,118],{},[113,114,115],"td",{},[26,116,117],{},"visible",[113,119,120],{},"預設屬性，當內容超出容器範圍就會讓它跑出去，不做任何處理。",[98,122,123,128],{},[113,124,125],{},[26,126,127],{},"hidden",[113,129,130],{},"內容超出的部分直接被切掉，看不到也沒辦法捲動。",[98,132,133,138],{},[113,134,135],{},[26,136,137],{},"scroll",[113,139,140],{},"不管內容有沒有超出，都保留捲軸的位置一直顯示捲軸。",[98,142,143,148],{},[113,144,145],{},[26,146,147],{},"auto",[113,149,150],{},"只有當內容真的超出時，捲軸才會出現。",[12,152,153,154,156,157,159,160,162,163,165],{},"這邊要特別拉 ",[26,155,137],{}," 跟 ",[26,158,147],{}," 出來講，因為這兩個屬性最容易搞混，但它們兩者差異只有一個小地方，也就是 ",[26,161,137],{}," 是「永遠都會出現捲軸」，但 ",[26,164,147],{}," 則是「內容超出時，需要才會出現捲軸」。",[19,167,169],{"id":168},"那為什麼-overflow-scroll-在我電腦上看不到捲軸","那為什麼 overflow: scroll 在我電腦上看不到捲軸？",[12,171,172,173,176,177,180],{},"這是因為 macOS 預設使用的是 ",[51,174,175],{},"「隱形捲軸（Overlay Scrollbar）」","，這種捲軸只有在你正在捲動時才會浮現出來，平常是隱藏的，而且不會占據版面的空間。但你同事如果是用 Windows，那邊的捲軸是 ",[51,178,179],{},"「古典捲軸（Classic Scrollbar）」","，會固定保留位置而且永遠看得到。",[12,182,183],{},"所以兩個人開同一個網頁、同一個版本的 Chrome，但看到的視覺結果就會不同，根本原因不是 Chrome 不一樣，而是底下的作業系統不一樣。",[82,185,187],{"id":186},"macos-的隱形捲軸","macOS 的「隱形捲軸」",[12,189,190],{},"在 macOS 上，捲軸的顯示行為是由系統設定決定的，查看方式是「設定 → 外觀 → 顯示捲軸」，這邊有三個選項可以選：",[12,192,193],{},[15,194],{"alt":195,"src":196},"macOS 系統設定中的顯示捲軸選項","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fcss\u002F20260521112123.png",[12,198,199],{},"通常預設屬性是「自動依揵滑鼠或觸控式軌跡板」，也就是當你用的是觸控板 or Mac 內建的軌跡板時，它就會走「捲動時」的行為，有點饒舌對吧？簡單來講，也就是平常完全看不到捲軸，只有你在捲的當下會浮出一條半透明的細條，停下來幾秒它又會自動淡出消失。",[12,201,202,203,205],{},"而 Chrome、Safari 跟其他大多數的 Mac 瀏覽器，預設都會跟著這個系統設定走，所以即便你在 CSS 寫了 ",[26,204,28],{},"，瀏覽器還是會用「隱形捲軸」的方式渲染，不會把捲軸固定地顯示在那邊。",[12,207,208],{},"那要怎麼確認到底是不是這個原因呢？很簡單，你只要走兩個步驟驗證：",[210,211,212,219],"ol",{},[66,213,214,215,218],{},"把 macOS 的**「顯示捲軸」",[51,216,217],{},"切到","「總是」**",[66,220,221],{},"重新整理一下你的瀏覽器（或者重新開啟）",[12,223,224],{},"這時候捲軸就會直接固定地出現了，這代表 CSS 沒寫錯，是作業系統的設定在控制視覺呈現。",[82,226,228],{"id":227},"為什麼-windows-沒這個問題","為什麼 Windows 沒這個問題？",[12,230,231],{},"因為 Windows 從以前到現在都是用「古典捲軸」，捲軸會固定占住版面右側（大約 15 ~ 17px 寬），不管你有沒有在捲都看得到，也不會自動淡出消失。",[12,233,234,235,237],{},"所以你同事打開同一個頁面時，那條灰灰的細長捲軸就直接掛在右邊，他寫的 ",[26,236,28],{}," 看起來就是 CSS 預期的樣子，沒有「捲軸到底跑去哪了」的疑問。",[12,239,240],{},"這邊順便提一個容易忽略的點，如果你都在 Mac 上開發、可是實際使用者大多用 Windows，那你看到的內容寬度其實會比使用者那邊還多一段（被捲軸吃掉的那段）。做 RWD 切版時，建議借同事的 Windows 開一下看看版面有沒有跑掉，免得交付後才發現右邊有點擠。",[19,242,244],{"id":243},"那怎麼讓兩邊看起來一樣","那怎麼讓兩邊看起來一樣？",[12,246,247],{},"如果你希望不管使用者用什麼系統都看得到捲軸（例如怕 Mac 使用者根本不知道內容還可以往下捲），這邊有幾種做法可以選：",[82,249,251,252,255],{"id":250},"方法一用-webkit-scrollbar-強制顯示","方法一：用 ",[26,253,254],{},"::-webkit-scrollbar"," 強制顯示",[12,257,258,259,261,262,265,266,269],{},"最直接的做法是用 ",[26,260,254],{}," 這個 CSS 偽元素去自訂捲軸樣式，只要你給它一個明確的 ",[26,263,264],{},"width"," 或 ",[26,267,268],{},"height","，Chrome 就會自動把這個元素的捲軸從隱形捲軸切換成古典捲軸，永遠固定顯示。",[271,272,277],"pre",{"className":273,"code":274,"language":275,"meta":276,"style":276},"language-css shiki shiki-themes github-dark-high-contrast",".scroll-box {\n  width: 300px;\n  height: 200px;\n  overflow: scroll;\n}\n\n.scroll-box::-webkit-scrollbar {\n  width: 8px;\n  height: 8px;\n}\n\n.scroll-box::-webkit-scrollbar-thumb {\n  background-color: #888;\n  border-radius: 4px;\n}\n\n.scroll-box::-webkit-scrollbar-track {\n  background-color: #f0f0f0;\n}\n","css","",[26,278,279,292,311,326,338,344,351,359,373,386,391,396,404,417,432,437,442,450,462],{"__ignoreMap":276},[280,281,284,288],"span",{"class":282,"line":283},"line",1,[280,285,287],{"class":286},"sCcAr",".scroll-box",[280,289,291],{"class":290},"sMAXC"," {\n",[280,293,295,298,301,304,308],{"class":282,"line":294},2,[280,296,297],{"class":286},"  width",[280,299,300],{"class":290},": ",[280,302,303],{"class":286},"300",[280,305,307],{"class":306},"sWyjQ","px",[280,309,310],{"class":290},";\n",[280,312,314,317,319,322,324],{"class":282,"line":313},3,[280,315,316],{"class":286},"  height",[280,318,300],{"class":290},[280,320,321],{"class":286},"200",[280,323,307],{"class":306},[280,325,310],{"class":290},[280,327,329,332,334,336],{"class":282,"line":328},4,[280,330,331],{"class":286},"  overflow",[280,333,300],{"class":290},[280,335,137],{"class":286},[280,337,310],{"class":290},[280,339,341],{"class":282,"line":340},5,[280,342,343],{"class":290},"}\n",[280,345,347],{"class":282,"line":346},6,[280,348,350],{"emptyLinePlaceholder":349},true,"\n",[280,352,354,357],{"class":282,"line":353},7,[280,355,356],{"class":286},".scroll-box::-webkit-scrollbar",[280,358,291],{"class":290},[280,360,362,364,366,369,371],{"class":282,"line":361},8,[280,363,297],{"class":286},[280,365,300],{"class":290},[280,367,368],{"class":286},"8",[280,370,307],{"class":306},[280,372,310],{"class":290},[280,374,376,378,380,382,384],{"class":282,"line":375},9,[280,377,316],{"class":286},[280,379,300],{"class":290},[280,381,368],{"class":286},[280,383,307],{"class":306},[280,385,310],{"class":290},[280,387,389],{"class":282,"line":388},10,[280,390,343],{"class":290},[280,392,394],{"class":282,"line":393},11,[280,395,350],{"emptyLinePlaceholder":349},[280,397,399,402],{"class":282,"line":398},12,[280,400,401],{"class":286},".scroll-box::-webkit-scrollbar-thumb",[280,403,291],{"class":290},[280,405,407,410,412,415],{"class":282,"line":406},13,[280,408,409],{"class":286},"  background-color",[280,411,300],{"class":290},[280,413,414],{"class":286},"#888",[280,416,310],{"class":290},[280,418,420,423,425,428,430],{"class":282,"line":419},14,[280,421,422],{"class":286},"  border-radius",[280,424,300],{"class":290},[280,426,427],{"class":286},"4",[280,429,307],{"class":306},[280,431,310],{"class":290},[280,433,435],{"class":282,"line":434},15,[280,436,343],{"class":290},[280,438,440],{"class":282,"line":439},16,[280,441,350],{"emptyLinePlaceholder":349},[280,443,445,448],{"class":282,"line":444},17,[280,446,447],{"class":286},".scroll-box::-webkit-scrollbar-track",[280,449,291],{"class":290},[280,451,453,455,457,460],{"class":282,"line":452},18,[280,454,409],{"class":286},[280,456,300],{"class":290},[280,458,459],{"class":286},"#f0f0f0",[280,461,310],{"class":290},[280,463,465],{"class":282,"line":464},19,[280,466,343],{"class":290},[12,468,469],{},"寫完之後你會發現 Mac 上的 Chrome 終於把捲軸固定顯示出來了，而且因為它已經變成古典捲軸，會吃掉一段內容寬度，這時候版面就會跟 Windows 上看到的比較接近。",[12,471,472],{},"可是這個做法有兩個小坑要記得：",[63,474,475,480],{},[66,476,477,479],{},[26,478,254],{}," 是 Webkit \u002F Blink 系列才支援的非標準屬性，Chrome、Edge、Safari、Opera 都吃，可是 Firefox 不吃",[66,481,482,483,485],{},"iOS Safari 對 ",[26,484,254],{}," 的支援也很有限，大部分情況下還是會走系統的隱形捲軸",[82,487,489],{"id":488},"方法二用標準化的-scrollbar-width-跟-scrollbar-color","方法二：用標準化的 scrollbar-width 跟 scrollbar-color",[12,491,492,493,156,496,499,500,502],{},"如果你不想用非標準屬性，CSS 後來也有把捲軸樣式標準化，新增了 ",[26,494,495],{},"scrollbar-width",[26,497,498],{},"scrollbar-color"," 兩個 W3C 標準屬性（出自 CSS Scrollbars Module Level 1），跟 ",[26,501,254],{}," 比起來最大的差異就是它有規格背書。",[271,504,506],{"className":273,"code":505,"language":275,"meta":276,"style":276},".scroll-box {\n  width: 300px;\n  height: 200px;\n  overflow: scroll;\n  scrollbar-width: thin;\n  scrollbar-color: #888 #f0f0f0;\n}\n",[26,507,508,514,526,538,548,560,574],{"__ignoreMap":276},[280,509,510,512],{"class":282,"line":283},[280,511,287],{"class":286},[280,513,291],{"class":290},[280,515,516,518,520,522,524],{"class":282,"line":294},[280,517,297],{"class":286},[280,519,300],{"class":290},[280,521,303],{"class":286},[280,523,307],{"class":306},[280,525,310],{"class":290},[280,527,528,530,532,534,536],{"class":282,"line":313},[280,529,316],{"class":286},[280,531,300],{"class":290},[280,533,321],{"class":286},[280,535,307],{"class":306},[280,537,310],{"class":290},[280,539,540,542,544,546],{"class":282,"line":328},[280,541,331],{"class":286},[280,543,300],{"class":290},[280,545,137],{"class":286},[280,547,310],{"class":290},[280,549,550,553,555,558],{"class":282,"line":340},[280,551,552],{"class":286},"  scrollbar-width",[280,554,300],{"class":290},[280,556,557],{"class":286},"thin",[280,559,310],{"class":290},[280,561,562,565,567,569,572],{"class":282,"line":346},[280,563,564],{"class":286},"  scrollbar-color",[280,566,300],{"class":290},[280,568,414],{"class":286},[280,570,571],{"class":286}," #f0f0f0",[280,573,310],{"class":290},[280,575,576],{"class":282,"line":353},[280,577,343],{"class":290},[63,579,580,594],{},[66,581,582,584,585,587,588,265,590,593],{},[26,583,495],{}," 可以設 ",[26,586,147],{},"、",[26,589,557],{},[26,591,592],{},"none","，分別對應「預設粗細」、「細捲軸」、「隱藏捲軸」",[66,595,596,598],{},[26,597,498],{}," 接收兩個顏色值，前者是捲軸 thumb 的顏色，後者是 track 的底色",[12,600,601,602,604],{},"可是支援度要先注意一下，Firefox 從 64 就支援這兩個屬性了，Chromium 系列（Chrome、Edge）要到 Chrome 121 之後才支援，Safari 則是要 Safari 26.2 之後才有完整支援。如果你的網站還要兼容比較舊的瀏覽器，建議把 ",[26,603,254],{}," 一起寫上去當 fallback。",[606,607,608],"blockquote",{},[12,609,610,613,614,265,616,618,619,621,622,624],{},[51,611,612],{},"Note","\nMDN 文件有提到，當 ",[26,615,495],{},[26,617,498],{}," 設成非 ",[26,620,147],{}," 的值時，會直接蓋掉 ",[26,623,254],{}," 的樣式。所以兩個一起寫的時候，要注意誰會贏。",[82,626,628],{"id":627},"為什麼不用-scrollbar-gutter","為什麼不用 scrollbar-gutter？",[12,630,631,632,635],{},"看到這邊你可能會想說，CSS 不是還有 ",[26,633,634],{},"scrollbar-gutter"," 可以拿來保留捲軸位置嗎？那直接用它來解這個問題不是更省事？",[12,637,638],{},"可惜不行，這個屬性對 macOS 的隱形捲軸沒效果。",[12,640,641,644,645,647],{},[26,642,643],{},"scrollbar-gutter: stable"," 原本的設計目的是保留捲軸需要的版面空間，避免內容因為捲軸有無而抖動。可是 MDN 文件上有明確寫一行：當瀏覽器使用隱形捲軸時，",[26,646,634],{}," 不會有任何效果。",[12,649,650],{},"簡單來講，它要解決的是古典捲軸那種會占空間的場景下，內容因為捲軸出現\u002F消失而跳動的問題。可是 macOS 預設用的是隱形捲軸，本來就不占空間，自然也沒東西好保留。",[12,652,653,654,656,657,265,659,661],{},"所以如果你的目標是讓 Mac 上的 Chrome 永遠看得到捲軸，",[26,655,634],{}," 解決不了這個問題，還是要回去用 ",[26,658,254],{},[26,660,495],{},"。",[19,663,664],{"id":664},"結語",[12,666,667,668,670],{},"回到開頭那個「同事看得到、你看不到」的情境，這個問題的根源其實不是 CSS 寫錯，也不是 Chrome 哪裡壞掉，而是作業系統層級的捲軸機制本來就不一樣 — macOS 預設走隱形捲軸，Windows 預設走古典捲軸，兩邊對 ",[26,669,28],{}," 的視覺呈現自然就不同。",[12,672,673,674,676,677,679],{},"知道這件事之後，下次再遇到一樣的狀況就不用懷疑自己 CSS 寫錯，可以直接想到是系統設定差異，再依需求選 ",[26,675,254],{}," or 新版的 ",[26,678,495],{}," 補上一致的視覺。",[12,681,682,683,690],{},"如果你對瀏覽器底層怎麼把 CSS 渲染成你看到的畫面有興趣，可以再看看 ",[684,685,689],"a",{"href":686,"rel":687},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20250424\u002F3992645625\u002F",[688],"nofollow","前端工程師應該要懂的瀏覽器渲染機制"," 這一篇，裡面把 Render Process 從 DOM 樹一路到 Composite 的流程整理得滿完整的，跟這篇可以串成更完整的「為什麼瀏覽器會這樣顯示」的脈絡。",[692,693,694],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":276,"searchDepth":294,"depth":294,"links":696},[697,698,701,705,711],{"id":21,"depth":294,"text":21},{"id":36,"depth":294,"text":37,"children":699},[700],{"id":84,"depth":313,"text":85},{"id":168,"depth":294,"text":169,"children":702},[703,704],{"id":186,"depth":313,"text":187},{"id":227,"depth":313,"text":228},{"id":243,"depth":294,"text":244,"children":706},[707,709,710],{"id":250,"depth":313,"text":708},"方法一：用 ::-webkit-scrollbar 強制顯示",{"id":488,"depth":313,"text":489},{"id":627,"depth":313,"text":628},{"id":664,"depth":294,"text":664},"CSS","2026-05-18 17:00:00","CSS 設了 overflow: scroll 之後，Mac 的 Chrome 看不到捲軸，但同事的 Windows 卻看得到？這一篇從 overflow 屬性四個值開始講起，搭配 macOS 的『隱形捲軸（Overlay Scrollbar）』機制，解釋為什麼 macOS 上 Chrome 即使設了 overflow: scroll 也不會永遠顯示捲軸，並提供三種解法：::-webkit-scrollbar 強制顯示、新版 scrollbar-width 跟 scrollbar-color 標準屬性，以及把 macOS 系統的『顯示捲軸』切到『總是』。","md","zh-Hant",{},"\u002Fcss\u002Foverflow-scroll-macos-windows-chrome","5",{"title":6,"description":714},false,"CSS\u002F為什麼-overflow-scroll-看不到捲軸-macOS-跟-Windows-的-Chrome-差異",[32,712,724,725,726,727,728],"捲軸","scrollbar","macOS","Chrome","前端開發",null,"\u002Fcss\u002F20260518\u002F2738592104\u002F","jhlabffnOGTZNOT0PjLZcLSFH7mleTBpa9gdn3mzw6k",{"newer":733,"older":737},{"url":734,"title":735,"date":736},"\u002Fai\u002F20260525\u002F1843702956\u002F","Claude Code Routines 排程怎麼設？\u002Fschedule 完整教學與 main 分支推錯解法","2026-05-25 14:00:00",{"url":738,"title":739,"date":740},"\u002Fother\u002F20260518\u002F3674582910\u002F","VSCode 連結都自動開在內建瀏覽器？教你關掉整合瀏覽器自動接管","2026-05-18 14:30:00",[742,747,751],{"url":743,"title":744,"date":745,"readingMinutes":746},"\u002Fcss\u002F20240505\u002F2248376443\u002F","該如何避免使用者透過滑鼠選取特定元素？","2024-05-05 14:02:05","2",{"url":748,"title":749,"date":750,"readingMinutes":719},"\u002Fcss\u002F20210807\u002F3641451940\u002F","Reset CSS 與 Normalize.css 差異","2021-08-07 20:54:14",{"url":752,"title":753,"date":754,"readingMinutes":755},"\u002Fcss\u002F20210205\u002F1934188738\u002F","什麼！Bootstrap 4 變成 Bootstrap 5 了","2021-02-05 11:41:28","6",1784010266676]