[{"data":1,"prerenderedAt":1693},["ShallowReactive",2],{"header-locale:\u002Fcss\u002F20200516\u002F2341336904\u002F":3,"page:\u002Fcss\u002F20200516\u002F2341336904\u002F":4,"alt:\u002Fcss\u002F20200516\u002F2341336904\u002F":3,"prev-next:\u002Fcss\u002F20200516\u002F2341336904\u002F":1670,"related:\u002Fcss\u002F20200516\u002F2341336904\u002F":1679},"\u002Fen\u002Fcss\u002F2020\u002F05\u002F16\u002Fcss-design-patterns-smacss\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1655,"date":1656,"description":18,"extension":1657,"lang":1658,"meta":1659,"navigation":150,"path":1660,"readingMinutes":1661,"seo":1662,"standalone":1663,"stem":1664,"tags":1665,"tldr":1667,"updated":1667,"url":1668,"__hash__":1669},"content\u002FCSS\u002F淺談-CSS-設計模式-SMACSS-篇.md","淺談 CSS 設計模式-SMACSS 篇","2341336904",{"type":9,"value":10,"toc":1645},"minimark",[11,15,19,23,34,37,56,60,63,66,259,278,281,400,406,536,539,542,578,581,589,597,601,608,646,653,656,830,833,897,900,955,966,1022,1028,1032,1035,1038,1263,1274,1404,1411,1414,1456,1459,1494,1497,1501,1504,1577,1584,1592,1609,1613,1616,1622,1631,1634,1641],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"CSS 設計模式是一個觀念、規範以及心法，最主要就是要替我們提高開發與維護的效率。",[12,20,22],{"id":21},"smacss","SMACSS",[16,24,25,26,33],{},"SMACSS 其實是一個縮寫，我們可以透過 ",[27,28,32],"a",{"href":29,"rel":30},"http:\u002F\u002Fsmacss.com\u002F",[31],"nofollow","官方網站"," 了解到其實全名是「Scalable and Modular Architecture for CSS」，中文意思是可以擴展且模組化的 CSS 架構。",[16,35,36],{},"而 SMACSS 其中主要的核心架構是以下",[38,39,40,44,47,50,53],"ul",{},[41,42,43],"li",{},"Base",[41,45,46],{},"Layout",[41,48,49],{},"Module",[41,51,52],{},"State",[41,54,55],{},"Theme",[12,57,59],{"id":58},"base-基礎","Base (基礎)",[16,61,62],{},"Base 是屬於所有網站的基礎架構，概念與 CSS Reset 概念雷同，因此 CSS Reset 就是屬於 SMACSS 中的 Base 的一種。",[16,64,65],{},"因此假使來講今天有一段 CSS 像以下這樣",[67,68,73],"pre",{"className":69,"code":70,"language":71,"meta":72,"style":72},"language-css shiki shiki-themes github-light github-light github-dark-high-contrast",".header a {