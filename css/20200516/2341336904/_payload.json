 主要是用於「初始化 HTML 標籤的預設樣式」，所以與 Module 是不同的觀念。",[16,1411,1412],{},"最後這邊要注意一件事情，盡可能 CSS 不要針對 HTML 標籤給予樣式，這樣子會大大減少 CSS 的彈性",[67,1414,1416],{"className":543,"code":1415,"language":545,"meta":72,"style":72},".table h2 {\n  \n}\n.list li {\n\n}\n",[74,1417,1418,1428,1433,1437,1447,1451],{"__ignoreMap":72},[77,1419,1420,1423,1426],{"class":79,"line":80},[77,1421,1422],{"class":83},".table",[77,1424,1425],{"class":87}," h2",[77,1427,92],{"class":91},[77,1429,1430],{"class":79,"line":95},[77,1431,1432],{"class":91},"  \n",[77,1434,1435],{"class":79,"line":110},[77,1436,143],{"class":91},[77,1438,1439,1442,1445],{"class":79,"line":123},[77,1440,1441],{"class":83},".list",[77,1443,1444],{"class":87}," li",[77,1446,92],{"class":91},[77,1448,1449],{"class":79,"line":140},[77,1450,150],{"emptyLinePlaceholder":149},[77,1452,1453],{"class":79,"line":146},[77,1454,143],{"class":91},[16,1456,1457],{},"在 SMACSS 中他會希望你改寫成這樣",[67,1459,1461],{"className":543,"code":1460,"language":545,"meta":72,"style":72},".table-title {\n\n}\n.list-list {\n\n}\n",[74,1462,1463,1470,1474,1478,1485,1489],{"__ignoreMap":72},[77,1464,1465,1468],{"class":79,"line":80},[77,1466,1467],{"class":83},".table-title",[77,1469,92],{"class":91},[77,1471,1472],{"class":79,"line":95},[77,1473,150],{"emptyLinePlaceholder":149},[77,1475,1476],{"class":79,"line":110},[77,1477,143],{"class":91},[77,1479,1480,1483],{"class":79,"line":123},[77,1481,1482],{"class":83},".list-list",[77,1484,92],{"class":91},[77,1486,1487],{"class":79,"line":140},[77,1488,150],{"emptyLinePlaceholder":149},[77,1490,1491],{"class":79,"line":146},[77,1492,143],{"class":91},[16,1494,1495],{},"這樣子才能夠大大增加 CSS 的活用性。",[12,1497,1499],{"id":1498},"state-狀態","State (狀態)",[16,1501,1502],{},"SMACSS 中的 State 就相對比較簡單一點，舉例來講按鈕可能會有狀態的切換或是一些訊息提示",[67,1504,1506],{"className":543,"code":1505,"language":545,"meta":72,"style":72},".is-active {\n\n}\n\n.is-error {\n\n}\n\n.is-success {\n\n}\n.is-collapsed {\n\n}\n",[74,1507,1508,1515,1519,1523,1527,1534,1538,1542,1546,1553,1557,1561,1568,1572],{"__ignoreMap":72},[77,1509,1510,1513],{"class":79,"line":80},[77,1511,1512],{"class":83},".is-active",[77,1514,92],{"class":91},[77,1516,1517],{"class":79,"line":95},[77,1518,150],{"emptyLinePlaceholder":149},[77,1520,1521],{"class":79,"line":110},[77,1522,143],{"class":91},[77,1524,1525],{"class":79,"line":123},[77,1526,150],{"emptyLinePlaceholder":149},[77,1528,1529,1532],{"class":79,"line":140},[77,1530,1531],{"class":83},".is-error",[77,1533,92],{"class":91},[77,1535,1536],{"class":79,"line":146},[77,1537,150],{"emptyLinePlaceholder":149},[77,1539,1540],{"class":79,"line":153},[77,1541,143],{"class":91},[77,1543,1544],{"class":79,"line":163},[77,1545,150],{"emptyLinePlaceholder":149},[77,1547,1548,1551],{"class":79,"line":174},[77,1549,1550],{"class":83},".is-success",[77,1552,92],{"class":91},[77,1554,1555],{"class":79,"line":185},[77,1556,150],{"emptyLinePlaceholder":149},[77,1558,1559],{"class":79,"line":199},[77,1560,143],{"class":91},[77,1562,1563,1566],{"class":79,"line":204},[77,1564,1565],{"class":83},".is-collapsed",[77,1567,92],{"class":91},[77,1569,1570],{"class":79,"line":209},[77,1571,150],{"emptyLinePlaceholder":149},[77,1573,1574],{"class":79,"line":219},[77,1575,143],{"class":91},[16,1577,1578,1579,1582],{},"通常狀態都會使用 ",[74,1580,1581],{},".is-"," 當作前綴詞，Status 與 Module 是存在一個非常模糊的關係，他們彼此都是修改現有元素的外觀，但在 SMACSS 中對於 Status 的重點在於",[38,1584,1585,1588],{},[41,1586,1587],{},"狀態的樣式可以用於任意 Layout 或是 Module",[41,1589,1590],{},"狀態是依賴於 JavaScript 才加入的",[16,1592,1593,1594,1597,1598,1600,1601,1604,1605,1607],{},"此外這邊還有一件很特別的事情 Status 是允許你使用 ",[74,1595,1596],{},"!important","，通常來講你是不會在一個 CSS 上面放入兩個 Status 必定是只有一個 ",[74,1599,1531],{}," 或 ",[74,1602,1603],{},"is-success","，所以除非你的系統非常複雜，否則 ",[74,1606,1596],{}," 基本上用不到。",[12,1609,1611],{"id":1610},"theme-主題","Theme (主題)",[16,1613,1614],{},"Theme 這個風格使用的機會非常非常的低，就連 SMACSS 官方都說",[1616,1617,1618],"blockquote",{},[16,1619,1620],{},"Theme Rules aren't as often used",[16,1622,1623,1624,1629],{},"因此