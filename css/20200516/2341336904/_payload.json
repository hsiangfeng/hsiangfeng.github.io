[{"data":1,"prerenderedAt":1692},["ShallowReactive",2],{"header-locale:\u002Fcss\u002F20200516\u002F2341336904\u002F":3,"page:\u002Fcss\u002F20200516\u002F2341336904\u002F":4,"alt:\u002Fcss\u002F20200516\u002F2341336904\u002F":3,"prev-next:\u002Fcss\u002F20200516\u002F2341336904\u002F":1669,"related:\u002Fcss\u002F20200516\u002F2341336904\u002F":1678},"\u002Fen\u002Fcss\u002F2020\u002F05\u002F16\u002Fcss-design-patterns-smacss\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1654,"date":1655,"description":18,"extension":1656,"lang":1657,"meta":1658,"navigation":149,"path":1659,"readingMinutes":1660,"seo":1661,"standalone":1662,"stem":1663,"tags":1664,"tldr":1666,"updated":1666,"url":1667,"__hash__":1668},"content\u002FCSS\u002F淺談-CSS-設計模式-SMACSS-篇.md","淺談 CSS 設計模式-SMACSS 篇","2341336904",{"type":9,"value":10,"toc":1644},"minimark",[11,15,19,23,34,37,56,60,63,66,258,277,280,399,405,535,538,541,577,580,588,596,600,607,645,652,655,829,832,896,899,954,965,1021,1027,1031,1034,1037,1262,1273,1403,1410,1413,1455,1458,1493,1496,1500,1503,1576,1583,1591,1608,1612,1615,1621,1630,1633,1640],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"CSS 設計模式是一個觀念、規範以及心法，最主要就是要替我們提高開發與維護的效率。",[12,20,22],{"id":21},"smacss","SMACSS",[16,24,25,26,33],{},"SMACSS 其實是一個縮寫，我們可以透過 ",[27,28,32],"a",{"href":29,"rel":30},"http:\u002F\u002Fsmacss.com\u002F",[31],"nofollow","官方網站"," 了解到其實全名是「Scalable and Modular Architecture for CSS」，中文意思是可以擴展且模組化的 CSS 架構。",[16,35,36],{},"而 SMACSS 其中主要的核心架構是以下",[38,39,40,44,47,50,53],"ul",{},[41,42,43],"li",{},"Base",[41,45,46],{},"Layout",[41,48,49],{},"Module",[41,51,52],{},"State",[41,54,55],{},"Theme",[12,57,59],{"id":58},"base-基礎","Base (基礎)",[16,61,62],{},"Base 是屬於所有網站的基礎架構，概念與 CSS Reset 概念雷同，因此 CSS Reset 就是屬於 SMACSS 中的 Base 的一種。",[16,64,65],{},"因此假使來講今天有一段 CSS 像以下這樣",[67,68,73],"pre",{"className":69,"code":70,"language":71,"meta":72,"style":72},"language-css shiki shiki-themes github-dark-high-contrast",".header a {\n  color: red;\n  display: inline-block;\n  height: 240px;\n}\n\n.footer a {\n  color: red;\n  display: inline-block;\n  height: 290px;\n}\n\n.main a {\n  color: red;\n  display: inline-block;\n  height: 210px;\n}\n","css","",[74,75,76,93,108,121,138,144,151,161,172,183,197,202,207,217,228,239,253],"code",{"__ignoreMap":72},[77,78,81,85,89],"span",{"class":79,"line":80},"line",1,[77,82,84],{"class":83},"sCcAr",".header",[77,86,88],{"class":87},"sKpQp"," a",[77,90,92],{"class":91},"sMAXC"," {\n",[77,94,96,99,102,105],{"class":79,"line":95},2,[77,97,98],{"class":83},"  color",[77,100,101],{"class":91},": ",[77,103,104],{"class":83},"red",[77,106,107],{"class":91},";\n",[77,109,111,114,116,119],{"class":79,"line":110},3,[77,112,113],{"class":83},"  display",[77,115,101],{"class":91},[77,117,118],{"class":83},"inline-block",[77,120,107],{"class":91},[77,122,124,127,129,132,136],{"class":79,"line":123},4,[77,125,126],{"class":83},"  height",[77,128,101],{"class":91},[77,130,131],{"class":83},"240",[77,133,135],{"class":134},"sWyjQ","px",[77,137,107],{"class":91},[77,139,141],{"class":79,"line":140},5,[77,142,143],{"class":91},"}\n",[77,145,147],{"class":79,"line":146},6,[77,148,150],{"emptyLinePlaceholder":149},true,"\n",[77,152,154,157,159],{"class":79,"line":153},7,[77,155,156],{"class":83},".footer",[77,158,88],{"class":87},[77,160,92],{"class":91},[77,162,164,166,168,170],{"class":79,"line":163},8,[77,165,98],{"class":83},[77,167,101],{"class":91},[77,169,104],{"class":83},[77,171,107],{"class":91},[77,173,175,177,179,181],{"class":79,"line":174},9,[77,176,113],{"class":83},[77,178,101],{"class":91},[77,180,118],{"class":83},[77,182,107],{"class":91},[77,184,186,188,190,193,195],{"class":79,"line":185},10,[77,187,126],{"class":83},[77,189,101],{"class":91},[77,191,192],{"class":83},"290",[77,194,135],{"class":134},[77,196,107],{"class":91},[77,198,200],{"class":79,"line":199},11,[77,201,143],{"class":91},[77,203,205],{"class":79,"line":204},12,[77,206,150],{"emptyLinePlaceholder":149},[77,20