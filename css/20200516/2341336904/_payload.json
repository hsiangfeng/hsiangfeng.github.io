],{"class":79,"line":153},[77,330,126],{"class":83},[77,332,101],{"class":91},[77,334,131],{"class":83},[77,336,135],{"class":134},[77,338,107],{"class":91},[77,340,341],{"class":79,"line":163},[77,342,143],{"class":91},[77,344,345],{"class":79,"line":174},[77,346,150],{"emptyLinePlaceholder":149},[77,348,349,351,353],{"class":79,"line":185},[77,350,156],{"class":83},[77,352,88],{"class":87},[77,354,92],{"class":91},[77,356,357,359,361,363,365],{"class":79,"line":199},[77,358,126],{"class":83},[77,360,101],{"class":91},[77,362,192],{"class":83},[77,364,135],{"class":134},[77,366,107],{"class":91},[77,368,369],{"class":79,"line":204},[77,370,143],{"class":91},[77,372,373],{"class":79,"line":209},[77,374,150],{"emptyLinePlaceholder":149},[77,376,377,379,381],{"class":79,"line":219},[77,378,212],{"class":83},[77,380,88],{"class":87},[77,382,92],{"class":91},[77,384,385,387,389,391,393],{"class":79,"line":230},[77,386,126],{"class":83},[77,388,101],{"class":91},[77,390,248],{"class":83},[77,392,135],{"class":134},[77,394,107],{"class":91},[77,396,397],{"class":79,"line":241},[77,398,143],{"class":91},[16,400,401,402,404],{},"我們可以看到 ",[74,403,27],{}," 連結的基礎樣式就可以變成通用樣式且可以減少 CSS 重複撰寫，通過這種方式我們可以滿足網頁上八成的樣式，那至於剩下的兩成呢？此時就會使用覆蓋的概念",[67,406,408],{"className":69,"code":407,"language":71,"meta":72,"style":72},"a {\n  color: red;\n  display: inline-block;\n}\n\n.header a {\n  height: 240px;\n}\n\n.footer a {\n  height: 290px;\n}\n\n.main a {\n  color: white;\n  height: 210px;\n}\n",[74,409,410,416,426,436,440,444,452,464,468,472,480,492,496,500,508,519,531],{"__ignoreMap":72},[77,411,412,414],{"class":79,"line":80},[77,413,27],{"class":87},[77,415,92],{"class":91},[77,417,418,420,422,424],{"class":79,"line":95},[77,419,98],{"class":83},[77,421,101],{"class":91},[77,423,104],{"class":83},[77,425,107],{"class":91},[77,427,428,430,432,434],{"class":79,"line":110},[77,429,113],{"class":83},[77,431,101],{"class":91},[77,433,118],{"class":83},[77,435,107],{"class":91},[77,437,438],{"clas