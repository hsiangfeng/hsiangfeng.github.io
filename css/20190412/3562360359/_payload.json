[{"data":1,"prerenderedAt":1119},["ShallowReactive",2],{"header-locale:\u002Fcss\u002F20190412\u002F3562360359\u002F":3,"page:\u002Fcss\u002F20190412\u002F3562360359\u002F":4,"alt:\u002Fcss\u002F20190412\u002F3562360359\u002F":3,"prev-next:\u002Fcss\u002F20190412\u002F3562360359\u002F":1095,"related:\u002Fcss\u002F20190412\u002F3562360359\u002F":1104},"\u002Fen\u002Fcss\u002F2019\u002F04\u002F12\u002Fhexschool-flexpirate-game\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1080,"date":1081,"description":18,"extension":1082,"lang":1083,"meta":1084,"navigation":1085,"path":1086,"readingMinutes":1087,"seo":1088,"standalone":1089,"stem":1090,"tags":1091,"tldr":1092,"updated":1092,"url":1093,"__hash__":1094},"content\u002FCSS\u002F六角學院-FlexPIRATE.md","六角學院-FLEXPIRATE","3562360359",{"type":9,"value":10,"toc":1042},"minimark",[11,15,19,23,26,29,32,36,39,57,60,68,72,75,81,90,93,96,102,108,111,114,120,126,129,132,138,143,146,149,155,160,163,166,172,175,178,184,187,190,210,213,222,225,228,232,243,249,257,261,264,272,277,281,284,307,312,316,319,335,340,344,347,367,372,376,379,399,404,408,411,430,435,439,442,457,462,466,469,491,496,500,503,532,537,541,544,560,565,569,572,592,597,601,604,630,635,639,642,674,679,683,686,708,713,717,720,741,746,750,753,784,789,793,796,823,828,832,835,881,886,890,893,934,939,943,946,949,982,985,1022,1027,1030,1033,1038],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"六角學院是一個致力於提供學生舞台的線上教學平台，昨天開放了一個 FLEXPIRATE 遊戲，而本身就是六角學院的學生當然要去玩一下，所以在這邊做一些紀錄學習。",[12,20,22],{"id":21},"認識flexbox","認識FlexBox",[16,24,25],{},"以往在開發版型時往往都會使用 float 元素來做控制，自從有了 FlexBox 對於前端開發者來講，是一個非常方便的參數。",[16,27,28],{},"但是 FlexBox 在最近整個大爆紅主要原因出在 CSS3 的規範普及，加上行動裝置的響應式布局 (RWD) 導致。",[16,30,31],{},"基本上 FlexBox 都是仰賴主軸和交叉軸來運作，先來繼續認識 Flex 參數，等一下讓我們直接實戰 FLEXPIRATE。",[12,33,35],{"id":34},"flexbox參數認識","FlexBox參數認識",[16,37,38],{},"若要能夠使用 flex，就必須透過 dispaly 來改變元素。",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-css shiki shiki-themes github-dark-high-contrast","display: flex;\n","css","",[47,48,49],"code",{"__ignoreMap":45},[50,51,54],"span",{"class":52,"line":53},"line",1,[50,55,43],{"class":56},"sMAXC",[16,58,59],{},"再來我們來認識一下其他參數",[40,61,66],{"className":62,"code":64,"language":65,"meta":45},[63],"language-text","justify-content\nalign-items\nflex-wrap\nalign-self\nalign-content\nflex-direction\norder\nflex\n","text",[47,67,64],{"__ignoreMap":45},[69,70,71],"h3",{"id":71},"justify-content",[16,73,74],{},"justify-content 可選參數有以下幾種",[40,76,79],{"className":77,"code":78,"language":65,"meta":45},[63],"flex-start \u002F\u002F 容器開頭or起始點，這也是默認值\nflex-end \u002F\u002F 容器終點or結尾\ncenter \u002F\u002F 容器置中\nspace-between \u002F\u002F 等均排列，通常會與around搞混\nspace-around \u002F\u002F 元素前後留有空白的分配\nspace-evenly \u002F\u002F 每個方塊之間擁有相同間隔\n",[47,80,78],{"__ignoreMap":45},[16,82,83],{},[84,85,89],"a",{"href":86,"rel":87},"http:\u002F\u002Fwww.runoob.com\u002Ftry\u002Fplayit.php?f=playcss_justify-content",[88],"nofollow","w3c練習",[69,91,92],{"id":92},"align-items",[16,94,95],{},"align-items 可選參數有以下幾種",[40,97,100],{"className":98,"code":99,"language":65,"meta":45},[63],"stretch \u002F\u002F 默認值\ncenter \u002F\u002F 置中\nflex-start \u002F\u002F 容器終點or結尾\nflex-end \u002F\u002F 容器開頭or起始點，這也是默認值\nbaseline \ninitial\ninherit\n",[47,101,99],{"__ignoreMap":45},[16,103,104],{},[84,105,89],{"href":106,"rel":107},"http:\u002F\u002Fwww.runoob.com\u002Ftry\u002Fplayit.php?f=playcss_align-items",[88],[69,109,110],{"id":110},"flex-wrap",[16,112,113],{},"flex-wrap 參數主要用於控制 flex 容器是否為單行或是多行，簡單來講就是超出容器時是否斷行。",[40,115,118],{"className":116,"code":117,"language":65,"meta":45},[63],"nowrap \u002F\u002F 默認值\nwrap \u002F\u002F 斷行\nwrap-reverse \u002F\u002F 反轉斷行\ninitial\ninherit\n",[47,119,117],{"__ignoreMap":45},[16,121,122],{},[84,123,89],{"href":124,"rel":125},"http:\u002F\u002Fwww.runoob.com\u002Ftry\u002Ftry.php?filename=trycss3_flex-wrap",[88],[69,127,128],{"id":128},"align-self",[16,130,131],{},"align-self 主要是針對單獨在縱軸做處理，簡單來講就是中間的元素。",[40,133,136],{"className":134,"code":135,"language":65,"meta":45},[63],"auto \u002F\u002F 默認值\nstretch \u002F\u002F 基本上與auto相同，但是他會吃滿整個容器\ncenter \u002F\u002F 置中\nflex-start \u002F\u002F 元素開頭\nflex-end \u002F\u002F 元素結尾\nbaseline \u002F\u002F 這個參數與flex-start類似\ninitial\ninherit\n",[47,137,135],{"__ignoreMap":45},[16,139,140],{},[84,141,89],{"href":142},"www.runoob.com\u002Ftry\u002Fplayit.php?f=playcss_align-self",[69,144,145],{"id":145},"align-content",[16,147,148],{},"align-content 是針對交叉軸上的容器做調整，另外這個參數必須要再多行 (使用 flex-wrap) 情況下才有效。",[40,150,153],{"className":151,"code":152,"language":65,"meta":45},[63],"stretch \u002F\u002F 默認值\ncenter \u002F\u002F 置中\nflex-start \u002F\u002F 元素開頭\nflex-end \u002F\u002F 元素結尾\nspace-between \u002F\u002F 等均排列，通常會與around搞混\nspace-around \u002F\u002F 元素前後留有空白的分配\ninitial\ninherit\n",[47,154,152],{"__ignoreMap":45},[16,156,157],{},[84,158,89],{"href":159},"www.runoob.com\u002Ftry\u002Fplayit.php?f=playcss_align-content",[69,161,162],{"id":162},"flex-direction",[16,164,165],{},"flex-direction 是將原本的主軸轉換成縱軸，而縱軸轉成主軸",[40,167,170],{"className":168,"code":169,"language":65,"meta":45},[63],"row \u002F\u002F 預設值，水平呈現\nrow-reverse \u002F\u002F 反轉水平，原本的開頭便到結尾，而結尾轉至開頭\ncolumn \u002F\u002F 將元素垂直顯示\ncolumn-reverse \u002F\u002F 反轉垂直，原本的開頭便到結尾，而結尾轉至開頭\ninitial\ninherit\n",[47,171,169],{"__ignoreMap":45},[69,173,174],{"id":174},"order",[16,176,177],{},"order 可以將元素的順序做調整，原本 A 變成 B 而 B 變成 A",[16,179,180],{},[84,181,89],{"href":182,"rel":183},"http:\u002F\u002Fwww.runoob.com\u002Ftry\u002Ftry.php?filename=trycss3_order",[88],[69,185,186],{"id":186},"flex",[16,188,189],{},"這個參數其實是 flex-grow、 flex-shrink 和 flex-basis 的簡寫。",[40,191,193],{"className":42,"code":192,"language":44,"meta":45,"style":45},"flex: flex-grow flex-shrink flex-basis\n",[47,194,195],{"__ignoreMap":45},[50,196,197,200,204,207],{"class":52,"line":53},[50,198,199],{"class":56},"flex: ",[50,201,203],{"class":202},"sKpQp","flex-grow",[50,205,206],{"class":202}," flex-shrink",[50,208,209],{"class":202}," flex-basis\n",[16,211,212],{},"依照參數撰寫後可這樣寫",[40,214,216],{"className":42,"code":215,"language":44,"meta":45,"style":45},"flex: 1 1 auto\n",[47,217,218],{"__ignoreMap":45},[50,219,220],{"class":52,"line":53},[50,221,215],{"class":56},[69,223,224],{"id":224},"認識參數結尾",[16,226,227],{},"參數使用上若僅僅附上圖片是很難了解使用方式，所以看完以上參數有一個基本認知之後就準備直接挑戰 FLEXPIRATE，透過實戰來學習會比紙上談兵更實在。",[12,229,231],{"id":230},"flexpirate-start","FLEXPIRATE Start",[16,233,234,239],{},[235,236],"img",{"alt":237,"src":238},"圖片","https:\u002F\u002Fi.imgur.com\u002F5vwcnzw.png",[235,240],{"alt":241,"src":242},"\b圖片","https:\u002F\u002Fi.imgur.com\u002F1BPyJGN.png",[244,245,246],"blockquote",{},[16,247,248],{},"開頭進去將會有一段簡易的故事說明，而我們主要是控制準心來打爆海盜船!",[16,250,251,252],{},"連結→",[84,253,256],{"href":254,"rel":255},"https:\u002F\u002Fhexschool.github.io\u002Fflexbox-pirate\u002Findex.html#\u002F",[88],"FLEXPIRATE",[69,258,260],{"id":259},"level1","Level.1",[16,262,263],{},"第一關必須將準心元素改成 flexbox 才能夠瞄準海盜船。",[40,265,266],{"className":42,"code":43,"language":44,"meta":45,"style":45},[47,267,268],{"__ignoreMap":45},[50,269,270],{"class":52,"line":53},[50,271,43],{"class":56},[16,273,274],{},[235,275],{"alt":237,"src":276},"https:\u002F\u002Fi.imgur.com\u002Ffpcocps.png",[69,278,280],{"id":279},"level2","Level.2",[16,282,283],{},"第二關你會發現海盜船都躲上主軸結尾，所以我們這邊必須使用 flex-end 來將元素移置結尾。",[40,285,287],{"className":42,"code":286,"language":44,"meta":45,"style":45},"display: flex;\njustify-content: flex-end;\n",[47,288,289,293],{"__ignoreMap":45},[50,290,291],{"class":52,"line":53},[50,292,43],{"class":56},[50,294,296,298,301,304],{"class":52,"line":295},2,[50,297,71],{"class":202},[50,299,300],{"class":56},": ",[50,302,303],{"class":202},"flex-end",[50,305,306],{"class":56},";\n",[16,308,309],{},[235,310],{"alt":237,"src":311},"https:\u002F\u002Fi.imgur.com\u002F3IuSe9S.png",[69,313,315],{"id":314},"level3","Level.3",[16,317,318],{},"第三關海盜船停在主軸中間，這時候就要使用 center。",[40,320,322],{"className":42,"code":321,"language":44,"meta":45,"style":45},"display: flex;\njustify-content: center;\n",[47,323,324,328],{"__ignoreMap":45},[50,325,326],{"class":52,"line":53},[50,327,43],{"class":56},[50,329,330,332],{"class":52,"line":295},[50,331,71],{"class":202},[50,333,334],{"class":56},": center;\n",[16,336,337],{},[235,338],{"alt":237,"src":339},"https:\u002F\u002Fi.imgur.com\u002FFUFBSf5.png",[69,341,343],{"id":342},"level4","Level.4",[16,345,346],{},"第四關出現了三艘海盜船，他們均勻地分配而且前後都有空白元素，由此分析我們就要採用 space-around。",[40,348,350],{"className":42,"code":349,"language":44,"meta":45,"style":45},"display: flex;\njustify-content: space-around;\n",[47,351,352,356],{"__ignoreMap":45},[50,353,354],{"class":52,"line":53},[50,355,43],{"class":56},[50,357,358,360,362,365],{"class":52,"line":295},[50,359,71],{"class":202},[50,361,300],{"class":56},[50,363,364],{"class":202},"space-around",[50,366,306],{"class":56},[16,368,369],{},[235,370],{"alt":237,"src":371},"https:\u002F\u002Fi.imgur.com\u002FRfw051a.png",[69,373,375],{"id":374},"level5","Level.5",[16,377,378],{},"第五關海盜船只有中間那一艘占用最多空白元素，那就使用 space-between。",[40,380,382],{"className":42,"code":381,"language":44,"meta":45,"style":45},"display: flex;\njustify-content: space-between;\n",[47,383,384,388],{"__ignoreMap":45},[50,385,386],{"class":52,"line":53},[50,387,43],{"class":56},[50,389,390,392,394,397],{"class":52,"line":295},[50,391,71],{"class":202},[50,393,300],{"class":56},[50,395,396],{"class":202},"space-between",[50,398,306],{"class":56},[16,400,401],{},[235,402],{"alt":237,"src":403},"https:\u002F\u002Fi.imgur.com\u002FzvsFJBJ.png",[69,405,407],{"id":406},"level6","Level.6",[16,409,410],{},"第六關開始將會考驗交錯軸觀念，所以我們這邊要將準心元素修改置交錯軸結尾。",[40,412,414],{"className":42,"code":413,"language":44,"meta":45,"style":45},"display: flex;\nalign-items: flex-end;\n",[47,415,416,420],{"__ignoreMap":45},[50,417,418],{"class":52,"line":53},[50,419,43],{"class":56},[50,421,422,424,426,428],{"class":52,"line":295},[50,423,92],{"class":202},[50,425,300],{"class":56},[50,427,303],{"class":202},[