[{"data":1,"prerenderedAt":419},["ShallowReactive",2],{"header-locale:\u002Fcss\u002F20200523\u002F116058774\u002F":3,"page:\u002Fcss\u002F20200523\u002F116058774\u002F":4,"alt:\u002Fcss\u002F20200523\u002F116058774\u002F":3,"prev-next:\u002Fcss\u002F20200523\u002F116058774\u002F":396,"related:\u002Fcss\u002F20200523\u002F116058774\u002F":405},"\u002Fen\u002Fcss\u002F2020\u002F05\u002F23\u002Fcss-design-patterns-sass-7-1-pattern\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":379,"date":380,"description":18,"extension":381,"lang":382,"meta":383,"navigation":384,"path":385,"readingMinutes":386,"seo":387,"standalone":388,"stem":389,"tags":390,"tldr":393,"updated":393,"url":394,"__hash__":395},"content\u002FCSS\u002F淺談-CSS-設計模式系列-Sass-7-1-Pattern-篇.md","淺談 CSS 設計模式系列-Sass 7-1 Pattern 篇","116058774",{"type":9,"value":10,"toc":365},"minimark",[11,15,19,23,26,51,54,59,62,67,70,81,85,88,99,103,106,117,121,124,132,136,139,147,151,163,174,178,181,189,193,200,203,331,341,344,361],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"7+1 的設計模式主要是在講目錄結構的區分，早期開發 CSS 時只能將所有檔案放在同一個地方，那麼這樣就會導致維護上的困擾，因此在開發 Sass 時就可以搭配 @import 然後使用資料夾區分相關檔案，也就是所謂的 Sass 7-1 Pattern。",[12,20,22],{"id":21},"sass-7-1-pattern","Sass 7-1 Pattern",[16,24,25],{},"Sass 7-1 Pattern 中的 7-1 代表著七個資料夾以及一個檔案，基本上就是為了方便區分 Sass。",[27,28,29,33,36,39,42,45,48],"ul",{},[30,31,32],"li",{},"base",[30,34,35],{},"components",[30,37,38],{},"layout",[30,40,41],{},"pages",[30,43,44],{},"themes",[30,46,47],{},"utils",[30,49,50],{},"vendors",[16,52,53],{},"以及主要引入的檔案",[27,55,56],{},[30,57,58],{},"all.scss or main.scss",[16,60,61],{},"以上就是所謂的 Sass 7-1 Pattern，簡單來講 Sass 7-1 Pattern 就是要你去做檔案的切分，否則做你將全部檔案散在同一層，其實在維護上會非常的困擾。",[63,64,66],"h3",{"id":65},"base-基礎","base (基礎)",[16,68,69],{},"base 資料夾底下都會放 CSS Reset 、SMACSS 的初始化或是字型的基礎設置等都是屬於該資料夾底下",[27,71,72,75,78],{},[30,73,74],{},"_reset.scss",[30,76,77],{},"_base.scss",[30,79,80],{},"_fontStyle.scss",[63,82,84],{"id":83},"components-元件","components (元件)",[16,86,87],{},"components 基本上概念就跟 Bootstrap 的元件一樣，這些元件簡單來講並不會受限在特定區塊，例如限制在 header，因此基本上 components 就是任何地方都可以使用的。",[27,89,90,93,96],{},[30,91,92],{},"_button.scss",[30,94,95],{},"_dropdown.scss",[30,97,98],{},"_alert.scss",[63,100,102],{"id":101},"layout-版型","layout (版型)",[16,104,105],{},"layout 的的話就跟他的翻譯是一樣的，就是針對版面去做切分",[27,107,108,111,114],{},[30,109,110],{},"_header.scss",[30,112,113],{},"_footer.scss",[30,115,116],{},"_nav.scss",[63,118,120],{"id":119},"pages-頁面","pages (頁面)",[16,122,123],{},"pages 的話通常會放一些只有這個頁面才會使用的樣式",[27,125,126,129],{},[30,127,128],{},"_index.scss",[30,130,131],{},"_content.scss",[63,133,135],{"id":134},"themes-主題","themes (主題)",[16,137,138],{},"themes 的概念就是如果這個網站上面多個風格版型，例如有白色版型與黑色版型，那就可以用這個方式去區分",[27,140,141,144],{},[30,142,143],{},"_theme.scss",[30,145,146],{},"_admin.scss",[63,148,150],{"id":149},"utils-工具","utils (工具)",[16,152,153,154,158,159,162],{},"utils 通常都是放一些工具類型的檔案，例如 ",[155,156,157],"code",{},"p-1","、",[155,160,161],{},"mt-10"," 這類的生成工具",[27,164,165,168,171],{},[30,166,167],{},"_helpers.scss",[30,169,170],{},"_mixin.scss",[30,172,173],{},"_function.scss",[63,175,177],{"id":176},"vendors-外部","vendors (外部)",[16,179,180],{},"vendors 通常都是放一些外部的第三方套件",[27,182,183,186],{},[30,184,185],{},"_bootstrap.scss",[30,187,188],{},"_swiper.scss",[63,190,192],{"id":191},"main-or-all","main or all",[16,194,195,196,199],{},"最後一個檔案就是主要的引入檔案，通常這一支裡面只會有 ",[155,197,198],{},"@import"," 而已",[16,201,202],{},"以下僅是引入範例。",[204,205,210],"pre",{"className":206,"code":207,"language":208,"meta":209,"style":209},"language-scss shiki shiki-themes github-dark-high-contrast","\u002F\u002F base\n@import '_reset';\n\u002F\u002F utils\n@import '_helpers';\n\u002F\u002F components\n@import '_button';\n\u002F\u002F layout\n@import '_index';\n\u002F\u002F pages\n@import '_home';\n\u002F\u002F themes\n@import '_admin';\n\u002F\u002F vendors\n@import '_bootstrap';\n","scss","",[155,211,212,221,235,241,251,257,267,273,283,289,299,305,315,321],{"__ignoreMap":209},[213,214,217],"span",{"class":215,"line":216},"line",1,[213,218,220],{"class":219},"sQrFR","\u002F\u002F base\n",[213,222,224,227,231],{"class":215,"line":223},2,[213,225,198],{"class":226},"sWyjQ",[213,228,230],{"class":229},"sTRMh"," '_reset'",[213,232,234],{"class":233},"sMAXC",";\n",[213,236,238],{"class":215,"line":237},3,[213,239,240],{"class":219},"\u002F\u002F utils\n",[213,242,244,246,249],{"class":215,"line":243},4,[213,245,198],{"class":226},[213,247,248],{"class":229}," '_helpers'",[213,250,234],{"class":233},[213,252,254],{"class":215,"line":253},5,[213,255,256],{"class":219},"\u002F\u002F components\n",[213,258,260,262,265],{"class":215,"line":259},6,[213,261,198],{"class":226},[213,263,264],{"class":229}," '_button'",[213,266,234],{"class":233},[213,268,270],{"class":215,"line":269},7,[213,271,272],{"class":219},"\u002F\u002F layout\n",[213,274,276,278,281],{"class":215,"line":275},8,[213,277,198],{"class":226},[213,279,280],{"class":229}," '_index'",[213,282,234],{"class":233},[213,284,286],{"class":215,"line":285},9,[213,287,288],{"class":219},"\u002F\u002F pages\n",[213,290,292,294,297],{"class":215,"line":291},10,[213,293,198],{"class":226},[213,295,296],{"class":229}," '_home'",[213,298,234],{"class":233},[213,300,302],{"class":215,"line":301},11,[213,303,304],{"class":219},"\u002F\u002F themes\n",[213,306,308,310,313],{"class":215,"line":307},12,[213,309,198],{"class":226},[213,311,312],{"class":229}," '_admin'",[213,314,234],{"class":233},[213,316,318],{"class":215,"line":317},13,[213,319,320],{"class":219},"\u002F\u002F vendors\n",[213,322,324,326,329],{"class":215,"line":323},14,[213,325,198],{"class":226},[213,327,328],{"class":229}," '_bootstrap'",[213,330,234],{"class":233},[16,332,333,334,158,336,158,338,340],{},"基本上這些規範並不一定要完全遵守，如果專案其實沒有很大的話，其實也可以只使用 ",[155,335,32],{},[155,337,35],{},[155,339,38],{},"，最主要 Sass 7-1 Pattern 是為了讓我們未來要維護時，可以比較容易找到檔案而已。",[12,342,343],{"id":343},"參考文獻",[27,345,346,354],{},[30,347,348],{},[349,350,22],"a",{"href":351,"rel":352},"https:\u002F\u002Fgist.github.com\u002Frveitch\u002F84cea9650092119527bc",[353],"nofollow",[30,355,356],{},[349,357,360],{"href":358,"rel":359},"https:\u002F\u002Fsass-guidelin.es\u002F#the-7-1-pattern",[353],"sass-guidelin",[362,363,364],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":209,"searchDepth":223,"depth":223,"links":366},[367,368,378],{"id":14,"depth":223,"text":14},{"id":21,"depth":223,"text":22,"children":369},[370,371,372,373,374,375,376,377],{"id":65,"depth":237,"text":66},{"id":83,"depth":237,"text":84},{"id":101,"depth":237,"text":102},{"id":119,"depth":237,"text":120},{"id":134,"depth":237,"text":135},{"id":149,"depth":237,"text":150},{"id":176,"depth":237,"text":177},{"id":191,"depth":237,"text":192},{"id":343,"depth":223,"text":343},"CSS","2020-05-23 21:00:52","md","zh-Hant",{},true,"\u002Fcss\u002Fcss-sass-7-1-pattern","2",{"title":6,"description":18},false,"CSS\u002F淺談-CSS-設計模式系列-Sass-7-1-Pattern-篇",[391,392,379],"CSS 設計模式","7+1 設計模式",null,"\u002Fcss\u002F20200523\u002F116058774\u002F","_gi5pTuR9AvhUI02wZqZ4EZ43kl3thEB1lKeIMeMxnw",{"newer":397,"older":401},{"url":398,"title":399,"date":400},"\u002Fjavascript\u002F20200524\u002F995184384\u002F","JavaScript 核心觀念(8)-執行環境與作用域-記憶體存放與釋放","2020-05-24 10:56:06",{"url":402,"title":403,"