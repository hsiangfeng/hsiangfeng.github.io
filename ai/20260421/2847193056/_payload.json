0},29,[225,712,713],{"class":394},"          sitemap: ",[225,715,716],{"class":446},"\"https:\u002F\u002Fisraynotarray.com\u002Fsitemap.xml\"\n",[225,718,720],{"class":227,"line":719},30,[225,721,722],{"class":394},"        })\n",[225,724,726],{"class":227,"line":725},31,[225,727,728],{"class":394},"      }\n",[225,730,732],{"class":227,"line":731},32,[225,733,734],{"class":394},"    ]\n",[225,736,738],{"class":227,"line":737},33,[225,739,740],{"class":394},"  });\n",[225,742,744],{"class":227,"line":743},34,[225,745,746],{"class":394},"}\n",[225,748,750,753,755],{"class":227,"line":749},35,[225,751,752],{"class":394},"\u003C\u002F",[225,754,399],{"class":398},[225,756,402],{"class":394},[12,758,759],{},"把這段放在你網站的 HTML template 裡面就好，要確保它在頁面載入時就會執行，因為 scanner 是在頁面載入的時候去偵測有沒有 WebMCP 工具的。",[19,761,763],{"id":762},"修正第五項well-known-系列","修正第五項：.well-known 系列",[12,765,766,767,770,771,773],{},"接下來是最後五個項目，它們都需要在網站的 ",[222,768,769],{},"\u002F.well-known\u002F"," 路徑下放置 JSON 檔案。",[222,772,769],{}," 是一個網路標準的公開資訊目錄，讓 AI Agent 可以透過固定路徑找到你的網站提供了哪些服務跟能力。",[12,775,776],{},"需要放的檔案有：",[81,778,779,785,791,797,803],{},[84,780,781,784],{},[222,782,783],{},"\u002F.well-known\u002Fapi-catalog"," - API 目錄",[84,786,787,790],{},[222,788,789],{},"\u002F.well-known\u002Fopenid-configuration"," - 認證資訊",[84,792,793,796],{},[222,794,795],{},"\u002F.well-known\u002Foauth-protected-resource"," - 受保護資源資訊",[84,798,799,802],{},[222,800,801],{},"\u002F.well-known\u002Fmcp\u002Fserver-card.json"," - MCP 伺服器資訊",[84,804,805,808],{},[222,806,807],{},"\u002F.well-known\u002Fagent-skills\u002Findex.json"," - Agent Skills 索引",[12,810,811],{},"你可能會想說：「我只是一個靜態部落格，又沒有 API 也沒有 OAuth，為什麼要放這些？」，確實這些項目本來是設計給有後端服務的網站用的，對純靜態部落格來說實際上不會有 AI Agent 真的來呼叫你的 OAuth endpoint。但 scanner 檢查的是「這些檔案存不存在、格式對不對」，所以如果想拿滿分的話，放上去就對了。",[12,813,814,815,817,818,821],{},"如果你是部署在 GitHub Pages 上的話要注意，GitHub Pages 沒辦法正常服務 ",[222,816,364],{}," 目錄下的檔案，即使放了 ",[222,819,820],{},".nojekyll"," 也一樣，所以這邊一樣交給 Cloudflare Worker 來處理。",[12,823,824,825,827,828,830],{},"前面 Markdown Negotiation 已經需要 Worker 了，順便把 ",[222,826,364],{}," 的回應也寫進去就好。做法是在 Worker 裡面建一個對照表，收到 ",[222,829,364],{}," 路徑的請求時直接回傳對應的 JSON：",[215,832,836],{"className":833,"code":834,"language":835,"meta":220,"style":220},"language-javascript shiki shiki-themes github-dark-high-contrast","const WELL_KNOWN_FILES = {\n  '\u002F.well-known\u002Fapi-catalog': {\n    content: JSON.stringify({\n      linkset: [{\n        anchor: 'https:\u002F\u002F你的網域\u002F',\n        'service-doc': [{ href: 'https:\u002F\u002F你的網域\u002Fsitemap.xml', type: 'application\u002Fxml' }]\n      }]\n    }),\n    type: 'application\u002Flinkset+json',\n  },\n  '\u002F.well-known\u002Fmcp\u002Fserver-card.json': {\n    content: JSON.stringify({\n      serverInfo: { name: '你的網站名稱', version: '1.0.0' },\n      transport: { type: 'streamable-http', endpoint: '\u002Fmcp' },\n      capabilities: { tools: true, resources: true, prompts: false },\n    }),\n    type: 'application\u002Fjson',\n  },\n  \u002F\u002F ... 其他檔案也是同樣的格式\n};\n\nexport default {\n  async fetch(request) {\n    const url = new URL(request.url);\n\n    \u002F\u002F 如果是 .well-known 的路徑，就直接回傳 JSON\n    const wellKnown = WELL_KNOWN_FILES[url.pathname];\n    if (wellKnown) {\n      return new Response(wellKnown.content, {\n        status: 200,\n        headers: {\n          'Content-Type': wellKnown.type,\n          'Access-Control-Allow-Origin': '*',\n        },\n      });\n    }\n\n    \u002F\u002F 如果 AI 要求 Markdown 格式，就把 HTML 轉成 Markdown\n    const accept = request.headers.get('Accept') || '';\n    const response = await fetch(request);\n    if (accept.includes('text\u002Fmarkdown') && response.headers.get('Content-Type')?.includes('text\u002Fhtml')) {\n      const html = await response.text();\n      const markdown = htmlToMarkdown(html);\n      return new Response(markdown, {\n        status: response.status,\n        headers: { 'Content-Type': 'text\u002Fmarkdown; charset=utf-8' },\n      });\n    }\n\n    \u002F\u002F 其他情況就正常回傳\n    return response;\n  },\n};\n","javascript",[222,837,838,852,860,876,881,891,911,916,921,931,936,943,955,972,988,1009,1013,1022,1026,1032,1037,1043,1053,1067,1086,1090,1095,1109,1117,1130,1140,1145,1153,1165,1169,1174,1180,1185,1191,1223,1241,1285,1307,1323,1335,1341,1356,1361,1366,1371,1377,1386,1394],{"__ignoreMap":220},[225,839,840,843,847,850],{"class":227,"line":228},[225,841,842],{"class":408},"const",[225,844,846],{"class":845},"sCcAr"," WELL_KNOWN_FILES",[225,848,849],{"class":408}," =",[225,851,554],{"class":394},[225,853,854,857],{"class":227,"line":405},[225,855,856],{"class":446},"  '\u002F.well-known\u002Fapi-catalog'",[225,858,859],{"class":394},": {\n",[225,861,862,865,868,871,874],{"class":227,"line":415},[225,863,864],{"class":394},"    content: ",[225,866,867],{"class":845},"JSON",[225,869,870],{"class":394},".",[225,872,873],{"class":421},"stringify",[225,875,425],{"class":394},[225,877,878],{"class":227,"line":428},[225,879,880],{"class":394},"      linkset: [{\n",[225,882,883,886,889],{"class":227,"line":434},[225,884,885],{"class":394},"        anchor: ",[225,887,888],{"class":446},"'https:\u002F\u002F你的網域\u002F'",[225,890,450],{"class":394},[225,892,893,896,899,902,905,908],{"class":227,"line":440},[225,894,895],{"class":446},"        'service-doc'",[225,897,898],{"class":394},": [{ href: ",[225,900,901],{"class":446},"'https:\u002F\u002F你的網域\u002Fsitemap.xml'",[225,903,904],{"class":394},", type: ",[225,906,907],{"class":446},"'application\u002Fxml'",[225,909,910],{"class":394}," }]\n",[225,912,913],{"class":227,"line":453},[225,914,915],{"class":394},"      }]\n",[225,917,918],{"class":227,"line":464},[225,919,920],{"class":394},"    }),\n",[225,922,923,926,929],{"class":227,"line":470},[225,924,925],{"class":394},"    type: ",[225,927,928],{"class":446},"'application\u002Flinkset+json'",[225,930,450],{"class":394},[225,932,933],{"class":227,"line":481},[225,934,935],{"class":394},"  },\n",[225,937,938,941],{"class":227,"line":487