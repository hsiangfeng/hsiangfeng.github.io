這邊一樣交給 Cloudflare Worker 來處理。",[12,823,824,825,827,828,830],{},"前面 Markdown Negotiation 已經需要 Worker 了，順便把 ",[222,826,364],{}," 的回應也寫進去就好。做法是在 Worker 裡面建一個對照表，收到 ",[222,829,364],{}," 路徑的請求時直接回傳對應的 JSON：",[215,832,836],{"className":833,"code":834,"language":835,"meta":220,"style":220},"language-javascript shiki shiki-themes github-light github-light github-dark-high-contrast","const WELL_KNOWN_FILES = {\n  '\u002F.well-known\u002Fapi-catalog': {\n    content: JSON.stringify({\n      linkset: [{\n        anchor: 'https:\u002F\u002F你的網域\u002F',\n        'service-doc': [{ href: 'https:\u002F\u002F你的網域\u002Fsitemap.xml', type: 'application\u002Fxml' }]\n      }]\n    }),\n    type: 'application\u002Flinkset+json',\n  },\n  '\u002F.well-known\u002Fmcp\u002Fserver-card.json': {\n    content: JSON.stringify({\n      serverInfo: { name: '你的網站名稱', version: '1.0.0' },\n      transport: { type: 'streamable-http', endpoint: '\u002Fmcp' },\n      capabilities: { tools: true, resources: true, prompts: false },\n    }),\n    type: 'application\u002Fjson',\n  },\n  \u002F\u002F ... 其他檔案也是同樣的格式\n};\n\nexport default {\n  async fetch(request) {\n    const url = new URL(request.url);\n\n    \u002F\u002F 如果是 .well-known 的路徑，就直接回傳 JSON\n    const wellKnown = WELL_KNOWN_FILES[url.pathname];\n    if (wellKnown) {\n      return new Response(wellKnown.content, {\n        status: 200,\n        headers: {\n          'Content-Type': wellKnown.type,\n          'Access-Control-Allow-Origin': '*',\n        },\n      });\n    }\n\n    \u002F\u002F 如果 AI 要求 Markdown 格式，就把 HTML 轉成 Markdown\n    const accept = request.headers.get('Accept') || '';\n    const response = await fetch(request);\n    if (accept.includes('text\u002Fmarkdown') && response.headers.get('Content-Type')?.includes('text\u002Fhtml')) {\n      const html = await response.text();\n      const markdown = htmlToMarkdown(html);\n      return new Response(markdown, {\n        status: response.status,\n        headers: { 'Content-Type': 'text\u002Fmarkdown; charset=utf-8' },\n      });\n    }\n\n    \u002F\u002F 其他情況就正常回傳\n    return response;\n  },\n};\n","javascript",[222,837,838,852,860,876,881,891,911,916,921,931,936,943,955,972,988,1009,1013,1022,1026,1032,1037,1043,1054,1073,1092,1096,1101,1115,1123,1136,1146,1151,1159,1171,1175,1180,1186,1191,1197,1228,1246,1290,1312,1328,1340,1346,1361,1366,1371,1376,1382,1391,1399],{"__ignoreMap":220},[225,839,840,843,847,850],{"class":227,"line":228},[225,841,842],{"class":408},"const",[225,844,846],{"class":845},"stw71"," WELL_KNOWN_FILES",[225,848,849],{"class":408}," =",[225,851,554],{"class":394},[225,853,854,857],{"class":227,"line":405},[225,855,856],{"class":446},"  '\u002F.well-known\u002Fapi-catalog'",[225,858,859],{"class":394},": {\n",[225,861,862,865,868,871,874],{"class":227,"line":415},[225,863,864],{"class":394},"    content: ",[225,866,867],{"class":845},"JSON",[225,869,870],{"class":394},".",[225,872,873],{"class":421},"stringify",[225,875,425],{"class":394},[225,877,878],{"class":227,"line":428},[225,879,880],{"class":394},"      linkset: [{\n",[225,882,883,886,889],{"class":227,"line":434},[225,884,885],{"class":394},"        anchor: ",[225,887,888],{"class":446},"'https:\u002F\u002F你的網域\u002F'",[225,890,450],{"class":394},[225,892,893,896,899,902,905,908],{"class":227,"line":440},[225,894,895],{"class":446},"        'service-doc'",[225,897,898],{"class":394},": [{ href: ",[225,900,901],{"class":446},"'https:\u002F\u002F你的網域\u002Fsitemap.xml'",[225,903,904],{"class":394},", type: ",[225,906,907],{"class":446},"'application\u002Fxml'",[225,909,910],{"class":394}," }]\n",[225,912,913],{"class":227,"line":453},[225,914,915],{"class":394},"      }]\n",[225,917,918],{"class":227,"line":464},[225,919,920],{"class":394},"    }),\n",[225,922,923,926,929],{"class":227,"line":470},[225,924,925],{"class":394},"    type: ",[225,927,928],{"class":446},"'application\u002Flinkset+json'",[225,930,450],{"class":394},[225,932,933],{"class":227,"line":481},