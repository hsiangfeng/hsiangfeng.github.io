[{"data":1,"prerenderedAt":1373},["ShallowReactive",2],{"header-locale:\u002Fwebpack\u002F20190609\u002F3910344198\u002F":3,"page:\u002Fwebpack\u002F20190609\u002F3910344198\u002F":4,"alt:\u002Fwebpack\u002F20190609\u002F3910344198\u002F":3,"prev-next:\u002Fwebpack\u002F20190609\u002F3910344198\u002F":1350,"related:\u002Fwebpack\u002F20190609\u002F3910344198\u002F":1359},"\u002Fen\u002Fwebpack\u002F2019\u002F06\u002F09\u002Fwebpack-learning-ep-11-prod-dev\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1335,"date":1336,"description":18,"extension":1337,"lang":1338,"meta":1339,"navigation":318,"path":1340,"readingMinutes":1341,"seo":1342,"standalone":1343,"stem":1344,"tags":1345,"tldr":1347,"updated":1347,"url":1348,"__hash__":1349},"content\u002FWebpack\u002FEP-11-關於-Webpack-學習這件小事之prod與dev？.md","EP-11-關於-Webpack-學習這件小事之 prod 與 dev？","3910344198",{"type":9,"value":10,"toc":1323},"minimark",[11,15,19,23,26,36,39,42,55,62,69,149,155,162,167,177,182,195,201,204,210,216,220,223,226,254,261,266,398,402,646,650,1251,1254,1300,1303,1312,1319],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"一般來講 Webpack 都會有兩種開發模式，一種是 prod 與 dev，這邊就來記錄一下該如何設置 prod 與 dev 吧!",[12,20,22],{"id":21},"prod-與-dev-是什麼","prod 與 dev 是什麼?",[16,24,25],{},"製作之前必須先科普一下 prod 與 dev 這兩個東西是什麼的縮寫",[27,28,29,33],"ul",{},[30,31,32],"li",{},"prod： production (上線 or 生產版本)，通常這個版本是會針對檔案做壓縮以及優化",[30,34,35],{},"dev ： development (開發 or 編譯版本)，簡單來講就是只做編譯的動作",[16,37,38],{},"那這兩個版本差異在哪裡？當我們系統還沒開發完成時都會在 loacl (本地端) 做測試，但是如果我們每一次測試都要做做壓縮以及優化，其實這會浪費不少效能，如果專案大小夠大的話，就有可能導致電腦停在那邊什麼事情都不能做，所以通常都會區分為 prod 與 dev，那這邊就來記錄一下該怎麼做吧!",[12,40,41],{"id":41},"webpack4",[16,43,44,45,49,50,54],{},"首先 ",[46,47,48],"strong",{},"webpack4 在預設編譯的情況下是 prod 的模式","，舉例如果我只輸入 ",[51,52,53],"code",{},"webpack","，你會發現 webpack 壓縮及優化了檔案",[16,56,57],{},[58,59],"img",{"alt":60,"src":61},"預設編譯","https:\u002F\u002Fi.imgur.com\u002FcPgIDN1.png",[16,63,64,65,68],{},"那我們該如何避免這種狀況？最簡單的方式就是針對 ",[51,66,67],{},"package.json"," 做自定義的啟動指令(我將原本 start 修改為 server)",[70,71,76],"pre",{"className":72,"code":73,"language":74,"meta":75,"style":75},"language-js shiki shiki-themes github-dark-high-contrast","\"scripts\": {\n  \"server\": \"webpack-dev-server --config webpack.config.js\",\n  \"dev\": \"webpack --watch --mode development\",\n  \"prod\": \"webpack --mode production\",\n  \"test\": \"jest\"\n},\n","js","",[51,77,78,91,106,119,132,143],{"__ignoreMap":75},[79,80,83,87],"span",{"class":81,"line":82},"line",1,[79,84,86],{"class":85},"sTRMh","\"scripts\"",[79,88,90],{"class":89},"sMAXC",": {\n",[79,92,94,97,100,103],{"class":81,"line":93},2,[79,95,96],{"class":85},"  \"server\"",[79,98,99],{"class":89},": ",[79,101,102],{"class":85},"\"webpack-dev-server --config webpack.config.js\"",[79,104,105],{"class":89},",\n",[79,107,109,112,114,117],{"class":81,"line":108},3,[79,110,111],{"class":85},"  \"dev\"",[79,113,99],{"class":89},[79,115,116],{"class":85},"\"webpack --watch --mode development\"",[79,118,105],{"class":89},[79,120,122,125,127,130],{"class":81,"line":121},4,[79,123,124],{"class":85},"  \"prod\"",[79,126,99],{"class":89},[79,128,129],{"class":85},"\"webpack --mode production\"",[79,131,105],{"class":89},[79,133,135,138,140],{"class":81,"line":134},5,[79,136,137],{"class":85},"  \"test\"",[79,139,99],{"class":89},[79,141,142],{"class":85},"\"jest\"\n",[79,144,146],{"class":81,"line":145},6,[79,147,148],{"class":89},"},\n",[16,150,151],{},[58,152],{"alt":153,"src":154},"scripts","https:\u002F\u002Fi.imgur.com\u002FcG1Ebuv.png",[16,156,157,158,161],{},"那我們就可以試著輸入 ",[51,159,160],{},"npm run dev"," 來看看結果囉",[16,163,164],{},[58,165],{"alt":160,"src":166},"https:\u002F\u002Fi.imgur.com\u002Ft3ecDTC.png",[16,168,169,170,173,174,176],{},"但是由於我們有安裝 ",[51,171,172],{},"webpack-dev-server","，而 ",[51,175,172],{}," 本身就與 dev 類似，所以其實不使用也沒關係。",[16,178,179],{},[58,180],{"alt":172,"src":181},"https:\u002F\u002Fi.imgur.com\u002Fh8OvMhO.png",[16,183,184,185,188,189,191,192,194],{},"這邊主要是要講解 ",[51,186,187],{},"--watch"," 這個東西，",[51,190,187],{}," 簡單來講就是監聽，所以當 webpack 執行帶有 ",[51,193,187],{}," 的指令時是不會停止的，你會看到底線一直處於閃爍中",[16,196,197],{},[58,198],{"alt":199,"src":200},"dev","https:\u002F\u002Fi.imgur.com\u002Fx96E4O6.png",[16,202,203],{},"那 prod 則是輸入完後就可以在輸入指令",[16,205,206],{},[58,207],{"alt":208,"src":209},"prod","https:\u002F\u002Fi.imgur.com\u002FrZeZCgC.png",[16,211,212,213,215],{},"當然這邊其實有一個很嚴重的錯誤，也就是執行 ",[51,214,160],{}," 的時候，其實還是會做壓縮打包的動作，所以這邊要做一下調整",[12,217,219],{"id":218},"新增-dev-prod-檔","新增 dev & prod 檔",[16,221,222],{},"建立兩個檔案，分別為 webpack.config.prod.js、webpack.config.dev.js，所以總共會有三個檔案",[16,224,225],{},"然後這邊還會再安裝一個套件 webpack-merge",[70,227,229],{"className":72,"code":228,"language":74,"meta":75,"style":75},"npm install --save-dev webpack-merge\n",[51,230,231],{"__ignoreMap":75},[79,232,233,236,240,243,246,249,251],{"class":81,"line":82},[79,234,235],{"class":89},"npm install ",[79,237,239],{"class":238},"sWyjQ","--",[79,241,242],{"class":89},"save",[79,244,245],{"class":238},"-",[79,247,248],{"class":89},"dev webpack",[79,250,245],{"class":238},[79,252,253],{"class":89},"merge\n",[16,255,256,257,260],{},"webpack-merge 的用處在於幫助我們",[46,258,259],{},"合併檔案","，讓我們不用再重複撰寫程式碼，因為 dev 與 prod 的版本其實差異不大，如果又複製來複製去這樣子在管理上是滿亂的，這邊會附上拆開來的程式碼",[262,263,265],"h3",{"id":264},"webpackconfigdevjs","webpack.config.dev.js",[70,267,269],{"className":72,"code":268,"language":74,"meta":75,"style":75},"const merge = require('webpack-merge');\nconst config = require('.\u002Fwebpack.config.js');\n\nmodule.exports = merge(config, {\n  mode: 'development',\n  devtool: 'inline-source-map',\n  devServer: {\n    contentBase: '.\u002Fdist',\n    port: 3000,\n  }\n});\n",[51,270,271,296,314,320,338,348,358,364,375,386,392],{"__ignoreMap":75},[79,272,273,276,280,283,287,290,293],{"class":81,"line":82},[79,274,275],{"class":238},"const",[79,277,279],{"class":278},"sCcAr"," merge",[79,281,282],{"class":238}," =",[79,284,286],{"class":285},"sj_SG"," require",[79,288,289],{"class":89},"(",[79,291,292],{"class":85},"'webpa