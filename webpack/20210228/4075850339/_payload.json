2,213,214,217,218,221,222,224,225,228,229,232],{},"前者 ",[51,215,216],{},"path.resolve"," 簡單來講是合併路徑在使用的語法，而後者則是取得當前執行環境路徑，舉例來講我當前路徑輸出之後就會是這樣 ",[51,219,220],{},"\u002FUsers\u002Frayxu\u002FGitHub\u002Fwebpack5sample","，透過 ",[51,223,216],{}," 合併之後就會變成 ",[51,226,227],{},"\u002FUsers\u002Frayxu\u002FGitHub\u002Fwebpack5sample\u002Fsrc\u002Fmain.js","，之所以會這樣做原因在於，在某些作業系統下如果單純的撰寫 ",[51,230,231],{},".\u002Fsrc\u002Fmain.js"," 可能會發生一些問題，例如：路徑錯誤等問題。",[16,234,235,236,239],{},"接下來應該是滿多前端工程師很熟悉的語法 ",[51,237,238],{},"module.exports","，在前面有說過，如果要使用 Webpack 的話，那麼就必須安裝 Node.js，因此這邊 Webpack 的模組化就會採用 Node.js 的 CommonJS 規範，至於什麼是 CommonJS 建議可以直接上網查，相信有更多大神介紹的非常詳細。",[16,241,242,243,246,247,250],{},"通常我們在開發時，都會有開發模式、部署模式這兩種模式，而 Webpack 也不意外也擁有該兩種模式，在此就主要是透過 ",[51,244,245],{},"mode"," 屬性來設置，如果沒有撰寫該屬性的話，預設 Webpack 是會走 ",[51,248,249],{},"production"," 的，在官方網站也有提到這一點",[252,253,254],"blockquote",{},[16,255,256],{},"By setting the mode parameter to either development, production or none, you can enable webpack's built-in optimizations that correspond to each environment. The default value is production.",[16,258,259,262,263,265,266,268,269,271],{},[51,260,261],{},"entry"," 這個屬性是 Webpack 的核心屬性之一，通常來講你會很常聽到「進入點」，而在此所謂的進入點就是講「",[51,264,261],{},"」，我們在使用 Webpack 的時候都會從這個進入點開始解析我們模組化引入的東西，因此這個 ",[51,267,261],{}," 是必填的屬性，假使不填寫就必定會出現錯誤，預設通常我們會讓它指向 ",[51,270,231],{},"，與此同時你也可以先建立該檔案。",[16,273,274,277,278,280,281,284,285,288,289,292,293,295,296,299,300,303,304,307,308,311],{},[51,275,276],{},"output"," 是告知 Webpack 我要輸出的要到哪個路徑以及輸出的檔案名稱要叫什麼，這邊可以發現 ",[51,279,276],{}," 具有兩個屬性分別是 ",[51,282,283],{},"path"," 與 ",[51,286,287],{},"filename","，這兩個屬性可以看簡單一點，前者是要輸出的路徑，後者則是輸出後的檔案名稱，通常來講要輸出的檔案名稱會使用 ",[51,290,291],{},"[name]","，當若你使用 ",[51,294,291],{}," 時，那麼你的進入點檔案叫什麼名字，他就會輸出什麼名字的檔案，如果你是寫死 ",[51,297,298],{},"filename: 'index.bundle.js',"," 那麼不管你進入點改叫 ",[51,301,302],{},"main.js"," 他也只會輸出 ",[51,305,306],{},"index.bundle.js","，而 ",[51,309,310],{},"[contenthash]"," 則是會生成一組 hash 而這個生成邏輯會依據提取的內容來生成，當然不只這種命名方式，你也可以使用以下",[26,313,314,319,324],{},[29,315,316],{},[51,317,318],{},"[name].[hash].bundle.js",[29,320,321],{},[51,322,323],{},"[name].[chunkhash].bundle.js",[29,325,326],{},[51,327,328],{},"[name].[contenthash].bundle.js",[16,330,331,332,335],{},"這三種都會有人使用，附帶一提來講，如果你覺得 hash 太長你也可以限制長度，例如改成這樣 ",[51,333,334],{},"[name].[hash:6].bundle.js","，最後聊一下為什麼會使用到 hash，最主要是避免瀏覽器的緩存問題，我們在開發時，通常會瘋狂的重新整理，而這過程就有可能導致緩存發生而無法確定我們修改的內容，那麼透過 hash 每一次存擋就重新生成不同的檔案名稱，這樣子瀏覽器就不會緩存內容了。",[16,337,338,339,342],{},"Webpack 最基本與最核心的配置就先介紹到這邊，那麼讓我們來建立進入點 (",[51,340,341],{},"\u002Fsrc\u002Fmain.js",") 的檔案與內容",[16,344,345],{},"內容：",[59,347,349],{"className":61,"code":348,"language":63,"meta":64,"style":64},"console.log('Hello Ray!');\n",[51,350,351],{"__ignoreMap":64},[68,352,353,356,359,361,364],{"class":70,"line":71},[68,354,355],{"class":89},"console.",[68,357,358],{"class":85},"log",[68,360,90],{"class":89},[68,362,363],{"class":93},"'Hello Ray!'",[68,365,97],{"class":89},[16,367,368],{},"最後我們去修改 package.json 中的 scripts 屬性增加一行啟動指令",[59,370,374],{"className":371,"code":372,"language":373,"meta":64,"style":64},"language-json shiki shiki-themes github-dark-high-contrast","\"scripts\": {\n    \"build\": \"webpack\"\n},\n","json",[51,375,376,384,396],{"__ignoreMap":64},[68,377,378,381],{"class":70,"line":71},[68,379,380],{"class":93},"\"scripts\"",[68,382,383],{"class":89},": {\n",[68,385,386,390,393],{"class":70,"line":100},[68,387,389],{"class":388},"sKpQp","    \"build\"",[68,391,392],{"class":89},": ",[68,394,395],{"class":93},"\"webpack\"\n",[68,397,398],{"class":70,"line":107},[68,399,400],{"class":89},"},\n",[16,402,403,404,407],{},"接下來你只要在終端機輸入 ",[51,405,406],{},"npm run dev"," 就可以看到 webpack 做完以上動作囉",[16,409,410],{},[411,412],"img",{"alt":413,"src":414},"webpack","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FWebpack\u002F%E6%88%AA%E5%9C%96%202021-02-28%2022.06.32.png",[16,416,417,418,421],{},"現在你的專案資料夾下應該會有一個 ",[51,419,420],{},"dist\u002Fmain.a87486.bundle.js"," 這個就是 webpack 打包出來的檔案。",[12,423,42