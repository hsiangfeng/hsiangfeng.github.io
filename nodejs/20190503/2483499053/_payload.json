[{"data":1,"prerenderedAt":146},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190503\u002F2483499053\u002F":3,"page:\u002Fnodejs\u002F20190503\u002F2483499053\u002F":4,"alt:\u002Fnodejs\u002F20190503\u002F2483499053\u002F":3,"prev-next:\u002Fnodejs\u002F20190503\u002F2483499053\u002F":121,"related:\u002Fnodejs\u002F20190503\u002F2483499053\u002F":130},"\u002Fen\u002Fnodejs\u002F2019\u002F05\u002F03\u002Fnodejs-500-error-debugging\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":103,"date":104,"description":105,"extension":106,"lang":107,"meta":108,"navigation":109,"path":110,"readingMinutes":111,"seo":112,"standalone":113,"stem":114,"tags":115,"tldr":118,"updated":118,"url":119,"__hash__":120},"content\u002FNodejs\u002Fnodejs出現錯誤代碼500.md","nodejs出現錯誤代碼500","2483499053",{"type":9,"value":10,"toc":97},"minimark",[11,15,19,22,25,32,35,38,43,55,62,67,70,75,81,86],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"昨天在弄 nodejs 的時候發生一件很奇妙的事情，前一天使用 ajax 還很正常，昨天突然 ajax 掛掉了...\n最後今天發現原因紀錄一下自己多白癡。",[12,20,21],{"id":21},"問題點",[16,23,24],{},"昨天不論怎麼使用 AJAX 呼叫這隻 API 就是會一直出現錯誤代碼 500",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"圖片","https:\u002F\u002Fi.imgur.com\u002FWrfMX1W.png",[16,33,34],{},"一開始我就先去找其他呼叫的方式的 API，舉例 POST 方法的 API，結果都是可以正常打出去的，但是只要是 method 是 PUT、DELETE 就會出現 500，所以可以先排除資料庫的方面問題。",[16,36,37],{},"今天為了確定問題，使用了 Postman 來幫助我 Debug 試著打看看到底是我前端撰寫有問題還是真的是後端問題?打出去之後發現問題了...",[16,39,40],{},[28,41],{"alt":30,"src":42},"https:\u002F\u002Fi.imgur.com\u002FimU05Wk.png",[16,44,45,46,50,51,54],{},"結果是出在 ",[47,48,49],"code",{},"req.params is not a function"," 沒有 ",[47,52,53],{},"params"," 這個方法所導致。",[16,56,57,58,61],{},"沒想到是自己手賤多打一個 s，所以改回 ",[47,59,60],{},"req.param","。",[16,63,64],{},[28,65],{"alt":30,"src":66},"https:\u002F\u002Fi.imgur.com\u002FnEX8QeI.png",[16,68,69],{},"這時候在試一次AJAX，果然正常了，但是卻跳出別的提示訊息...",[16,71,72],{},[28,73],{"alt":30,"src":74},"https:\u002F\u002Fi.imgur.com\u002FPsxcHCH.png",[16,76,77,78,61],{},"依照這一段提示訊息做了 Google 搜尋，發現在官網有說明 Express 4 必須改另一種方式取得 ",[47,79,80],{},"param",[16,82,83],{},[28,84],{"alt":30,"src":85},"https:\u002F\u002Fi.imgur.com\u002FjLZrG8X.png",[16,87,88,89,92,93,96],{},"所以只要將原本的 ",[47,90,91],{},"const id = req.param('id')"," 修改成 ",[47,94,95],{},"const id = req.params.id;"," 就搞定沒問題哩。",{"title":98,"searchDepth":99,"depth":99,"links":100},"",2,[101,102],{"id":14,"depth":99,"text":14},{"id":21,"depth":99,"text":21},"Nodejs","2019-05-03 09:06:26","昨天在弄 nodejs 的時候發生一件很奇妙的事情，前一天使用 ajax 還很正常，昨天突然 ajax 掛掉了...最後今天發現原因紀錄一下自己多白癡。","md","zh-Hant",{},true,"\u002Fnodejs\u002Fnodejs500","1",{"title":6,"description":105},false,"Nodejs\u002Fnodejs出現錯誤代碼500",[116,117],"Node.js","障礙排除",null,"\u002Fnodejs\u002F20190503\u002F2483499053\u002F","3WyDDSBrSgx7kQPL98OyvFijf5Bc6FJU4RaXg5uU19g",{"newer":122,"older":126},{"url":123,"title":124,"date":125},"\u002Flearnexp\u002F20190503\u002F3738458215\u002F","該如何制定自己的學習","2019-05-03 09:53:55",{"url":127,"title":128,"date":129},"\u002Flearnexp\u002F20190502\u002F4023370690\u002F","你願意犧牲多少來得到你想要的事物?","2019-05-02 10:24:41",[131,136,141],{"url":132,"title":133,"date":134,"readingMinutes":135},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":137,"title":138,"date":139,"readingMinutes":140},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":142,"title":143,"date":144,"readingMinutes":145},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784012800784]