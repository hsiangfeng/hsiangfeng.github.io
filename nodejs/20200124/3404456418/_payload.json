[{"data":1,"prerenderedAt":248},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20200124\u002F3404456418\u002F":3,"page:\u002Fnodejs\u002F20200124\u002F3404456418\u002F":4,"alt:\u002Fnodejs\u002F20200124\u002F3404456418\u002F":3,"prev-next:\u002Fnodejs\u002F20200124\u002F3404456418\u002F":223,"related:\u002Fnodejs\u002F20200124\u002F3404456418\u002F":232},"\u002Fen\u002Fnodejs\u002F2020\u002F01\u002F24\u002Finstall-nvm-on-mac-os-x\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":206,"date":207,"description":18,"extension":208,"lang":209,"meta":210,"navigation":211,"path":212,"readingMinutes":213,"seo":214,"standalone":215,"stem":216,"tags":217,"tldr":220,"updated":220,"url":221,"__hash__":222},"content\u002FNodejs\u002FMac-OS-X-安裝-nvm.md","Mac OS X 安裝 nvm","3404456418",{"type":9,"value":10,"toc":201},"minimark",[11,15,19,23,34,37,54,62,69,76,79,85,100,122,125,134,141,146,149,171,179,182,197],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來身為一名會碰到 NodeJS 的前端工程師，那麼 nvm 就是必備要裝的，只是在 Mac 環境會稍微麻煩一點不像 Windows 一樣有專屬安裝包那麼簡單。",[12,20,22],{"id":21},"安裝-nvm","安裝 nvm",[16,24,25,26,33],{},"其實在",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Fgithub.com\u002Fnvm-sh\u002Fnvm#troubleshooting-on-macos",[31],"nofollow","官方 nvm"," 是有教學，但有時候所以這邊就直接紀錄一下我先前的操作。",[16,35,36],{},"打開 iTrem2 然後輸入以下指令",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-cmd shiki shiki-themes github-dark-high-contrast","curl -o- https:\u002F\u002Fraw.githubusercontent.com\u002Fnvm-sh\u002Fnvm\u002Fv0.35.2\u002Finstall.sh | bash\n","cmd","",[45,46,47],"code",{"__ignoreMap":43},[48,49,52],"span",{"class":50,"line":51},"line",1,[48,53,41],{},[16,55,56,57,61],{},"這邊要注意不支援 Homebrew 來安裝，避免出現問題(",[58,59,60],"del",{},"反正參考文獻都這樣講了",")。",[16,63,64,65,68],{},"輸入完以上指令之後會將 nvm 安裝在 ",[45,66,67],{},"~\u002F.nvm","，這邊不懂沒關係，接下來打開 Finder 然後切到自己的目錄底下，此時你可能會看到這樣",[16,70,71],{},[72,73],"img",{"alt":74,"src":75},"Finder","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002Frayxu_%E5%92%8C_Mac-OS-X-%E5%AE%89%E8%A3%9D-nvm_md_%E2%80%94_WelcomeWebWorld.png",[16,77,78],{},"基本上你不會看到任何東西，那麼如果你要讓你的終端機或是 iTerm2 可以執行 nvm 的話，你就必須去調整一下環境變數，環境變數的調整是在相關的終端機底下設置的，但是一般來說終端機是隱藏的，所以此時在 Finder 畫面按下組合鍵 Command + Shift+ . 號(ㄡ的按鈕) 就可以顯示隱藏的檔案",[16,80,81],{},[72,82],{"alt":83,"src":84},"隱藏檔案","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202020-01-24%2019.13.53.png",[16,86,87,88,91,92,95,96,99],{},"接下來預設終端機是 ",[45,89,90],{},".bash_profile","，而 ",[45,93,94],{},"iTrem2"," 用的是 ZSH，所以是 ",[45,97,98],{},".zshrc"," 只需要在各別檔案最後加上以下環境變數即可",[38,101,103],{"className":40,"code":102,"language":42,"meta":43,"style":43},"export NVM_DIR=\"$HOME\u002F.nvm\"\n[ -s \"$NVM_DIR\u002Fnvm.sh\" ] && \\. \"$NVM_DIR\u002Fnvm.sh\"  # This loads nvm\n[ -s \"$NVM_DIR\u002Fbash_completion\" ] && \\. \"$NVM_DIR\u002Fbash_completion\"  # This loads nvm bash_completion\n",[45,104,105,110,116],{"__ignoreMap":43},[48,106,107],{"class":50,"line":51},[48,108,109],{},"export NVM_DIR=\"$HOME\u002F.nvm\"\n",[48,111,113],{"class":50,"line":112},2,[48,114,115],{},"[ -s \"$NVM_DIR\u002Fnvm.sh\" ] && \\. \"$NVM_DIR\u002Fnvm.sh\"  # This loads nvm\n",[48,117,119],{"class":50,"line":118},3,[48,120,121],{},"[ -s \"$NVM_DIR\u002Fbash_completion\" ] && \\. \"$NVM_DIR\u002Fbash_completion\"  # This loads nvm bash_completion\n",[16,123,124],{},"這樣就可以指向到 nvm 並使用囉",[16,126,127,128,130,131,133],{},"(如果底下沒有 ",[45,129,90],{}," 或是 ",[45,132,98],{}," 就自己建立一個即可)",[16,135,136,137,140],{},"最後打開終端機並輸入 ",[45,138,139],{},"nvm"," 就可以看到可以使用哪些指令囉~",[16,142,143],{},[72,144],{"alt":139,"src":145},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202020-01-24%2019.19.07.png",[16,147,148],{},"至於 nvm 常用的指令一樣是以下",[150,151,152,159,165],"ul",{},[153,154,155,158],"li",{},[45,156,157],{},"nvm install [node 版本號]"," - 安裝特定版本的 nvm",[153,160,161,164],{},[45,162,163],{},"nvm list"," - 列出已安裝清單",[153,166,167,170],{},[45,168,169],{},"nvm use [node 版本號]"," - 切換到特定 Node 版本(只限有安裝的版本)",[16,172,173,174,178],{},"如果你是想看 Windows 版的 nvm 安裝可以參考 ",[27,175,177],{"href":176},"\u002Fnodejs\u002F20200107\u002F3738078915\u002F","這一篇文章"," 唷。",[12,180,181],{"id":181},"參考文獻",[150,183,184,190],{},[153,185,186],{},[27,187,189],{"href":29,"rel":188},[31],"Troubleshooting on macOS",[153,191,192],{},[27,193,196],{"href":194,"rel":195},"https:\u002F\u002Fmedium.com\u002F@toumasaya\u002Fnode-js-%E7%92%B0%E5%A2%83%E8%A8%AD%E5%AE%9A-for-mac-a2628836feaf",[31],"Node.js 環境設定-for mac",[198,199,200],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":43,"searchDepth":112,"depth":112,"links":202},[203,204,205],{"id":14,"depth":112,"text":14},{"id":21,"depth":112,"text":22},{"id":181,"depth":112,"text":181},"Nodejs","2020-01-24 18:54:11","md","zh-Hant",{},true,"\u002Fnodejs\u002Fmac-os-x-nvm","1",{"title":6,"description":18},false,"Nodejs\u002FMac-OS-X-安裝-nvm",[218,219,139],"Mac","Node.js",null,"\u002Fnodejs\u002F20200124\u002F3404456418\u002F","_Skev0sOdKIVhbPoYvhZpXI4MQH4vgN9NWBkQsZBiDM",{"newer":224,"older":228},{"url":225,"title":226,"date":227},"\u002Fjavascript\u002F20200203\u002F3949702627\u002F","PixiJS V5 教學 (0) - 前言＆目錄","2020-02-03 08:36:41",{"url":229,"title":230,"date":231},"\u002Fother\u002F20200123\u002F1105303313\u002F","Mac OS 終端機美化看這一篇就夠了！(Mac OS Terminal)","2020-01-23 00:01:10",[233,238,243],{"url":234,"title":235,"date":236,"readingMinutes":237},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":2