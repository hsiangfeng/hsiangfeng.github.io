[{"data":1,"prerenderedAt":482},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20220221\u002F3674730635\u002F":3,"page:\u002Fnodejs\u002F20220221\u002F3674730635\u002F":4,"alt:\u002Fnodejs\u002F20220221\u002F3674730635\u002F":3,"prev-next:\u002Fnodejs\u002F20220221\u002F3674730635\u002F":458,"related:\u002Fnodejs\u002F20220221\u002F3674730635\u002F":467},"\u002Fen\u002Fnodejs\u002F2022\u002F02\u002F21\u002Fforced-to-eat-mango-09-mongoose-connect-mongodb-schema\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":439,"date":440,"description":18,"extension":441,"lang":442,"meta":443,"navigation":444,"path":445,"readingMinutes":446,"seo":447,"standalone":448,"stem":449,"tags":450,"tldr":455,"updated":455,"url":456,"__hash__":457},"content\u002F被迫吃芒果的前端工程師\u002F9-被迫吃芒果的前端工程師-Mongoose-Connect-MongoDB-Schema.md","(9)被迫吃芒果的前端工程師 - Mongoose - Connect MongoDB 與 Schema","3674730635",{"type":9,"value":10,"toc":434},"minimark",[11,15,19,23,26,29,70,73,93,100,107,118,136,155,230,239,244,254,259,263,266,269,285,288,308,311,347,350,416,427,430],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來我們將會進入 Express 開發章節，因此就會開始使用 Mongoose 連接資料庫，但是在一開始的起手式基本上就是先認識 Schema。",[12,20,22],{"id":21},"connect-mongodb","Connect MongoDB",[16,24,25],{},"相信你應該已經使用 express-generator 建立好一個 Express 應用程式，因此在這個專案下面建立一個資料夾叫做 connections 資料夾，然後再建立一個檔案叫做 database.js。",[16,27,28],{},"而連接 MongoDB 的方式很簡單，首先先請入 Mongoose",[30,31,36],"pre",{"className":32,"code":33,"language":34,"meta":35,"style":35},"language-js shiki shiki-themes github-dark-high-contrast","const mongoose = require('mongoose');\n","js","",[37,38,39],"code",{"__ignoreMap":35},[40,41,44,48,52,55,59,63,67],"span",{"class":42,"line":43},"line",1,[40,45,47],{"class":46},"sWyjQ","const",[40,49,51],{"class":50},"sCcAr"," mongoose",[40,53,54],{"class":46}," =",[40,56,58],{"class":57},"sj_SG"," require",[40,60,62],{"class":61},"sMAXC","(",[40,64,66],{"class":65},"sTRMh","'mongoose'",[40,68,69],{"class":61},");\n",[16,71,72],{},"然後開始撰寫連接方式",[30,74,76],{"className":32,"code":75,"language":34,"meta":35,"style":35},"mongoose.connect('MongoDB URL');\n",[37,77,78],{"__ignoreMap":35},[40,79,80,83,86,88,91],{"class":42,"line":43},[40,81,82],{"class":61},"mongoose.",[40,84,85],{"class":57},"connect",[40,87,62],{"class":61},[40,89,90],{"class":65},"'MongoDB URL'",[40,92,69],{"class":61},[16,94,95,96,99],{},"而 MongoDB 的 URL 可以在終端機你輸入 ",[37,97,98],{},"mongo"," 之後上方可以看到",[16,101,102],{},[103,104],"img",{"alt":105,"src":106},"MongoDB URL","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F202201292205.png",[16,108,109,110,113,114,117],{},"因此就是 ",[37,111,112],{},"mongodb:\u002F\u002F127.0.0.1:27017","，而這邊我們將會指定要連接的資料庫，例如 ",[37,115,116],{},"example","，那麼就要這樣寫",[30,119,121],{"className":32,"code":120,"language":34,"meta":35,"style":35},"mongoose.connect('mongodb:\u002F\u002F127.0.0.1:27017\u002Fexample');\n",[37,122,123],{"__ignoreMap":35},[40,124,125,127,129,131,134],{"class":42,"line":43},[40,126,82],{"class":61},[40,128,85],{"class":57},[40,130,62],{"class":61},[40,132,133],{"class":65},"'mongodb:\u002F\u002F127.0.0.1:27017\u002Fexample'",[40,135,69],{"class":61},[16,137,138,139,142,143,146,147,150,151,154],{},"那麼接下來你就可以回到 app.js 中直接寫 ",[37,140,141],{},"require('.\u002Fconnections\u002Fdatabase');"," 這時候你終端機輸入 ",[37,144,145],{},"npm start"," 基本上你會發現沒有任何的提示訊息，因為預設狀況下 ",[37,148,149],{},"mongoose"," 連接上也不會跟你說，因此你可以再打開 ",[37,152,153],{},"database.js"," 檔案，然後加入以下兩行",[30,156,158],{"className":32,"code":157,"language":34,"meta":35,"style":35},"mongoose.connection.once('open', () => console.log('connected to database'));\nmongoose.connection.on('error', (error) => console.error('database error', error));\n",[37,159,160,193],{"__ignoreMap":35},[40,161,162,165,168,170,173,176,179,182,185,187,190],{"class":42,"line":43},[40,163,164],{"class":61},"mongoose.connection.",[40,166,167],{"class":57},"once",[40,169,62],{"class":61},[40,171,172],{"class":65},"'open'",[40,174,175],{"class":61},", () ",[40,177,178],{"class":46},"=>",[40,180,181],{"class":61}," console.",[40,183,184],{"class":57},"log",[40,186,62],{"class":61},[40,188,189],{"class":65},"'connected to database'",[40,191,192],{"class":61},"));\n",[40,194,196,198,201,203,206,209,213,216,218,220,222,224,227],{"class":42,"line":195},2,[40,197,164],{"class":61},[40,199,200],{"class":57},"on",[40,202,62],{"class":61},[40,204,205],{"class":65},"'error'",[40,207,208],{"class":61},", (",[40,210,212],{"class":211},"s_sBn","error",[40,214,215],{"class":61},") ",[40,217,178],{"class":46},[40,219,181],{"class":61},[40,221,212],{"class":57},[40,223,62],{"class":61},[40,225,226],{"class":65},"'database error'",[40,228,229],{"class":61},", error));\n",[16,231,232,233,235,236],{},"首先第一行 ",[37,234,167],{}," 的意思是我只觸發一次，然後當連接上資料庫後就會輸出 ",[37,237,238],{},"connected to database",[16,240,241],{},[103,242],{"alt":238,"src":243},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-29%2022.16.54.png",[16,245,246,247,249,250,253],{},"而第二行的 ",[37,248,200],{}," 則是會實時監聽錯誤訊息，例如突然 MongoDB 不能連接上，那麼 ",[37,251,252],{},"database error"," 就會立刻噴出來",[16,255,256],{},[103,257],{"alt":252,"src":258},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-29%2022.33.16.png",[12,260,262],{"id":261},"schema","Schema",[16,264,265],{},"Schema 中文是「架構」的意思，前面我們已經透過 Mongoose 連接上 MongoDB，那接下來就必須定義 Schema，而 Schema 也類似 Model 概念。",[16,267,268],{},"而 Schema 類似再告知 MongoDB 我們要儲存什麼資料，因此首先我們先定義一個使用者的表，而通常使用者在註冊時必須提供哪些資料，以常見來講的就是以下",[270,271,272,276,279,282],"ul",{},[273,274,275],"li",{},"使用者帳號",[273,277,278],{},"使用者密碼",[273,280,281],{},"使用者暱稱",[273,283,284],{},"帳號建立日期",[16,286,287],{},"那該怎麼寫呢？首先請先在專案底下建立一個 Model 資料夾，然後取名為 User.js，接下來在裡面引入 Mongoose",[30,289,290],{"className":32,"code":33,"language":34,"meta":35,"style":35},[37,291,292],{"__ignoreMap":35},[40,293,294,296,298,300,302,304,306],{"class":42,"line":43},[40,295,47],{"class":46},[40,297,51],{"class":50},[40,299,54],{"class":46},[40,301,58],{"class":57},[40,303,62],{"class":61},[40,305,66],{"class":65},[40,307,69],{"class":61},[16,309,310],{},"引入完畢之後宣告一個變數接收 Schema 的實例",[30,312,314],{"className":32,"code":313,"language":34,"meta":35,"style":35},"const UserSchema = new mongoose.Schema({\n  ...\n});\n",[37,315,316,336,341],{"__ignoreMap":35},[40,317,318,320,323,325,328,331,333],{"class":42,"line":43},[40,319,47],{"class":46},[40,321,322],{"class":50}," UserSchema",[40,324,54],{"class":46},[40,326,327],{"class":46}," new",[40,329,330],{"class":61}," mongoose.",[40,332,262],{"class":57},[40,334,335],{"class":61},"({\n",[40,337,338],{"class":42,"line":195},[40,339,340],{"class":46},"  ...\n",[40,342,344],{"class":42,"line":343},3,[40,345,346],{"class":61},"});\n",[16,348,349],{},"而內容非常簡單，就依序填入物件屬性即可，如果你寫過 Vue 的話可能會覺得與 Props 概念很像，這邊我就直接填寫相關參數",[30,351,353],{"className":32,"code":352,"language":34,"meta":35,"style":35},"const UserSchema = new mongoose.Schema({\n  account: String,\n  password: String,\n  nickname: String,\n  createTime: {\n    type: Date,\n    default: Date.now,\n  }\n});\n",[37,354,355,371,376,381,387,393,399,405,411],{"__ignoreMap":35},[40,356,357,359,361,363,365,367,369],{"class":42,"line":43},[40,358,47],{"class":46},[40,360,322],{"class":50},[40,362,54],{"class":46},[40,364,327],{"class":46},[40,366,330],{"class":61},[40,368,262],{"class":57},[40,370,335],{"class":61},[40,372,373],{"class":42,"line":195},[40,374,375],{"class":61},"  account: String,\n",[40,377,378],{"class":42,"line":343},[40,379,380],{"class":61},"  password: String,\n",[40,382,384],{"class":42,"line":383},4,[40,385,386],{"class":61},"  nickname: String,\n",[40,388,390],{"class":42,"line":389},5,[40,391,392],{"class":61},"  createTime: {\n",[40,394,396],{"class":42,"line":395},6,[40,397,398],{"class":61},"    type: Date,\n",[40,400,402],{"class":42,"line":401},7,[40,403,404],{"class":61},"    default: Date.now,\n",[40,406,408],{"class":42,"line":407},8,[40,409,410],{"class":61},"  }\n",[40,412,414],{"class":42,"line":413},9,[40,415,346],{"class":61},[16,417,418,419,422,423,426],{},"基本上可以發現 ",[37,420,421],{},"createTime"," 會特別寫一個 ",[37,424,425],{},"default","，主要原因是當使用者建立帳號時，這個帳號建立日期預設是會自己帶上的，因此可以不用寫。",[16,428,429],{},"那麼以上就是最簡單基本的 Schema 寫法，下一篇開始會針對 Schema 的內容開始說明。",[431,432,433],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}",{"title":35,"searchDepth":195,"depth":195,"links":435},[436,437,438],{"id":14,"depth":195,"text":14},{"id":21,"depth":195,"text":22},{"id":261,"depth":195,"text":262},"Nodejs","2022-02-21 09:00:19","md","zh-Hant",{},true,"\u002F9-mongoose-connect-mongodb-schema","2",{"title":6,"description":18},false,"被迫吃芒果的前端工程師\u002F9-被迫吃芒果的前端工程師-Mongoose-Connect-MongoDB-Schema",[451,452,453,262,454],"MongoDB","Mongoose","Node.js","被迫吃芒果的前端工程師",null,"\u002Fnodejs\u002F20220221\u002F3674730635\u002F","qZI6IULLdgZJVOpMQZvYkc7IF1Fg2iAStxe5zzrbIGM",{"newer":459,"older":463},{"url":460,"title":461,"date":462},"\u002Fnodejs\u002F20220222\u002F1694798924\u002F","(10)被迫吃芒果的前端工程師 - Mongoose - String Validators","2022-02-22 09:00:19",{"url":464,"title":465,"date":466},"\u002Fgit\u002F