[{"data":1,"prerenderedAt":664},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190716\u002F135070108\u002F":3,"page:\u002Fnodejs\u002F20190716\u002F135070108\u002F":4,"alt:\u002Fnodejs\u002F20190716\u002F135070108\u002F":3,"prev-next:\u002Fnodejs\u002F20190716\u002F135070108\u002F":640,"related:\u002Fnodejs\u002F20190716\u002F135070108\u002F":649},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F16\u002Fkoa-saga-mysql-basics-3\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":623,"date":624,"description":18,"extension":625,"lang":626,"meta":627,"navigation":628,"path":629,"readingMinutes":630,"seo":631,"standalone":632,"stem":633,"tags":634,"tldr":637,"updated":637,"url":638,"__hash__":639},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-基礎篇-3.md","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-基礎篇(3)","135070108",{"type":9,"value":10,"toc":610},"minimark",[11,15,19,22,34,37,83,86,125,128,134,137,142,145,152,198,203,206,212,218,221,228,239,245,248,273,279,288,294,297,325,334,340,350,353,380,386,408,413,419,425,432,435,446,450,452,473,476,495,498,514,517,556,559,583,600,606],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇將會講到 CRUD 的 SQL 指令，所以有可能會稍微複雜一點，查詢部分在前一篇就已經寫了，所以本篇就不會再寫一次",[12,20,21],{"id":21},"新增資料",[16,23,24,25,29,30,33],{},"SQL 中將資料新增至資料表中的語法是 ",[26,27,28],"code",{},"INSERT INTO","，舉例來講我要將資料新增至 ",[26,31,32],{},"testtable"," 中，其中有兩種做法",[16,35,36],{},"新增資料:",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-sql shiki shiki-themes github-light github-light github-dark-high-contrast","INSERT INTO testtable VALUE ('Mark', 166, 50);\n","sql","",[26,45,46],{"__ignoreMap":43},[47,48,51,54,58,61,64,68,71,75,77,80],"span",{"class":49,"line":50},"line",1,[47,52,28],{"class":53},"sOudu",[47,55,57],{"class":56},"s8XSl"," testtable ",[47,59,60],{"class":53},"VALUE",[47,62,63],{"class":56}," (",[47,65,67],{"class":66},"sWayO","'Mark'",[47,69,70],{"class":56},", ",[47,72,74],{"class":73},"stw71","166",[47,76,70],{"class":56},[47,78,79],{"class":73},"50",[47,81,82],{"class":56},");\n",[16,84,85],{},"針對指定欄位新增資料:",[38,87,89],{"className":40,"code":88,"language":42,"meta":43,"style":43},"INSERT INTO testtable (name, weight, height) VALUE ('Mark', 166, 50);\n",[26,90,91],{"__ignoreMap":43},[47,92,93,95,98,101,103,106,109,111,113,115,117,119,121,123],{"class":49,"line":50},[47,94,28],{"class":53},[47,96,97],{"class":56}," testtable (",[47,99,100],{"class":53},"name",[47,102,70],{"class":56},[47,104,105],{"class":53},"weight",[47,107,108],{"class":56},", height) ",[47,110,60],{"class":53},[47,112,63],{"class":56},[47,114,67],{"class":66},[47,116,70],{"class":56},[47,118,74],{"class":73},[47,120,70],{"class":56},[47,122,79],{"class":73},[47,124,82],{"class":56},[16,126,127],{},"我個人是偏好於第二種新增方式",[16,129,130],{},[131,132],"img",{"alt":21,"src":133},"https:\u002F\u002Fi.imgur.com\u002FuzVUMlb.png",[16,135,136],{},"成功之後我們就可以看到 testtable 資料表已經新增我們剛剛新增的資料",[16,138,139],{},[131,140],{"alt":21,"src":141},"https:\u002F\u002Fi.imgur.com\u002F1nzytlW.png",[12,143,144],{"id":144},"更新資料",[16,146,147,148,151],{},"有新增那就會有更新，所以這邊就會使用到 ",[26,149,150],{},"UPDATE"," 語法，假設 jack 一夜之間的體重從 65 > 60 以及身高 156 > 180，那麼就這樣寫",[38,153,155],{"className":40,"code":154,"language":42,"meta":43,"style":43},"UPDATE testtable SET weight = 60, height = 180 WHERE name = 'jack';\n",[26,156,157],{"__ignoreMap":43},[47,158,159,161,163,166,169,172,175,178,181,184,187,190,192,195],{"class":49,"line":50},[47,160,150],{"class":53},[47,162,57],{"class":56},[47,164,165],{"class":53},"SET",[47,167,168],{"class":53}," weight",[47,170,171],{"class":53}," =",[47,173,174],{"class":73}," 60",[47,176,177],{"class":56},", height ",[47,179,180],{"class":53},"=",[47,182,183],{"class":73}," 180",[47,185,186],{"class":53}," WHERE",[47,188,189],{"class":53}," name",[47,191,171],{"class":53},[47,193,194],{"class":66}," 'jack'",[47,196,197],{"class":56},";\n",[16,199,200],{},[131,201],{"alt":144,"src":202},"https:\u002F\u002Fi.imgur.com\u002FQFVZmmx.png",[16,204,205],{},"那麼我們就可以看到資料 jack 的資料更新哩~",[16,207,208],{},[131,209],{"alt":210,"src":211},"更新前","https:\u002F\u002Fi.imgur.com\u002Fvz7VmYF.png",[16,213,214],{},[131,215],{"alt":216,"src":217},"更新後","https:\u002F\u002Fi.imgur.com\u002FmFpiDP9.png",[12,219,220],{"id":220},"刪除資料",[16,222,223,224],{},"最後來到最危險的 SQL 指令，如果只要一個不小心沒有寫好是有可能將一整張資料表資料給刪除的，所以這邊使用這個語法的時",[225,226,227],"strong",{},"務必寫清楚，否則刪除的資料將無法恢復",[16,229,230,231,234,235,238],{},"刪除語法會使用到 ",[26,232,233],{},"DELETE","，舉例我今天要刪除 ",[26,236,237],{},"TOM"," 的資料",[16,240,241],{},[131,242],{"alt":243,"src":244},"大寫 TOM","https:\u002F\u002Fi.imgur.com\u002FeLMmpvZ.png",[16,246,247],{},"那麼語法就是這樣寫",[38,249,251],{"className":40,"code":250,"language":42,"meta":43,"style":43},"DELETE FROM testtable WHERE name='TOM';\n",[26,252,253],{"__ignoreMap":43},[47,254,255,257,260,262,265,268,271],{"class":49,"line":50},[47,256,233],{"class":53},[47,258,259],{"class":53}," FROM",[47,261,57],{"class":56},[47,263,264],{"class":53},"WHERE",[47,266,267],{"class":53}," name=",[47,269,270],{"class":66},"'TOM'",[47,272,197],{"class":56},[16,274,275],{},[131,276],{"alt":277,"src":278},"刪除大 TOM","https:\u002F\u002Fi.imgur.com\u002Fu1iX86M.png",[16,280,281,282,284,285,287],{},"語法執行之後我們就可以看到大 ",[26,283,237],{}," 被刪除了，但是你也會發現很奇妙的事情，也就是通通叫 ",[26,286,237],{}," 的都被刪除了",[16,289,290],{},[131,291],{"alt":292,"src":293},"只要叫 TOM 的都被刪除","https:\u002F\u002Fi.imgur.com\u002FwzfmLzP.png",[16,295,296],{},"那麼這個原因出在 MySQL 在 Window 並不區分大小寫，所以就會有這個問題，我們可以嘗試輸入語法來驗證",[38,298,300],{"className":40,"code":299,"language":42,"meta":43,"style":43},"SELECT * FROM testtable WHERE name = 'TOM';\n",[26,301,302],{"__ignoreMap":43},[47,303,304,307,310,312,314,316,318,320,323],{"class":49,"line":50},[47,305,306],{"class":53},"SELECT",[47,308,309],{"class":53}," *",[47,311,259],{"class":53},[47,313,57],{"class":56},[47,315,264],{"class":53},[47,317,189],{"class":53},[47,319,171],{"class":53},[47,321,322],{"class":66}," 'TOM'",[47,324,197],{"class":56},[16,326,327,328,331,332],{},"我們會發現答案有兩個，也就是小 ",[26,329,330],{},"tom"," 以及大 ",[26,333,237],{},[16,335,336],{},[131,337],{"alt":338,"src":339},"大 TOM 與小 tom","https:\u002F\u002Fi.imgur.com\u002FrW1sHNX.png",[16,341,342,343],{},"只有 Linux 環境下才會區分大小寫，可以參考 ",[344,345,349],"a",{"href":346,"rel":347},"https:\u002F\u002Fjuejin.im\u002Fpost\u002F5d01235af265da1bc4144c42",[348],"nofollow","這篇文章",[16,351,352],{},"所以通常我們再刪除的時候都會針對 ID 去做刪除，因為通常 ID 是唯一值，並不會有重複的問題，所以正確要這樣寫才對",[38,354,356],{"className":40,"code":355,"language":42,"meta":43,"style":43},"SELECT * FROM testtable WHERE t_id = 3;\n",[26,357,358],{"__ignoreMap":43},[47,359,360,362,364,366,368,370,373,375,378],{"class":49,"line":50},[47,361,306],{"class":53},[47,363,309],{"class":53},[47,365,259],{"class":53},[47,367,57],{"class":56},[47,369,264],{"class":53},[47,371,372],{"class":56}," t_id ",[47,374,180],{"class":53},[47,376,377],{"class":73}," 3",[47,379,197],{"class":56},[16,381,382,383,385],{},"但是如果你真的還是要依照 ",[26,384,100],{}," 欄位去做判定，那麼就這樣寫",[38,387,389],{"className":40,"code":388,"language":42,"meta":43,"style":43},"DELETE FROM testtable BINARY name='TOM';\n",[26,390,391],{"__ignoreMap":43},[47,392,393,395,397,399,402,404,406],{"class":49,"line":50},[47,394,233],{"class":53},[47,396,259],{"class":53},[47,398,57],{"class":56},[47,400,401],{"class":53},"BINARY",[47,403,267],{"class":53},[47,405,270],{"class":66},[47,407,197],{"class":56},[16,409,410],{},[131,411],{"alt":401,"src":412},"https:\u002F\u002Fi.imgur.com\u002FSpFpjos.png",[16,414,415,416,418],{},"此時再看資料表就會看到大 ",[26,417,237],{}," 被刪除了",[16,420,421],{},[131,422],{"alt":423,"src":424},"大 TOM 說再見","https:\u002F\u002Fi.imgur.com\u002FdDM82Or.png",[16,426,427,428,431],{},"如果你是要刪除整張表的資料，那就只需要打 ",[26,429,430],{},"DELETE FROM testtable"," ← 請小心使用，資料刪除不可逆，這邊我就不示範了",[12,433,434],{"id":434},"補充",[16,436,437,438,440,441,440,443,445],{},"最後附上 ",[26,439,28],{},"、",[26,442,150],{},[26,444,233],{},"，各別說明",[447,448,28],"h3",{"id":449},"insert-into",[16,451,36],{},[38,453,455],{"className":40,"code":454,"language":42,"meta":43,"style":43},"INSERT INTO [指定資料表名稱] VALUE (欲新增的資料, 欲新增的資料, 欲新增的資料) \u002F* 注意它會依照欄位順序新增 *\u002F\n",[26,456,457],{"__ignoreMap":43},[47,458,459,461,464,466,469],{"class":49,"line":50},[47,460,28],{"class":53},[47,462,463],{"class":56}," [指定資料表名稱] ",[47,465,60],{"class":53},[47,467,468],{"class":56}," (欲新增的資料, 欲新增的資料, 欲新增的資料) ",[47,470,472],{"class":471},"sGBqm","\u002F* 注意它會依照欄位順序新增 *\u002F\n",[16,474,475],{},"指定欄位新增資料:",[38,477,479],{"className":40,"code":478,"language":42,"meta":43,"style":43},"INSERT INTO [指定資料表名稱] (指定新增的欄位, 指定新增的欄位, 指定新增的欄位) VALUE (欲新增的資料, 欲新增的資料, 欲新增的資料) \u002F* 個人都使用這個語法 *\u002F\n",[26,480,481],{"__ignoreMap":43},[47,482,483,485,488,490,492],{"class":49,"line":50},[47,484,28],{"class":53},[47,486,487],{"class":56}," [指定資料表名稱] (指定新增的欄位, 指定新增的欄位, 指定新增的欄位) ",[47,489,60],{"class":53},[47,491,468],{"class":56},[47,493,494],{"class":471},"\u002F* 個人都使用這個語法 *\u002F\n",[16,496,497],{},"新增多筆資料",[38,499,501],{"className":40,"code":500,"language":42,"meta":43,"style":43},"INSERT INTO [指定資料表名稱] (指定新增的欄位, 指定新增的欄位, 指定新增的欄位) VALUE (欲新增的資料, 欲新增的資料, 欲新增的資料),(欲新增的資料, 欲新增的資料, 欲新增的資料),(欲新增的資料, 欲新增的資料, 欲新增的資料)\n",[26,502,503],{"__ignoreMap":43},[47,504,505,507,509,511],{"class":49,"line":50},[47,506,28],{"class":53},[47,508,487],{"class":56},[47,510,60],{"class":53},[47,512,513],{"class":56}," (欲新增的資料, 欲新增的資料, 欲新增的資料),(欲新增的資料, 欲新增的資料, 欲新增的資料),(欲新增的資料, 欲新增的資料, 欲新增的資料)\n",[447,515,150],{"id":516},"update",[38,518,520],{"className":40,"code":519,"language":42,"meta":43,"style":43},"UPDATE [指定資料表名稱] SET [指定要更新的欄位] = [欲更新的資料], [指定要更新的欄位] = [欲更新的資料] WHERE [條件欄位] = [條件資料]; \u002F* 針對特定資料行更新特定欄位 *\u002F\n",[26,521,522],{"__ignoreMap":43},[47,523,524,526,528,530,533,535,538,540,543,545,548,550,553],{"class":49,"line":50},[47,525,150],{"class":53},[47,527,463],{"class":56},[47,529,165],{"class":53},[47,531,532],{"class":56}," [指定要更新的欄位] ",[47,534,180],{"class":53},[47,536,537],{"class":56}," [欲更新的資料], [指定要更新的欄位] ",[47,539,180],{"class":53},[47,541,542],{"class":56}," [欲更新的資料] ",[47,544,264],{"class":53},[47,546,547],{"class":56}," [條件欄位] ",[47,549,180],{"class":53},[47,551,552],{"class":56}," [條件資料]; ",[47,554,555],{"class":471},"\u002F* 針對特定資料行更新特定欄位 *\u002F\n",[447,557,233],{"id":558},"delete",[38,560,562],{"className":40,"code":561,"language":42,"meta":43,"style":43},"DELETE FROM [指定資料表名稱] WHERE [條件欄位] = [條件資料]; \u002F* 針對特定資料刪除特定的行 *\u002F\n",[26,563,564],{"__ignoreMap":43},[47,565,566,568,570,572,574,576,578,580],{"class":49,"line":50},[47,567,233],{"class":53},[47,569,259],{"class":53},[47,571,463],{"class":56},[47,573,264],{"class":53},[47,575,547],{"class":56},[47,577,180],{"class":53},[47,579,552],{"class":56},[47,581,582],{"class":471},"\u002F* 針對特定資料刪除特定的行 *\u002F\n",[38,584,586],{"className":40,"code":585,"language":42,"meta":43,"style":43},"DELETE FROM [指定資料表名稱]; \u002F* 刪除整個資料表資料 *\u002F\n",[26,587,588],{"__ignoreMap":43},[47,589,590,592,594,597],{"class":49,"line":50},[47,591,233],{"class":53},[47,593,259],{"class":53},[47,595,596],{"class":56}," [指定資料表名稱]; ",[47,598,599],{"class":471},"\u002F* 刪除整個資料表資料 *\u002F\n",[16,601,602,603,605],{},"※ ",[26,604,233],{}," 這個語法非常危險，請小心服用。",[607,608,609],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html pre.shiki code .stw71, html code.shiki .stw71{--shiki-light:#005CC5;--shiki-default:#005CC5;--shiki-dark:#91CBFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);fo