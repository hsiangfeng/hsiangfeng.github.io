[{"data":1,"prerenderedAt":416},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190717\u002F3433181406\u002F":3,"page:\u002Fnodejs\u002F20190717\u002F3433181406\u002F":4,"alt:\u002Fnodejs\u002F20190717\u002F3433181406\u002F":3,"prev-next:\u002Fnodejs\u002F20190717\u002F3433181406\u002F":392,"related:\u002Fnodejs\u002F20190717\u002F3433181406\u002F":401},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sql-injection\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":375,"date":376,"description":18,"extension":377,"lang":378,"meta":379,"navigation":380,"path":381,"readingMinutes":382,"seo":383,"standalone":384,"stem":385,"tags":386,"tldr":389,"updated":389,"url":390,"__hash__":391},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-SQL-injection.md","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-SQL injection","3433181406",{"type":9,"value":10,"toc":369},"minimark",[11,15,19,23,26,29,32,35,87,97,160,167,170,216,219,247,250,253,260,263,268,271,285,289,292,295,354,362,365],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"學習完畢基礎的 SQL 指令之後，接下來要來講一下關於 SQL injection，SQL injection 又是什麼?",[12,20,22],{"id":21},"sql-injection","SQL injection",[16,24,25],{},"SQL injection 又稱 SQL 注入 or SQL 隱碼、SQL 注碼等，通常這個問題是非常危險的，稍後會寫一些範例來示範",[16,27,28],{},"那個 SQL injection 主要會發生在什麼地方?與 SQL 指令的查詢、新增、更新以及刪除等動作有關係，通常會使用到分號、註解等不正常的方式塞入至 SQL 指令內，而這種行為就是 SQL injection",[12,30,31],{"id":31},"小範例",[16,33,34],{},"假設我們網站上某個地方所使用的 SQL 指令是這樣子",[36,37,42],"pre",{"className":38,"code":39,"language":40,"meta":41,"style":41},"language-sql shiki shiki-themes github-dark-high-contrast","SELECT * FROM testtable WHERE name=\"tom\" AND t_id = 1\n","sql","",[43,44,45],"code",{"__ignoreMap":41},[46,47,50,54,57,60,64,67,70,74,77,80,83],"span",{"class":48,"line":49},"line",1,[46,51,53],{"class":52},"sWyjQ","SELECT",[46,55,56],{"class":52}," *",[46,58,59],{"class":52}," FROM",[46,61,63],{"class":62},"sMAXC"," testtable ",[46,65,66],{"class":52},"WHERE",[46,68,69],{"class":52}," name=",[46,71,73],{"class":72},"sTRMh","\"tom\"",[46,75,76],{"class":52}," AND",[46,78,79],{"class":62}," t_id ",[46,81,82],{"class":52},"=",[46,84,86],{"class":85},"sCcAr"," 1\n",[16,88,89,90,93,94],{},"但是在實際 JavaScript 還是其他語言例如 PHP，都是使用變數來傳入 ",[43,91,92],{},"name"," 與 ",[43,95,96],{},"id",[36,98,102],{"className":99,"code":100,"language":101,"meta":41,"style":41},"language-js shiki shiki-themes github-dark-high-contrast","var a = \"tom\"\nvar b = 1\nconsole.log(`SELECT * FROM testtable WHERE name=${a} AND t_id = ${b}`);\n","js",[43,103,104,117,129],{"__ignoreMap":41},[46,105,106,109,112,114],{"class":48,"line":49},[46,107,108],{"class":52},"var",[46,110,111],{"class":62}," a ",[46,113,82],{"class":52},[46,115,116],{"class":72}," \"tom\"\n",[46,118,120,122,125,127],{"class":48,"line":119},2,[46,121,108],{"class":52},[46,123,124],{"class":62}," b ",[46,126,82],{"class":52},[46,128,86],{"class":85},[46,130,132,135,139,142,145,148,151,154,157],{"class":48,"line":131},3,[46,133,134],{"class":62},"console.",[46,136,138],{"class":137},"sj_SG","log",[46,140,141],{"class":62},"(",[46,143,144],{"class":72},"`SELECT * FROM testtable WHERE name=${",[46,146,147],{"class":62},"a",[46,149,150],{"class":72},"} AND t_id = ${",[46,152,153],{"class":62},"b",[46,155,156],{"class":72},"}`",[46,158,159],{"class":62},");\n",[16,161,162,163,166],{},"那麼丟到 SQL 上就會變成 ",[43,164,165],{},"SELECT * FROM testtable WHERE name='tom' AND t_id = 1","，那麼 SQL injection 又是怎麼回事?",[16,168,169],{},"當變數傳入的是這樣子",[36,171,173],{"className":99,"code":172,"language":101,"meta":41,"style":41},"var a = \"tom'#\"\nvar b = 1\nconsole.log(`SELECT * FROM testtable WHERE name=${a} AND t_id = ${b}`);\n",[43,174,175,186,196],{"__ignoreMap":41},[46,176,177,179,181,183],{"class":48,"line":49},[46,178,108],{"class":52},[46,180,111],{"class":62},[46,182,82],{"class":52},[46,184,185],{"class":72}," \"tom'#\"\n",[46,187,188,190,192,194],{"class":48,"line":119},[46,189,108],{"class":52},[46,191,124],{"class":62},[46,193,82],{"class":52},[46,195,86],{"class":85},[46,197,198,200,202,204,206,208,210,212,214],{"class":48,"line":131},[46,199,134],{"class":62},[46,201,138],{"class":137},[46,203,141],{"class":62},[46,205,144],{"class":72},[46,207,147],{"class":62},[46,209,150],{"class":72},[46,211,153],{"class":62},[46,213,156],{"class":72},[46,215,159],{"class":62},[16,217,218],{},"那麼輸出結果就會變成",[36,220,222],{"className":38,"code":221,"language":40,"meta":41,"style":41},"SELECT * FROM testtable WHERE name='tom'#' AND t_id = 1\n",[43,223,224],{"__ignoreMap":41},[46,225,226,228,230,232,234,236,238,241,244],{"class":48,"line":49},[46,227,53],{"class":52},[46,229,56],{"class":52},[46,231,59],{"class":52},[46,233,63],{"class":62},[46,235,66],{"class":52},[46,237,69],{"class":52},[46,239,240],{"class":72},"'tom'",[46,242,243],{"class":62},"#",[46,245,246],{"class":72},"' AND t_id = 1\n",[16,248,249],{},"那你一定會問這會有什麼影響?讓我們丟進去 SQL 中就知道了",[16,251,252],{},"原本正常我們只會找到一個 tom，而且是小寫的 tom",[16,254,255],{},[256,257],"img",{"alt":258,"src":259},"小寫的 tom","https:\u002F\u002Fi.imgur.com\u002FYIx8yr8.png",[16,261,262],{},"當你被 SQL injection 之後就會發生這種狀況",[16,264,265],{},[256,266],{"alt":22,"src":267},"https:\u002F\u002Fi.imgur.com\u002FzMIsAX3.png",[16,269,270],{},"你會發現全部的 TOM 都被撈出來了，那麼這就是所謂的 SQL injection，而這只是其中一個範例而已",[16,272,273,274,278,279],{},"這危險程度非常的高，可以導致駭客不需要任何帳號密碼就可以取得帳號，所以 SQL injection 又被稱為",[275,276,277],"strong",{},"填空遊戲","，危險程度可以看這邊 ",[147,280,284],{"href":281,"rel":282},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002FSQL%E6%B3%A8%E5%85%A5",[283],"nofollow","Wiki",[12,286,288],{"id":287},"javascript-避免方法","JavaScript 避免方法",[16,290,291],{},"由於本篇是在講 Koa.js，所以只會講關於 JavaScript 的解決方式唷~",[16,293,294],{},"一般來講就是使用參數話來防禦 SQL 注入的問題，舉一個最簡單的範例如下",[36,296,298],{"className":99,"code":297,"language":101,"meta":41,"style":41},"var a = \"tom'#\"\nvar b = 1\nvar sql = connection.query(`SELECT * FROM testtable WHERE name=? AND t_id=?`, ['tom', 1]);\n",[43,299,300,310,320],{"__ignoreMap":41},[46,301,302,304,306,3