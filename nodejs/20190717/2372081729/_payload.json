[{"data":1,"prerenderedAt":1009},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190717\u002F2372081729\u002F":3,"page:\u002Fnodejs\u002F20190717\u002F2372081729\u002F":4,"alt:\u002Fnodejs\u002F20190717\u002F2372081729\u002F":3,"prev-next:\u002Fnodejs\u002F20190717\u002F2372081729\u002F":984,"related:\u002Fnodejs\u002F20190717\u002F2372081729\u002F":993},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F17\u002Fkoa-saga-mysql-sequelize-1\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":967,"date":968,"description":18,"extension":969,"lang":970,"meta":971,"navigation":972,"path":973,"readingMinutes":974,"seo":975,"standalone":976,"stem":977,"tags":978,"tldr":981,"updated":981,"url":982,"__hash__":983},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-sequelize-1.md","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-sequelize(1)","2372081729",{"type":9,"value":10,"toc":958},"minimark",[11,15,19,23,26,34,40,43,46,72,75,155,158,172,181,184,187,194,197,200,203,233,236,239,311,314,339,345,427,437,602,609,615,618,624,630,637,640,646,835,841,845,848,851,857,860,871,874,880,883,889,892,899,910,915,924,930,937,940,947,954],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來將會使用 sequelize 這個套件，sequelize 它是一個 ORM，ORM 可以幫助我們解決一些問題，例如 SQL injection 的問題",[12,20,22],{"id":21},"orm","ORM",[16,24,25],{},"想必一定會有人問 ORM 是什麼鬼東西，在前面有講到 ORM 可以幫助我們解決一些問題，例如 SQL injection 的問題，但是其實不只有這個，他還可以減少我們重複程式碼的使用性，進而達到程式碼的簡潔與美麗",[16,27,28,29,33],{},"ORM 若要解釋起來說真的非常複雜，因為會與後端牽扯比較重，所以這邊引用 ",[30,31,32],"strong",{},"阮一峰"," 的簡單說法就是",[35,36,37],"blockquote",{},[16,38,39],{},"ORM 就是通過實例物件的語法，完成關聯性資料庫的操作與技術，就是物件-關聯鏡像(Object\u002FRelational Mapping)的縮寫",[12,41,42],{"id":42},"起手式",[16,44,45],{},"首先我們先來安裝一下 sequelize",[47,48,53],"pre",{"className":49,"code":50,"language":51,"meta":52,"style":52},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save sequelize\n","js","",[54,55,56],"code",{"__ignoreMap":52},[57,58,61,65,69],"span",{"class":59,"line":60},"line",1,[57,62,64],{"class":63},"sMAXC","npm install ",[57,66,68],{"class":67},"sWyjQ","--",[57,70,71],{"class":63},"save sequelize\n",[16,73,74],{},"另外這個 ORM 支援多種資料庫的處理，所以必須另外安裝相關的資料庫",[47,76,78],{"className":49,"code":77,"language":51,"meta":52,"style":52},"# 選擇對應的安裝:\nnpm install --save pg pg-hstore # Postgres\nnpm install --save mysql2\nnpm install --save mariadb\nnpm install --save sqlite3\nnpm install --save tedious # Microsoft SQL Server\n",[54,79,80,92,108,118,128,138],{"__ignoreMap":52},[57,81,82,85,89],{"class":59,"line":60},[57,83,84],{"class":63},"# ",[57,86,88],{"class":87},"s_sBn","選擇對應的安裝",[57,90,91],{"class":63},":\n",[57,93,95,97,99,102,105],{"class":59,"line":94},2,[57,96,64],{"class":63},[57,98,68],{"class":67},[57,100,101],{"class":63},"save pg pg",[57,103,104],{"class":67},"-",[57,106,107],{"class":63},"hstore # Postgres\n",[57,109,111,113,115],{"class":59,"line":110},3,[57,112,64],{"class":63},[57,114,68],{"class":67},[57,116,117],{"class":63},"save mysql2\n",[57,119,121,123,125],{"class":59,"line":120},4,[57,122,64],{"class":63},[57,124,68],{"class":67},[57,126,127],{"class":63},"save mariadb\n",[57,129,131,133,135],{"class":59,"line":130},5,[57,132,64],{"class":63},[57,134,68],{"class":67},[57,136,137],{"class":63},"save sqlite3\n",[57,139,141,143,145,148,152],{"class":59,"line":140},6,[57,142,64],{"class":63},[57,144,68],{"class":67},[57,146,147],{"class":63},"save tedious # Microsoft ",[57,149,151],{"class":150},"sCcAr","SQL",[57,153,154],{"class":63}," Server\n",[16,156,157],{},"那我們這個文章的範例是使用 MySQL 所以完整套件安裝指令是這樣子",[47,159,161],{"className":49,"code":160,"language":51,"meta":52,"style":52},"npm install --save sequelize mysql2\n",[54,162,163],{"__ignoreMap":52},[57,164,165,167,169],{"class":59,"line":60},[57,166,64],{"class":63},[57,168,68],{"class":67},[57,170,171],{"class":63},"save sequelize mysql2\n",[16,173,174,175],{},"那麼有可能有人會說為什麼不挑選這一個 ",[176,177,21],"a",{"href":178,"rel":179},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Form",[180],"nofollow",[16,182,183],{},"其實在最前面這個 node-orm 作者也是推薦我們使用 sequelize 或是 bookshelf，主要原因就是出在這兩個套件在社群上活耀度比較高，當我們出現問題的時候也會比較容易找到相關的解答，所以挑選社群活耀度較高的套件對於我們在開發上也是有一定幫助",[16,185,186],{},"那麼廢話就不多說，先來安裝套件再說",[16,188,189],{},[190,191],"img",{"alt":192,"src":193},"套件安裝","https:\u002F\u002Fi.imgur.com\u002Fatr4a6Q.png",[12,195,196],{"id":196},"使用方式",[16,198,199],{},"那麼由於 sequelize 有版本差異，如果你沒有特別挑選版本的話，應該會安裝到 sequelize V5 版，所以我這邊就會直接依照 V5 版的參考文件去做撰寫",[16,201,202],{},"首先先開啟 app.js 引入 sequelize 套件",[47,204,206],{"className":49,"code":205,"language":51,"meta":52,"style":52},"const Sequelize = require('sequelize');\n",[54,207,208],{"__ignoreMap":52},[57,209,210,213,216,219,223,226,230],{"class":59,"line":60},[57,211,212],{"class":67},"const",[57,214,215],{"class":150}," Sequelize",[57,217,218],{"class":67}," =",[57,220,222],{"class":221},"sj_SG"," require",[57,224,225],{"class":63},"(",[57,227,229],{"class":228},"sTRMh","'sequelize'",[57,231,232],{"class":63},");\n",[16,234,235],{},"接下來我們要針對資料庫做連接，那麼連接語法如下",[16,237,238],{},"基本上連接方式有兩種，另一種是比較簡短的傳輸方式，是使用 URL 的，可是我比較喜歡下面這種",[47,240,242],{"className":49,"code":241,"language":51,"meta":52,"style":52},"const sequelize = new Sequelize('test','root','123456', { \u002F\u002F 要連接的資料庫、帳號、密碼\n  host: 'localhost', \u002F\u002F 資料庫 IP\n  dialect: 'mysql' \u002F\u002F 可以選擇 mysql、mariadb、postgres、mssql 其中一個\n});\n",[54,243,244,281,295,306],{"__ignoreMap":52},[57,245,246,248,251,253,256,258,260,263,266,269,271,274,277],{"class":59,"line":60},[57,247,212],{"class":67},[57,249,250],{"class":150}," sequelize",[57,252,218],{"class":67},[57,254,255],{"class":67}," new",[57,257,215],{"class":221},[57,259,225],{"class":63},[57,261,262],{"class":228},"'test'",[57,264,265],{"class":63},",",[57,267,268],{"class":228},"'root'",[57,270,265],{"class":63},[57,272,273],{"class":228},"'123456'",[57,275,276],{"class":63},", { ",[57,278,280],{"class":279},"sQrFR","\u002F\u002F 要連接的資料庫、帳號、密碼\n",[57,282,283,286,289,292],{"class":59,"line":94},[57,284,285],{"class":63},"  host: "