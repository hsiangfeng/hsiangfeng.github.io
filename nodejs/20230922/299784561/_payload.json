而這又稱為動態路由",[763,785,786,789,790,793],{},[40,787,788],{},"https:\u002F\u002Fisraynotarray.com\u002Fsearch?keyword=Express","：搜尋頁面，",[40,791,792],{},"?keyword=Express"," 代表搜尋的關鍵字，而這又稱為查詢字串。",[12,795,796],{},"我相信你到現在應該對於路由比較有概念了，就讓我們回來前面我們所寫的 Express.js 範例吧？！",[12,798,799],{},"前面我們有簡單的寫了一下路由範例：",[33,801,803],{"className":35,"code":802,"language":37,"meta":38,"style":38},"\u002F\u002F...略過其他程式碼\n\napp.get('\u002Ftodos', (req, res) => {\n  \u002F\u002F...略過其他程式碼\n});\n\napp.post('\u002Ftodos', (req, res) => {\n  \u002F\u002F...略過其他程式碼\n});\n\n\u002F\u002F...略過其他程式碼\n",[40,804,805,810,814,838,843,847,851,875,879,883,887],{"__ignoreMap":38},[43,806,807],{"class":45,"line":46},[43,808,809],{"class":433},"\u002F\u002F...略過其他程式碼\n",[43,811,812],{"class":45,"line":75},[43,813,110],{"emptyLinePlaceholder":109},[43,815,816,818,820,822,824,826,828,830,832,834,836],{"class":45,"line":90},[43,817,134],{"class":64},[43,819,137],{"class":60},[43,821,65],{"class":64},[43,823,142],{"class":68},[43,825,145],{"class":64},[43,827,149],{"class":148},[43,829,152],{"class":64},[43,831,155],{"class":148},[43,833,158],{"class":64},[43,835,161],{"class":49},[43,837,164],{"class":64},[43,839,840],{"class":45,"line":106},[43,841,842],{"class":433},"  \u002F\u002F...略過其他程式碼\n",[43,844,845],{"class":45,"line":113},[43,846,182],{"class":64},[43,848,849],{"class":45,"line":126},[43,850,110],{"emptyLinePlaceholder":109},[43,852,853,855,857,859,861,863,865,867,869,871,873],{"class":45,"line":131},[43,854,134],{"class":64},[43,856,195],{"class":60},[43,858,65],{"class":64},[43,860,142],{"class":68},[43,862,145],{"class":64},[43,864,149],{"class":148},[43,866,152],{"class":64},[43,868,155],{"class":148},[43,870,158],{"class":64},[43,872,161],{"class":49},[43,874,164],{"class":64},[43,876,877],{"class":45,"line":167},[43,878,842],{"class":433},[43,880,881],{"class":45,"line":179},[43,882,182],{"class":64},[43,884,885],{"class":45,"line":185},[43,886,110],{"emptyLinePlaceholder":109},[43,888,889],{"class":