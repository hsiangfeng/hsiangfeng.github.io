],{},":id"," 代表文章的 ID，而這又稱為動態路由",[761,783,784,787,788,791],{},[40,785,786],{},"https:\u002F\u002Fisraynotarray.com\u002Fsearch?keyword=Express","：搜尋頁面，",[40,789,790],{},"?keyword=Express"," 代表搜尋的關鍵字，而這又稱為查詢字串。",[12,793,794],{},"我相信你到現在應該對於路由比較有概念了，就讓我們回來前面我們所寫的 Express.js 範例吧？！",[12,796,797],{},"前面我們有簡單的寫了一下路由範例：",[33,799,801],{"className":35,"code":800,"language":37,"meta":38,"style":38},"\u002F\u002F...略過其他程式碼\n\napp.get('\u002Ftodos', (req, res) => {\n  \u002F\u002F...略過其他程式碼\n});\n\napp.post('\u002Ftodos', (req, res) => {\n  \u002F\u002F...略過其他程式碼\n});\n\n\u002F\u002F...略過其他程式碼\n",[40,802,803,808,812,836,841,845,849,873,877,881,885],{"__ignoreMap":38},[43,804,805],{"class":45,"line":46},[43,806,807],{"class":433},"\u002F\u002F...略過其他程式碼\n",[43,809,810],{"class":45,"line":75},[43,811,110],{"emptyLinePlaceholder":109},[43,813,814,816,818,820,822,824,826,828,830,832,834],{"class":45,"line":90},[43,815,134],{"class":64},[43,817,137],{"class":60},[43,819,65],{"class":64},[43,821,142],{"class":68},[43,823,145],{"class":64},[43,825,149],{"class":148},[43,827,152],{"class":64},[43,829,155],{"class":148},[43,831,158],{"class":64},[43,833,161],{"class":49},[43,835,164],{"class":64},[43,837,838],{"class":45,"line":106},[43,839,840],{"class":433},"  \u002F\u002F...略過其他程式碼\n",[43,842,843],{"class":45,"line":113},[43,844,182],{"class":64},[43,846,847],{"class":45,"line":126},[43,848,110],{"emptyLinePlaceholder":109},[43,850,851,853,855,857,859,861,863,865,867,869,871],{"class":45,"line":131},[43,852,134],{"class":64},[43,854,195],{"class":60},[43,856,65],{"class":64},[43,858,142],{"class":68},[43,860,145],{"class":64},[43,862,149],{"class":148},[43,864,152],{"class":64},[43,866,155],{"class":148},[43,868,158],{"class":64},[43,870,161],{"class":49},[43,872,164],{"class":64},[43,874,875],{"class":45,"line":167},[43,876,840],{"class":433},[43,878,879],{"class":45,"line":179},[43,880,182],{"class":64},[43,882,883],{"class":45,"line":185},[43,884,110],{"emptyLinePlaceholder":109},