[{"data":1,"prerenderedAt":863},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20240101\u002F268408973\u002F":3,"page:\u002Fnodejs\u002F20240101\u002F268408973\u002F":4,"alt:\u002Fnodejs\u002F20240101\u002F268408973\u002F":3,"prev-next:\u002Fnodejs\u002F20240101\u002F268408973\u002F":838,"related:\u002Fnodejs\u002F20240101\u002F268408973\u002F":847},"\u002Fen\u002Fnodejs\u002F2024\u002F01\u002F01\u002Fhexschool-freyja-hotel-api-deployment-guide\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":820,"date":821,"description":18,"extension":822,"lang":823,"meta":824,"navigation":215,"path":825,"readingMinutes":826,"seo":827,"standalone":828,"stem":829,"tags":830,"tldr":835,"updated":821,"url":836,"__hash__":837},"content\u002FNodejs\u002F六角旅館 API 系統-freyja-之後端完整部署教學.md","六角旅館 API 系統（freyja）之後端完整部署教學","268408973",{"type":9,"value":10,"toc":811},"minimark",[11,15,19,22,33,40,43,49,59,62,68,71,74,80,83,110,113,116,119,142,149,160,176,182,188,340,343,353,356,360,368,374,377,382,385,388,394,397,403,406,412,415,421,424,430,433,439,442,448,455,458,464,471,477,487,490,496,499,505,521,546,549,552,561,567,574,580,583,589,596,599,604,607,615,621,631,654,657,660,675,678,684,687,691,702,709,712,718,721,727,730,736,743,746,757,760,766,773,776,779,785,788,793,804,807],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇將會針對六角學院所出的「六角旅館 API 系統（freyja）」後端記錄一下部署教學。",[12,20,21],{"id":21},"取得專案",[16,23,24,25,32],{},"首先一開始先點擊",[26,27,31],"a",{"href":28,"rel":29},"https:\u002F\u002Fgithub.com\u002Fhexschool\u002Ffreyja",[30],"nofollow","這裡"," 進入到六角學院的後端範例專案，然後這邊我會使用「Fork」的方式將專案複製到自己的 GitHub 帳號底下",[16,34,35],{},[36,37],"img",{"alt":38,"src":39},"fork","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fgithub-fork.jpg",[16,41,42],{},"接著你會進入 Fork 的頁面，你只需要點一下「Create Fork」就可以了",[16,44,45],{},[36,46],{"alt":47,"src":48},"fork setting","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffork_setting.png",[50,51,52],"blockquote",{},[16,53,54,58],{},[55,56,57],"strong",{},"Note","\n如果你發現你的畫面上有出現「The repository freyja already exists on this account.」的話，那就代表你已經 Fork 過，那麼就可以不用重複 Fork 了。",[16,60,61],{},"這樣你的專案底下就會多出一個專案",[16,63,64],{},[36,65],{"alt":66,"src":67},"Fork Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffork_setting2.jpg",[16,69,70],{},"（紅框處通常會變成你的 GitHub 帳號名稱）",[16,72,73],{},"接下來請你在你剛剛 Fork 的專案底下點擊「Code」，然後複製你的專案網址",[16,75,76],{},[36,77],{"alt":78,"src":79},"Copy Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fcopy_url.jpg",[16,81,82],{},"取得網址後，請打開你的終端機，並且輸入以下指令：",[84,85,90],"pre",{"className":86,"code":87,"language":88,"meta":89,"style":89},"language-bash shiki shiki-themes github-dark-high-contrast","git clone [剛剛複製的網址]\n","bash","",[91,92,93],"code",{"__ignoreMap":89},[94,95,98,102,106],"span",{"class":96,"line":97},"line",1,[94,99,101],{"class":100},"s_sBn","git",[94,103,105],{"class":104},"sTRMh"," clone",[94,107,109],{"class":108},"sMAXC"," [剛剛複製的網址]\n",[16,111,112],{},"這樣就可以將專案複製到你的電腦上囉～",[12,114,115],{"id":115},"初始化環境",[16,117,118],{},"接下來我們要進入到專案底下，並且安裝相關套件，請輸入以下指令：",[84,120,122],{"className":86,"code":121,"language":88,"meta":89,"style":89},"cd freyja\nnpm install\n",[91,123,124,133],{"__ignoreMap":89},[94,125,126,130],{"class":96,"line":97},[94,127,129],{"class":128},"sCcAr","cd",[94,131,132],{"class":104}," freyja\n",[94,134,136,139],{"class":96,"line":135},2,[94,137,138],{"class":100},"npm",[94,140,141],{"class":104}," install\n",[50,143,144],{},[16,145,146,148],{},[55,147,57],{},"\n請注意這個專案至少要 Node.js 18.16.0 以上版本才可以執行喔～",[16,150,151,152,155,156,159],{},"還原專案後，接著我們要設定一下環境變數，請你在終端機下輸入以下指令將 ",[91,153,154],{},".env.example"," 複製一份 ",[91,157,158],{},".env","：",[84,161,163],{"className":86,"code":162,"language":88,"meta":89,"style":89},"cp .env.example .env\n",[91,164,165],{"__ignoreMap":89},[94,166,167,170,173],{"class":96,"line":97},[94,168,169],{"class":100},"cp",[94,171,172],{"class":104}," .env.example",[94,174,175],{"class":104}," .env\n",[16,177,178],{},[36,179],{"alt":180,"src":181},"cp env","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fenv_cp.jpg",[16,183,184,185,187],{},"接下來打開 ",[91,186,158],{}," 檔案，你會看到以下內容：",[84,189,191],{"className":86,"code":190,"language":88,"meta":89,"style":89},"# 環境變數，區分開發或正式環境( development、production )\nNODE_ENV = \"development\"\n\n# 伺服器埠號\nPORT = 3005\n\n# MongoDB 連結\nDATABASE =\n# MongoDB 密碼\nDATABASE_PASSWORD =\n\n# JTW Token 到期日\nJWT_EXPIRES_DAY = \"7d\"\n# JTW Token 密鑰\nJWT_SECRET = \"hexschool\"\n\n# Gmail 帳號\nEMAILER_USER =\n# Gmail 應用程式密碼\nEMAILER_PASSWORD =\n",[91,192,193,199,210,217,223,234,239,245,254,260,268,273,279,290,296,307,312,318,326,332],{"__ignoreMap":89},[94,194,195],{"class":96,"line":97},[94,196,198],{"class":197},"sQrFR","# 環境變數，區分開發或正式環境( development、production )\n",[94,200,201,204,207],{"class":96,"line":135},[94,202,203],{"class":100},"NODE_ENV",[94,205,206],{"class":104}," =",[94,208,209],{"class":104}," \"development\"\n",[94,211,213],{"class":96,"line":212},3,[94,214,216],{"emptyLinePlaceholder":215},true,"\n",[94,218,220],{"class":96,"line":219},4,[94,221,222],{"class":197},"# 伺服器埠號\n",[94,224,226,229,231],{"class":96,"line":225},5,[94,227,228],{"class":100},"PORT",[94,230,206],{"class":104},[94,232,233],{"class":128}," 3005\n",[94,235,237],{"class":96,"line":236},6,[94,238,216],{"emptyLinePlaceholder":215},[94,240,242],{"class":96,"line":241},7,[94,243,244],{"class":197},"# MongoDB 連結\n",[94,246,248,251],{"class":96,"line":247},8,[94,249,250],{"class":100},"DATABASE",[94,252,253],{"class":104}," =\n",[94,255,257],{"class":96,"line":256},9,[94,258,259],{"class":197},"# MongoDB 密碼\n",[94,261,263,266],{"class":96,"line":262},10,[94,264,265],{"class":100},"DATABASE_PASSWORD",[94,267,253],{"class":104},[94,269,271],{"class":96,"line":270},11,[94,272,216],{"emptyLinePlaceholder":215},[94,274,276],{"class":96,"line":275},12,[94,277,278],{"class":197},"# JTW Token 到期日\n",[94,280,282,285,287],{"class":96,"line":281},13,[94,283,284],{"class":100},"JWT_EXPIRES_DAY",[94,286,206],{"class":104},[94,288,289],{"class":104}," \"7d\"\n",[94,291,293],{"class":96,"line":292},14,[94,294,295],{"class":197},"# JTW Token 密鑰\n",[94,297,299,302,304],{"class":96,"line":298},15,[94,300,301],{"class":100},"JWT_SECRET",[94,303,206],{"class":104},[94,305,306],{"class":104}," \"hexschool\"\n",[94,308,310],{"class":96,"line":309},16,[94,311,216],{"emptyLinePlaceholder":215},[94,313,315],{"class":96,"line":314},17,[94,316,317],{"class":197},"# Gmail 帳號\n",[94,319,321,324],{"class":96,"line":320},18,[94,322,323],{"class":100},"EMAILER_USER",[94,325,253],{"class":104},[94,327,329],{"class":96,"line":328},19,[94,330,331],{"class":197},"# Gmail 應用程式密碼\n",[94,333,335,338],{"class":96,"line":334},20,[94,336,337],{"class":100},"EMAILER_PASSWORD",[94,339,253],{"class":104},[16,341,342],{},"這邊有幾個東西要準備一下，分別是：",[344,345,346,350],"ul",{},[347,348,349],"li",{},"MongoDB 連結與密碼",[347,351,352],{},"Gmail 帳號與應用程式密碼",[16,354,355],{},"所以就讓我們來一個一個設定吧～",[357,358,349],"h3",{"id":359},"mongodb-連結與密碼",[16,361,362,363,367],{},"首先我們這邊將會使用 MongoDB Atlas 來當作我們的資料庫（這邊我會直接忽略註冊的過程），所以請你點一下",[26,364,31],{"href":365,"rel":366},"https:\u002F\u002Fwww.mongodb.com\u002F",[30],"進入到 MongoDB Atlas 的官網，然後點一下「Sign in」，如下圖：",[16,369,370],{},[36,371],{"alt":372,"src":373},"Sign in","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FMongoDB_sigin.jpg",[16,375,376],{},"接著你會進入到登入頁面，請你選擇適合你自己的方式登入",[16,378,379],{},[36,380],{"alt":372,"src":381},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fmongodb_sigin_account.png",[16,383,384],{},"這邊我會選擇「GitHub」的方式登入，所以就麻煩你選擇你自己的方式登入囉～",[16,386,387],{},"登入後，如果你是一個全新的帳號，那麼你會先被要求建立一個組織",[16,389,390],{},[36,391],{"alt":392,"src":393},"Organizations","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fmogodb_Organizations.png",[16,395,396],{},"所以就請你點一下「Create Organization」，然後輸入你的組織名稱，然後選「MongoDB Atlas」，就可以儲存建立組織了",[16,398,399],{},[36,400],{"alt":401,"src":402},"Create Organization","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FCreate_Organization.jpg",[16,404,405],{},"按下儲存後，下一頁會是「Members and Security」，也就是成員與安全性的設定，這邊你可以選擇要不要邀請其他人加入，或是直接點擊「Create Organization」（基本上這邊都是預設的，所以你可以直接點擊「Create Organization」）",[16,407,408],{},[36,409],{"alt":410,"src":411},"Members and Security","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FCreate_Organization2.jpg",[16,413,414],{},"接下來我們要來建立一個專案，因為 MongoDB Atlas 是以組織為單位，所以前面才會需要設置組織，所以現在我們要建立一個專案，請你點一下「New Project」",[16,416,417],{},[36,418],{"alt":419,"src":420},"New Project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FProjects.jpg",[16,422,423],{},"這個專案名稱可以隨便取，我就取「freyja-project」",[16,425,426],{},[36,427],{"alt":428,"src":429},"freyja-project","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Ffreyja-project.png",[16,431,432],{},"然後下一步基本上會問你要不要邀請其他人加入，這邊你可以直接點擊「Create Project」，然後就會進入到專案的首頁，這時候請你點一下畫面上的「Create」，因為我們要來部署一個資料庫",[16,434,435],{},[36,436],{"alt":437,"src":438},"Create Db","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fcreate_db.jpg",[16,440,441],{},"接下來你會進入「Deploy your database」頁面，這邊要請你選擇 「M0 Free」專案，就可以按下「Create」了",[16,443,444],{},[36,445],{"alt":446,"src":447},"Deploy your database","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FDeploy_your_database.jpg",[50,449,450],{},[16,451,452,454],{},[55,453,57],{},"\n底下的 Provider 跟 Region 的意思是指你的資料庫要部署在哪個雲端服務商的哪個地區以及哪個區域，基本上預設就很足夠了。",[16,456,457],{},"然後你就會進入 MongoDB 的快速入門設定頁面，底下你會比較需要注意一件事情，請你記下你底下的帳號與密碼，因為這個帳號與密碼會是你連接資料庫的帳號與密碼，沒問題就可以按下「Create User」",[16,459,460],{},[36,461],{"alt":462,"src":463},"Security Quickstart","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FSecurity_Quickstart.jpg",[16,465,466,467,470],{},"接著往下滾，是要設定 IP 位址的部分，也就是你會怎麼連接到資料庫，由於我們只是練習而已，所以請你在 IP 欄位輸入 ",[91,468,469],{},"0.0.0.0\u002F0","，並按下「Add Entry」，然後按下「Finish And Close」",[16,472,473],{},[36,474],{"alt":475,"src":476},"Network Access","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FNetwork%20Access.png",[50,478,479],{},[16,480,481,483,484,486],{},[55,482,57],{},"\n通常在正式環境下，我們會設定主機的固定 IP 位址，但因為這邊只是練習，所以我們就直接設定 ",[91,485,469],{},"，代表任何 IP 位址都可以連接到資料庫。",[16,488,489],{},"建立好後，畫面上有一個「Connect」的按鈕，請你點一下",[16,491,492],{},[36,493],{"alt":494,"src":495},"Connect Db","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FConnent_Db.jpg",[16,497,498],{},"接著應該會跳出一個視窗，請你選擇「Connect your application」的「Driver」，然後選擇「Node.js」，然後複製你的連結字串",[16,500,501],{},[36,502],{"alt":503,"src":504},"Connect Db2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FConnect%20Db2.jpg",[16,506,507,508,510,511,513,514,516,517,520],{},"這就是我們的 MongoDB 連結字串，請你複製起來，然後回到剛剛的 ",[91,509,158],{}," 檔案，將 ",[91,512,250],{}," 與 ",[91,515,265],{}," 的值改成你剛剛複製的連結字串，並且將 ",[91,518,519],{},"\u003Cpassword>"," 改成你剛剛設定的密碼，如下：",[84,522,526],{"className":523,"code":524,"language":525,"meta":89,"style":89},"language-env shiki shiki-themes github-dark-high-contrast","# MongoDB 連結\nDATABASE = \"mongodb+srv:\u002F\u002Ftypescript-30-ray:\u003Cpassword>@cluster0.937ixka.mongodb.net\u002F?retryWrites=true&w=majority\"\n# MongoDB 密碼\nDATABASE_PASSWORD = jqZsdqdwqwd31 # 不用擔心這是假密碼\n","env",[91,527,528,532,537,541],{"__ignoreMap":89},[94,529,530],{"class":96,"line":97},[94,531,244],{},[94,533,534],{"class":96,"line":135},[94,535,536],{},"DATABASE = \"mongodb+srv:\u002F\u002Ftypescript-30-ray:\u003Cpassword>@cluster0.937ixka.mongodb.net\u002F?retryWrites=true&w=majority\"\n",[94,538,539],{"class":96,"line":212},[94,540,259],{},[94,542,543],{"class":96,"line":219},[94,544,545],{},"DATABASE_PASSWORD = jqZsdqdwqwd31 # 不用擔心這是假密碼\n",[16,547,548],{},"恭喜你，到目前為止，終於完成了 MongoDB 的設定了～",[357,550,352],{"id":551},"gmail-帳號與應用程式密碼",[16,553,554,555,560],{},"接下來我們要來取得 Gmail 的帳號以及應用程式密碼，首先請你到 Google 設定中心，然後點選「",[26,556,559],{"href":557,"rel":558},"https:\u002F\u002Fmyaccount.google.com\u002Fu\u002F1\u002Fsecurity",[30],"安全性","」",[16,562,563],{},[36,564],{"alt":565,"src":566},"Google 設定中心","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnodemailer-google-email\u002F2023-07-22%2012.19.15.png",[16,568,569,570,573],{},"這邊要麻煩你先確定你的帳號是否有先啟用",[55,571,572],{},"兩步驗驗證","，否則 Google 不會讓你繼續往下的哦！",[16,575,576],{},[36,577],{"alt":578,"src":579},"Two Security","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FTwo%20Security.jpg",[16,581,582],{},"確定有啟用後，麻煩你在上方搜尋欄位搜尋「應用程式密碼」，然後點一下「應用程式密碼」，如下圖：",[16,584,585],{},[36,586],{"alt":587,"src":588},"Application Password","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password.png",[50,590,591],{},[16,592,593,595],{},[55,594,57],{},"\n早期可以在畫面上直接找到「應用程式密碼」，但是現在要搜尋才可以找到。",[16,597,598],{},"接著你會進入到「應用程式密碼」的頁面，請你在 App Name 欄位輸入「freyja」，然後按下「建立」",[16,600,601],{},[36,602],{"alt":587,"src":603},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password2.jpg",[16,605,606],{},"接下來畫面就會彈跳出由 Google 產生的密碼四組四位數的 16 字元密碼，如...",[84,608,613],{"className":609,"code":611,"language":612,"meta":89},[610],"language-text","abba dqwd asbc d3hr # 這是假密碼\n","text",[91,614,611],{"__ignoreMap":89},[16,616,617],{},[36,618],{"alt":619,"src":620},"Application Password3","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fapp_password3.jpg",[16,622,623,624,510,626,513,628,630],{},"接下來你就可以回到專案的 ",[91,625,158],{},[91,627,323],{},[91,629,337],{}," 的值改成你剛剛產生的密碼，如下：",[84,632,634],{"className":523,"code":633,"language":525,"meta":89,"style":89},"# Gmail 帳號\nEMAILER_USER = \"example@gmail.com\" # 你用來申請應用程式密碼的 Gmail 帳號\n# Gmail 應用程式密碼\nEMAILER_PASSWORD = \"abba dqwd asbc d3hr\" # 你申請的應用程式密碼\n",[91,635,636,640,645,649],{"__ignoreMap":89},[94,637,638],{"class":96,"line":97},[94,639,317],{},[94,641,642],{"class":96,"line":135},[94,643,644],{},"EMAILER_USER = \"example@gmail.com\" # 你用來申請應用程式密碼的 Gmail 帳號\n",[94,646,647],{"class":96,"line":212},[94,648,331],{},[94,650,651],{"class":96,"line":219},[94,652,653],{},"EMAILER_PASSWORD = \"abba dqwd asbc d3hr\" # 你申請的應用程式密碼\n",[16,655,656],{},"到目前為止，你已經把這個 Freyja 專案所需要的環境變數都設定好了，接下來我們要來執行專案了～",[16,658,659],{},"你只需要輸入以下指令：",[84,661,663],{"className":86,"code":662,"language":88,"meta":89,"style":89},"npm run dev\n",[91,664,665],{"__ignoreMap":89},[94,666,667,669,672],{"class":96,"line":97},[94,668,138],{"class":100},[94,670,671],{"class":104}," run",[94,673,674],{"class":104}," dev\n",[16,676,677],{},"你就可以看到終端機出現以下畫面：",[16,679,680],{},[36,681],{"alt":682,"src":683},"npm run dev","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fstart.png",[16,685,686],{},"這樣我們 Freyja 專案的後端就算是完成囉！",[12,688,690],{"id":689},"部署到-rendercom","部署到 Render.com",[16,692,693,694,699,700],{},"接下來請你打開 「",[26,695,698],{"href":696,"rel":697},"https:\u002F\u002Frender.com\u002F",[30],"Render.com","」，然後點一下「Sign up」，登入到 ",[26,701,698],{"href":698},[50,703,704],{},[16,705,706,708],{},[55,707,57],{},"\n如果你還沒註冊就請你註冊一下，這邊我會直接忽略註冊過程。（建議使用 GitHub 登入）",[16,710,711],{},"接著要麻煩你點一下上方的「New」，然後選擇「New Web Service」",[16,713,714],{},[36,715],{"alt":716,"src":717},"Web Service","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FRender_Dashboard.jpg",[16,719,720],{},"進入「Create a new Web Service」之後，我們選「Build and deploy from a Git repository」，並點下一步",[16,722,723],{},[36,724],{"alt":725,"src":726},"Build and deploy from a Git repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy_setp1.jpg",[16,728,729],{},"接下來請在「Connect a repository」欄位搜尋我們前面所 Fork 的名稱，也就是「freyja」，然後選擇「freyja」，並點 Connect",[16,731,732],{},[36,733],{"alt":734,"src":735},"Connect a Repository","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Fconnect_repository.jpg",[50,737,738],{},[16,739,740,742],{},[55,741,57],{},"\n如果找不到的話，代表你註冊 Render.com 的帳號跟你 Fork 的帳號不一樣，或者你的 GitHub 沒有正確給予 Render.com 的權限。",[16,744,745],{},"接下來請你輸入以下欄位",[344,747,748,751,754],{},[347,749,750],{},"Name：請輸入「freyja」",[347,752,753],{},"Instance Type：請選擇「Free」",[347,755,756],{},"Environment Variables：請依照 .env 檔案的內容輸入",[16,758,759],{},"所以會長的像這樣：",[16,761,762],{},[36,763],{"alt":764,"src":765},"Environment Variables","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002FEnvironment%20Variables.jpg",[50,767,768],{},[16,769,770,772],{},[55,771,57],{},"\n這邊並不需要設定 PROT 跟 NODE_ENV，因為 Dockerfile 裡面已經有設定了；建議填寫在 Environment Variables 時，不用補上引號。",[16,774,775],{},"接下來請你點一下「Create Web Service」，Render.com 就會開始幫你部署專案囉！",[16,777,778],{},"你只要看到畫面出現以下畫面，就代表部署成功囉！",[16,780,781],{},[36,782],{"alt":783,"src":784},"部署成功","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy.jpg",[16,786,787],{},"接著你就可以滾到上方找到 Render.com 給你的網址，點一下就可以看到你的專案囉！",[16,789,790],{},[36,791],{"alt":783,"src":792},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002F2023-typescript-nodejs\u002Frender_deploy_2.jpg",[50,794,795],{},[16,796,797,799,800,803],{},[55,798,57],{},"\n正常點網址進入你會收到一個 JSON 物件，所以建議你在網址後方補上 ",[91,801,802],{},"swagger","，這樣就可以進入到 API Doc 頁面囉！",[16,805,806],{},"以上就是完整的部署教學囉！",[808,809,810],"style",{},"html pre.shiki code .s_sBn, html cod