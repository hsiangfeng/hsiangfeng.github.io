":54},"}\u002Fapi\u002Fv1\u002Fusers`",[44,2304,188],{"class":181},[44,2306,2307],{"class":46,"line":232},[44,2308,1934],{"class":995},[44,2310,2311,2313,2315,2317,2319,2321,2323,2325,2327,2329,2332],{"class":46,"line":237},[44,2312,1894],{"class":181},[44,2314,643],{"class":177},[44,2316,182],{"class":181},[44,2318,2257],{"class":54},[44,2320,2260],{"class":181},[44,2322,2263],{"class":54},[44,2324,2266],{"class":181},[44,2326,2263],{"class":54},[44,2328,2222],{"class":170},[44,2330,2331],{"class":54},"}\u002Fapi\u002Fv1\u002Fposts`",[44,2333,188],{"class":181},[12,2335,2336],{},"很輕鬆吧？這樣子就可以增加可維護性了。",[12,2338,2339,2340,2342,2343,2345,2346,2348,2349,2351,2352,2354,2355,2357],{},"那麼這邊也提一下，為什麼要使用 ",[41,2341,1983],{}," 套件來使用環境變數呢？因為 ",[41,2344,1983],{}," 套件可以讓我們在程式碼中使用環境變數，而且 ",[41,2347,1983],{}," 套件會自動幫我們讀取 ",[41,2350,2004],{}," 檔案，並且把 ",[41,2353,2004],{}," 檔案中的環境變數加到 ",[41,2356,2134],{}," 中，這樣子我們就可以在程式碼中使用環境變數了。",[12,2359,2360,2361,2363],{},"因此這邊最後做個結論，Node.js 本身就內建 ",[41,2362,2134],{}," 的環境變數物件，但 dotenv 套件提供了更好的方式來管理、組織和使用環境變數。",[12,2365,2366],{},"那麼這一篇就先到這邊結束，我們下一篇見哩。",[20,2368,2369],{"id":2369},"碎碎念",[12,2371,2372,2373,2378],{},"其實 Env 官方後來有出一個 Dotenv Vault，我認為還滿不錯用的，詳情可以參考",[944,2374,2377],{"href":2375,"rel":2376},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20220623\u002F2852057115\u002F",[948],"這裡","唷～",[2380,2381,2382],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);te