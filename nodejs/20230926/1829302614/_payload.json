962],{"class":54},[44,2004,2005],{"class":54}," dotenv\n",[12,2007,2008,2009,2012],{},"接著我們要來建立一個 ",[41,2010,2011],{},".env"," 檔案，這個檔案就是用來存放環境變數的地方，我們可以在這個檔案中定義環境變數，例如我們可以這樣子寫",[34,2014,2016],{"className":36,"code":2015,"language":38,"meta":39,"style":39},"PORT=3000\n",[41,2017,2018],{"__ignoreMap":39},[44,2019,2020,2023,2025],{"class":46,"line":47},[44,2021,2022],{"class":181},"PORT",[44,2024,246],{"class":166},[44,2026,2027],{"class":54},"3000\n",[12,2029,2030,2031,2033],{},"這樣子就定義了一個 ",[41,2032,2022],{}," 的環境變數，接著我們要來修改我們的程式碼，讓我們的程式碼可以使用環境變數。",[34,2035,2037],{"className":157,"code":2036,"language":159,"meta":39,"style":39},"const express = require('express');\n\n\u002F\u002F 加入 dotenv 套件\nrequire('dotenv').config();\n\nconst app = express();\n\n\u002F\u002F ...略過其他程式碼\n\napp.listen(process.env.PORT);\n",[41,2038,2039,2055,2059,2064,2081,2085,2097,2101,2105,2109],{"__ignoreMap":39},[44,2040,2041,2043,2045,2047,2049,2051,2053],{"class":46,"line":47},[44,2042,167],{"class":166},[44,2044,171],{"class":170},[44,2046,174],{"class":166},[44,2048,178],{"class":177},[44,2050,182],{"class":181},[44,2052,185],{"class":54},[44,2054,188],{"class":181},[44,2056,2057],{"class":46,"line":191},[44,2058,229],{"emptyLinePlaceholder":228},[44,2060,2061],{"class":46,"line":210},[44,2062,2063],{"class":994},"\u002F\u002F 加入 dotenv 套件\n",[44,2065,2066,2069,2071,2074,2076,2079],{"class":46,"line":225},[44,2067,2068],{"class":177},"require",[44,2070,182],{"class":181},[44,2072,2073],{"class":54},"'dotenv'",[44,2075,482],{"class":181},[44,2077,2078],{"class":177},"config",[44,2080,222],{"class":181},[44,2082,2083],{"class":46,"line":232},[44,2084,229],{"emptyLinePlaceholder":228},[44,2086,2087,2089,2091,2093,2095],{"class":46,"line":237},[44,2088,167],{"class":166},[44,2090,215],{"class":170},[44,2092,174],{"class":166},[44,2094,171],{"class":177},[44,2096,222],{"class":181},[44,2098,2099],{"class":46,"line":255},[44,2100,229],{"emptyLinePlaceholder":228},[44,2102,2103],{"class":46,"line"