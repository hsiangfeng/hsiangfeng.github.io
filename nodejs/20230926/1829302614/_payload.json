[{"data":1,"prerenderedAt":2445},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20230926\u002F1829302614\u002F":3,"page:\u002Fnodejs\u002F20230926\u002F1829302614\u002F":4,"alt:\u002Fnodejs\u002F20230926\u002F1829302614\u002F":3,"prev-next:\u002Fnodejs\u002F20230926\u002F1829302614\u002F":2421,"related:\u002Fnodejs\u002F20230926\u002F1829302614\u002F":2430},"\u002Fen\u002Fnodejs\u002F2023\u002F09\u002F26\u002Fday-12-cors-and-env\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":2405,"date":2406,"description":25,"extension":2407,"lang":2408,"meta":2409,"navigation":228,"path":2410,"readingMinutes":2411,"seo":2412,"standalone":2413,"stem":2414,"tags":2415,"tldr":2418,"updated":2406,"url":2419,"__hash__":2420},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay12-關於-CORS-與-Env.md","Day12 - 關於 CORS 與 Env","1829302614",{"type":9,"value":10,"toc":2392},"minimark",[11,19,23,26,30,33,119,122,125,128,131,134,144,147,152,155,933,936,939,950,966,969,1068,1071,1074,1077,1080,1142,1156,1159,1170,1290,1301,1307,1536,1562,1571,1577,1834,1840,1844,1847,1850,1853,1864,1866,1869,1872,1874,1877,1879,1882,1885,1953,1964,1970,1980,1983,1992,2006,2013,2028,2034,2122,2135,2155,2158,2218,2233,2247,2343,2346,2367,2373,2376,2379,2388],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"關於 CORS 與 Env","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_CORS_iran_man_8c27f9b5-d41c-4ecd-8435-8dc26831b159.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"前一篇我們完成了 Express + Mongoose 的整合，接下來我們要來處理一些環境變數的問題，以及 CORS 的問題。",[20,27,29],{"id":28},"cross-origin-resource-sharing","Cross-origin resource sharing？",[12,31,32],{},"Cross-origin resource sharing？看不懂沒關係，我相信你應該知道 CORS 是什麼，假設你今天是一個前端工程師的話，你應該會很常看到這個錯誤訊息：",[34,35,40],"pre",{"className":36,"code":37,"language":38,"meta":39,"style":39},"language-bash shiki shiki-themes github-dark-high-contrast","Access to XMLHttpRequest at 'http:\u002F\u002Flocalhost:3000\u002Fapi\u002Fv1\u002Fusers' from origin 'http:\u002F\u002Flocalhost:8080' has been blocked by CORS policy: No 'Access-Control-Allow-Origin' header is present on the requested resource.\n","bash","",[41,42,43],"code",{"__ignoreMap":39},[44,45,48,52,56,59,62,65,68,71,74,77,80,83,86,89,92,95,98,101,104,107,110,113,116],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"s_sBn","Access",[44,53,55],{"class":54},"sTRMh"," to",[44,57,58],{"class":54}," XMLHttpRequest",[44,60,61],{"class":54}," at",[44,63,64],{"class":54}," 'http:\u002F\u002Flocalhost:3000\u002Fapi\u002Fv1\u002Fusers'",[44,66,67],{"class":54}," from",[44,69,70],{"class":54}," origin",[44,72,73],{"class":54}," 'http:\u002F\u002Flocalhost:8080'",[44,75,76],{"class":54}," has",[44,78,79],{"class":54}," been",[44,81,82],{"class":54}," blocked",[44,84,85],{"class":54}," by",[44,87,88],{"class":54}," CORS",[44,90,91],{"class":54}," policy:",[44,93,94],{"class":54}," No",[44,96,97],{"class":54}," 'Access-Control-Allow-Origin'",[44,99,100],{"class":54}," header",[44,102,103],{"class":54}," is",[44,105,106],{"class":54}," present",[44,108,109],{"class":54}," on",[44,111,112],{"class":54}," the",[44,114,115],{"class":54}," requested",[44,117,118],{"class":54}," resource.\n",[12,120,121],{},"這個是什麼意思呢？簡單來講就是你目前的網域以及 Prot 與你要存取的網域不同，所以會被瀏覽器擋下來，這個時候你就需要在你的後端加上 CORS 的設定，讓瀏覽器知道你允許哪些網域可以存取你的 API。",[12,123,124],{},"那麼這麼又稱之為「跨來源資源共用」，什麼意思呢？簡單來講，當你從 A 網域存取 B 網域的資源時，就稱之為跨來源資源共用。",[12,126,127],{},"而這時候為了安全性考量，瀏覽器會擋下來，這時候你就需要在後端加上 CORS 的設定，讓瀏覽器知道你允許哪些網域可以存取你的 API，這樣子就沒有問題了。",[12,129,130],{},"（通常最常發生的時機點是 AJAX 的請求。）",[12,132,133],{},"那麼我們並不打算深入探討 CORS 的原理，我們基本上只需要知道幾個小重點",[135,136,137,141],"ul",{},[138,139,140],"li",{},"當網域不同時，瀏覽器會擋下來",[138,142,143],{},"你可以在後端加上 CORS 的設定，讓瀏覽器知道你允許哪些網域可以存取你的 API",[12,145,146],{},"接下來，我們就要來替前一章節的 API 加上 CORS 的設定。",[148,149,151],"h3",{"id":150},"cors-設定","CORS 設定",[12,153,154],{},"首先我們先回顧一下前一章節寫的範例程式碼",[34,156,160],{"className":157,"code":158,"language":159,"meta":39,"style":39},"language-js shiki shiki-themes github-dark-high-contrast","const express = require('express');\nconst mongoose = require('mongoose');\nconst app = express();\n\n\nlet connectStatus = false;\n\nasync function connectMongoDB () {\n  try {\n    await mongoose.connect('mongodb+srv:\u002F\u002Furl')\n    console.log('Connected to MongoDB...')\n    connectStatus = true;\n  } catch (error) {\n    console.log(error)\n  }\n}\n\nconnectMongoDB()\n\napp.use(express.json());\n\napp.use((req, res, next) => {\n  if (connectStatus) {\n    next();\n  } else {\n    res.status(503).send({\n      status: false,\n      message: 'Server is not ready'\n    });\n  }\n})\n\nconst todoSchema = new mongoose.Schema({\n  id: Number,\n  title: String,\n  completed: Boolean,\n},{\n  versionKey: false,\n  _id: false,\n});\n\nconst Todo = mongoose.model('Todo', todoSchema);\n\napp.get('\u002Ftodos', async (req, res) => {\n  const todos = await Todo.find().select('-__v -_id');\n  res.send({\n    status: true,\n    data: todos,\n  });\n});\n\napp.post('\u002Ftodos', async (req, res) => {\n  const { title, completed } = req.body;\n\n  const todo = new Todo({\n    id: new Date().getTime(),\n    title,\n    completed,\n  });\n\n  await todo.save();\n  res.send({\n    status: true,\n    message: 'Create todo successfully',\n  });\n});\n\napp.listen(3000)\n","js",[41,161,162,189,208,223,230,235,253,258,273,282,302,318,331,343,353,359,365,370,379,384,402,407,439,448,456,466,489,501,510,516,521,527,532,552,558,564,570,576,586,596,602,607,630,635,667,700,710,721,727,733,738,743,773,797,802,818,838,844,850,855,860,874,883,892,903,908,913,918],{"__ignoreMap":39},[44,163,164,168,172,175,179,183,186],{"class":46,"line":47},[44,165,167],{"class":166},"sWyjQ","const",[44,169,171],{"class":170},"sCcAr"," express",[44,173,174],{"class":166}," =",[44,176,178],{"class":177},"sj_SG"," require",[44,180,182],{"class":181},"sMAXC","(",[44,184,185],{"class":54},"'express'",[44,187,188],{"class":181},");