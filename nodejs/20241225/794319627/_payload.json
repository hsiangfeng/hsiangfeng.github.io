[{"data":1,"prerenderedAt":1269},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20241225\u002F794319627\u002F":3,"page:\u002Fnodejs\u002F20241225\u002F794319627\u002F":4,"alt:\u002Fnodejs\u002F20241225\u002F794319627\u002F":3,"prev-next:\u002Fnodejs\u002F20241225\u002F794319627\u002F":1247,"related:\u002Fnodejs\u002F20241225\u002F794319627\u002F":1256},"\u002Fen\u002Fnodejs\u002F2024\u002F12\u002F25\u002Fpm2-process-manager-not-pm25\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1230,"date":1231,"description":1232,"extension":1233,"lang":1234,"meta":1235,"navigation":1072,"path":1236,"readingMinutes":1237,"seo":1238,"standalone":1239,"stem":1240,"tags":1241,"tldr":1244,"updated":1231,"url":1245,"__hash__":1246},"content\u002FNodejs\u002FNode-js-工程師不能不懂的-Process-Manager-2（PM2）之不是-PM2-5！.md","PM2 是 Process Manager 不是 PM2.5！","794319627",{"type":9,"value":10,"toc":1214},"minimark",[11,19,23,26,30,33,39,42,65,68,71,74,77,127,130,154,157,169,180,191,194,203,210,214,217,235,238,257,261,264,272,275,291,294,308,311,317,323,328,331,336,343,355,358,363,366,369,385,391,394,521,525,528,554,557,599,602,608,615,634,640,676,679,686,694,726,729,752,759,762,783,786,809,812,815,822,842,845,859,862,869,889,892,905,908,918,938,941,954,958,961,964,967,979,982,985,1198,1201,1207,1210],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"PM2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002Fpm2-logo-1.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"PM2 的全名是 Process Manager 2，它是一款 Node.js 的進程管理工具，並不是指 Particulate Matter（懸浮微粒）2.5 的縮寫，所以不要搞錯囉～",[20,27,29],{"id":28},"pm2process-manager-2是什麼","PM2（Process Manager 2）是什麼？",[12,31,32],{},"首先依照常見的文獻說法會說 PM2 是...",[34,35,36],"blockquote",{},[12,37,38],{},"PM2 是 JavaScript 執行環境時的 Node.js 進程管理工具。",[12,40,41],{},"雖然這句話看似非常的短，但實質上也包含了很多的內容，所以我們來拆解一下這句話，或許你會更了解 PM2 是什麼用途：",[43,44,45,53,59],"ul",{},[46,47,48,52],"li",{},[49,50,51],"strong",{},"JavaScript 執行環境","：這句話意思是指 JavaScript 在運作執行時會產生一個環境，也就是我們說的 Runtime（執行環境），這個 Runtime 會負責執行 JavaScript 的程式碼。",[46,54,55,58],{},[49,56,57],{},"Node.js","：這是一個基於 Chrome V8 引擎的 JavaScript 開發框架，它可以讓 JavaScript 在伺服器端執行，並且可以使用一些系統的 API。",[46,60,61,64],{},[49,62,63],{},"進程管理工具","：這是指一個可以管理進程（Process）的工具，所謂的進程就是一個正在運行的程式，而進程管理工具就是可以讓我們管理這些程式的工具。",[12,66,67],{},"透過上述拆解說明，我們對於 PM2 是什麼就有一定的基礎概念，但是我們為什麼要用呢？",[12,69,70],{},"這邊我舉例一個最簡單的場景，假設你有一個 Node.js 應用程式，你希望它可以一直處於運行狀態下，但應用程式可能會一些我們無法預期的 Bug 而導致程式掛掉，這時候如果沒有使用 PM2 來做管理的話，很常見的狀況就是我們要被 onCall 了，這時候就會需要一個進程管理工具來幫助我們管理這些進程哩～",[20,72,73],{"id":73},"建立初始環境",[12,75,76],{},"首先我們要來建立一個初始環境，這樣在使用 PM2 的時候才會比較有感覺，請你輸入以下指令快速建立一個 Node.js 應用程式：",[78,79,84],"pre",{"className":80,"code":81,"language":82,"meta":83,"style":83},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir pm2-example\ncd pm2-example\nexpress --no-view\nnpm install\n","bash","",[85,86,87,100,109,118],"code",{"__ignoreMap":83},[88,89,92,96],"span",{"class":90,"line":91},"line",1,[88,93,95],{"class":94},"s_sBn","mkdir",[88,97,99],{"class":98},"sTRMh"," pm2-example\n",[88,101,103,107],{"class":90,"line":102},2,[88,104,106],{"class":105},"sCcAr","cd",[88,108,99],{"class":98},[88,110,112,115],{"class":90,"line":111},3,[88,113,114],{"class":94},"express",[88,116,117],{"class":105}," --no-view\n",[88,119,121,124],{"class":90,"line":120},4,[88,122,123],{"class":94},"npm",[88,125,126],{"class":98}," install\n",[12,128,129],{},"上方指令我們做了一下行為",[43,131,132,139,145,151],{},[46,133,134,135,138],{},"建立一個名為 ",[85,136,137],{},"pm2-example"," 的資料夾",[46,140,141,142,144],{},"進入 ",[85,143,137],{}," 資料夾",[46,146,147,148,150],{},"使用 ",[85,149,114],{}," 快速建立一個 Express 應用程式，並且不使用 View Engine（因為我們只是要示範 PM2，所以使用純 API 的方式）",[46,152,153],{},"安裝 Express 的相依套件",[12,155,156],{},"接著請務必養成一個習慣，專案建立完畢後，請先執行一次程式，確保程式可以正常運行，這樣在後續使用 PM2 的時候才不會有問題：",[78,158,160],{"className":80,"code":159,"language":82,"meta":83,"style":83},"npm start\n",[85,161,162],{"__ignoreMap":83},[88,163,164,166],{"class":90,"line":91},[88,165,123],{"class":94},[88,167,168],{"class":98}," start\n",[12,170,171,172,179],{},"你現在已經可以透過 ",[173,174,178],"a",{"href":175,"rel":176},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20211207\u002F427026\u002F",[177],"nofollow","Postman"," 來去測試你的 API",[78,181,185],{"className":182,"code":183,"language":184,"meta":83,"style":83},"language-txt shiki shiki-themes github-dark-high-contrast","GET http:\u002F\u002Flocalhost:3000\u002Fusers\n","txt",[85,186,187],{"__ignoreMap":83},[88,188,189],{"class":90,"line":91},[88,190,183],{},[12,192,193],{},"不意外應該會回傳以下結果：",[78,195,197],{"className":182,"code":196,"language":184,"meta":83,"style":83},"respond with a resource\n",[85,198,199],{"__ignoreMap":83},[88,200,201],{"class":90,"line":91},[88,202,196],{},[12,204,205,206,209],{},"到這邊為主，代表你的專案是正常運作的，後面我們會再微調一下專案，讓它可以透過 PM2 來管理，而不是我們手動去輸入 ",[85,207,208],{},"npm start"," 來啟動。",[20,211,213],{"id":212},"安裝-pm2","安裝 PM2",[12,215,216],{},"首先請打開終端機，並輸入以下指令：",[78,218,220],{"className":80,"code":219,"language":82,"meta":83,"style":83},"npm install pm2 -g\n",[85,221,222],{"__ignoreMap":83},[88,223,224,226,229,232],{"class":90,"line":91},[88,225,123],{"class":94},[88,227,228],{"class":98}," install",[88,230,231],{"class":98}," pm2",[88,233,234],{"class":105}," -g\n",[12,236,237],{},"這樣就安裝完畢，非常的簡單呢！當然，如果你是使用 yarn 的話，也可以使用以下指令：",[78,239,241],{"className":80,"code":240,"language":82,"meta":83,"style":83},"yarn global add pm2\n",[85,242,243],{"__ignoreMap":83},[88,244,245,248,251,254],{"class":90,"line":91},[88,246,247],{"class":94},"yarn",[88,249,250],{"class":98}," global",[88,252,253],{"class":98}," add",[88,255,256],{"class":98}," pm2\n",[20,258,260],{"id":259},"pm2-的基本操作","PM2 的基本操作",[12,262,263],{},"使用的方式非常簡單，你主要需要記得的指令為以下：",[43,265,266],{},[46,267,268,271],{},[85,269,270],{},"pm2 start \u003C檔案名稱>","：啟動一個應用程式",[12,273,274],{},"就是這麼簡單，如果是直接啟動一個專案時，通常可能的指令會是：",[78,276,278],{"className":80,"code":277,"language":82,"meta":83,"style":83},"pm2 start app.js\n",[85,279,280],{"__ignoreMap":83},[88,281,282,285,288],{"class":90,"line":91},[88,283,284],{"class":94},"pm2",[88,286,287],{"class":98}," start",[88,289,290],{"class":98}," app.js\n",[12,292,293],{},"但是我們的專案是使用 Express 來產生的專案，所以我們要修改一下指令：",[78,295,297],{"className":80,"code":296,"language":82,"meta":83,"style":83},"pm2 start bin\u002Fwww\n",[85,298,299],{"__ignoreMap":83},[88,300,301,303,305],{"class":90,"line":91},[88,302,284],{"class":94},[88,304,287],{"class":98},[88,306,307],{"class":98}," bin\u002Fwww\n",[12,309,310],{},"輸入完畢後，你就可以看到以下畫面：",[12,312,313],{},[15,314],{"alt":315,"src":316},"Start","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.31.39.png",[12,318,319,320,322],{},"此時你會發現終端機跟以前完全不一樣，原本你輸入 ",[85,321,208],{}," 會看到以下狀況：",[12,324,325],{},[15,326],{"alt":208,"src":327},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.37.07.png",[12,329,330],{},"而使用 PM2 後，我們會發現所有的請求以及畫面都不會再呈現於終端機畫面上，這是因為 PM2 啟動專案後，它會將該啟動行為轉移到背景執行，這樣我們就可以不用擔心終端機關閉後，專案就會停止運行的問題。",[332,333,335],"h3",{"id":334},"查看-pm2-狀態與列表","查看 PM2 狀態與列表",[12,337,338,339,342],{},"那這時候問題來了，我們該怎麼查看 PM2 的狀態呢？首先你必須要先使用 ",[85,340,341],{},"pm2 list"," 來查看目前 PM2 的狀態：",[78,344,346],{"className":80,"code":345,"language":82,"meta":83,"style":83},"pm2 list\n",[85,347,348],{"__ignoreMap":83},[88,349,350,352],{"class":90,"line":91},[88,351,284],{"class":94},[88,353,354],{"class":98}," list\n",[12,356,357],{},"這時候你會看到運行於 PM2 上的專案：",[12,359,360],{},[15,361],{"alt":17,"src":362},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.46.29.png",[12,364,365],{},"這個畫面類似於儀表板，可以讓你查看目前 PM2 上運行的專案，以及一些基本資訊。",[12,367,368],{},"其中，其實有很多語法可以使用，例如：",[43,370,371,376,381],{},[46,372,373],{},[85,374,375],{},"pm2 status",[46,377,378],{},[85,379,380],{},"pm2 ls",[46,382,383],{},[85,384,341],{},[12,386,387,388,390],{},"這些指令都是可以查看目前 PM2 上運行的專案，而我自己比較習慣使用 ",[85,389,341],{}," 這個指令。",[12,392,393],{},"底下我也條列每個欄位的意義：",[43,395,396,402,415,425,435,449,455,461,490,496,502,508],{},[46,397,398,401],{},[85,399,400],{},"id","：專案的 ID，由 PM2 自動產生",[46,403,404,407,408,411,412],{},[85,405,406],{},"name","：專案的名稱，通常是專案的檔案名稱，預設會是指令後面的檔案名稱，如：",[85,409,410],{},"bin\u002Fwww"," => ",[85,413,414],{},"www",[46,416,417,420,421,424],{},[85,418,419],{},"namespace","：專案的命名空間，預設為 ",[85,422,423],{},"default","，簡單來講就是專案的群組",[46,426,427,430,431,434],{},[85,428,429],{},"version","：專案的版本，PM2 會參考 ",[85,432,433],{},"package.json"," 的版本",[46,436,437,440,441,444,445,448],{},[85,438,439],{},"mode","：專案的模式，通常是 ",[85,442,443],{},"fork","，也就是單一進程模式，當然也可以是 ",[85,446,447],{},"cluster","，也就是多進程模式",[46,450,451,454],{},[85,452,453],{},"pid","：專案的 PID，也就是 Process ID",[46,456,457,460],{},[85,458,459],{},"uptime","：專案的運行時間，也就是啟動後的時間",[46,462,463,466,467,470,471,473,474,477,478,481,482,485,486,489],{},[85,464,465],{},"status","：專案的狀態，通常是 ",[85,468,469],{},"online","，主要有 ",[85,472,469],{},"（運作中）、",[85,475,476],{},"stopped","（專案已停止）、",[85,479,480],{},"errored","（發生錯誤）、",[85,483,484],{},"launching","（正在啟動） 以及",[85,487,488],{},"unknown","（狀態未知） 等狀態",[46,491,492,495],{},[85,493,494],{},"cpu","：專案的 CPU 使用率",[46,497,498,501],{},[85,499,500],{},"mem","：專案的記憶體使用率",[46,503,504,507],{},[85,505,506],{},"user","：專案的使用者，這會撈取目前使用者的名稱",[46,509,510,513,514,517,518],{},[85,511,512],{},"watching","：專案是否有監聽檔案變化，通常是 ",[85,515,516],{},"false","，當有監聽檔案變化時，會是 ",[85,519,520],{},"true",[332,522,524],{"id":523},"查看-pm2-logs","查看 PM2 Logs",[12,526,527],{},"接著我們要查看該專案運行的 Logs 呢？只需要輸入以下指令即可：",[78,529,531],{"className":80,"code":530,"language":82,"meta":83,"style":83},"pm2 logs \u003C專案名稱\u002FID\u002F名稱空間>\n",[85,532,533],{"__ignoreMap":83},[88,534,535,537,540,544,547,551],{"class":90,"line":91},[88,536,284],{"class":94},[88,538,539],{"class":98}," logs",[88,541,543],{"class":542},"sWyjQ"," \u003C",[88,545,546],{"class":98},"專案名稱\u002FID\u002F名稱空",[88,548,550],{"class":549},"sMAXC","間",[88,552,553],{"class":542},">\n",[12,555,556],{},"以我們範例來講，就是：",[78,558,560],{"className":80,"code":559,"language":82,"meta":83,"style":83},"pm2 logs 0 # 0 是專案的 ID\npm2 logs www # www 是專案的名稱\npm2 logs default # default 是專案的名稱空間\n",[85,561,562,575,587],{"__ignoreMap":83},[88,563,564,566,568,571],{"class":90,"line":91},[88,565,284],{"class":94},[88,567,539],{"class":98},[88,569,570],{"class":105}," 0",[88,572,574],{"class":573},"sQrFR"," # 0 是專案的 ID\n",[88,576,577,579,581,584],{"class":90,"line":102},[88,578,284],{"class":94},[88,580,539],{"class":98},[88,582,583],{"class":98}," www",[88,585,586],{"class":573}," # www 是專案的名稱\n",[88,588,589,591,593,596],{"class":90,"line":111},[88,590,284],{"class":94},[88,592,539],{"class":98},[88,594,595],{"class":98}," default",[88,597,598],{"class":573}," # default 是專案的名稱空間\n",[12,600,601],{},"這樣就可以持續查看專案的 Logs 了！",[12,603,604],{},[15,605],{"alt":606,"src":607},"Logs","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fpm2-express\u002F%E6%88%AA%E5%9C%96%202024-12-25%2013.54.51.png",[12,609,610,611,614],{},"我這邊也詳細說明一下 ",[85,612,613],{},"pm2 logs"," 的指令：",[43,616,617,622,628],{},[46,618,619,621],{},[85,620,613],{},"：查看所有專案的 Logs",[46,623,624,627],{},[85,625,626],{},"pm2 logs \u003C專案名稱\u002FID>","：查看指定專案的 Logs",[46,629,630,633],{},[85,631,632],{},"pm2 logs \u003C命名空間>","：概念其實類似於群組，你可以將專案分類，這樣就可以使用命名空間來查看該群組的 Logs",[12,635,636,637,639],{},"除此之外，",[85,638,613],{}," 搭配不同的參數，可以讓你更精準的查看 Logs，例如：",[43,641,642,648,654,660,670],{},[46,643,644,647],{},[85,645,646],{},"pm2 logs --out","：只查看標準輸出，也就是正常輸出",[46,649,650,653],{},[85,651,652],{},"pm2 logs --err","：只查看錯誤輸出",[46,655,656,659],{},[85,657,658],{},"pm2 logs --json > logs.json","：將 Logs 輸出成 JSON 格式，這樣你就可以透過程式來處理 Logs",[46,661,662,665,666,669],{},[85,663,664],{},"pm2 logs \u003C專案名稱\u002FID> | grep \"關鍵字\"","：查看特定關鍵字的 Logs，概念就是一個篩選器，例如：",[85,667,668],{},"pm2 logs www | grep \"GET\"","，就可以查看所有 GET 的 Logs",[46,671,672,675],{},[85,673,674],{},"pm2 logs \u003C專案名稱\u002FID> --lines 100","：只查看最後 100 行的 Logs，也就是最新的 100 行",[12,677,678],{},"以上差不多是很常用的指令。",[332,680,682,683],{"id":681},"傳遞參數給-pm2-start","傳遞參數給 ",[85,684,685],{},"pm2 start",[12,687,688,690,691,693],{},[85,689,685],{}," 並不是這麼單純的指令，你可以透過傳遞參數給 ",[85,692,685],{}," 來做更多的事情，例如：",[43,695,696,702,708,714,720],{},[46,697,698,701],{},[85,699,700],{},"--name","：指定專案名稱",[46,703,704,707],{},[85,705,706],{},"--watch","：監聽檔案變化，當檔案變化時，自動重新啟動專案",[46,709,710,713],{},[85,711,712],{},"--cron-restart","：透過 Cron 表達式定時重新啟動專案",[46,715,716,719],{},[85,717,718],{},"--max-memory-restart","：當記憶體使用超過指定值時，自動重新啟動專案",[46,721,722,725],{},[85,723,724],{},"--namespace","：指定專案名稱空間",[12,727,728],{},"這邊我舉例一個常見的使用方式：",[78,730,732],{"className":80,"code":731,"language":82,"meta":83,"style":83},"pm2 start bin\u002Fwww --name \"hexschool-example\" --watch\n",[85,733,734],{"__ignoreMap":83},[88,735,736,738,740,743,746,749],{"class":90,"line":91},[88,737,284],{"class":94},[88,739,287],{"class":98},[88,741,742],{"class":98}," bin\u002Fwww",[88,744,745],{"class":105}," --name",[88,747,748],{"class":98}," \"hexschool-example\"",[88,750,751],{"class":105}," --watch\n",[12,753,754,755,758],{},"這樣就可以指定專案名稱為 ",[85,756,757],{},"hexschool-example","，並且監聽檔案變化，當檔案變化時，自動重新啟動專案。",[12,760,761],{},"如果我想要指定專案名稱空間的話，可以這樣做：",[78,763,765],{"className":80,"code":764,"language":82,"meta":83,"style":83},"pm2 start bin\u002Fwww --namespace \"hexschool\" --watch\n",[85,766,767],{"__ignoreMap":83},[88,768,769,771,773,775,778,781],{"class":90,"line":91},[88,770,284],{"class":94},[88,772,287],{"class":98},[88,774,742],{"class":98},[88,776,777],{"class":105}," --namespace",[88,779,780],{"class":98}," \"hexschool\"",[88,782,751],{"class":105},[12,784,785],{},"如果想要同時更改專案名稱以及名稱空間的話，可以這樣做：",[78,787,789],{"className":80,"code":788,"language":82,"meta":83,"style":83},"pm2 start bin\u002Fwww --name \"hexschool-example\" --namespace \"hexschool\" --watch\n",[85,790,791],{"__ignoreMap":83},[88,792,793,795,797,799,801,803,805,807],{"class":90,"line":91},[88,794,284],{"class":94},[88,796,287],{"class":98},[88,798,742],{"class":98},[88,800,745],{"class":105},[88,802,748],{"class":98},[88,804,777],{"class":105},[88,806,780],{"class":98},[88,808,751],{"class":105},[12,810,811],{},"這樣就可以同時指定專案名稱以及名稱空間了！",[332,813,814],{"id":814},"重新啟動專案",[12,816,817,818,821],{},"當你的專案有異常時，你可以透過 ",[85,819,820],{},"pm2 restart"," 來重新啟動專案：",[78,823,825],{"className":80,"code":824,"language":82,"meta":83,"style":83},"pm2 restart \u003C專案名稱\u002FID\u002F名稱空間>\n",[85,826,827],{"__ignoreMap":83},[88,828,829,831,834,836,838,840],{"class":90,"line":91},[88,830,284],{"class":94},[88,832,833],{"class":98}," restart",[88,835,543],{"class":542},[88,837,546],{"class":98},[88,839,550],{"class":549},[88,841,553],{"class":542},[12,843,844],{},"如果是想要重新啟動所有專案的話，可以這樣做：",[78,846,848],{"className":80,"code":847,"language":82,"meta":83,"style":83},"pm2 restart all\n",[85,849,850],{"__ignoreMap":83},[88,851,852,854,856],{"class":90,"line":91},[88,853,284],{"class":94},[88,855,833],{"class":98},[88,857,858],{"class":98}," all\n",[332,860,861],{"id":861},"停止專案",[12,863,864,865,868],{},"當你的專案不再需要運行時，你可以透過 ",[85,866,867],{},"pm2 stop"," 來停止專案：",[78,870,872],{"className":80,"code":871,"language":82,"meta":83,"style":83},"pm2 stop \u003C專案名稱\u002FID\u002F名稱空間>\n",[85,873,874],{"__ignoreMap":83},[88,875,876,878,881,883,885,887],{"class":90,"line":91},[88,877,284],{"class":94},[88,879,880],{"class":98}," stop",[88,882,543],{"class":542},[88,884,546],{"class":98},[88,886,550],{"class":549},[88,888,553],{"class":542},[12,890,891],{},"如果是想要停止所有專案的話，可以這樣做：",[78,893,895],{"className":80,"code":894,"language":82,"meta":83,"style":83},"pm2 stop all\n",[85,896,897],{"__ignoreMap":83},[88,898,899,901,903],{"class":90,"line":91},[88,900,284],{"class":94},[88,902,880],{"class":98},[88,904,858],{"class":98},[332,906,907],{"id":907},"刪除專案",[12,909,910,911,913,914,917],{},"請注意，輸入 ",[85,912,867],{}," 並不會刪除專案，只是停止專案而已，如果你想要刪除專案的話，可以透過 ",[85,915,916],{},"pm2 delete"," 來刪除專案：",[78,919,921],{"className":80,"code":920,"language":82,"meta":83,"style":83},"pm2 delete \u003C專案名稱\u002FID\u002F名稱空間>\n",[85,922,923],{"__ignoreMap":83},[88,924,925,927,930,932,934,936],{"class":90,"line":91},[88,926,284],{"class":94},[88,928,929],{"class":98}," delete",[88,931,543],{"class":542},[88,933,546],{"class":98},[88,935,550],{"class":549},[88,937,553],{"class":542},[12,939,940],{},"如果是想要刪除所有專案的話，可以這樣做：",[78,942,944],{"className":80,"code":943,"language":82,"meta":83,"style":83},"pm2 delete all\n",[85,945,946],{"__ignoreMap":83},[88,947,948,950,952],{"class":90,"line":91},[88,949,284],{"class":94},[88,951,929],{"class":98},[88,953,858],{"class":98},[20,955,957],{"id":956},"pm2-進階設定ecosystem-file","PM2 進階設定（Ecosystem File）",[12,959,960],{},"PM2 有一個進階的設定檔案，稱為 Ecosystem File，你可以透過這個檔案直接做到更多的設定，而 Ecosystem File 支援 JavaScript、JSON 以及 YAML 格式。",[12,962,963],{},"但以實戰來講，比較常見使用 ecosystem.config.js（JavaScript 格式）。",[12,965,966],{},"那麼我們該如何使用呢？你只需要輸入以下指令，PM2 就會自動幫你產出一個 Ecosystem File（ecosystem.config.js）：",[78,968,970],{"className":80,"code":969,"language":82,"meta":83,"style":83},"pm2 ecosystem\n",[85,971,972],{"__ignoreMap":83},[88,973,974,976],{"class":90,"line":91},[88,975,284],{"class":94},[88,977,978],{"class":98}," ecosystem\n",[12,980,981],{},"基本上他會基於你當前的專案環境，產出一個 Ecosystem File，這樣你就可以直接使用這個檔案來做進階設定。",[12,983,984],{},"格式大概長這樣：",[78,986,990],{"className":987,"code":988,"language":989,"meta":83,"style":83},"language-javascript shiki shiki-themes github-dark-high-contrast","module.exports = {\n  apps : [{\n    script: 'index.js',\n    watch: '.'\n  }, {\n    script: '.\u002Fservice-worker\u002F',\n    watch: ['.\u002Fservice-worker']\n  }],\n\n  deploy : {\n    production : {\n      user : 'SSH_USERNAME',\n      host : 'SSH_HOSTMACHINE',\n      ref  : 'origin\u002Fmaster',\n      repo : 'GIT_REPOSITORY',\n      path : 'DESTINATION_PATH',\n      'pre-deploy-local': '',\n      'post-deploy' : 'npm install && pm2 reload ecosystem.config.js --env production',\n      'pre-setup': ''\n    }\n  }\n};\n","javascrip