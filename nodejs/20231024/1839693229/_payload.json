[{"data":1,"prerenderedAt":1914},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20231024\u002F1839693229\u002F":3,"page:\u002Fnodejs\u002F20231024\u002F1839693229\u002F":4,"alt:\u002Fnodejs\u002F20231024\u002F1839693229\u002F":3,"prev-next:\u002Fnodejs\u002F20231024\u002F1839693229\u002F":1889,"related:\u002Fnodejs\u002F20231024\u002F1839693229\u002F":1898},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F24\u002Fmac-auto-nvm-use-on-project-open\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1873,"date":1874,"description":25,"extension":1875,"lang":1876,"meta":1877,"navigation":231,"path":1878,"readingMinutes":1879,"seo":1880,"standalone":1881,"stem":1882,"tags":1883,"tldr":1886,"updated":1874,"url":1887,"__hash__":1888},"content\u002FNodejs\u002FMac-開啟專案時，自動使用-nvm-use-切換到專案的-Node-版本.md","Mac 開啟專案時，自動使用 nvm use 切換到專案的 Node 版本","1839693229",{"type":9,"value":10,"toc":1865},"minimark",[11,19,23,26,29,32,52,55,59,83,91,108,111,121,149,163,246,263,269,287,290,362,365,369,372,375,381,387,390,399,410,415,434,441,447,451,454,1032,1048,1054,1072,1079,1193,1197,1200,1206,1511,1518,1521,1847,1861],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"nvm auto use","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fnvm-auto-use\u002Fisray_notarray_auto_use_bot_796b39ea-0c32-4ad8-8c4a-2a151ff28d99.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"身為一名 Node.js 相關的開發者，常常會遇到需要切換 Node.js 版本的情況，但是我們每個專案所使用的 Node.js 都不同，因此就很容易忘記切換版本，所以這一篇就要來記錄一下如何在 Mac 上開啟專案時，就自動使用 nvm 切換 Node 版本。",[20,27,28],{"id":28},"前置動作",[12,30,31],{},"這邊有幾件事情必須先告知，你要開始使用這一篇往下設定之前，你必須先透過我的底下兩篇文章設定過 zsh、nvm，如果你還沒有設定過，建議你先設定完再繼續往下閱讀，否則有很高機會遇到一些奇怪的問題哩",[33,34,35,45],"ul",{},[36,37,38],"li",{},[39,40,44],"a",{"href":41,"rel":42},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20200123\u002F1105303313\u002F",[43],"nofollow","Mac OS 終端機美化看這一篇就夠了！(Mac OS Terminal)",[36,46,47],{},[39,48,51],{"href":49,"rel":50},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20200124\u002F3404456418\u002F",[43],"Mac OS X 安裝 nvm",[12,53,54],{},"如果你確定你本身已經電腦有安裝 nvm 並且有設定過 zsh（oh-my-zsh），那麼就可以繼續往下閱讀囉！",[20,56,58],{"id":57},"安裝-zsh-nvm","安裝 zsh-nvm",[12,60,61,62,66,67,70,71,74,75,78,79,82],{},"那麼如前提來講，我們開發的專案每一個 Node.js 版本都不同，而我們 ",[63,64,65],"code",{},"nvm"," 所預設的 Node.js 版本可能也不同，例如專案所需要使用的版本是 ",[63,68,69],{},"18.17.0","，但我 nvm 預設版本是 ",[63,72,73],{},"16.15.0","，那麼就有可能發生忘記使用 ",[63,76,77],{},"nvm use 18.17.0"," 的情況，因此我們可以透過 ",[63,80,81],{},"zsh-nvm"," 來幫我們自動切換版本。",[12,84,85,86,90],{},"首先 ",[39,87,81],{"href":88,"rel":89},"https:\u002F\u002Fgithub.com\u002Flukechilds\u002Fzsh-nvm",[43]," 官方文件來講，你可以使用以下方式安裝：",[33,92,93,96,99,102,105],{},[36,94,95],{},"antigen",[36,97,98],{},"zplug",[36,100,101],{},"zgen",[36,103,104],{},"手動",[36,106,107],{},"作為 oh-my-zsh 自定義套件",[12,109,110],{},"那麼這邊我就會以「As an Oh My ZSH! custom plugin」來安裝，因為我本身就是使用 oh-my-zsh 所以我就直接使用這個方式。",[12,112,113,114,116,117,120],{},"首先我們先打開終端機輸入以下將 ",[63,115,81],{}," 安裝到 ",[63,118,119],{},"oh-my-zsh"," 的自定義套件資料夾：",[122,123,128],"pre",{"className":124,"code":125,"language":126,"meta":127,"style":127},"language-bash shiki shiki-themes github-dark-high-contrast","git clone https:\u002F\u002Fgithub.com\u002Flukechilds\u002Fzsh-nvm ~\u002F.oh-my-zsh\u002Fcustom\u002Fplugins\u002Fzsh-nvm\n","bash","",[63,129,130],{"__ignoreMap":127},[131,132,135,139,143,146],"span",{"class":133,"line":134},"line",1,[131,136,138],{"class":137},"s_sBn","git",[131,140,142],{"class":141},"sTRMh"," clone",[131,144,145],{"class":141}," https:\u002F\u002Fgithub.com\u002Flukechilds\u002Fzsh-nvm",[131,147,148],{"class":141}," ~\u002F.oh-my-zsh\u002Fcustom\u002Fplugins\u002Fzsh-nvm\n",[12,150,151,152,155,156,159,160,162],{},"接著找到 ",[63,153,154],{},"~\u002F.zshrc"," 這個檔案，並且在 ",[63,157,158],{},"plugins"," 這個參數中加入 ",[63,161,81],{},"：",[122,164,166],{"className":124,"code":165,"language":126,"meta":127,"style":127},"plugins=( \n  git\n  # other plugins...\n  zsh-autosuggestions\n  zsh-syntax-highlighting\n  # 加入底下這一行\n  zsh-nvm  \n)\n\nsource $ZSH\u002Foh-my-zsh.sh\n",[63,167,168,180,186,193,199,205,211,220,226,233],{"__ignoreMap":127},[131,169,170,173,177],{"class":133,"line":134},[131,171,158],{"class":172},"sMAXC",[131,174,176],{"class":175},"sWyjQ","=",[131,178,179],{"class":172},"( \n",[131,181,183],{"class":133,"line":182},2,[131,184,185],{"class":141},"  git\n",[131,187,189],{"class":133,"line":188},3,[131,190,192],{"class":191},"sQrFR","  # other plugins...\n",[131,194,196],{"class":133,"line":195},4,[131,197,198],{"class":141},"  zsh-autosuggestions\n",[131,200,202],{"class":133,"line":201},5,[131,203,204],{"class":141},"  zsh-syntax-highlighting\n",[131,206,208],{"class":133,"line":207},6,[131,209,210],{"class":191},"  # 加入底下這一行\n",[131,212,214,217],{"class":133,"line":213},7,[131,215,216],{"class":141},"  zsh-nvm",[131,218,219],{"class":172},"  \n",[131,221,223],{"class":133,"line":222},8,[131,224,225],{"class":172},")\n",[131,227,229],{"class":133,"line":228},9,[131,230,232],{"emptyLinePlaceholder":231},true,"\n",[131,234,236,240,243],{"class":133,"line":235},10,[131,237,239],{"class":238},"sCcAr","source",[131,241,242],{"class":172}," $ZSH",[131,244,245],{"class":141},"\u002Foh-my-zsh.sh\n",[247,248,249],"blockquote",{},[12,250,251,255,256,259,260,262],{},[252,253,254],"strong",{},"Note","\n請注意 ",[63,257,258],{},"source $ZSH\u002Foh-my-zsh.sh"," 一定要在 ",[63,261,158],{}," 這個參數的下面，否則會出現錯誤。",[12,264,265,266,268],{},"最後你要在 ",[63,267,258],{}," 之前加入以下這一行：",[122,270,272],{"className":124,"code":271,"language":126,"meta":127,"style":127},"export NVM_AUTO_USE=true\n",[63,273,274],{"__ignoreMap":127},[131,275,276,279,282,284],{"class":133,"line":134},[131,277,278],{"class":175},"export",[131,280,281],{"class":172}," NVM_AUTO_USE",[131,283,176],{"class":175},[131,285,286],{"class":172},"true\n",[12,288,289],{},"所以會變成以下這樣：",[122,291,293],{"className":124,"code":292,"language":126,"meta":127,"style":127},"plugins=( \n  git\n  # other plugins...\n  zsh-autosuggestions\n  zsh-syntax-highlight