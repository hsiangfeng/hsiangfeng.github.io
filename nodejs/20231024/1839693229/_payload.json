}\n\nadd-zsh-hook chpwd load-nvmrc\nload-nvmrc\n",[63,1525,1526,1530,1534,1538,1542,1547,1555,1559,1564,1570,1575,1581,1586,1598,1602,1607,1625,1630,1636,1641,1665,1669,1674,1694,1699,1705,1710,1734,1739,1750,1754,1758,1763,1803,1808,1821,1825,1829,1833,1842],{"__ignoreMap":127},[131,1527,1528],{"class":133,"line":134},[131,1529,1215],{"class":191},[131,1531,1532],{"class":133,"line":182},[131,1533,232],{"emptyLinePlaceholder":231},[131,1535,1536],{"class":133,"line":188},[131,1537,337],{"class":191},[131,1539,1540],{"class":133,"line":195},[131,1541,232],{"emptyLinePlaceholder":231},[131,1543,1544],{"class":133,"line":201},[131,1545,1546],{"class":191},"## 自動載入 Zsh hook 函式庫\n",[131,1548,1549,1551,1553],{"class":133,"line":207},[131,1550,1228],{"class":238},[131,1552,1231],{"class":238},[131,1554,1234],{"class":141},[131,1556,1557],{"class":133,"line":213},[131,1558,232],{"emptyLinePlaceholder":231},[131,1560,1561],{"class":133,"line":222},[131,1562,1563],{"class":191},"## 宣告 load-nvmrc 函式\n",[131,1565,1566,1568],{"class":133,"line":228},[131,1567,1244],{"class":1243},[131,1569,1247],{"class":172},[131,1571,1572],{"class":133,"line":235},[131,1573,1574],{"class":191},"  ## 宣告 nvmrc_path 變數，紀錄 .nvmrc 檔案路徑\n",[131,1576,1577,1579],{"class":133,"line":350},[131,1578,1252],{"class":175},[131,1580,1255],{"class":172},[131,1582,1583],{"class":133,"line":355},[131,1584,1585],{"class":191},"  ## 使用 nvm_find_nvmrc 函式尋找 .nvmrc 檔案\n",[131,1587,1588,1590,1592,1594,1596],{"class":133,"line":662},[131,1589,1260],{"class":172},[131,1591,176],{"class":175},[131,1593,1265],{"class":141},[131,1595,1268],{"class":137},[131,1597,1271],{"class":141},[131,1599,1600],{"class":133,"line":667},[131,1601,232],{"emptyLinePlaceholder":231},[131,1603,1604],{"class":133,"line":703},[131,1605,1606],{"class":191},"  ## 如果有找到 .nvmrc 檔案\n",[131,1608,1609,1611,1613,1615,1617,1619,1621,1623],{"class":133,"line":717},[131,1610,1280],{"class":175},[131,1612,1283],{"class":172},[131,1614,1286],{"class":17