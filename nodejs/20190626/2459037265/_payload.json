[{"data":1,"prerenderedAt":198},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190626\u002F2459037265\u002F":3,"page:\u002Fnodejs\u002F20190626\u002F2459037265\u002F":4,"alt:\u002Fnodejs\u002F20190626\u002F2459037265\u002F":3,"prev-next:\u002Fnodejs\u002F20190626\u002F2459037265\u002F":173,"related:\u002Fnodejs\u002F20190626\u002F2459037265\u002F":182},"\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-version-number-explained\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":157,"date":158,"description":18,"extension":159,"lang":160,"meta":161,"navigation":162,"path":163,"readingMinutes":164,"seo":165,"standalone":166,"stem":167,"tags":168,"tldr":170,"updated":170,"url":171,"__hash__":172},"content\u002FNodejs\u002Fnpm-版本號辨別.md","npm 版本號辨別","2459037265",{"type":9,"value":10,"toc":152},"minimark",[11,15,19,22,25,32,35,64,67,80,83,97,100,103,119,122,125,132,148],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這邊紀錄一下如何辨別 npm 版本號，避免自己忘記怎麼看板本號...",[12,20,21],{"id":21},"範例",[16,23,24],{},"這邊範例將會使用 hexo 的 package.json 來做介紹",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"package.json","https:\u002F\u002Fi.imgur.com\u002FUbn0HlU.png",[16,33,34],{},"拿這一段做介紹",[36,37,42],"pre",{"className":38,"code":39,"language":40,"meta":41,"style":41},"language-js shiki shiki-themes github-dark-high-contrast","\"hexo\": \"^3.8.0\",\n","js","",[43,44,45],"code",{"__ignoreMap":41},[46,47,50,54,58,61],"span",{"class":48,"line":49},"line",1,[46,51,53],{"class":52},"sTRMh","\"hexo\"",[46,55,57],{"class":56},"sMAXC",": ",[46,59,60],{"class":52},"\"^3.8.0\"",[46,62,63],{"class":56},",\n",[16,65,66],{},"通常第一個數字是重大的改版 3，一般來講 hexo 2.x.x 與 3.x.x 就會有可能是什麼重大的改版",[68,69,70,74,77],"ul",{},[71,72,73],"li",{},"第一個數字是主要的版本號 → 3",[71,75,76],{},"第二個數字是次要版本號 → 8",[71,78,79],{},"第三個數字是 Bug 的修正號 → 0",[16,81,82],{},"那箭頭 (^) 呢?",[36,84,85],{"className":38,"code":39,"language":40,"meta":41,"style":41},[43,86,87],{"__ignoreMap":41},[46,88,89,91,93,95],{"class":48,"line":49},[46,90,53],{"class":52},[46,92,57],{"class":56},[46,94,60],{"class":52},[46,96,63],{"class":56},[16,98,99],{},"這代表的意思是它會自動更新第二及第三數字的版本更新，例如 3.7.2 更新至 3.8.0，但是它並不會更新第一個主要版本號碼，因為通常第一個數字的更新都是屬於重大改版，隨意更新可能會導致 GG",[16,101,102],{},"那如果是蚯蚓符號(~)呢?",[36,104,106],{"className":38,"code":105,"language":40,"meta":41,"style":41},"\"hexo\": \"~3.8.0\",\n",[43,107,108],{"__ignoreMap":41},[46,109,110,112,114,117],{"class":48,"line":49},[46,111,53],{"class":52},[46,113,57],{"class":56},[46,115,116],{"class":52},"\"~3.8.0\"",[46,118,63],{"class":56},[16,120,121],{},"這個符號的意思代表著，我只更新 bug 的修正，也就是第三個數字。",[16,123,124],{},"如果沒有箭頭 or 蚯蚓，就代表你只安裝這個版本。",[16,126,127,128,131],{},"另外還有一個特別的東西，也就是 ",[43,129,130],{},"latest","，意旨永遠都更新到最新，但是一般來講很少有開發者使用，因為這樣子會導致出現一些奇怪的問題。",[36,133,135],{"className":38,"code":134,"language":40,"meta":41,"style":41},"\"hexo\": \"latest\",\n",[43,136,137],{"__ignoreMap":41},[46,138,139,141,143,146],{"class":48,"line":49},[46,140,53],{"class":52},[46,142,57],{"class":56},[46,144,145],{"class":52},"\"latest\"",[46,147,63],{"class":56},[149,150,151],"style",{},"html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":41,"searchDepth":153,"depth":153,"links":154},2,[155,156],{"id":14,"depth":153,"text":14},{"id":21,"depth":153,"text":21},"Nodejs","2019-06-26 21:19:03","md","zh-Hant",{},true,"\u002Fnodejs\u002Fnpm","1",{"title":6,"description":18},false,"Nodejs\u002Fnpm-版本號辨別",[169],"Node.js",null,"\u002Fnodejs\u002F20190