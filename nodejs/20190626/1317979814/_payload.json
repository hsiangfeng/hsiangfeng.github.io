[{"data":1,"prerenderedAt":339},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190626\u002F1317979814\u002F":3,"page:\u002Fnodejs\u002F20190626\u002F1317979814\u002F":4,"alt:\u002Fnodejs\u002F20190626\u002F1317979814\u002F":3,"prev-next:\u002Fnodejs\u002F20190626\u002F1317979814\u002F":314,"related:\u002Fnodejs\u002F20190626\u002F1317979814\u002F":323},"\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F26\u002Fnpm-install-command-variations\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":298,"date":299,"description":18,"extension":300,"lang":301,"meta":302,"navigation":303,"path":304,"readingMinutes":305,"seo":306,"standalone":307,"stem":308,"tags":309,"tldr":311,"updated":311,"url":312,"__hash__":313},"content\u002FNodejs\u002Fnpm-安裝指令差異.md","npm 安裝指令差異","1317979814",{"type":9,"value":10,"toc":280},"minimark",[11,15,19,22,25,32,37,63,67,76,80,95,98,101,116,119,122,137,150,153,156,175,181,184,187,196,203,206,215,218,221,230,236,239,253,258,261,264,270,276],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"基本上這一篇算是做一下筆記整理，避免自己哪天金魚腦忘記，雖然很常打就是了",[12,20,21],{"id":21},"基礎指令",[16,23,24],{},"基本上我在另一篇教學系列已經講了差不多了，但是這邊特別拉出來獨立做筆記紀錄。",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"npm","https:\u002F\u002Fi.imgur.com\u002FT6EsjSb.png",[33,34,36],"h3",{"id":35},"查看-npm-版本","查看 npm 版本",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-themes github-dark-high-contrast","npm -v\n","js","",[45,46,47],"code",{"__ignoreMap":43},[48,49,52,56,60],"span",{"class":50,"line":51},"line",1,[48,53,55],{"class":54},"sMAXC","npm ",[48,57,59],{"class":58},"sWyjQ","-",[48,61,62],{"class":54},"v\n",[33,64,66],{"id":65},"npm-初始化指令","npm 初始化指令",[38,68,70],{"className":40,"code":69,"language":42,"meta":43,"style":43},"npm init\n",[45,71,72],{"__ignoreMap":43},[48,73,74],{"class":50,"line":51},[48,75,69],{"class":54},[33,77,79],{"id":78},"npm-初始化指令-全部載入預設不用輸入資料","npm 初始化指令 (全部載入預設，不用輸入資料)",[38,81,83],{"className":40,"code":82,"language":42,"meta":43,"style":43},"npm init -y\n",[45,84,85],{"__ignoreMap":43},[48,86,87,90,92],{"class":50,"line":51},[48,88,89],{"class":54},"npm init ",[48,91,59],{"class":58},[48,93,94],{"class":54},"y\n",[33,96,97],{"id":97},"全域安裝",[16,99,100],{},"(這邊用 gulp 做範例)",[38,102,104],{"className":40,"code":103,"language":42,"meta":43,"style":43},"npm install gulp -g\n",[45,105,106],{"__ignoreMap":43},[48,107,108,111,113],{"class":50,"line":51},[48,109,110],{"class":54},"npm install gulp ",[48,112,59],{"class":58},[48,114,115],{"class":54},"g\n",[16,117,118],{},"全域安裝的意思就是安裝在自己的電腦上，而不是專案資料夾，如果這個套件只是自己開發用，例如 ESlint，那就可以只安裝在自己電腦上，但是建議以文檔說明為準",[33,120,121],{"id":121},"專案安裝",[38,123,125],{"className":40,"code":124,"language":42,"meta":43,"style":43},"npm install gulp --save\n",[45,126,127],{"__ignoreMap":43},[48,128,129,131,134],{"class":50,"line":51},[48,130,110],{"class":54},[48,132,133],{"class":58},"--",[48,135,136],{"class":54},"save\n",[16,138,139,142,143,146,147,149],{},[45,140,141],{},"--save"," 意旨安裝在專案目錄下，但是必須要先做 ",[45,144,145],{},"npm init"," 初始化，加入 ",[45,148,141],{}," 之後就可以將套件相關資訊安裝進 package.json 中。",[16,151,152],{},"套件資訊將會寫入至 package.json 的 \"dependencies\" 欄位。",[33,154,155],{"id":155},"專案開發環境安裝",[38,157,159],{"className":40,"code":158,"language":42,"meta":43,"style":43},"npm install gulp --save-dev\n",[45,160,161],{"__ignoreMap":43},[48,162,163,165,167,170,172],{"class":50,"line":51},[48,164,110],{"class":54},[48,166,133],{"class":58},[48,168,169],{"class":54},"save",[48,171,59],{"class":58},[48,173,174],{"class":54},"dev\n",[16,176,177,178,180],{},"意旨這個套件只會在開發模式下運作，生產環境下並不會有，如果不確定的話建議使用 ",[45,179,141],{}," 即可。",[16,182,183],{},"套件資訊會被寫入至 package.json 的 \"devDependencies\" 欄位。",[33,185,186],{"id":186},"還原套件",[38,188,190],{"className":40,"code":189,"language":42,"meta":43,"style":43},"npm install\n",[45,191,192],{"__ignoreMap":43},[48,193,194],{"class":50,"line":51},[48,195,189],{"class":54},[16,197,198,199,202],{},"當接手它人系統時，可以透過輸入 ",[45,200,201],{},"npm install"," 還原開發環境",[33,204,205],{"id":205},"顯示已套件列表",[38,207,209],{"className":40,"code":208,"language":42,"meta":43,"style":43},"npm list\n",[45,210,211],{"__ignoreMap":43},[48,212,213],{"class":50,"line":51},[48,214,208],{"class":54},[16,216,217],{},"可以顯示當前專案已經安裝了那些套件的指令",[33,219,220],{"id":220},"移除套件",[38,222,224],{"className":40,"code":223,"language":42,"meta":43,"style":43},"npm uninstall [套件名稱]\n",[45,225,226],{"__ignoreMap":43},[48,227,228],{"class":50,"line":51},[48,229,223],{"class":54},[16,231,232,233],{},"假設我要移除 gulp 套件，也就是 ",[45,234,235],{},"npm uninstall gulp",[33,237,238],{"id":238},"移除全域套件",[38,240,242],{"className":40,"code":241,"language":42,"meta":43,"style":43},"npm uninstall [套件名稱] -g\n",[45,243,244],{"__ignoreMap":43},[48,245,246,249,251],{"class":50,"line":51},[48,247,248],{"class":54},"npm uninstall [套件名稱] ",[48,250,59],{"class":58},[48,252,115],{"class":54},[16,254,232,255],{},[45,256,257],{},"npm uninstall gulp -g",[12,259,260],{"id":260},"補充",[16,262,263],{},"這邊順便記錄一下 npm -g 全域安裝檔案的路徑",[16,265,266,267],{},"Window\n※ 通常 AppData 資料夾是預設隱藏的\n",[45,268,269],{},"C:\\Users\\[使用者名稱]\\AppData\\Roaming\\npm\\node_modules",[16,271,272,273],{},"Mac\n",[45,274,275],{},"\u002Fusr\u002Flocal\u002Flib\u002Fnode_modules",[277,278,279],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":43,"searchDepth":281,"depth":281,"links":282},2,[283,284,297],{"id":14,"depth":281,"text":14},{"id"