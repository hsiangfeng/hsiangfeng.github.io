14,803,542],{"class":127},[12,805,806,807,809],{},"如果不想要使用某個功能的話，也是可以的，例如你不想要使用 ",[50,808,99],{}," 的話，你可以這樣子寫：",[105,811,813],{"className":515,"code":812,"language":517,"meta":110,"style":110},"app.use(\n  helmet({\n    xFrameOptions: false,\n  })\n);\n",[50,814,815,823,829,840,844],{"__ignoreMap":110},[114,816,817,819,821],{"class":116,"line":117},[114,818,598],{"class":127},[114,820,601],{"class":378},[114,822,735],{"class":127},[114,824,825,827],{"class":116,"line":124},[114,826,740],{"class":378},[114,828,743],{"class":127},[114,830,831,834,837],{"class":116,"line":142},[114,832,833],{"class":127},"    xFrameOptions: ",[114,835,836],{"class":135},"false",[114,838,839],{"class":127},",\n",[114,841,842],{"class":116,"line":152},[114,843,772],{"class":127},[114,845,846],{"class":116,"line":162},[114,847,542],{"class":127},[12,849,850,851,853],{},"那假設我只想要引入 ",[50,852,86],{}," 來刪除 Express（或其他）的標頭，但其他的都不想要引入，你可以這樣子寫：",[105,855,857],{"className":515,"code":856,"language":517,"meta":110,"style":110},"app.use(helmet.xPoweredBy());\n",[50,858,859],{"__ignoreMap":110},[114,860,861,863,865,868,871],{"class":116,"line":117},[114,862,598],{"class":127},[114,864,601],{"class":378},[114,866,867],{"class":127},"(helmet.",[114,869,870],{"class":378},"xPoweredBy",[114,872,609],{"class":127},[12,874,875,876,878],{},"這樣子就只會引入 ",[50,877,86],{}," 這個功能，其他的都不會引入。",[67,880,881],{},[12,882,883,885,886,888,889,320],{},[72,884,74],{},"\n其實 Express 官方的 Issues 曾經爭論過要不要把 ",[50,887,86],{}," 這個功能拿掉，詳情可見 ",[314,890,893],{"href":891,"rel":892},"https:\u002F\u002Fgithub.com\u002Fexpressjs\u002Fexpress\u002Fpull\u002F2813",[318],"Security improvement: don't reveal powered-by",[20,895,896],{"id":896},"結論",[12,898,899],{},"雖然 Helmet 已經盡可能幫你的 Express 戴上頭盔，但也千萬不要認為 Helmet 是一個萬靈藥，畢竟資安事件層出不窮，而且攻擊者也會不斷的找尋漏洞，因此我們還是要多加注意，不要因為 Helmet 的存在，而忽略了資安的重要性唷。",[12,901,902],{},[15,903],{"alt":904,"src":905},"中箭","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1694781630689