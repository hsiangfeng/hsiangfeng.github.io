625],{"class":374},[112,794,378],{"class":125},[112,796,630],{"class":524},[112,798,539],{"class":125},[12,800,801,802,804],{},"如果不想要使用某個功能的話，也是可以的，例如你不想要使用 ",[50,803,97],{}," 的話，你可以這樣子寫：",[103,806,808],{"className":511,"code":807,"language":513,"meta":108,"style":108},"app.use(\n  helmet({\n    xFrameOptions: false,\n  })\n);\n",[50,809,810,818,824,835,839],{"__ignoreMap":108},[112,811,812,814,816],{"class":114,"line":115},[112,813,595],{"class":125},[112,815,598],{"class":374},[112,817,730],{"class":125},[112,819,820,822],{"class":114,"line":122},[112,821,735],{"class":374},[112,823,738],{"class":125},[112,825,826,829,832],{"class":114,"line":140},[112,827,828],{"class":125},"    xFrameOptions: ",[112,830,831],{"class":524},"false",[112,833,834],{"class":125},",\n",[112,836,837],{"class":114,"line":150},[112,838,767],{"class":125},[112,840,841],{"class":114,"line":160},[112,842,539],{"class":125},[12,844,845,846,848],{},"那假設我只想要引入 ",[50,847,84],{}," 來刪除 Express（或其他）的標頭，但其他的都不想要引入，你可以這樣子寫：",[103,850,852],{"className":511,"code":851,"language":513,"meta":108,"style":108},"app.use(helmet.xPoweredBy());\n",[50,853,854],{"__ignoreMap":108},[112,855,856,858,860,863,866],{"class":114,"line":115},[112,857,595],{"class":125},[112,859,598],{"class":374},[112,861,862],{"class":125},"(helmet.",[112,864,865],{"class":374},"xPoweredBy",[112,867,606],{"class":125},[12,869,870,871,873],{},"這樣子就只會引入 ",[50,872,84],{}," 這個功能，其他的都不會引入。",[67,875,876],{"title":69,"type":70},[12,877,878,879,881,882,316],{},"其實 Express 官方的 Issues 曾經爭論過要不要把 ",[50,880,84],{}," 這個功能拿掉，詳情可見 ",[310,883,886],{"href":884,"rel":885},"https:\u002F\u002Fgithub.com\u002Fexpressjs\u002Fexpress\u002Fpull\u002F2813",[314],"Security improvement: don't reveal powered-by",[20,888,889],{"id":889},"結論",[12,891,892],{},"雖然 Helmet 已經盡可能幫你的 Express 戴上頭盔，但也千萬不要認為 Helmet 是一個萬靈藥，畢竟資安事件層出不窮，而且攻擊者也會不斷的找尋漏洞，因此我們還是要多加注意，不要因為 Helmet 的存在，而忽略了資安的重要性唷。",[12,894,895],{},[15,896],{"alt":897,"src":898},"中箭","https:\u002F\u002Fimages.israyn