[{"data":1,"prerenderedAt":964},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":3,"page:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":4,"alt:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":3,"prev-next:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":939,"related:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":948},"\u002Fen\u002Fnodejs\u002F2023\u002F09\u002F27\u002Fday-13-put-a-helmet-on-your-express\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":923,"date":924,"description":25,"extension":925,"lang":926,"meta":927,"navigation":565,"path":928,"readingMinutes":929,"seo":930,"standalone":931,"stem":932,"tags":933,"tldr":936,"updated":924,"url":937,"__hash__":938},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay13-替你的-Express-戴上頭盔.md","Day13 - 替你的 Express 戴上頭盔吧！","4133508926",{"type":9,"value":10,"toc":910},"minimark",[11,19,23,26,30,33,36,39,42,46,54,59,66,76,79,82,88,91,94,101,104,285,288,292,321,324,327,330,341,348,351,354,361,393,396,430,434,437,476,484,488,491,510,513,636,643,656,662,804,810,848,854,873,879,894,897,900,906],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"替你的 Express 戴上頭盔吧","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_Helmet_408e4fa3-b225-4ee3-b62c-3e0df2a5bba8.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"前面介紹了 CORS 跟 Env 可以說是基本的基本，接下來要來介紹一個很特別的東西，叫做 Helmet。",[20,27,29],{"id":28},"helmet-是什麼","Helmet 是什麼？",[12,31,32],{},"開始說明 Helmet 之前，我們要先釐清一件事情，也就是關於「網路安全」的事情。",[12,34,35],{},"網路資訊安全是一個非常大的議題，當然這一篇不可能全部都介紹到，畢竟網路資訊安全包含了個人註冊帳號密碼時的註冊規則等，因此這一篇只會著重於後端的安全性。",[12,37,38],{},"Helmet 其實在官方文件中有特別提到，Helmet 是一個幫助你保護你的 Express 應用程式的中介軟體，它會設定一些 HTTP 標頭，這些標頭可以幫助你的應用程式避免一些已知的網路攻擊。",[12,40,41],{},"簡單來講，Helmet 就是在替你的 Express 戴上頭盔（Helmet），讓你的應用程式可以避免一些已知的網路攻擊，就如同一個人戴上頭盔，可以避免一些已知的傷害。",[20,43,45],{"id":44},"helmet-做了哪些事情","Helmet 做了哪些事情？",[12,47,48,49,53],{},"預設引入 ",[50,51,52],"code",{},"app.use(helmet());"," 的狀況下，它會自動幫你在 HTTP 標頭中加入一些東西，而這些東西是可以幫助你的應用程式避免一些已知的網路攻擊。",[55,56,58],"h3",{"id":57},"隱藏-x-powered-by-標頭","隱藏 X-Powered-By 標頭",[12,60,61,62,65],{},"在預設的情況下，Express 會在 HTTP 標頭中加入 ",[50,63,64],{},"X-Powered-By: Express","，這個標頭會讓攻擊者知道你的應用程式是使用 Express 來開發的，因此攻擊者可以針對 Express 來進行攻擊。",[67,68,69],"blockquote",{},[12,70,71,75],{},[72,73,74],"strong",{},"Note","\n實戰開發上會避免讓攻擊者知道你的應用程式是使用什麼來開發的，因為當該應用程式爆出漏洞時，攻擊者就可以針對該漏洞來進行攻擊，因此基本的隱藏是必要的；早期我在接觸 WordPress 時，就有遇到過攻擊者針對 WordPress 的漏洞來進行攻擊，因此這點是非常重要的。",[12,77,78],{},"而 Helmet 會幫你隱藏這個標頭，因此攻擊者就無法知道你的應用程式是使用 Express 來開發的。",[12,80,81],{},"不信？你可以試著用前面所練習的 Express 用 Postman 試戳一下，你會看到以下的結果",[12,83,84],{},[15,85],{"alt":86,"src":87},"X-Powered-By","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fx_powered-by.jpg",[55,89,90],{"id":90},"減緩點擊劫持",[12,92,93],{},"Clickjacking（點擊劫持）是一種攻擊，簡單來講就是誘騙你在網頁上點擊某個元素（通常是按鈕或連結），基本上就是在網頁上做了一個透明的覆蓋層，讓你以為你點擊的是某個元素，但實際上點擊的是另一個元素。",[12,95,96,97,100],{},"而 Helmet 會幫你在 HTTP 標頭中加入 ",[50,98,99],{},"X-Frame-Options","，這個標頭可以讓你的網頁在被嵌入到其他網頁時，可以避免被點擊劫持。",[12,102,103],{},"如果不好懂的話，我們可以看一下範例程式碼：",[105,106,111],"pre",{"className":107,"code":108,"language":109,"meta":110,"style":110},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!-- 底下是一個惡意 HTML From 結構-->\n\u003C!DOCTYPE html>\n\u003Chtml>\n\u003Chead>\n    \u003Ctitle>惡意網頁\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n    \u003Ch1>點擊這裡贏取大獎！\u003C\u002Fh1>\n    \u003Ciframe\n      src=\"駭客的網站\"\n      style=\"opacity: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%;\"\n      frameborder=\"0\">\n    \u003C\u002Fiframe>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html","",[50,112,113,122,140,150,160,176,186,196,211,219,232,243,256,267,276],{"__ignoreMap":110},[114,115,118],"span",{"class":116,"line":117},"line",1,[114,119,121],{"class":120},"sQrFR","\u003C!-- 底下是一個惡意 HTML From 結構-->\n",[114,123,125,129,133,137],{"class":116,"line":124},2,[114,126,128],{"class":127},"sMAXC","\u003C!",[114,130,132],{"class":131},"sKpQp","DOCTYPE",[114,134,136],{"class":135},"sCcAr"," html",[114,138,139],{"class":127},">\n",[114,141,143,146,148],{"class":116,"line":142},3,[114,144,145],{"class":127},"\u003C",[114,147,109],{"class":131},[114,149,139],{"class":127},[114,151,153,155,158],{"class":116,"line":152},4,[114,154,145],{"class":127},[114,156,157],{"class":131},"head",[114,159,139],{"class":127},[114,161,163,166,169,172,174],{"class":116,"line":162},5,[114,164,165],{"class":127},"    \u003C",[114,167,168],{"class":131},"title",[114,170,171],{"class":127},">惡意網頁\u003C\u002F",[114,173,168],{"class":131},[114,175,139],{"class":127},[114,177,179,182,184],{"class":116,"line":178},6,[114,180,181],{"class":127},"\u003C\u002F",[114,183,157],{"class":131},[114,185,139],{"class":127},[114,187,189,191,194],{"class":116,"line":188},7,[114,190,145],{"class":127},[114,192,193],{"class":131},"body",[114,195,139],{"class":127},[114,197,199,201,204,207,209],{"class":116,"line":198},8,[114,200,165],{"class":127},[114,202,203],{"class":131},"h1",[114,205,206],{"class":127},">點擊這裡贏取大獎！\u003C\u002F",[114,208,203],{"class":131},[114,210,139],{"class":127},[114,212,214,216],{"class":116,"line":213},9,[114,215,165],{"class":127},[114,217,218],{"class":131},"iframe\n",[114,220,222,225,228],{"class":116,"line":221},10,[114,223,224],{"class":135},"      src",[114,226,227],{"class":127},"=",[114,229,231],{"class":230},"sTRMh","\"駭客的網站\"\n",[114,233,235,238,240],{"class":116,"line":234},11,[114,236,237],{"class":135},"      style",[114,239,227],{"class":127},[114,241,242],{"class":230},"\"opacity: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%;\"\n",[114,244,246,249,251,254],{"class":116,"line":245},12,[114,247,248],{"class":135},"      frameborder",[114,250,227],{"class":127},[114,252,253],{"class":230},"\"0\"",[114,255,139],{"class":127},[114,257,259,262,265],{"class":116,"line":258},13,[114,260,261],{"class":127},"    \u003C\u002F",[114,263,264],{"class":131},"iframe",[114,266,139],{"class":127},[114,268,270,272,274],{"class":116,"line":269},14,[114,271,181],{"class":127},[114,273,193],{"class":131},[114,275,139],{"class":127},[114,277,279,281,283],{"class":116,"line":278},15,[114,280,181],{"class":127},[114,282,109],{"class":131},[114,284,139],{"class":127},[12,286,287],{},"因此當你點擊「點擊這裡贏取大獎！」時，實際上你點擊的是駭客的網站，而不是你想要的網站。",[12,289,96,290,100],{},[50,291,99],{},[67,293,294],{},[12,295,296,298,299,302,303,302,306,309,310,312,313,320],{},[72,297,74],{},"\n這個標頭有三種設定方式，分別是 ",[50,300,301],{},"DENY","、",[50,304,305],{},"SAMEORIGIN",[50,307,308],{},"ALLOW-FROM","，而預設的設定是 ",[50,311,305],{},"，也就是只有同源的網頁才可以嵌入，詳細你可以參考",[314,315,319],"a",{"href":316,"rel":317},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FHTTP\u002FHeaders\u002FX-Frame-Options",[318],"nofollow","這裡","。",[55,322,323],{"id":323},"跨站請求偽造",[12,325,326],{},"跨站請求偽造可能比較多人看到，中文若你不熟悉的話，或許 CSRF 會比較熟悉，這是一種攻擊，簡單來講就是攻擊者會在你的網頁中加入一些惡意的東西，當你點擊時，就會觸發攻擊者的惡意程式碼。",[12,328,329],{},"而關於這一點我就不多說明了，畢竟我之前有寫文章說明過了",[331,332,333],"ul",{},[334,335,336],"li",{},[314,337,340],{"href":338,"rel":339},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20190704\u002F2336420619\u002F",[318],"全端勇士之路 Node.js 基礎學習-CSRF 篇",[12,342,343,344,320],{},"早期防禦的方式是在表單中加入 CSRF Token，但現今主流開發模式是前後端分離，因此就會改用所謂的 Client Double Submit Cookie，而這個方式是在 Cookie 中加入 CSRF Token，然後在 HTTP 標頭中加入 CSRF Token，當後端收到請求時，就會比對 Cookie 中的 CSRF Token 跟 HTTP 標頭中的 CSRF Token 是否相同，如果相同就代表是合法的請求，否則就是非法的請求，實作方式可以參考",[314,345,319],{"href":346,"rel":347},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20210527\u002F2874571028\u002F",[318],[55,349,350],{"id":350},"跨站腳本攻擊",[12,352,353],{},"這個其實在一般開發上是滿常遇到的攻擊手法，又稱之為跨網站指令碼攻擊，簡稱 XSS，通常比較常見於 Input 欄位，攻擊者會在 Input 欄位中輸入一些惡意的指令碼，當你點擊送出後，這一段惡意的指令碼就會在某個地方執行，而這個地方可以是你的網頁，也可以是其他網頁。",[12,355,356,357,360],{},"例如你的圖片 ",[50,358,359],{},"src"," 屬性來源是使用者輸入的，而使用者輸入的內容是惡意的指令碼，當你的網頁載入時，這段惡意的指令碼就會被執行，概念就像是使用者在 input 輸入以下",[105,362,364],{"className":107,"code":363,"language":109,"meta":110,"style":110},"\u003Cscript>alert('哈哈，你被 XSS 攻擊囉!');\u003C\u002Fscript>\n",[50,365,366],{"__ignoreMap":110},[114,367,368,370,373,376,380,383,386,389,391],{"class":116,"line":117},[114,369,145],{"class":127},[114,371,372],{"class":131},"script",[114,374,375],{"class":127},">",[114,377,379],{"class":378},"sj_SG","alert",[114,381,382],{"class":127},"(",[114,384,385],{"class":230},"'哈哈，你被 XSS 攻擊囉!'",[114,387,388],{"class":127},");\u003C\u002F",[114,390,372],{"class":131},[114,392,139],{"class":127},[12,394,395],{},"接著渲染出來的結果就會是",[105,397,399],{"className":107,"code":398,"language":109,"meta":110,"style":110},"\u003Cimg src=\"#\" onerror=\"alert('哈哈，你被 XSS 攻擊囉!');\">\n",[50,400,401],{"__ignoreMap":110},[114,402,403,405,407,410,412,415,418,420,423,425,428],{"class":116,"line":117},[114,404,145],{"class":127},[114,406,15],{"class":131},[114,408,409],{"class":135}," src",[114,411,227],{"class":127},[114,413,414],{"class":230},"\"#\"",[114,416,417],{"class":135}," onerror",[114,419,227],{"class":127},[114,421,422],{"class":230},"\"",[114,424,379],{"class":378},[114,426,427],{"class":230},"('哈哈，你被 XSS 攻擊囉!');\"",[114,429,139],{"class":127},[55,431,433],{"id":432},"其他-helmet","其他 Helmet",[12,435,436],{},"當然不只有以上這些，Helmet 還有其他的東西，例如：",[331,438,439,442,445,448,451,454,457,460,463,466,468,471,473],{},[334,440,441],{},"Content-Security-Policy",[334,443,444],{},"Cross-Origin-Opener-Policy",[334,446,447],{},"Cross-Origin-Resource-Policy",[334,449,450],{},"Origin-Agent-Cluster",[334,452,453],{},"Referrer-Policy",[334,455,456],{},"Strict-Transport-Security",[334,458,459],{},"X-Content-Type-Options",[334,461,462],{},"X-DNS-Prefetch-Control",[334,464,465],{},"X-Download-Options",[334,467,99],{},[334,469,470],{},"X-Permitted-Cross-Domain-Policies",[334,472,86],{},[334,474,475],{},"X-XSS-Protection",[12,477,478,479,320],{},"這些都是可以幫助你的應用程式避免一些已知的網路攻擊，當然這些都是可以自行設定的，如果你想要了解更多的話，可以參考",[314,480,483],{"href":481,"rel":482},"https:\u002F\u002Fhelmetjs.github.io\u002F",[318],"官方文件",[20,485,487],{"id":486},"該如何在-express-中使用-helmet","該如何在 Express 中使用 Helmet？",[12,489,490],{},"Helmet 的使用方式非常簡單，只需要在你的專案中安裝 Helmet 套件：",[105,492,496],{"className":493,"code":494,"language":495,"meta":110,"style":110},"language-bash shiki shiki-themes github-dark-high-contrast","npm install helmet\n","bash",[50,497,498],{"__ignoreMap":110},[114,499,500,504,507],{"class":116,"line":117},[114,501,503],{"class":502},"s_sBn","npm",[114,505,506],{"class":230}," install",[114,508,509],{"class":230}," helmet\n",[12,511,512],{},"接著在你的程式碼中引用 Helmet：",[105,514,518],{"className":515,"code":516,"language":517,"meta":110,"style":110},"language-js shiki shiki-themes github-dark-high-contrast","const express = require('express');\nconst helmet = require('helmet');\n\nconst app = express();\n\n\u002F\u002F ...略過其他程式碼\n\napp.use(helmet());\n\n\u002F\u002F ...略過其他程式碼\n\napp.listen(3000);\n","js",[50,519,520,543,561,567,581,585,590,594,610,614,618,622],{"__ignoreMap":110},[114,521,522,526,529,532,535,537,540],{"class":116,"line":117},[114,523,525],{"class":524},"sWyjQ","const",[114,527,528],{"class":135}," express",[114,530,531],{"class":524}," =",[114,533,534],{"class":378}," require",[114,536,382],{"class":127},[114,538,539],{"class":230},"'express'",[114,541,542],{"class":127},");\n",[114,544,545,547,550,552,554,556,559],{"class":116,"line":124},[114,546,525],{"class":524},[114,548,549],{"class":135}," helmet",[114,551,531],{"class":524},[114,553,534],{"class":378},[114,555,382],{"class":127},[114,557,558],{"class":230},"'helmet'",[114,560,542],{"class":127},[114,562,563],{"class":116,"line":142},[114,564,566],{"emptyLinePlaceholder":565},true,"\n",[114,568,569,571,574,576,578],{"class":116,"line":152},[114,570,525],{"class":524},[114,572,573],{"class":135}," app",[114,575,531],{"class":524},[114,577,528],{"class":378},[114,579,580],{"class":127},"();\n",[114,582,583],{"class":116,"line":162},[114,584,566],{"emptyLinePlaceholder":565},[114,586,587],{"class":116,"line":178},[114,588,589],{"class":120},"\u002F\u002F ...略過其他程式碼\n",[114,591,592],{"class":116,"line":188},[114,593,566],{"emptyLinePlaceholder":565},[114,595,596,599,602,604,607],{"class":116,"line":198},[114,597,598],{"class":127},"app.",[114,600,601],{"class":378},"use",[114,603,382],{"class":127},[114,605,606],{"class":378},"helmet",[114,608,609],{"class":127},"());\n",[114,611,612],{"class":116,"line":213},[114,613,566],{"emptyLinePlaceholder":565},[114,615,616],{"class":116,"line":221},[114,617,589],{"class":120},[114,619,620],{"class":116,"line":234},[114,621,566],{"emptyLinePlaceholder":565},[114,623,624,626,629,631,634],{"class":116,"line":245},[114,625,598],{"class":127},[114,627,628],{"class":378},"listen",[114,630,382],{"class":127},[114,632,633],{"class":135},"3000",[114,635,542],{"class":127},[12,637,638,639,642],{},"其引用的方式跟其他的中介軟體一樣，只需要在 ",[50,640,641],{},"app.use()"," 中加入即可。",[67,644,645],{},[12,646,647,649,650,655],{},[72,648,74],{},"\n如果你覺得從頭建立 Express 很煩的話，官方其實也有出一個叫做 ",[314,651,654],{"href":652,"rel":653},"https:\u002F\u002Fexpressjs.com\u002Fen\u002Fstarter\u002Fgenerator.html",[318],"Express Generator"," 的東西，可以幫你快速建立一個 Express 專案唷。",[12,657,658,659,661],{},"基本上預設 Helmet 會幫你加入前面所提到的東西，但如果你想要自行設定的話，也是可以的，例如你想要自行設定 ",[50,660,99],{},"，你可以這樣子寫：",[105,663,665],{"className":515,"code":664,"language":517,"meta":110,"style":110},"const express = require('express');\nconst helmet = require('helmet');\n\nconst app = express();\n\n\u002F\u002F ...略過其他程式碼\n\napp.use(\n  helmet({\n    frameguard: {\n      xFrameOptions: { action: \"deny\" }, \u002F\u002F 不然就是 sameorigin\n    },\n  })\n);\n\n\u002F\u002F ...略過其他程式碼\n\napp.listen(3000);\n",[50,666,667,683,699,703,715,719,723,727,736,744,749,763,768,773,777,781,786,791],{"__ignoreMap":110},[114,668,669,671,673,675,677,679,681],{"class":116,"line":117},[114,670,525],{"class":524},[114,672,528],{"class":135},[114,674,531],{"class":524},[114,676,534],{"class":378},[114,678,382],{"class":127},[114,680,539],{"class":230},[114,682,542],{"