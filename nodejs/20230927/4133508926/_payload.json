[{"data":1,"prerenderedAt":957},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":3,"page:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":4,"alt:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":3,"prev-next:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":932,"related:\u002Fnodejs\u002F20230927\u002F4133508926\u002F":941},"\u002Fen\u002Fnodejs\u002F2023\u002F09\u002F27\u002Fday-13-put-a-helmet-on-your-express\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":916,"date":917,"description":25,"extension":918,"lang":919,"meta":920,"navigation":562,"path":921,"readingMinutes":922,"seo":923,"standalone":924,"stem":925,"tags":926,"tldr":929,"updated":917,"url":930,"__hash__":931},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay13-替你的-Express-戴上頭盔.md","Day13 - 替你的 Express 戴上頭盔吧！","4133508926",{"type":9,"value":10,"toc":903},"minimark",[11,19,23,26,30,33,36,39,42,46,54,59,66,74,77,80,86,89,92,99,102,283,286,290,317,320,323,326,337,344,347,350,357,389,392,426,430,433,472,480,484,487,506,509,633,640,651,657,799,805,843,849,868,874,887,890,893,899],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"替你的 Express 戴上頭盔吧","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_Helmet_408e4fa3-b225-4ee3-b62c-3e0df2a5bba8.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"前面介紹了 CORS 跟 Env 可以說是基本的基本，接下來要來介紹一個很特別的東西，叫做 Helmet。",[20,27,29],{"id":28},"helmet-是什麼","Helmet 是什麼？",[12,31,32],{},"開始說明 Helmet 之前，我們要先釐清一件事情，也就是關於「網路安全」的事情。",[12,34,35],{},"網路資訊安全是一個非常大的議題，當然這一篇不可能全部都介紹到，畢竟網路資訊安全包含了個人註冊帳號密碼時的註冊規則等，因此這一篇只會著重於後端的安全性。",[12,37,38],{},"Helmet 其實在官方文件中有特別提到，Helmet 是一個幫助你保護你的 Express 應用程式的中介軟體，它會設定一些 HTTP 標頭，這些標頭可以幫助你的應用程式避免一些已知的網路攻擊。",[12,40,41],{},"簡單來講，Helmet 就是在替你的 Express 戴上頭盔（Helmet），讓你的應用程式可以避免一些已知的網路攻擊，就如同一個人戴上頭盔，可以避免一些已知的傷害。",[20,43,45],{"id":44},"helmet-做了哪些事情","Helmet 做了哪些事情？",[12,47,48,49,53],{},"預設引入 ",[50,51,52],"code",{},"app.use(helmet());"," 的狀況下，它會自動幫你在 HTTP 標頭中加入一些東西，而這些東西是可以幫助你的應用程式避免一些已知的網路攻擊。",[55,56,58],"h3",{"id":57},"隱藏-x-powered-by-標頭","隱藏 X-Powered-By 標頭",[12,60,61,62,65],{},"在預設的情況下，Express 會在 HTTP 標頭中加入 ",[50,63,64],{},"X-Powered-By: Express","，這個標頭會讓攻擊者知道你的應用程式是使用 Express 來開發的，因此攻擊者可以針對 Express 來進行攻擊。",[67,68,71],"callout",{"title":69,"type":70},"Note","note",[12,72,73],{},"實戰開發上會避免讓攻擊者知道你的應用程式是使用什麼來開發的，因為當該應用程式爆出漏洞時，攻擊者就可以針對該漏洞來進行攻擊，因此基本的隱藏是必要的；早期我在接觸 WordPress 時，就有遇到過攻擊者針對 WordPress 的漏洞來進行攻擊，因此這點是非常重要的。",[12,75,76],{},"而 Helmet 會幫你隱藏這個標頭，因此攻擊者就無法知道你的應用程式是使用 Express 來開發的。",[12,78,79],{},"不信？你可以試著用前面所練習的 Express 用 Postman 試戳一下，你會看到以下的結果",[12,81,82],{},[15,83],{"alt":84,"src":85},"X-Powered-By","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fx_powered-by.jpg",[55,87,88],{"id":88},"減緩點擊劫持",[12,90,91],{},"Clickjacking（點擊劫持）是一種攻擊，簡單來講就是誘騙你在網頁上點擊某個元素（通常是按鈕或連結），基本上就是在網頁上做了一個透明的覆蓋層，讓你以為你點擊的是某個元素，但實際上點擊的是另一個元素。",[12,93,94,95,98],{},"而 Helmet 會幫你在 HTTP 標頭中加入 ",[50,96,97],{},"X-Frame-Options","，這個標頭可以讓你的網頁在被嵌入到其他網頁時，可以避免被點擊劫持。",[12,100,101],{},"如果不好懂的話，我們可以看一下範例程式碼：",[103,104,109],"pre",{"className":105,"code":106,"language":107,"meta":108,"style":108},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C!-- 底下是一個惡意 HTML From 結構-->\n\u003C!DOCTYPE html>\n\u003Chtml>\n\u003Chead>\n    \u003Ctitle>惡意網頁\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n    \u003Ch1>點擊這裡贏取大獎！\u003C\u002Fh1>\n    \u003Ciframe\n      src=\"駭客的網站\"\n      style=\"opacity: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%;\"\n      frameborder=\"0\">\n    \u003C\u002Fiframe>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html","",[50,110,111,120,138,148,158,174,184,194,209,217,230,241,254,265,274],{"__ignoreMap":108},[112,113,116],"span",{"class":114,"line":115},"line",1,[112,117,119],{"class":118},"sGBqm","\u003C!-- 底下是一個惡意 HTML From 結構-->\n",[112,121,123,127,131,135],{"class":114,"line":122},2,[112,124,126],{"class":125},"s8XSl","\u003C!",[112,128,130],{"class":129},"syv7_","DOCTYPE",[112,132,134],{"class":133},"sK3KL"," html",[112,136,137],{"class":125},">\n",[112,139,141,144,146],{"class":114,"line":140},3,[112,142,143],{"class":125},"\u003C",[112,145,107],{"class":129},[112,147,137],{"class":125},[112,149,151,153,156],{"class":114,"line":150},4,[112,152,143],{"class":125},[112,154,155],{"class":129},"head",[112,157,137],{"class":125},[112,159,161,164,167,170,172],{"class":114,"line":160},5,[112,162,163],{"class":125},"    \u003C",[112,165,166],{"class":129},"title",[112,168,169],{"class":125},">惡意網頁\u003C\u002F",[112,171,166],{"class":129},[112,173,137],{"class":125},[112,175,177,180,182],{"class":114,"line":176},6,[112,178,179],{"class":125},"\u003C\u002F",[112,181,155],{"class":129},[112,183,137],{"class":125},[112,185,187,189,192],{"class":114,"line":186},7,[112,188,143],{"class":125},[112,190,191],{"class":129},"body",[112,193,137],{"class":125},[112,195,197,199,202,205,207],{"class":114,"line":196},8,[112,198,163],{"class":125},[112,200,201],{"class":129},"h1",[112,203,204],{"class":125},">點擊這裡贏取大獎！\u003C\u002F",[112,206,201],{"class":129},[112,208,137],{"class":125},[112,210,212,214],{"class":114,"line":211},9,[112,213,163],{"class":125},[112,215,216],{"class":129},"iframe\n",[112,218,220,223,226],{"class":114,"line":219},10,[112,221,222],{"class":133},"      src",[112,224,225],{"class":125},"=",[112,227,229],{"class":228},"sWayO","\"駭客的網站\"\n",[112,231,233,236,238],{"class":114,"line":232},11,[112,234,235],{"class":133},"      style",[112,237,225],{"class":125},[112,239,240],{"class":228},"\"opacity: 0; position: absolute; top: 0; left: 0; width: 100%; height: 100%;\"\n",[112,242,244,247,249,252],{"class":114,"line":243},12,[112,245,246],{"class":133},"      frameborder",[112,248,225],{"class":125},[112,250,251],{"class":228},"\"0\"",[112,253,137],{"class":125},[112,255,257,260,263],{"class":114,"line":256},13,[112,258,259],{"class":125},"    \u003C\u002F",[112,261,262],{"class":129},"iframe",[112,264,137],{"class":125},[112,266,268,270,272],{"class":114,"line":267},14,[112,269,179],{"class":125},[112,271,191],{"class":129},[112,273,137],{"class":125},[112,275,277,279,281],{"class":114,"line":276},15,[112,278,179],{"class":125},[112,280,107],{"class":129},[112,282,137],{"class":125},[12,284,285],{},"因此當你點擊「點擊這裡贏取大獎！」時，實際上你點擊的是駭客的網站，而不是你想要的網站。",[12,287,94,288,98],{},[50,289,97],{},[67,291,292],{"title":69,"type":70},[12,293,294,295,298,299,298,302,305,306,308,309,316],{},"這個標頭有三種設定方式，分別是 ",[50,296,297],{},"DENY","、",[50,300,301],{},"SAMEORIGIN",[50,303,304],{},"ALLOW-FROM","，而預設的設定是 ",[50,307,301],{},"，也就是只有同源的網頁才可以嵌入，詳細你可以參考",[310,311,315],"a",{"href":312,"rel":313},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FWeb\u002FHTTP\u002FHeaders\u002FX-Frame-Options",[314],"nofollow","這裡","。",[55,318,319],{"id":319},"跨站請求偽造",[12,321,322],{},"跨站請求偽造可能比較多人看到，中文若你不熟悉的話，或許 CSRF 會比較熟悉，這是一種攻擊，簡單來講就是攻擊者會在你的網頁中加入一些惡意的東西，當你點擊時，就會觸發攻擊者的惡意程式碼。",[12,324,325],{},"而關於這一點我就不多說明了，畢竟我之前有寫文章說明過了",[327,328,329],"ul",{},[330,331,332],"li",{},[310,333,336],{"href":334,"rel":335},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20190704\u002F2336420619\u002F",[314],"全端勇士之路 Node.js 基礎學習-CSRF 篇",[12,338,339,340,316],{},"早期防禦的方式是在表單中加入 CSRF Token，但現今主流開發模式是前後端分離，因此就會改用所謂的 Client Double Submit Cookie，而這個方式是在 Cookie 中加入 CSRF Token，然後在 HTTP 標頭中加入 CSRF Token，當後端收到請求時，就會比對 Cookie 中的 CSRF Token 跟 HTTP 標頭中的 CSRF Token 是否相同，如果相同就代表是合法的請求，否則就是非法的請求，實作方式可以參考",[310,341,315],{"href":342,"rel":343},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20210527\u002F2874571028\u002F",[314],[55,345,346],{"id":346},"跨站腳本攻擊",[12,348,349],{},"這個其實在一般開發上是滿常遇到的攻擊手法，又稱之為跨網站指令碼攻擊，簡稱 XSS，通常比較常見於 Input 欄位，攻擊者會在 Input 欄位中輸入一些惡意的指令碼，當你點擊送出後，這一段惡意的指令碼就會在某個地方執行，而這個地方可以是你的網頁，也可以是其他網頁。",[12,351,352,353,356],{},"例如你的圖片 ",[50,354,355],{},"src"," 屬性來源是使用者輸入的，而使用者輸入的內容是惡意的指令碼，當你的網頁載入時，這段惡意的指令碼就會被執行，概念就像是使用者在 input 輸入以下",[103,358,360],{"className":105,"code":359,"language":107,"meta":108,"style":108},"\u003Cscript>alert('哈哈，你被 XSS 攻擊囉!');\u003C\u002Fscript>\n",[50,361,362],{"__ignoreMap":108},[112,363,364,366,369,372,376,379,382,385,387],{"class":114,"line":115},[112,365,143],{"class":125},[112,367,368],{"class":129},"script",[112,370,371],{"class":125},">",[112,373,375],{"class":374},"scAaK","alert",[112,377,378],{"class":125},"(",[112,380,381],{"class":228},"'哈哈，你被 XSS 攻擊囉!'",[112,383,384],{"class":125},");\u003C\u002F",[112,386,368],{"class":129},[112,388,137],{"class":125},[12,390,391],{},"接著渲染出來的結果就會是",[103,393,395],{"className":105,"code":394,"language":107,"meta":108,"style":108},"\u003Cimg src=\"#\" onerror=\"alert('哈哈，你被 XSS 攻擊囉!');\">\n",[50,396,397],{"__ignoreMap":108},[112,398,399,401,403,406,408,411,414,416,419,421,424],{"class":114,"line":115},[112,400,143],{"class":125},[112,402,15],{"class":129},[112,404,405],{"class":133}," src",[112,407,225],{"class":125},[112,409,410],{"class":228},"\"#\"",[112,412,413],{"class":133}," onerror",[112,415,225],{"class":125},[112,417,418],{"class":228},"\"",[112,420,375],{"class":374},[112,422,423],{"class":228},"('哈哈，你被 XSS 攻擊囉!');\"",[112,425,137],{"class":125},[55,427,429],{"id":428},"其他-helmet","其他 Helmet",[12,431,432],{},"當然不只有以上這些，Helmet 還有其他的東西，例如：",[327,434,435,438,441,444,447,450,453,456,459,462,464,467,469],{},[330,436,437],{},"Content-Security-Policy",[330,439,440],{},"Cross-Origin-Opener-Policy",[330,442,443],{},"Cross-Origin-Resource-Policy",[330,445,446],{},"Origin-Agent-Cluster",[330,448,449],{},"Referrer-Policy",[330,451,452],{},"Strict-Transport-Security",[330,454,455],{},"X-Content-Type-Options",[330,457,458],{},"X-DNS-Prefetch-Control",[330,460,461],{},"X-Download-Options",[330,463,97],{},[330,465,466],{},"X-Permitted-Cross-Domain-Policies",[330,468,84],{},[330,470,471],{},"X-XSS-Protection",[12,473,474,475,316],{},"這些都是可以幫助你的應用程式避免一些已知的網路攻擊，當然這些都是可以自行設定的，如果你想要了解更多的話，可以參考",[310,476,479],{"href":477,"rel":478},"https:\u002F\u002Fhelmetjs.github.io\u002F",[314],"官方文件",[20,481,483],{"id":482},"該如何在-express-中使用-helmet","該如何在 Express 中使用 Helmet？",[12,485,486],{},"Helmet 的使用方式非常簡單，只需要在你的專案中安裝 Helmet 套件：",[103,488,492],{"className":489,"code":490,"language":491,"meta":108,"style":108},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","npm install helmet\n","bash",[50,493,494],{"__ignoreMap":108},[112,495,496,500,503],{"class":114,"line":115},[112,497,499],{"class":498},"smYoP","npm",[112,501,502],{"class":228}," install",[112,504,505],{"class":228}," helmet\n",[12,507,508],{},"接著在你的程式碼中引用 Helmet：",[103,510,514],{"className":511,"code":512,"language":513,"meta":108,"style":108},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","const express = require('express');\nconst helmet = require('helmet');\n\nconst app = express();\n\n\u002F\u002F ...略過其他程式碼\n\napp.use(helmet());\n\n\u002F\u002F ...略過其他程式碼\n\napp.listen(3000);\n","js",[50,515,516,540,558,564,578,582,587,591,607,611,615,619],{"__ignoreMap":108},[112,517,518,522,526,529,532,534,537],{"class":114,"line":115},[112,519,521],{"class":520},"sOudu","const",[112,523,525],{"class":524},"stw71"," express",[112,527,528],{"class":520}," =",[112,530,531],{"class":374}," require",[112,533,378],{"class":125},[112,535,536],{"class":228},"'express'",[112,538,539],{"class":125},");\n",[112,541,542,544,547,549,551,553,556],{"class":114,"line":122},[112,543,521],{"class":520},[112,545,546],{"class":524}," helmet",[112,548,528],{"class":520},[112,550,531],{"class":374},[112,552,378],{"class":125},[112,554,555],{"class":228},"'helmet'",[112,557,539],{"class":125},[112,559,560],{"class":114,"line":140},[112,561,563],{"emptyLinePlaceholder":562},true,"\n",[112,565,566,568,571,573,575],{"class":114,"line":150},[112,567,521],{"class":520},[112,569,570],{"class":524}," app",[112,572,528],{"class":520},[112,574,525],{"class":374},[112,576,577],{"class":125},"();\n",[112,579,580],{"class":114,"line":160},[112,581,563],{"emptyLinePlaceholder":562},[112,583,584],{"class":114,"line":176},[112,585,586],{"class":118},"\u002F\u002F ...略過其他程式碼\n",[112,588,589],{"class":114,"line":186},[112,590,563],{"emptyLinePlaceholder":562},[112,592,593,596,599,601,604],{"class":114,"line":196},[112,594,595],{"class":125},"app.",[112,597,598],{"class":374},"use",[112,600,378],{"class":125},[112,602,603],{"class":374},"helmet",[112,605,606],{"class":125},"());\n",[112,608,609],{"class":114,"line":211},[112,610,563],{"emptyLinePlaceholder":562},[112,612,613],{"class":114,"line":219},[112,614,586],{"class":118},[112,616,617],{"class":114,"line":232},[112,618,563],{"emptyLinePlaceholder":562},[112,620,621,623,626,628,631],{"class":114,"line":243},[112,622,595],{"class":125},[112,624,625],{"class":374},"listen",[112,627,378],{"class":125},[112,629,630],{"class":524},"3000",[112,632,539],{"class":125},[12,634,635,636,639],{},"其引用的方式跟其他的中介軟體一樣，只需要在 ",[50,637,638],{},"app.use()"," 中加入即可。",[67,641,642],{"title":69,"type":70},[12,643,644,645,650],{},"如果你覺得從頭建立 Express 很煩的話，官方其實也有出一個叫做 ",[310,646,649],{"href":647,"rel":648},"https:\u002F\u002Fexpressjs.com\u002Fen\u002Fstarter\u002Fgenerator.html",[314],"Express Generator"," 的東西，可以幫你快速建立一個 Express 專案唷。",[12,652,653,654,656],{},"基本上預設 Helmet 會幫你加入前面所提到的東西，但如果你想要自行設定的話，也是可以的，例如你想要自行設定 ",[50,655,97],{},"，你可以這樣子寫：",[103,658,660],{"className":511,"code":659,"language":513,"meta":108,"style":108},"const express = require('express');\nconst helmet = require('helmet');\n\nconst app = express();\n\n\u002F\u002F ...略過其他程式碼\n\napp.use(\n  helmet({\n    frameguard: {\n      xFrameOptions: { action: \"deny\" }, \u002F\u002F 不然就是 sameorigin\n    },\n  })\n);\n\n\u002F\u002F ...略過其他程式碼\n\napp.listen(3000);\n",[50,661,662,678,694,698,710,714,718,722,731,739,744,758,763,768,772,776,781,786],{"__ignoreMap":108},[112,663,664,666,668,670,672,674,676],{"class":114,"line":115},[112,665,521],{"class":520},[112,667,525],{"class":524},[112,669,528],{"class":520},[112,671,531],{"class":