[{"data":1,"prerenderedAt":1383},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20231013\u002F3280561145\u002F":3,"page:\u002Fnodejs\u002F20231013\u002F3280561145\u002F":4,"alt:\u002Fnodejs\u002F20231013\u002F3280561145\u002F":3,"prev-next:\u002Fnodejs\u002F20231013\u002F3280561145\u002F":1358,"related:\u002Fnodejs\u002F20231013\u002F3280561145\u002F":1367},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F13\u002Fday-29-about-jwt-authentication\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1342,"date":1343,"description":25,"extension":1344,"lang":1345,"meta":1346,"navigation":681,"path":1347,"readingMinutes":1348,"seo":1349,"standalone":1350,"stem":1351,"tags":1352,"tldr":1355,"updated":1343,"url":1356,"__hash__":1357},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay29-關於-JWT-驗證.md","Day29-關於 JWT 驗證","3280561145",{"type":9,"value":10,"toc":1331},"minimark",[11,19,23,26,29,32,35,38,46,50,61,64,92,109,112,121,124,146,150,153,169,174,177,185,188,196,200,203,272,275,283,286,297,300,303,306,329,332,382,387,391,394,440,443,479,482,514,517,551,554,557,560,568,577,583,586,589,592,969,972,978,981,984,987,991,998,1017,1023,1118,1124,1135,1141,1144,1196,1203,1307,1310,1324,1327],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"關於 JWT 驗證","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_web_Certification_87b4aacf-552a-40c1-8cb8-9fa5dca7d52d.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"接下來這一篇將會來介紹 JWT 的驗證，畢竟前面一直都沒提到，可是實戰上來講卻是非常重要的一環哩。",[20,27,28],{"id":28},"身份認證",[12,30,31],{},"為什麼要身份認證呢？前面的許多章節中，其實我們都沒有做身份認證的機制，舉凡 API、Discord、Chrome Extension 等等，都沒有做身份認證，那麼為什麼要做身份認證呢？",[12,33,34],{},"我們所開發的東西有些功能是僅限於特定的人才能使用，例如：管理員、VIP 等等，這時候我們就需要一個機制來做身份認證，那麼這時候就會提到 JWT（JSON Web Token）了。",[12,36,37],{},"而現今主流開發比較常見於前後端分離的架構，不再是傳統的 SSR（Server Side Rendering）的架構，前端大多都是透過後端所提供的 API 來取得資料，而這個取資料的過程就必須要被認證。",[39,40,43],"callout",{"title":41,"type":42},"Note","note",[12,44,45],{},"早期開發時，使用者登入後，後端會將使用者的 UID 儲存在伺服器的記憶體中（Session），但因為現今主流開發事前後端分離的架構，因此這種方式已經不適用了，因此就有了 JWT。",[20,47,49],{"id":48},"json-web-token-是什麼","JSON Web Token 是什麼？",[12,51,52,53,60],{},"剛才有提到 JWT 的全名是 JSON Web Token，是一個廣泛被使用來驗證與授權的標準，尤其是在網頁開發上很常被使用，而且也是一個開放的標準（",[54,55,59],"a",{"href":56,"rel":57},"https:\u002F\u002Fdatatracker.ietf.org\u002Fdoc\u002Fhtml\u002Frfc7519",[58],"nofollow","RFC 7519","）。",[12,62,63],{},"基本上 JWT 的結構分為三個部分：",[65,66,67,76,84],"ul",{},[68,69,70,71],"li",{},"HEADER（標頭）：ALGORITHM & TOKEN TYPE\n",[65,72,73],{},[68,74,75],{},"用來說明這一組 Token 是用什麼演算法加密的，以及 Token 的類型",[68,77,78,79],{},"PAYLOAD（負載）：DATA\n",[65,80,81],{},[68,82,83],{},"主要是用來存放一些資料，例如使用者的 ID、名字等等",[68,85,86,87],{},"VERIFY SIGNATURE（驗證簽名）\n",[65,88,89],{},[68,90,91],{},"這一部分是用來驗證 Token 是否為正確的 Token",[93,94,99],"pre",{"className":95,"code":96,"language":97,"meta":98,"style":98},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c\n","txt","",[100,101,102],"code",{"__ignoreMap":98},[103,104,107],"span",{"class":105,"line":106},"line",1,[103,108,96],{},[12,110,111],{},"很難看出其差異吧？如果我依據上面的結構來拆解的話，就會變成這樣：",[93,113,115],{"className":95,"code":114,"language":97,"meta":98,"style":98},"HEADER.PAYLOAD.VERIFY SIGNATURE\n",[100,116,117],{"__ignoreMap":98},[103,118,119],{"class":105,"line":106},[103,120,114],{},[12,122,123],{},"搭配上方的 JWT 範例，就會變成這樣：",[93,125,127],{"className":95,"code":126,"language":97,"meta":98,"style":98},"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.  # HEADER（標頭）\neyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ. # PAYLOAD（負載）\nSflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c # VERIFY SIGNATURE（驗證簽名）\n",[100,128,129,134,140],{"__ignoreMap":98},[103,130,131],{"class":105,"line":106},[103,132,133],{},"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.  # HEADER（標頭）\n",[103,135,137],{"class":105,"line":136},2,[103,138,139],{},"eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ. # PAYLOAD（負載）\n",[103,141,143],{"class":105,"line":142},3,[103,144,145],{},"SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c # VERIFY SIGNATURE（驗證簽名）\n",[20,147,149],{"id":148},"jwt-原理","JWT 原理",[12,151,152],{},"那麼 JWT 是如何實作出來的呢？剛才有提到 JWT 的結構分為三個部分，其實比較核心的部分是 PAYLOAD（負載）與 VERIFY SIGNATURE（驗證簽名），但我們還是針對 JWT 三個部分來做介紹，而這邊示範的範例會是前面所講的 JWT Token 範例：",[93,154,155],{"className":95,"code":126,"language":97,"meta":98,"style":98},[100,156,157,161,165],{"__ignoreMap":98},[103,158,159],{"class":105,"line":106},[103,160,133],{},[103,162,163],{"class":105,"line":136},[103,164,139],{},[103,166,167],{"class":105,"line":142},[103,168,145],{},[170,171,173],"h3",{"id":172},"header標頭","HEADER（標頭）",[12,175,176],{},"HEADER 主要組合會是兩個部分：",[65,178,179,182],{},[68,180,181],{},"alg（Algorithm）：加密演算法",[68,183,184],{},"typ（Type）：Token 類型",[12,186,187],{},"而這兩個部分會被編碼成 Base64 字串，例如：",[93,189,190],{"className":95,"code":133,"language":97,"meta":98,"style":98},[100,191,192],{"__ignoreMap":98},[103,193,194],{"class":105,"line":106},[103,195,133],{},[170,197,199],{"id":198},"payload負載","PAYLOAD（負載）",[12,201,202],{},"PAYLOAD（負載）的部分，其實就是一個 JSON 物件，例如：",[93,204,208],{"className":205,"code":206,"language":207,"meta":98,"style":98},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  \"username\": \"Ray\", \u002F\u002F 使用者名稱\n  \"email\": \"example.com\", \u002F\u002F 使用者信箱\n  \"iat\": 1516239022 \u002F\u002F 簽發（Issued At）時間\n}\n","json",[100,209,210,216,236,251,266],{"__ignoreMap":98},[103,211,212],{"class":105,"line":106},[103,213,215],{"class":214},"s8XSl","{\n",[103,217,218,222,225,229,232],{"class":105,"line":136},[103,219,221],{"class":220},"sWTrB","  \"username\"",[103,223,224],{"class":214},": ",[103,226,228],{"class":227},"sWayO","\"Ray\"",[103,230,231],{"class":214},", ",[103,233,235],{"class":234},"sGBqm","\u002F\u002F 使用者名稱\n",[103,237,238,241,243,246,248],{"class":105,"line":142},[103,239,240],{"class":220},"  \"email\"",[103,242,224],{"class":214},[103,244,245],{"class":227},"\"example.com\"",[103,247,231],{"class":214},[103,249,250],{"class":234},"\u002F\u002F 使用者信箱\n",[103,252,254,257,259,263],{"class":105,"line":253},4,[103,255,256],{"class":220},"  \"iat\"",[103,258,224],{"class":214},[103,260,262],{"class":261},"stw71","1516239022",[103,264,265],{"class":234}," \u002F\u002F 簽發（Issued At）時間\n",[103,267,269],{"class":105,"line":268},5,[103,270,271],{"class":214},"}\n",[12,273,274],{},"而這個 JSON 物件會被編碼成 Base64 字串，例如：",[93,276,277],{"className":95,"code":139,"language":97,"meta":98,"style":98},[100,278,279],{"__ignoreMap":98},[103,280,281],{"class":105,"line":106},[103,282,139],{},[12,284,285],{},"感覺 PAYLOAD 滿單純的吧？但實際上它是由三個部分組成的，分別是：",[65,287,288,291,294],{},[68,289,290],{},"Registered Claim（註冊聲明）",[68,292,293],{},"Public Claim（公開聲明）",[68,295,296],{},"Private Claim（私有聲明）",[12,298,299],{},"而這三個部分都是選填的，但實戰上來講，通常都會使用 Public Claim（公開聲明）來存放一些資料，例如：使用者的 ID、名字等等。",[12,301,302],{},"比較常見的設定會是 Registered Claim 中的 iat（Issued At）與 exp（Expiration Time），而這兩個屬性可以用來驗證 Token 是否過期等。",[12,304,305],{},"當然，Registered Claim 中還有很多屬性，例如：",[65,307,308,311,314,317,320,323,326],{},[68,309,310],{},"iss（Issuer）：發行者",[68,312,313],{},"sub（Subject）：主體",[68,315,316],{},"aud（Audience）：對象",[68,318,319],{},"exp（Expiration Time）：過期時間",[68,321,322],{},"nbf（Not Before）：生效時間",[68,324,325],{},"iat（Issued At）：簽發時間",[68,327,328],{},"jti（JWT ID）：JWT ID",[12,330,331],{},"因此以上面前面的 JSON 物件來說，就會變成這樣：",[93,333,335],{"className":205,"code":334,"language":207,"meta":98,"style":98},"{\n  \"username\": \"Ray\", \u002F\u002F 使用者名稱 => Public Claim（公開聲明）\n  \"email\": \"example.com\", \u002F\u002F 使用者信箱 => Public Claim（公開聲明）\n  \"iat\": 1516239022 \u002F\u002F 簽發（Issued At）時間 => Registered Claim（註冊聲明）\n}\n",[100,336,337,341,354,367,378],{"__ignoreMap":98},[103,338,339],{"class":105,"line":106},[103,340,215],{"class":214},[103,342,343,345,347,349,351],{"class":105,"line":136},[103,344,221],{"class":220},[103,346,224],{"class":214},[103,348,228],{"class":227},[103,350,231],{"class":214},[103,352,353],{"class":234},"\u002F\u002F 使用者名稱 => Public Claim（公開聲明）\n",[103,355,356,358,360,362,364],{"class":105,"line":142},[103,357,240],{"class":220},[103,359,224],{"class":214},[103,361,245],{"class":227},[103,363,231],{"class":214},[103,365,366],{"class":234},"\u002F\u002F 使用者信箱 => Public Claim（公開聲明）\n",[103,368,369,371,373,375],{"class":105,"line":253},[103,370,256],{"class":220},[103,372,224],{"class":214},[103,374,262],{"class":261},[103,376,377],{"class":234}," \u002F\u002F 簽發（Issued At）時間 => Registered Claim（註冊聲明）\n",[103,379,380],{"class":105,"line":268},[103,381,271],{"class":214},[39,383,384],{"title":41,"type":42},[12,385,386],{},"要注意一下 Claim（聲明）的單字只有三個字母，因為 JWT 旨在簡潔與輕量化，因此 Claim（聲明）的單字只有三個字母。",[170,388,390],{"id":389},"verify-signature驗證簽名","VERIFY SIGNATURE（驗證簽名）",[12,392,393],{},"VERIFY SIGNATURE（驗證簽名）的部分，其實就是將 PAYLOAD（負載）與 HEADER（標頭）進行編碼，然後再進行加密，例如：",[93,395,399],{"className":396,"code":397,"language":398,"meta":98,"style":98},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","HMACSHA256(\n  base64UrlEncode(header) + \".\" +\n  base64UrlEncode(payload),\n  secret)\n","js",[100,400,401,410,428,435],{"__ignoreMap":98},[103,402,403,407],{"class":105,"line":106},[103,404,406],{"class":405},"scAaK","HMACSHA256",[103,408,409],{"class":214},"(\n",[103,411,412,415,418,422,425],{"class":105,"line":136},[103,413,414],{"class":405},"  base64UrlEncode",[103,416,417],{"class":214},"(header) ",[103,419,421],{"class":420},"sOudu","+",[103,423,424],{"class":227}," \".\"",[103,426,427],{"class":420}," +\n",[103,429,430,432],{"class":105,"line":142},[103,431,414],{"class":405},[103,433,434],{"class":214},"(payload),\n",[103,436,437],{"class":105,"line":253},[103,438,439],{"class":214},"  secret)\n",[12,441,442],{},"那麼問題來了，JWT 是如何知道要用什麼演算法來加密呢？其實就是透過 HEADER（標頭）來取得，例如：",[93,444,446],{"className":205,"code":445,"language":207,"meta":98,"style":98},"{\n  \"alg\": \"HS256\",\n  \"typ\": \"JWT\"\n}\n",[100,447,448,452,465,475],{"__ignoreMap":98},[103,449,450],{"class":105,"line":106},[103,451,215],{"class":214},[103,453,454,457,459,462],{"class":105,"line":136},[103,455,456],{"class":220},"  \"alg\"",[103,458,224],{"class":214},[103,460,461],{"class":227},"\"HS256\"",[103,463,464],{"class":214},",\n",[103,466,467,470,472],{"class":105,"line":142},[103,468,469],{"class":220},"  \"typ\"",[103,471,224],{"class":214},[103,473,474],{"class":227},"\"JWT\"\n",[103,476,477],{"class":105,"line":253},[103,478,271],{"class":214},[12,480,481],{},"如果今天是用 PS256 演算法來加密的話，就會變成這樣：",[93,483,485],{"className":205,"code":484,"language":207,"meta":98,"style":98},"{\n  \"alg\": \"PS256\",\n  \"typ\": \"JWT\"\n}\n",[100,486,487,491,502,510],{"__ignoreMap":98},[103,488,489],{"class":105,"line":106},[103,490,215],{"class":214},[103,492,493,495,497,500],{"class":105,"line":136},[103,494,456],{"class":220},[103,496,224],{"class":214},[103,498,499],{"class":227},"\"PS256\"",[103,501,464],{"class":214},[103,503,504,506,508],{"class":105,"line":142},[103,505,469],{"class":220},[103,507,224],{"class":214},[103,509,474],{"class":227},[103,511,512],{"class":105,"line":253},[103,513,271],{"class":214},[12,515,516],{},"接著就會將 PAYLOAD（負載）與 HEADER（標頭）進行編碼，然後再進行加密，例如：",[93,518,520],{"className":396,"code":519,"language":398,"meta":98,"style":98},"PS256(\n  base64UrlEncode(header) + \".\" +\n  base64UrlEncode(payload),\n  secret)\n",[100,521,522,529,541,547],{"__ignoreMap":98},[103,523,524,527],{"class":105,"line":106},[103,525,526],{"class":405},"PS256",[103,528,409],{"class":214},[103,530,531,533,535,537,539],{"class":105,"line":136},[103,532,414],{"class":405},[103,534,417],{"class":214},[103,536,421],{"class":420},[103,538,424],{"class":227},[103,540,427],{"class":420},[103,542,543,545],{"class":105,"line":142},[103,544,414],{"class":405},[103,546,434],{"class":214},[103,548,549],{"class":105,"line":253},[103,550,439],{"class":214},[12,552,553],{},"而這個加密後的字串也會被編碼成 Base64 字串。",[12,555,556],{},"那 secret 是什麼呢？其實就是一個私鑰，我們在針對 JWT TOken 生成時，會需要使用一組私鑰，而這組私鑰會被用來加密，而當我們要驗證 JWT Token 時，就會需要使用這組私鑰來解密。",[12,558,559],{},"那麼另一個問題來了，我們生成的 JWT Token：",[93,561,562],{"className":95,"code":96,"language":97,"meta":98,"style":98},[100,563,564],{"__ignoreMap":98},[103,565,566],{"class":105,"line":106},[103,567,96],{},[12,569,570,571,576],{},"你可以把它丟到 ",[54,572,575],{"href":573,"rel":574},"https:\u002F\u002Fjwt.io\u002F",[58],"jwt.io"," 這個網站上，然後你就會發現它會自動幫你解析，並且告訴你這個 Token 是用什麼演算法加密的，以及 Token 的類型，如下圖：",[12,578,579],{},[15,580],{"alt":581,"src":582},"JWT Token","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fjwt_token.png",[12,584,585],{},"好的，問題來了",[12,587,588],{},"「為什麼我們沒有提供私鑰（secret），但是它卻可以解析出來呢？」",[12,590,591],{},"因為 JWT Token 只是透過 Base64 編碼，而並沒有進行加密，因此你是可以自己寫一個 JWT Token 解析器，這邊我也簡單示範寫一個 JWT Token 解析器範例：",[93,593,595],{"className":396,"code":594,"language":398,"meta":98,"style":98},"\u002F\u002F Base64 解碼\nconst Base64decoded = (str) => {\n  str = str.replace(\u002F-\u002Fg, '+').replace(\u002F_\u002Fg, '\u002F');\n\n  \u002F\u002F 如果字串長度不是 4 的倍數，補上 \"=\"\n  while (str.length % 4 !== 0) {\n    str += '=';\n  }\n\n  return window.atob(str);\n}\n\n\u002F\u002F 解析 JWT Token\nconst jwtTokenEncoded = (str) => {\n  if(!str) return console.log('請輸入 JWT Token');\n  const [header, payload, signature] = str.split('.');\n\n  const headerDecoded = JSON.parse(Base64decoded(header));\n  const payloadDecoded = JSON.parse(Base64decoded(payload));\n\n  return {\n    header: headerDecoded,\n    payload: payloadDecoded,\n  }\n}\n\njwtTokenEncoded('eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c')\n",[100,596,597,602,629,677,683,688,715,730,736,741,756,761,766,772,792,822,861,866,893,916,921,928,934,940,945,950,955],{"__ignoreMap":98},[103,598,599],{"class":105