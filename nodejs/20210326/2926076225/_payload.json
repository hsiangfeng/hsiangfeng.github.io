[{"data":1,"prerenderedAt":286},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20210326\u002F2926076225\u002F":3,"page:\u002Fnodejs\u002F20210326\u002F2926076225\u002F":4,"alt:\u002Fnodejs\u002F20210326\u002F2926076225\u002F":3,"prev-next:\u002Fnodejs\u002F20210326\u002F2926076225\u002F":261,"related:\u002Fnodejs\u002F20210326\u002F2926076225\u002F":270},"\u002Fen\u002Fnodejs\u002F2021\u002F03\u002F26\u002Fbody-parser-deprecated-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":244,"date":245,"description":18,"extension":246,"lang":247,"meta":248,"navigation":102,"path":249,"readingMinutes":250,"seo":251,"standalone":252,"stem":253,"tags":254,"tldr":258,"updated":258,"url":259,"__hash__":260},"content\u002FNodejs\u002F解決-body-parser-被標記為棄用-body-parser-as-deprecated.md","解決 body-parser 被標記為棄用(body-parser as deprecated)","2926076225",{"type":9,"value":10,"toc":240},"minimark",[11,15,19,23,29,32,35,38,41,167,170,236],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近在使用 Express 的時候發現 body-parser 被標記為棄用了，因此來紀錄一下如何解決這個問題。",[12,20,22],{"id":21},"body-parser-棄用","body-parser 棄用",[16,24,25],{},[26,27],"img",{"alt":22,"src":28},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002Fimage.png",[16,30,31],{},"這個問題算是很好解決，可是這邊也稍微紀錄一下為什麼會出現該問題。",[16,33,34],{},"body-parser 最主要是幫助我們處理一些 HTTP request 的資料，簡單白話文就是表單資料，而其實 Express v3.x 就有內建支援 body-parser，但我們都還是使用第三方套件，只是後來 Express v4.x 出現之後 VSCode 就會跳出訊息告知你這個功能被棄用了。",[16,36,37],{},"而這邊只需要將原本的程式碼稍微調整一下即可。",[16,39,40],{},"原始程式碼：",[42,43,48],"pre",{"className":44,"code":45,"language":46,"meta":47,"style":47},"language-js shiki shiki-themes github-dark-high-contrast","const express = require('express');\nconst app = express();\n\nconst bodyParser = require('body-parser');\n\napp.use(bodyParser.json());\napp.use(bodyParser.urlencoded({ extended: false }));\n","js","",[49,50,51,82,97,104,123,128,146],"code",{"__ignoreMap":47},[52,53,56,60,64,67,71,75,79],"span",{"class":54,"line":55},"line