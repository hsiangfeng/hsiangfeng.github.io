\nconst job = new CronJob(\n  '0 9 * * 1',\n  function() {\n    crawler();\n  }\n);\n\njob.start();\n",[40,1421,1422,1426,1430,1435,1439,1453,1460,1466,1472,1476,1480,1484],{"__ignoreMap":38},[43,1423,1424],{"class":45,"line":46},[43,1425,488],{"class":487},[43,1427,1428],{"class":45,"line":57},[43,1429,158],{"emptyLinePlaceholder":157},[43,1431,1432],{"class":45,"line":66},[43,1433,1434],{"class":487},"\u002F\u002F ... 略過程式碼\n",[43,1436,1437],{"class":45,"line":78},[43,1438,158],{"emptyLinePlaceholder":157},[43,1440,1441,1443,1445,1447,1449,1451],{"class":45,"line":187},[43,1442,278],{"class":131},[43,1444,302],{"class":60},[43,1446,283],{"class":131},[43,1448,170],{"class":131},[43,1450,173],{"class":142},[43,1452,176],{"class":135},[43,1454,1455,1458],{"class":45,"line":196},[43,1456,1457],{"class":53},"  '0 9 * * 1'",[43,1459,184],{"class":135},[43,1461,1462,1464],{"class":45,"line":213},[43,1463,1396],{"class":131},[43,1465,193],{"class":135},[43,1467,1468,1470],{"class":45,"line":219},[43,1469,1403],{"class":142},[43,1471,436],{"class":135},[43,1473,1474],{"class":45,"line":227},[43,1475,640],{"class":135},[43,1477,1478],{"class":45,"line":235},[43,1479,210],{"class":135},[43,1481,1482],{"class":45,"line":241},[43,1483,158],{"emptyLinePlaceholder":157},[43,1485,1486,1488,1490],{"class":45,"line":626},[43,1487,430],{"class":135},[43,1489,433],{"class":142},[43,1491,436],{"class":135},[12,1493,1494],{},"那麼另一個爬取鐵人賽文章詳細資訊的程式碼也是一樣的，只是這邊就留給你自己試試看了，我就不多做說明與解釋囉~",[20,1496,1497],{"id":1497},"混亂知識點",[12,1499,1500],{},"現在應該會發生一點混亂點，也就是 Node.js 的 Cron 跟 Linux 的 Cron 有什麼差別呢？",[12,1502,1503],{},[15,1504],{"alt":1497,"src":1505},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1694788997653.png",[12,1507,1508,1509,1511],{},"首先我們在 npm 所下載安裝的 ",[40,1510,90],{}," 套件，主要是運行於 Node.js 環境下的，而 Linux 則是一個作業系統，所以這兩個東西是不太一樣的東西，只是概念以及時間格式是類似相同的，所以有時候會讓人有點混淆。",[12,1513,1514,1515,1518],{},"因此通常你會比較常看到人家講 ",[40,1516,1517],{},"node-cron","，但只是因為你在安裝 npm 套件時，指令是這樣...",[33,1520,1521],{"className":35,"code":94,"language":37,"meta":38,"style":38},[40,1522,1523],{"__ignoreMap":38},[43,1524,1525,1527,1529],{"class":45,"line":46},[43,1526,69],{"class":49},[43,1528,103],{"class":53},[43,1530,106],{"class":53},[12,1532,1533],{},"所以才會有一點混亂，但其實這兩個東西是不一樣的，只是概念上有點類似而已。",[12,1535,1536],{},"那這兩者有什麼明顯差異嗎？剛才有提到概念以及時間的格式非常雷同，但是大多在 Linux 上的 Cron 比較常用來執行 Shell Script，所以與 Node.js 的 Cron 相比會比較難以擴充成更複雜的邏輯。",[438,1538,1539],{},[12,1540,1541,1543,1544,1547,1548,1547,1550,1552],{},[443,1542,445],{},"\nShell Script 是一個純文字檔案，裡面可以寫一些指令，例如 ",[40,1545,1546],{},"ls","、",[40,1549,61],{},[40,1551,50],{}," 等等，而這些指令都是可以在終端機上執行的，所以你可以把 Shell Script 想像成一個可以在終端機上執行的檔案。",[12,1554,1555,1556,1558],{},"簡而總之，如果你想要在 Node.js 上執行自己所撰寫的 JavaScript 程式碼，那就使用 ",[40,1557,1517],{},"，如果你想要在 Linux 上執行 Shell Script，那就使用 Linux 的 Cron。",[12,1560,1561],{},"那麼這一篇也差不多了，我們就先到這邊結束，我們下一篇見囉～",[1563,1564,1565],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":38,"searchDepth":57,"depth":57,"links":1567},[1568,1569,1570,1571,1572],{"id":22,"depth":57,"text":22},{"id":28,"depth":57,"text":28},{"id":109,"depth":57,"text":110},{"id":456,"depth":57,"text":456},{"id":1497,"depth":57,"text":1497},"Nodejs","2023-10-03 00:00:01","前一篇我們對於 Crontab 已經有一個基本的概念，接下來當然要套用到實戰上，不然認識了也沒用，所以這一篇我們就來實作一個 Crontab + Node.js 的範例。","md","zh-Hant",{},"\u002Fnode.js-node.js\u002Fday19-crontab-node-js","4",{"title":6,"description":1575},false,"《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay19-Crontab-Node-js",[1585,1586],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》",null,"\u002Fnodejs\u002F20231003\u002F1830434204\u002F","KsH96QwNa9S8OcIxuMsfp3LSbloj_EDlLIof7QhUIVc",{"newer":1591,"older":1595},{"url":1592,"title":1593,"date":1594},"\u002Fnodejs\u002F20231004\u002F1031795777\u002F","Day20 - Discord Bot？","2023-10-04 00:00:01",{"url":1596,"title":1597,"date":1598},"\u002Fnodejs\u002F20231002\u002F2297973079\u002F","Day18 - 初識 Crontab","2023-10-02 00:00:01",[1600,1605,1610],{"url":1601,"title":1602,"date":1603,"readingMinutes":1604},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":1606,"title":1607,"date":1608,"readingMinutes":1609},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":1611,"title":1612,"date":1613,"readingMinutes":1614},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784010303462]