[{"data":1,"prerenderedAt":2144},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20231008\u002F2016996949\u002F":3,"page:\u002Fnodejs\u002F20231008\u002F2016996949\u002F":4,"alt:\u002Fnodejs\u002F20231008\u002F2016996949\u002F":3,"prev-next:\u002Fnodejs\u002F20231008\u002F2016996949\u002F":2119,"related:\u002Fnodejs\u002F20231008\u002F2016996949\u002F":2128},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F08\u002Fday-24-deploying-to-zeabur\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":2103,"date":2104,"description":25,"extension":2105,"lang":2106,"meta":2107,"navigation":273,"path":2108,"readingMinutes":2109,"seo":2110,"standalone":2111,"stem":2112,"tags":2113,"tldr":2116,"updated":2104,"url":2117,"__hash__":2118},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay24-部署到-Zeabur.md","Day24-部署到 Zeabur","2016996949",{"type":9,"value":10,"toc":2095},"minimark",[11,19,23,26,29,32,35,38,54,57,60,69,72,75,78,81,166,190,193,235,238,699,702,990,993,1387,1390,1667,1670,1754,1757,1772,1786,1789,1795,1798,1804,1807,1813,1816,1822,1825,1831,1834,1840,1843,1846,1852,1855,1860,1863,1868,1871,1877,1882,1885,1891,1894,1900,1903,1908,1915,1919,1926,2018,2021,2024,2042,2045,2054,2057,2060,2063,2072,2075,2078,2085,2088,2091],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Zeabur","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F%E6%88%AA%E5%9C%96%202023-09-08%2014.22.48.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"前一面我們對於伺服器有基本概念後，接下來當然是要實際部署專案到伺服器上囉～",[20,27,17],{"id":28},"zeabur",[12,30,31],{},"Zeabur 是一個 PaaS 平台，何謂 PaaS 呢？Platform as a service 中文又稱平台即服務。",[12,33,34],{},"有點模糊吧？那我舉個例子來講好了，假設你今天要蓋一個房子好了，那你需要什麼呢？當然是地基、水泥、磚頭、木頭等等，更不用說你還需要去設計房子的樣子，這些都是你需要做的事情。",[12,36,37],{},"而 PaaS 概念就跟請一個專業的建築公司來蓋一樣，因為這間建築公司本身就有提供相對應得服務，例如：設計、施工、材料等等，你只需要跟他們說你要蓋什麼樣的房子，他們就會幫你蓋好，這就是 PaaS 的概念。",[12,39,40,41,45,46,49,50,53],{},"所以以這個概念來講，你代表著",[42,43,44],"strong",{},"開發者","，而建築公司則代表著",[42,47,48],{},"PaaS 平台","，而房子則代表著",[42,51,52],{},"專案","，你只需要專注於專案的開發，而不需要去擔心伺服器的問題，這就是 PaaS 的好處。",[12,55,56],{},"常見的 PaaS 平台非常多，例如...先前轉成收費的 Heroku 就是一個 PaaS 平台，因此我們不用過度的去擔心伺服器的問題，只需要註冊帳號、建立專案、部屬專案就好了，非常的方便呢！",[12,58,59],{},"而 PaaS 平台核心理念在於抽象化你原有在伺服器上複雜管理工作，讓你可以更專注於專案上的開發，因此對於新手、小白等開發者，其實是非常的方便的。",[61,62,63],"blockquote",{},[12,64,65,68],{},[42,66,67],{},"Note","\n當然，也有所謂的 Iass（Infrastructure as a Service）與 SaaS（Software as a Service），但這兩個東西就不是我們這邊要講的了，有興趣的話可以自行去查詢看看。",[12,70,71],{},"那麼為什麼我會選擇 Zeabur 呢？因為 Zeabur 是台灣的 PaaS 平台，當然要支持一下本土的平台，而且 Zeabur 也有提供免費的方案（每個月 5 美金），更不用說非常的方便，所以我們就來使用 Zeabur 來部屬我們的專案吧！",[20,73,74],{"id":74},"部署",[12,76,77],{},"接下來我會全程一步一步帶著你將前一篇的專案部屬到 Zeabur 上，當然你也可以自己先試試看，如果有問題的話再回來看看這篇文章。",[12,79,80],{},"首先底下我提供相對應的指令以及預期要部署的程式碼，確保你我之間的程式碼是一致的，這樣才能夠順利的部屬。",[82,83,88],"pre",{"className":84,"code":85,"language":86,"meta":87,"style":87},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir example-discord-bot-crawler\ncd example-discord-bot-crawler\nnpm init -y\ntouch index.js\ntouch register.js\ntouch crawler.js\ntouch postCron.js\ntouch .env\n","bash","",[89,90,91,104,113,125,134,142,150,158],"code",{"__ignoreMap":87},[92,93,96,100],"span",{"class":94,"line":95},"line",1,[92,97,99],{"class":98},"s_sBn","mkdir",[92,101,103],{"class":102},"sTRMh"," example-discord-bot-crawler\n",[92,105,107,111],{"class":94,"line":106},2,[92,108,110],{"class":109},"sCcAr","cd",[92,112,103],{"class":102},[92,114,116,119,122],{"class":94,"line":115},3,[92,117,118],{"class":98},"npm",[92,120,121],{"class":102}," init",[92,123,124],{"class":109}," -y\n",[92,126,128,131],{"class":94,"line":127},4,[92,129,130],{"class":98},"touch",[92,132,133],{"class":102}," index.js\n",[92,135,137,139],{"class":94,"line":136},5,[92,138,130],{"class":98},[92,140,141],{"class":102}," register.js\n",[92,143,145,147],{"class":94,"line":144},6,[92,146,130],{"class":98},[92,148,149],{"class":102}," crawler.js\n",[92,151,153,155],{"class":94,"line":152},7,[92,154,130],{"class":98},[92,