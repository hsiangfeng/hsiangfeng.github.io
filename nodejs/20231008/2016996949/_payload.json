n});\n\nclient.once(Events.ClientReady, () => {\n  console.log('Ready!');\n  postCron(client).start();\n});\n\nclient.on(Events.InteractionCreate, async (interaction) => {\n  if (interaction.commandName === 'blog') {\n    const data = await crawler();\n    const randomIndex = Math.floor(Math.random() * data.length);\n    const randomData = data[randomIndex];\n    await interaction.reply(`隨機推薦一篇 Ray 的文章：[${randomData.title}](${randomData.url})`);\n  }\n});\n\nclient.login(process.env.DISCORD_TOKEN);\n",[88,241,242,247,268,274,296,314,318,325,333,341,349,357,375,380,399,405,411,417,423,429,435,441,446,452,457,474,490,504,509,514,542,560,578,614,627,668,674,679,684],{"__ignoreMap":86},[91,243,244],{"class":93,"line":94},[91,245,246],{"class":203},"\u002F\u002F index.js\n",[91,248,249,253,256,259,262,265],{"class":93,"line":105},[91,250,252],{"class":251},"scAaK","require",[91,254,255],{"class":209},"(",[91,257,258],{"class":101},"'dotenv'",[91,260,261],{"class":209},").",[91,263,264],{"class":251},"config",[91,266,267],{"class":209},"();\n",[91,269,270],{"class":93,"line":114},[91,271,273],{"emptyLinePlaceholder":272},true,"\n",[91,275,276,279,282,285,288,290,293],{"class":93,"line":126},[91,277,278],{"class":218},"const",[91,280,281],{"class":108}," crawler",[91,283,284],{"class":218}," =",[91,286,287],{"class":251}," require",[91,289,255],{"class":209},[91,291,292],{"class":101},"'.\u002Fcrawler'",[91,294,295],{"class":209},");\n",[91,297,298,300,303,305,307,309,312],{"class":93,"line":135},[91,299,278],{"class":218},[91,301,302],{"class":108}," postCron",[91,304,284],{"class":218},[91,306,287],{"class":251},[91,308,255],{"class":209},[91,310,311],{"class":101},"'.\u002FpostCron'",[91,313,295],{"class":209},[91,315,316],{"class":93,"line":143},[91,317,273],{"emptyLinePlaceholder":272},[91,319,320,322],{"class":93,"line":151},[91,321,278],{"class":218},[91,323,324],{"class":209}," {\n",[91,326,327,330],{"class":93,"line":159},[91,328,329],{"class":108},"  Client",[91,