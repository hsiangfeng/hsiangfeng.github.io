le.log('Ready!');\n  postCron(client).start();\n});\n\nclient.on(Events.InteractionCreate, async (interaction) => {\n  if (interaction.commandName === 'blog') {\n    const data = await crawler();\n    const randomIndex = Math.floor(Math.random() * data.length);\n    const randomData = data[randomIndex];\n    await interaction.reply(`隨機推薦一篇 Ray 的文章：[${randomData.title}](${randomData.url})`);\n  }\n});\n\nclient.login(process.env.DISCORD_TOKEN);\n",[89,242,243,248,269,275,297,315,319,326,334,342,350,358,376,381,400,406,412,418,424,430,436,442,447,453,458,475,491,505,510,515,542,560,578,614,627,668,674,679,684],{"__ignoreMap":87},[92,244,245],{"class":94,"line":95},[92,246,247],{"class":204},"\u002F\u002F index.js\n",[92,249,250,254,257,260,263,266],{"class":94,"line":106},[92,251,253],{"class":252},"sj_SG","require",[92,255,256],{"class":210},"(",[92,258,259],{"class":102},"'dotenv'",[92,261,262],{"class":210},").",[92,264,265],{"class":252},"config",[92,267,268],{"class":210},"();\n",[92,270,271],{"class":94,"line":115},[92,272,274],{"emptyLinePlaceholder":273},true,"\n",[92,276,277,280,283,286,289,291,294],{"class":94,"line":127},[92,278,279],{"class":219},"const",[92,281,282],{"class":109}," crawler",[92,284,285],{"class":219}," =",[92,287,288],{"class":252}," require",[92,290,256],{"class":210},[92,292,293],{"class":102},"'.\u002Fcrawler'",[92,295,296],{"class":210},");\n",[92,298,299,301,304,306,308,310,313],{"class":94,"line":136},[92,300,279],{"class":219},[92,302,303],{"class":109}," postCron",[92,305,285],{"class":219},[92,307,288],{"class":252},[92,309,256],{"class":210},[92,311,312],{"class":102},"'.\u002FpostCron'",[92,314,296],{"class":210},[92,316,317],{"class":94,"line":144},[92,318,274],{"emptyLinePlaceholder":273},[92,320,321,323],{"class":94,"line":152},[92,322,279],{"class":219},[92,324,325],{"class":210}," {\n",[92,327,328,331],{"class":94,"line":160},[92,329,330],{"class":109},"  Client",[92,332,333],{"class":210},",\n",[92,335,337,340],{"class":9