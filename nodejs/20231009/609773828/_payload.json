[{"data":1,"prerenderedAt":621},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20231009\u002F609773828\u002F":3,"page:\u002Fnodejs\u002F20231009\u002F609773828\u002F":4,"alt:\u002Fnodejs\u002F20231009\u002F609773828\u002F":3,"prev-next:\u002Fnodejs\u002F20231009\u002F609773828\u002F":596,"related:\u002Fnodejs\u002F20231009\u002F609773828\u002F":605},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F09\u002Fday-25-google-extension\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":580,"date":581,"description":25,"extension":582,"lang":583,"meta":584,"navigation":585,"path":586,"readingMinutes":199,"seo":587,"standalone":588,"stem":589,"tags":590,"tldr":593,"updated":581,"url":594,"__hash__":595},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay25-Google-Extension.md","Day25-Google Extension","609773828",{"type":9,"value":10,"toc":573},"minimark",[11,19,23,26,30,33,36,42,45,51,54,57,60,63,66,69,101,104,124,127,153,156,160,163,166,169,317,328,331,482,485,490,493,499,508,511,516,519,524,527,530,543,546,553,556,559,566,569],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Google Extension","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_Google_Extension_e8da17f6-0589-4a56-a23c-69e58c66adb4.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"又進入新的章節了，這章節我們要來介紹 Google Extension，那麼 Google Extension 是什麼呢？這一篇就讓我們來簡單的認識一下吧！",[20,27,29],{"id":28},"chrome-extension","Chrome Extension",[12,31,32],{},"身為市占率最高的瀏覽器 Chrome，你一定逛過它的擴充功能商店吧？而這些擴充功能就是我們所謂的 Chrome Extension，透過這些擴充功能可以讓你的瀏覽器變得更加的強大，例如：廣告封鎖、翻譯、下載影片等等，而這些擴充功能都是使用 JavaScript 所寫成的。",[12,34,35],{},"（謎之聲：除非你跟我一樣是邊緣人，使用的是 Firefox，不然大部分開發者幾乎是使用 Chrome QQ）",[12,37,38],{},[15,39],{"alt":40,"src":41},"邊緣人","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1696435415522.png",[12,43,44],{},"那麼為什麼我們要認識 Chrome Extension 呢？你還記得最初的文章我提到的這件事情嗎？",[46,47,48],"blockquote",{},[12,49,50],{},"V8 是由 Google 所推出的一個開源 JavaScript 引擎，它可以將 JavaScript 的程式碼轉換成機器碼，讓電腦可以執行 JavaScript 的程式碼。",[12,52,53],{},"那麼這時候問題來了",[12,55,56],{},"「Node.js 跟 Chrome Extension 有什麼關係？」",[12,58,59],{},"其實兩者來講，前者是屬於伺服器端的 JavaScript，而後者則是屬於瀏覽器端的 JavaScript，但是兩者都是使用 V8 來執行 JavaScript，還是不懂吧？Chrome Extension 本身就是運行於瀏覽器上的 JavaScript，而且它也是使用 V8 來執行 JavaScript，因此你可以把 Chrome Extension 當作是一個瀏覽器上的 JavaScript 程式。",[12,61,62],{},"那麼我們就來準備起手一下 Chrome Extension 吧！？",[20,64,65],{"id":65},"準備工作",[12,67,68],{},"首先我們要先建立一個專案環境，請你輸入以下指令",[70,71,76],"pre",{"className":72,"code":73,"language":74,"meta":75,"style":75},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir example-chrome-extension\ncd example-chrome-extension\n","bash","",[77,78,79,92],"code",{"__ignoreMap":75},[80,81,84,88],"span",{"class":82,"line":83},"line",1,[80,85,87],{"class":86},"s_sBn","mkdir",[80,89,91],{"class":90},"sTRMh"," example-chrome-extension\n",[80,93,95,99],{"class":82,"line":94},2,[80,96,98],{"class":97},"sCcAr","cd",[80,100,91],{"class":90},[12,102,103],{},"接下來還要在建立幾個檔案，請你輸入以下指令",[70,105,107],{"className":72,"code":106,"language":74,"meta":75,"style":75},"touch manifest.json\ntouch popup.html\n",[77,108,109,117],{"__ignoreMap":75},[80,110,111,114],{"class":82,"line":83},[80,112,113],{"class":86},"touch",[80,115,116],{"class":90}," manifest.json\n",[80,118,119,121],{"class":82,"line":94},[80,120,113],{"class":86},[80,122,123],{"class":90}," popup.html\n",[12,125,126],{},"這時候你的專案應該會長這樣",[70,128,130],{"className":72,"code":129,"language":74,"meta":75,"style":75},"- example-chrome-extension\n  - manifest.json\n  - popup.html\n",[77,131,132,139,146],{"__ignoreMap":75},[80,133,134,137],{"class":82,"line":83},[80,135,136],{"class":86},"-",[80,138,91],{"class":90},[80,140,141,144],{"class":82,"line":94},[80,142,143],{"class":86},"  -",[80,145,116],{"class":90},[80,147,149,151],{"class":82,"line":148},3,[80,150,143],{"class":86},[80,152,123],{"class":90},[12,154,155],{},"這幾個檔案先不用擔心，我們後面會在介紹，先把環境準備好再說。",[20,157,159],{"id":158},"第一個-chrome-extension","第一個 Chrome Extension",[12,161,162],{},"首先我們必須要先來介紹一下 manifest.json，這個檔案非常的重要，可以說是整個 Chrome Extension 的核心，因為它會告訴瀏覽器這個擴充功能的資訊，例如：擴充功能的名稱、版本、描述、圖示、權限等等，而且這個檔案必須要放在根目錄下，也就是說不能放在子目錄下。",[12,164,165],{},"這個檔案內容要貼入什麼呢？請你先貼入以下：",[12,167,168],{},"（不用擔心，我一樣會補上註解說明）",[70,170,174],{"className":171,"code":172,"language":173,"meta":75,"style":75},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \u002F\u002F 這個 Manifest 的版本，目前最新的版本是 3\n  \"manifest_version\": 3,\n  \u002F\u002F 這個擴充套件的名稱，你可以改成你喜歡的名稱\n  \"name\": \"Hello Extensions\",\n  \u002F\u002F 這個擴充套件的描述\n  \"description\": \"Base Level Extension\",\n  \u002F\u002F 這個擴充套件的版本\n  \"version\": \"1.0\",\n  \"action\": {\n    \u002F\u002F 這個屬性是用來設定點擊擴充套件後要執行的 HTML 檔案\n    \"default_popup\": \"popup.html\",\n    \u002F\u002F 擴充套件的圖示，主要是用來顯示在瀏覽器的工具列上\n    \"default_icon\": \"hello_extensions.png\"\n  }\n}\n","json",[77,175,176,182,188,203,209,222,228,241,247,260,269,275,288,294,305,311],{"__ignoreMap":75},[80,177,178],{"class":82,"line":83},[80,179,181],{"class":180},"sMAXC","{\n",[80,183,184],{"class":82,"line":94},[80,185,187],{"class":186},"sQrFR","  \u002F\u002F 這個 Manifest 的版本，目前最新的版本是 3\n",[80,189,190,194,197,200],{"class":82,"line":148},[80,191,193],{"class":192},"sKpQp","  \"manifest_version\"",[80,195,196],{"class":180},": ",[80,198,199],{"class":97},"3",[80,201,202],{"class":180},",\n",[80,204,206],{"class":82,"line":205},4,[80,207,208],{"class":186},"  \u002F\u002F 這個擴充套件的名稱，你可以改成你喜歡的名稱\n",[80,210,212,215,217,220],{"class":82,"line":211},5,[80,213,214],{"class":192},"  \"name\"",[80,216,196],{"class":180},[80,218,219],{"class":90},"\"Hello Extensions\"",[80,221,202],{"class":180},[80,223,225],{"class":82,"line":224},6,[80,226,227],{"class":186},"  \u002F\u002F 這個擴充套件的描述\n",[80,229,231,234,236,239],{"class":82,"line":230},7,[80,232,233],{"class":192},"  \"description\"",[80,235,196],{"class":180},[80,237,238],{"class":90},"\"Base Level Extension\"",[80,240,202],{"class":180},[80,242,244],{"class":82,"line":243},8,[80,245,246],{"class":186},"  \u002F\u002F 這個擴充套件的版本\n",[80,248,250,253,255,258],{"class":82,"line":249},9,[80,251,252],{"class":192},"  \"version\"",[80,254,196],{"class":180},[80,256,257],{"class":90},"\"1.0\"",[80,259,202],{"class":180},[80,261,263,266],{"class":82,"line":262},10,[80,264,265],{"class":192},"  \"action\"",[80,267,268],{"class":180},": {\n",[80,270,272],{"class":82,"line":271},11,[80,273,274],{"class":186},"    \u002F\u002F 這個屬性是用來設定點擊擴充套件後要執行的 HTML 檔案\n",[80,276,278,281,283,286],{"class":82,"line":277},12,[80,279,280],{"class":192},"    \"default_popup\"",[80,282,196],{"class":180},[80,284,285],{"class":90},"\"popup.html\"",[80,287,202],{"class":180},[80,289,291],{"class":82,"line":290},13,[80,292,293],{"class":186},"    \u002F\u002F 擴充套件的圖示，主要是用來顯示在瀏覽器的工具列上\n",[80,295,297,300,302],{"class":82,"line":296},14,[80,298,299],{"class":192},"    \"default_icon\"",[80,301,196],{"class":180},[80,303,304],{"class":90},"\"hello_extensions.png\"\n",[80,306,308],{"class":82,"line":307},15,[80,309,310],{"class":180},"  }\n",[80,312,314],{"class":82,"line":313},16,[80,315,316],{"class":180},"}\n",[12,318,319,320,327],{},"圖示呢？圖示來源你可以用 Google 官方所提供的圖示，請你先下載 ",[321,322,326],"a",{"href":323,"rel":324},"https:\u002F\u002Fstorage.googleapis.com\u002Fweb-dev-uploads\u002Fimage\u002FWlD8wC6g8khYWPJUsQceQkhXSlv1\u002FgmKIT88Ha1z8VBMJFOOH.png",[325],"nofollow","Google 官方圖示"," 並且放在根目錄下。",[12,329,330],{},"接著打開 popup.html，並且貼入以下內容：",[70,332,336],{"className":333,"code":334,"language":335,"meta":75,"style":75},"language-html shiki shiki-themes github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>Hello Extension\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>Hello Extension\u003C\u002Fh1>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html",[77,337,338,352,370,379,397,421,435,444,453,466,474],{"__ignoreMap":75},[80,339,340,343,346,349],{"class":82,"line":83},[80,341,342],{"class":180},"\u003C!",[80,344,345],{"class":192},"DOCTYPE",[80,347,348],{"class":97}," html",[80,350,351],{"class":180},">\n",[80,353,354,357,359,362,365,368],{"class":82,"line":94},[80,355,356],{"class":180},"\u003C",[80,358,335],{"class":192},[80,360,361],{"class":97}," lang",[80,363,364],{"class":180},"=",[80,366,367],{"class":90},"\"zh-Hant-TW\"",[80,369,351],{"class":180},[80,371,372,374,377],{"class":82,"line":148},[80,373,356],{"class":180},[80,375,376],{"class":192},"head",[80,378,351],{"class":180},[80,380,381,384,387,390,392,395],{"class":82,"line":205},[80,382,383],{"class":180},"  \u003C",[80,385,386],{"class":192},"meta",[80,388,389],{"class":97}," charset",[80,391,364],{"class":180},[80,393,394],{"class":90},"\"UTF-8\"",[80,396,351],{"class":180},[80,398,399,401,403,406,408,411,414,416,419],{"class":82,"line":211},[80,400,383],{"class":180},[80,402,386],{"class":192},[80,404,405],{"class":97}," name",[80,407,364],{"class":180},[80,409,410],{"class":90},"\"viewport\"",[80,412,413],{"class":97}," content",[80,415,364],{"class":180},[80,417,418],{"class":90},"\"width=device-width, initial-scale=1.0\"",[80,420,351],{"class":180},[80,422,423,425,428,431,433],{"class":82,"line":224},[80,424,383],{"class":180},[80,426,427],{"class":192},"title",[80,429,430],{"class":180},">Hello Extension\u003C\u002F",[80,432,427],{"class":192},[80,434,351],{"class":180},[80,436,437,440,442],{"class":82,"line":230},[80,438,439],{"class":180},"\u003C\u002F",[80,441,376],{"class":192},[80,443,351],{"class":180},[80,445,446,448,451],{"class":82,"line":243},[80,447,356],{"class":180},[80,449,450],{"class":192},"body",[80,452,351],{"class":180},[80,454,455,457,460,462,464],{"class":82,"line":249},[80,456,383],{"class":180},[80,458,459],{"class":192},"h1",[80,461,430],{"class":180},[80,463,459],{"class":192},[80,465,351],{"class":180},[80,467,468,470,472],{"class":82,"line":262},[80,469,439],{"class":180},[80,471,450],{"class":192},[80,473,351],{"class":180},[80,475,476,478,480],{"class":82,"line":271},[80,477,439],{"class":180},[80,479,335],{"class":192},[80,481,351],{"class":180},[12,483,484],{},"接著打開 Chrome 找到擴充功能，進入擴充功能頁面",[12,486,487],{},[15,488],{"alt":29,"src":489},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension.png",[12,491,492],{},"然後找到上方的「載入未封裝項目」，並且選擇你的專案資料夾",[12,494,495],{},[15,496],{"alt":497,"src":498},"載入未封裝項目","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension_2.png",[46,500,501],{},[12,502,503,507],{},[504,505,506],"strong",{},"Note","\n如果你找不到「載入未封裝項目」的話，請先確認你是否有勾選「開發人員模式」，如果沒有的話，請先勾選「開發人員模式」唷！",[12,509,510],{},"接著你應該就會看到你的擴充功能出現在瀏覽器的工具列上了",[12,512,513],{},[15,514],{"alt":29,"src":515},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension_3.png",[12,517,518],{},"並且你也可以在工具列上看到你這個套件，而且你也可以點一下看看，會發現你的 popup.html 會跳出來囉～",[12,520,521],{},[15,522],{"alt":29,"src":523},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fchrome_extension_hello.png",[12,525,526],{},"很簡單吧？這就是你的第一個 Chrome Extension 了！",[12,528,529],{},"我相信你應該發現到一件事情了，其實 Chrome Extension 整體不外乎就是 HTML、CSS、JavaScript，因此對於 Web 開發者來講是非常容易上手的。",[46,531,532],{},[12,533,534,536,537,542],{},[504,535,506],{},"\nFirefox 的套件實作與 Chrome Extension 有些許不同，因為本身兩者底層核心不同的關係，因此如果你想要開發 Firefox 的套件，請參考 ",[321,538,541],{"href":539,"rel":540},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fen-US\u002Fdocs\u002FMozilla\u002FAdd-ons\u002FWebExtensions",[325],"Firefox Extension","。",[12,544,545],{},"基本上只要是基於 V8 引擎開發的瀏覽器都是可以使用的，例如...內在是 Chromium 的 Edge、Arc 等等，因此你可以開發一個 Chrome Extension，然後在其他瀏覽器上也是可以使用的唷！",[46,547,548],{},[12,549,550,552],{},[504,551,506],{},"\nChromium 是一個開源的瀏覽器專案，主要也是由 Google 所推出，而且 Chromium 的內核也是使用 V8 引擎，因此兩者通常是相輔相成的關係；Chrome 也是基於 Chromium 所開發的，而後來的 Edge、Arc 也是基於 Chromium 所開發的。",[20,554,555],{"id":555},"引用外部套件",[12,557,558],{},"基本上如果你要在 Chrome Extension 中使用 npm 套件的話，你就必須額外使用打包工具，例如：Webpack、Parcel 等等，畢竟 Chrome Extension 本身是一個單純的 CSS、HTML、JavaScript 檔案，因此如果你要使用 npm 套件的話，你必須要透過打包工具來幫你打包成一個檔案，然後再引入到 Chrome Extension 中。",[46,560,561],{},[12,562,563,565],{},[504,564,506],{},"\n其實換個面向來看，就像我們在網頁上執行 JavaScript 一樣，我們也是透過打包工具來幫我們打包成一個檔案，然後再引入到網頁中。",[12,567,568],{},"那麼下一篇文章我們就來來介紹一下如何使用打包工具來打包 Chrome Extension 吧～",[570,571,572],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}",{"title":75,"searchDepth":94,"depth":94,"links":574},[575,576,577,578,579],{"id":22,"depth":94,"text":22},{"id":28,"depth":94,"text":29},{"id":65,"depth":94,"text":65},{"id":158,"depth":94,"text":159},{"id":555,"depth":94,"text":555},"Nodejs","2023-10-09 00:00:01","md","zh-Hant",{},true,"\u002Fnode.js-node.js\u002Fday25-google-extension",{"title":6,"description":25},false,"《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay25-Google-Extension",[591,592],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》",null,"\u002Fnodejs\u002F20231009\u002F609773828\u002F","WH69xvtg_MRfHBmpaN8UNRBaCQ7kKHB17T4sHa950VI",{"newer":597,"older":601},{"url":598,"title":599,"date":600},"\u002Fnodejs\u002F20231010\u002F3798507505\u002F","Day26-Google Extension 與 Vite","2023-10-10 00:00:01",{"url":602,"title":603,"date":604},"\u002Fnodejs\u002F20231008\u002F2016996949\u002F","Day24-部署到 Zeabur","2023-10-08 00:00:01",[606,611,616],{"url":607,"title":608,"date":609,"readingMinutes":610},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":612,"title":613,"date":614,"readingMinutes":615},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":617,"title":618,"date":619,"readingMinutes":620},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784012802842]