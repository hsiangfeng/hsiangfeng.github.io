[{"data":1,"prerenderedAt":234},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190708\u002F3972209423\u002F":3,"page:\u002Fnodejs\u002F20190708\u002F3972209423\u002F":4,"alt:\u002Fnodejs\u002F20190708\u002F3972209423\u002F":3,"prev-next:\u002Fnodejs\u002F20190708\u002F3972209423\u002F":209,"related:\u002Fnodejs\u002F20190708\u002F3972209423\u002F":218},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F08\u002Fnodejs-fullstack-04-middleware-route-guard\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":192,"date":193,"description":18,"extension":194,"lang":195,"meta":196,"navigation":197,"path":198,"readingMinutes":199,"seo":200,"standalone":201,"stem":202,"tags":203,"tldr":206,"updated":206,"url":207,"__hash__":208},"content\u002F全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-會員機制-4.md","全端勇士之路 Node.js 基礎學習-會員機制(4)","3972209423",{"type":9,"value":10,"toc":188},"minimark",[11,15,19,22,25,32,39,147,150,171,181,184],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面已經記錄了許多會員註冊 & 登入以及判定，但是如果今天不希望讓使用者直接透過網址列跳到 user 頁面呢?那麼就要使用到 middleware",[12,20,21],{"id":21},"頁面管控",[16,23,24],{},"一般我們都不會希望使用者可以透過瀏覽器輸入特定網址列進入某頁面，雖然可以使用判斷的方式來做安全阻擋，但是有些頁面可能太過複雜，那麼就要使用 middleware (中間組件?) 來解決這個問題，首先假設我們 user 這個邏輯全部都必須經由登入才能夠使用，那麼就要修改 app.js",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"app.js","https:\u002F\u002Fi.imgur.com\u002Fdd2MuaP.png",[16,33,34,35],{},"首先先來寫個 middleware，然後存進 ",[36,37,38],"code",{},"check",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F check login\nvar check = function(req, res, next) {\n  if(req.session.uid){\n    return next();\n  }\n  res.redirect('\u002Flogin');\n}\n","js","",[36,47,48,57,96,105,117,123,141],{"__ignoreMap":45},[49,50,53],"span",{"class":51,"line":52},"line",1,[49,54,56],{"class":55},"sQrFR","\u002F\u002F check login\n",[49,58,60,64,68,71,74,78,82,85,88,90,93],{"class":51,"line":59},2,[49,61,63],{"class":62},"sWyjQ","var",[