[{"data":1,"prerenderedAt":273},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190718\u002F2790148994\u002F":3,"page:\u002Fnodejs\u002F20190718\u002F2790148994\u002F":4,"alt:\u002Fnodejs\u002F20190718\u002F2790148994\u002F":3,"prev-next:\u002Fnodejs\u002F20190718\u002F2790148994\u002F":249,"related:\u002Fnodejs\u002F20190718\u002F2790148994\u002F":258},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F18\u002Fkoa-saga-mysql-sequelize-2\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":232,"date":233,"description":18,"extension":234,"lang":235,"meta":236,"navigation":237,"path":238,"readingMinutes":239,"seo":240,"standalone":241,"stem":242,"tags":243,"tldr":246,"updated":246,"url":247,"__hash__":248},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-sequelize-2.md","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-sequelize(2)","2790148994",{"type":9,"value":10,"toc":225},"minimark",[11,15,19,22,25,57,64,71,74,77,80,102,105,111,114,120,123,129,132,135,138,141,152,155,161,164,169,176,182,185,191,194,200,203,209,212,221],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面已經學會如何使用 sequelize 連接資料庫，接下來就是準備學習新增資料到資料庫中",[12,20,21],{"id":21},"起手式",[16,23,24],{},"接下來將會學習如何新增資料進去資料庫中，但是我們必須先做一點不同的事情，也就是系統規劃，但是在那之前我們還要安裝一個套件，也就是 sequelize-cli",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save sequelize-cli\n","js","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40,44,48,51,54],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sMAXC","npm install ",[36,45,47],{"class":46},"sWyjQ","--",[36,49,50],{"class":42},"save sequelize",[36,52,53],{"class":46},"-",[36,55,56],{"class":42},"cli\n",[16,58,59,60,63],{},"安裝完畢後輸入 ",[33,61,62],{},"npx sequelize init","，此時你會發現它幫我們建立兩個資料夾，分別為 models、config、migrations、seeders 資料夾，models 也就是 MVC 中的 M 的進入點，config\u002Fconfig.js 則是一些資料庫的設置檔案，而 migrations、seeders 則是空資料夾",[16,65,66],{},[67,68],"img",{"alt":69,"src":70},"sequelize init","https:\u002F\u002Fi.imgur.com\u002FiNYBKU4.png",[16,72,73],{},"基本上我們不太會動到 models\u002Findex.js",[16,75,76],{},"那麼我們就可以透過 sequelize 本身的一些配置來切換 development、test、production 三種資料庫連結設置，那麼切換的方式如下",[16,78,79],{},"假設我們今天要切換成 test 的設置的話",[26,81,83],{"className":28,"code":82,"language":30,"meta":31,"style":31},"npx sequelize db:migrate --env test\n",[33,84,85],{"__ignoreMap":31},[36,86,87,90,94,97,99],{"class":38,"line":39},[36,88,89],{"class":42},"npx sequelize ",[36,91,93],{"class":92},"s_sBn","db",[36,95,96],{"class":42},":migrate ",[36,98,47],{"class":46},[36,100,101],{"class":42},"env test\n",[16,103,104],{},"但是請記得務必修改 config.json 的資料庫帳號、密碼及資料庫 IP",[16,106,107],{},[67,108],{"alt":109,"src":110},"config.js","https:\u002F\u002Fi.imgur.com\u002FqTnIZYx.png",[16,112,113],{},"否則會出現這種狀況",[16,115,116],{},[67,117],{"alt":118,"src":119},"ERROR: Access denied for user 'root'@'localhost'","https:\u002F\u002Fi.imgur.com\u002FmRutjzX.png",[16,121,122],{},"若是沒問題的話基本上就會出現這個畫面",[16,124,125],{},[67,126],{"alt":127,"src":128},"No migrations","https:\u002F\u002Fi.imgur.com\u002FIMEB6er.png",[16,130,131],{},"那是因為我們還沒準備好要新增資料到資料庫中",[12,133,134],{"id":134},"新增資料模型",[16,136,137],{},"通常我們是將新增資料表、資料欄位稱之為模型，也就是一個 models (M)，那該如何建立資料模型呢?",[16,139,140],{},"我們先在 CMD 中輸入以下指令看看吧",[26,142,146],{"className":143,"code":144,"language":145,"meta":31,"style":31},"language-cmd shiki shiki-themes github-dark-high-contrast","npx sequelize-cli model:generate --name User --attributes firstName:string,lastName:string,email:string\n","cmd",[33,147,148],{"__ignoreMap":31},[36,149,150],{"class":38,"line":39},[36,151,144],{},[16,153,154],{},"跑完之後你可以看到你的資料夾中 models 以及 migrations 多了這些檔案",[16,156,157],{},[67,158],{"alt":159,"src":160},"模組化","https:\u002F\u002Fi.imgur.com\u002FynL1Grn.png",[16,162,163],{},"而這些就是資料庫的模組，我們可以打開 models\u002Fuser.js 看看",[16,165,166],{},[67,167],{"alt":159,"src":168},"https:\u002F\u002Fi.imgur.com\u002F3rgEa3q.png",[16,170,171,172,175],{},"而這些就是我們資料庫的模組化兼欄位，而 migrations 中文叫遷移，也就是準備加入資料庫中類似一個暫存的地方，所以我們可以試著輸入 ",[33,173,174],{},"npx sequelize-cli db:migrate --env test"," 來執行遷移看看",[16,177,178],{},[67,179],{"alt":180,"src":181},"migrations","https:\u002F\u002Fi.imgur.com\u002FEpcdouL.png",[16,183,184],{},"執行完之後我們可以打開 Navicat 來看資料庫，你會發現多了兩個資料表，分別為 sequelizemeta 以及我們剛剛建立的資料 Models User",[16,186,187],{},[67,188],{"alt":189,"src":190},"Navicat","https:\u002F\u002Fi.imgur.com\u002Fyf0M7Fn.png",[16,192,193],{},"sequelizemeta 資料表會記錄你遷移過的檔案，避免重複遷移",[16,195,196],{},[67,197],{"alt":198,"src":199},"sequelizemeta","https:\u002F\u002Fi.imgur.com\u002FwslJR8S.png",[16,201,202],{},"而 User 就是我們剛剛建立的資料表啦~",[16,204,205],{},[67,206],{"alt":207,"src":208},"User","https:\u002F\u002Fi.imgur.com\u002FD3wBFlh.png",[12,210,211],{"id":211},"參考文獻",[16,213,214],{},[215,216,220],"a",{"href":217,"rel":218},"http:\u002F\u002Fdocs.sequelizejs.com\u002Fmanual\u002Fmigrations.html",[219],"nofollow","Migrations",[222,223,224],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}",{"title":31,"searchDepth":226,"depth":226,"links":227},2,[228,229,230,231],{"id":14,"depth":226,"text":14},{"id":21,"depth":226,"text":21},{"id":134,"depth":226,"text":134},{"id":211,"depth":226,"text":211},"Nodejs","2019-07-18 13:50:28","md","zh-Hant",{},true,"\u002Fkoa\u002Fkoa-mysql-sequelize-2","2",{"title":6,"description":18},false,"這是在講關於一名叫 Koa 的全端勇士