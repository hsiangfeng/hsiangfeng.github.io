[{"data":1,"prerenderedAt":302},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190701\u002F3784687574\u002F":3,"page:\u002Fnodejs\u002F20190701\u002F3784687574\u002F":4,"alt:\u002Fnodejs\u002F20190701\u002F3784687574\u002F":3,"prev-next:\u002Fnodejs\u002F20190701\u002F3784687574\u002F":278,"related:\u002Fnodejs\u002F20190701\u002F3784687574\u002F":287},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F01\u002Fnodejs-express-generator\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":261,"date":262,"description":18,"extension":263,"lang":264,"meta":265,"navigation":266,"path":267,"readingMinutes":268,"seo":269,"standalone":270,"stem":271,"tags":272,"tldr":275,"updated":275,"url":276,"__hash__":277},"content\u002F全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-Express-應用產生器.md","全端勇士之路 Node.js 基礎學習-Express 應用產生器","3784687574",{"type":9,"value":10,"toc":252},"minimark",[11,15,19,22,29,60,63,66,73,80,83,89,94,97,101,115,122,129,135,138,141,172,176,187,190,196,207,212,215,221,226,229,235,238,248],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"基礎 Express 學習的差不多了，但是到這邊一定會很納悶，難道每次寫 Express 都要這樣子一個一個設置?其實不用，這邊要來講一個超好用的東西，也就是 Express 應用產生器",[12,20,21],{"id":21},"起手式",[16,23,24,25],{},"使用之前必須先安裝一個套件叫做 ",[26,27,28],"code",{},"express-generator",[30,31,36],"pre",{"className":32,"code":33,"language":34,"meta":35,"style":35},"language-js shiki shiki-themes github-dark-high-contrast","npm install --g express-generator\n","js","",[26,37,38],{"__ignoreMap":35},[39,40,43,47,51,54,57],"span",{"class":41,"line":42},"line",1,[39,44,46],{"class":45},"sMAXC","npm install ",[39,48,50],{"class":49},"sWyjQ","--",[39,52,53],{"class":45},"g express",[39,55,56],{"class":49},"-",[39,58,59],{"class":45},"generator\n",[16,61,62],{},"(注意，這一定要在全域下安裝)",[12,64,65],{"id":65},"使用方式",[16,67,68,69,72],{},"首先先開啟一個 project 空資料夾，並且開啟 CMD 進入該目錄，接下來在指令模式下輸入 ",[26,70,71],{},"express --view=ejs","，此時你會發現一個很神奇的事情發生了",[16,74,75],{},[76,77],"img",{"alt":78,"src":79},"所有 Express 已經產生","https:\u002F\u002Fi.imgur.com\u002FpwK8YrV.png",[16,81,82],{},"你可能會說為什麼不一開始就講這個超好用的東西，那是因為如果直接接觸 express-generator 那麼有可能你會看不懂裡面的東西。",[16,84,85,86],{},"那麼讓我們來看一下它生成了哪些東西，先來看看 ",[26,87,88],{},"app.js",[16,90,91],{},[76,92],{"alt":88,"src":93},"https:\u002F\u002Fi.imgur.com\u002FtGDugOO.png",[16,95,96],{},"你會發現有 6 ~ 7 成，你都看得懂了，這邊就不再多說，route 部分與前面撰寫一樣。",[12,98,100],{"id":99},"express-generator-指令","express-generator 指令",[16,102,103,104,107,108,111,112],{},"現在回頭來講講剛剛輸入的指令是什麼意思，首先 ",[26,105,106],{},"express"," 就是要建立應用程式，那 ",[26,109,110],{},"--view=ejs"," 的意思是說要使用 ejs Template，如果要改用 pug 的話，就改打 ",[26,113,114],{},"--view=pug",[16,116,117,118,121],{},"另外也可以改用 SCSS 來開發前端頁面，只需要補上 ",[26,119,120],{},"--css=sass"," 就可以哩，但是有一個地方記得修改，否則無法讀取 SCSS 檔案唷~",[16,123,124,125,128],{},"在 app.js 中將箭頭所指處改成 ",[26,126,127],{},"false"," 即可",[16,130,131],{},[76,132],{"alt":133,"src":134},"SCSS","https:\u002F\u002Fi.imgur.com\u002F9GkCR9c.png",[16,136,137],{},"ejs + SCSS 完整指令",[16,139,140],{},"完整指令",[30,142,144],{"className":32,"code":143,"language":34,"meta":35,"style":35},"express --view=ejs --css=sass\n",[26,145,146],{"__ignoreMap":35},[39,147,148,151,153,156,159,162,164,167,169],{"class":41,"line":42},[39,149,150],{"class":45},"express ",[39,152,50],{"class":49},[39,154,155],{"class":45},"view",[39,157,158],{"class":49},"=",[39,160,161],{"class":45},"ejs ",[39,163,50],{"class":49},[39,165,166],{"class":45},"css",[39,168,158],{"class":49},[39,170,171],{"class":45},"sass\n",[12,173,175],{"id":174},"啟動-express","啟動 Express",[16,177,178,179,182,183,186],{},"記得在使用之前記得先輸入 ",[26,180,181],{},"npm install","，輸入完畢之後就可以打 ",[26,184,185],{},"npm start"," 即可以啟動瀏覽器哩",[16,188,189],{},"(通常預設 port 是 3000)",[16,191,192],{},[76,193],{"alt":194,"src":195},"localhost:3000","https:\u002F\u002Fi.imgur.com\u002Fg3Tuljp.png",[16,197,198,199,202,203,206],{},"那它就會自動使用 ",[26,200,201],{},"node app.js","，如果想要改成 ",[26,204,205],{},"nodemon app.js"," 的話只需要打開 package.json 修改 scripts 中的 start 即可",[16,208,209],{},[76,210],{"alt":201,"src":211},"https:\u002F\u002Fi.imgur.com\u002FavI7gqA.png",[16,213,214],{},"(部屬的時候不要使用 nodemon 絕對會出事情)",[16,216,217,218],{},"如果想要調整 port 的話，則是打開 ",[26,219,220],{},"\u002Fbin\u002Fwww",[16,222,223],{},[76,224],{"alt":220,"src":225},"https:\u002F\u002Fi.imgur.com\u002FZngQWZW.png",[16,227,228],{},"然後調整紅色箭頭所指之處即可",[16,230,231],{},[76,232],{"alt":233,"src":234},"port 修改","https:\u002F\u002Fi.imgur.com\u002FfxwW8He.png",[12,236,237],{"id":237},"補充",[16,239,240,241],{},"最後附上 express-generator 的",[242,243,247],"a",{"href":244,"rel":245},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fexpress-generator",[246],"nofollow","官方文件",[249,250,251],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":35,"searchDepth":253,"depth":253,"links":254},2,[255,256,257,258,259,260],{"id":14,"depth":253,"text":14},{"id":21,"depth":253,"text":21},{"id":65,"depth":253,"text":65},{"id":99,"depth":253,"text":100},{"id":174,"depth":253,"text":175},{"id":237,"depth":253,"text":237},"Nodejs","2019-07-01 20:06:42","md","zh-Hant",{},true,"\u002Fnode.js\u002Fnode-js-express","2",{"title":6,"description":18},false,"全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-Express-應用產生器",[273,274],"Node.js","全端勇士之路 Node.js",null,"\u002Fnodejs\u002F20190701\u002F3784687574\u002F","IanH7kAYLo6SdCpvhZg5TgEDXNofJ3P8tIY503UKMEA",{"newer":279,"older":283},{"url":280,"title":281,"date":282},"\u002Fnodejs\u002F20190702\u002F3749489780\u002F","全端勇士之路 Node.js 基礎學習