[{"data":1,"prerenderedAt":1067},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20220216\u002F326471867\u002F":3,"page:\u002Fnodejs\u002F20220216\u002F326471867\u002F":4,"alt:\u002Fnodejs\u002F20220216\u002F326471867\u002F":3,"prev-next:\u002Fnodejs\u002F20220216\u002F326471867\u002F":1042,"related:\u002Fnodejs\u002F20220216\u002F326471867\u002F":1051},"\u002Fen\u002Fnodejs\u002F2022\u002F02\u002F16\u002Fforced-to-eat-mango-frontend-04-mongodb-crud-read\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1025,"date":1026,"description":18,"extension":1027,"lang":1028,"meta":1029,"navigation":687,"path":1030,"readingMinutes":1031,"seo":1032,"standalone":1033,"stem":1034,"tags":1035,"tldr":1039,"updated":1039,"url":1040,"__hash__":1041},"content\u002F被迫吃芒果的前端工程師\u002F4-被迫吃芒果的前端工程師-MongoDB-CRUD-之-Read.md","(4)被迫吃芒果的前端工程師 - MongoDB CRUD 之 Read","326471867",{"type":9,"value":10,"toc":1012},"minimark",[11,15,19,23,31,36,43,50,60,66,72,75,80,87,127,133,143,146,149,613,616,622,625,631,634,639,650,655,658,708,714,720,724,729,748,754,758,764,781,787,800,818,824,828,837,840,858,864,868,876,894,900,903,907,913,936,942,966,971,975,980,1003,1008],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面我們已經新增了許多資料到 MongoDB 中，但我們要怎麼知道我們資料真的有新增進去呢？所以接下來我們要學習查詢的語法。",[12,20,22],{"id":21},"read","Read",[16,24,25,26,30],{},"雖然是寫著 Read (讀取)，但本質上來講比較偏向搜尋(Query)的概念，在 MongoDB 的世界中，最基本的搜尋語法是 ",[27,28,29],"code",{},"db.collection.find()","。",[16,32,33,35],{},[27,34,29],{}," 隨著你傳入的內容來決定要搜尋的結果，如果你什麼都不帶入的話，就會直接列出全部的東西",[16,37,38],{},[39,40],"img",{"alt":41,"src":42},"find","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2000.05.46.png",[16,44,45,46,49],{},"有趣的是，如果你是輸入 ",[27,47,48],{},"db.users.find({})"," 也是會回傳全部資料。",[16,51,52,53,56,57,30],{},"對應到 SQL 語法的話 ",[27,54,55],{},"db.users.find()"," 則類似於 ",[27,58,59],{},"SELECT * FROM users",[16,61,62,63],{},"如果想要指定特定屬性的搜尋的話，則是傳入一個屬性與值，舉例來講我要搜尋年齡 28 歲的使用者，那就要這樣寫 ",[27,64,65],{},"db.users.find({ age: 28 })",[16,67,68],{},[39,69],{"alt":70,"src":71},"指定搜尋","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2000.50.13.png",[16,73,74],{},"這種搜尋方式要注意一件事情，如果有多筆相同的結果，那就會全部回傳，例如搜尋年齡 25 人就會全部出現",[16,76,77],{},[39,78],{"alt":70,"src":79},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-23%2000.51.55.png",[16,81,82,83,86],{},"而這種搜尋方式就跟使用 ",[27,84,85],{},"WHERE"," 是相同的",[88,89,94],"pre",{"className":90,"code":91,"language":92,"meta":93,"style":93},"language-sql shiki shiki-themes github-dark-high-contrast","SELECT * FROM users WHERE age = \"28\"\n","sql","",[27,95,96],{"__ignoreMap":93},[97,98,101,105,108,111,115,117,120,123],"span",{"class":99,"line":100},"line",1,[97,102,104],{"class":103},"sWyjQ","SELECT",[97,106,107],{"class":103}," *",[97,109,110],{"class":103}," FROM",[97,112,114],{"class":113},"sMAXC"," users ",[97,116,85],{"class":103},[97,118,119],{"class":113}," age ",[97,121,122],{"class":103},"=",[97,124,126],{"class":125},"sTRMh"," \"28\"\n",[16,128,129,130,30],{},"當然也可以帶入多個欄位條件 ",[27,131,132],{},"db.users.find({ age: 25, name: 'Roy' })",[16,134,135,136,139,140],{},"如果是只想回傳符合條件的第一筆的話，則是使用 ",[27,137,138],{},"findOne","，例如：",[27,141,142],{},"db.users.findOne({ age: 25, name: 'Roy' })",[12,144,145],{"id":145},"條件式查詢",[16,147,148],{},"那麼真實在使用資料庫上只會使用單一欄位查詢這種方式嗎？當然不可能，那為了方面稍後的練習，因此建議你輸入以下程式碼注入一些資料，以便稍後的練習",[88,150,154],{"className":151,"code":152,"language":153,"meta":93,"style":93},"language-js shiki shiki-themes github-dark-high-contrast","db.users.insertMany([\n  {\n    \"name\": \"Clayton Jimenez\",\n    \"age\": 15,\n    \"status\": false\n  },\n  {\n    \"name\": \"Annie Barrett\",\n    \"age\": 38,\n    \"status\": true\n  },\n  {\n    \"name\": \"Monica Hale\",\n    \"age\": 56,\n    \"status\": true\n  },\n  {\n    \"name\": \"Monica Curtis\",\n    \"age\": 35,\n    \"status\": true\n  },\n  {\n    \"name\": \"Sarah Rodriquez