,[219,1449,431],{"class":337},[219,1451,434],{"class":229},[219,1453,437],{"class":337},[219,1455,434],{"class":229},[219,1457,442],{"class":337},[219,1459,445],{"class":229},[219,1461,366],{"class":337},[219,1463,1464],{"class":221,"line":561},[219,1465,453],{"class":337},[219,1467,1468],{"class":221,"line":566},[219,1469,391],{"emptyLinePlaceholder":390},[219,1471,1472,1474,1476,1478,1480,1482,1484,1486,1488],{"class":221,"line":571},[219,1473,397],{"class":337},[219,1475,400],{"class":356},[219,1477,360],{"class":337},[219,1479,835],{"class":229},[219,1481,344],{"class":337},[219,1483,475],{"class":333},[219,1485,842],{"class":478},[219,1487,482],{"class":333},[219,1489,414],{"class":337},[219,1491,1492,1494,1496,1498,1500],{"class":221,"line":863},[219,1493,420],{"class":337},[219,1495,423],{"class":356},[219,1497,360],{"class":337},[219,1499,857],{"class":229},[219,1501,860],{"class":337},[219,1503,1504,1506,1509,1511,1514],{"class":221,"line":868},[219,1505,490],{"class":333},[219,1507,1508],{"class":337}," (message.author.bot) ",[219,1510,508],{"class":333},[219,1512,1513],{"class":337},"; ",[219,1515,1516],{"class":1155},"\u002F\u002F 避免機器人互相回覆\n",[219,1518,1519,1522,1525,1527,1529,1531],{"class":221,"line":873},[219,1520,1521],{"class":333},"  const",[219,1523,1524],{"class":236}," response",[219,1526,376],{"class":333},[219,1528,1077],{"class":333},[219,1530,1046],{"class":356},[219,1532,1533],{"class":337},"(message.content);\n",[219,1535,1536,1539,1541],{"class":221,"line":1140},[219,1537,1538],{"class":337},"  message.",[219,1540,545],{"class":356},[219,1542,1543],{"class":337},"(response);\n",[219,1545,1546],{"class":221,"line":1159},[219,1547,453],{"class":337},[219,1549,1550],{"class":221,"line":1171},[219,1551,391],{"emptyLinePlaceholder":390},[219,1553,1554,1556,1558,1560,1562],{"class":221,"line":1177},[219,1555,397],{"class":337},[219,1557,576],{"class":356},[219,1559,880],{"class":337},[219,1561,883],{"class":236},[219,1563,366],{"class":337},[16,1565,1566,1567,1570],{},"那麼這邊比較需要這邊多了一個新語法，也就是 ",[158,1568,1569],{},"message.reply(response);","，這個語法簡單來講就是針對使用者的訊息去「回覆」，接著你就可以試著在 Discord 中輸入一些訊息，然後你就會發現你的 Discord Bot 已經會回覆你一些訊息，而這些訊息就是 OpenAI 所回傳的訊息唷！",[16,1572,1573],{},[83,1574],{"alt":1575,"src":1576},"JOJO","https:\u002F\u002Fi.imgur.com\u002F3dJOApu.png",[16,1578,1579],{},[83,1580],{"alt":1575,"src":1581},"https:\u002F\u002Fi.imgur.com\u002F2V0pEpu.png",[12,1583,1585],{"id":1584},"讓你的-discord-bot-更聰明吧","讓你的 Discord Bot 更聰明吧",[16,1587,1588],{},"到目前為止，其實我們已經完成了一個串接 OpenAI 的 Discord 聊天機器人，但是這個聊天機器人還是有一些缺點...",[48,1590,1591,1594],{},[51,1592,1593],{},"好像有點笨",[51,1595,1596],{},"無法前後文理解",[16,1598,1599],{},"那麼要解決這個問題的核心重點在於，要將先前的訊息(包含機器人回你的部分)在每次使用者發送訊息後疊加發送給 OpenAI，這樣 OpenAI 才能夠理解使用者的上下文。",[16,1601,1602,1603,1608],{},"但是這一段其實有一個很大的問題存在，也就是 OpenAI 的計算方式是一個字代表一個 Token，因此疊加上去是非常可怕的，詳情可以參考",[33,1604,1607],{"href":1605,"rel":1606},"https:\u002F\u002Fjcyh.work\u002Fchatgpt-integration-with-linebot\u002F",[77],"這位","大大的分享，我就不多述了。",[16,1610,1611],{},"所以如果你還是期望你的 Discord Bot 能夠更聰明的話，這邊我提供幾個思路方向，第一種方式就是利用 Discord 的 Forum 論壇就可以解決這個問題",[16,1613,1614],{},[83,1615],{"alt":1616,"src":1617},"Forum","https:\u002F\u002Fi.imgur.com\u002FjQ4swB2.png",[16,1619,1620],{},"因為論壇就是以一個貼文作為一個主題貼文來集中討論，因此就可以針對該主題的內容撈全部上下文，接著就可以疊加送給 OpenAI 分析，這樣就可以解決上下文的問題，而且我們也可以去限制一則貼文內的總字數，進而限制 OpenAI 的計算量，這樣就可以避免 OpenAI 的計算量太大的問題發生。",[16,1622,1623],{},"但是 Discord 的 Forum 論壇我印象是必須為「社群」模式才能夠擁有的，因此另一種做法就是只撈特定數量的訊息，例如只撈前 10 筆訊息，只要超過就直接重新計算，這樣也可以解決上下文的問題。",[16,1625,1626],{},"只是我自己認為還是沒有 Forum 論壇模式的好就是了 xD",[12,1628,1629],{"id":1629},"範例程式碼",[16,1631,1632],{},"最後這邊，我也提供一下我自己做的範例程式碼，你可以參考這一篇文章建立 Discord，然後搭配我提供的程式碼去建立屬於你自己的 Discord 聊天機器人唷。",[16,1634,1635,1636],{},"GitHub：",[33,1637,1638],{"href":1638,"rel":1639},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione",[77],[12,1641,1642],{"id":1642},"後續更新",[16,1644,1645],{},"由於 OpenAI 後來放了 ChatGPT 的 API，所以範例程式碼我也有做了一下，你可以直接觀看以下 Commit 的程式碼來了解如果要從 GPT-3 轉換到 GPT-3.5 要改哪些唷~",[48,1647,1648,1655,1662],{},[51,1649,1650],{},[33,1651,1654],{"href":1652,"rel":1653},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002Fccb78b0f5f5b42eb366e5f85f50612a5f31842be",[77],"轉換改用 createChatCompletion 方法",[51,1656,1657],{},[33,1658,1661],{"href":1659,"rel":1660},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002F2a701f7c4335850b9ace40c1511900c7c80aabb7",[77],"論壇寫法調整",[51,1663,1664],{},[33,1665,1668],{"href":1666,"rel":1667},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002F3957938f69e548d0a5ecb03534685861d41cbf19",[77],"文字串寫法調整",[16,1670,1671],{},"除此之外我也有開出分支區分兩個版本，所以你可以直接切換到不同的分支來了解不同版本的程式碼唷~",[12,1673,1674],{"id":1674},"重要事項",[16,1676,1677],{},"本篇並沒有免費提供 OpenAI 的 API Key 或是 Discord Token 給你使用，所以你必須自行申請，這邊僅是提供一個串接範例，所以在使用時，請務必申請以下兩者",[48,1679,1680,1687],{},[51,1681,1682,1683],{},"OpenAI API Key：",[33,1684,1685],{"href":1685,"rel":1686},"https:\u002F\u002Fplatform.openai.com\u002F",[77],[51,1688,1689,1690],{},"Discord Token：",[33,1691,75],{"href":75,"rel":1692},[77],[16,1694,1695,1696,1701],{},"OpenAI Key 的申請教學可以參考：「",[33,1697,1700],{"href":1698,"rel":1699},"https:\u002F\u002Fisraynotarray.com\u002F\u002Fodejs\u002F20221210\u002F1224824056\u002F#%E7%94%B3%E8%AB%8B-OpenAI-API",[77],"申請 OpenAI API","」章節",[16,1703,1704,1705,1708,1709,1712],{},"本專案範例是採用 Env 環境變數掛入的，如果你確實申請了相關 Token 與 Key，但使用時依然出現「",[158,1706,1707],{},"RequestAbortedError [AbortError]: Request aborted","、",[158,1710,1711],{},"對不起，我發生 401 - Unauthorized 錯誤，所以沒有辦法回覆你。","」，代表你的 Key 或是 Token 有問題，請務必確認你的 Env 是否填寫正確，除此之外專案的執行方式是採用 Node.js，所以你必須要先安裝 Node.js 才能夠執行唷。",[16,1714,1715,1716],{},"最後這邊也提供關於 Env 的教學：",[33,1717,1720],{"href":1718,"rel":1719},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20230218\u002F3618693250\u002F",[77],"什麼是 Env 以及什麼時候該用 Env？",[1722,1723,1724],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--sh