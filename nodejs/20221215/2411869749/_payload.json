1355,1357,1359,1361],{"class":223,"line":244},[221,1342,336],{"class":335},[221,1344,340],{"class":339},[221,1346,343],{"class":238},[221,1348,346],{"class":339},[221,1350,349],{"class":238},[221,1352,352],{"class":339},[221,1354,355],{"class":335},[221,1356,359],{"class":358},[221,1358,362],{"class":339},[221,1360,365],{"class":231},[221,1362,368],{"class":339},[221,1364,1365,1367,1369,1372,1374,1376,1378,1380,1383],{"class":223,"line":396},[221,1366,336],{"class":335},[221,1368,340],{"class":339},[221,1370,1371],{"class":238},"openAiMessage",[221,1373,352],{"class":339},[221,1375,355],{"class":335},[221,1377,359],{"class":358},[221,1379,362],{"class":339},[221,1381,1382],{"class":231},"'.\u002Fservices\u002Fopenai'",[221,1384,368],{"class":339},[221,1386,1387],{"class":223,"line":419},[221,1388,393],{"emptyLinePlaceholder":392},[221,1390,1391,1393,1395,1397,1399,1401],{"class":223,"line":452},[221,1392,336],{"class":335},[221,1394,375],{"class":238},[221,1396,378],{"class":335},[221,1398,381],{"class":335},[221,1400,384],{"class":358},[221,1402,753],{"class":339},[221,1404,1405],{"class":223,"line":458},[221,1406,758],{"class":339},[221,1408,1409],{"class":223,"line":463},[221,1410,763],{"class":339},[221,1412,1413],{"class":223,"line":488},[221,1414,768],{"class":339},[221,1416,1417],{"class":223,"line":515},[221,1418,773],{"class":339},[221,1420,1421],{"class":223,"line":520},[221,1422,393],{"emptyLinePlaceholder":392},[221,1424,1425,1427,1429,1431,1433,1435,1437],{"class":223,"line":537},[221,1426,399],{"class":339},[221,1428,402],{"class":358},[221,1430,362],{"class":339},[221,1432,407],{"class":231},[221,1434,410],{"class":339},[221,1436,413],{"class":335},[221,1438,416],{"class":339},[221,1440,1441,1443,1445,1447,1449,1451,1453,1455,1457,1459,1461],{"class":223,"line":556},[221,1442,422],{"class":339},[221,1444,425],{"class":358},[221,1446,362],{"class":339},[221,1448,430],{"class":231},[221,1450,433],{"class":339},[221,1452,436],{"class":231},[221,1454,439],{"class":339},[221,1456,436],{"class":231},[221,1458,444],{"class":339},[221,1460,447],{"class":231},[221,1462,368],{"class":339},[221,1464,1465],{"class":223,"line":562},[221,1466,455],{"class":339},[221,1468,1469],{"class":223,"line":567},[221,1470,393],{"emptyLinePlaceholder":392},[221,1472,1473,1475,1477,1479,1481,1483,1485,1487,1489],{"class":223,"line":572},[221,1474,399],{"class":339},[221,1476,402],{"class":358},[221,1478,362],{"class":339},[221,1480,836],{"class":231},[221,1482,346],{"class":339},[221,1484,477],{"class":335},[221,1486,843],{"class":227},[221,1488,483],{"class":335},[221,1490,416],{"class":339},[221,1492,1493,1495,1497,1499,1501],{"class":223,"line":864},[221,1494,422],{"class":339},[221,1496,425],{"class":358},[221,1498,362],{"class":339},[221,1500,858],{"class":231},[221,1502,861],{"class":339},[221,1504,1505,1507,1510,1512,1515],{"class":223,"line":869},[221,1506,491],{"class":335},[221,1508,1509],{"class":339}," (message.author.bot) ",[221,1511,509],{"class":335},[221,1513,1514],{"class":339},"; ",[221,1516,1517],{"class":1156},"\u002F\u002F 避免機器人互相回覆\n",[221,1519,1520,1523,1526,1528,1530,1532],{"class":223,"line":874},[221,1521,1522],{"class":335},"  const",[221,1524,1525],{"class":238}," response",[221,1527,378],{"class":335},[221,1529,1078],{"class":335},[221,1531,1047],{"class":358},[221,1533,1534],{"class":339},"(message.content);\n",[221,1536,1537,1540,1542],{"class":223,"line":1141},[221,1538,1539],{"class":339},"  message.",[221,1541,546],{"class":358},[221,1543,1544],{"class":339},"(response);\n",[221,1546,1547],{"class":223,"line":1160},[221,1548,455],{"class":339},[221,1550,1551],{"class":223,"line":1172},[221,1552,393],{"emptyLinePlaceholder":392},[221,1554,1555,1557,1559,1561,1563],{"class":223,"line":1178},[221,1556,399],{"class":339},[221,1558,577],{"class":358},[221,1560,881],{"class":339},[221,1562,884],{"class":238},[221,1564,368],{"class":339},[16,1566,1567,1568,1571],{},"那麼這邊比較需要這邊多了一個新語法，也就是 ",[160,1569,1570],{},"message.reply(response);","，這個語法簡單來講就是針對使用者的訊息去「回覆」，接著你就可以試著在 Discord 中輸入一些訊息，然後你就會發現你的 Discord Bot 已經會回覆你一些訊息，而這些訊息就是 OpenAI 所回傳的訊息唷！",[16,1573,1574],{},[84,1575],{"alt":1576,"src":1577},"JOJO","https:\u002F\u002Fi.imgur.com\u002F3dJOApu.png",[16,1579,1580],{},[84,1581],{"alt":1576,"src":1582},"https:\u002F\u002Fi.imgur.com\u002F2V0pEpu.png",[12,1584,1586],{"id":1585},"讓你的-discord-bot-更聰明吧","讓你的 Discord Bot 更聰明吧",[16,1588,1589],{},"到目前為止，其實我們已經完成了一個串接 OpenAI 的 Discord 聊天機器人，但是這個聊天機器人還是有一些缺點...",[49,1591,1592,1595],{},[52,1593,1594],{},"好像有點笨",[52,1596,1597],{},"無法前後文理解",[16,1599,1600],{},"那麼要解決這個問題的核心重點在於，要將先前的訊息(包含機器人回你的部分)在每次使用者發送訊息後疊加發送給 OpenAI，這樣 OpenAI 才能夠理解使用者的上下文。",[16,1602,1603,1604,1609],{},"但是這一段其實有一個很大的問題存在，也就是 OpenAI 的計算方式是一個字代表一個 Token，因此疊加上去是非常可怕的，詳情可以參考",[34,1605,1608],{"href":1606,"rel":1607},"https:\u002F\u002Fjcyh.work\u002Fchatgpt-integration-with-linebot\u002F",[78],"這位","大大的分享，我就不多述了。",[16,1611,1612],{},"所以如果你還是期望你的 Discord Bot 能夠更聰明的話，這邊我提供幾個思路方向，第一種方式就是利用 Discord 的 Forum 論壇就可以解決這個問題",[16,1614,1615],{},[84,1616],{"alt":1617,"src":1618},"Forum","https:\u002F\u002Fi.imgur.com\u002FjQ4swB2.png",[16,1620,1621],{},"因為論壇就是以一個貼文作為一個主題貼文來集中討論，因此就可以針對該主題的內容撈全部上下文，接著就可以疊加送給 OpenAI 分析，這樣就可以解決上下文的問題，而且我們也可以去限制一則貼文內的總字數，進而限制 OpenAI 的計算量，這樣就可以避免 OpenAI 的計算量太大的問題發生。",[16,1623,1624],{},"但是 Discord 的 Forum 論壇我印象是必須為「社群」模式才能夠擁有的，因此另一種做法就是只撈特定數量的訊息，例如只撈前 10 筆訊息，只要超過就直接重新計算，這樣也可以解決上下文的問題。",[16,1626,1627],{},"只是我自己認為還是沒有 Forum 論壇模式的好就是了 xD",[12,1629,1630],{"id":1630},"範例程式碼",[16,1632,1633],{},"最後這邊，我也提供一下我自己做的範例程式碼，你可以參考這一篇文章建立 Discord，然後搭配我提供的程式碼去建立屬於你自己的 Discord 聊天機器人唷。",[16,1635,1636,1637],{},"GitHub：",[34,1638,1639],{"href":1639,"rel":1640},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione",[78],[12,1642,1643],{"id":1643},"後續更新",[16,1645,1646],{},"由於 OpenAI 後來放了 ChatGPT 的 API，所以範例程式碼我也有做了一下，你可以直接觀看以下 Commit 的程式碼來了解如果要從 GPT-3 轉換到 GPT-3.5 要改哪些唷~",[49,1648,1649,1656,1663],{},[52,1650,1651],{},[34,1652,1655],{"href":1653,"rel":1654},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002Fccb78b0f5f5b42eb366e5f85f50612a5f31842be",[78],"轉換改用 createChatCompletion 方法",[52,1657,1658],{},[34,1659,1662],{"href":1660,"rel":1661},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002F2a701f7c4335850b9ace40c1511900c7c80aabb7",[78],"論壇寫法調整",[52,1664,1665],{},[34,1666,1669],{"href":1667,"rel":1668},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione\u002Fcommit\u002F3957938f69e548d0a5ecb03534685861d41cbf19",[78],"文字串寫法調整",[16,1671,1672],{},"除此之外我也有開出分支區分兩個版本，所以你可以直接切換到不同的分支來了解不同版本的程式碼唷~",[12,1674,1675],{"id":1675},"重要事項",[16,1677,1678],{},"本篇並沒有免費提供 OpenAI 的 API Key 或是 Discord Token 給你使用，所以你必須自行申請，這邊僅是提供一個串接範例，所以在使用時，請務必申請以下兩者",[49,1680,1681,1688],{},[52,1682,1683,1684],{},"OpenAI API Key：",[34,1685,1686],{"href":1686,"rel":1687},"https:\u002F\u002Fplatform.openai.com\u002F",[78],[52,1689,1690,1691],{},"Discord Token：",[34,1692,76],{"href":76,"rel":1693},[78],[16,1695,1696,1697,1702],{},"OpenAI Key 的申請教學可以參考：「",[34,1698,1701],{"href":1699,"rel":1700},"https:\u002F\u002Fisraynotarray.com\u002F\u002Fodejs\u002F20221210\u002F1224824056\u002F#%E7%94%B3%E8%AB%8B-OpenAI-API",[78],"申請 OpenAI API","」章節",[16,1704,1705,1706,1709,1710,1713],{},"本專案範例是採用 Env 環境變數掛入的，如果你確實申請了相關 Token 與 Key，但使用時依然出現「",[160,1707,1708],{},"RequestAbortedError [AbortError]: Request aborted","、",[160,1711,1712],{},"對不起，我發生 401 - Unauthorized 錯誤，所以沒有辦法回覆你。","」，代表你的 Key 或是 Token 有問題，請務必確認你的 Env 是否填寫正確，除此之外專案的執行方式是採用 Node.js，所以你必須要先安裝 Node.js 才能夠執行唷。",[16,1715,1716,1717],{},"最後這邊也提供關於 Env 的教學：",[34,1718,1721],{"href":1719,"rel":1720},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20230218\u002F3618693250\u002F",[78],"什麼是 Env 以及什麼時候該用 Env？",[1723,1724,1725],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki 