.. })","，這邊的 ",[160,627,628],{},"Event"," 就是我們要監聽的事件，例如前面的 ",[160,631,632],{},"ready"," 就代表著我們要監聽機器人啟動的事件。",[16,635,636],{},"當然 Discord 的事件非常的多，比較常見的事件有：",[49,638,639,644,650],{},[52,640,641,643],{},[160,642,632],{},"：當機器人啟動時觸發",[52,645,646,649],{},[160,647,648],{},"interactionCreate","：當使用者呼叫機器人的指令時觸發",[52,651,652,655],{},[160,653,654],{},"messageCreate","：當使用者發送訊息時觸發",[16,657,658,659,661,662,664,665,625,668,670,671,674,675,678,679,682],{},"這三個算是最常見的事件，只是我們這邊只會使用到 ",[160,660,632],{}," 跟 ",[160,663,654],{},"，然後還有一個地方必須調整，也就是 ",[160,666,667],{},"intents",[160,669,667],{}," 就是我們要決定我們的機器人要做什麼事情，而我們這邊會需要 ",[160,672,673],{},"GuildsMessages"," 與 ",[160,676,677],{},"MessageContent"," 這兩個權限，所以我們就先把官方的程式碼修改成以下並貼入到 ",[160,680,681],{},"index.js"," 中",[212,684,686],{"className":326,"code":685,"language":328,"meta":217,"style":217},"require('dotenv').config()\n\nconst { Client, GatewayIntentBits } = require('discord.js');\n\nconst client = new Client({ intents: [\n  GatewayIntentBits.Guilds,\n  GatewayIntentBits.GuildMessages,\n  GatewayIntentBits.MessageContent,\n]});\n\nclient.on('ready', () => {\n  console.log(`Logged in as ${client.user.tag}!`);\n});\n\nclient.on('messageCreate', async message => {\n  console.log('使用者發送的訊息：', message.content);\n});\n\nclient.login(process.env.DISCORD_TOKEN);\n",[160,687,688,707,711,735,739,754,759,764,769,774,778,794,818,822,826,848,862,867,872],{"__ignoreMap":217},[221,689,690,693,695,698,701,704],{"class":223,"line":224},[221,691,692],{"class":358},"require",[221,694,362],{"class":339},[221,696,697],{"class":231},"'dotenv'",[221,699,700],{"class":339},").",[221,702,703],{"class":358},"config",[221,705,706],{"class":339},"()\n",[221,708,709],{"class":223,"line":235},[221,710,393],{"emptyLinePlaceholder":392},[221,712,713,715,717,719,721,723,725,727,729,731,733],{"class":223,"line":244},[221,714,336],{"class":335},[221,716,340],{"class":339},[221,718,343],{"class":238},[221,720,346],{"class":339},[221,722,349],{"class":238},[221,724,352],{"c