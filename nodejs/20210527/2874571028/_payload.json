[{"data":1,"prerenderedAt":541},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20210527\u002F2874571028\u002F":3,"page:\u002Fnodejs\u002F20210527\u002F2874571028\u002F":4,"alt:\u002Fnodejs\u002F20210527\u002F2874571028\u002F":3,"prev-next:\u002Fnodejs\u002F20210527\u002F2874571028\u002F":516,"related:\u002Fnodejs\u002F20210527\u002F2874571028\u002F":525},"\u002Fen\u002Fnodejs\u002F2021\u002F05\u002F27\u002Fcsrf-xsrf-with-decoupled-frontend-backend\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":498,"date":499,"description":18,"extension":500,"lang":501,"meta":502,"navigation":318,"path":503,"readingMinutes":504,"seo":505,"standalone":506,"stem":507,"tags":508,"tldr":513,"updated":513,"url":514,"__hash__":515},"content\u002FNodejs\u002F前後端分離下的-CSRF-XSRF.md","前後端分離下的 CSRF\u002FXSRF","2874571028",{"type":9,"value":10,"toc":492},"minimark",[11,15,19,23,32,43,53,61,65,68,120,127,130,133,136,139,142,145,339,348,353,356,392,395,427,430,433,459,462,465,468,471,488],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"CSRF 雖然滿常見的，大多時候都可以解決，但是在完全前後分離下的處理方式又是另一回事。",[12,20,22],{"id":21},"csrf","CSRF",[16,24,25,26,31],{},"由於先前的文章 ",[27,28,30],"a",{"href":29},"\u002Fnodejs\u002F20190704\u002F2336420619\u002F","全端勇士之路 Node.js 基礎學習-CSRF 篇"," 已經有描述相關的例子，所以這邊就直接貼上先前的描述",[33,34,35],"blockquote",{},[16,36,37,38,42],{},"CSRF 簡單來講就是利用使用者瀏覽器對於網站的信任來達到攻擊，假設我們已經知道某某某 API 路徑，例如刪除帳號的API ",[39,40,41],"code",{},"https:\u002Fwww.example.com\u002Fdelete?id=XXX","，然後黑客就傳給你一個句話「快看!點這個網址可以取得一個比特幣」(屁)",[16,44,45,46,52],{},"因此其實在 ",[27,47,51],{"href":48,"rel":49},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002F%E8%B7%A8%E7%AB%99%E8%AF%B7%E6%B1%82%E4%BC%AA%E9%80%A0",[50],"nofollow","維基百科"," 上也有特別粗體黑字標示 CSRF 的重點觀念",[33,54,55],{},[16,56,57],{},[58,59,60],"strong",{},"這利用了web中使用者身分驗證的一個漏洞：簡單的身分驗證只能保證請求發自某個使用者的瀏覽器，卻不能保證請求本身是使用者自願發出的。",[12,62,64],{"id":63},"client-double-submit-cookie","Client Double Submit Cookie",[16,66,67],{},"在前面的文章中，就有描述到在沒有前後端分離的狀況下是如何處理 CSRF 的，基本上簡單來講就是透過 SSR 渲染畫面時，同時後端往前端丟一個 CSRF Token 的隨機字串，並儲存在畫面某個地方(通常是隱藏表單)，所以當你打開開發者工具時，是可以找到一個畫面看不到的隱藏 input 欄位的：",[69,70,75],"pre",{"className":71,"code":72,"language":73,"meta":74,"style":74},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cinput type=\"hidden\" name=\"_csrf\" value=\"BUMy6bl3-wtVBYgP9zA8xZLtFEP68mqNbQ-w\">\n","html","",[39,76,77],{"__ignoreMap":74},[78,79,82,86,90,94,97,101,104,106,109,112,114,117],"span",{"class":80,"line":81},"line",1,[78,83,85],{"class":84},"sMAXC","\u003C",[78,87,89],{"class":88},"sKpQp","input",[78,91,93],{"class":92},"sCcAr"," type",[78,95,96],{"class":84},"=",[78,98,100],{"class":99},"sTRMh","\"hidden\"",[78,102,103],{"class":92}," name",[78,105,96],{"class":84},[78,107,108],{"class":99},"\"_csrf\"",[78,110,111],{"class":92}," value",[78,113,96],{"class":84},[78,115,116],{"class":99},"\"BUMy6bl3-wtVBYgP9zA8xZLtFEP68mqNbQ-w\"",[78,118,119],{"class":84},">\n",[16,121,122],{},[123,124],"img",{"alt":125,"src":126},"JavaScript 直播班 API","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fother\u002F%E6%88%AA%E5%9C%96%202021-05-27%2011.04.02.png",[16,128,129],{},"透過這種方式後端則必須暫存一個 CSRF Token，當前端往後端送資料時，就會取出該欄位來做比對，值若相同時才會繼續往下動作(新增、編輯等行為)。",[16,131,132],{},"在上面所講的主要都是在「沒有完整的前後端分離」狀況下實作，這一段可能沒有什麼太大問題，但是在完整的前後端分離的狀況，那麼狀況就會完全不同，畢竟我們已經脫離了後端環境，因此前端的畫面就不是透過後端來渲染，那這樣子我們該如何取得 CSRF Token 呢？所以這邊這句話就是重點了",[16,134,135],{},"「透過瀏覽器來生成 CSRF Token」",[16,137,138],{},"這時候你可能會很疑惑，難道有 CORS 沒用嗎？或者開一個後端 API 來取得 CSRF Token 不就好了嗎？",[16,140,141],{},"可以試著思考一下，網路上的 CORS 都有可能被繞過的，畢竟 CORS 最多只能防禦 XMLHttpRequest，而若特別開一個 API 來取得 CSRF Token 也相當奇怪，不就代表著我如果可以繞過 CORS 那麼不就可以一直請求拿到 CSRF Token？",[16,143,144],{},"那麼回歸正題講講 Client 的 Double Submit Cookie，前面有講到會「透過瀏覽器來生成 CSRF Token」，那麼這一段可以怎麼做呢？舉例來講我們可以寫一個隨機字串產生器",[69,146,150],{"className":147,"code":148,"language":149,"meta":74,"style":74},"language-js shiki shiki-themes github-dark-high-contrast","function  generateRandomString (num) {\n  const characters ='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\n  let result1= ' ';\n  const charactersLength = characters.length;\n  for ( let i = 0; i \u003C num; i++ ) {\n      result1 += characters.charAt(Math.floor(Math.random() * charactersLength));\n  }\n  return result1;\n}\n\ndocument.cookie = `XSRF-TOKEN=${generateRandomString}`;\n","js",[39,151,152,172,190,206,224,258,292,298,307,313,320],{"__ignoreMap":74},[78,153,154,158,162,165,169],{"class":80,"line":81},[78,155,157],{"class":156},"sWyjQ","function",[78,159,161],{"class":160},"sj_SG","  generateRandomString",[78,163,164],{"class":84}," (",[78,166,168],{"class":167},"s_sBn","num",[78,170,171],{"class":84},") {\n",[78,173,175,178,181,184,187],{"class":80,"line":174},2,[78,176,177],{"class":156},"  const",[78,179,180],{"class":92}," characters",[78,182,183],{"class":156}," =",[78,185,186],{"class":99},"'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789'",[78,188,189],{"class":84},";\n",[78,191,193,196,199,201,204],{"class":80,"line":192},3,[78,194,195],{"class":156},"  let",[78,197,198],{"class":84}," result1",[78,200,96],{"class":156},[78,202,203],{"class":99}," ' '",[78,205,189],{"class":84},[78,207,209,211,214,216,219,222],{"class":80,"line":208},4,[78,210,177],{"class":156},[78,212,213],{"class":92}," charactersLength",[78,215,183],{"class":156},[78,217,218],{"class":84}," characters.",[78,220,221],{"class":92},"length",[78,223,189],{"class":84},[78,225,227,230,233,236,239,241,244,247,249,252,255],{"class":80,"line":226},5,[78,228,229],{"class":156},"  for",[78,231,232],{"class":84}," ( ",[78,234,235],{"class":156},"let",[78,237,238],{"class":84}," i ",[78,240,96],{"class":156},[78,242,243],{"class":92}," 0",[78,245,246],{"class":84},"; i ",[78,248,85],{"class":156},[78,250,251],{"class":84}," num; i",[78,253,254],{"class":156},"++",[78,256,257],{"class":84}," ) {\n",[78,259,261,264,267,269,272,275,278,280,283,286,289],{"class":80,"line":260},6,[78,262,263],{"class":84},"      result1 ",[78,265,266],{"class":156},"+=",[78,268,218],{"class":84},[78,270,271],{"class":160},"charAt",[78,273,274],{"class":84},"(Math.",[78,276,277],{"class":160},"floor",[78,279,274],{"class":84},[78,281,282],{"class":160},"random",[78,284,285],{"class":84},"() ",[78,287,288],{"class":156},"*",[78,290,291],{"class":84}," charactersLength));\n",[78,293,295],{"class":80,"line":294},7,[78,296,297],{"class":84},"  }\n",[78,299,301,304],{"class":80,"line":300},8,[78,302,303],{"class":156},"  return",[78,305,306],{"class":84}," result1;\n",[78,308,310],{"class":80,"line":309},9,[78,311,312],{"class":84},"}\n",[78,314,316],{"class":80,"line":315},10,[78,317,319],{"emptyLinePlaceholder":318},true,"\n",[78,321,323,326,328,331,334,337],{"class":80,"line":322},11,[78,324,325],{"class":84},"document.cookie ",[78,327,96],{"class":156},[78,329,330],{"class":99}," `XSRF-TOKEN=${",[78,332,333],{"class":84},"generateRandomString",[78,335,336],{"class":99},"}`",[78,338,189],{"class":84},[16,340,341,342,347],{},"那麼這邊 XSRF-TOKEN 其實就是 CSRF-TOKEN，可以看到 ",[27,343,346],{"href":344,"rel":345},"https:\u002F\u002Fdocs.microsoft.com\u002Fzh-tw\u002Faspnet\u002Fcore\u002Fsecurity\u002Fanti-request-forgery?view=aspnetcore-5.0",[50],"微軟官方"," 描述也是相同的：",[33,349,350],{},[16,351,352],{},"跨網站要求偽造 (也稱為 XSRF 或 CSRF) 是針對 web 裝載的應用程式進行攻擊",[16,354,355],{},"接下來再請求往後端打的時候將存在 Cookie 的 XSRF-TOKEN 一起往後端送，如果你使用的是 axios 套件的話，只需要這樣子設定即可(不得不說 axios 超方便)：",[69,357,359],{"className":147,"code":358,"language":149,"meta":74,"style":74},"axios.defaults.xsrfCookieName: 'XSRF-TOKEN', \u002F\u002F 名稱請與儲存在 cookies 相同，axios 預設是 'XSRF-TOKEN'\naxios.defaults.xsrfHeaderName = 'X-XSRF-TOKEN'; \u002F\u002F 這一個主要是請求時，會帶在 header 的名稱，建議與後端溝通，有些後端接收是接收 XSRF-TOKEN，axios 預設是 'X-XSRF-TOKEN'\n",[39,360,361,376],{"__ignoreMap":74},[78,362,363,366,369,372],{"class":80,"line":81},[78,364,365],{"class":84},"axios.defaults.xsrfCookieName: ",[78,367,368],{"class":99},"'XSRF-TOKEN'",[78,370,371],{"class":84},", ",[78,373,375],{"class":374},"sQrFR","\u002F\u002F 名稱請與儲存在 cookies 相同，axios 預設是 'XSRF-TOKEN'\n",[78,377,378,381,383,386,389],{"class":80,"line":174},[78,379,380],{"class":84},"axios.defaults.xsrfHeaderName ",[78,382,96],{"class":156},[78,384,385],{"class":99}," 'X-XSRF-TOKEN'",[78,387,388],{"class":84},"; ",[78,390,391],{"class":374},"\u002F\u002F 這一個主要是請求時，會帶在 header 的名稱，建議與後端溝通，有些後端接收是接收 XSRF-TOKEN，axios 預設是 'X-XSRF-TOKEN'\n",[16,393,394],{},"如果你是在 Vue Cli 環境的話則是以下：",[69,396,398],{"className":147,"code":397,"language":149,"meta":74,"style":74},"this.$http.defaults.xsrfCookieName: 'XSRF-TOKEN',\nthis.$http.defaults.xsrfHeaderName = 'XSRF-TOKEN';\n",[39,399,400,413],{"__ignoreMap":74},[78,401,402,405,408,410],{"class":80,"line":81},[78,403,404],{"class":92},"this",[78,406,407],{"class":84},".$http.defaults.xsrfCookieName: ",[78,409,368],{"class":99},[78,411,412],{"class":84},",\n",[78,414,415,417,420,422,425],{"class":80,"line":174},[78,416,404],{"class":92},[78,418,419],{"class":84},".$http.defaults.xsrfHeaderName ",[78,421,96],{"class":156},[78,423,424],{"class":99}," 'XSRF-TOKEN'",[78,426,189],{"class":84},[16,428,429],{},"透過上面設置之後，每一次請求 axios 到後端時就會預設帶上由 Client 生成的 CSRF Token，而這個方式也可以避免 CSRF 攻擊問題。",[16,431,432],{},"那麼你可能會疑惑為什麼這樣子可以預防 CSRF 攻擊，你可以試想一下，當使用者點了這個網址後的狀況會是如何",[69,434,436],{"className":147,"code":435,"language":149,"meta":74,"style":74},"\u003Ca href=\"https:\u002Fwww.example.com\u002Fdelete?id=1\">取得比特幣\u003C\u002Fa>\n",[39,437,438],{"__ignoreMap":74},[78,439,440,442,444,447,449,452,455,457],{"class":80,"line":81},[78,441,85],{"class":84},[78,443,27],{"class":88},[78,445,446],{"class":92}," href",[78,448,96],{"class":156},[78,450,451],{"class":99},"\"https:\u002Fwww.example.com\u002Fdelete?id=1\"",[78,453,454],{"class":84},">取得比特幣\u003C\u002F",[78,456,27],{"class":88},[78,458,119],{"class":84},[16,460,461],{},"會因為使用者是直接點連結進入到該頁面，因此並不會有 axios 行為所以就不會有 Client 產生得 XSRF-TOKEN，這樣子後端就不會執行這個刪除行為，因此如果要達到正確的刪除行為你就必須需持有 Token 之外也必須持有 XSRF-TOKEN，這樣子就可以避免這種狀況。",[16,463,464],{},"但你可能也會疑惑「可是通常登入的功能必須有 Token 才能夠刪除啊？」",[16,466,467],{},"基本上是的，但是如果你傳送時如果能夠多這個保護，是可以減少被攻擊的機會，而這個 CSRF 大部分都是在預防不需要 Token 的頁面為主哩。",[12,469,470],{"id":470},"參考文獻",[472,473,474,481],"ul",{},[475,476,477],"li",{},[27,478,480],{"href":48,"rel":479},[50],"跨站請求偽造",[475,482,483],{},[27,484,487],{"href":485,"rel":486},"https:\u002F\u002Fblog.techbridge.cc\u002F2017\u002F02\u002F25\u002Fcsrf-introduction\u002F",[50],"讓我們來談談 CSRF",[489,490,491],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":74,"searchDepth":174,"depth":174,"links":493},[494,495,496,497],{"id":14,"depth":174,"text":14},{"id":21,"depth":174,"text":22},{"id":63,"depth":174,"text":64},{"id":470,"depth":174,"text":470},"Nodejs","2021-05-27 10:48:11","md","zh-Hant",{},"\u002Fnodejs\u002Fcsrf-xsrf","3",{"title":6,"description":18},false,"Nodejs\u002F前後端分離下的-CSRF-XSRF",[22,509,510,511,512],"XSRF","前後端分離","Node.js","JavaScript",null,"\u002Fnodejs\u002F20210527\u002F2874571028\u002F","lsNE1UAKBeOY120SnoUGJzlMQoWMrfyMZqeMhH1EWog",{"newer":517,"older":521},{"url":518,"title":519,"date":520},"\u002Fother\u002F20210529\u002F2519649612\u002F","淺談 SPA、CSR、SSR、MPA、SSG 專有名詞","2021-05-29 11:08:28",{"url":522,"title":523,"date":524},"\u002Fother\u002F20210525\u002F2636910669\u002F","軟體版本號中的 Beta?Alpha?RC?","2021-05-25 21:41:41",[526,531,536],{"url":527,"title":528,"date":529,"readingMinutes":530},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":532,"title":533,"date":534,"readingMinutes":535},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":537,"title":538,"date":539,"readingMinutes":540},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784012801757]