[{"data":1,"prerenderedAt":644},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20220215\u002F1747232197\u002F":3,"page:\u002Fnodejs\u002F20220215\u002F1747232197\u002F":4,"alt:\u002Fnodejs\u002F20220215\u002F1747232197\u002F":3,"prev-next:\u002Fnodejs\u002F20220215\u002F1747232197\u002F":620,"related:\u002Fnodejs\u002F20220215\u002F1747232197\u002F":629},"\u002Fen\u002Fnodejs\u002F2022\u002F02\u002F15\u002Fforced-to-eat-mango-frontend-03-mongodb-crud-create\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":601,"date":602,"description":603,"extension":604,"lang":605,"meta":606,"navigation":607,"path":608,"readingMinutes":609,"seo":610,"standalone":611,"stem":612,"tags":613,"tldr":617,"updated":617,"url":618,"__hash__":619},"content\u002F被迫吃芒果的前端工程師\u002F3-被迫吃芒果的前端工程師-MongoDB-CRUD-之-Create.md","(3)被迫吃芒果的前端工程師 - MongoDB CRUD 之 Create","1747232197",{"type":9,"value":10,"toc":596},"minimark",[11,15,19,23,26,62,74,103,107,110,113,125,131,134,153,160,166,179,184,195,205,213,222,229,288,291,296,343,349,497,504,509,580,583,589,592],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面認識了基本常見的 MongoDB Basic 操作之後，接下來當然就是要認識 CRUD 的部分，因此我們還是會繼續在終端機上面操作。",[12,20,22],{"id":21},"mongodb-crud","MongoDB CRUD",[16,24,25],{},"接下來聊聊 CRUD 的部分，雖然 CRUD 算是已經非常常見的，可是還是解釋一下各自單字所代表的意思",[27,28,29,38,46,54],"ul",{},[30,31,32,33],"li",{},"C = Create\n",[27,34,35],{},[30,36,37],{},"新增、建立或是創建",[30,39,40,41],{},"R = Read\n",[27,42,43],{},[30,44,45],{},"讀取、查詢",[30,47,48,49],{},"U = Update\n",[27,50,51],{},[30,52,53],{},"更新",[30,55,56,57],{},"D = Delete\n",[27,58,59],{},[30,60,61],{},"刪除",[16,63,64,65,69,70,73],{},"準備開始往下閱讀之前，建議你一樣先進入到 MongoDB 介面，然後輸入 ",[66,67,68],"code",{},"use example","，因為接下來都會在 ",[66,71,72],{},"example"," 中做 CRUD 的練習與動作，如果你忘記怎麼進去的話，我也在提供一次流程",[75,76,81],"pre",{"className":77,"code":78,"language":79,"meta":80,"style":80},"language-cmd shiki shiki-themes github-dark-high-contrast","mongo\nuse example\ndb \u002F\u002F 確定目前是在 exampleDB 底下操作\n","cmd","",[66,82,83,91,97],{"__ignoreMap":80},[84,85,88],"span",{"class":86,"line":87},"line",1,[84,89,90],{},"mongo\n",[84,92,94],{"class":86,"line":93},2,[84,95,96],{},"use example\n",[84,98,100],{"class":86,"line":99},3,[84,101,102],{},"db \u002F\u002F 確定目前是在 exampleDB 底下操作\n",[12,104,106],{"id":105},"create","Create",[16,108,109],{},"雖然 C 代表著 Create 的意思，雖然 Create 代表著新增、建立或是創建的意思，但我們實際上使用的語法則是 Insertion。",[16,111,112],{},"而 MongoDb 有兩種新增語法的方式",[27,114,115,120],{},[30,116,117],{},[66,118,119],{},"db.collection.insertOne()",[30,121,122],{},[66,123,124],{},"db.collection.insertMany()",[16,126,127,130],{},[66,128,129],{},"insertOne"," 語法非常顧名思義，就是新增一筆的意思。",[16,132,133],{},"前面章節有提到 collection 代表的意思類似於 SQL 的 Tables，因此我們如果今天要新增的資料是一個使用者的話，那麼就要這樣輸入才對",[75,135,139],{"className":136,"code":137,"language":138,"meta":80,"style":80},"language-js shiki shiki-themes github-dark-high-contrast","db.users.insertOne()\n","js",[66,140,141],{"__ignoreMap":80},[84,142,143,147,150],{"class":86,"line":87},[84,144,146],{"class":145},"sMAXC","db.users.",[84,148,129],{"class":149},"sj_SG",[84,151,152],{"class":145},"()\n",[16,154,155,156,159],{},"那...為什麼是這樣輸入呢？讓我畫一張圖理解一下 MongoDB 的架構，首先先讓我們看一下基本的 ",[66,157,158],{},"db"," 架構",[16,161,162],{},[163,164],"img",{"alt":158,"src":165},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-22%2022.23.57.png",[16,167,168,169,171,172,174,175,178],{},"而我們通常輸入 ",[66,170,158],{}," 就會直接顯示當前資料庫的位置，因此起手一定會是先 ",[66,173,158],{},"，後面第二個則是 ",[66,176,177],{},"collection","，就必須明確的說明是哪一個集合(集合)，例如我現在要新增一筆資料到 Users 集合內",[16,180,181],{},[163,182],{"alt":177,"src":183},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-22%2022.29.37.png",[16,185,186,187,190,191,194],{},"因此若要新增一個使用者的集合就必須寫 ",[66,188,189],{},"db.users.insertOne"," 或 ",[66,192,193],{},"db.users.insertMany","。",[16,196,197,198,201,202,194],{},"透過上面那張圖我們也可以理解到一件事情，如果你是想新增資料到 ",[66,199,200],{},"news"," 的集合的話，那麼就會是 ",[66,203,204],{},"db.news.insertOne",[16,206,207,208,210,211,194],{},"了解上面之後，讓我們拉回剛剛的兩個語法，也就是 ",[66,209,119],{}," 跟 ",[66,212,124],{},[16,214,215,216,210,218,221],{},"那 ",[66,217,129],{},[66,219,220],{},"insertMany"," 有什麼差異呢？簡單來講就是一個一次只能新增一筆，另一個則是可以批次新增，",[16,223,224,225,228],{},"首先先讓我們使用單一新增將一個使用者資料新增到資料庫的 ",[66,226,227],{},"users"," 集合",[75,230,232],{"className":136,"code":231,"language":138,"meta":80,"style":80},"db.users.insertOne({\n  \"name\": \"Ray\",\n  \"age\": 28,\n  \"status\": false\n})\n",[66,233,234,243,258,271,282],{"__ignoreMap":80},[84,235,236,238,240],{"class":86,"line":87},[84,237,146],{"class":145},[84,239,129],{"class":149},[84,241,242],{"class":145},"({\n",[84,244,245,249,252,255],{"class":86,"line":93},[84,246,248],{"class":247},"sTRMh","  \"name\"",[84,250,251],{"class":145},": ",[84,253,254],{"class":247},"\"Ray\"",[84,256,257],{"class":145},",\n",[84,259,260,263,265,269],{"class":86,"line":99},[84,261,262],{"class":247},"  \"age\"",[84,264,251],{"class":145},[84,266,268],{"class":267},"sCcAr","28",[84,270,257],{"class":145},[84,272,274,277,279],{"class":86,"line":273},4,[84,275,276],{"class":247},"  \"status\"",[84,278,251],{"class":145},[84,280,281],{"class":267},"false\n",[84,283,285],{"class":86,"line":284},5,[84,286,287],{"class":145},"})\n",[16,289,290],{},"那麼當你輸入之後如果有新增成功 MongoDB 會回傳給你訊息告訴你有成功，然後這個 document ID 是什麼",[16,292,293],{},[163,294],{"alt":129,"src":295},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-22%2022.59.20.png",[75,297,299],{"className":136,"code":298,"language":138,"meta":80,"style":80},"{\n  \"acknowledged\" : true,\n  \"insertedId\" : ObjectId(\"61ec1b832fecb74092ce1462\")\n}\n",[66,300,301,306,319,338],{"__ignoreMap":80},[84,302,303],{"class":86,"line":87},[84,304,305],{"class":145},"{\n",[84,307,308,311,314,317],{"class":86,"line":93},[84,309,310],{"class":247},"  \"acknowledged\"",[84,312,313],{"class":145}," : ",[84,315,316],{"class":267},"true",[84,318,257],{"clas