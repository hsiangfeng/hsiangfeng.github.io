[{"data":1,"prerenderedAt":521},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190704\u002F2336420619\u002F":3,"page:\u002Fnodejs\u002F20190704\u002F2336420619\u002F":4,"alt:\u002Fnodejs\u002F20190704\u002F2336420619\u002F":3,"prev-next:\u002Fnodejs\u002F20190704\u002F2336420619\u002F":497,"related:\u002Fnodejs\u002F20190704\u002F2336420619\u002F":506},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F04\u002Ffullstack-nodejs-csrf-protection\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":481,"date":482,"description":18,"extension":483,"lang":484,"meta":485,"navigation":209,"path":486,"readingMinutes":487,"seo":488,"standalone":489,"stem":490,"tags":491,"tldr":494,"updated":494,"url":495,"__hash__":496},"content\u002F全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-CSRF-篇.md","全端勇士之路 Node.js 基礎學習-CSRF 篇","2336420619",{"type":9,"value":10,"toc":475},"minimark",[11,15,19,23,26,33,40,53,94,97,106,110,116,135,138,166,172,175,178,339,342,465,468,471],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"CSRF 中文又稱為跨站請求偽造，這是一個非常常見的攻擊手法，如果沒有謹慎處理，是有可能導致系統掛掉的",[12,20,22],{"id":21},"csrf-是什麼","CSRF 是什麼",[16,24,25],{},"一般來講我們都會在某個網頁上操作，假設在註冊",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"Google 註冊","https:\u002F\u002Fi.imgur.com\u002FTKVzvLZ.png",[16,34,35,39],{},[36,37,38],"del",{},"「我們都會透過瀏覽器去操作註冊的，但是 CSRF 可能就是透過一些程式來去跟你每幾秒請求註冊，這個動作就有可能導致系統掛掉。」"," - 這一段解釋太過像 DDOS，所以換另一種說法 ↓",[16,41,42,43,47,48,52],{},"CSRF 簡單來講就是利用使用者瀏覽器對於網站的信任來達到攻擊，假設我們已經知道某某某 API 路徑，例如刪除帳號的API ",[44,45,46],"code",{},"https:\u002Fwww.example.com\u002Fdelete?id=XXX","，然後黑客就傳給你一個句話「快看!點這個網址可以取得",[49,50,51],"strong",{},"一個比特幣","」(屁)",[54,55,60],"pre",{"className":56,"code":57,"language":58,"meta":59,"style":59},"language-html shiki shiki-themes github-dark-high-contrast","\u003Ca href=\"https:\u002Fwww.example.com\u002Fdelete?id=1\">取得比特幣\u003C\u002Fa>\n","html","",[44,61,62],{"__ignoreMap":59},[63,64,67,71,75,79,82,86,89,91],"span",{"class":65,"line":66},"line",1,[63,68,70],{"class":69},"sMAXC","\u003C",[63,72,74],{"class":73},"sKpQp","a",[63,76,78],{"class":77},"sCcAr"," href",[63,80,81],{"class":69},"=",[63,83,85],{"class":84},"sTRMh","\"https:\u002Fwww.example.com\u002Fdelete?id=1\"",[63,87,88],{"class":69},">取得比特幣\u003C\u002F",[63,90,74],{"class":73},[63,92,93],{"class":69},">\n",[16,95,96],{},"接下來你不疑有他就直接點了，當網站沒有做好 CSRF 防禦的時候，網站就只會知道說 「哦~你有我網站的 cookie & session，所以你要刪除 id = 1 的帳號是嗎?沒問題」就這樣網站不疑有他的把第一筆帳號刪除了，那麼為了避免這個狀況發生，那就要在網站上加入一個 CSRF 的防禦，當資料往後端時還必須帶上一組亂碼(類似 hash) 驗證沒問題我才會讓你執行，但是這一串數字並不是隨便帶都可以，而是要由瀏覽器觸發後端往前端傳才可以。",[16,98,99,100],{},"更詳細可以看 ",[74,101,105],{"href":102,"rel":103},"https:\u002F\u002Fblog.techbridge.cc\u002F2017\u002F02\u002F25\u002Fcsrf-introduction\u002F",[104],"nofollow","這篇",[12,107,109],{"id":108},"防禦-csrf","防禦 CSRF",[16,111,112,113],{},"Express 中其實有一個套件可以拿來防禦 CSRF 的問題，所以首先要先安裝一個套件，它叫做 ",[44,114,115],{},"CSURF",[54,117,121],{"className":118,"code":119,"language":120,"meta":59,"style":59},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save csurf\n","js",[44,122,123],{"__ignoreMap":59},[63,124,125,128,132],{"class":65,"line":66},[63,126,127],{"class":69},"npm install ",[63,129,131],{"class":130},"sWyjQ","--",[63,133,134],{"class":69},"save csurf\n",[16,136,137],{},"引入方式也是一樣簡單",[54,139,141],{"className":118,"code":140,"language":120,"meta":59,"style":59},"var csurf = require('csurf')\n",[44,142,143],{"__ignoreMap":59},[63,144,145,148,151,153,157,160,163],{"class":65,"line":66},[63,146,147],{"class":130},"var",[63,149,150],{"class":69}," csurf ",[63,152,81],{"class":130},[63,154,156],{"class":155},"sj_SG"," require",[63,158,159],{"class":69},"(",[63,161,162],{"class":84},"'csurf'",[63,164,165],{"class":69},")\n",[16,167,168,169],{},"CSURF 它是會驗證 Cookie 所以是必須要有 ",[44,170,171],{},"var cookieParser = require('cookie-parser')",[16,173,174],{},"那使用方式其實很簡單，它採用 middleware 的作法",[16,176,177],{},"(以下摘錄官方文件)",[54,179,181],{"className":118,"code":180,"language":120,"meta":59,"style":59},"var csrfProtection = csrf({ cookie: 