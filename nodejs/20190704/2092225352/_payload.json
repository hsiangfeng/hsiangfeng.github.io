[{"data":1,"prerenderedAt":555},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190704\u002F2092225352\u002F":3,"page:\u002Fnodejs\u002F20190704\u002F2092225352\u002F":4,"alt:\u002Fnodejs\u002F20190704\u002F2092225352\u002F":3,"prev-next:\u002Fnodejs\u002F20190704\u002F2092225352\u002F":531,"related:\u002Fnodejs\u002F20190704\u002F2092225352\u002F":540},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F04\u002Fnodejs-cookie-session\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":514,"date":515,"description":18,"extension":516,"lang":517,"meta":518,"navigation":519,"path":520,"readingMinutes":521,"seo":522,"standalone":523,"stem":524,"tags":525,"tldr":528,"updated":528,"url":529,"__hash__":530},"content\u002F全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-關於-Cookie-Session.md","全端勇士之路 Node.js 基礎學習-關於 Cookie & Session","2092225352",{"type":9,"value":10,"toc":502},"minimark",[11,15,19,23,26,42,45,53,57,60,63,71,81,85,88,92,95,103,106,109,113,116,119,149,152,159,170,186,189,212,215,222,238,242,252,255,309,312,316,319,341,352,378,385,462,469,498],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來將會講講 Cookie 與 Session 這兩個東西，身為一名網頁開發者，這兩個東西是一定要知道的",[12,20,22],{"id":21},"cookie","Cookie",[16,24,25],{},"Cookie 通常會儲存我們造訪過的網站記錄，舉凡登入、偏好等等，那它的特性有以下",[27,28,29,33,36,39],"ul",{},[30,31,32],"li",{},"記憶體僅可儲存 4KB",[30,34,35],{},"能夠在 Client (瀏覽器)、Server (伺服器) 進行讀取與寫入",[30,37,38],{},"是由 key\u002Fvalue 組合而成",[30,40,41],{},"另外最大的特點就是可以設置失效日期",[16,43,44],{},"但是 Cookie 其實還可以分為兩種",[27,46,47,50],{},[30,48,49],{},"記憶體 Cookie",[30,51,52],{},"硬體 Cookie",[54,55,49],"h3",{"id":56},"記憶體-cookie",[16,58,59],{},"通常記憶體 Cookie 都是由 Client (瀏覽器)所維護，並且儲存於記憶體中，只要關閉瀏覽器就會消失，所以存在的時間極短。",[54,61,52],{"id":62},"硬體-cookie",[16,64,65,66,70],{},"硬體 Cookie 就有點特別了，它是儲存在",[67,68,69],"strong",{},"硬體","中，所以除非使用者手動清除 or 設置的時間到期，否則是不會刪除的，那時間通常是很久",[16,72,73,74,77,78],{},"所以若用時間來劃分就又可以稱之為兩種 Cookie，",[67,75,76],{},"非長期 Cookie"," 與",[67,79,80],{},"長期 Cookie",[54,82,84],{"id":83},"cookie-的缺點","Cookie 的缺點",[16,86,87],{},"另外他也是有缺點的，因為 Cookie 本身只有 4 KB，所以較複雜的儲存方式是不可行的，另外 Cookie 也會導致流量的增加，最後如果使用 HTTP 的方式傳遞是會有安全性的問題，除非採用 HTTPS",[12,89,91],{"id":90},"session","Session",[16,93,94],{},"上面看完 Cookie 後，就是來講 Session，那麼 Session 又有什麼特別的呢?",[27,96,97,100],{},[30,98,99],{},"儲存在 Server 的暫存資料，可以放在記憶體或是資料庫上",[30,101,102],{},"Session 也可以在 Cookie 上儲存 UUID 確保知道你是誰",[16,104,105],{},"通常 Session 都會放在記憶體上，比較少會放在資料庫上",[16,107,108],{},"實務上呢?實務上通常都會結合這兩者一起搭配著使用進而驗證使用者的登入，這是最常見的實務做法，所以下面就來繼續講該如何用 JS 來寫吧",[12,110,112],{"id":111},"javascript-cookie","JavaScript Cookie",[16,114,115],{},"JavaScript 也可以做到替瀏覽器寫入 Cookie，甚至時間、過期時間等等，讓我們來看看語法吧",[16,117,118],{},"寫入 Cookie",[120,121,126],"pre",{"className":122,"code":123,"language":124,"meta":125,"style":125},"language-js shiki shiki-themes github-dark-high-contrast","document.cookie = 'name=Ray';\n","js","",[127,128,129],"code",{"__ignoreMap":125},[130,131,134,138,142,146],"span",{"class":132,"line":133},"line",1,[130,135,137],{"class":136},"sMAXC","document.cookie ",[130,139,141],{"class":140},"sWyjQ","=",[130,143,145],{"class":144},"sTRMh"," 'name=Ray'",[130,147,148],{"class":136},";\n",[16,150,151],{},"這樣就可以在 Cookie 上看到剛剛輸入的資料",[16,153,154],{},[155,156],"img",{"alt":157,"src":158},"Image","https:\u002F\u002Fi.imgur.com\u002FyTdnsKb.png",[16,160,161,162,165,166,169],{},"設置失效時間\n(失效時間是使用 ",[127,163,164],{},"expires","，",[127,167,168],{},"path=\u002F"," 代表路徑的意思，通常時間會使用 GMT 時間)",[120,171,173],{"className":122,"code":172,"language":124,"meta":125,"style":125},"document.cookie = 'name=Ray;expires=Thu, 04 Jul 2019 05:08:19 GMT;path=\u002F';\n",[127,174,175],{"__ignoreMap":125},[130,176,177,179,181,184],{"class":132,"line":133},[130,178,137],{"class":136},[130,180,141],{"class":140},[130,182,183],{"class":144}," 'name=Ray;expires=Thu, 04 Jul 2019 05:08:19 GMT;path=\u002F'",[130,185,148],{"class":136},[16,187,188],{},"GMT 時間產生方式",[120,190,192],{"className":122,"code":191,"language":124,"meta":125,"style":125},"new Date().toGMTString();\n",[127,193,194],{"__ignoreMap":125},[130,195,196,199,203,206,209],{"class":132,"line":133},[130,197,198],{"class":140},"new",[130,200,202],{"class":201},"sj_SG"," Date",[130,204,205],{"class":136},"().",[130,207,208],{"class":201},"toGMTString",[130,210,211],{"class":136},"();\n",[16,213,214],{},"設定時效",[16,216,217,218,221],{},"(",[127,219,220],{},"max-age=5"," 意旨五秒後失效)",[120,223,225],{"className":122,"code":224,"language":124,"meta":125,"style":125},"document.cookie = 'name=Ray;max-age=5;path=\u002F';\n",[127,226,227],{"__ignoreMap":125},[130,228,229,231,233,236],{"class":132,"line":133},[130,230,137],{"class":136},[130,232,141],{"class":140},[130,234,235],{"class":144}," 'name=Ray;max-age=5;path=\u002F'",[130,237,148],{"class":136},[12,239,241],{"id":240},"nodejs-cookie","Node.js Cookie",[16,243,244,245,248,249],{},"在 Express 中可以使用 ",[127,246,247],{},"req.cookie"," 來取得使用者的 cookie，那如果回傳資料進去 cookie 呢?也是可以，例如名子是 Ray 失效時間是 5 秒，那麼就這樣寫 ",[127,250,251],{},"res.cookie('name','Ray', { maxAge: 5000 })",[16,253,254],{},"另外如果不想要讓人家使用 JS 取的 cookie 的話，就可以這樣改寫",[120,256,258],{"className":122,"code":257,"language":124,"meta":125,"style":125},"res.cookie('name','Ray', {\n  maxAge: 5000,\n  httpOnly: true\n})\n",[127,259,260,281,294,303],{"__ignoreMap":125},[130,261,262,265,267,269,272,275,278],{"class":132,"line":133},[130,263,264],{"class":136},"res.",[130,266,21],{"class":201},[130,268,217],{"class":136},[130,270,271],{"class":144},"'name'",[130,273,274],{"class":136},",",[130,276,277],{"class":144},"'Ray'",[130,279,280],{"class":136},", {\n",[130,282,284,287,291],{"class":132,"line":283},2,[130,285,286],{"class":136},"  maxAge: ",[130,288,290],{"class":289},"sCcAr","5000",[130,292,293],{"class":136},",\n",[130,295,297,300],{"class":132,"line":296},3,[130,298,299],{"class":136},"  httpOnly: ",[130,301,302],{"class":289},"true\n",[130,304,306],{"class":132,"line":305},4,[130,307,308],{"class":136},"})\n",[16,310,311],{},"這樣就無法透過 JS 來拉取 cookie 哩",[12,313,315],{"id":314},"nodejs-session","Node.js Session",[16,317,318],{},"在 Express 環境下比較特別的是 Session，透過產生器是可以看到有 Cookie，但是並沒有 Session，所以在使用之前務必要記得先安裝 express-session",[120,320,322],{"className":122,"code":321,"language":124,"meta":125,"style":125},"npm install --save express-session\n",[127,323,324],{"__ignoreMap":125},[130,325,326,329,332,335,338],{"class":132,"line":133},[130,327,328],{"class":136},"npm install ",[130,330,331],{"class":140},"--",[130,333,334],{"class":136},"save express",[130,336,337],{"class":140},"-",[130,339,340],{"class":136},"session\n",[16,342,343,344,351],{},"引入的方式也非常簡單，",[345,346,350],"a",{"href":347,"rel":348},"https:\u002F\u002Fgithub.com\u002Fexpressjs\u002Fsession",[349],"nofollow","官方文件"," 都有寫",[120,353,355],{"className":122,"code":354,"language":124,"meta":125,"style":125},"var session = require('express-session')\n",[127,356,357],{"__ignoreMap":125},[130,358,359,362,365,367,370,372,375],{"class":132,"line":133},[130,360,361],{"class":140},"var",[130,363,364],{"class":136}," session ",[130,366,141],{"class":140},[130,368,369],{"class":201}," require",[130,371,217],{"class":136},[130,373,374],{"class":144},"'express-session'",[130,376,377],{"class":136},")\n",[16,379,380,381,384],{},"那麼要使用這個套件一定是使用 ",[127,382,383],{},"app.use","，所以這樣寫",[120,386,388],{"className":122,"code":387,"language":124,"meta":125,"style":125},"app.use(session({\n  secret: 'keyboard cat', \u002F\u002F 安全方式，會依照裡面的字串去做加密邏輯\n  resave: true, \u002F\u002F 是否要每次進入網頁時重新設置 seesion cookie，如果有設置失效，例如 5 分鐘，重新整理後又有 5 分鐘，但是必須要改成 true 才有效，但是建議改成 true\n  saveUninitialized: true,\n  cookie: { maxAge: 5000 } \u002F\u002F 另外也可以設置 cookie 過期時間，例如 5 秒後過期\n}))\n",[127,389,390,405,420,433,442,456],{"__ignoreMap":125},[130,391,392,395,398,400,402],{"class":132,"line":133},[130,393,394],{"class":136},"app.",[130,396,397],{"class":201},"use",[130,399,217],{"class":136},[130,401,90],{"class":201},[130,403,404],{"class":136},"({\n",[130,406,407,410,413,416],{"class":132,"line":283},[130,408,409],{"class":136},"  secret: ",[130,411,412],{"class":144},"'keyboard cat'",[130,414,415],{"class":136},", ",[130,417,419],{"class":418},"sQrFR","\u002F\u002F 安全方式，會依照裡面的字串去做加密邏輯\n",[130,421,422,425,428,430],{"class":132,"line":296},[130,423,424],{"class":136},"  resave: ",[130,426,427],{"class":289},"true",[130,429,415],{"class":136},[130,431,432],{"class":418},"\u002F\u002F 是否要每次進入網頁時重新設置 seesion cookie，如果有設置失效，例如 5 分鐘，重新整理後又有 5 分鐘，但是必須要改成 true 才有效，但是建議改成 true\n",[130,434,435,438,440],{"class":132,"line":305},[130,436,437],{"class":136},"  saveUninitialized: ",[130,439,427],{"class":289},[130,441,293],{"class":136},[130,443,445,448,450,453],{"class":132,"line":444},5,[130,446,447],{"class":136},"  cookie: { maxAge: ",[130,449,290],{"class":289},[130,451,452],{"class":136}," } ",[130,454,455],{"class":418},"\u002F\u002F 另外也可以設置 cookie 過期時間，例如 5 秒後過期\n",[130,457,459],{"class":132,"line":458},6,[130,460,461],{"class":136},"}))\n",[16,463,464,465,468],{},"那當然 Express 也可以查看使用者的 Session，只需要這樣寫就可以 ",[127,466,467],{},"req.session","，反之也可以寫入如下",[120,470,472],{"className":122,"code":471,"language":124,"meta":125,"style":125},"res.session.name = 'Ray';\nres.session.account = 'QQ123';\n",[127,473,474,486],{"__ignoreMap":125},[130,475,476,479,481,484],{"class":132,"line":133},[130,477,478],{"class":136},"res.session.name ",[130,480,141],{"class":140},[130,482,483],{"class":144}," 'Ray'",[130,485,148],{"class":136},[130,487,488,491,493,496],{"class":132,"line":283},[130,489,490],{"class":136},"res.session.account ",[130,492,141],{"class":140},[130,494,495],{"class":144}," 'QQ123'",[130,497,148],{"class":136},[499,500,501],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight