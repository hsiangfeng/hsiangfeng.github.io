,676,679,682,685,687],{"class":98,"line":675},37,[96,677,678],{"class":113},"  })).",[96,680,681],{"class":183},"setMimeType",[96,683,684],{"class":113},"(ContentService.MimeType.",[96,686,491],{"class":106},[96,688,689],{"class":113},")\n",[96,691,693],{"class":98,"line":692},38,[96,694,133],{"class":113},[12,696,697],{},"這邊我們就完成了 Google Apps Script 的部分，接下來我們要把原本的 Open AI 程式碼移除，並且改成 Google Apps Script 的 API。",[254,699,700],{"title":256,"type":257},[12,701,702,703,706],{},"請記得自己把 OpenAI Url 加入到 ",[75,704,705],{},"env.gs"," 中唷。",[12,708,709],{},"那我們該如何取得呢？點一下「部署」，這時候會跳出下拉選單，選擇「新增部署作業」，然後找到齒輪選擇「網路應用程式」",[12,711,712],{},[15,713],{"alt":714,"src":715},"網路應用程式","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web.png",[12,717,718],{},"然後這邊為了方便練習，請記得填寫一下說明，並把「存取權限」改成「任何人」，這樣子我們就可以不用登入就可以使用 API 了",[12,720,721],{},[15,722],{"alt":723,"src":724},"API","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web_2.jpg",[12,726,727],{},"接著你如果是第一次部署的話，會跳出一些視窗，基本上只要依照提示點授權及允許就可以了，這時候你應該會看到以下畫面，紅框圈起來的就是你的 API 網址",[12,729,730],{},[15,731],{"alt":732,"src":733},"API Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_deloy_web_3.jpg",[12,735,736],{},"複製下來後，就可以準備回到 Google Extension 了。",[67,738,740],{"id":739},"google-extension","Google Extension",[12,742,743],{},"接下來這邊我們就不額外建立新專案了，會直接沿用前一篇的範例專案，打開 App.vue 替換成以下：",[87,745,749],{"className":746,"code":747,"language":748,"meta":92,"style":92},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cscript setup>\nimport { onMounted } from 'vue'\nimport HelloWorld from '.\u002Fcomponents\u002FHelloWorld.vue'\n\nasync function main() {\n  const data = await fetch('APU Url', {\n    method: 'POST',\n    body: JSON.stringify({\n      text: 'Hello, world!'\n    })\n  }).then(res => res.json())\n\n  console.log(data)\n}\n\nonMounted(main);\n\u003C\u002F