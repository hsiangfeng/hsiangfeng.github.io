"https:\u002F\u002Fwww.google.com\u002Fscript\u002Fstart\u002F",[57],"nofollow","Google Apps Script 官網","，並且點一下「新專案」建立一個新專案",[12,61,62],{},[15,63],{"alt":64,"src":65},"Google Apps Script","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgoogle_apps_script_dash.png",[67,68,70],"h3",{"id":69},"properties-service","Properties Service",[12,72,73,74],{},"接下來點一下旁邊建立「指令碼」，我們要先來建立環境變數，所以檔案名稱叫 ",[75,76,77],"code",{},"env",[12,79,80],{},[15,81],{"alt":77,"src":82},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas-env.png",[12,84,85],{},"內容填入以下程式碼",[87,88,93],"pre",{"className":89,"code":90,"language":91,"meta":92,"style":92},"language-js shiki shiki-themes github-dark-high-contrast","const env = {\n  openai_key: 'OpenAI Key',\n}\n","js","",[75,94,95,115,128],{"__ignoreMap":92},[96,97,100,104,108,111],"span",{"class":98,"line":99},"line",1,[96,101,103],{"class":102},"sWyjQ","const",[96,105,107],{"class":106},"sCcAr"," env",[96,109,110],{"class":102}," =",[96,112,114],{"class":113},"sMAXC"," {\n",[96,116,118,121,125],{"class":98,"line":117},2,[96,119,120],{"class":113},"  openai_key: ",[96,122,124],{"class":123},"sTRMh","'OpenAI Key'",[96,126,127],{"class":113},",\n",[96,129,131],{"class":98,"line":130},3,[96,132,133],{"class":113},"}\n",[12,135,136,137,139,140,143],{},"ok，暫停一下，這時候你應該會感到疑惑，畢竟前面我們在介紹 ",[75,138,77],{}," 會需要安裝一個 ",[75,141,142],{},"dotenv"," 套件，但是這邊我們並沒有安裝，這是為什麼呢？因為 Google Apps Script 本身沒有環境變數（env）的概念，而且目前這種做法也比較不正確。",[12,145,146,147,149],{},"雖然剛剛有提到 Google Apps Script 沒有環境變數的概念，但有類似的東西，也就是 Properties Service，因此我們可以使用這個來取代 ",[75,148,77],{},"。",[12,151,152],{},"首先請你點一下齒輪（專案設定）",[12,154,155],{},[15,156],{"alt":157,"src":158},"專案設定","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_setting.png",[12,160,161],{},"接著往下滾可以找到「指令碼屬性」，點一下「新增指令碼屬性」，可以把你的 OpenAI Key 填入",[12,163,164],{},[15,165],{"alt":166,"src":167},"指令碼屬性","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fgas_env_key.jpg",[12,169,170],{},"接著回到任一程式碼中，填寫以下並執行它",[87,172,174],{"className":89,"code":173,"language":91,"meta":92,"style":92},"Logger.log(PropertiesService.getScriptProperties().getProperty('openai_token'))\n",[75,175,176],{"__ignoreMap":92},[96,177,178,181,185,188,191,194,197,200,203],{"class":98,"line":99},[96,179,180],{"class":113},"Logger.",[96,182,184],{"class":183},"sj_SG","log",[96,186,187],{"class":113},"(PropertiesService.",[96,189,190],{"class":183},"getScriptProperties",[96,192,193],{"class":113},"().",[96,195,196],{"class":183},"getProperty",[96,198,199],{"class":113},"(",[96,201,202],{"class":123},"'openai_token'",[96,204,205],{"class":113},"))\n",[12,207,208],{},"基本上不意外你應該是可以在底下看到你的 OpenAI Key，接著回到 env.gs 改成以下程式碼",[87,210,212],{"className":89,"code":211,"language":91,"meta":92,"style":92},"const env = {\n  openai_key: PropertiesService.getScriptProperties().getProperty('openai_token'),\n}\n",[75,213,214,224,242],{"__ignoreMap":92},[96,215,216,218,220,222],{"class":98,"line":99},[96,217,103],{"class":102},[96,219,107],{"class":106},[96,221,110],{"class":102},[96,223,114],{"class":113},[96,225,226,229,231,233,235,237,239],{"class":98,"line":117},[96,227,228],{"class":113},"  openai_key: PropertiesService.",[96,230,190],{"class":183},[96,232,193],{"class":113},[96,234,196],{"class":183},[96,236,199],{"class":113},[96,238,202],{"class":123},[96,240,241],{"class":113},"),\n",[96,243,244],{"class":98,"line":130},[96,245,133],{"class":113},[12,247,248,249,252],{},"這樣子我們就可以在任一程式碼中使用 ",[75,250,251],{},"env.openai_key"," 來取得 OpenAI Key 了。",[254,255,256],"blockquote",{},[12,257,258,262,263,149],{},[259,260,261],"strong",{},"Note","\nGoogle Apps Script 的變數宣告後都是全域的，因此你可以在任一程式碼中使用 ",[75,264,77],{},[67,266,268],{"id":267},"串接-openai","串接 OpenAI",[12,270,271],{},"接下來當然就是要串接 OpenAI 囉～",[12,273,274,275,280,281,284,285,288],{},"但是 Google Apps Script 有一個不方便的問題存在，也就是沒辦法隨意引入套件，因此我們必須使用 ",[53,276,279],{"href":277,"rel":278},"https:\u002F\u002Fplatform.openai.com\u002Fdocs\u002Fapi-reference\u002Fchat\u002Fcreate",[57],"OpenAI"," 的 API 來串接，剛好 OpenAI 的 API 串接上非常的容易，只需要用 ",[75,282,283],{},"UrlFetchApp"," 發起請求到 ",[75,286,287],{},"Post https:\u002F\u002Fapi.openai.com\u002Fv1\u002Fchat\u002Fcompletions"," 就可以了。",[12,290,291,292,295],{},"因此接下來請你任一開一個新的檔案，叫做 ",[75,293,294],{},"openai.gs","，並且填入以下程式碼",[12,297,298],{},"（一樣我都會給註解，所以你可以看註解來理解程式碼）",[87,300,302],{"className":89,"code":301,"language":91,"meta":92,"style":92},"\u002F\u002F 宣告一個 doPost 方法，這是 Google Apps Script 的規定\nconst doPost = (e) => {\n  \u002F\u002F 取得 e.postData.contents，取出來後必須使用 JSON.parse 轉成物件\n  const postData = JSON.parse(e.postData.contents);\n  \u002F\u002F 取出 text\n  const text = postData.text;\n  \u002F\u002F 宣告 options 物件\n  const options = {\n    \u002F\u002F 設定請求方式為 post\n    method: 'post',\n    \u002F\u002F 設定請求的 headers\n    headers: {\n      \u002F\u002F 預設 Google Apps Script 是 application\u002Fx-www-form-urlencoded，但是 OpenAI 需要 application\u002Fjson\n      'Content-Type': 'application\u002Fjson',\n      \u002F\u002F 設定 Authorization 為 Bearer ${env.openai_key}\n      Authorization: `Bearer ${env.openai_key}`\n    },\n    \u002F\u002F 準備要發送的資料，必須使用 JSON.stringify 將物件轉成 JSON 字串\n    payload: JSON.stringify({\n      model: 'gpt-3.5-turbo', \u002F\u002F 使用 gpt-3.5-turbo 模型\n      \u002F\u002F 設定 prompt，這邊使用 text\n      messages: [\n        {\n          role: 'user', \u002F\u002F 設定角色為 user\n          content: text \n        }\n      ]\n    })\n  }\n  \u002F\u002F 發送請求，並且取得回傳的資料\n  const response = UrlFetchApp.fetch(env.openai_url, options)\n  \u002F\u002F 將回傳的資料轉成物件，並且取出 choices[0].message.content\n  const message = JSON.parse(response.getContentText()).choices[0].message.content\n  \u002F\u002F 回傳 JSON 物件，並透過 setMimeType 設定為 JSON\n  return ContentService.createTextOutput(JSON.stringify({\n    content: message\n  })).setMimeType(ContentService.MimeType.JSON)\n}\n",[75,303,304,310,