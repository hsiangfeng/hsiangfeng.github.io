[{"data":1,"prerenderedAt":1887},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20230929\u002F3878806252\u002F":3,"page:\u002Fnodejs\u002F20230929\u002F3878806252\u002F":4,"alt:\u002Fnodejs\u002F20230929\u002F3878806252\u002F":3,"prev-next:\u002Fnodejs\u002F20230929\u002F3878806252\u002F":1862,"related:\u002Fnodejs\u002F20230929\u002F3878806252\u002F":1871},"\u002Fen\u002Fnodejs\u002F2023\u002F09\u002F29\u002Fday-15-your-first-web-scraper\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1845,"date":1846,"description":25,"extension":1847,"lang":1848,"meta":1849,"navigation":342,"path":1850,"readingMinutes":1851,"seo":1852,"standalone":1853,"stem":1854,"tags":1855,"tldr":1858,"updated":1859,"url":1860,"__hash__":1861},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay15-第一個爬蟲.md","Day15 - 第一個爬蟲","3878806252",{"type":9,"value":10,"toc":1836},"minimark",[11,19,23,26,29,32,48,51,54,107,110,113,116,118,121,132,147,162,174,177,186,189,365,372,378,381,386,388,397,411,414,526,529,532,540,543,546,680,692,695,701,706,709,715,718,775,786,937,956,1194,1203,1209,1215,1218,1220,1223,1596,1610,1616,1813,1816,1829,1832],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"第一個爬蟲","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_Web_Crawler_2f4c3c25-cbd7-4286-aac4-c0cfa01cf28e.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"前一篇我們對於爬蟲應該有一些基本的概念與認知了，接下來當然就是要來實作一下囉。",[20,27,28],{"id":28},"爬蟲實作",[12,30,31],{},"首先一開始在實作之前，我們先回顧一下爬蟲的流程：",[33,34,35,39,42,45],"ul",{},[36,37,38],"li",{},"分析來源",[36,40,41],{},"取得資料",[36,43,44],{},"解析資料",[36,46,47],{},"儲存資料",[12,49,50],{},"爬蟲不外乎就是透過這三個步驟來實作的，因此接下來我們會先講講「取得資料」的方式。",[12,52,53],{},"實作的時候，請你先輸入以下指令來建立第一個專案：",[55,56,61],"pre",{"className":57,"code":58,"language":59,"meta":60,"style":60},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","mkdir example-crawler\ncd example-crawler\nnpm init -y\ntouch index.js\n","bash","",[62,63,64,77,86,98],"code",{"__ignoreMap":60},[65,66,69,73],"span",{"class":67,"line":68},"line",1,[65,70,72],{"class":71},"smYoP","mkdir",[65,74,76],{"class":75},"sWayO"," example-crawler\n",[65,78,80,84],{"class":67,"line":79},2,[65,81,83],{"class":82},"stw71","cd",[65,85,76],{"class":75},[65,87,89,92,95],{"class":67,"line":88},3,[65,90,91],{"class":71},"npm",[65,93,94],{"class":75}," init",[65,96,97],{"class":82}," -y\n",[65,99,101,104],{"class":67,"line":100},4,[65,102,103],{"class":71},"touch",[65,105,106],{"class":75}," index.js\n",[12,108,109],{},"其餘的一些部分我就不再重複說明了，例如什麼 package.json 之類的，所以接下來就直接準備開始實作吧。",[111,112,38],"h3",{"id":38},[12,114,115],{},"其實分析來源很簡單，簡單來講就是你要知道你要爬的網站是什麼，然後你要取得的資料是什麼，這樣就可以了，後面會直接進入實作，所以這邊讓我簡單帶過就好。",[111,117,41],{"id":41},[12,119,120],{},"取得資料的方式有很多種，我們可以透過 HTTP Request 來取得資料，什麼意思呢？簡單來講就是模擬我們打開瀏覽器，並且輸入網址，然後瀏覽器就會幫我們發送 HTTP Request，並且取得資料，這就是一種方式。",[12,122,123,124,131],{},"那我們該怎麼取得呢？你可以透過 ",[125,126,130],"a",{"href":127,"rel":128},"https:\u002F\u002Fgithub.com\u002Faxios\u002Faxios",[129],"nofollow","axios"," 這個套件，因此如果你要使用 axios 的話，你可以先安裝：",[55,133,135],{"className":57,"code":134,"language":59,"meta":60,"style":60},"npm i axios\n",[62,136,137],{"__ignoreMap":60},[65,138,139,141,144],{"class":67,"line":68},[65,140,91],{"class":71},[65,142,143],{"class":75}," i",[65,145,146],{"class":75}," axios\n",[12,148,149,150,152,153,158,159,161],{},"但我這邊並不打算使用 ",[62,151,130],{},"，因為 Node.js 在大概 v18 左右，就已經內建了 ",[125,154,157],{"href":155,"rel":156},"https:\u002F\u002Fnodejs.org\u002Fdist\u002Flatest-v18.x\u002Fdocs\u002Fapi\u002Fglobals.html#fetch",[129],"fetch"," 這個方法，因此我們可以直接使用 ",[62,160,157],{}," 來取得資料。",[163,164,167],"callout",{"title":165,"type":166},"Note","note",[12,168,169,170,158,172,161],{},"Fetch API 原本是瀏覽器才有的方法，但是 Node.js 在 v18 內建支援 ",[62,171,157],{},[62,173,157],{},[12,175,176],{},"那我們目標是誰呢？這邊就先以我的部落格當作範例吧？我的部落格網址是以下",[55,178,180],{"className":57,"code":179,"language":59,"meta":60,"style":60},"https:\u002F\u002Fisraynotarray.com\u002F\n",[62,181,182],{"__ignoreMap":60},[65,183,184],{"class":67,"line":68},[65,185,179],{"class":71},[12,187,188],{},"接下來就是撰寫範例程式碼，我們先來看一下程式碼：",[55,190,194],{"className":191,"code":192,"language":193,"meta":60,"style":60},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","\u002F\u002F index.js\nconst getData = async (url) => {\n  try {\n    const response = await fetch(url);\n    const data = await response.text();\n    console.log(data);\n    return data;\n  } catch (error) {\n    console.log(error);\n  }\n}\n\nconst html = getData('https:\u002F\u002Fisraynotarray.com\u002F');\n","js",[62,195,196,202,235,242,261,282,294,303,315,325,331,337,344],{"__ignoreMap":60},[65,197,198],{"class":67,"line":68},[65,199,201],{"class":200},"sGBqm","\u002F\u002F index.js\n",[65,203,204,208,212,215,218,222,226,229,232],{"class":67,"line":79},[65,205,207],{"class":206},"sOudu","const",[65,209,211],{"class":210},"scAaK"," getData",[65,213,214],{"class":206}," =",[65,216,217],{"class":206}," async",[65,219,221],{"class":220},"s8XSl"," (",[65,223,225],{"class":224},"syBk-","url",[65,227,228],{"class":220},") ",[65,230,231],{"class":206},"=>",[65,233,234],{"class":220}," {\n",[65,236,237,240],{"class":67,"line":88},[65,238,239],{"class":206},"  try",[65,241,234],{"class":220},[65,243,244,247,250,252,255,258],{"class":67,"line":100},[65,245,246],{"class":206},"    const",[65,248,249],{"class":82}," response",[65,251,214],{"class":206},[65,253,254],{"class":206}," await",[65,256,257],{"class":210}," fetch",[65,259,260],{"class":220},"(url);\n",[65,262,264,266,269,271,273,276,279],{"class":67,"line":263},5,[65,265,246],{"class":206},[65,267,268],{"class":82}," data",[65,270,214],{"class":206},[65,272,254],{"class":206},[65,274,275],{"class":220}," response.",[65,277,278],{"class":210},"text",[65,280,281],{"class":220},"();\n",[65,283,285,288,291],{"class":67,"line":284},6,[65,286,287],{"class":220},"    console.",[65,289,290],{"class":