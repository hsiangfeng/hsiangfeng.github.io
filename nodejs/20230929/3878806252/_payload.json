,"",[62,63,64,77,86,98],"code",{"__ignoreMap":60},[65,66,69,73],"span",{"class":67,"line":68},"line",1,[65,70,72],{"class":71},"s_sBn","mkdir",[65,74,76],{"class":75},"sTRMh"," example-crawler\n",[65,78,80,84],{"class":67,"line":79},2,[65,81,83],{"class":82},"sCcAr","cd",[65,85,76],{"class":75},[65,87,89,92,95],{"class":67,"line":88},3,[65,90,91],{"class":71},"npm",[65,93,94],{"class":75}," init",[65,96,97],{"class":82}," -y\n",[65,99,101,104],{"class":67,"line":100},4,[65,102,103],{"class":71},"touch",[65,105,106],{"class":75}," index.js\n",[12,108,109],{},"其餘的一些部分我就不再重複說明了，例如什麼 package.json 之類的，所以接下來就直接準備開始實作吧。",[111,112,38],"h3",{"id":38},[12,114,115],{},"其實分析來源很簡單，簡單來講就是你要知道你要爬的網站是什麼，然後你要取得的資料是什麼，這樣就可以了，後面會直接進入實作，所以這邊讓我簡單帶過就好。",[111,117,41],{"id":41},[12,119,120],{},"取得資料的方式有很多種，我們可以透過 HTTP Request 來取得資料，什麼意思呢？簡單來講就是模擬我們打開瀏覽器，並且輸入網址，然後瀏覽器就會幫我們發送 HTTP Request，並且取得資料，這就是一種方式。",[12,122,123,124,131],{},"那我們該怎麼取得呢？你可以透過 ",[125,126,130],"a",{"href":127,"rel":128},"https:\u002F\u002Fgithub.com\u002Faxios\u002Faxios",[129],"nofollow","axios"," 這個套件，因此如果你要使用 axios 的話，你可以先安裝：",[55,133,135],{"className":57,"code":134,"language":59,"meta":60,"style":60},"npm i axios\n",[62,136,137],{"__ignoreMap":60},[65,138,139,141,144],{"class":67,"line":68},[65,140,91],{"class":71},[65,142,143],{"class":75}," i",[65,145,146],{"class":75}," axios\n",[12,148,149,150,152,153,158,159,161],{},"但我這邊並不打算使用 ",[62,151,130],{},"，因為 Node.js 在大概 v18 左右，就已經內建了 ",[125,154,157],{"href":155,"rel":156},"https:\u002F\u002Fnodejs.org\u002Fdist\u002Flatest-v18.x\u002Fdocs\u002Fapi\u002Fglobals.html#fetch",[129],"fetch"," 這個方法，因此我們可以直接使用 ",[62,160,157],{}," 來取得資料。",[163,164,165],"blockquote",{},[12,166,167,171,172,158,174,161],{},[168,169,170],"strong",{},"Note","\nFetch API 原本是瀏覽器才有的方法，但是 Node.js 在 v18 內建支援 ",[62,173,157],{},[62,175,157],{},[12,177,178],{},"那我們目標是誰呢？這邊就先以我的部落格當作範例吧？我的部落格網址是以下",[55,180,182],{"className":57,"code":181,"language":59,"meta":60,"style":60},"https:\u002F\u002Fisraynotarray.com\u0