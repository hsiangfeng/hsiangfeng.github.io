,[36,46,47,48,51],{},"ex: ",[39,49,50],{},"cd \u002FUsers\u002Fusername\u002FDesktop","：移動到桌面",[36,53,54,57],{},[39,55,56],{},"cd ..","：回到上一層資料夾",[36,59,60,63,64],{},[39,61,62],{},"mkdir [資料夾名稱]","：建立資料夾\n",[33,65,66],{},[36,67,47,68,71],{},[39,69,70],{},"mkdir my-project","：建立 my-project 資料夾",[36,73,74,77,78],{},[39,75,76],{},"touch [檔案名稱（副檔名）]","：建立檔案\n",[33,79,80,86],{},[36,81,47,82,85],{},[39,83,84],{},"touch index.js","：建立 index.js 檔案",[36,87,88,89,92],{},"需注意 Windows 系統不支援此指令，請使用 ",[39,90,91],{},"echo > [檔案名稱（副檔名）]"," 代替",[36,94,95,98],{},[39,96,97],{},"ls","：列出當前路徑下的所有檔案與資料夾",[36,100,101,104],{},[39,102,103],{},"ll","：列出當前路徑下的所有檔案與資料夾（包含詳細資訊）",[12,106,107],{},"以上都是最基本、最常見的終端機指令，如果你還不熟悉的話，我會建議你要嘗試去使用並習慣這些指令，因為這些指令在日後的開發上都是非常常用的。",[109,110,113],"callout",{"title":111,"type":112},"Note","note",[12,114,115,116,119,120,123,124,127],{},"副檔名意指檔案的類型，例如：",[39,117,118],{},"index.js"," 的副檔名為 ",[39,121,122],{},".js","，主檔名為 ",[39,125,126],{},"index","，通常作業系統會特別隱藏副檔名，所以如果看不到副檔名的話，你必須特別去作業系統的設定中開啟才看得到。",[20,129,131],{"id":130},"先聊聊-packagejson-吧","先聊聊 Package.json 吧？",[12,133,134],{},"為了讓你可以更習慣終端機的操作，我會希望你試著使用終端機來輸入以下指令",[136,137,142],"pre",{"className":138,"code":139,"language":140,"meta":141,"style":141},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","mkdir example\n","bash","",[39,143,144],{"__ignoreMap":141},[145,146,149,153],"span",{"class":147,"line":148},"line",1,[145,150,152],{"class":151},"smYoP","mkdir",[145,154,156],{"class":155},"sWayO"," example\n",[12,158,159],{},"接著請你移動到 example 資料夾中",[136,161,163],{"className":138,"code":162,"language":140,"meta":141,"style":141},"cd example\n",[39,164,165],{"__ignoreMap":141},[145,166,167,171],{"class":147,"line":148},[145,168,170],{"class":169},"stw71","cd",[145,172,156],{"class":155},[12,174,175],{},"接著請你在 example 這個資料夾下輸入以下指令",[136,177,179],{"className":138,"code":178,"language":140,"meta":141,"style":141},"npm init -y\n",[39,180,181],{"__ignoreMap":141},[145,182,183,186,189],{"class":147,"line":148},[145,184,185],{"class":151},"npm",[145,187,188],{"class":155}," init",[145,190,191],{"class":169}," -y\n",[12,193,194],{},"這時候你用 VSCode 打開這個專案時，應該會長這個樣子",[12,196,197],{},[15,198],{"alt":199,"src":200},"package.json","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fnpm_init.png",[109,202,203],{"title":111,"type":112},[12,204,205,208],{},[39,206,207],{},"npm init -y"," 是一個快速建立 package.json 的指令。",[12,210,211,212,216,217,220,221,224],{},"那麼以上這些行為，我們通常稱之為「",[213,214,215],"strong",{},"初始化專案","」（通常還會有 ",[39,218,219],{},"git init","，但這不是這一篇主軸，因此就沒特別介紹），也就是說我們透過 ",[39,222,223],{},"npm init"," 來初始化專案，這樣子稍後我們才可以安裝套件，為什麼呢？因為我們所有的套件資訊都是寫在 package.json 中，因此我們必須先初始化專案，才能夠安裝套件。",[12,226,227],{},"那麼我們可以看到畫面上有一個 package.json 的檔案，打開後你會看到以下內容",[136,229,233],{"className":230,"code":231,"language":232,"meta":141,"style":141},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  \"name\": \"example\",\n  \"version\": \"1.0.0\",\n  \"description\": \"\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\"\n}\n","json",[39,234,235,241,257,270,283,296,305,328,334,343,355,366],{"__ignoreMap":141},[145,236,237],{"class":147,"line":148},[145,238,240],{"class":239},"s8XSl","{\n",[145,242,244,248,251,254],{"class":147,"line":243},2,[145,245,247],{"class":246},"sWTrB","  \"name\"",[145,249,250],{"class":239},": ",[145,252,253],{"class":155},"\"example\"",[145,255,256],{"class":239},",\n",[145,258,260,263,265,268],{"class":147,"line":259},3,[145,261,262],{"class":246},"  \"version\"",[145,264,250],{"class":239},[145,266,267],{"class":155},"\"1.0.0\"",[145,269,256],{"class":239},[145,271,273,276,278,281],{"class":147,"line":272},4,[145,274,275],{"class":246},"  \"description\"",[145,277,250],{"class":239},[145,279,280],{"class":155},"\"\"",[145,282,256],{"class":239},[145,284,286,289,291,294],{"class":147,"line":285},5,[145,287,288],{"class":246},"  \"main\"",[145,290,250],{"class":239},[145,292,293],{"class":155},"\"index.js\"",[145,295,256],{"class":239},[145,297,299,302],{"class":147,"line":298},6,[145,300,301],{"class":246},"  \"scripts\"",[145,303,304],{"class":239},": {\n",[145,306,308,311,313,316,320,323,325],{"class":147,"line":307},7,[145,309,310],{"class":246},"    \"test\"",[145,312,250],{"class":239},[145,314,315],{"class":155},"\"echo ",[145,317,319],{"class":318},"sbsOT","\\\"",[145,321,322],{"class":155},"Error: no test specified",[145,324,319],{"class":318},[145,326,327],{"class":155}," && exit 1\"\n",[145,329,331],{"class":147,"line":330},8,[145,332,333],{"class":239},"  },\n",[145,335,337,340],{"class":147,"line":336},9,[145,338,339],{"class":246},"  \"keywords\"",[145,341,342],{"class":239},": [],\n",[145,344,346,349,351,353],{"class":147,"line":345},10,[145,347,348],{"class":246},"  \"author\"",[145,350,250],{"class":239},[145,352,280],{"class":155},[145,354,256],{"class":239},[145,356,358,361,363],{"class":147,"line":357},11,[145,359,360],{"class":246},"  \"license\"",[145,362,250],{"class":239},[145,364,365],{"class":155},"\"ISC\"\n",[145,367,369],{"class":147,"line":368},12,[145,370,371],{"class":239},"}\n",[12,373,374],{},"如同前面所言，這個 package.json 會是我們管理套件的地方，因此我們可以透過 package.json 來安裝套件，那麼我們就來安裝第一個套件吧！",[12,376,377,378,381],{},"首先我們先安裝一個套件，也就是 ",[39,379,380],{},"nodemon","，這個套件可以幫助我們在修改程式碼時，自動重新執行程式碼，這樣我們就不用每次都要重新執行程式碼了。",[136,383,385],{"className":138,"code":384,"language":140,"meta":141,"style":141},"npm install nodemon\n",[39,386,387],{"__ignoreMap":141},[145,388,389,391,394],{"class":147,"line":148},[145,390,185],{"class":151},[145,392,393],{"class":155}," install",[145,395,396],{"class":155}," nodemon\n",[12,398,399],{},"安裝完畢後，你會發現 package.json 內容變成以下",[136,401,403],{"className":230,"code":402,"language":232,"meta":141,"style":141},"{\n  \"name\": \"example\",\n  \"version\": \"1.0.0\",\n  \"descripti