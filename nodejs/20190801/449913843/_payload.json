[{"data":1,"prerenderedAt":208},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190801\u002F449913843\u002F":3,"page:\u002Fnodejs\u002F20190801\u002F449913843\u002F":4,"alt:\u002Fnodejs\u002F20190801\u002F449913843\u002F":3,"prev-next:\u002Fnodejs\u002F20190801\u002F449913843\u002F":183,"related:\u002Fnodejs\u002F20190801\u002F449913843\u002F":192},"\u002Fen\u002Fnodejs\u002F2019\u002F08\u002F01\u002Fcommand-not-recognized-as-cmdlet-windows\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":165,"date":166,"description":167,"extension":168,"lang":169,"meta":170,"navigation":171,"path":172,"readingMinutes":173,"seo":174,"standalone":175,"stem":176,"tags":177,"tldr":180,"updated":180,"url":181,"__hash__":182},"content\u002FNodejs\u002F無法辨識-XXX-詞彙是否為-Cmdlet、函數、指令檔或可執行程式的名稱.md","無法辨識 'XXX' 詞彙是否為 Cmdlet、函數、指令檔或可執行程式的名稱","449913843",{"type":9,"value":10,"toc":158},"minimark",[11,15,19,22,48,58,61,64,77,80,83,90,96,99,105,111,116,122,127,138,144,152,155],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這是一個很奇妙的事情，不管我輸入任何一個套件都是出現 無法辨識 xxx 詞彙是否為 Cmdlet、函數指令檔或可執行程式的名稱，所以這一篇來記錄一下徹底解決問題的方法",[12,20,21],{"id":21},"問題",[16,23,24,25,30,31,35,36,39,40,43,44,47],{},"前幾天我撰寫了一篇 ",[26,27,29],"a",{"href":28},"\u002Fhexo\u002F20190730\u002F884035779\u002F","Hexo 指令失效"," 的文章，後來我今天要輸入其他 ",[32,33,34],"code",{},"npm"," 指令 ",[32,37,38],{},"vue cli","、",[32,41,42],{},"express"," 以及 ",[32,45,46],{},"koa"," 全都是出現",[49,50,56],"pre",{"className":51,"code":53,"language":54,"meta":55},[52],"language-text","XXX : 無法辨識 'XXX' 詞彙是否為 Cmdlet、函數、指令檔或可執行程式的名稱。請檢查名稱拼字\n是否正確，如果包含路徑的話，請確認路徑是否正確，然後再試一次。\n位於 線路:1 字元:1\n+ XXX s\n+ ~~~~\n    + CategoryInfo          : ObjectNotFound: (XXX:String) [], CommandNotFoundExceptio\n   n\n    + FullyQualifiedErrorId : CommandNotFoundException\n","text","",[32,57,53],{"__ignoreMap":55},[16,59,60],{},"(XXX > 代表你輸入的指令)",[16,62,63],{},"後來我嘗試了以下做法",[65,66,67,71,74],"ul",{},[68,69,70],"li",{},"移除 Yarn (發生事情前一天我是安裝 Yarn)",[68,72,73],{},"移除 Composer (發生事情前一天我有安裝 Composer)",[68,75,76],{},"重新安裝 Node.js",[16,78,79],{},"以上結果通通無效，所以下面就來講一下該如何解決這個問題",[12,81,82],{"id":82},"解決方式",[16,84,85,86],{},"首先先開啟控制台\u002F系統及安全性\u002F系統，然後點",[87,88,89],"strong",{},"進階系統設定",[16,91,92],{},[93,94],"img",{"alt":89,"src":95},"https:\u002F\u002Fi.imgur.com\u002FvblSJcg.png",[16,97,98],{},"接下來進階\u002F環境變數",[16,100,101],{},[93,102],{"alt":103,"src":104},"環境變數","https:\u002F\u002Fi.imgur.com\u002FF5nIfHs.png",[16,106,107,108],{},"在下方系統環境變數中找到 ",[87,109,110],{},"Path",[16,112,113],{},[93,114],{"alt":110,"src":115},"https:\u002F\u002Fi.imgur.com\u002FsNnUoeJ.png",[16,117,118,119],{},"接下來點",[87,120,121],{},"瀏覽",[16,123,124],{},[93,125],{"alt":121,"src":126},"https:\u002F\u002Fi.imgur.com\u002FOSBG361.png",[16,128,129,130,133,134,137],{},"找到你的 npm 目錄並指定到該 npm 目錄，通常是 ",[32,131,132],{},"C:\\Users\\username\\AppData\\Roaming\\npm"," (username 請換成你的使用者名稱)\n(例如我的是 ",[32,135,136],{},"C:\\Users\\Hsiangfeng\\AppData\\Roaming\\npm",")",[16,139,140],{},[93,141],{"alt":142,"src":143},"Image","https:\u002F\u002Fi.imgur.com\u002Fe6gGNKT.png",[16,145,146,147,39,149,151],{},"最後你重新打開 CMD or PowerShell 就可以輸入 ",[32,148,38],{},[32,150,42],{}," 任何指令了",[12,153,154],{"id":154},"結尾",[16,156,157],{},"至於問題為何發生呢?我也不知道，甚至找不出原因，但是問題解決了就好哩~",{"title":55,"searchDepth":159,"depth":159,"links":160},2,[161,162,163,164],{"id":14,"depth":159,"text":14},{"id":21,"depth":159,"text":21},{"id":82,"depth":159,"text":82},{"id":154,"depth":159,"text":154},"Nodejs","2019-08-01 10:28:33","Windows PowerShell 突然每個指令都跳「無法辨識 XXX 詞彙是否為 Cmdlet」？這一篇分享我試過移除套件、重裝 Node 都無效之後， 從環境變數 Path 找到的真正解法。","md","zh-Hant",{},true,"\u002Fnodejs\u002Fxxx-cmdlet","1",{"title":6,"description":167},false,"Nodejs\u002F無法辨識-XXX-詞彙是否為-Cmdlet、函數、指令檔或可執行程式的名稱",[178,179],"Node.js","障礙排除",null,"\u002Fnodejs\u002F20190801\u002F449913843\u002F","xluCJo6q9CUDgCZxaR3IYBN4BV6kvwLYzuZFfnqF7Q0",{"newer":184,"older":188},{"url":185,"title":186,"date":187},"\u002Fvue\u002F20190801\u002F1336347183\u002F","Vue 出一個女友吧!-中場休息","2019-08-01 10:54:29",{"url":189,"title":190,"date":191},"\u002Fphp\u002F20190731\u002F2973745480\u002F","Laravel-Vue ESLint 在 VSCode 上無法靜態使用的問題","2019-07-31 14:49:14",[193,198,203],{"url":194,"title":195,"date":196,"readingMinutes":197},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":199,"title":200,"date":201,"readingMinutes":202},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":204,"title":205,"date":206,"readingMinutes":207},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784020393483]