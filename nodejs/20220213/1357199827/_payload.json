[{"data":1,"prerenderedAt":239},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20220213\u002F1357199827\u002F":3,"page:\u002Fnodejs\u002F20220213\u002F1357199827\u002F":4,"alt:\u002Fnodejs\u002F20220213\u002F1357199827\u002F":3,"prev-next:\u002Fnodejs\u002F20220213\u002F1357199827\u002F":215,"related:\u002Fnodejs\u002F20220213\u002F1357199827\u002F":224},"\u002Fen\u002Fnodejs\u002F2022\u002F02\u002F13\u002Fmango-fullstack-01-meet-and-install-mongodb\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":196,"date":197,"description":18,"extension":198,"lang":199,"meta":200,"navigation":201,"path":202,"readingMinutes":203,"seo":204,"standalone":205,"stem":206,"tags":207,"tldr":212,"updated":212,"url":213,"__hash__":214},"content\u002F被迫吃芒果的前端工程師\u002F1-被迫吃芒果的前端工程師-認識-MongoDB-與安裝-MongoDB.md","(1)被迫吃芒果的前端工程師 - 認識 MongoDB 與安裝 MongoDB","1357199827",{"type":9,"value":10,"toc":189},"minimark",[11,15,19,23,31,34,37,46,49,52,74,77,80,84,87,110,118,128,135,142,146,149,158,161,170,173,176,185],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"又是一個新的學習紀錄，這次的學習紀錄是 MongoDB，那因為 Mongo 唸起來很像芒果，所以這一次主題就取名為「被迫吃芒果的全端工程師」。",[12,20,22],{"id":21},"mongodb","MongoDB",[16,24,25,26,30],{},"那麼什麼是 MongoDB 呢？MongoDB 是一套以文件 (",[27,28,29],"code",{},"document",") 導向的資料庫管理系統，也是所謂的 NoSQL 資料庫。",[16,32,33],{},"NoSQL 又稱之為非關聯式資料庫，以 SQL (關聯式資料庫)為舉例的話，SQL 主要是以 Tables 的表格形式來儲存資料，而 NoSQL 則是用 JSON 的形式來儲存資料，因此在 NoSQL 中會很常看到 JSON 格式。",[16,35,36],{},"題外話一下，在 MongoDB 中並不是稱之為 JSON 而是 BSON。",[16,38,39,40,45],{},"JSON 由來如果你不清楚的話，可以參考我先前寫的文章 ",[41,42,44],"a",{"href":43},"\u002Fjavascript\u002F20201112\u002F8535\u002F","JavaScript 核心觀念(32)-物件-JSON","，因此這邊不會再次贅述。",[16,47,48],{},"那什麼是 BSON 呢？BSON 全名是 Binary JSON。",[16,50,51],{},"主要是為了更快的解析與效能，因此改採用二進制的方式編碼，因此 Binary JSON 所提供的資料類型就會相當多，以官方文件講得如下",[53,54,55,59,62,65,68,71],"ul",{},[56,57,58],"li",{},"String",[56,60,61],{},"Boolean",[56,63,64],{},"Number (Integer, Float, Long, Decimal128...)",[56,66,67],{},"Array",[56,69,70],{},"Date",[56,72,73],{},"Raw Binary",[16,75,76],{},"相較原本的 JSON 來講可以儲存的資料類型會較多，畢竟 JSON 只能儲存 String、Boolean、Number 與 Array 而已。",[16,78,79],{},"那因為 BSON 採用的是二進制關係，因此是無法閱讀的，僅限電腦可以閱讀，反之 JSON 則是人與電腦都可以讀得懂，因此我們得出一個結論 MongoDB 是一個 NoSQL 且使用 BSON 格式來儲存資料的資料庫系統。",[12,81,83],{"id":82},"安裝-mongodb","安裝 MongoDB",[16,85,86],{},"安裝 MongoDB 的方式非常簡單，如果你是 Mac 的話，只需要透過 Homebrew 然後依序輸入以下指令即可安裝完畢",[88,89,94],"pre",{"className":90,"code":91,"language":92,"meta":93,"style":93},"language-cmd shiki shiki-themes github-dark-high-contrast","brew tap mongodb\u002Fbrew\nbrew install mongodb-community@5.0\n","cmd","",[27,95,96,104],{"__ignoreMap":93},[97,98,101],"span",{"class":99,"line":100},"line",1,[97,102,103],{},"brew tap mongodb\u002Fbrew\n",[97,105,107],{"class":99,"line":106},2,[97,108,109],{},"brew install mongodb-community@5.0\n",[16,111,112,113,117],{},"如果你不知道 Homebrew 是什麼的話，你可以參考我先前寫的",[41,114,116],{"href":115},"\u002Fpython\u002F20210904\u002F2075223567\u002F","這一篇","介紹過。",[16,119,120,121,127],{},"Window 部分只需要到該",[41,122,126],{"href":123,"rel":124},"https:\u002F\u002Fwww.mongodb.com\u002Ftry\u002Fdownload\u002Fcommunity",[125],"nofollow","網址"," 即可下載安裝檔案，安裝過程基本上一直下一步就可以了。",[16,129,130,131,134],{},"那如果知道自己是否有安裝成功？基本上只要在終端機輸入 ",[27,132,133],{},"mongo"," 只要有出現以下畫面，那麼恭喜你，你已經安裝成功了",[16,136,137],{},[138,139],"img",{"alt":140,"src":141},"安裝成功","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-22%2014.18.24.png",[12,143,145],{"id":144},"啟動與暫停-mongodb","啟動與暫停 MongoDB",[16,147,148],{},"如果你想要暫停 MongoDB 的話是輸入以下",[88,150,152],{"className":90,"code":151,"language":92,"meta":93,"style":93},"brew services stop mongodb-community@5.0\n",[27,153,154],{"__ignoreMap":93},[97,155,156],{"class":99,"line":100},[97,157,151],{},[16,159,160],{},"反之啟動則是",[88,162,164],{"className":90,"code":163,"language":92,"meta":93,"style":93},"brew services start mongodb-community@5.0\n",[27,165,166],{"__ignoreMap":93},[97,167,168],{"class":99,"line":100},[97,169,163],{},[16,171,172],{},"以上主要是針對 macOS，如果是 Windows 的的話則是到 Windows 服務中啟動或停止即可。",[12,174,175],{"id":175},"參考文件",[53,177,178],{},[56,179,180],{},[41,181,184],{"href":182,"rel":183},"https:\u002F\u002Fwww.mongodb.com\u002Fjson-and-bson",[125],"JSON to BSON",[186,187,188],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":93,"searchDepth":106,"depth":106,"links":190},[191,192,193,194,195],{"id":14,"depth":106,"text":14},{"id":21,"depth":106,"text":22},{"id":82,"depth":106,"text":83},{"id":144,"depth":106,"text":145},{"id":175,"depth":106,"text":175},"Nodejs","2022-02-13 20:45:50","md","zh-Hant",{},true,"\u002F1-mongodb-mongodb","2",{"title":6,"description":18},false,"被迫吃芒果的前端工程師\u002F1-被迫吃芒果的前端工程師-認識-MongoDB-與安裝-MongoDB",[22,208,209,210,211],"Node.js","Mac","Window","被迫吃芒果的前端工程師",null,"\u002Fnodejs\u002F20220213\u002F1357199827\u002F","96Yhm_E4XuDejlhoFCXbSs49q5rgSt6p04HClVBbKcY",{"newer":216,"older":220},{"url":217,"title":218,"date":219},"\u002Fnodejs\u002F20220214\u002F2786492944\u002F","(2)被迫吃芒果的前端工程師 - MongoDB Basic","2022-02-14 15:01:45",{"url":221,"title":222,"date":223},"\u002Fother\u002F20220211\u002F2705866340\u002F","用 Google Apps Script 搭配 Google 試算表開一個 API","2022-02-11 09:48:18",[225,229,234],{"url":226,"title":227,"date":228,"readingMinutes":203},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28",{"url":230,"title":231,"date":232,"readingMinutes":233},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":235,"title":236,"date":237,"readingMinutes":238},