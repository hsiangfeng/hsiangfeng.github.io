[{"data":1,"prerenderedAt":478},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20220227\u002F1934733921\u002F":3,"page:\u002Fnodejs\u002F20220227\u002F1934733921\u002F":4,"alt:\u002Fnodejs\u002F20220227\u002F1934733921\u002F":3,"prev-next:\u002Fnodejs\u002F20220227\u002F1934733921\u002F":454,"related:\u002Fnodejs\u002F20220227\u002F1934733921\u002F":463},"\u002Fen\u002Fnodejs\u002F2022\u002F02\u002F27\u002Fforced-to-eat-mango-14-mongoose-update\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":434,"date":435,"description":18,"extension":436,"lang":437,"meta":438,"navigation":439,"path":440,"readingMinutes":441,"seo":442,"standalone":443,"stem":444,"tags":445,"tldr":451,"updated":451,"url":452,"__hash__":453},"content\u002F被迫吃芒果的前端工程師\u002F14-被迫吃芒果的前端工程師-Mongoose-之-Update.md","(14)被迫吃芒果的前端工程師 - Mongoose 之 Update","1934733921",{"type":9,"value":10,"toc":430},"minimark",[11,15,19,23,43,158,161,167,174,186,189,203,208,254,265,297,311,407,412,426],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面認識了查詢語法，那麼接下來就要認識更新的語法，在 Mongoose 中更新的語法是與 MongoDB 稍微有一點不同的，但本質上並不會太難，所以就來認識一下吧。",[12,20,22],{"id":21},"update","Update",[16,24,25,26,30,31,34,35,38,39,42],{},"在 Mongoose 中一樣是支援 ",[27,28,29],"code",{},"updateOne","、",[27,32,33],{},"updateMany"," 與 ",[27,36,37],{},"replaceOne"," 語法的，但是在這邊並不是使用 ",[27,40,41],{},"$set"," 語法，而是直接寫要更新成怎樣",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-js shiki shiki-themes github-dark-high-contrast","User.updateOne(\n  {\n    nickname: 'RayXu'\n  },\n  {\n    nickname: 'Ray'\n  }\n).then((data) => {\n  console.log('data', data);\n})\n","js","",[27,51,52,67,73,83,89,94,102,108,134,152],{"__ignoreMap":49},[53,54,57,61,64],"span",{"class":55,"line":56},"line",1,[53,58,60],{"class":59},"sMAXC","User.",[53,62,29],{"class":63},"sj_SG",[53,65,66],{"class":59},"(\n",[53,68,70],{"class":55,"line":69},2,[53,71,72],{"class":59},"  {\n",[53,74,76,79],{"class":55,"line":75},3,[53,77,78],{"class":59},"    nickname: ",[53,80,82],{"class":81},"sTRMh","'RayXu'\n",[53,84,86],{"class":55,"line":85},4,[53,87,88],{"class":59},"  },\n",[53,90,92],{"class":55,"line":91},5,[53,93,72],{"class":59},[53,95,97,99],{"class":55,"line":96},6,[53,98,78],{"class":59},[53,100,101],{"class":81},"'Ray'\n",[53,103,105],{"class":55,"line":104},7,[53,106,107],{"class":59},"  }\n",[53,109,111,114,117,120,124,127,131],{"class":55,"line":110},8,[53,112,113],{"class":59},").",[53,115,116],{"class":63},"then",[53,118,119],{"class":59},"((",[53,121,123],{"class":122},"s_sBn","data",[53,125,126],{"class":59},") ",[53,128,130],{"class":129},"sWyjQ","=>",[53,132,133],{"class":59}," {\n",[53,135,137,140,143,146,149],{"class":55,"line":136},9,[53,138,139],{"class":59},"  console.",[53,141,142],{"class":63},"log",[53,144,145],{"class":59},"(",[53,147,148],{"class":81},"'data'",[53,150,151],{"class":59},", data);\n",[53,153,155],{"class":55,"line":154},10,[53,156,157],{"class":59},"})\n",[16,159,160],{},"更新成功後也一樣會回傳給你一些資訊",[16,162,163],{},[164,165],"img",{"alt":29,"src":166},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-31%2021.32.09.png",[16,168,169,170,173],{},"如果你想確定自己是否修改成功的話，那麼也可以自己試試看前面章節所學的 ",[27,171,172],{},"find"," 語法。",[16,175,176,177,179,180,182,183,185],{},"另一個 ",[27,178,33],{}," 跟 ",[27,181,37],{}," 就不示範了，畢竟概念相同只是變成了不用寫 ",[27,184,41],{}," 而已。",[16,187,188],{},"難道 Mongoose 就只有這樣嗎？其實 Mongoose 還有提供其他更新語法",[190,191,192,198],"ul",{},[193,194,195],"li",{},[27,196,197],{},"findByIdAndUpdate",[193,199,200],{},[27,201,202],{},"findOneAndUpdate",[16,204,205,206],{},"光看上方語法就可以很直覺知道分別是搜尋 ID 並更新以及搜尋並更新，那寫法有差嗎？讓我們先來看一下 ",[27,207,202],{},[44,209,211],{"className":46,"code":210,"language":48,"meta":49,"style":49},"User.findOneAndUpdate(\n  {\n    nickname: 'Ray'\n  },\n  {\n    nickname: 'RayXu'\n  }\n)\n",[27,212,213,221,225,231,235,239,245,249],{"__ignoreMap":49},[53,214,215,217,219],{"class":55,"line":56},[53,216,60],{"class":59},[53,218,202],{"class":63},[53,220,66],{"class":59},[53,222,223],{"class":55,"line":69},[53,224,72],{"class":59},[53,226,227,229],{"class":55,"line":75},[53,228,78],{"class":59},[53,230,101],{"class":81},[53,232,233],{"class":55,"line":85},[53,234,88],{"class":59},[53,236,237],{"class":55,"line":91},[53,238,72],{"class":59},[53,240,241,243],{"class":55,"line":96},[53,242,78],{"class":59},[53,244,82],{"class":81},[53,246,247],{"class":55,"line":104},[53,248,107],{"class":59},[53,250,251],{"class":55,"line":110},[53,252,253],{"class":59},")\n",[16,255,256,257,259,260,34,262,264],{},"你會發現好像跟使用 ",[27,258,21],{}," 沒有什麼差異，但其實真正差異在於 ",[27,261,202],{},[27,263,197],{}," 可以設置第三個參數，以下截至官方文件",[190,266,267,270,273,276,279,282,285,288,291,294],{},[193,268,269],{},"new: bool - true to return the modified document rather than the original. defaults to false",[193,271,272],{},"upsert: bool - creates the object if it doesn't exist. defaults to false.",[193,274,275],{},"overwrite: bool - if true, replace the entire document.",[193,277,278],{},"fields: {Object|String} - Field selection. Equivalent to .select(fields).findOneAndUpdate()",[193,280,281],{},"maxTimeMS: puts a time limit on the query - requires mongodb >= 2.6.0",[193,283,284],{},"sort: if multiple docs are found by the conditions, sets the sort order to choose which doc to update",[193,286,287],{},"runValidators: if true, runs update validators on this command. Update validators validate the update operation against the model's schema.",[193,289,290],{},"setDefaultsOnInsert: true by default. If setDefaultsOnInsert and upsert are true, mongoose will apply the defaults specified in the model's schema if a new document is created.",[193,292,293],{},"rawResult: if true, returns the raw result from the MongoDB driver",[193,295,296],{},"strict: overwrites the schema's strict mode option for this update",[16,298,299,300,303,304,306,307,310],{},"但通常來講我們並不會使用全部的參數，而只會使用特定參數，例如 ",[27,301,302],{},"new"," 參數就非常好用，因為預設修改成功後 Mongoose 只會回傳修改的資訊，而不會回傳修改成功的資料，如果期望結果是修改成功後會回傳修改成功的資料的話，那麼就將 ",[27,305,302],{}," 改為 ",[27,308,309],{},"true"," 即可。",[44,312,314],{"className":46,"code":313,"language":48,"meta":49,"style":49},"User.findOneAndUpdate(\n  {\n    nickname: 'Ray'\n  },\n  {\n    nickname: 'RayXu'\n  },\n  {\n    new: true,\n  }\n).then((data) => {\n  console.log('data', data)\n})\n",[27,315,316,324,328,334,338,342,348,352,356,367,371,388,402],{"__ignoreMap":49},[53,317,318,320,322],{"class":55,"line":56},[53,319,60],{"class":59},[53,321,202],{"class":63},[53,323,66],{"class":59},[53,325,326],{"class":55,"line":69},[53,327,72],{"class":59},[53,329,330,332],{"class":55,"line":75},[53,331,78],{"class":59},[53,333,101],{"class":81},[53,335,336],{"class":55,"line":85},[53,337,88],{"class":59},[53,339,340],{"class":55,"line":91},[53,341,72],{"class":59},[53,343,344,346],{"class":55,"line":96},[53,345,78],{"class":59},[53,347,82],{"class":81},[53,349,350],{"class":55,"line":104},[53,351,88],{"class":59},[53,353,354],{"class":55,"line":110},[53,355,72],{"class":59},[53,357,358,361,364],{"class":55,"line":136},[53,359,360],{"class":59},"    new: ",[53,362,309],{"class":363},"sCcAr",[53,365,366],{"class":59},",\n",[53,368,369],{"class":55,"line":154},[53,370,107],{"class":59},[53,372,374,376,378,380,382,384,386],{"class":55,"line":373},11,[53,375,113],{"class":59},[53,377,116],{"class":63},[53,379,119],{"class":59},[53,381,123],{"class":122},[53,383,126],{"class":59},[53,385,130],{"class":129},[53,387,133],{"class":59},[53,389,391,393,395,397,399],{"class":55,"line":390},12,[53,392,139],{"class":59},[53,394,142],{"class":63},[53,396,145],{"class":59},[53,398,148],{"class":81},[53,400,401],{"class":59},", data)\n",[53,403,405],{"class":55,"line":404},13,[53,406,157],{"class":59},[16,408,409],{},[164,410],{"alt":202,"src":411},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202022-01-31%2021.51.24.png",[16,413,414,415,179,417,419,420,422,423,425],{},"那麼 ",[27,416,21],{},[27