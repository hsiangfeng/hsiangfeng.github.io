[{"data":1,"prerenderedAt":1058},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20231004\u002F1031795777\u002F":3,"page:\u002Fnodejs\u002F20231004\u002F1031795777\u002F":4,"alt:\u002Fnodejs\u002F20231004\u002F1031795777\u002F":3,"prev-next:\u002Fnodejs\u002F20231004\u002F1031795777\u002F":1033,"related:\u002Fnodejs\u002F20231004\u002F1031795777\u002F":1042},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F04\u002Fday-20-what-is-a-discord-bot\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1018,"date":1019,"description":25,"extension":1020,"lang":1021,"meta":1022,"navigation":377,"path":1023,"readingMinutes":787,"seo":1024,"standalone":1025,"stem":1026,"tags":1027,"tldr":1030,"updated":1019,"url":1031,"__hash__":1032},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay20-Discord-Bot？.md","Day20 - Discord Bot？","1031795777",{"type":9,"value":10,"toc":1009},"minimark",[11,19,23,26,30,33,44,50,53,59,62,68,71,77,83,89,92,110,113,119,122,128,138,144,156,159,165,178,181,184,236,243,258,261,268,271,287,290,299,303,306,654,661,673,676,682,689,811,818,822,825,985,996,1002,1005],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Discord Bot","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_discord_bot_7ffc90d7-a1fd-4705-8a01-7c982263c868.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"除了爬蟲之外，Node.js 可以做的事情其實非常多，所以接下來將會介紹一些其他的應用的實作，也就是 Bot。",[20,27,29],{"id":28},"bot","Bot？",[12,31,32],{},"Bot 是什麼呢？我相信你應該看過不少人家說 Line Bot、Discord Bot 以及 Slack Bot，那麼這些 Bot 是什麼呢？簡單來說，Bot 就是一個自動化的程式，可以幫助你自動化一些事情，例如：自動回覆訊息、自動發送訊息、自動發送 Email 等等。",[12,34,35,36,43],{},"那我們這次要示範什麼呢？這次我打算示範一個 Discord Bot，但是在那之前我會建議你準備好一個 Discord 伺服器，並且到「",[37,38,42],"a",{"href":39,"rel":40},"https:\u002F\u002Fdiscord.com\u002Fdevelopers\u002Fdocs\u002Fintro",[41],"nofollow","Developer Portal","」建立一個機器人，如下圖點一下 Applications",[12,45,46],{},[15,47],{"alt":48,"src":49},"Applications","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_1.jpg",[12,51,52],{},"接著點一下上方的 New Application",[12,54,55],{},[15,56],{"alt":57,"src":58},"New Application","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_2.jpg",[12,60,61],{},"名稱的話，看你自己需求，我命名為「node-ithelp-2023」",[12,63,64],{},[15,65],{"alt":66,"src":67},"New Application 2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_3.jpg",[12,69,70],{},"新增完畢後，找到你剛剛新增的 Application，然後點一下左邊的 Bot，接著你可以找到「Reset Token」按鈕，點一下就可以取得 Token",[12,72,73],{},[15,74],{"alt":75,"src":76},"Get Token","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_4.jpg",[12,78,79],{},[80,81,82],"strong",{},"請注意這個 Token 不要外流，稍後我們練習會使用到。",[12,84,85],{},[15,86],{"alt":87,"src":88},"Token 很重要","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002F1694789575685.png",[12,90,91],{},"Token 大概會長這樣（底下不用擔心，我已經把 Token 換掉了）：",[93,94,99],"pre",{"className":95,"code":96,"language":97,"meta":98,"style":98},"language-bash shiki shiki-themes github-dark-high-contrast","MTE0ODExxxxxxxxxxxxxxxxxx.GJ6bFp.t1h86ISWswdqidu173ydwmawd1213P9mNj9qbXlhI\n","bash","",[100,101,102],"code",{"__ignoreMap":98},[103,104,107],"span",{"class":105,"line":106},"line",1,[103,108,96],{"class":109},"s_sBn",[12,111,112],{},"接下來，我們可能有些操作會需要一些權限，所以麻煩往下滾到「Privileged Gateway Intents」，這個區塊主要是操作權限，底下要請你把底下的權限都打開，如下圖：",[12,114,115],{},[15,116],{"alt":117,"src":118},"Privileged Gateway Intents","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_5.jpg",[12,120,121],{},"最後我們就是要把這個 Bot 加入到我們的伺服器，所以點一下「OAuth2」取得 Client ID",[12,123,124],{},[15,125],{"alt":126,"src":127},"Client ID","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_client_id.jpg",[12,129,130,131,133,134,137],{},"取得後接著點「Url Generator」，並勾選 ",[100,132,28],{}," 與 ",[100,135,136],{},"Administrator","，如下圖：",[12,139,140],{},[15,141],{"alt":142,"src":143},"Discord Url","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_6.jpg",[145,146,147],"blockquote",{},[12,148,149,152,153,155],{},[80,150,151],{},"Note","\n為了方便練習才選 ",[80,154,136],{},"，實際開發上還是會依照 Bot 的需求來設定權限。",[12,157,158],{},"最後你往下滾就可以看到邀請連結了，複製下來貼上到瀏覽器，然後選擇你要加入的伺服器就搞定囉！",[12,160,161],{},[15,162],{"alt":163,"src":164},"Discord Url 2","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fdiscord_bot_url.jpg",[145,166,167],{},[12,168,169,171,172,177],{},[80,170,151],{},"\nDiscord 是一款遊戲社群軟體（許多技術社群也都陸續轉移到此軟體），你可以在上面建立一個伺服器，然後邀請你的朋友一起加入，然後你們就可以在上面聊天、玩遊戲等等，如果你有興趣的話，可以參考我這一篇文章「",[37,173,176],{"href":174,"rel":175},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20220428\u002F1571298383\u002F",[41],"Discord 好難？不怕！我教你！","」。",[20,179,180],{"id":180},"專案環境",[12,182,183],{},"首先我們先來建立一個專案",[93,185,187],{"className":95,"code":186,"language":97,"meta":98,"style":98},"mkdir discord-bot-example\ncd discord-bot-example\nnpm init -y\ntouch index.js\ntouch register.js\n",[100,188,189,198,207,219,228],{"__ignoreMap":98},[103,190,191,194],{"class":105,"line":106},[103,192,193],{"class":109},"mkdir",[103,195,197],{"class":196},"sTRMh"," discord-bot-example\n",[103,199,201,205],{"class":105,"line":200},2,[103,202,204],{"class":203},"sCcAr","cd",[103,206,197],{"class":196},[103,208,210,213,216],{"class":105,"line":209},3,[103,211,212],{"class":109},"npm",[103,214,215],{"class":196}," init",[103,217,218],{"class":203}," -y\n",[103,220,222,225],{"class":105,"line":221},4,[103,223,224],{"class":109},"touch",[103,226,227],{"class":196}," index.js\n",[103,229,231,233],{"class":105,"line":230},5,[103,232,224],{"class":109},[103,234,235],{"class":196}," register.js\n",[12,237,238,239,242],{},"接下來我們要來安裝 ",[100,240,241],{},"discord.js"," 套件，這個套件是用來實作 Discord Bot 的，所以我們必須要安裝這個套件",[93,244,246],{"className":95,"code":245,"language":97,"meta":98,"style":98},"npm i discord.js\n",[100,247,248],{"__ignoreMap":98},[103,249,250,252,255],{"class":105,"line":106},[103,251,212],{"class":109},[103,253,254],{"class":196}," i",[103,256,257],{"class":196}," discord.js\n",[12,259,260],{},"這是由 Discord 官方所提供的套件，所以你可以放心的使用。",[145,262,263],{},[12,264,265,267],{},[80,266,151],{},"\n如果你熟悉其他語言的話，也可以嘗試使用 Python、Go 等套件唷！",[12,269,270],{},"這邊有件事情我要特別提醒一下，由於接下來的實作我們要使用比較新版的 Discord Bot，所以建議你切換到 Node.js 18 會比較好唷！",[93,272,274],{"className":95,"code":273,"language":97,"meta":98,"style":98},"nvm use 18\n",[100,275,276],{"__ignoreMap":98},[103,277,278,281,284],{"class":105,"line":106},[103,279,280],{"class":109},"nvm",[103,282,283],{"class":196}," use",[103,285,286],{"class":203}," 18\n",[20,288,289],{"id":289},"實作",[12,291,292,293,298],{},"接下來我們會來實作一個簡易的 Discord Bot，那麼該怎麼起手呢？其實",[37,294,297],{"href":295,"rel":296},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fdiscord.js",[41],"官方文件","都有提供範例程式碼，但官方程式碼是基於 ES6 的語法，所以底下我還是會介紹一下。",[300,301,302],"h3",{"id":302},"註冊指令",[12,304,305],{},"首先我們來看第一個範例，也就是註冊指令，不用擔心，這邊我會逐行補上註解說明：",[93,307,311],{"className":308,"code":309,"language":310,"meta":98,"style":98},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F register.js\nconst {\n  REST, \u002F\u002F 引入 REST\n  Routes \u002F\u002F 引入 Routes\n} = require('discord.js'); \u002F\u002F 引入 discord.js 套件\n\n\u002F\u002F 指令表\nconst list = [\n  {\n    name: 'ping', \u002F\u002F 指令名稱\n    description: 'Replies with Pong!', \u002F\u002F 指令描述\n  },\n];\n\n\u002F\u002F 實例化 REST，並設定版本與 Token\nconst rest = new REST({ version: '10' }).setToken(TOKEN);\n\nconst registerCommands = async (commands) => {\n  try {\n    console.log('Started refreshing application (\u002F) commands.');\n    \u002F\u002F 註冊指令\n    await rest.put(Routes.applicationCommands(CLIENT_ID), { body: commands });\n\n    console.log('Successfully reloaded application (\u002F) commands.');\n  } catch (error) {\n    console.error(error);\n  }\n}\n\n\u002F\u002F 執行註冊指令\nregisterCommands(list);\n","js",[100,312,313,319,329,340,348,372,379,385,399,405,419,433,439,445,450,456,492,497,524,532,548,554,580,585,599,611,622,628,634,639,645],{"__ignoreMap":98},[103,314,315],{"class":105,"line":106},[103,316,318],{"class":317},"sQrFR","\u002F\u002F register.js\n",[103,320,321,325],{"class":105,"line":200},[103,322,324],{"class":323},"sWyjQ","const",[103,326,328],{"class":327},"sMAXC"," {\n",[103,330,331,334,337],{"class":105,"line":209},[103,332,333],{"class":203},"  REST",[103,335,336],{"class":327},", ",[103,338,339],{"class":317},"\u002F\u002F 引入 REST\n",[103,341,342,345],{"class":105,"line":221},[103,343,344],{"class":203},"  Routes",[103,346,347],{"class":317}," \u002F\u002F 引入 Routes\n",[103,349,350,353,356,360,363,366,369],{"class":105,"line":230},[103,351,352],{"class":327},"} ",[103,354,355],{"class":323},"=",[103,357,359],{"class":358},"sj_SG"," require",[103,361,362],{"class":327},"(",[103,364,365],{"class":196},"'discord.js'",[103,367,368],{"class":327},"); ",[103,370,371],{"class":317},"\u002F\u002F 引入 discord.js 套件\n",[103,373,375],{"class":105,"line":374},6,[103,376,378],{"emptyLinePlaceholder":377},true,"\n",[103,380,382],{"class":105,"line":381},7,[103,383,384],{"class":317},"\u002F\u002F 指令表\n",[103,386,388,390,393,396],{"class":105,"line":387},8,[103,389,324],{"class":323},[103,391,392],{"class":203}," list",[103,394,395],{"class":323}," =",[103,397,398],{"class":327}," [\n",[103,400,402],{"class":105,"line":401},9,[103,403,404],{"class":327},"  {\n",[103,406,408,411,414,416],{"class":105,"line":407},10,[103,409,410],{"class":327},"    name: ",[103,412,413],{"class":196},"'ping'",[103,415,336],{"class":327},[103,417,418],{"class":317},"\u002F\u002F 指令名稱\n",[103,420,422,425,428,430],{"class":105,"line":421},11,[103,423,424],{"class":327},"    description: ",[103,426,427],{"class":196},"'Replies with Pong!'",[103,429,336],{"