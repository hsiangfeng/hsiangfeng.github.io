[{"data":1,"prerenderedAt":145},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190628\u002F905867989\u002F":3,"page:\u002Fnodejs\u002F20190628\u002F905867989\u002F":4,"alt:\u002Fnodejs\u002F20190628\u002F905867989\u002F":3,"prev-next:\u002Fnodejs\u002F20190628\u002F905867989\u002F":120,"related:\u002Fnodejs\u002F20190628\u002F905867989\u002F":129},"\u002Fen\u002Fnodejs\u002F2019\u002F06\u002F28\u002Fnodejs-firebase-create-project\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":103,"date":104,"description":18,"extension":105,"lang":106,"meta":107,"navigation":108,"path":109,"readingMinutes":110,"seo":111,"standalone":112,"stem":113,"tags":114,"tldr":117,"updated":117,"url":118,"__hash__":119},"content\u002F全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-Firebase-建立專案.md","全端勇士之路 Node.js 基礎學習-Firebase 建立專案","905867989",{"type":9,"value":10,"toc":96},"minimark",[11,15,19,23,26,34,37,46,50,58,65,68,74,77,82,87,90],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"由於接下來可能將會透過 firebase 來實作一些東西，所以這邊就必須了解基礎的 firebase。",[12,20,22],{"id":21},"firebase-是什麼","Firebase 是什麼?",[16,24,25],{},"是 Google 底下其中之一的子產品，那它是一個同時擁有支援 Android、iOS、Web 網頁開發的 APP 平台，可以說是非常的強大，那這邊主要會使用到它的資料庫也就是 Firebase，而 Firebase 是一個雲端 NoSQL 資料庫。",[16,27,28,29,33],{},"那 NoSQL 是什麼呢?基本上 NoSQL 概念每一間制訂的規則都不太一樣，所以這邊就單純只用 Wiki 的一小段簡單重點來介紹，簡單來講 NoSQL 就是",[30,31,32],"strong",{},"不使用 SQL 指令作為查詢語言","，所以你可能也會看到有人這樣稱呼 NoSQL → Not Only SQL (不只是 SQL 的意思)",[16,35,36],{},"而使用 NoSQL 有很高的擴展性，當今天資料滿的時候只需要加裝機器即可擴展，如果是 SQL 的話就會比較複雜，需要做切割調整等動作。",[16,38,39,40],{},"這邊也附上 Wiki 參考連結: ",[41,42,43],"a",{"href":43,"rel":44},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002FNoSQL",[45],"nofollow",[12,47,49],{"id":48},"firebase-基礎認識","Firebase 基礎認識",[16,51,52,53],{},"接下來開啟 ",[41,54,57],{"href":55,"rel":56},"https:\u002F\u002Fconsole.firebase.google.com\u002Fu\u002F0\u002F",[45],"Firebase",[16,59,60],{},[61,62],"img",{"alt":63,"src":64},"因為我已經建立過 Firebase，所以會稍微不太一樣","https:\u002F\u002Fi.imgur.com\u002FF4T1bWD.png",[16,66,67],{},"剛進來可能會要求你建立專案，所以就直接依照欄位填入即可。",[16,69,70],{},[61,71],{"alt":72,"src":73},"建立專案","https:\u002F\u002Fi.imgur.com\u002FyHesM9b.png",[16,75,76],{},"建立過程大概 1 分鐘 ~ 2 分鐘內就可以搞定哩",[16,78,79],{},[61,80],{"alt":72,"src":81},"https:\u002F\u002Fi.imgur.com\u002F2ZYLWUw.png",[16,83,84],{},[61,85],{"alt":72,"src":86},"https:\u002F\u002Fi.imgur.com\u002FnQIt5wR.png",[16,88,89],{},"進來之後會看到這個畫面 ↓",[16,91,92],{},[61,93],{"alt":94,"src":95},"看到這個畫面代表你已經建立成功哩","https:\u002F\u002Fi.imgur.com\u002F35Q4zS7.png",{"title":97,"searchDepth":98,"depth":98,"links":99},"",2,[100,101,102],{"id":14,"depth":98,"text":14},{"id":21,"depth":98,"text":22},{"id":48,"depth":98,"text":49},"Nodejs","2019-06-28 09:19:36","md","zh-Hant",{},true,"\u002Fnode.js\u002Fnode-js-firebase","1",{"title":6,"description":18},false,"全端勇士之路 Node.js\u002F全端勇士之路-Node-js-基礎學習-Firebase-建立專案",[115,116],"Node.js","全端勇士之路 Node.js",null,"\u002Fnodejs\u002F20190628\u002F905867989\u002F","Vsw0vMpFwYJk2kcey5dwb8RgZ2QBq2F76V-JpcdTOk0",{"newer":121,"older":125},{"url":122,"title":123,"date":124},"\u002Fnodejs\u002F20190628\u002F2843547398\u002F","全端勇士之路 Node.js 基礎學習-Firebase 建立 Realtime 資料庫","2019-06-28 09:48:57",{"url":126,"title":127,"date":128},"\u002Flearnexp\u002F20190627\u002F2015018446\u002F","我在六角實習試著開發一個小專案這件事","2019-06-27 14:51:31",[130,135,140],{"url":131,"title":132,"date":133,"readingMinutes":134},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":136,"title":137,"date":138,"readingMinutes":139},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":141,"title":142,"date":143,"readingMinutes":144},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784011724084]