[{"data":1,"prerenderedAt":1735},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20201229\u002F1974873838\u002F":3,"page:\u002Fnodejs\u002F20201229\u002F1974873838\u002F":4,"alt:\u002Fnodejs\u002F20201229\u002F1974873838\u002F":3,"prev-next:\u002Fnodejs\u002F20201229\u002F1974873838\u002F":1710,"related:\u002Fnodejs\u002F20201229\u002F1974873838\u002F":1719},"\u002Fen\u002Fnodejs\u002F2020\u002F12\u002F29\u002Fauto-generate-api-docs-with-swagger\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1693,"date":1694,"description":1695,"extension":1696,"lang":1697,"meta":1698,"navigation":164,"path":1699,"readingMinutes":1700,"seo":1701,"standalone":1702,"stem":1703,"tags":1704,"tldr":1707,"updated":1707,"url":1708,"__hash__":1709},"content\u002FNodejs\u002F使用-Swagger-自動生成-API-文件.md","使用 Swagger 自動生成 API 文件","1974873838",{"type":9,"value":10,"toc":1684},"minimark",[11,15,19,22,35,38,42,45,51,62,68,71,88,95,100,103,112,115,118,121,124,225,228,236,239,242,465,468,675,678,710,717,723,730,733,736,808,820,825,829,832,1107,1110,1257,1260,1383,1386,1389,1395,1638,1647,1650,1657,1660,1680],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"通常我們在開發後端時，時常開發完畢之後必須撰寫 API 文件，因此這一邊就來介紹一下，如何自動生成 API 文件。",[12,20,21],{"id":21},"開發環境",[23,24,25,29,32],"ul",{},[26,27,28],"li",{},"Node.js 14",[26,30,31],{},"Express",[26,33,34],{},"MacOS Big Sur",[16,36,37],{},"雖然這邊列上了開發環境，但實際上後面還是會提供範例程式碼。",[12,39,41],{"id":40},"自動產生-api-文件","自動產生 API 文件",[16,43,44],{},"這邊我們將會使用 Swagger，而 Swagger 是什麼呢？這邊擷取 wiki 部分說明",[46,47,48],"blockquote",{},[16,49,50],{},"Swagger 與一組開源軟件工具一起使用，以設計，構建，記錄和使用RESTful Web服務。Swagger包括自動文檔，代碼生成和測試用例生成。",[16,52,53,54,61],{},"簡單來講就是方便後端 API 介接時有一個更直覺的 GUI 介面，透過 ",[55,56,60],"a",{"href":57,"rel":58},"https:\u002F\u002Fswagger.io\u002Ftools\u002Fswagger-ui\u002F",[59],"nofollow","Swagger UI"," 你可以生成一個網頁，讓你可以直接在網頁上測試 API 以及了解狀況。",[16,63,64],{},[65,66],"img",{"alt":60,"src":67},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002Fswagger_ui.png",[16,69,70],{},"講那麼多廢話，那麼該如何實際應用在自己專案中呢？這邊我將會使用 Express 作為範本。",[72,73,78],"pre",{"className":74,"code":75,"language":76,"meta":77,"style":77},"language-cmd shiki shiki-themes github-dark-high-contrast","express --pug --css sass \u002F\u002F 建立之後記得進入該目錄輸入 npm install\n","cmd","",[79,80,81],"code",{"__ignoreMap":77},[82,83,86],"span",{"class":84,"line":85},"line",1,[82,87,75],{},[16,89,90,91,94],{},"(在此我是使用「Express 應用程式產生器」建立，若沒有安裝的話則可以試著安裝 ",[79,92,93],{},"npm install express-generator -g","。)",[16,96,97],{},[65,98],{"alt":31,"src":99},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F%E6%88%AA%E5%9C%96%202020-12-29%2020.41.23.png",[16,101,102],{},"接下來我們要替專案安裝兩個重點套件",[72,104,106],{"className":74,"code":105,"language":76,"meta":77,"style":77},"npm install --save swagger-autogen swagger-ui-express\n",[79,107,108],{"__ignoreMap":77},[82,109,110],{"class":84,"line":85},[82,111,105],{},[12,113,114],{"id":114},"swagger-autogen",[16,116,117],{},"swagger-ui-express 簡單來講就是讓 Express 支援 swagger 的 UI 介面呈現而已，這邊的自動化產生 API 的重點套件在於 swagger-autogen。",[16,119,120],{},"swagger-autogen 是什麼呢？簡單來講，你只需要在 API 的 router 撰寫註解，那麼在執行 swagger-autogen 時，它就會自動依照註解內容生成 API 文件，是不是超貼心呢？",[16,122,123],{},"因此接下來我們要建立一個檔案叫做「swagger.js」，內容則是以下",[72,125,129],{"className":126,"code":127,"language":128,"meta":77,"style":77},"language-js shiki shiki-themes github-dark-high-contrast","const swaggerAutogen = require('swagger-autogen')();\n\nconst outputFile = '.\u002Fswagger_output.json'; \u002F\u002F 輸出的文件名稱\nconst endpointsFiles = ['.\u002Fapp.js']; \u002F\u002F 要指向的 API，通常使用 Express 直接指向到 app.js 就可以\n\nswaggerAutogen(outputFile, endpointsFiles); \u002F\u002F swaggerAutogen 的方法\n","js",[79,130,131,159,166,186,208,213],{"__ignoreMap":77},[82,132,133,137,141,144,148,152,156],{"class":84,"line":85},[82,134,136],{"class":135},"sWyjQ","const",[82,138,140],{"class":139},"sCcAr"," swaggerAutogen",[82,142,143],{"class":135}," =",[82,145,147],{"class":146},"sj_SG"," require",[82,149,151]