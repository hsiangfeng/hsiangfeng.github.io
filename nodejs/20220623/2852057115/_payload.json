159,163,166],{"class":38,"line":39},[36,160,162],{"class":161},"sWyjQ","import",[36,164,165],{"class":89}," 'dotenv\u002Fconfig'",[36,167,168],{"class":85},";\n",[36,170,171,173,175,177,179,181,183,185],{"class":38,"line":63},[36,172,104],{"class":85},[36,174,107],{"class":81},[36,176,86],{"class":85},[36,178,112],{"class":89},[36,180,115],{"class":85},[36,182,119],{"class":118},[36,184,122],{"class":85},[36,186,126],{"class":125},[36,188,189,191,193,195,197,199,201,203],{"class":38,"line":129},[36,190,104],{"class":85},[36,192,107],{"class":81},[36,194,86],{"class":85},[36,196,138],{"class":89},[36,198,115],{"class":85},[36,200,143],{"class":118},[36,202,122],{"class":85},[36,204,148],{"class":125},[16,206,207],{},"當然你也可以自己客製化調整要讀取什麼檔案，但這不是這一次分享的內容內。",[16,209,210,211,213,214,216,217,219],{},"透過上面我們可以快速知道 ",[33,212,47],{}," 通常都會放一些較機敏的資訊，但是我們在開發上一定不只有一個人，必定是兩三個共用一個 ",[33,215,47],{},"，而這時候我們可能就會將這個 ",[33,218,47],{}," 檔案透過加密壓縮的方式並使用 Email 或 Slack 等工具傳遞給他人。",[16,221,222],{},"但...這樣子做還是有一些安全性上的考量與疑慮，所以 dotenv 官方出了一個服務叫做 Dotenv Vault，接下來就讓我們認識一下 Dotenv Vault 吧。",[12,224,226],{"id":225},"dotenv-vault","Dotenv Vault",[16,228,229,230,232],{},"Dotenv Vault 是 ",[33,231,21],{}," 官方出的一個服務，現階段來講是滿新的服務，此篇撰寫於 2022\u002F06\u002F23。",[16,234,235,236,238,239,241],{},"而這個服務非常簡單，簡單來講就是統一管理你的 ",[33,237,47],{},"，並且可以設置成組織，讓加入組織的人可以直接下載下來，所以你可以不用在使用 Email 或是 Slack 加密壓縮 ",[33,240,47],{}," 檔案。",[16,243,244],{},"接下來就讓我們實際示範一下吧！",[246,247,249],"h3",{"id":248},"註冊-dotenv-vault","註冊 Dotenv Vault",[16,251,252,253,260],{},"首先先進入 ",[254,255,259],"a",{"href":256,"rel":257},"https:\u002F\u002Fwww.dotenv.org\u002F",[258],"nofollow","Dotenv Vault 官方網站","，並點上方「Log in」按鈕",[16,262,263],{},[264,265],"img",{"alt":266,"src":267},"Log in","https:\u002F\u002Fi.imgur.com\u002FUEvKOJ2.png",[16,269,270],{},"然後點一下下方「Create a new account」",[16,272,273],{},[264,274],{"alt":275,"src":276},"Create a new account","https:\u002F\u002Fi.imgur.com\u002F387U9AQ.png",[16,278,279],{},"接下來會有三步驟，你要分別輸入你的 Email、組織名稱，沒問題就按下「Next:Create project」",[16,281,282],{},[264,283],{"alt":284,"src":285},"Next:Create project","https:\u002F\u002Fi.imgur.com\u002FqN3GNZo.png",[16,287,288],{},"按下之後它會要你確認一下信箱",[16,290,291],{},[264,292],{"alt":293,"src":294},"確認信箱","https:\u002F\u002Fi.imgur.com\u002FMomPHuL.png",[246,296,298],{"id":297},"建立-env-專案","建立 env 專案",[16,300,301],{},"確認完畢後就準備來建立專案囉",[16,303,304],{},[264,305],{"alt":284,"src":306},"https:\u002F\u002Fi.imgur.com\u002FE9jaKuv.png",[16,308,309],{},"第一個專案名稱就先取名為 「test-env」，畢竟這只是示範而已",[16,311,312],{},[264,313],{"alt":314,"src":315},"test-env","https:\u002F\u002Fi.imgur.com\u002FmoKLe9B.png",[16,317,318,319,322],{},"(其實你也可以注意到下方也有提示你可以使用 ",[33,320,321],{},"npx dotenv-vault new"," 來建立)",[16,324,325],{},"建立好後你會看到這一個 Setup 畫面",[16,327,328],{},[264,329],{"alt":330,"src":331},"Setup","https:\u002F\u002Fi.imgur.com\u002FW0SlfwC.png",[16,333,334,335,338,339,342],{},"(第三步驟應該是 ",[33,336,337],{},"npx dotenv-vault@latest pull"," 不知道為什麼官方是寫 ",[33,340,341],{},"npx dotenv-vault@latest push",")",[16,344,345],{},"所以接下來要來建立一個專案哩",[246,347,349],{"id":348},"測試用-express","測試用 Express",[16,351,352],{},"首先這邊偷懶用 Express 產生器產生一個專案，這邊我環境是使用 Mac 所以我直接附上指令就好",[26,354,356],{"className":28,"code":355,"language":30,"meta":31,"style":31},"mkdir test-express\ncd test-express\nexpress --no-view\nnpm install\n",[33,357,358,363,368,373],{"__ignoreMap":31},[36,359,360],{"class":38,"line":39},[36,361,362],{},"mkdir test-express\n",[36,364,365],{"class":38,"line":63},[36,366,367],{},"cd test-express\n",[36,369,370],{"class":38,"line":129},[36,371,372],{},"express --no-view\n",[36,374,376],{"class":38,"line":375},4,[36,377,378],{},"npm install\n",[16,380,381],{},"接下來其實就是複製剛剛 Setup 畫面的指令一一輸入就對了，基本上過程會問你要不要安裝「dotenv-vault」按下 Y 就對了",[16,383,384],{},[264,385],{"alt":225,"src":386},"https:\u002F\u002Fi.imgur.com\u002FGEgFrCc.png",[16,388,389,390,393,394,397],{},"你會發現它幫你建立了 ",[33,391,392],{},".env.vault"," 檔案，然後接著第二步驟輸入 ",[33,395,396],{},"npx dotenv-vault@latest login","，這時候會開啟瀏覽器，然後就給它點「Log in」 吧",[16,399,400],{},[264,401],{"alt":266,"src":402},"https:\u002F\u002Fi.imgur.com\u002FolKuyOq.png",[16,404,405,406,409],{},"然後接下來畫面會要求你在終端機輸入 ",[33,407,408],{},"npx dotenv-vault@latest open","，輸入後你會開啟 env 專案的後台",[16,411,412],{},[264,413],{"alt":414,"src":415},"env 後台","https:\u002F\u002Fi.imgur.com\u002FXaYaggs.png",[16,417,418],{},"這邊我新增一個 env 名稱是 TEST 然後 value 是 Hello 並新增",[16,420,421],{},[264,422],{"alt":423,"src":424},"新增","https:\u002F\u002Fi.imgur.com\u002FpIRT9JI.png",[16,426,427,428,430],{},"新增成功後一樣回到終端機輸入 ",[33,429,337],{}," 就可以將遠端的 env 拉下來了",[16,432,433],{},[264,434],{"alt":435,"src":436},"pull","https:\u002F\u002Fi.imgur.com\u002F22WveiN.png",[16,438,439],{},"接下來若你有任何新增，你可以直接在這個 .env 增加，例如我改成以下",[26,441,443],{"className":51,"code":442,"language":53,"meta":31,"style":31},"# development\nTEST=\"Hello\"\nDATEBASE=\"URLQQ\"\nDATEBASE_PASSWORD=\"URLQQ\"\n",[33,444,445,450,455,460],{"__ignoreMap":31},[36,446,447],{"class":38,"line":39},[36,448,449],{},"# development\n",[36,451,452],{"class":38,"line":63},[36,453,454],{},"TEST=\"Hello\"\n",[36,456,457],{"class":38,"line":129},[36,458,459],{},"DATEBASE=\"URLQQ\"\n",[36,461,462],{"class":38,"line":375},[36,463,464],{},"DATEBASE_PASSWORD=\"URLQQ\"\n",[16,466,467],{},[264,468],{"alt":469,"src":470},"push","https:\u002F\u002Fi.imgur.com\u002FdVIDo4Q.png",[16,472,473,474,476],{},"接下來如何更新到遠端 env 上呢？只需要在終端機輸入 ",[33,475,341],{}," 就可以了",[16,478,479],{},[264,480],{"alt":469,"src":481},"https:\u002F\u002Fi.imgur.com\u002F6IrShOd.png",[16,483,484],{},"這樣子遠端就會出現我們本地更新的 env 內容囉",[16,486,487],{},[264,488],{"alt":53,"src":489},"https:\u002F\u002Fi.imgur.com\u002FtMtzWy9.png",[246,491,493],{"id":492},"新增-env-專案成員","新增 env 專案成員",[16,495,496],{},"新增成員方式也非常簡單，專案上方有一個 People 只需要切換過去並新增使用者的 Email 就可以了",[16,498,499],{},[264,500],{"alt":493,"src":501},"https:\u002F\u002Fi.imgur.com\u002FfFl6eVh.png",[16,503,504],{},"新增後成員就可以在自己畫面上看到相關 env 專案了",[16,506,507],{},[264,508],{"alt":53,"src":509},"https:\u002F\u002Fi.imgur.com\u002FmfJAC1n.pn