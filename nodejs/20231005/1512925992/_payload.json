[{"data":1,"prerenderedAt":1493},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20231005\u002F1512925992\u002F":3,"page:\u002Fnodejs\u002F20231005\u002F1512925992\u002F":4,"alt:\u002Fnodejs\u002F20231005\u002F1512925992\u002F":3,"prev-next:\u002Fnodejs\u002F20231005\u002F1512925992\u002F":1468,"related:\u002Fnodejs\u002F20231005\u002F1512925992\u002F":1477},"\u002Fen\u002Fnodejs\u002F2023\u002F10\u002F05\u002Fday-21-discord-basics\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1452,"date":1453,"description":25,"extension":1454,"lang":1455,"meta":1456,"navigation":163,"path":1457,"readingMinutes":1458,"seo":1459,"standalone":1460,"stem":1461,"tags":1462,"tldr":1465,"updated":1453,"url":1466,"__hash__":1467},"content\u002F《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》\u002FDay21-Discord 基礎.md","Day21 - Discord 基礎","1512925992",{"type":9,"value":10,"toc":1445},"minimark",[11,19,23,26,30,33,36,242,249,299,303,309,316,322,325,401,407,435,438,464,475,479,489,575,580,583,589,593,596,602,716,719,731,738,754,757,786,796,820,846,856,1022,1039,1048,1054,1060,1136,1139,1176,1179,1212,1215,1218,1425,1432,1438,1441],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Discord 基礎","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnodejs\u002Fithelp-nodejs-2023\u002Fisray_notarray_Junior_Discord_a7d3cdbb-252f-41f8-8923-48a5697c51f9.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"在前一篇我們準備好了 Discord 基本的一些東西與設定，接下來當然要繼續聊 Discord 的部分囉～",[20,27,29],{"id":28},"discord","Discord",[12,31,32],{},"前一篇我們分別認識了官方所提供的註冊指令到 Bot 的程式碼，以及登入 Discord Bot 的程式碼，但實際上來講就這樣嗎？不，其實還有很多東西可以講，就讓我們專注於 Discord Bot 的方便吧！",[12,34,35],{},"首先我們先看一下前一篇寫的程式碼：",[37,38,43],"pre",{"className":39,"code":40,"language":41,"meta":42,"style":42},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F index.js\nconst { Client, Intents } = require('discord.js'); \u002F\u002F 引入 discord.js 套件\n\u002F\u002F 實例化 Client\nconst client = new Client({\n  intents: [\n    Intents.FLAGS.GUILDS\n  ]\n});\n\n\u002F\u002F 當機器人準備好時\nclient.once('ready', () => {\n  console.log('Ready!');\n});\n\n\u002F\u002F 登入機器人\nclient.login(TOKEN);\n","js","",[44,45,46,55,99,105,125,131,146,152,158,165,171,194,211,216,221,227],"code",{"__ignoreMap":42},[47,48,51],"span",{"class":49,"line":50},"line",1,[47,52,54],{"class":53},"sQrFR","\u002F\u002F index.js\n",[47,56,58,62,66,70,73,76,79,82,86,89,93,96],{"class":49,"line":57},2,[47,59,61],{"class":60},"sWyjQ","const",[47,63,65],{"class":64},"sMAXC"," { ",[47,67,69],{"class":68},"sCcAr","Client",[47,71,72],{"class":64},", ",[47,74,75],{"class":68},"Intents",[47,77,78],{"class":64}," } ",[47,80,81],{"class":60},"=",[47,83,85],{"class":84},"sj_SG"," require",[47,87,88],{"class":64},"(",[47,90,92],{"class":91},"sTRMh","'discord.js'",[47,94,95],{"class":64},"); ",[47,97,98],{"class":53},"\u002F\u002F 引入 discord.js 套件\n",[47,100,102],{"class":49,"line":101},3,[47,103,104],{"class":53},"\u002F\u002F 實例化 Client\n",[47,106,108,110,113,116,119,122],{"class":49,"line":107},4,[47,109,61],{"class":60},[47,111,112],{"class":68}," client",[47,114,115],{"class":60}," =",[47,117,118],{"class":60}," new",[47,120,121],{"class":84}," Client",[47,123,124],{"class":64},"({\n",[47,126,128],{"class":49,"line":127},5,[47,129,130],{"class":64},"  intents: [\n",[47,132,134,137,140,143],{"class":49,"line":133},6,[47,135,136],{"class":64},"    Intents.",[47,138,139],{"class":68},"FLAGS",[47,141,142],{"class":64},".",[47,144,145],{"class":68},"GUILDS\n",[47,147,149],{"class":49,"line":148},7,[47,150,151],{"class":64},"  ]\n",[47,153,155],{"class":49,"line":154},8,[47,156,157],{"class":64},"});\n",[47,159,161],{"class":49,"line":160},9,[47,162,164],{"emptyLinePlaceholder":163},true,"\n",[47,166,168],{"class":49,"line":167},10,[47,169,170],{"class":53},"\u002F\u002F 當機器人準備好時\n",[47,172,174,177,180,182,185,188,191],{"class":49,"line":173},11,[47,175,176],{"class":64},"client.",[47,178,179],{"class":84},"once",[47,181,88],{"class":64},[47,183,184],{"class":91},"'ready'",[47,186,187],{"class":64},", () ",[47,189,190],{"class":60},"=>",[47,192,193],{"class":64}," {\n",[47,195,197,200,203,205,208],{"class":49,"line":196},12,[47,198,199],{"class":64},"  console.",[47,201,202],{"class":84},"log",[47,204,88],{"class":64},[47,206,207],{"class":91},"'Ready!'",[47,209,210],{"class":64},");\n",[47,212,214],{"class":49,"line":213},13,[47,215,157],{"class":64},[47,217,219],{"class":49,"line":218},14,[47,220,164],{"emptyLinePlaceholder":163},[47,222,224],{"class":49,"line":223},15,[47,225,226],{"class":53},"\u002F\u002F 登入機器人\n",[47,228,230,232,235,237,240],{"class":49,"line":229},16,[47,231,176],{"class":64},[47,233,234],{"class":84},"login",[47,236,88],{"class":64},[47,238,239],{"class":68},"TOKEN",[47,241,210],{"class":64},[12,243,244,245,248],{},"我們先專注於 ",[44,246,247],{},"const client = new Client({ ... })"," 這裡面的物件",[37,250,252],{"className":39,"code":251,"language":41,"meta":42,"style":42},"\u002F\u002F ... 略過其他程式碼\nconst client = new Client({\n  intents: [\n    Intents.FLAGS.GUILDS\n  ]\n});\n\u002F\u002F ... 略過其他程式碼\n",[44,253,254,259,273,277,287,291,295],{"__ignoreMap":42},[47,255,256],{"class":49,"line":50},[47,257,258],{"class":53},"\u002F\u002F ... 略過其他程式碼\n",[47,260,261,263,265,267,269,271],{"class":49,"line":57},[47,262,61],{"class":60},[47,264,112],{"class":68},[47,266,115],{"class":60},[47,268,118],{"class":60},[47,270,121],{"class":84},[47,272,124],{"class":64},[47,274,275],{"class":49,"line":101},[47,276,130],{"class":64},[47,278,279,281,283,285],{"class":49,"line":107},[47,280,136],{"class":64},[47,282,139],{"class":68},[47,284,142],{"class":64},[47,286,145],{"class":68},[47,288,289],{"class":49,"line":127},[47,290,151],{"class":64},[47,292,293],{"class":49,"line":133},[47,294,157],{"class":64},[47,296,297],{"class":49,"line":148},[47,298,258],{"class":53},[20,300,302],{"id":301},"intents意圖","Intents（意圖）",[12,304,305,306,308],{},"首先 ",[44,307,247],{}," 這行是在建立一個新的 Discord.js 物件，你可以想像它就像是一個接入 Discord API 的橋樑，讓我們可以透過程式碼去操作 Discord。",[12,310,311,312,315],{},"而裡面是傳入一些地方，先講講 ",[44,313,314],{},"intents"," 這個參數，這個參數非常的重要，會影響你的機器人可以做哪些事情。",[12,317,318,319,321],{},"問題來了，",[44,320,314],{}," 主要是幹嘛的呢？簡單來說就是告知 Discord 我們會有哪些「意圖」，例如：我們的機器人會需要接收伺服器的訊息，那麼我們就需要告知 Discord 我們會需要接收伺服器的訊息，這樣 Discord 才會將伺服器的訊息傳送給我們的機器人。",[12,323,324],{},"這邊我先舉例一下我先前寫的程式碼：",[37,326,328],{"className":39,"code":327,"language":41,"meta":42,"style":42},"const { Client, GatewayIntentBits } = require('discord.js');\n\nconst client = new Client({\n  intents: [\n    GatewayIntentBits.Guilds,\n    GatewayIntentBits.GuildMessages,\n    GatewayIntentBits.MessageContent,\n  ],\n});\n",[44,329,330,355,359,373,377,382,387,392,397],{"__ignoreMap":42},[47,331,332,334,336,338,340,343,345,347,349,351,353],{"class":49,"line":50},[47,333,61],{"class":60},[47,335,65],{"class":64},[47,337,69],{"class":68},[47,339,72],{"class":64},[47,341,342],{"class":68},"GatewayIntentBits",[47,344,78],{"class":64},[47,346,81],{"class":60},[47,348,85],{"class":84},[47,350,88],{"class":64},[47,352,92],{"class":91},[47,354,210],{"class":64},[47,356,357],{"class":49,"line":57},[47,358,164],{"emptyLinePlaceholder":163},[47,360,361,363,365,367,369,371],{"class":49,"line":101},[47,362,61],{"class":60},[47,364,112],{"class":68},[47,366,115],{"class":60},[47,368,118],{"class":60},[47,370,121],{"class":84},[47,372,124],{"class":64},[47,374,375],{"class":49,"line":107},[47,376,130],{"class":64},[47,378,379],{"class":49,"line":127},[47,380,381],{"class":64},"    GatewayIntentBits.Guilds,\n",[47,383,384],{"class":49,"line":133},[47,385,386],{"class":64},"    GatewayIntentBits.GuildMessages,\n",[47,388,389],{"class":49,"line":148},[47,390,391],{"class":64},"    GatewayIntentBits.MessageContent,\n",[47,393,394],{"class":49,"line":154},[47,395,396],{"class":64},"  ],\n",[47,398,399],{"class":49,"line":160},[47,400,157],{"class":64},[12,402,403,404,406],{},"我們可以看到 ",[44,405,314],{}," 接收了一個陣列，裡面放了三個參數，這三個參數分別是：",[408,409,410,417,423],"ul",{},[411,412,413,416],"li",{},[44,414,415],{},"GatewayIntentBits.Guilds","：可以接收伺服器相關的事件，例如：使用者加入伺服器、使用者離開伺服器等等。",[411,418,419,422],{},[44,420,421],{},"GatewayIntentBits.GuildMembers","：可以接收伺服器內的聊天訊息事件，例如：使用者傳送訊息、使用者編輯訊息等等。",[411,424,425,428,429,431,432,434],{},[44,426,427],{},"GatewayIntentBits.MessageContent","：這個比較特別一點，這是在告知機器人我們需要接收訊息的內容，例如：使用者傳送的訊息內容、使用者編輯的訊息內容等等，這個跟前面的 ",[44,430,421],{}," 不同的地方在於，",[44,433,421],{}," 只會告知我們使用者傳送了訊息，但不會告知我們訊息的內容，所以我們需要另外告知 Discord 我們需要接收訊息的內容。",[12,436,437],{},"當然不只有這些，還有...",[408,439,440,446,452,458],{},[411,441,442,445],{},[44,443,444],{},"GatewayIntentBits.GuildMessageReactions","：可以接收伺服器內的反應事件，例如：使用者給予訊息反應、使用者移除訊息反應等等。",[411,447,448,451],{},[44,449,450],{},"GatewayIntentBits.DirectMessages","：可以接收私人訊息事件，例如：使用者傳送私人訊息、使用者編輯私人訊息等等。",[411,453,454,457],{},[44,455,456],{},"GatewayIntentBits.DirectMessageReactions","：可以接收私人訊息的反應事件，例如：使用者給予私人訊息反應、使用者移除私人訊息反應等等。",[411,459,460,463],{},[44,461,462],{},"GatewayIntentBits.DirectMessageTyping","：可以接收私人訊息的打字事件，例如：使用者正在打字、使用者停止打字等等。",[12,465,466,467,474],{},"當然這邊只列出一些而已，其他部分可以參考 ",[468,469,473],"a",{"href":470,"rel":471},"https:\u002F\u002Fdiscord.com\u002Fdevelopers\u002Fdocs\u002Ftopics\u002Fgateway#list-of-intents",[472],"nofollow","Discord.js 官方文件","。",[20,476,478],{"id":477},"partials部分","partials（部分）",[12,480,481,484,485,488],{},[44,482,483],{},"partials"," 有一點特別，它也是 ",[44,486,487],{},"new Client"," 時會傳入的參數之一：",[37,490,492],{"className":39,"code":491,"language":41,"meta":42,"style":42},"const { Client, GatewayIntentBits, Partials } = require('discord.js');\nconst client = new Client({\n  intents: [\n    GatewayIntentBits.Guilds,\n    GatewayIntentBits.GuildMessages,\n    GatewayIntentBits.MessageContent,\n  ],\n  partials: [\n    Partials.Channel\n  ],\n});\n",[44,493,494,523,537,541,545,549,553,557,562,567,571],{"__ignoreMap":42},[47,495,496,498,500,502,504,506,508,511,513,515,517,519,521],{"class":49,"line":50},[47,497,61],{"class":60},[47,499,65],{"class":64},[47,501,69],{"class":68},[47,503,72],{"class":64},[47,505,342],{"class":68},[47,507,72],{"class":64},[47,509,510],{"class":68},"Partials",[47,512,78],{"class":64},[47,514,81],{"class":60},[47,516,85],{"class":84},[47,518,88],{"class":64},[47,520,92],{"class":91},[47,522,210],{"class":64},[47,524,525,527,529,531,533,535],{"class":49,"line":57},[47,526,61],{"class":60},[47,528,112],{"class":68},[47,530,115],{"class":60},[47,532,118],{"class":60},[47,534,121],{"class":84},[47,536,124],{"class":64},[47,538,539],{"class":49,"line":101},[47,540,130],{"class":64},[47,542,543],{"class":49,"line":107},[47,544,381],{"class":64},[47,546,547],{"class":49,"line":127},[47,548,386],{"class":64},[47,550,551],{"class":49,"line":133},[47,552,391],{"class":64},[47,554,555],{"class":49,"line":148},[47,556,396],{"class":64},[47,558,559],{"class":49,"line":154},[47,560,561],{"class":64},"  partials: [\n",[47,563,564],{"class":49,"line":160},[47,565,566],{"class":64},"    Partials.Channel\n",[47,568,569],{"class":49,"line":167},[47,570,396],{"class":64},[47,572,573],{"class":49,"line":173},[47,574,157],{"class":64},[12,576,577,579],{},[44,578,483],{}," 這個參數是用來告知 Discord 我們需要接收哪些「部分」的資料，例如：我們需要接收哪些訊息的內容、哪些訊息的反應等等。",[12,581,582],{},"那為什麼要特別設定這個呢？主要原因是因為 Discord 會將一些資料分成兩個部分，一個是完整的資料，另一個是部分的資料，例如：我們需要接收訊息的內容，但 Discord 會將訊息的內容分成兩個部分，一個是完整的訊息內容，另一個是部分的訊息內容，這樣就會造成我們無法取得完整的訊息內容，所以我們需要告知 Discord 我們需要接收完整的訊息內容。",[12,584,585,586,588],{},"那麼我們大致上了解了 ",[44,587,510],{}," 的用途後，就先這樣繼續往下吧～有需要我們再來聊這個。",[20,590,592],{"id":591},"discord-方法與事件","Discord 方法與事件",[12,594,595],{},"接下來我們就來聊聊 Discord 的方法與事件，這邊我們就先來看看 Discord 的方法吧！",[12,597,598,599,601],{},"我們在範例程式碼中，其實有看到 ",[44,600,69],{}," 實例化後，做了一些事情...",[37,603,605],{"className":39,"code":604,"language":41,"meta":42,"style":42},"\u002F\u002F index.js\nconst { Client, Intents } = require('discord.js'); \u002F\u002F 引入 discord.js 套件\n\u002F\u002F 實例化 Client\nconst client = new Client({\n  \u002F\u002F ... 略過其他程式碼\n});\n\n\u002F\u002F 當機器人準備好時\nclient.once('ready', () => {\n  \u002F\u0