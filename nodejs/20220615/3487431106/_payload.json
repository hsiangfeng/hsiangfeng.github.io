[{"data":1,"prerenderedAt":272},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20220615\u002F3487431106\u002F":3,"page:\u002Fnodejs\u002F20220615\u002F3487431106\u002F":4,"alt:\u002Fnodejs\u002F20220615\u002F3487431106\u002F":3,"prev-next:\u002Fnodejs\u002F20220615\u002F3487431106\u002F":247,"related:\u002Fnodejs\u002F20220615\u002F3487431106\u002F":256},"\u002Fen\u002Fnodejs\u002F2022\u002F06\u002F15\u002Fnpm-warn-config-global-deprecated-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":230,"date":231,"description":18,"extension":232,"lang":233,"meta":234,"navigation":235,"path":236,"readingMinutes":237,"seo":238,"standalone":239,"stem":240,"tags":241,"tldr":244,"updated":244,"url":245,"__hash__":246},"content\u002FNodejs\u002Fnpm-WARN-config-global-global-local-are-deprecated-Use-location-global-instead-解決方式.md","npm WARN config global --global, --local are deprecated. Use --location=global instead 解決方式","3487431106",{"type":9,"value":10,"toc":224},"minimark",[11,15,19,22,25,61,64,73,76,79,88,95,103,110,121,126,129,147,158,164,171,179,182,188,191,194,197,220],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近更新到 Node.js 16.15.1 與 npm 8.11.0 時，會一直出現「npm WARN config global --global, --local are deprecated. Use --location=global instead 解決方式」的狀況，所以這一篇記錄下如何解決。",[12,20,21],{"id":21},"事出原因",[16,23,24],{},"首先我們開發上其實很常使用 nvm 來下載其他 Node.js，而某一天安裝了 16.15.1 版",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-cmd shiki shiki-themes github-dark-high-contrast","nvm install 16.15.1\nnvm use 16.15.1\nnode -v \u002F\u002F 16.15.1\nnpm -v  \u002F\u002F 8.11.0\n","cmd","",[33,34,35,43,49,55],"code",{"__ignoreMap":31},[36,37,40],"span",{"class":38,"line":39},"line",1,[36,41,42],{},"nvm install 16.15.1\n",[36,44,46],{"class":38,"line":45},2,[36,47,48],{},"nvm use 16.15.1\n",[36,50,52],{"class":38,"line":51},3,[36,53,54],{},"node -v \u002F\u002F 16.15.1\n",[36,56,58],{"class":38,"line":57},4,[36,59,60],{},"npm -v  \u002F\u002F 8.11.0\n",[16,62,63],{},"結果出現了以下錯誤訊息",[26,65,67],{"className":28,"code":66,"language":30,"meta":31,"style":31},"npm WARN config global --global, --local are deprecated. Use --location=global instead\n",[33,68,69],{"__ignoreMap":31},[36,70,71],{"class":38,"line":39},[36,72,66],{},[12,74,75],{"id":75},"解決方式",[16,77,78],{},"其實解決方式非常簡單，直接更新 npm 就可以了",[26,80,82],{"className":28,"code":81,"language":30,"meta":31,"style":31},"npm install -g npm\n",[33,83,84],{"__ignoreMap":31},[36,85,86],{"class":38,"line":39},[36,87,81],{},[16,89,90,91,94],{},"但是過程中可能會發生 「",[33,92,93],{},"Unexpected token '.'","」 這個錯誤，而這個錯誤其實並不是 Node.js 與 npm 的問題，而是 nvm-windows 的問題導致，解決方式很簡單，只需要到 nvm-windows 下載更新包就可以了",[16,96,97],{},[98,99,100],"a",{"href":100,"rel":101},"https:\u002F\u002Fgithub.com\u002Fcoreybutler\u002Fnvm-windows\u002Freleases\u002Ftag\u002F1.1.9",[102],"nofollow",[16,104,105],{},[106,107],"img",{"alt":108,"src":109},"1.1.9","https:\u002F\u002Fi.imgur.com\u002F4bbaiS0.png",[16,111,112,113,115,116,120],{},"更新好後基本上就可以先初步排除 ",[33,114,93],{}," 問題，因此接下來關閉終端機，記得使用開啟終端機時要用「",[117,118,119],"strong",{},"以系統管理員身份執行","」。",[16,122,123],{},[106,124],{"alt":119,"src":125},"https:\u002F\u002Fi.imgur.com\u002FX8bBPY6.png",[16,127,128],{},"然後將剛剛安裝有問題的 Node.js 移除重新安裝",[26,130,132],{"className":28,"code":131,"language":30,"meta":31,"style":31},"nvm uninstall 16.15.1\nnvm install 16.15.1\nnvm use 16.15.1\n",[33,133,134,139,143],{"__ignoreMap":31},[36,135,136],{"class":38,"line":39},[36,137,138],{},"nvm uninstall 16.15.1\n",[36,140,141],{"class":38,"line":45},[36,142,42],{},[36,144,145],{"class":38,"line":51},[36,146,48],{},[16,148,149,150,153,154,157],{},"接下來一樣輸入 ",[33,151,152],{},"npm -v"," 的時候，還是會出現 ",[33,155,156],{},"npm WARN config global --global, --local are deprecated. Use --location=global instead","，先不用太擔心",[16,159,160],{},[106,161],{"alt":162,"src":163},"錯誤訊息","https:\u002F\u002Fi.imgur.com\u002FHh4pYu3.png",[16,165,166,167,170],{},"接著輸入更新 ",[33,168,169],{},"npm"," 的指令",[26,172,173],{"className":28,"code":81,"language":30,"meta":31,"style":31},[33,174,175],{"__ignoreMap":31},[36,176,177],{"class":38,"line":39},[36,178,81],{},[16,180,181],{},"(更新後記得重啟終端機)",[16,183,184],{},[106,185],{"alt":186,"src":187},"更新 npm","https:\u002F\u002Fi.imgur.com\u002F0amp3fr.png",[16,189,190],{},"更新成功後就不會再出現啦~",[16,192,193],{},"而這個問題應該是 npm 8.11.0 的問題，所以只需要更新到新版就好，更新完畢後如果還是沒有解決的話會建議重新安裝 Node.js，然後重新開起終端機哩。",[12,195,196],{"id":196},"參考文獻",[198,199,200],"ul",{},[201,202,203],"li",{},[98,204,207,208,211,212,215,216,219],{"href":205,"rel":206},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F72401421\u002Fnpm-warn-config-global-global-local-are-deprecated-use-location-glo",[102],"npm WARN config global ",[33,209,210],{},"--global",", ",[33,213,214],{},"--local"," are deprecated. Use ",[33,217,218],{},"--location=global"," instead",[221,222,223],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":31,"searchDepth":45,"depth":45,"links":225},[226,227,228,229],{"id":14,"depth":45,"text":14},{"id":21,"depth":45,"text":21},{"id":75,"depth":45,"text":75},{"id":196,"depth":45,"text":196},"Nodejs","2022-06-15 14:48:59","md","zh-Hant",{},true,"\u002Fnodejs\u002Fnpm-warn-config-global-global-local-are-deprecated-use-location-global-instead","1",{"title":6,"description":18},false,"Nodejs\u002Fnpm-WARN-config-global-global-local-are-deprecated-Use-location-global-instead-解決方式",[230,242,169,243],"nvm","Windows",null,"\u002Fnodejs\u002F20220615\u002F3487431106\u002F","6HFep_mW7DeGR9C6ggrmB4Abw9v591B4SDunR5CAW3g",{"newer":248,"older":252},{"url":