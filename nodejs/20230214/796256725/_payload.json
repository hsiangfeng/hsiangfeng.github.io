"meta":72,"style":72},"language-js shiki shiki-themes github-dark-high-contrast","module.exports = {\n  publicPath: '.\u002F',\n};\n","js","",[26,74,75,98,111],{"__ignoreMap":72},[76,77,80,84,88,91,95],"span",{"class":78,"line":79},"line",1,[76,81,83],{"class":82},"sCcAr","module",[76,85,87],{"class":86},"sMAXC",".",[76,89,90],{"class":82},"exports",[76,92,94],{"class":93},"sWyjQ"," =",[76,96,97],{"class":86}," {\n",[76,99,101,104,108],{"class":78,"line":100},2,[76,102,103],{"class":86},"  publicPath: ",[76,105,107],{"class":106},"sTRMh","'.\u002F'",[76,109,110],{"class":86},",\n",[76,112,114],{"class":78,"line":113},3,[76,115,116],{"class":86},"};\n",[16,118,119,120,127],{},"雖然這樣子設置也是正確的，但是在 Vue Cli ",[121,122,126],"a",{"href":123,"rel":124},"https:\u002F\u002Fcli.vuejs.org\u002Fzh\u002Fconfig\u002F#publicpath",[125],"nofollow","官方文件","其實有給出一個建議的寫法",[16,129,130],{},[37,131],{"alt":132,"src":133},"Vue Cli publicPath","https:\u002F\u002Fi.imgur.com\u002FuwzkJA4.png",[67,135,137],{"className":69,"code":136,"language":71,"meta":72,"style":72},"module.exports = {\n  publicPath: process.env.NODE_ENV === 'production'\n    ? '\u002Fproduction-sub-path\u002F'\n    : '\u002F'\n}\n",[26,138,139,151,165,173,182],{"__ignoreMap":72},[76,140,141,143,145,147,149],{"class":78,"line":79},[76,142,83],{"class":82},[76,144,87],{"class":86},[76,146,90],{"class":82},[76,148,94],{"class":93},[76,150,97],{"class":86},[76,152,153,156,159,162],{"class":78,"line":100},[76,154,155],{"class":86},"  publicPath: process.env.",[76,157,158],{"class":82},"NODE_ENV",[76,160,161],{"class":93}," ===",[76,163,164],{"class":106}," 'production'\n",[76,166,167,170],{"class":78,"line":113},[76,168,169],{"class":93},"    ?",[76,171,172],{"class":106}," '\u002Fproduction-sub-path\u002F'\n",[76,174,176,179],{"class":78,"line":175},4,[76,177,178],{"class":93},"    :",[76,180,181],{"class":106}," '\u002F'\n",[76,183,185],{"class":78,"line":184},5,[76,186,187],{"class":86},"}\n",[51,189,190],{},[16,191,192,196,199,200,203,204,206,207,210],{},[193,194,195],"strong",{},"Note",[26,197,198],{},"production-sub-path"," 是你的 GitHub Pages 的儲存庫，例如我的儲存庫就是 ",[26,201,202],{},"vue3-example","，所以我的 ",[26,205,198],{}," 就是 ",[26,208,209],{},"\u002Fvue3-example\u002F","。",[16,212,213],{},"這樣子可以確保我們編譯後的路徑以及本地開發的路徑都是正確的。",[12,215,217],{"id":216},"設置-vite","設置 Vite",[16,219,220,221,65],{},"那麼 Vite 也是類似，通常我們 Vite 編譯後如果要部署到 GitHub Pages 之前都會先建立一個 vite.config.js 並新增一個屬性 ",[26,222,32],{},[67,224,226],{"className":69,"code":225,"language":71,"meta":72,"style":72},"\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...略過其他設置\n  base: '.\u002F'\n})\n",[26,227,228,234,250,255,263],{"__ignoreMap":72},[76,229,230],{"class":78,"line":79},[76,231,233],{"class":232},"sQrFR","\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\n",[76,235,236,239,242,246],{"class":78,"line":100},[76,237,238],{"class":93},"export",[76,240,241],{"class":93}," default",[76,243,245],{"class":244},"sj_SG"," defineConfig",[76,247,249],{"class":248},"s_sBn","({\n",[76,251,252],{"class":78,"line":113},[76,253,254],{"class":232},"  \u002F\u002F ...略過其他設置\n",[76,256,257,260],{"class":78,"line":175},[76,258,259],{"class":86},"  base: ",[76,261,262],{"class":106},"'.\u002F'\n",[76,264,265],{"class":78,"line":184},[76,266,267],{"class":248},"})\n",[16,269,270,271,275],{},"當然這一條在官方文件上也有，可是有趣的是",[121,272,126],{"href":273,"rel":274},"https:\u002F\u002Fcn.vitejs.dev\u002Fconfig\u002Fshared-options.html#base",[125],"上這次並沒有給出建議的寫法了",[16,277,278],{},[37,279],{"alt":280,"src":281},"Vite Base","https:\u002F\u002Fi.imgur.com\u002FoO5JIwQ.png",[16,283,284,285,288,289,292,293,295],{},"那這樣子我們是不是就一率寫 ",[26,286,287],{},".\u002F"," 或是寫死 ",[26,290,291],{},"\u002Frepo-name\u002F"," 就好了呢？其實不是，因為這樣子的話我們在本地開發的時候就會有問題，所以我們還是要像 Vue Cli 一樣，要根據環境來設置 ",[26,294,32],{}," 的值，所以你可能會很興高采烈地這樣寫...",[67,297,299],{"className":69,"code":298,"language":71,"meta":72,"style":72},"\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...略過其他設置\n  base: import.meta.env.MODE === 'production' ? '\u002Fproduction-sub-path\u002F' : '\u002F'\n})\n",[26,300,301,305,315,319,353],{"__ignoreMap":72},[76,302,303],{"class":78,"line":79},[76,304,233],{"class":232},[76,306,307,309,311,313],{"class":78,"line":100},[76,308,238],{"class":93},[76,310,241],{"class":93},[76,312,245],{"class":244},[76,314,249],{"class":248},[76,316,317],{"class":78,"line":113},[76,318,254],{"class":232},[76,320,321,323,326,328,331,334,337,339,342,345,348,351],{"class":78,"line":175},[76,322,259],{"class":86},[76,324,325],{"class":93},"import",[76,327,87],{"class":86},[76,329,330],{"class":82},"meta",[76,332,333],{"class":86},".env.",[76,335,336],{"class":82},"MODE",[76,338,161],{"class":93},[76,340,341],{"class":106}," 'production'",[76,343,344],{"class":93}," ?",[76,346,347],{"class":106}," '\u002Fproduction-sub-path\u002F'",[76,349,350],{"class":93}," :",[76,352,181],{"class":106},[76,354,355],{"class":78,"line":184},[76,356,267],{"class":248},[16,358,359,360,363,364,367],{},"但你會發現這樣寫會出現錯誤，因為在 vite.config.js 中是沒有 ",[26,361,362],{},"import.meta"," 的，所以我們要改成使用 ",[26,365,366],{},"process.env","，所以最後的寫法會是這樣",[67,369,371],{"className":69,"code":370,"language":71,"meta":72,"style":72},"\u002F* global process *\u002F\n\n\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...略過其他設置\n  base: process.env.NODE_ENV === 'production' ? '\u002Fproduction-sub-path\u002F' : '\u002F'\n})\n",[26,372,373,378,384,388,398,402,422],{"__ignoreMap":72},[76,374,375],{"class":78,"line":79},[76,376,377],{"class":232},"\u002F* global process *\u002F\n",[76,379,380],{"class":78,"line":100},[76,381,383],{"emptyLinePlaceholder":382},true,"\n",[76,385,386],{"class":78,"line":113},[76,387,233],{"class":232},[76,389,390,392,394,396],{"class":78,"line":175},[76,391,238],{"class":93},[76,393,241],{"class":93},[76,395,245],{"class":244},[76,3