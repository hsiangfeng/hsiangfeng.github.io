[{"data":1,"prerenderedAt":587},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20230214\u002F796256725\u002F":3,"page:\u002Fnodejs\u002F20230214\u002F796256725\u002F":4,"alt:\u002Fnodejs\u002F20230214\u002F796256725\u002F":3,"prev-next:\u002Fnodejs\u002F20230214\u002F796256725\u002F":563,"related:\u002Fnodejs\u002F20230214\u002F796256725\u002F":572},"\u002Fen\u002Fnodejs\u002F2023\u002F02\u002F14\u002Fvue-cli-vite-correct-build-path\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":546,"date":547,"description":18,"extension":548,"lang":549,"meta":550,"navigation":381,"path":551,"readingMinutes":552,"seo":553,"standalone":554,"stem":555,"tags":556,"tldr":560,"updated":547,"url":561,"__hash__":562},"content\u002FVue\u002F正確的設置-Vue-Cli-與-Vite-編譯後的路徑.md","正確的設置 Vue Cli 與 Vite 編譯後的路徑","796256725",{"type":9,"value":10,"toc":539},"minimark",[11,15,19,22,34,41,47,50,56,60,66,117,128,134,188,210,213,217,222,267,275,281,295,356,367,426,439,443,461,532,535],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇文章主要是要介紹如何正確的設置 Vue Cli 與 Vite 編譯後的路徑，而這件事情其實也攸關重要，如果沒有正確的設置，那麼在本地開發以及編譯後的路徑都會有問題，所以這篇文章就來介紹如何正確的設置。",[12,20,21],{"id":21},"路徑問題",[16,23,24,25,29,30,33],{},"首先這一個路徑設置大多都是為了編譯，但是許多人都會錯誤的去設置 ",[26,27,28],"code",{},"publicPath"," 或是 ",[26,31,32],{},"base","，而這兩個屬性的是不建議隨意設置的，因此基本上只要你看到你在本地開發時終端機出現的畫面是以下：",[16,35,36],{},[37,38],"img",{"alt":39,"src":40},"Vite","https:\u002F\u002Fi.imgur.com\u002FlChYr73.png",[16,42,43],{},[37,44],{"alt":45,"src":46},"Vue Cli","https:\u002F\u002Fi.imgur.com\u002FChdzKwA.png",[16,48,49],{},"那麼你的路徑就是錯誤的，所以這一篇我將會來介紹如何正確的設置編譯路徑。",[51,52,53],"blockquote",{},[16,54,55],{},"Note\n為什麼要正確的設置編譯路徑呢？其主要原因是區分出開發環境與部署環境的差異，而這主要比較明顯影響在靜態資源的路徑取用上，例如：圖片、CSS、JS 等等，因此正確的去設置編譯路徑就格外重要。",[12,57,59],{"id":58},"設置-vue-cli","設置 Vue Cli",[16,61,62,63,65],{},"首先我們先聊一下 Vue Cli 的設置，通常我們 Vue Cli 編譯後如果要部署到 GitHub Pages 之前都會先建立一個 vue.config.js 並新增一個屬性 ",[26,64,28],{},"，而這個屬性的值就是我們要設置的路徑，例如：",[67,68,73],"pre",{"className":69,"code":70,"language":71,"meta":72,"style":72},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","module.exports = {\n  publicPath: '.\u002F',\n};\n","js","",[26,74,75,98,111],{"__ignoreMap":72},[76,77,80,84,88,91,95],"span",{"class":78,"line":79},"line",1,[76,81,83],{"class":82},"stw71","module",[76,85,87],{"class":86},"s8XSl",".",[76,89,90],{"class":82},"exports",[76,92,94],{"class":93},"sOudu"," =",[76,96,97],{"class":86}," {\n",[76,99,101,104,108],{"class":78,"line":100},2,[76,102,103],{"class":86},"  publicPath: ",[76,105,107],{"class":106},"sWayO","'.\u002F'",[76,109,110],{"class":86},",\n",[76,112,114],{"class":78,"line":113},3,[76,115,116],{"class":86},"};\n",[16,118,119,120,127],{},"雖然這樣子設置也是正確的，但是在 Vue Cli ",[121,122,126],"a",{"href":123,"rel":124},"https:\u002F\u002Fcli.vuejs.org\u002Fzh\u002Fconfig\u002F#publicpath",[125],"nofollow","官方文件","其實有給出一個建議的寫法",[16,129,130],{},[37,131],{"alt":132,"src":133},"Vue Cli publicPath","https:\u002F\u002Fi.imgur.com\u002FuwzkJA4.png",[67,135,137],{"className":69,"code":136,"language":71,"meta":72,"style":72},"module.exports = {\n  publicPath: process.env.NODE_ENV === 'production'\n    ? '\u002Fproduction-sub-path\u002F'\n    : '\u002F'\n}\n",[26,138,139,151,165,173,182],{"__ignoreMap":72},[76,140,141,143,145,147,149],{"class":78,"line":79},[76,142,83],{"class":82},[76,144,87],{"class":86},[76,146,90],{"class":82},[76,148,94],{"class":93},[76,150,97],{"class":86},[76,152,153,156,159,162],{"class":78,"line":100},[76,154,155],{"class":86},"  publicPath: process.env.",[76,157,158],{"class":82},"NODE_ENV",[76,160,161],{"class":93}," ===",[76,163,164],{"class":106}," 'production'\n",[76,166,167,170],{"class":78,"line":113},[76,168,169],{"class":93},"    ?",[76,171,172],{"class":106}," '\u002Fproduction-sub-path\u002F'\n",[76,174,176,179],{"class":78,"line":175},4,[76,177,178],{"class":93},"    :",[76,180,181],{"class":106}," '\u002F'\n",[76,183,185],{"class":78,"line":184},5,[76,186,187],{"class":86},"}\n",[189,190,193],"callout",{"title":191,"type":192},"Note","note",[16,194,195,198,199,202,203,205,206,209],{},[26,196,197],{},"production-sub-path"," 是你的 GitHub Pages 的儲存庫，例如我的儲存庫就是 ",[26,200,201],{},"vue3-example","，所以我的 ",[26,204,197],{}," 就是 ",[26,207,208],{},"\u002Fvue3-example\u002F","。",[16,211,212],{},"這樣子可以確保我們編譯後的路徑以及本地開發的路徑都是正確的。",[12,214,216],{"id":215},"設置-vite","設置 Vite",[16,218,219,220,65],{},"那麼 Vite 也是類似，通常我們 Vite 編譯後如果要部署到 GitHub Pages 之前都會先建立一個 vite.config.js 並新增一個屬性 ",[26,221,32],{},[67,223,225],{"className":69,"code":224,"language":71,"meta":72,"style":72},"\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  \u002F\u002F ...略過其他設置\n  base: '.\u002F'\n})\n",[26,226,227,233,249,254,262],{"__ignoreMap":72},[76,228,229],{"class":78,"line":79},[76,230,232],{"class":231},"sGBqm","\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\n",[76,234,235,238,241,245],{"class":78,"line":100},[76,236,237],{"class":93},"export",[76,239,240],{"class":93}," default",[76,242,244],{"class":243},"scAaK"," defineConfig",[76,246,248],{"class":247},"sTzn1","({\n",[76,250,251],{"class":78,"line":113},[76,252,253],{"class":231},"  \u002F\u002F ...略過其他設置\n",[76,255,256,259],{"class":78,"line":175},[76,257,258],{"class":86},"  base: ",[76,260,261],{"class":106},"'.\u002F'\n",[76,263,264],{"class":78,"line":184},[76,265,266],{"class":247},"})\n",[16,268,269,270,274],{},"當然這一條在官方文件上也有，可是有趣的是",[121,271,126],{"href":272,"rel":273},"https:\u002F\u002Fcn.vitejs.dev\u002Fconfig\u002Fshared-options.html#base",[125],"上這次並沒有給出建議的寫法了",[16,276,277],{},[37,278],{"alt":279,"src":280},"Vite Base","https:\u002F\u002Fi.imgur.com\u002FoO5JIwQ.png",[16,282,283,284,287,288,291,292,294],{},"那這樣子我們是不是就一率寫 ",[26,285,286],{},".\u002F"," 或是寫死 ",[26,289,290],{},"\u002Frepo-name\u002F"," 就好了呢？其實不是，因為這樣子的話我們在本地開發的時候就會有問題，所以我們還是要像 Vue Cli 一樣，要根據環境來設置 ",[26,293,32],{}," 的值，所以你可能會很興高采烈地這樣寫...",[67,296,298],{"className":69,"code":297,"language":71,"meta":72,"style":72}