8,108,114,130,136,141],{"__ignoreMap":79},[83,84,87],"span",{"class":85,"line":86},"line",1,[83,88,90],{"class":89},"sMAXC","{\n",[83,92,94],{"class":85,"line":93},2,[83,95,97],{"class":96},"szH_Z","  ...\n",[83,99,101,105],{"class":85,"line":100},3,[83,102,104],{"class":103},"sKpQp","  \"scripts\"",[83,106,107],{"class":89},": {\n",[83,109,111],{"class":85,"line":110},4,[83,112,113],{"class":96},"    ...\n",[83,115,117,120,123,127],{"class":85,"line":116},5,[83,118,119],{"class":103},"    \"test\"",[83,121,122],{"class":89},": ",[83,124,126],{"class":125},"sTRMh","\"mocha\"",[83,128,129],{"class":89},",\n",[83,131,133],{"class":85,"line":132},6,[83,134,135],{"class":89},"  },\n",[83,137,139],{"class":85,"line":138},7,[83,140,97],{"class":96},[83,142,144],{"class":85,"line":143},8,[83,145,146],{"class":89},"}\n",[16,148,149],{},"新增完畢之後，我們回到 test_helper.js 中就可以準備開始了。",[12,151,35],{"id":35},[16,153,154,156],{},[33,155,35],{}," 的意思是「準備測試執行之前」先執行裡面的內容，所以基本語法是這樣撰寫",[74,158,162],{"className":159,"code":160,"language":161,"meta":79,"style":79},"language-js shiki shiki-themes github-dark-high-contrast","before(() => {\n  console.log('before');\n})\n","js",[33,163,164,179,196],{"__ignoreMap":79},[83,165,166,169,172,176],{"class":85,"line":86},[83,167,35],{"class":168},"sj_SG",[83,170,171],{"class":89},"(() ",[83,173,175],{"class":174},"sWyjQ","=>",[83,177,178],{"class":89}," {\n",[83,180,181,184,187,190,193],{"class":85,"line":93},[83,182,183],{"class":89},"  console.",[83,185,186],{"class":168},"log",[83,188,189],{"class":89},"(",[83,191,192],{"class":125},"'before'",[83,194,195],{"class":89},");\n",[83,197,198],{"class":85,"line":100},[83,199,200],{"class":89},"})\n",[16,202,203,204,207,208,210],{},"反過另來一個則是 ",[33,205,206],{},"after","，但 ",[33,209,206],{}," 則是全部測試完畢後才會執行裡面內容。",[12,212,40],{"id":213},"beforeeach",[16,215,216,218,219,221,222,224,225,227,228,230],{},[33,217,40],{}," 是「每次執行測試之前」，都先執行裡面的內容一次，這邊要注意與 ",[33,220,35],{}," 不同，因為 ",[33,223,35],{}," 只會執行一次，而 ",[33,226,40],{}," 則是每一個測試執行時，都會先跑過一次，撰寫方式也與 ",[33,229,35],{}," 相同",[74,232,234],{"className":159,"code":233,"language":161,"meta":79,"style":79},"beforeEach(() => {\n  console.log('beforeEach');\n})\n",[33,235,236,246,259],{"__ignoreMap":79},[83,237,238,240,242,244],{"class":85,"line":86},[83,239,40],{"class":168},[83,241,171],{"class":89},[83,243,175],{"class":174},[83,245,178],{"class":89},[83,247,248,250,252,254,257],{"class":85,"line":93},[83,249,183],{"class":89},[83,251,186],{"class":168},[83,253,189],{"class":89},[83,255,256],{"class":125},"'beforeEach'",[83,258,195],{"class":89},[83,260,261],{"class":85,"line":100},[83,262,200],{"class":89},[16,264,265,266,269],{},"另一個則是 ",[33,267,268],{},"afterEach","，也就是每個測試完成之後就會執行裡面內容。",[12,271,273],{"id":272},"describe-與-it","describe 與 it",[16,275,276,278,279,281,282,284],{},[33,277,45],{}," 則是描述這個測試區塊在做什麼，而這個是一個群組概念，通常裡面會有很多測試在裡面，因此會搭配 ",[33,280,50],{}," 居多，而 ",[33,283,50],{}," 就是預計要測試的內容，撰寫方式如下",[74,286,288],{"className":159,"code":287,"language":161,"meta":79,"style":79},"describe('第一條測試', () => {\n  it('這是一個測試 1 + 1 是不是等於 2', () => {\n    ...\n  })\n})\n",[33,289,290,306,322,326,331],{"__ignoreMap":79},[83,291,292,294,296,299,302,304],{"class":85,"line":86},[83,293,45],{"class":168},[83,295,189],{"class":89},[83,297,298],{"class":125},"'第一條測試'",[83,300,301],{"class":89},", () ",[83,303,175],{"class":174},[83,305,178],{"class":89},[83,307,308,311,313,316,318,320],{"class":85,"line":93},[83,309,310],{"class":168},"  it",[83,312,189],{"class":89},[83,314,315],{"class":125},"'這是一個測試 1 + 1 是不是等於 2'",[83,317,301],{"class":89},[83,319,175],{"class":174},[83,321,178],{"class":89},[83,323,324],{"class":85,"line":100},[83,325,113],{"class":174},[83,327,328],{"class":85,"line":110},[83,329,330],{"class":89},"  })\n",[83,332,333],{"class":85,"line":116},[83,334,200],{"class":89},[16,336,337,338,340,341,343,344,346,347,349],{},"上面是 ",[33,339,45],{}," 與 ",[33,342,50],{}," 的基本用法，而 ",[33,345,55],{}," 則是一個很特別的測試方式，簡單來講就是當如果你有一個寫好的測試，但是你暫時不想要跑這一個測試時，可以使用 ",[33,348,55],{}," 忽略該測試，你可能會想說為什麼不乾脆刪除就好了？",[16,351,352,353,355],{},"主要原因是，有時候我們只是要暫時忽略該測試而不是真的要刪除，因為裡面可能包含了之前的邏輯在裡面，當你刪除的話，那麼我們之後要回頭尋找就會非常困難，因此就會建議使用 ",[33,354,55],{}," 忽略並保留當初撰寫的測試邏輯。",[16,357,358,359,361],{},"那這邊出現了一個疑惑，我們要如何驗證結果？這邊就要使用剛剛前面所講的 ",[33,360,61],{},"，意旨斷言結果是不是真的，例如：",[74,363,365],{"className":159,"code":364,"language":161,"meta":79,"style":79},"describe('第一條測試', () => {\n  it('這是一個測試 1 + 1 是不是等於 2', () => {\n    const a = 1 + 1;\n    assert(a === 2);\n  })\n})\n",[33,366,367,381,395,418,434,438],{"__ignoreMap":79},[83,368,369,371,373,375,377,379],{"class":85,"line":86},[83,370,45],{"class":168},[83,372,189],{"class":89},[83,374,298],{"class":125},[83,376,301],{"class":89},[83,378,175],{"class":174},[83,380,178],{"class":89},[83,382,383,385,387,389,391,393],{"class":85,"line":93},[83,384,310],{"class":168},[83,386,189],{"class":89},[83,388,315],{"class":125},[83,390,301],{"class":89},[83,392,175],{"class":174},[83,394,178],{"class":89},[83,396,397,400,404,407,410,413,415],{"class":85,"line":100},[83,398,399],{"class":174},"    const",[83,401,403],{"class":402},"sCcAr"," a",[83,405,406],{"class":174}," =",[83,408,409],{"class":402}," 1",[83,411,412],{"class":174}," +",[83,414,409],{"class":402},[83,416,417],{"class":89},";\n",[83,419,420,423,426,429,432],{"class":85,"line":110},[83,421,422],{"class":168},"    assert",[83,424,425],{"class":89},"(a ",[83,427,428],{"class":174},"===",[83,430,431],{"class":402}," 2",[83,433,195],{"class":89},[83,435,436],{"class":85,"line":116},[83,437,330],{"class":89},[83,439,440],{"class":85,"line":132},[83,441,200],{"class":89},[16,443,444,445,448],{},"這樣子撰寫後你就可以透過 ",[33,446,447],{},"npm run test"," 跑一次看結果，而這邊我也提供完整的範例確保你執行是正確的",[74,450,452],{"className":159,"code":451,"language":161,"meta":79,"style":79},"const { describe, it } = require('mocha');\n\ndescribe('第一條測試', () => {\n  it('這是一個測試 1 + 1 是不是等於 2', () => {\n    const a = 1 + 1;\n    assert(a === 2);\n  })\n})\n",[33,453,454,485,491,505,519,535,547