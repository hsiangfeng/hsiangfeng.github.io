[{"data":1,"prerenderedAt":451},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190530\u002F957018086\u002F":3,"page:\u002Fnodejs\u002F20190530\u002F957018086\u002F":4,"alt:\u002Fnodejs\u002F20190530\u002F957018086\u002F":3,"prev-next:\u002Fnodejs\u002F20190530\u002F957018086\u002F":427,"related:\u002Fnodejs\u002F20190530\u002F957018086\u002F":436},"\u002Fen\u002Fnodejs\u002F2019\u002F05\u002F30\u002Fkoajs-install-and-setup\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":412,"date":413,"description":18,"extension":414,"lang":415,"meta":416,"navigation":296,"path":417,"readingMinutes":418,"seo":419,"standalone":420,"stem":421,"tags":422,"tldr":424,"updated":424,"url":425,"__hash__":426},"content\u002FNodejs\u002FKoajs安裝及架設.md","Koajs安裝及架設","957018086",{"type":9,"value":10,"toc":405},"minimark",[11,15,19,23,26,56,63,73,76,81,84,88,95,221,228,233,237,240,243,264,270,277,316,321,324,327,342,345,354,360,365,372,377,384,389,392,395,401],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"因為工作上需要，將會接觸到 Koajs 這個框架，所以就自己來試著架設摸摸看，雖然主管說本質上與 Express 很像，但是自己還是要摸一下才知道所以然，因為這框架似乎使用了非常多的非同步與同步的做法，裡面也主要使用 ES6、ES7 寫法，所以說如果是寫 Express 的人是可以直接轉用這個沒問題。",[12,20,22],{"id":21},"安裝-koa","安裝 koa",[16,24,25],{},"首先要一定要先安裝 koa，所以要打開 cmd 輸入指令",[27,28,33],"pre",{"className":29,"code":30,"language":31,"meta":32,"style":32},"language-cmd shiki shiki-themes github-dark-high-contrast","cd project\nnpm init\nnpm install koa --save\n","cmd","",[34,35,36,44,50],"code",{"__ignoreMap":32},[37,38,41],"span",{"class":39,"line":40},"line",1,[37,42,43],{},"cd project\n",[37,45,47],{"class":39,"line":46},2,[37,48,49],{},"npm init\n",[37,51,53],{"class":39,"line":52},3,[37,54,55],{},"npm install koa --save\n",[16,57,58],{},[59,60],"img",{"alt":61,"src":62},"koa","https:\u002F\u002Fi.imgur.com\u002Fx9LuMw0.png",[16,64,65,66],{},"另外 koa 也有",[67,68,72],"a",{"href":69,"rel":70},"https:\u002F\u002Fkoa.bootcss.com\u002F",[71],"nofollow","中文網站",[16,74,75],{},"以上指令輸入完之後，應該可以看到資料夾有這三個結構 ↓",[