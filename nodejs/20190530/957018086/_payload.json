":121},[37,212,213],{"class":117},"listen",[37,215,122],{"class":121},[37,217,218],{"class":110},"3000",[37,220,129],{"class":121},[16,222,223,224,227],{},"接下來就可以再 cmd 畫面下輸入 ",[34,225,226],{},"node app.js","，你應該會發現好像停止了，但是其實已經開始運作了哩~",[16,229,230],{},[59,231],{"alt":61,"src":232},"https:\u002F\u002Fi.imgur.com\u002FXolDwMk.png",[12,234,236],{"id":235},"koa-應用程式產生器","koa 應用程式產生器",[16,238,239],{},"其實中文文件真的很少 koa，我想應該是主要開發大多都是 Express，但是 koa 是由 Express 演變而來，所以其實也有類似的應用程式產生器，所以讓我們紀錄一下該如何使用吧 ↓",[16,241,242],{},"首先套件必須安裝在全域底下與 Express-generator 一樣。",[27,244,246],{"className":97,"code":245,"language":99,"meta":32,"style":32},"npm install -g koa-generator\n",[34,247,248],{"__ignoreMap":32},[37,249,250,253,256,259,261],{"class":39,"line":40},[37,251,252],{"class":121},"npm install ",[37,254,255],{"class":106},"-",[37,257,258],{"class":121},"g koa",[37,260,255],{"class":106},[37,262,263],{"class":121},"generator\n",[16,265,266],{},[59,267],{"alt":268,"src":269},"koa-generator","https:\u002F\u002Fi.imgur.com\u002FzN5UUIu.png",[16,271,272,273],{},"我們可以試著輸入以下指令確定是否已安裝成功，另外這邊要",[274,275,276],"strong",{},"注意一件事情 koa-generator 支援安裝 1.X 及 2.X 的 koa，所以在輸入指令的時候自己要注意一下。",[27,278,280],{"className":97,"code":279,"language":99,"meta":32,"style":32},"koa -V\n\nor\n\nkoa2 -V\n",[34,281,282,292,298,303,307],{"__ignoreMap":32},[37,283,284,287,289],{"class":39,"line":40},[37,285,286],{"class":121},"koa ",[37,288,255],{"class":106},[37,290,291],{"class":110},"V\n",[37,293,294],{"class":39,"line":46},[37,295,297],{"emptyLinePlaceholder":296},true,"\n",[37,299,300],{"class":39,"line":52},[37,301,302],{"class":121},"or\n",[37,304,305],{"class":39,"line":154},[37,306,297],{"emptyLinePlaceholder":296},[37,308,309,312,314],{"class":39,"line":161},[37,310,311],{"class":121},"koa2 ",[37,313,255],{"class":106},[37,315,291],{"class":110},[16,317,318],{},[59,319],{"alt":61,"src":320},"https:\u002F\u002Fi.imgur.com\u002FCdp3sX8.png",[16,322,323],{},"接下來就快速產生一個應用程式吧。",[16,325,326],{},"這邊我會使用 koa2 並使用 PUG Templates，若不熟悉 PUG 可以使用 ejs，只需要這樣寫就可以哩 ↓\n(聽說 koa1 結構上比較亂，所以我個人也建議使用 koa2)",[27,328,330],{"className":97,"code":329,"language":99,"meta":32,"style":32},"koa2 --ejs\n",[34,331,332],{"__ignoreMap":32},[37,333,334,336,339],{"class":39,"line":40},[37,335,311],{"class":121},[37,337,338],{"class":106},"--",[37,340,341],{"class":121},"ejs\n",[16,343,344],{},"如果你與我一樣習慣使用 PUG(jade) 那就直接輸入以下指令默認生成就好了 ↓",[27,346,348],{"className":97,"code":347,"language":99,"meta":32,"style":32},"koa2\n",[34,349,350],{"__ignoreMap":32},[37,351,352],{"class":39,"line":40},[37,353,347],{"class":121},[16,355,356],{},[59,357],{"alt":358,"src":359},"koa jade","https:\u002F\u002Fi.imgur.com\u002FXC4Lt4A.png",[16,361,362],{},[59,363],{"alt":358,"src":364},"https:\u002F\u002Fi.imgur.com\u002FDz2gUZH.png",[16,366,367,368,371],{},"生成完畢後只需要輸入 ",[34,369,370],{},"npm install"," 就可以將相依套件給安裝完畢哩 ↓",[16,373,374],{},[59,375],{"alt":61,"src":376},"https:\u002F\u002Fi.imgur.com\u002F41cAhrj.png",[16,378,379,380,383],{},"接下來只需要輸入神奇的指令 ",[34,381,382],{},"npm start"," 就成功建立完畢哩!",[16,385,386],{},[59,387],{"alt":61,"src":388},"https:\u002F\u002Fi.imgur.com\u002FjD7QtWl.png",[12,390,391],{"id":391},"結尾",[16,393,394],{},"這邊附上 koa-generator 的 npm 安裝網址。",[16,396,397],{},[67,398,268],{"href":399,"rel":400},"https:\u002F\u002Fwww.npmjs.com\u002Fpackage\u002Fkoa-generator",[71],[402,403,404],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .s