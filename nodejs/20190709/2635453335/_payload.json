[{"data":1,"prerenderedAt":652},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190709\u002F2635453335\u002F":3,"page:\u002Fnodejs\u002F20190709\u002F2635453335\u002F":4,"alt:\u002Fnodejs\u002F20190709\u002F2635453335\u002F":3,"prev-next:\u002Fnodejs\u002F20190709\u002F2635453335\u002F":628,"related:\u002Fnodejs\u002F20190709\u002F2635453335\u002F":637},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F09\u002Fkoa-saga-basics\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":612,"date":613,"description":18,"extension":614,"lang":615,"meta":616,"navigation":207,"path":617,"readingMinutes":618,"seo":619,"standalone":620,"stem":621,"tags":622,"tldr":625,"updated":625,"url":626,"__hash__":627},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-基礎篇.md","這是在講關於一名叫 Koa 的全端勇士傳說-基礎篇","2635453335",{"type":9,"value":10,"toc":606},"minimark",[11,15,19,23,26,32,35,38,61,64,67,70,73,76,79,85,88,106,109,115,118,135,138,144,147,150,153,312,318,324,335,341,344,347,475,478,590,602],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這是一篇新的學習紀錄，前一系列是 全端勇士之路 Node.js 基礎學習，接下來這一篇將會開始介紹一個新的框架，叫做 Koa.js",[12,20,22],{"id":21},"koajs","Koa.js",[16,24,25],{},"老樣子，先來科普一下 Koa.js 是什麼吧~",[16,27,28],{},[29,30],"img",{"alt":22,"src":31},"https:\u002F\u002Fi.imgur.com\u002F0GNffeE.png",[16,33,34],{},"Koa.js 是由 Express 原團隊所開發的新一代框架，使用方式與操作方式我們後面再來講。",[16,36,37],{},"那麼 Koa.js 又有什麼特色? Koa.js 最主要特色是支援 ES 7、ES 8 的最新語法以及它大量的使用了 Async \u002F Await，如果不知道 Async \u002F Await 的人建議可以看我先前寫的以下文章，這樣才不會一下子就被嚇到 ↓",[39,40,41,49,55],"ul",{},[42,43,44],"li",{},[45,46,48],"a",{"href":47},"\u002Fjavascript\u002F20190530\u002F3337676145\u002F","JavaScript 非同步與同步事件之 Promise",[42,50,51],{},[45,52,54],{"href":53},"\u002Fjavascript\u002F20190530\u002F2986904348\u002F","JavaScript 非同步與同步事件之 await",[42,56,57],{},[45,58,60],{"href":59},"\u002Fjavascript\u002F20190530\u002F3821927811\u002F","JavaScript 非同步與同步事件之 async",[16,62,63],{},"Koa 有分為兩種版本，也就是 Koa 1、Koa 2，但是目前來講若不是特殊需求，大致上都是採用 Koa2 來開發。",[16,65,66],{},"※ Koa 的開發環境必須為 Node.js 7.6.0 以上才可以唷~",[16,68,69],{},"※ 這一篇開發將會使用滿滿的 ES6 與 ES7，所以建議至少要懂 ES6 再來看此系列。",[12,71,72],{"id":72},"基礎安裝",[16,74,75],{},"那麼 Koa 安裝的方式也是與 Express，但是這邊一樣會從頭介紹如何安裝。",[16,77,78],{},"首先先建立一個專案資料夾叫 koa-project，並透過終端機移動到該目錄下",[16,80,81],{},[29,82],{"alt":83,"src":84},"移動到該目錄","https:\u002F\u002Fi.imgur.com\u002FIWAKoej.png",[16,86,87],{},"然後初始化 npm",[89,90,95],"pre",{"className":91,"code":92,"language":93,"meta":94,"style":94},"language-js shiki shiki-themes github-dark-high-contrast","npm init\n","js","",[96,97,98],"code",{"__ignoreMap":94},[99,100,103],"span",{"class":101,"line":102},"line",1,[99,104,92],{"class":105},"sMAXC",[16,107,108],{},"(我偷懶輸入 -y，快速生成)",[16,110,111],{},[29,112],{"alt":113,"src":114},"npm init","https:\u002F\u002Fi.imgur.com\u002F8pPIthl.png",[16,116,117],{},"接下來就是準備安裝 koa",[89,119,121],{"className":91,"code":120,"language":93,"meta":94,"style":94},"npm install --save koa\n",[96,122,123],{"__ignoreMap":94},[99,124,125,128,132],{"class":101,"line":102},[99,126,127],{"class":105},"npm install ",[99,129,131],{"class":130},"sWyjQ","--",[99,133,134],{"class":105},"save koa\n",[16,136,137],{},"正常安裝狀況下，koa 會直接安裝第二版的 koa2，而不是 koa1",[16,139,140],{},[29,141],{"alt":142,"src":143},"koa2","https:\u002F\u002Fi.imgur.com\u002F4hFWgQL.png",[12,145,146],{"id":146},"起手式",[16,148,149],{},"前面有講到 koa.js 是 Express 原團隊所開發的新一代框架，所以其實滿多地方與 Express 雷同，這對於學習過 Express 的人來講是一個福音，只需要會 Express 就等同會 6 成 ~ 7 成的 koa.js 了",[16,151,152],{},"那麼我們先來建立一個 app.js 內容如下",[89,154,156],{"className":91,"code":155,"language":93,"meta":94,"style":94},"const koa = require('koa');\nconst app = new koa();\n\napp.use(async (ctx) => {\n  ctx.body = 'Hello Koa';\n});\n\napp.listen(3000, async ()=>{\n  console.log('Example app listening on port 3000!');\n});\n",[96,157,158,184,202,209,239,254,260,265,291,307],{"__ignoreMap":94},[99,159,160,163,167,170,174,177,181],{"class":101,"line":102},[99,161,162],{"class":130},"const",[99,164,166],{"class":165},"sCcAr"," koa",[99