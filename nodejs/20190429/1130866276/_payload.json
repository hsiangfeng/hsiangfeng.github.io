[{"data":1,"prerenderedAt":115},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190429\u002F1130866276\u002F":3,"page:\u002Fnodejs\u002F20190429\u002F1130866276\u002F":4,"alt:\u002Fnodejs\u002F20190429\u002F1130866276\u002F":3,"prev-next:\u002Fnodejs\u002F20190429\u002F1130866276\u002F":90,"related:\u002Fnodejs\u002F20190429\u002F1130866276\u002F":99},"\u002Fen\u002Fnodejs\u002F2019\u002F04\u002F29\u002Fnodejs-mysterious-double-request\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":73,"date":74,"description":18,"extension":75,"lang":76,"meta":77,"navigation":78,"path":79,"readingMinutes":80,"seo":81,"standalone":82,"stem":83,"tags":84,"tldr":87,"updated":87,"url":88,"__hash__":89},"content\u002FNodejs\u002Fnodejs神奇的兩次Request.md","nodejs神奇的兩次Request","1130866276",{"type":9,"value":10,"toc":65},"minimark",[11,15,19,22,29,32,35,38,43,46,51,54,59,62],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"由於最近再進修 Nodejs + firebase ，所以也挪不太出時間來寫文章，但是練習 Nodejs 過程中遇到一個很低級&智障問題，結果因此卡了三天，所以這邊做一下紀錄。",[12,20,21],{"id":21},"問題",[16,23,24],{},[25,26],"img",{"alt":27,"src":28},"圖片","https:\u002F\u002Fi.imgur.com\u002F66AhQGE.png",[16,30,31],{},"使用 Nodejs 的時候，請求 auth 頁面卻不知道為什麼 Request 兩次，這個問題會導致 connect-flash 套件無法正常運作。",[12,33,34],{"id":34},"解決方式",[16,36,37],{},"後來請教了大大給予指引，說要我看一下開發者工具中的 network，看一下加載的檔案，一看我發現這兩個...",[16,39,40],{},[25,41],{"alt":27,"src":42},"https:\u002F\u002Fi.imgur.com\u002FQtTzTae.png",[16,44,45],{},"看到這個 Request 之後立刻去看一下 HTML 才發現我裡面塞了一個錯誤的 img",[16,47,48],{},[25,49],{"alt":27,"src":50},"https:\u002F\u002Fi.imgur.com\u002FYXme4KQ.png",[16,52,53],{},"刪除這一個錯誤的 img 或是給他一個正確圖片的路徑就會正常了。",[16,55,56],{},[25,57],{"alt":27,"src":58},"https:\u002F\u002Fi.imgur.com\u002FpnSbs8B.png",[12,60,61],{"id":61},"結論",[16,63,64],{},"自己完全沒料想到是圖片的問題，結果一直往錯誤的方向排查，一度以為是我的 router 有問題，殊不知結果是一個笨蛋問題...",{"title":66,"searchDepth":67,"depth":67,"links":68},"",2,[69,70,71,72],{"id":14,"depth":67,"text":14},{"id":21,"depth":67,"text":21},{"id":34,"depth":67,"text":34}