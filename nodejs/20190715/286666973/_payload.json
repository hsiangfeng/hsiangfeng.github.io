[{"data":1,"prerenderedAt":728},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190715\u002F286666973\u002F":3,"page:\u002Fnodejs\u002F20190715\u002F286666973\u002F":4,"alt:\u002Fnodejs\u002F20190715\u002F286666973\u002F":3,"prev-next:\u002Fnodejs\u002F20190715\u002F286666973\u002F":703,"related:\u002Fnodejs\u002F20190715\u002F286666973\u002F":712},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-2\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":685,"date":686,"description":687,"extension":688,"lang":689,"meta":690,"navigation":691,"path":692,"readingMinutes":693,"seo":694,"standalone":695,"stem":696,"tags":697,"tldr":700,"updated":700,"url":701,"__hash__":702},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-基礎篇-2.md","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-基礎篇(2)","286666973",{"type":9,"value":10,"toc":675},"minimark",[11,15,19,23,34,37,44,47,53,56,64,70,73,79,82,88,91,97,104,110,113,119,122,125,128,131,137,140,143,205,208,344,347,366,369,375,378,384,387,392,395,401,406,409,412,419,425,428,434,439,442,462,465,471,486,517,520,526,533,553,558,561,567,573,578,581,616,621,624,627,665,668,671],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面我們已經準備好 MySQL 的部分了，接下來這邊將會使用一套資料庫管理軟體來做 MySQL 操作也就是 Navicat (導航貓)",[12,20,22],{"id":21},"mysql","MySQL",[16,24,25,26,33],{},"可以自行到官方網站下載 ",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Fwww.navicat.com\u002Fcht",[31],"nofollow","導航貓","，安裝過程我就不附上了直接來操作。",[16,35,36],{},"打開 Navicat 新增一個連線",[16,38,39],{},[40,41],"img",{"alt":42,"src":43},"新增一個 MySQL 連線","https:\u002F\u002Fi.imgur.com\u002Fd60uIIL.png",[16,45,46],{},"依照欄位輸入相關欄位",[16,48,49],{},[40,50],{"alt":51,"src":52},"相關欄位","https:\u002F\u002Fi.imgur.com\u002Fb3QqIRz.png",[16,54,55],{},"輸入完畢之後可以點一下連線測試，確保連線成功",[16,57,58,59,63],{},"如果出現 ",[60,61,62],"code",{},"2003 - Can't connect to MySQL server on 'localhost'(10038)"," 基本上就是 XAMPP 沒有打開 MySQL，或者 MySQL IP位址輸入錯誤了",[16,65,66],{},[40,67],{"alt":68,"src":69},"Can't connect to MySQL server on 'localhost'(10038)","https:\u002F\u002Fi.imgur.com\u002Fn2HLn8G.png",[16,71,72],{},"正常成功的話會出現連線成功",[16,74,75],{},[40,76],{"alt":77,"src":78},"連線成功","https:\u002F\u002Fi.imgur.com\u002FSOWLDdC.png",[16,80,81],{},"接下來點兩下旁邊的 localhost 名稱的灰色小圖案",[16,83,84],{},[40,85],{"alt":86,"src":87},"灰色小圖案","https:\u002F\u002Fi.imgur.com\u002FvIVJ2lj.png",[16,89,90],{},"當它變成綠色就是我們已經連入 MySQL 資料庫哩~",[16,92,93],{},[40,94],{"alt":95,"src":96},"連入 MySQL","https:\u002F\u002Fi.imgur.com\u002Fk3lhTdK.png",[16,98,99,100,103],{},"接下來我們點一下 ",[60,101,102],{},"test"," 這個資料庫，然後在左邊點一下新增資料表",[16,105,106],{},[40,107],{"alt":108,"src":109},"新增資料表","https:\u002F\u002Fi.imgur.com\u002F23op6bb.png",[16,111,112],{},"然後資料表名稱叫 account，內容如下",[16,114,115],{},[40,116],{"alt":117,"src":118},"account 表","https:\u002F\u002Fi.imgur.com\u002FdEkELkM.png",[16,120,121],{},"這樣子資料表就新增成功哩~",[12,123,124],{"id":124},"基礎語法認識",[16,126,127],{},"接下來我們就要來認識一下基礎常用的 MySQL 語法哩~",[16,129,130],{},"所以這邊先切到查詢，並點一下新增查詢",[16,132,133],{},[40,134],{"alt":135,"src":136},"新增查詢","https:\u002F\u002Fi.imgur.com\u002F6DBUviD.png",[12,138,139],{"id":139},"建立資料表",[16,141,142],{},"由於後面練習會需要使用到資料表，你可以選擇手動開資料表，也可以用語法的方式來新增，如果要使用語法的話，那麼就要使用 CREATE TABLE 語法，範例如下",[144,145,150],"pre",{"className":146,"code":147,"language":148,"meta":149,"style":149},"language-sql shiki shiki-themes github-dark-high-contrast","  CREATE TABLE  '資料表名稱' (\n    欄位名稱1 資料類型 欄位設定選項\n    欄位名稱2 資料類型 欄位設定選項\n    ...\n    索引 欄位\n  )\n","sql","",[60,151,152,175,181,187,193,199],{"__ignoreMap":149},[153,154,157,161,164,168,172],"span",{"class":155,"line":156},"line",1,[153,158,160],{"class":159},"sWyjQ","  CREATE",[153,162,163],{"class":159}," TABLE",[153,165,167],{"class":166},"sMAXC","  '",[153,169,171],{"class":170},"sj_SG","資料表名稱",[153,173,174],{"class":166},"' (\n",[153,176,178],{"class":155,"line":177},2,[153,179,180],{"class":166},"    欄位名稱1 資料類型 欄位設定選項\n",[153,182,184],{"class":155,"line":183},3,[153,185,186],{"class":166},"    欄位名稱2 資料類型 欄位設定選項\n",[153,188,190],{"class":155,"line":189},4,[153,191,192],{"class":166},"    ...\n",[153,194,196],{"class":155,"line":195},5,[153,197,198],{"class":166},"    索引 欄位\n",[153,200,202],{"class":155,"line":201},6,[153,203,204],{"class":166},"  )\n",[16,206,207],{},"那麼我這邊會建立一個同學身高體重資料表，所以就這樣新增",[144,209,211],{"className":146,"code":210,"language":148,"meta":149,"style":149},"  CREATE TABLE testtabel (\n    t_id int(10) NOT NULL auto_increment,\n    name varchar(5) NOT NULL default '',\n    weight int(5) NOT NULL default 0,\n    height float(5) NOT NULL default 0,\n    PRIMARY KEY (t_id)\n  ) AUTO_INCREMENT=1;\n",[60,212,213,225,249,276,299,321,329],{"__ignoreMap":149},[153,214,215,217,219,222],{"class":155,"line":156},[153,216,160],{"class":159},[153,218,163],{"class":159},[153,220,221],{"class":170}," testtabel",[153,223,224],{"class":166}," (\n",[153,226,227,230,233,236,240,243,246],{"class":155,"line":177},[153,228,229],{"class":166},"    t_id ",[153,231,232],{"class":159},"int",[153,234,235],{"class":166},"(",[153,237,239],{"class":238},"sCcAr","10",[153,241,242],{"class":166},") ",[153,244,245],{"class":159},"NOT NULL",[153,247,248],{"class":166}," auto_increment,\n",[153,250,251,254,257,259,262,264,266,269,273],{"class":155,"line":183},[153,252,253],{"class":159},"    name",[153,255,256],{"class":159}," varchar",[153,258,235],{"class":166},[153,260,261],{"class":238},"5",[153,263,242],{"class":166},[153,265,245],{"class":159},[153,267,268],{"class":159}," default",[153,270,272],{"class":271},"sTRMh"," ''",[153,274,275],{"class":166},",\n",[153,277,278,281,284,286,288,290,292,294,297],{"class":155,"line":189},[153,279,280],{"class":159},"    weight",[153,282,283],{"class":159}," int",[153,285,235],{"class":166},[153,287,261],{"class":238},[153,289,242],{"class":166},[153,291,245],{"class":159},[153,293,268],{"class":159},[153,295,296],{"class":238}," 0",[153,298,275],{"class":166},[153,300,301,304,307,309,311,313,315,317,319],{"class":155,"line":195},[153,302,303],{"class":166},"    height ",[153,305,306],{"class":159},"float",[153,308,235],{"class":166},[153,310,261],{"class":238},[153,312,242],{"class":166},[153,314,245],{"class":159},[153,316,268],{"class":159},[153,318,296],{"class":238},[153,320,275],{"class":166},[153,322,323,326],{"class":155,"line":201},[153,324,325],{"class":159},"    PRIMARY KEY",[153,327,328],{"class":166}," (t_id)\n",[153,330,332,335,338,341],{"class":155,"line":331},7,[153,333,334],{"class":166},"  ) AUTO_INCREMENT",[153,336,337],{"class":159},"=",[153,339,340],{"class":238},"1",[153,342,343],{"class":166},";\n",[16,345,346],{},"說明:",[348,349,350,354,357,360,363],"ul",{},[351,352,353],"li",{},"NOT NULL - 不得為空",[351,355,356],{},"auto_increment - 自動填入",[351,358,359],{},"default - 預設值",[351,361,362],{},"PRIMARY KEY - 設置索引",[351,364,365],{},"AUTO_INCREMENT - 自動遞增，並於數字 1 開始",[16,367,368],{},"然後將上面這些 SQL 指令貼入並執行",[16,370,371],{},[40,372],{"alt":373,"src":374},"執行 SQL 指令","https:\u002F\u002Fi.imgur.com\u002FesqSrwT.png",[16,376,377],{},"執行完畢後，我們回到資料表的位子，然後按一下 F5 重新整理一下畫面就可以看到剛剛新增的資料表哩~",[16,379,380],{},[40,381],{"alt":382,"src":383},"資料表","https:\u002F\u002Fi.imgur.com\u002FXt9o3Ac.png",[16,385,386],{},"內容也會與我們所新增的相同",[16,388,389],{},[40,390],{"alt":382,"src":391},"https:\u002F\u002Fi.imgur.com\u002FnOxa0gL.png",[16,393,394],{},"當然也可以點一下資料表右鍵，設計資料表來查看是否都有與我們所撰寫的指令相同",[16,396,397],{},[40,398],{"alt":399,"src":400},"設計資料表","https:\u002F\u002Fi.imgur.com\u002FksCjIOo.png",[16,402,403],{},[40,404],{"alt":399,"src":405},"https:\u002F\u002Fi.imgur.com\u002F16sj6RQ.png",[16,407,408],{},"那麼這就是一個透過 SQL 指令生成資料表的方式~",[12,410,411],{"id":411},"查詢資料表",[16,413,414,415,418],{},"首先在上面輸入 ",[60,416,417],{},"SELECT * FROM account;"," 並點一下上方執行看看",[16,420,421],{},[40,422],{"alt":423,"src":424},"SELECT","https:\u002F\u002Fi.imgur.com\u002FBKiKWPn.png",[16,426,427],{},"接下來下方就會跳出查詢結果 (裡面沒東西是正常的)",[16,429,430],{},[40,431],{"alt":432,"src":433},"查詢結果","https:\u002F\u002Fi.imgur.com\u002FIsfa7O8.png",[435,436,438],"h3",{"id":437},"where","WHERE",[16,440,441],{},"讓我們回頭講一下語法吧~",[16,443,444,446,447,450,451,455,456,458,459],{},[60,445,423],{}," 是最 SQL 指令中最常被使用的語法，那 ",[60,448,449],{},"SELECT * FROM account"," 的意思是再說",[452,453,454],"strong",{},"查詢表中所有資料","，那麼如果要指定特定欄位查詢呢?那麼就會搭配使用 ",[60,457,438],{},"，完整語法就像這樣子 ",[60,460,461],{},"SELECT * FROM account WHERE aid = 1;",[16,463,464],{},"意思就是指查詢 account 資料表中 aid 欄位等於 1 的(由於資料表內沒資料，所以我塞入一下資料)，那麼就會得到這個結果",[16,466,467],{},[40,468],{"alt":469,"src":470},"查詢","https:\u002F\u002Fi.imgur.com\u002FVGGRYNQ.png",[16,472,473,474,477,478,481,482,485],{},"當然也可以加入 ",[60,475,476],{},"\u003C="," OR ",[60,479,480],{},">="," 等符號，所以另外做一下測試針對 ",[60,483,484],{},"testtabel"," 資料表來做一下查詢的動作，假設我今天要找體重大於 66 的人，那麼就這樣輸入查詢指令",[144,487,489],{"className":146,"code":488,"language":148,"meta":149,"style":149},"SELECT * FROM testtabel WHERE weight \u003C= 66;\n",[60,490,491],{"__ignoreMap":149},[153,492,493,495,498,501,504,506,509,512,515],{"class":155,"line":156},[153,494,423],{"class":159},[153,496,497],{"class":159}," *",[153,499,500],{"class":159}," FROM",[153,502,503],{"class":166}," testtabel ",[153,505,438],{"class":159},[153,507,508],{"class":159}," weight",[153,510,511],{"class":159}," \u003C=",[153,513,514],{"class":238}," 66",[153,516,343],{"class":166},[16,518,519],{},"那麼就會找到 tom、Tom (竟然兩個同名?!)",[16,521,522],{},[40,523],{"alt":524,"src":525},"tom","https:\u002F\u002Fi.imgur.com\u002FL1P1HdW.png",[16,527,528,529,532],{},"那如果我希望它做身高排序由低至高呢呢?那就會使用 ",[60,530,531],{},"ORDER BY","(預設是遞增排序由小至大)",[144,534,536],{"className":146,"code":535,"language":148,"meta":149,"style":149},"SELECT * FROM testtabel ORDER BY height\n",[60,537,538],{"__ignoreMap":149},[153,539,540,542,544,546,548,550],{"class":155,"line":156},[153,541,423],{"class":159},[153,543,497],{"class":159},[153,545,500],{"class":159},[153,547,503],{"class":166},[153,549,531],{"class":159},[153,551,552],{"class":166}," height\n",[16,554,555],{},[40,556],{"alt":531,"src":557},"https:\u002F\u002Fi.imgur.com\u002Fcl9hW0o.png",[16,559,560],{},"當然可以混和 WHERE + ORDER BY，但是務必注意先條件查詢在排序，否則會出現錯誤",[16,562,563],{},[40,564],{"alt":565,"src":566},"先條件查詢在排序","https:\u002F\u002Fi.imgur.com\u002FgbACNN8.png",[16,568,569,570],{},"正確用法是這樣 ",[60,571,572],{},"SELECT * FROM testtabel WHERE weight >= 66 ORDER BY height;",[16,574,575],{},[40,576],{"alt":565,"src":577},"https:\u002F\u002Fi.imgur.com\u002FR4N6oj2.png",[16,579,580],{},"如果希望做遞減排序(由大至小)，那麼只需要這樣寫即可",[144,582,584],{"className":146,"code":583,"language":148,"meta":149,"style":149},"SELECT * FROM testtabel WHERE weight >= 66 ORDER BY height DESC;\n",[60,585,586],{"__ignoreMap":149},[153,587,588,590,592,594,596,598,600,603,605,608,611,614],{"class":155,"line":156},[153,589,423],{"class":159},[153,591,497],{"class":159},[153,593,500],{"class":159},[153,595,503],{"class":166},[153,597,438],{"class":159},[153,599,508],{"class":159},[153,601,602],{"class":159}," >=",[153,604,514],{"class":238},[153,606,607],{"class":159}," ORDER BY",[153,609,610],{"class":166}," height ",[153,612,613],{"class":159},"DESC",[153,615,343],{"class":166},[16,617,618],{},[40,619],{"alt":613,"src":620},"https:\u002F\u002Fi.imgur.com\u002FnE5PKNc.png",[12,622,623],{"id":623},"補充",[16,625,626],{},"其中還有其他的條件例如:",[348,628,629,635,653,659],{},[351,630,631,634],{},[60,632,633],{},"GROUP BY"," - 將特定欄位做資料群組",[351,636,637,640,641,643,644,646,647,649,650,652],{},[60,638,639],{},"HAVING"," - 必須與 ",[60,642,633],{}," 一起使用會出現錯誤，類似 ",[60,645,438],{}," 功能，但是無法取代 ",[60,648,438],{},"，因為 ",[60,651,639],{}," 是先讀取後篩選",[351,654,655,658],{},[60,656,657],{},"DISINCT"," - 查詢某個欄位裡面是否有特定的資料",[351,660,661,664],{},[60,662,663],{},"LIMIT"," - 限制輸出的資料筆數",[16,666,667],{},"但是接下來的範例不太會講到其他的查詢條件，所以就不多作介紹囉~",[16,669,670],{},"除非後面有使用到，若有使用到那就會介紹一下哩",[672,673,674],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":149,"searchDepth":177,"depth":177,"links":676},[677,678,679,680,681,684],{"id":14,"depth":177,"text":14},{"id":21,"depth":177,"text":22},{"id":124,"depth":177,"text":124},{"id":139,"depth":177,"text":139},{"id":411,"depth":177,"text":411,"children":682},[683],{"id":437,"depth":183,"text":438},{"id":623,"depth":177,"text":623},"Nodejs","2019-07-15 10:35:15","前面我們已經準備好 MySQL 的部分了，接下來這邊將會使用一套資料庫管理軟體來做 MySQL 操作","md","zh-Hant",{},true,"\u002Fkoa\u002Fkoa-mysql-2","3",{"title":6,"description":687},false,"這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-基礎篇-2",[698,699],"Node.js","這是在講關於一名叫 Koa 的全端勇士傳說",null,"\u002Fnodejs\u002F20190715\u002F286666973\u002F","ckii3u18gqivXuD5oxaUbQ8ogkfkJuAddfUJkRjSPJA",{"newer":704,"older":708},{"url":705,"title":706,"date":707},"\u002Fnodejs\u002F20190716\u002F135070108\u002F","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-基礎篇(3)","2019-07-16 10:09:57",{"url":709,"title":710,"date":711},"\u002Fnodejs\u002F20190715\u002F976970526\u002F","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-基礎篇(1)","2019-07-15 10:11:32",[713,718,723],{"url":714,"title":715,"date":716,"readingMinutes":717},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":719,"title":720,"date":721,"readingMinutes":722},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":724,"title":725,