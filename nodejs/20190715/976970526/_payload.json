[{"data":1,"prerenderedAt":144},["ShallowReactive",2],{"header-locale:\u002Fnodejs\u002F20190715\u002F976970526\u002F":3,"page:\u002Fnodejs\u002F20190715\u002F976970526\u002F":4,"alt:\u002Fnodejs\u002F20190715\u002F976970526\u002F":3,"prev-next:\u002Fnodejs\u002F20190715\u002F976970526\u002F":119,"related:\u002Fnodejs\u002F20190715\u002F976970526\u002F":128},"\u002Fen\u002Fnodejs\u002F2019\u002F07\u002F15\u002Fkoa-saga-mysql-basics-1\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":102,"date":103,"description":18,"extension":104,"lang":105,"meta":106,"navigation":107,"path":108,"readingMinutes":109,"seo":110,"standalone":111,"stem":112,"tags":113,"tldr":116,"updated":116,"url":117,"__hash__":118},"content\u002F這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-基礎篇-1-.md","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-基礎篇(1)","976970526",{"type":9,"value":10,"toc":95},"minimark",[11,15,19,23,31,41,45,48,56,62,65,71,74,77,83,86,92],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來將會講點不同的東西，在 Express 章節有介紹過使用 firebase + Express 實作會員機制，所以這邊就來用 koa + MySQL 來實作一點東西，但是必須要先來做一下認識",[12,20,22],{"id":21},"mysql-是什麼","MySQL 是什麼?",[16,24,25,26],{},"在 Express 有介紹過 Firebase 是一個 NoSQL 的資料庫，如果不清楚可以看我這篇的 ",[27,28,30],"a",{"href":29},"\u002Fnodejs\u002F20190628\u002F905867989\u002F","介紹",[16,32,33,34,40],{},"那 MySQL 呢?簡單來講 MySQL 會使用到 SQL 指令來操控資料庫，本身 MySQL 也是開源的 ",[27,35,39],{"href":36,"rel":37},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002F%E9%97%9C%E8%81%AF%E5%BC%8F%E8%B3%87%E6%96%99%E5%BA%AB%E7%AE%A1%E7%90%86%E7%B3%BB%E7%B5%B1",[38],"nofollow","關聯式資料庫","，許多大型網站都有使用 MySQL，舉例來講 Facebook、Google 這類型網站都有使用 MySQL (雖然目前 MySQL 創辦人已經轉至開發 MariaDB，但是學會 MySQL 對於使用 MariaDB 也是有幫助的，因為 MariaDB 是以 MySQL 為基底開發)",[12,42,44],{"id":43},"mysql-預備動作","MySQL 預備動作",[16,46,47],{},"由於接下來要準備實作 MySQL 的部分，所以要先做一下一些起手式，在這邊我選擇較簡單的方式來安裝 MySQL，也就是使用 XAMPP 服務(當然你也可以使用你習慣的 MySQL 服務，我只是挑選一個最簡單的套裝軟體而已)",[16,49,50,51],{},"首先先開啟 ",[27,52,55],{"href":53,"rel":54},"https:\u002F\u002Fwww.apachefriends.org\u002Fzh_tw\u002Findex.html",[38],"XAMPP 網站",[16,57,58],{},[59,60],"img",{"alt":55,"src":61},"https:\u002F\u002Fi.imgur.com\u002FotLoGTk.png",[16,63,64],{},"接下來依照自己的作業系統下載 XAMPP 安裝檔案，下載完畢後開啟檔案安裝",[16,66,67],{},[59,68],{"alt":69,"src":70},"檔案安裝","https:\u002F\u002Fi.imgur.com\u002FCkCV4rq.png",[16,72,73],{},"基本上就是一直下一步下一步就安裝好哩~",[16,75,76],{},"接下來就是開啟 XAMPP，如果 port 被占用下方也會有提示訊息",[16,78,79],{},[59,80],{"alt":81,"src":82},"port 被占用","https:\u002F\u002Fi.imgur.com\u002FhB7dfOL.png",[16,84,85],{},"如果沒問題的話，就點一下 MySQL Start 吧!",[16,87,88],{},[59,89],{"alt":90,"src":91},"Start","https:\u002F\u002Fi.imgur.com\u002FUH4blKb.png",[16,93,94],{},"MySQL 欄位若亮起綠色代表成功開啟囉~",{"title":96,"searchDepth":97,"depth":97,"links":98},"",2,[99,100,101],{"id":14,"depth":97,"text":14},{"id":21,"depth":97,"text":22},{"id":43,"depth":97,"text":44},"Nodejs","2019-07-15 10:11:32","md","zh-Hant",{},true,"\u002Fkoa\u002Fkoa-mysql-1","1",{"title":6,"description":18},false,"這是在講關於一名叫 Koa 的全端勇士傳說\u002F這是在講關於一名叫-Koa-的全端勇士傳說-MySQL篇-基礎篇-1-",[114,115],"Node.js","這是在講關於一名叫 Koa 的全端勇士傳說",null,"\u002Fnodejs\u002F20190715\u002F976970526\u002F","i-wEHRcZ0L0STI0xSGod-Z8I7pQ8bfR_lcd3tf9OwGk",{"newer":120,"older":124},{"url":121,"title":122,"date":123},"\u002Fnodejs\u002F20190715\u002F286666973\u002F","這是在講關於一名叫 Koa 的全端勇士傳說-MySQL篇-基礎篇(2)","2019-07-15 10:35:15",{"url":125,"title":126,"date":127},"\u002Fnodejs\u002F20190714\u002F2270817411\u002F","這是在講關於一名叫 Koa 的全端勇士傳說-CSRF","2019-07-14 12:44:29",[129,134,139],{"url":130,"title":131,"date":132,"readingMinutes":133},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","2",{"url":135,"title":136,"date":137,"readingMinutes":138},"\u002Fnodejs\u002F20250313\u002F3008873732\u002F","六角專題班學習組電商 API 之完整教學","2025-03-13 09:13:26","11",{"url":140,"title":141,"date":142,"readingMinutes":143},"\u002Fnodejs\u002F20241225\u002F794319627\u002F","PM2 是 Process Manager 不是 PM2.5！","2024-12-25 10:31:33","6",1784013089542]