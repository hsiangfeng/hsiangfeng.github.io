[{"data":1,"prerenderedAt":2175},["ShallowReactive",2],{"header-locale:\u002Falgorithm\u002F20250204\u002F3664816602\u002F":3,"page:\u002Falgorithm\u002F20250204\u002F3664816602\u002F":4,"alt:\u002Falgorithm\u002F20250204\u002F3664816602\u002F":3,"prev-next:\u002Falgorithm\u002F20250204\u002F3664816602\u002F":2161,"related:\u002Falgorithm\u002F20250204\u002F3664816602\u002F":2170},"\u002Fen\u002Falgorithm\u002F2025\u002F02\u002F04\u002Ffizzbuzz-for-javascript\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":2147,"date":2148,"description":24,"extension":2149,"lang":2150,"meta":2151,"navigation":405,"path":2152,"readingMinutes":718,"seo":2153,"standalone":2154,"stem":2155,"tags":2156,"tldr":2158,"updated":2148,"url":2159,"__hash__":2160},"content\u002F演算法\u002FFizzBuzz-for-JavaScript.md","FizzBuzz for JavaScript","3664816602",{"type":9,"value":10,"toc":2134},"minimark",[11,18,22,25,29,32,35,61,64,104,116,119,122,125,128,201,204,209,223,312,317,329,333,342,367,425,431,437,440,460,469,587,592,599,702,707,731,735,747,886,891,895,906,909,920,937,951,967,977,995,998,1181,1186,1214,1394,1399,1402,1406,1409,1416,1419,1423,1426,1643,1650,1849,1852,2079,2082,2127,2130],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Falgorithm\u002Ffizzbuzz\u002FFizzBuzz_for_JavaScript_banner%20.webp",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"FizzBuzz 其實是一個遊戲，而這個遊戲也被作為一個程式設計面試考題，尤其是 Google、Facebook 等這些大公司都會使用這個 FizzBuzz 來考驗應徵者的基本程式能力，因此這個遊戲也是一個很好的練習題目。",[19,26,28],{"id":27},"簡單認識一下-fizzbuzz","簡單認識一下 FizzBuzz",[12,30,31],{},"相信滿多人都聽過 FizzBuzz，就算不知道也沒關係，其實 FizzBuzz 是一個很簡單的數學遊戲，而這個數學遊戲也廣泛被使用在程式設計的面試中，所以如果你是一位求職者，我會非常推薦你要去了解什麼是 FizzBuzz，以及它的規則。",[12,33,34],{},"那麼 FizzBuzz 的規則如下：",[36,37,38,46,52,58],"ol",{},[39,40,41,42],"li",{},"如果這個數字可以被 3 整除，則輸出 ",[43,44,45],"code",{},"Fizz",[39,47,48,49],{},"如果這個數字可以被 5 整除，則輸出 ",[43,50,51],{},"Buzz",[39,53,54,55],{},"如果這個數字可以被 3 與 5 同時整除，則輸出 ",[43,56,57],{},"FizzBuzz",[39,59,60],{},"如果這個數字都不符合上述條件，則輸出這個數字",[12,62,63],{},"所以基於以上規則來講，玩法就會如下：",[36,65,66,69,75,81,90,96],{},[39,67,68],{},"一群玩家圍繞起來",[39,70,71,72],{},"從指定的第一位玩家開始，第一位玩家說 ",[43,73,74],{},"1",[39,76,77,78],{},"第二位玩家接著說 ",[43,79,80],{},"2",[39,82,83,84,86,87],{},"第三位玩家時，第三位玩家要說 ",[43,85,45],{},"，而不是 ",[43,88,89],{},"3",[39,91,92,93],{},"第四位玩家時，第四位玩家要說 ",[43,94,95],{},"4",[39,97,98,99,86,101],{},"第五位玩家時，第五位玩家要說 ",[43,100,51],{},[43,102,103],{},"5",[12,105,106,107,110,111,86,113,115],{},"以此類推，當玩家說到 ",[43,108,109],{},"15"," 時，第十五位玩家要說 ",[43,112,57],{},[43,114,109],{},"。",[12,117,118],{},"以上就是 FizzBuzz 的規則。",[19,120,6],{"id":121},"fizzbuzz-for-javascript",[12,123,124],{},"那麼套用到程式語言中，常見的考題不外乎是以下：",[12,126,127],{},"「請建立一個 FizzBuzz 函式，當傳入一個數字時，請回傳符合 FizzBuzz 規則的結果，這邊將會傳入 1 到 100 的數字。」",[129,130,135],"pre",{"className":131,"code":132,"language":133,"meta":134,"style":134},"language-js shiki shiki-themes github-dark-high-contrast","FizzBuzz(1); \u002F\u002F 1\nFizzBuzz(3); \u002F\u002F Fizz\nFizzBuzz(5); \u002F\u002F Buzz\nFizzBuzz(15); \u002F\u002F FizzBuzz\n","js","",[43,136,137,159,173,187],{"__ignoreMap":134},[138,139,142,145,149,152,155],"span",{"class":140,"line":141},"line",1,[138,143,57],{"class":144},"sj_SG",[138,146,148],{"class":147},"sMAXC","(",[138,150,74],{"class":151},"sCcAr",[138,153,154],{"class":147},"); ",[138,156,158],{"class":157},"sQrFR","\u002F\u002F 1\n",[138,160,162,164,166,168,170],{"class":140,"line":161},2,[138,163,57],{"class":144},[138,165,148],{"class":147},[138,167,89],{"class":151},[138,169,154],{"class":147},[138,171,172],{"class":157},"\u002F\u002F Fizz\n",[138,174,176,178,180,182,184],{"class":140,"line":175},3,[138,177,57],{"class":144},[138,179,148],{"class":147},[138,181,103],{"class":151},[138,183,154],{"class":147},[138,185,186],{"class":157},"\u002F\u002F Buzz\n",[138,188,190,192,194,196,198],{"class":140,"line":189},4,[138,191,57],{"class":144},[138,193,148],{"class":147},[138,195,109],{"class":151},[138,197,154],{"class":147},[138,199,200],{"class":157},"\u002F\u002F FizzBuzz\n",[12,202,203],{},"那麼透過上述考題以及 FizzBuzz 的規則，我們可以分析出幾個步驟：",[205,206,208],"h3",{"id":207},"步驟一建立-fizzbuzz-函式","步驟一：建立 FizzBuzz 函式",[12,210,211,212,215,216,218,219,222],{},"由於會傳入 ",[43,213,214],{},"1~100"," 的數字，代表著我們這邊會需要使用到迴圈，跑 ",[43,217,214],{}," 的數字，因此我們會使用 ",[43,220,221],{},"for"," 迴圈來處理",[129,224,226],{"className":131,"code":225,"language":133,"meta":134,"style":134},"const FizzBuzz = (num) => {\n  for (let i = 1; i \u003C= num; i++) {\n    console.log(i);\n  }\n};\n",[43,227,228,256,290,301,306],{"__ignoreMap":134},[138,229,230,234,237,240,243,247,250,253],{"class":140,"line":141},[138,231,233],{"class":232},"sWyjQ","const",[138,235,236],{"class":144}," FizzBuzz",[138,238,239],{"class":232}," =",[138,241,242],{"class":147}," (",[138,244,246],{"class":245},"s_sBn","num",[138,248,249],{"class":147},") ",[138,251,252],{"class":232},"=>",[138,254,255],{"class":147}," {\n",[138,257,258,261,263,266,269,272,275,278,281,284,287],{"class":140,"line":161},[138,259,260],{"class":232},"  for",[138,262,242],{"class":147},[138,264,265],{"class":232},"let",[138,267,268],{"class":147}," i ",[138,270,271],{"class":232},"=",[138,273,274],{"class":151}," 1",[138,276,277],{"class":147},"; i ",[138,279,280],{"class":232},"\u003C=",[138,282,283],{"class":147}," num; i",[138,285,286],{"class":232},"++",[138,288,289],{"class":147},") {\n",[138,291,292,295,298],{"class":140,"line":175},[138,293,294],{"class":147},"    console.",[138,296,297],{"class":144},"log",[138,299,300],{"class":147},"(i);\n",[138,302,303],{"class":140,"line":189},[138,304,305],{"class":147},"  }\n",[138,307,309],{"class":140,"line":308},5,[138,310,311],{"class":147},"};\n",[12,313,314],{},[15,315],{"alt":57,"src":316},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Falgorithm\u002Ffizzbuzz\u002F%E6%88%AA%E5%9C%96%202025-02-05%2022.52.11.png",[12,318,319,320,322,323,325,326,328],{},"第一個步驟相對比較單純簡單，只需要建立一個 ",[43,321,57],{}," 函式，並且使用 ",[43,324,221],{}," 迴圈跑 ",[43,327,214],{}," 的數字，這樣就完成了第一步驟。",[205,330,332],{"id":331},"步驟二判斷是否為-3-的倍數","步驟二：判斷是否為 3 的倍數",[12,334,335,336,338,339,115],{},"接著我們要判斷是否為 3 的倍數，當出現可以被 3 整除的倍數時，就要回傳 ",[43,337,45],{},"，那麼如何判斷是否為 3 的倍數呢？這邊就要使用到餘數運算子 ",[43,340,341],{},"%",[12,343,344,345,347,348,350,351,354,355,358,359,362,363,366],{},"那麼什麼是 ",[43,346,341],{}," 呢？",[43,349,341],{}," 叫做餘數運算子，使用方式很簡單，只需要 ",[43,352,353],{},"a % b","，當 ",[43,356,357],{},"a"," 能被 ",[43,360,361],{},"b"," 整除時，則會回傳 ",[43,364,365],{},"0","，否則會回傳餘數，舉例來講：",[129,368,370],{"className":131,"code":369,"language":133,"meta":134,"style":134},"const a = 5;\nconst b = 3;\n\nconsole.log(a % b); \u002F\u002F 2\n",[43,371,372,387,401,407],{"__ignoreMap":134},[138,373,374,376,379,381,384],{"class":140,"line":141},[138,375,233],{"class":232},[138,377,378],{"class":151}," a",[138,380,239],{"class":232},[138,382,383],{"class":151}," 5",[138,385,386],{"class":147},";\n",[138,388,389,391,394,396,399],{"class":140,"line":161},[138,390,233],{"class":232},[138,392,393],{"class":151}," b",[138,395,239],{"class":232},[138,397,398],{"class":151}," 3",[138,400,386],{"class":147},[138,402,403],{"class":140,"line":175},[138,404,406],{"emptyLinePlaceholder":405},true,"\n",[138,408,409,412,414,417,419,422],{"class":140,"line":189},[138,410,411],{"class":147},"console.",[138,413,297],{"class":144},[138,415,416],{"class":147},"(a ",[138,418,341],{"class":232},[138,420,421],{"class":147}," b); ",[138,423,424],{"class":157},"\u002F\u002F 2\n",[12,426,427],{},[15,428],{"alt":429,"src":430},"餘數運算子","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Falgorithm\u002Ffizzbuzz\u002F%E6%88%AA%E5%9C%96%202025-02-05%2022.55.19.png",[12,432,433,434,436],{},"那麼為什麼會回傳 ",[43,435,80],{}," 呢？你可以想像成有五顆蘋果，然後要分給 3 個人，一開始一人一顆，接下來會剩下兩顆無法分，因此這兩顆就是餘數。",[12,438,439],{},"如果以計算公式來講，通常會區分成兩個部分，首先要先計算商數，然後再計算餘數：",[441,442,443,453],"ul",{},[39,444,445,446,449,450,452],{},"商數：",[43,447,448],{},"5\u002F3 = 1.6666666666666667","，這邊會取整數部分，也就是 ",[43,451,74],{},"，代表蘋果一個人只能拿一顆",[39,454,455,456,459],{},"餘數：",[43,457,458],{},"5 - 3 x 1 = 2","，這邊就是餘數，也就是剩下的蘋果",[12,461,462,463,465,466,468],{},"了解餘數的計算方式之後，讓我們回到 Fizz 的判斷上，當這個數字可以被 3 整除時，就要回傳 ",[43,464,45],{},"，這邊就要使用到餘數運算子 ",[43,467,341],{}," 來判斷",[129,470,472],{"className":131,"code":471,"language":133,"meta":134,"style":134},"const FizzBuzz = (num) => {\n  for (let i = 1; i \u003C= num; i++) {\n    if (i % 3 === 0) {\n      console.log('Fizz');\n    } else {\n      console.log(i);\n    }\n  }\n};\n",[43,473,474,492,516,536,552,562,571,577,582],{"__ignoreMap":134},[138,475,476,478,480,482,484,486,488,490],{"class":140,"line":141},[138,477,233],{"class":232},[138,479,236],{"class":144},[138,481,239],{"class":232},[138,483,242],{"class":147},[138,485,246],{"class":245},[138,487,249],{"class":147},[138,489,252],{"class":232},[138,491,255],{"class":147},[138,493,494,496,498,500,502,504,506,508,510,512,514],{"class":140,"line":161},[138,495,260],{"class":232},[138,497,242],{"class":147},[138,499,265],{"class":232},[138,501,268],{"class":147},[138,503,271],{"class":232},[138,505,274],{"class":151},[138,507,277],{"class":147},[138,509,280],{"class":232},[138,511,283],{"class":147},[138,513,286],{"class":232},[138,515,289],{"class":147},[138,517,518,521,524,526,528,531,534],{"class":140,"line":175},[138,519,520],{"class":232},"    if",[138,522,523],{"class":147}," (i ",[138,525,341],{"class":232},[138,527,398],{"class":151},[138,529,530],{"class":232}," ===",[138,532,533],{"class":151}," 0",[138,535,289],{"class":147},[138,537,538,541,543,545,549],{"class":140,"line":189},[138,539,540],{"class":147},"      console.",[138,542,297],{"class":144},[138,544,148],{"class":147},[138,546,548],{"class":547},"sTRMh","'Fizz'",[138,550,551],{"class":147},");\n",[138,553,554,557,560],{"class":140,"line":308},[138,555,556],{"class":147},"    } ",[138,558,559],{"class":232},"else",[138,561,255],{"class":147},[138,563,565,567,569],{"class":140,"line":564},6,[138,566,540],{"class":147},[138,568,297],{"class":144},[138,570,300],{"class":147},[138,