[{"data":1,"prerenderedAt":1127},["ShallowReactive",2],{"header-locale:\u002Finformation-security\u002F20230516\u002F18406287\u002F":3,"page:\u002Finformation-security\u002F20230516\u002F18406287\u002F":4,"alt:\u002Finformation-security\u002F20230516\u002F18406287\u002F":3,"prev-next:\u002Finformation-security\u002F20230516\u002F18406287\u002F":1117,"related:\u002Finformation-security\u002F20230516\u002F18406287\u002F":1126},"\u002Fen\u002Fsecurity\u002F2023\u002F05\u002F16\u002Fjwt-token-localstorage-sessionstorage-cookie\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1101,"date":1102,"description":25,"extension":1103,"lang":1104,"meta":1105,"navigation":246,"path":1106,"readingMinutes":1107,"seo":1108,"standalone":1109,"stem":1110,"tags":1111,"tldr":1114,"updated":1102,"url":1115,"__hash__":1116},"content\u002F資安\u002Ftoken-放-localStorage？sessionStorage？還是-Cookie？.md","Token 放 localStorage？sessionStorage？還是 Cookie？","18406287",{"type":9,"value":10,"toc":1086},"minimark",[11,19,23,26,30,33,36,49,52,55,61,64,69,72,83,86,112,122,128,131,135,138,141,158,178,184,278,281,286,298,358,364,369,382,393,399,402,421,427,438,441,445,448,454,457,462,465,471,474,494,497,500,801,804,845,848,854,860,863,869,875,878,889,895,910,918,921,925,928,932,935,938,942,945,948,951,978,981,985,998,1003,1006,1018,1022,1025,1028,1031,1037,1052,1055,1058,1082],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"不要再把 JWT Token 放在 localStorage 了","https:\u002F\u002Fi.imgur.com\u002FYRLvwMA.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"這一篇文章來分享與記錄一下關於 JWT Token 的一些事情，以及為什麼不要把 JWT Token 放在 localStorage。",[20,27,29],{"id":28},"json-web-tokenjwt","JSON Web Token(JWT)",[12,31,32],{},"那麼這邊也簡單描述一下什麼是 JSON Web Token(JWT) 呢？基本上 JWT 是一個基於 JSON 標準的格式，那...它常見在哪些場景呢？",[12,34,35],{},"基本上需要授權的地方都可以使用 JWT，例如...",[37,38,39,43,46],"ul",{},[40,41,42],"li",{},"登入",[40,44,45],{},"重設密碼",[40,47,48],{},"修改個人資料",[12,50,51],{},"等等。",[12,53,54],{},"因此當使用者登入的時候，你就會得到一組 JWT Token",[12,56,57],{},[15,58],{"alt":59,"src":60},"Token","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Finformation-security\u002F202305161720.jpg",[12,62,63],{},"而這一組 Token 就會是你未來跟伺服器溝通的識別碼，而伺服器也會透過這一組 Token 來驗證你的身份。",[65,66,68],"h3",{"id":67},"jwt-token-的組成","JWT Token 的組成",[12,70,71],{},"接下來我們來快速聊一下關於 JWT 的組成，底下是 JWT 官方網站所提供的範例 Token",[73,74,80],"pre",{"className":75,"code":77,"language":78,"meta":79},[76],"language-text","eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ.SflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c\n","text","",[81,82,77],"code",{"__ignoreMap":79},[12,84,85],{},"JWT Token 基本上是由三個部分組合而成，分別是...",[37,87,88,96,104],{},[40,89,90,91],{},"HEADER（標頭）：ALGORITHM & TOKEN TYPE\n",[37,92,93],{},[40,94,95],{},"用來說明這一組 Token 是用什麼演算法加密的，以及 Token 的類型",[40,97,98,99],{},"PAYLOAD（負載）：DATA\n",[37,100,101],{},[40,102,103],{},"主要是用來存放一些資料，例如使用者的 ID、名字等等",[40,105,106,107],{},"VERIFY SIGNATURE（驗證簽名）\n",[37,108,109],{},[40,110,111],{},"這一部分是用來驗證 Token 是否為正確的 Token",[12,113,114,115,118,119,121],{},"那麼我們該如何看出 HEADER、PAYLOAD 與 VERIFY SIGNATURE 呢？基本上 JWT Token 是使用 ",[81,116,117],{},"."," 來分隔的，因此我們可以透過 ",[81,120,117],{}," 來切割 Token，拆成以下：",[73,123,126],{"className":124,"code":125,"language":78,"meta":79},[76],"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9. # HEADER\neyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiaWF0IjoxNTE2MjM5MDIyfQ. # PAYLOAD\nSflKxwRJSMeKKF2QT4fwpMeJf36POk6yJV_adQssw5c # VERIFY SIGNATURE\n",[81,127,125],{"__ignoreMap":79},[12,129,130],{},"到目前為此，應該已經對於 JWT Token 的組成有一定的概念了，所以接下來就來快速聊一下瀏覽器的儲存空間吧。",[20,132,134],{"id":133},"localstoragesessionstoragecookie","localStorage？sessionStorage？cookie？",[12,136,137],{},"當我們登入之後會取得一組 JWT Token 作為與後端伺服器溝通的識別碼，那麼再往下介紹之前，我想先快速重溫一下關於瀏覽器儲存資料的地方。",[12,139,140],{},"底下我列出幾個常見的地方：",[37,142,143,148,153],{},[40,144,145],{},[81,146,147],{},"localStorage",[40,149,150],{},[81,151,152],{},"sessionStorage",[40,154,155],{},[81,156,157],{},"cookie",[12,159,160,161,163,164,166,167,169,170,174,175,177],{},"接下來我們先來認識一下 ",[81,162,147],{}," 與 ",[81,165,152],{},"，這兩個都是 HTML5 所提供的 Web Storage API，而這兩個的差別在於 ",[81,168,147],{}," 的資料會",[171,172,173],"strong",{},"永久（或半永久，因為如果使用者刪除的話）儲存","在瀏覽器中，而 ",[81,176,152],{}," 的資料只會存在於當前的瀏覽器分頁中。",[12,179,180,181,183],{},"接著我們來看一下 ",[81,182,147],{}," 的基本用法",[73,185,189],{"className":186,"code":187,"language":188,"meta":79,"style":79},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","const data = {\n  name: 'Ray',\n  url: 'https:\u002F\u002Fisraynotarray.com\u002F',\n};\n\nlocalStorage.setItem('data', JSON.stringify(data));\n","js",[81,190,191,211,224,235,241,248],{"__ignoreMap":79},[192,193,196,200,204,207],"span",{"class":194,"line":195},"line",1,[192,197,199],{"class":198},"sOudu","const",[192,201,203],{"class":202},"stw71"," data",[192,205,206],{"class":198}," =",[192,208,210],{"class":209},"s8XSl"," {\n",[192,212,214,217,221],{"class":194,"line":213},2,[192,215,216],{"class":209},"  name: ",[192,218,220],{"class":219},"sWayO","'Ray'",[192,222,223],{"class":209},",\n",[192,225,227,230,233],{"class":194,"line":226},3,[192,228,229],{"class":209},"  url: ",[192,231,232],{"class":219},"'https:\u002F\u002Fisraynotarray.com\u002F'",[192,234,223],{"class":209},[192,236,238],{"class":194,"line":237},4,[192,239,240],{"class":209},"};\n",[192,242,244],{"class":194,"line":243},5,[192,245,247],{"emptyLinePlaceholder":246},true,"\n",[192,249,251,254,258,261,264,267,270,272,275],{"class":194,"line":250},6,[192,252,253],{"class":209},"localStorage.",[192,255,257],{"class":256},"scAaK","setItem",[192,259,260],{"class":209},"(",[192,262,263],{"class":219},"'data'",[192,265,266],{"class":209},", ",[192,268,269],{"class":202},"JSON",[192,271,117],{"class":209},[192,273,274],{"class":256},"stringify",[192,276,277],{"class":209},"(data));\n",[12,279,280],{},"透過上面程式碼，我們可以將資料儲存到瀏覽器的儲存空間內，因此你可以在開發者工具中找到它",[12,282,283],{},[15,284],{"alt":147,"src":285},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Finformation-security\u002F202305161736.jpg",[12,287,288,289,291,292,294,295,297],{},"那麼 ",[81,290,152],{}," 的用法也是類似的，只是將 ",[81,293,147],{}," 改成 ",[81,296,152],{}," 即可",[73,299,301],{"className":186,"code":300,"language":188,"meta":79,"style":79},"const data = {\n  name: 'Ray',\n  url: 'https:\u002F\u002Fisraynotarray.com\u002F',\n};\n\nsessionStorage.setItem('data', JSON.stringify(data));\n",[81,302,303,313,321,329,333,337],{"__ignoreMap":79},[192,304,305,307,309,311],{"class":194,"line":195},[192,306,199],{"class":198},[192,308,203],{"class":202},[192,310,206],{"class":198},[192,312,210],{"class":209},[192,314,315,317,319],{"class":194,"line":213},[192,316,216],{"class":209},[192,318,220],{"class":219},[192,320,223],{"class":209},[192,322,323,325,327],{"class":194,"line":226},[192,324,229],{"class":209},[192,326,232],{"class":219},[192,328,223],{"class":209},[192,330,331],{"class":194,"line":237},[192,332,240],{"class":209},[192,334,335],{"class":194,"line":243},[192,336,247],{"emptyLinePlaceholder":246},[192,338,339,342,344,346,348,350,352,354,356],{"class":194,"line":250},[192,340,341],{"class":209},"sessionStorage.",[192,343,257],{"class":256},[192,345,260],{"class":209},[192,347,263],{"class":219},[192,349,266],{"class":209},[192,351,269],{"class":202},[192,353,117],{"class":209},[192,355,274],{"class":256},[192,357,277],{"class":209},[12,359,360,361,363],{},"而且它也可以在開發者工具中找到，只是位置就不會在 ",[81,362,147],{}," 的位置，而是瀏覽階段儲存空間中",[12,365,366],{},[15,367],{"alt":152,"src":368},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Finformation-security\u002F202305161740.jpg",[12,370,288,371,163,373,375,376,378,379,381],{},[81,372,152],{},[81,374,147],{}," 最大不同的地方在於，當你的瀏覽器分頁關閉之後 ",[81,377,152],{}," 的資料就會被清除，而 ",[81,380,147],{}," 的資料則會一直存在於瀏覽器中。",[12,383,384,385,388,389,392],{},"接下來我們接著看 Cookie 的寫法，Cookie 也是拿來儲存一些資料的，而儲存方式主要是採用 ",[81,386,387],{},"key=value"," 的方式，並使用 ",[81,390,391],{},";"," 來分隔不同的資料，例如",[73,394,397],{"className":395,"code":396,"language":78,"meta":79},[76],"name=Ray;\n",[81,398,396],{"__ignoreMap":79},[12,400,401],{},"因此寫入時，就可以這樣寫入",[73,403,405],{"className":186,"code":404,"language":188,"meta":79,"style":79},"document.cookie = 'name=Ray';\n",[81,406,407],{"__ignoreMap":79},[192,408,409,412,415,418],{"class":194,"line":195},[192,410,411],{"class":209},"document.cookie ",[192,413,414],{"class":198},"=",[192,416,417],{"class":219}," 'name=Ray'",[192,419,420],{"class":209},";\n",[12,422,423],{},[15,424],{"alt":425,"src":426},"Cookie","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Finformation-security\u002F202305161748.jpg",[12,428,429,430,432,433,163,435,437],{},"那麼上面就是我們最基本的 ",[81,431,147],{},"、",[81,434,152],{},[81,436,157],{}," 的用法。",[12,439,440],{},"（當然上面還有很多細節沒提到，為了讓我可以後面有東西講，所以我特別簡化了。）",[20,442,444],{"id":443},"jwt-token-該放","JWT Token 該放...？",[12,446,447],{},"那麼所以該把 JWT Token 放在哪裡呢？透過前面的範例講解之後，其實我們可以知道 JWT Token 是一個非常重要的識別碼，我們要跟後端拿任何資料都會需要它，因此這一組 Token 是不可以隨意外流的，如果被不法之徒拿到的話，就有可能造成資料外洩的問題。",[12,449,450,451],{},"但是你知道嗎？看似加密的 JWT Token 其實是可以反向解析的，也就是說",[171,452,453],{},"如果有人拿到了 JWT Token 就可以透過解析的方式來看到\u002F取得裡面的資料。",[12,455,456],{},"舉例來講，以官方所提供的 JWT Token 為例：",[73,458,460],{"className":459,"code":77,"language":78,"meta":79},[76],[81,461,77],{"__ignoreMap":79},[12,463,464],{},"你是可以在官方網站上面直接解析，而且它還會告訴你這個 JWT Token 的加密方式是什麼，以及裡面的資料是什麼",[12,466,467],{},[15,468],{"alt":469,"src":470},"Decoded JWT","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Finformation-security\u002F%E6%88%AA%E5%9C%96%202023-05-16%2017.55.08.png",[12,472,473],{},"你可以看到 PAYLOAD 直接顯示著以下資料",[37,475,476,482,488],{},[40,477,478,481],{},[81,479,480],{},"sub","：代表著 Subject，也就是使用者的 ID",[40,483,484,487],{},[81,485,486],{},"name","：代表著使用者的名字",[40,489,490,493],{},[81,491,492],{},"iat","：代表著 Issued At，也就是這個 JWT Token 的發行時間",[12,495,496],{},"當然 PAYLOAD 的內容是可以由後端開發者決定的，因此你可以在裡面放任何資料，例如你為了方便前端呈現使用者的 Email 或是使用者的姓名等等。",[12,498,499],{},"那麼這邊就簡單示範一下，底下我寫了一個簡單的 Express+JWT 範例給予參考",[73,501,503],{"className":186,"code":502,"language":188,"meta":79,"style":79},"const jwt = require('jsonwebtoken');\n\n\u002F\u002F ...略過一些程式碼\n\nrouter.post('\u002Flogin', function(req, res, next) {\n  const { username, password } = req.body;\n  if (username === 'admin' && password === '123456') {\n    const token = jwt.sign({\n      username,\n      email: 'example.com',\n    }, 'privateKeyTest', { expiresIn: 60 });\n\n    return res.send({\n      token,\n      message: '登入成功'\n    });\n  }\n\n  return res.status(401).send({\n    message: '登入失敗',\n    status: false,\n  });\n});\n\n\u002F\u002F ...略過一些程式碼\n",[81,504,505,525,529,535,539,576,600,628,648,654,665,683,688,702,708,717,723,729,734,757,768,779,785,791,796],{"__ignoreMap":79},[192,506,507,509,512,514,517,519,522],{"class":194,"line":195},[192,508,199],{"class":198},[192,510,511],{"class":202}," jwt",[192,513,206],{"class":198},[192,515,516],{"class":256}," require",[192,518,260],{"class":209},[192,520,521],{"class":219},"'jsonwebtoken'",[192,523,524],{"class":209},");\n",[192,526,527],{"class":194,"line":213},[192,528,247],{"emptyLinePlaceholder":246},[192,530,531],{"class":194,"line":226},[192,532,534],{"class":533},"sGBqm","\u002F\u002F ...略過一些程式碼\n",[192,536,537],{"class":194,"line":237},[192,538,247],{"emptyLinePlaceholder":246},[192,540,541,544,547,549,552,554,557,559,563,565,568,570,573],{"class":194,"line":243},[192,542,543],{"class":209},"router.",[192,545,546],{"class":256},"post",[192,548,260],{"class":209},[192,550,551],{"class":219},"'\u002Flogin'",[192,553,266],{"class":209},[192,555,556],{"class":198},"function",[192,558,260],{"class":209},[192,560,562],{"class":561},"syBk-","req",[192,564,266],{"class":209},[192,566,567],{"class":561},"res",[192,569,266],{"class":209},[192,571,572],{"class":561},"next",[192,574,575],{"class":209},") {\n",[192,577,578,581,584,587,589,592,595,597],{"class":194,"line":250},[192,579,580],{"class":198},"  const",[192,582,583],{"class":209}," { ",[192,585,586],{"class":202},"username",[192,588,266],{"class":209},[192