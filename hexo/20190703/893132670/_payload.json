[{"data":1,"prerenderedAt":696},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20190703\u002F893132670\u002F":3,"page:\u002Fhexo\u002F20190703\u002F893132670\u002F":4,"alt:\u002Fhexo\u002F20190703\u002F893132670\u002F":3,"prev-next:\u002Fhexo\u002F20190703\u002F893132670\u002F":673,"related:\u002Fhexo\u002F20190703\u002F893132670\u002F":682},"\u002Fen\u002Fhexo\u002F2019\u002F07\u002F03\u002Fadd-google-adsense-to-hexo-next\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":656,"date":657,"description":18,"extension":658,"lang":659,"meta":660,"navigation":661,"path":662,"readingMinutes":663,"seo":664,"standalone":665,"stem":666,"tags":667,"tldr":670,"updated":670,"url":671,"__hash__":672},"content\u002FHexo\u002F替-Hexo-NexT-增加-Google-AdSense.md","替 Hexo NexT 增加 Google AdSense","893132670",{"type":9,"value":10,"toc":634},"minimark",[11,15,19,22,25,30,40,44,49,52,55,58,82,85,96,99,103,110,114,121,125,131,134,139,142,145,148,153,157,160,171,174,178,181,283,286,297,378,382,392,434,437,452,551,558,564,567,575,581,584,590,598,603,606,612,619,624,627,630],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"好久不見的 Hexo 改動文章，這次要來介紹如何申請 Google AdSense，但是主要會介紹如何修改及部分申請而已，因為我已經有申請過 Google AdSense 啦~",[16,20,21],{},"(注意:由於最後一章節是需要等審核通過才能實作的，但是可以先修改模板及系統，這樣子審核通過時就只需要填入資訊即可。)",[12,23,24],{"id":24},"本文撰寫環境",[26,27,29],"h3",{"id":28},"hexo-版本","Hexo 版本",[31,32,33,37],"ul",{},[34,35,36],"li",{},"hexo: 3.8.0",[34,38,39],{},"hexo-cli: 2.0.0",[26,41,43],{"id":42},"next-版本","NexT 版本",[31,45,46],{},[34,47,48],{},"NexT: 7.1.0",[12,50,51],{"id":51},"起手式",[16,53,54],{},"由於我算是二次申請，所以接下來流程都是屬於二次申請滴，如果要找初次申請流程可以上網 Google 一下，但是大致上不會有什麼太困難的地方",[16,56,57],{},"另外補充 Google AdSense 申請的門檻(官方沒有真的公佈，我只是大概推敲)",[31,59,60,63,66,69,72],{},[34,61,62],{},"網站內容不能是農場文章 (簡單講就是垃圾文章)",[34,64,65],{},"申請人必須成年 (需滿18歲)",[34,67,68],{},"網站至少存活半年 (另一個站我是超過 7 個月才申請成功)",[34,70,71],{},"內容必須豐富且超過一定數量 (我記得我另一個網站超過 60 篇，就申請過了)",[34,73,74,75],{},"不可有反感內容，這個可以看 ",[76,77,81],"a",{"href":78,"rel":79},"https:\u002F\u002Fsupport.google.com\u002Fadsense\u002Fanswer\u002F1344080?hl=zh-Hant&ref_topic=1319756",[80],"nofollow","官網說明",[16,83,84],{},"申請後有幾個注意事項要注意，非常嚴重",[31,86,87,90,93],{},[34,88,89],{},"不可點擊自己網站廣告",[34,91,92],{},"同網域下的人不要點",[34,94,95],{},"不可鼓勵 or 要求他人點廣告",[16,97,98],{},"如果觸犯以上條款，恭喜你 Google AdSense 會把你這個帳號關閉，所以千萬不要觸犯以上禁忌。",[26,100,102],{"id":101},"開啟-google-adsense-後台首頁","開啟 Google AdSense 後台首頁",[16,104,105],{},[76,106,109],{"href":107,"rel":108},"https:\u002F\u002Fwww.google.com\u002Fadsense",[80],"Google AdSense",[26,111,113],{"id":112},"點選網站新增網站","點選網站>新增網站",[16,115,116],{},[117,118],"img",{"alt":119,"src":120},"新增網站","https:\u002F\u002Fi.imgur.com\u002FwhcUrrk.png",[26,122,124],{"id":123},"輸入網域並點下一步","輸入網域，並點下一步",[16,126,127],{},[117,128],{"alt":129,"src":130},"輸入網域並下一步","https:\u002F\u002Fi.imgur.com\u002FyeoQrON.png",[26,132,133],{"id":133},"複製代碼",[16,135,136],{},[117,137],{"alt":133,"src":138},"https:\u002F\u002Fi.imgur.com\u002FCnAJKaX.png",[16,140,141],{},"並點下提交",[26,143,144],{"id":144},"等待審核",[16,146,147],{},"接下來估計要等 7 ~ 14 天不等的審核，這期間就先修改一下模板以便於審核通過後使用",[16,149,150],{},[117,151],{"alt":144,"src":152},"https:\u002F\u002Fi.imgur.com\u002FJ69B4Ig.png",[12,154,156],{"id":155},"修改-next-模板","修改 NexT 模板",[16,158,159],{},"接下來要修改的地方稍微有點多，自己可以抉擇一下是否做這些地方的調整",[31,161,162,165,168],{},[34,163,164],{},"側邊欄 (也就是網站功能列)",[34,166,167],{},"NexT config檔案",[34,169,170],{},"header",[16,172,173],{},"由於考慮到使用者體驗，所以我並不會在文章中間 & 文章起頭插入廣告",[12,175,177],{"id":176},"修改主題-configyml","修改主題 config.yml",[16,179,180],{},"自己隨便找一個地方將以下這行加入",[182,183,188],"pre",{"className":184,"code":185,"language":186,"meta":187,"style":187},"language-yml shiki shiki-themes github-dark-high-contrast","# Google AdSense\ngoogle_adsense:\n  enable: true\n  google_ad_client_id: ca-pub-000000 # 請修改成自己的\n  enable_page_level_ads: true\n  ## siderbar_enable 這邊建立廣告後才會用到\n  siderbar_enable: true # 是否開啟側邊欄廣告\n  siderbar_data_ad_slot: 0000000 # 請輸入廣告 slot\n","yml","",[189,190,191,200,211,224,239,249,255,269],"code",{"