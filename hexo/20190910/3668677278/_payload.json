[{"data":1,"prerenderedAt":677},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20190910\u002F3668677278\u002F":3,"page:\u002Fhexo\u002F20190910\u002F3668677278\u002F":4,"alt:\u002Fhexo\u002F20190910\u002F3668677278\u002F":3,"prev-next:\u002Fhexo\u002F20190910\u002F3668677278\u002F":654,"related:\u002Fhexo\u002F20190910\u002F3668677278\u002F":663},"\u002Fen\u002Fhexo\u002F2019\u002F09\u002F10\u002Fauto-deploy-hexo-articles\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":639,"date":640,"description":18,"extension":641,"lang":642,"meta":643,"navigation":644,"path":645,"readingMinutes":646,"seo":647,"standalone":648,"stem":649,"tags":650,"tldr":651,"updated":651,"url":652,"__hash__":653},"content\u002FHexo\u002F自動化部屬-Hexo-文章.md","自動化部屬 Hexo 文章","3668677278",{"type":9,"value":10,"toc":630},"minimark",[11,15,19,22,25,32,40,44,55,75,86,92,100,107,113,116,122,125,131,134,140,144,151,156,167,172,175,181,184,190,194,197,203,209,214,224,229,248,253,259,266,272,275,280,287,293,299,303,310,316,322,559,566,569,575,578,584,587,593,596,602,605,612,619,626],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近在部屬文章上感覺越來越麻煩，所以乾脆索性將 Hexo 的部屬改成全自動化的方式。",[12,20,21],{"id":21},"使用自動化部屬的原因",[16,23,24],{},"其實使用 Hexo 的部落客都有一些麻煩點，就是每次編譯的速度實在太久，如果電腦效能差一點可能就會編譯超過 2 分鐘，然後我們也必須開著編譯視窗，就像我一樣 ↓",[16,26,27],{},[28,29],"img",{"alt":30,"src":31},"編譯中","https:\u002F\u002Fi.imgur.com\u002FY9iTgsS.png",[16,33,34,35,39],{},"所以這種時候通常就會建議改自動化部屬的方式，只要自動化工具偵測到你的 Repositories 有變化，就會立刻執行編譯，那我們也可以不用再開著視窗來執行 ",[36,37,38],"code",{},"hexo d -g"," 啦~",[12,41,43],{"id":42},"註冊-travis-ci","註冊 Travis CI",[16,45,46,47,50,51,54],{},"首先先進入 Travis CI 官方網站，這邊要注意一件事情 Travis CI 有分為有分 ",[36,48,49],{},".org"," 的免費版跟 ",[36,52,53],{},".com"," 的企業版",[56,57,58,68],"ul",{},[59,60,61],"li",{},[62,63,67],"a",{"href":64,"rel":65},"https:\u002F\u002Ftravis-ci.org\u002F",[66],"nofollow","非營利版",[59,69,70],{},[62,71,74],{"href":72,"rel":73},"https:\u002F\u002Ftravis-ci.com\u002F",[66],"企業版",[16,76,77,78,81,82,85],{},"我個人推薦使用 ",[62,79,67],{"href":64,"rel":80},[66],"，但是使用非營利版必須注意一件事情，非營利版不支援 private Repositories，如果你的專案是 private，那就會建議使用 ",[62,83,74],{"href":72,"rel":84},[66],"，但是企業版是屬於需要收費的，在它的付費頁面有講到前 100 次都是免費使用 ↓",[16,87,88],{},[28,89],{"alt":90,"src":91},"前 100 次都是免費使用","https:\u002F\u002Fi.imgur.com\u002FLcKOZ9S.png",[16,93,94,95],{},"最後這邊也提供企業版的付款借給給予參考：",[62,96,99],{"href":97,"rel":98},"https:\u002F\u002Ftravis-ci.com\u002Fplans",[66],"企業版付款介面",[16,101,102,103,106],{},"但是我個人本篇文章是使用",[104,105,74],"strong",{},"來介紹，所以在非營利版的介面上會稍微不太一樣，可是基本上操作流程是差不多的，如果沒有問題的話就準備來自動化部屬 Hexo 囉~",[16,108,109],{},[28,110],{"alt":111,"src":112},"Travis CI","https:\u002F\u002Fi.imgur.com\u002FeczHQ9G.png",[16,114,115],{},"接下來點一下中間使用 GitHub 註冊，此時它會跟你要求授權 ↓",[16,117,118],{},[28,119],{"alt":120,"src":121},"授權登入","https:\u002F\u002Fi.imgur.com\u002FdC0INND.png",[16,123,124],{},"通常 GitHub 也會再要求你輸入一次密碼 ↓",[16,126,127],{},[28,128],{"alt":129,"src":130},"輸入密碼","https:\u002F\u002Fi.imgur.com\u002FQQhCCwV.png",[16,132,133],{},"註冊成功後就可以進入到 Travis CI 畫面囉 ↓",[16,135,136],{},[28,137],{"alt":138,"src":139},"Travis CI 設定畫面","https:\u002F\u002Fi.imgur.com\u002FldIa005.png",[12,141,143],{"id":142},"設置-repositories","設置 Repositories",[16,145,146,147,150],{},"接下來要來設置我們要編譯的 Hexo 主系統(注意不是編譯出來的靜態頁面)，所以就點一下下方 ",[104,148,149],{},"Activate"," 的按鈕 ↓",[16,152,153],{},[28,154],{"alt":149,"src":155},"https:\u002F\u002Fi.imgur.com\u002F3rgZh4d.png",[16,157,158,159,162,163,166],{},"接下來選擇 ",[104,160,161],{},"Only Select Repositories"," 並找到你的 Hexo 主系統，沒問題就按下 ",[104,164,165],{},"Activate & Install"," ↓",[16,168,169],{},[28,170],{"alt":165,"src":171},"https:\u002F\u002Fi.imgur.com\u002FZMfBqWc.png",[16,173,174],{},"加入後就稍微等待一下 ↓",[16,176,177],{},[28,178],{"alt":179,"src":180},"小車車加速中","https:\u002F\u002Fi.imgur.com\u002FdeU7ABB.png",[16,182,183],{},"當你看到這個畫面時，就是設置完成了 ↓",[16,185,186],{},[28,187],{"alt":188,"src":189},"設置完成","https:\u002F\u002Fi.imgur.com\u002F8b31Gvs.png",[12,191,193],{"id":192},"取得-設置-github-token","取得 & 設置 github-token",[16,195,196],{},"接下來必須去取得 GitHub 的 token，否則無法自動化部屬，首先點一下右上角進入 Setting ↓",[16,198,199],{},[28,200],{"alt":201,"src":202},"Setting","https:\u002F\u002Fi.imgur.com\u002F0MfNRCc.png",[16,204,205,206,166],{},"然後點一下左邊功能列的 ",[104,207,208],{},"Developer settings",[16,210,211],{},[28,212],{"alt":208,"src":213},"https:\u002F\u002Fi.imgur.com\u002FhsEsxQH.png",[16,215,216,217,220,221,166],{},"進入 Developer settings 之後在點一下 ",[104,218,219],{},"Personal access tokens","，並點一下上方 ",[104,222,223],{},"Generate new token",[16,225,226],{},[28,227],{"alt":219,"src":228},"https:\u002F\u002Fi.imgur.com\u002FantxFUO.png",[16,230,231,232,235,236,239,240,243,244,247],{},"進入 Generate new token 後，我建議 ",[36,233,234],{},"Note"," 來欄位寫 ",[104,237,238],{},"Travis CI auto deploy","，這樣子你在看到這邊的時候才不會誤刪，然後底下只需要打勾 ",[36,241,242],{},"public_repo","，當然你要將整個 ",[36,245,246],{},"repo"," 給它也是可以 ↓",[16,249,250],{},[28,251],{"alt":238,"src":252},"https:\u002F\u002Fi.imgur.com\u002Fh04PXwj.png",[16,254,255,256,258],{},"新增 Token 之後就會在原本的 ",[104,257,219],{}," 上看到剛剛新增的 Token，此時請務必盡快複製，因為下次訪問該頁面就不會出現了 ↓",[16,260,261,262,265],{},"(",[104,263,264],{},"注意此 Token 很重要請不要隨意給他人",")",[16,267,268],{},[28,269],{"alt":270,"src":271},"Token","https:\u002F\u002Fi.imgur.com\u002F2bvSXpE.png",[16,273,274],{},"複製 Token 之後回到 Travis CI 的 Setting 畫面，並點一下 Setting ↓",[16,276,277],{},[28,278],{"alt":201,"src":279},"https:\u002F\u002Fi.imgur.com\u002FORA7J1V.png",[16,281,282,283,286],{},"接下來拉到下方有一個區塊叫 ",[104,284,285],{},"Environment Variables","，輸入相關欄位名稱，並在 VALUE 填入你剛剛複製的 Token，輸入完畢就點一下 ADD 即可 ↓",[16,288,289,290,265],{},"(NAME 建議叫 ",[36,291,292],{},"GITHUB_TOKEN",[16,294,295],{},[28,296],{"alt":297,"src":298},"ADD","https:\u002F\u002Fi.imgur.com\u002FE9Befa4.png",[12,300,302],{"id":301},"新增-travis-配置檔案","新增 travis 配置檔案",[16,304,305,306,309],{},"接下來要新增一隻 ",[36,307,308],{},".travis.yml"," 在 Hexo 主系統根目錄下 ↓",[16,311,312],{},[28,313],{"alt":314,"src":315},"travis 設置檔案","https:\u002F\u002Fi.imgur.com\u002FUo5A6Ex.png",[16,317,318,319,321],{},"而 ",[36,320,308],{}," 內容如下 ↓",[323,324,329],"pre",{"className":325,"code":326,"language":327,"meta":328,"style":328},"language-yml shiki shiki-themes github-dark-high-contrast","# 設置系統語言環境\nlanguage: node_js\n# 是否需要 sudo 權限\nsudo: false\n# 設置node_js版本\nnode_js: \n  - '10'\n# 設置暫存區塊\ncache:\n  apt: true\n  directories:\n      - node_modules # 不經常變動的資料夾\n# 指定部落格分支，一般來講是 Master，這是在告知當這個分支有 commit 時候就執行部屬指令\nbranches:\n  only:\n    - master\n## 安裝 Hexo-Cli\nbefore_script:\n  - npm install hexo-cli -g  # 安裝 Hexo 環境\n# 清除緩存並執行編譯\nscript:\n  - hexo clean\n  - hexo generate\n## deploy 相關設置\nafter_success:\n  - sed -i'' \"\u002F^ *repo\u002Fs~github\\.com~${GITHUB_TOKEN}@github.com~\" _config.yml\n  - hexo deploy\n","yml","",[36,330,331,340,355,361,373,379,388,397,403,412,423,431,443,449,457,465,474,480,488,499,505,513,521,529,535,543,551],{"__ignoreMap":328},[332,333,336],"span",{"class":334,"line":335},"line",1,[332,337,339],{"class":338},"sQrFR","# 設置系統語言環境\n",[332,341,343,347,351],{"class":334,"line":342},2,[332,344,346],{"class":345},"sKpQp","language",[332,348,350],{"class":349},"sMAXC",": ",[332,352,354],{"class":353},"sTRMh","node_js\n",[332,356,358],{"class":334,"line":357},3,[332,359,360],{"class":338},"# 是否需要 sudo 權限\n",[332,362,364,367,369],{"class":334,"line":363},4,[332,365,366],{"class":345},"sudo",[332,368,350],{"class":349},[332,370,372],{"class":371},"sCcAr","false\n",[332,374,376],{"class":334,"line":375},5,[332,377,378],{"class":338},"# 設置node_js版本\n",[332,380,382,385],{"class":334,"line":381},6,[332,383,384],{"class":345},"node_js",[332,386,387],{"class":349},": \n",[332,389,391,394],{"class":334,"line":390},7,[332,392,393],{"class":349},"  - ",[332,395,396],{"class":353},"'10'\n",[332,398,400],{"class":334,"line":399},8,[332,401,402],{"class":338},"# 設置暫存區塊\n",[332,404,406,409],{"class":334,"line":405},9,[332,407,408],{"class":345},"cache",[332,410,411],{"class":349},":\n",[332,413,415,418,420],{"class":334,"line":414},10,[332,416,417],{"class":345},"  apt",[332,419,350],{"class":349},[332,421,422],{"class":371},"true\n",[332,424,426,429],{"class":334,"line":425},11,[332,427,428],{"class":345},"  directories",[332,430,411],{"class":349},[332,432,434,437,440],{"class":334,"line":433},12,[332,435,436],{"class":349},"      - ",[332,438,439],{"class":353},"node_modules",[332,441,442],{"class":338}," # 不經常變動的資料夾\n",[332,444,446],{"class":334,"line":445},13,[332,447,448],{"class":338},"# 指定部落格分支，一般來講是 Master，這是在告知當這個分支有 commit 時候就執行部屬指令\n",[332,450,452,455],{"class":334,"line":451},14,[332,453,454],{"class":345},"branches",[332,456,411],{"class":349},[332,458,460,463],{"class":334,"line":459},15,[332,461,462],{"class":345},"  only",[332,464,411],{"class":349},[332,466,468,471],{"class":334,"line":467},16,[332,469,470],{"class":349},"    - ",[332,472,473],{"class":353},"master\n",[332,475,477],{"class":334,"line":476},17,[332,478,479],{"class":338},"## 安裝 Hexo-Cli\n",[332,481,483,486],{"class":334,"line":482},18,[332,484,485],{"class":345},"before_script",[332,487,411],{"class":349},[332,489,491,493,496],{"class":334,"line":490},19,[332,492,393],{"class":349},[332,494,495],{"class":353},"npm install hexo-cli -g",[332,497,498],{"class":338},"  # 安裝 Hexo 環境\n",[332,500,502],{"class":334,"line":501},20,[332,503,504],{"class":338},"# 清除緩存並執行編譯\n",[332,506,508,511],{"class":334,"line":507},21,[332,509,510],{"class":345},"script",[332,512,411],{"class":349},[332,514,516,518],{"class":334,"line":515},22,[332,517,393],{"class":349},[332,519,520],{"class":353},"hexo clean\n",[332,522,524,526],{"class":334,"line":523},23,[332,525,393],{"class":349},[332,527,528],{"class":353},"hexo generate\n",[332,530,532],{"class":334,"line":531},24,[332,533,534],{"class":338},"## deploy 相關設置\n",[332,536,538,541],{"class":334,"line":537},25,[332,539,540],{"class":345},"after_success",[332,542,411],{"class":349},[332,544,546,548],{"class":334,"line":545},26,[332,547,393],{"class":349},[332,549,550],{"class":353},"sed -i'' \"\u002F^ *repo\u002Fs~github\\.com~${GITHUB_TOKEN}@github.com~\" _config.yml\n",[332,552,554,556],{"class":334,"line":553},27,[332,555,393],{"class":349},[332,557,558],{"class":353},"hexo deploy\n",[16,560,561,562,565],{},"接下來就可以將這個 Hexo 主系統 ",[36,563,564],{},"git push"," 回去自己的 Repositories 啦~",[16,567,568],{},"然後你就可以回到 Travis CI 的 Setting 畫面，並點一下你部落格名稱 ↓",[16,570,571],{},[28,572],{"alt":573,"src":574},"查看 CI 狀態","https:\u002F\u002Fi.imgur.com\u002FfNWGLBD.png",[16,576,577],{},"然後就可以看到 Travis CI 已經開始自動運行囉 ↓",[16,579,580],{},[28,581],{"alt":582,"src":583},"自動部屬中","https:\u002F\u002Fi.imgur.com\u002FVkfINhJ.png",[16,585,586],{},"部屬完成你就會收到一封信跟你講說成功部屬了 ↓",[16,588,589],{},[28,590],{"alt":591,"src":592},"成功部屬","https:\u002F\u002Fi.imgur.com\u002FfxY2bPl.png",[16,594,595],{},"接下來你只要主系統的 Repositories Master 有變化，那 Travis CI 就會自動執行部屬的動作，如果出現錯誤 Travis CI 也會寄信跟你講 ↓",[16,597,598],{},[28,599],{"alt":600,"src":601},"設置過程瘋狂錯誤","https:\u002F\u002Fi.imgur.com\u002FOyooMsI.png",[12,603,604],{"id":604},"參考",[16,606,607],{},[62,608,611],{"href":609,"rel":610},"https:\u002F\u002Fsegmentfault.com\u002Fa\u002F1190000009054888",[66],"使用 Travis 自动部署 Hexo 到 Github 与 自己的服务器",[16,613,614],{},[62,615,618],{"href":616,"rel":617},"http:\u002F\u002Fduansm.top\u002F2018\u002F08\u002F05\u002Fhexo-travis\u002F",[66],"Hexo+github搭建个人博客（三）：Travis CI持续集成,自动部署博客",[16,620,621],{},[62,622,625],{"href":623,"rel":624},"https:\u002F\u002Fwww.slmt.tw\u002Fblog\u002F2019\u002F04\u002F26\u002Fhexo-auto-deploy\u002F",[66],"使用 Travis CI 來自動發布 Hexo Blog",[627,628,629],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":328,"searchDepth":342,"depth":342,"links":631},[632,633,634,635,636,637,638],{"id":14,"depth":342,"text":14},{"id":21,"depth":342,"text":21},{"id":42,"depth":342,"text":43},{"id":142,"depth":342,"text":143},{"id":192,"depth":342,"text":193},{"id":301,"depth":342,"text":302},{"id":604,"depth":342,"text":604},"Hexo","2019-09-10 09:12:37","md","zh-Hant",{},true,"\u002Fhexo\u002Fhexo","3",{"title":6,"description":18},false,"Hexo\u002F自動化部屬-Hexo-文章",[639,111],null,"\u002Fhexo\u002F20190910\u002F3668677278\u002F","3EL-jPKMY-jpDb4NKB50WdigMm5n3svLRVp8HK-LfzM",{"newer":655,"older":659},{"url":656,"title":657,"date":658},"\u002Fphp\u002F20190911\u002F2404668874\u002F","Day10-從基礎學習 ThinkPHP-View","2019-09-11 00:01:36",{"url":660,"title":661,"date":662},"\u002Fphp\u002F20190910\u002F533664939\u002F","Day9-從基礎學習 ThinkPHP-Controller","2019-09-10 00:07:30",[664,669,673],{"url":665,"title":666,"date":667,"readingMinutes":668},"\u002Fhexo\u002F20221030\u002F561405053\u002F","解決 Hexo 更新系統或使用 CI 部署後文章出現更新日期的問題","2022-10-30 11:52:35","2",{"url":670,"title":671,"date":672,"readingMinutes":646},"\u002Fhexo\u002F20201101\u002F60919\u002F","(33)試著學 Hexo-番外篇之更新 NexT 主題","2020-11-01 13:21:00",{"url":674,"title":675,"date":676,"readingMinutes":668},"\u002Fhexo\u002F20201031\u002F2194088152\u002F","(32)試著學 Hexo-番外篇之更新 Hexo","2020-10-31 14:01:51",1784020385635]