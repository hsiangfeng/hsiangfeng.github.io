[{"data":1,"prerenderedAt":193},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20190717\u002F3365093327\u002F":3,"page:\u002Fhexo\u002F20190717\u002F3365093327\u002F":4,"alt:\u002Fhexo\u002F20190717\u002F3365093327\u002F":3,"prev-next:\u002Fhexo\u002F20190717\u002F3365093327\u002F":169,"related:\u002Fhexo\u002F20190717\u002F3365093327\u002F":178},"\u002Fen\u002Fhexo\u002F2019\u002F07\u002F17\u002Fhexo-seo-404-page\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":153,"date":154,"description":18,"extension":155,"lang":156,"meta":157,"navigation":158,"path":159,"readingMinutes":160,"seo":161,"standalone":162,"stem":163,"tags":164,"tldr":166,"updated":166,"url":167,"__hash__":168},"content\u002FHexo\u002FHexo-SEO-優化小細節-關於-404-這件小事.md","Hexo SEO 優化小細節-關於 404 這件小事","3365093327",{"type":9,"value":10,"toc":144},"minimark",[11,15,19,22,27,37,41,46,50,53,60,63,67,70,78,89,94,97,137,140],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇是特別獨立出來講一下其中一個 SEO 小細節的，其中就是關於 404 頁面",[12,20,21],{"id":21},"本文撰寫環境",[23,24,26],"h3",{"id":25},"hexo-版本","Hexo 版本",[28,29,30,34],"ul",{},[31,32,33],"li",{},"hexo: 3.8.0",[31,35,36],{},"hexo-cli: 2.0.0",[23,38,40],{"id":39},"next-版本","NexT 版本",[28,42,43],{},[31,44,45],{},"NexT: 7.1.0",[12,47,49],{"id":48},"_404-頁面","404 頁面",[16,51,52],{},"有時候我們技術部落格會因為一開始架設的不優良導致 URL 一直變動，但是過程中搜尋引擎的爬蟲就已經來爬過我們的部落格了，如果是放在 GitHub 上面就會得到這個預設 404 畫面",[16,54,55],{},[56,57],"img",{"alt":58,"src":59},"預設 404 畫面","https:\u002F\u002Fi.imgur.com\u002F1PjvKrD.png",[16,61,62],{},"那為什麼要特別講 404 頁面呢?其實 GitHub 預設的 404 頁面並沒有不好，只是會有一個問題，也就是當使用者 OR 爬蟲跑到一個沒有的畫面，可是卻沒有地方可以回到我們的網站首頁，那麼對於使用者來者體驗就非常差，對於搜尋引擎爬蟲來講就更差了，這會大大影響自己的排名",[12,64,66],{"id":65},"_404-頁面製作","404 頁面製作",[16,68,69],{},"那麼解決的方式就是自己來製作一個 404 頁面或者自己網路找免費精美的 404 頁面，但是要有兩個重點",[28,71,72,75],{},[31,73,74],{},"定時自動跳轉回首頁",[31,76,77],{},"提供首頁按鈕返回",[16,79,80,81,85,86],{},"那麼製作好的 404 頁面該丟在哪呢?以我丟的地方做舉例，我是丟在 ",[82,83,84],"code",{},"theme\u002Fsource"," 底下，然後要記得檔案名稱必須叫做 ",[82,87,88],{},"404.html",[16,90,91],{},[56,92],{"alt":88,"src":93},"https:\u002F\u002Fi.imgur.com\u002F2YRXDdf.png",[16,95,96],{},"另外這個 html 裡面的最前面，必須加上這幾段，否則無法被 hexo 系統辨識",[98,99,104],"pre",{"className":100,"code":101,"language":102,"meta":103,"style":103},"language-hexo shiki shiki-themes github-dark-high-contrast","---\nlayout: false\ncomments: false\ntitle: 404-真巧在這裏遇見你!\n---\n","hexo","",[82,105,106,114,120,126,132],{"__ignoreMap":103},[107,108,111],"span",{"class":109,"line":110},"line",1,[107,112,113],{},"---\n",[107,115,117],{"class":109,"line":116},2,[107,118,119],{},"layout: false\n",[107,121,123],{"class":109,"line":122},3,[107,124,125],{},"comments: false\n",[107,127,129],{"class":109,"line":128},4,[107,130,131],{},"title: 404-真巧在這裏遇見你!\n",[107,133,135],{"class":109,"line":134},5,[107,136,113],{},[16,138,139],{},"那麼底下就是屬於你自己的 html 標籤、圖片等等了。",[141,142,143],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":103,"searchDepth":116,"depth":116,"links":145},[146,147,151,152],{"id":14,"depth":116,"text":14},{"id":21,"depth":116,"text":21,"children":148},[149,150],{"id":25,"depth":122,"text":26},{"id":39,"depth":122,"text":40},{"id":48,"depth":116,"text":49},{"id":65,"depth":116,"text":66},"Hexo","2019-07-17 17:37:43","md","zh-Hant",{},true,"\u002Fhexo\u002Fhexo-seo-404","1",{"title":6,"description":18},false,"Hexo\u002FHexo-SEO-優化小細節-關於-404-這件小事",[153,165],"SEO",null,"\u002Fhexo\u002F20190717\u002F3365093327\u002F","UC7N1GnwlmhJdRTuhIy8fS_UKwd5FXqKeGYDPq3bOJs",{"newer":170,"older":174},{"url":171,"title":172,"date":173},"\u002Fnodejs\u002F20190718\u002F2790148994\u002