[{"data":1,"prerenderedAt":255},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20190516\u002F2710757554\u002F":3,"page:\u002Fhexo\u002F20190516\u002F2710757554\u002F":4,"alt:\u002Fhexo\u002F20190516\u002F2710757554\u002F":3,"prev-next:\u002Fhexo\u002F20190516\u002F2710757554\u002F":231,"related:\u002Fhexo\u002F20190516\u002F2710757554\u002F":240},"\u002Fen\u002Fhexo\u002F2019\u002F05\u002F16\u002Fnext-hide-disqus-on-tags-categories\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":215,"date":216,"description":18,"extension":217,"lang":218,"meta":219,"navigation":220,"path":221,"readingMinutes":222,"seo":223,"standalone":224,"stem":225,"tags":226,"tldr":228,"updated":228,"url":229,"__hash__":230},"content\u002FHexo\u002FNexT分類與標籤頁不要有留言板-Disqus.md","NexT分類與標籤頁不要有留言板(Disqus)","2710757554",{"type":9,"value":10,"toc":206},"minimark",[11,15,19,22,27,37,41,46,49,52,55,62,74,79,85,120,125,128,131,136,139,144,147,152,155,158,161,172,181,184,187,192,195,202],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"雖然 NexT 模板是一個非常棒的模板，但是有些地方卻很奇怪，例如 tage 及 categories 竟然會出現 Disqus 留言版，所以這邊紀錄一下該如何修改 tage 及 categories 不要出現 Disqus 留言版。",[12,20,21],{"id":21},"本文撰寫環境",[23,24,26],"h3",{"id":25},"hexo-版本","Hexo 版本",[28,29,30,34],"ul",{},[31,32,33],"li",{},"hexo: 3.8.0",[31,35,36],{},"hexo-cli: 2.0.0",[23,38,40],{"id":39},"next-版本","NexT 版本",[28,42,43],{},[31,44,45],{},"NexT: 7.1.0",[12,47,48],{"id":48},"修改模板",[16,50,51],{},"由於我們是使用 NexT 模板，所以要開進入模版的頁面做調整(\\themes\\hexo-theme-next-master\\layout_layout.swig)。",[16,53,54],{},"因為 tage 及 categories 是採用與文章相同的模板，所以要修改的是 _layout.swig。",[16,56,57],{},[58,59],"img",{"alt":60,"src":61},"圖片","https:\u002F\u002Fi.imgur.com\u002FPZSwK3c.png",[16,63,64,65,69,70,73],{},"開啟之後查詢 ",[66,67,68],"code",{},"comments.swig","，可以找到一段 ",[66,71,72],{},"{% include '_partials\u002Fcomments.swig' %}","，模板是透過這一段做引入的。",[16,75,76],{},[58,77],{"alt":60,"src":78},"https:\u002F\u002Fi.imgur.com\u002FBUatGte.png",[16,80,81,82,84],{},"那我們必須將 ",[66,83,68],{}," 加入一個判斷式。",[86,87,92],"pre",{"className":88,"code":89,"language":90,"meta":91,"style":91},"language-swig shiki shiki-themes github-dark-high-contrast","{% set page_type = page.type === 'tags' || page.type === 'categories' %}\n  \u003Cdiv style=\"{%if page_type %} visibility:hidden; height:0px;{% endif %}\">\n  {% include '_partials\u002Fcomments.swig' %}\n  \u003C\u002Fdiv>\n","swig","",[66,93,94,102,108,114],{"__ignoreMap":91},[95,96,99],"span",{"class":97,"line":98},"line",1,[95,100,101],{},"{% set page_type = page.type === 'tags' || page.type === 'categories' %}\n",[95,103,105],{"class":97,"line":104},2,[95,106,107],{},"  \u003Cdiv style=\"{%if page_type %} visibility:hidden; height:0px;{% endif %}\">\n",[95,109,111],{"class":97,"line":110},3,[95,112,113],{},"  {% include '_partials\u002Fcomments.swig' %}\n",[95,115,117],{"class":97,"line":116},4,[95,118,119],{},"  \u003C\u002Fdiv>\n",[16,121,122],{},[58,123],{"alt":60,"src":124},"https:\u002F\u002Fi.imgur.com\u002F0TStEMK.png",[16,126,127],{},"這時候存檔重新啟動就可以看看 tage 及 categories 是否會有留言板。",[16,129,130],{},"tage:",[16,132,133],{},[58,134],{"alt":60,"src":135},"https:\u002F\u002Fi.imgur.com\u002Fww8dOWI.png",[16,137,138],{},"categories:",[16,140,141],{},[58,142],{"alt":60,"src":143},"https:\u002F\u002Fi.imgur.com\u002FaAiVa3q.png",[16,145,146],{},"文章頁面:",[16,148,149],{},[58,150],{"alt":60,"src":151},"https:\u002F\u002Fi.imgur.com\u002FqCYebRu.png",[12,153,154],{"id":154},"補充說明",[16,156,157],{},"在撰寫這篇文章時發現一個雷點，由於 Hexo 是使用 swig 模板引擎所撰寫，所以我在文章內撰寫 swig 模板語言一直出錯，還好發現官網有講解如何閃避，這邊紀錄一下。",[16,159,160],{},"以下為官網說明。",[16,162,163,164,167,168,171],{},"解決 Hexo 使用 Nunjucks 來解析文章（舊版本使用 Swig，兩者語法類似），內容若包含 ",[66,165,166],{},"{{ }}"," 或 ",[66,169,170],{},"{% %}"," 可能導致解析錯誤，您可以用 raw 標籤包裹來避免潛在問題發生。",[16,173,174],{},[175,176,180],"a",{"href":177,"rel":178},"https:\u002F\u002Fhexo.io\u002Fzh-tw\u002Fdocs\u002Ftroubleshooting.html#%E8%84%AB%E9%80%B8%EF%BC%88Escape%EF%BC%89%E5%85%A7%E5%AE%B9",[179],"nofollow","脫逸（Escape）內容",[16,182,183],{},"5\u002F18 踩雷紀錄",[16,185,186],{},"最早我是這樣寫",[16,188,189],{},[58,190],{"alt":60,"src":191},"https:\u002F\u002Fi.imgur.com\u002Fh1N8vCY.png",[16,193,194],{},"但是後來發現這種方式會出現錯誤，所以不能用這張圖的做法唷~",[16,196,197,198,201],{},"另外也不能使用 Display:none的做法，也會出現警告錯誤，所以使用 ",[66,199,200],{},"visibility:hidden; height:0px;","是最為妥當的。",[203,204,205],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":91,"searchDepth":104,"depth":104,"links":207},[208,209,213,214],{"id":14,"depth":104,"text":14},{"id":21,"depth":104,"text":21,"children":210},[211,212],{"id":25,"depth":110,"text":26},{"id":39,"depth":110,"text":40},{"id":48,"depth":104,"text":48},{"id":154,"depth":104,"text":154},"Hexo","2019-05-16 11:09:29","md","zh-Hant",{},true,"\u002Fhexo\u002Fnext-disqus","1",{"title":6,"description":18},false,"Hexo\u002FNexT分類與標籤頁不要有留言板-Disqus",[215,227],"NexT",null,"\u002Fhexo\u002F20190516\u002F2710757554\u002F","4GhEkp4xxotpGWA14SgBr_n5MkoDgTfa_29I0fHq_lM",{"newer":232,"older":236},{"url":233,"title":234,"date":235},"\u002Fjsweirdworld\u002F20190516\u002F2342284884\u002F","[JS奇怪的世界]No.9 函數、環境與變數環境","2019-05-16 13:30:35",{"url":237,"title":238,"date":239},"\u002Fjsweirdworld\u002F20190515\u002F3997485218\u002F","[JS奇怪的世界]No.8 函數呼叫與執行堆","2019-05-15 22:30:35",[241,246,251],{"url":242,"title":243,"date":244,"readingMinutes":245},"\u002Fhexo\u002F20221030\u002F561405053\u002F","解決 Hexo 更新系統或使用 CI 部署後文章出現更新日期的問題","2022-10-30 11:52:35","2",{"url":247,"title":248,"date":249,"readingMinutes":250},"\u002Fhexo\u002F20201101\u002F60919\u002F","(33)試著學 Hexo-番外篇之更新 NexT 主題","2020-11-01 13