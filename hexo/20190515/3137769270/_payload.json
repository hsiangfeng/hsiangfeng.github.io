[{"data":1,"prerenderedAt":284},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20190515\u002F3137769270\u002F":3,"page:\u002Fhexo\u002F20190515\u002F3137769270\u002F":4,"alt:\u002Fhexo\u002F20190515\u002F3137769270\u002F":3,"prev-next:\u002Fhexo\u002F20190515\u002F3137769270\u002F":261,"related:\u002Fhexo\u002F20190515\u002F3137769270\u002F":270},"\u002Fen\u002Fhexo\u002F2019\u002F05\u002F15\u002Fhexo-app-like-push-notifications\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":246,"date":247,"description":18,"extension":248,"lang":249,"meta":250,"navigation":251,"path":252,"readingMinutes":253,"seo":254,"standalone":255,"stem":256,"tags":257,"tldr":258,"updated":258,"url":259,"__hash__":260},"content\u002FHexo\u002F替Hexo加入發送通知功能.md","替Hexo加入像APP一樣的通知(推播)功能","3137769270",{"type":9,"value":10,"toc":233},"minimark",[11,15,19,22,27,37,41,46,50,61,68,71,76,79,84,87,92,95,100,108,113,116,121,124,129,132,136,139,144,147,152,155,160,163,168,171,174,179,182,187,190,193,198,201,204,209,212,217,220,225,228],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"由於我們部落格都會希望加入一個通知可以提醒使用者我的部落格文章更新囉~一般來講都是使用 RSS 方式，但是現階段手機很流行的情況下這邊就要用不同於 RSS 的作法來達到通知的效果。",[12,20,21],{"id":21},"本文撰寫環境",[23,24,26],"h3",{"id":25},"hexo-版本","Hexo 版本",[28,29,30,34],"ul",{},[31,32,33],"li",{},"hexo: 3.8.0",[31,35,36],{},"hexo-cli: 2.0.0",[23,38,40],{"id":39},"next-版本","NexT 版本",[28,42,43],{},[31,44,45],{},"NexT: 7.1.0",[12,47,49],{"id":48},"替hexo新增izooto","替Hexo新增iZooto",[16,51,52,53,60],{},"首先先開啟 ",[54,55,59],"a",{"href":56,"rel":57},"https:\u002F\u002Fpanel.izooto.com\u002Flogin",[58],"nofollow","iZooto"," 官方網站並註冊登入。",[16,62,63],{},[64,65],"img",{"alt":66,"src":67},"圖片","https:\u002F\u002Fi.imgur.com\u002F2dk3Hrs.png",[16,69,70],{},"由於我本身就已經使用過 iZooto 所以會少一些畫面直接進入新增網站部分，點上方【加網站】",[16,72,73],{},[64,74],{"alt":66,"src":75},"https:\u002F\u002Fi.imgur.com\u002FXhqqEnd.png",[16,77,78],{},"接下來會跳出一個視窗，依照欄位填寫即可生成代碼(只需要填寫網址與網站標題就好)。",[16,80,81],{},[64,82],{"alt":66,"src":83},"https:\u002F\u002Fi.imgur.com\u002FJTqDHFD.png",[16,85,86],{},"送出之後就會生成一段代碼，這段代碼複製下來。",[16,88,89],{},[64,90],{"alt":66,"src":91},"https:\u002F\u002Fi.imgur.com\u002FAG4pKiB.png",[16,93,94],{},"第一個步驟要將剛剛下載的 izooto-sdk 裡面的檔案放到 系統根目錄 source 下。",[16,96,97],{},[64,98],{"alt":66,"src":99},"https:\u002F\u002Fi.imgur.com\u002FvIaGe1D.png",[16,101,102,103,107],{},"然後就要來改造 Hexo 模板啦~要將剛剛複製的貼到 ",[104,105,106],"code",{},"\u003Chead>"," 中，所以我們要找主題模板的 head.swig (theme\u002Flayout\u002F_partials\u002Fhead\u002Fhead.swig)，將剛剛複製的代碼貼在這裡，基本上你想貼哪都可以，就是要貼在 head.swig 中，然後只要在 130行 之前即可，不確定就跟我放一樣位子就好。",[16,109,110],{},[64,111],{"alt":66,"src":112},"https:\u002F\u002Fi.imgur.com\u002FZQCjXTP.png",[16,114,115],{},"那如何確定是否成功?打開 F12 找看看就好哩",[16,117,118],{},[64,119],{"alt":66,"src":120},"https:\u002F\u002Fi.imgur.com\u002F9CfK1s6.png",[16,122,123],{},"如果確定沒問題後就可以把Hexo push 出去，然後用別的瀏覽器開起來看看，如果有看到這個視窗代表成功哩。",[16,125,126],{},[64,127],{"alt":66,"src":128},"https:\u002F\u002Fi.imgur.com\u002FrhY6i2O.png",[16,130,131],{},"※注意這兩者步驟缺一不可，少一個都會無法正常運作。",[12,133,135],{"id":134},"izooto-後台","iZooto 後台",[16,137,138],{},"那麼後臺可以針對訂閱樣式類型做調整。",[16,140,141],{},[64,142],{"alt":66,"src":143},"https:\u002F\u002Fi.imgur.com\u002F1gWFXxU.png",[16,145,146],{},"我是使用這個樣式。",[16,148,149],{},[64,150],{"alt":66,"src":151},"https:\u002F\u002Fi.imgur.com\u002FKeiuCVo.png",[16,153,154],{},"手機上的訂閱通知樣式也可以做調整。",[16,156,157],{},[64,158],{"alt":66,"src":159},"https:\u002F\u002Fi.imgur.com\u002Fv9SJUh3.png",[16,161,162],{},"另外我會建議當使用者按下稍等按鈕後過多久再一次提醒使用者，我建議就不要動它了，讓它預設一小時就好。",[16,164,165],{},[64,166],{"alt":66,"src":167},"https:\u002F\u002Fi.imgur.com\u002FALwfCKx.png",[16,169,170],{},"修改完後過一段時間就可以看到自己網站的訂閱通知樣式變了。",[16,172,173],{},"PC:",[16,175,176],{},[64,177],{"alt":66,"src":178},"https:\u002F\u002Fi.imgur.com\u002F6h99qs9.png",[16,180,181],{},"手機版:",[16,183,184],{},[64,185],{"alt":66,"src":186},"https:\u002F\u002Fi.imgur.com\u002FvdElkem.png",[12,188,189],{"id":189},"發送推播通知",[16,191,192],{},"發送的方式很簡單只要點旁邊的 【建立廣告系列】 就可以進入發送畫面。",[16,194,195],{},[64,196],{"alt":66,"src":197},"https:\u002F\u002Fi.imgur.com\u002F5hvTtnD.png",[16,199,200],{},"相關欄位填寫完就可以發送通知。",[16,202,203],{},"只有一個重點要填寫【著陸網頁】就是當使用者點擊之後會開啟哪一個頁面。",[16,205,206],{},[64,207],{"alt":66,"src":208},"https:\u002F\u002Fi.imgur.com\u002FQPgU7Rm.png",[16,210,211],{},"其他可以依照自己需求做調整，沒問題後就可以拉到最下面發送廣告。",[16,213,214],{},[64,215],{"alt":66,"src":216},"https:\u002F\u002Fi.imgur.com\u002FgRwjJlw.png",[16,218,219],{},"點下發送通知之後它還會再跟你確定是否真的要這樣發送",[16,221,222],{},[64,223],{"alt":66,"src":224},"https:\u002F\u002Fi.imgur.com\u002FMG6QU4M.png",[16,226,227],{},"發送之後我們就可以在電腦上收到通知啦~(背景鋼鐵人很帥，麻煩請忽略XD)",[16,229,230],{},[64,231],{"alt":66,"src":232},"https:\u002F\u002Fi.imgur.com\u002FmzpVl25.png",{"title":234,"searchDepth":235,"depth":235,"links":236},"",2,[237,238,243,244,245],{"id":14,"depth":235,"text":14},{"id":21,"depth":235,"text":21,"children":239},[240,242],{"id":25,"depth":241,"text":26},3,{"id":39,"depth":241,"text":40},{"id":48,"depth":235,"text":49},{"id":134,"depth":235,"text":135},{"id":189,"depth":235,"text":189},"Hexo","2019-05-15 13:58:15","md","zh-Hant",{},true,"\u002Fhexo\u002Fhexo","2",{"title":6,"description":18},false,"Hexo\u002F替Hexo加入發送通知功能",[246,59],null,"\u002Fhexo\u002F20190515\u002F3137769270\u002F","AqN63YIfT5UP9btE_r22yKdH0o4IyT3mcCKdTmpga-k",{"newer":262,"older":266},{"url":263,"title":264,"date":265},"\u002Fjsweirdworld\u002F20190515\u002F1399834060\u002F","[JS奇怪的世界]No.5 觀念小提醒:JavaScript 與 Undefined","2019-05-15 21:00:35",{"url":267,"title":268,"date":269},"\u002Fjsweirdworld\u002F20190515\u002F3344152504\u002F","[JS奇怪的世界]No.4 執行環境:創造與提升","2019-05-15 12:00:35",[271,275,280],{"url":272,"title":273,"date":274,"readingMinutes":253},"\u002Fhexo\u002F20221030\u002F561405053\u002F","解決 Hexo 更新系統或使用 CI 部署後文章出現更新日期的問題","2022-10-30 11:52:35",{"url":276,"title":277,"date":278,"readingMinutes":279},"\u002Fhexo\u002F20201101\u002F60919\u002F","(33)試著學 Hexo-番外篇之更新 NexT 主題","2020-11-01 13:21:00","3",{"url":281,"title":282,"date":283,"readingMinutes":253},"\u002Fhexo\u002F20201031\u002F2194088152\u002F","(32)試著學 Hexo-番外篇之更新 Hexo","2020-10-31 14:01:51",1784020385497]