[{"data":1,"prerenderedAt":371},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20201011\u002F1851462675\u002F":3,"page:\u002Fhexo\u002F20201011\u002F1851462675\u002F":4,"alt:\u002Fhexo\u002F20201011\u002F1851462675\u002F":3,"prev-next:\u002Fhexo\u002F20201011\u002F1851462675\u002F":348,"related:\u002Fhexo\u002F20201011\u002F1851462675\u002F":357},"\u002Fen\u002Fhexo\u002F2020\u002F10\u002F11\u002Flearn-hexo-28-writing-tips\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":333,"date":334,"description":18,"extension":39,"lang":335,"meta":336,"navigation":217,"path":337,"readingMinutes":338,"seo":339,"standalone":340,"stem":341,"tags":342,"tldr":345,"updated":345,"url":346,"__hash__":347},"content\u002F試著學 Hexo\u002F28-試著學-Hexo-奇淫技巧-寫作的小眉角.md","(28) 試著學 Hexo - 奇淫技巧 - 寫作的小眉角","1851462675",{"type":9,"value":10,"toc":326},"minimark",[11,15,19,22,34,92,101,120,146,161,164,226,229,232,254,260,263,266,269,272,281,284,288,295,302,305,311,319,322],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來這一篇教一些前面所沒有教的寫作小技巧哩~",[12,20,21],{"id":21},"快速生成模板",[16,23,24,25,29,30,33],{},"在前面有提到我們可以透過 ",[26,27,28],"code",{},"description"," 的標籤來生成 more 的按鈕，但是在預設 ",[26,31,32],{},"hexo new"," 一篇文章時，預設模板都是以下",[35,36,41],"pre",{"className":37,"code":38,"language":39,"meta":40,"style":40},"language-md shiki shiki-themes github-dark-high-contrast","---\ntitle: test\ndate: 2020-09-18 21:49:50\ntags:\n---\n","md","",[26,42,43,52,66,78,87],{"__ignoreMap":40},[44,45,48],"span",{"class":46,"line":47},"line",1,[44,49,51],{"class":50},"sMAXC","---\n",[44,53,55,59,62],{"class":46,"line":54},2,[44,56,58],{"class":57},"sKpQp","title",[44,60,61],{"class":50},": ",[44,63,65],{"class":64},"sTRMh","test\n",[44,67,69,72,74],{"class":46,"line":68},3,[44,70,71],{"class":57},"date",[44,73,61],{"class":50},[44,75,77],{"class":76},"sCcAr","2020-09-18 21:49:50\n",[44,79,81,84],{"class":46,"line":80},4,[44,82,83],{"class":57},"tags",[44,85,86],{"class":50},":\n",[44,88,90],{"class":46,"line":89},5,[44,91,51],{"class":50},[16,93,94,95,97,98,100],{},"因此每次我們撰寫文章的時候就必須再一次填寫 ",[26,96,28],{}," 這樣子實在是很不方便，因此在這邊教一下，如何將 ",[26,99,28],{}," 加入到預設生成的模板內。",[16,102,103,104,107,108,111,112,115,116,119],{},"首先 Hexo 專案底下有一個 ",[26,105,106],{},"scaffolds"," 資料夾，這裡分別有 ",[26,109,110],{},"post.md","、",[26,113,114],{},"page.md"," 以及 ",[26,117,118],{},"draft.md"," 這三個檔案，這三個檔案就是預設的模板，而分別個別對應的指令如下",[121,122,123,131,138],"ul",{},[124,125,126,128,129],"li",{},[26,127,32],{}," -> ",[26,130,110],{},[124,132,133,128,136],{},[26,134,135],{},"hexo new page",[26,137,114],{},[124,139,140,128,143],{},[26,141,142],{},"hexo new draft",[26,144,145],{},"darft.md",[16,147,148,149,151,152,154,155,157,158,160],{},"通常 ",[26,150,114],{}," 與 ",[26,153,145],{}," 是不太會去更動的設定，最主要會調整的是 ",[26,156,110],{}," 這隻檔案，那我們要如何增加預設欄位呢？只需要將你希望填入的欄位寫入到 ",[26,159,110],{}," 就可以了",[16,162,163],{},"而拿我自己當作範本的話，則會像下面這樣",[35,165,167],{"className":37,"code":166,"language":39,"meta":40,"style":40},"---\ntitle: {{ title }}\ndate: {{ date }}\ntags:\ndescription:\n---\n\n## 前言\n",[26,168,169,173,185,195,201,207,212,219],{"__ignoreMap":40},[44,170,171],{"class":46,"line":47},[44,172,51],{"class":50},[44,174,175,177,180,182],{"class":46,"line":54},[44,176,58],{"class":57},[44,178,179],{"class":50},": {{ ",[44,181,58],{"class":64},[44,183,184],{"class":50}," }}\n",[44,186,187,189,191,193],{"class":46,"line":68},[44,188,71],{"class":57},[44,190,179],{"class":50},[44,192,71],{"class":64},[44,194,184],{"class":50},[44,196,197,199],{"class":46,"line":80},[44,198,83],{"class":57},[44,200,86],{"class":50},[44,202,203,205],{"class":46,"line":89},[44,204,28],{"class":57},[44,206,86],{"class":50},[44,208,210],{"class":46,"line":209},6,[44,211,51],{"class":50},[44,213,215],{"class":46,"line":214},7,[44,216,218],{"emptyLinePlaceholder":217},true,"\n",[44,220,222],{"class":46,"line":221},8,[44,223,225],{"class":224},"s-VM4","## 前言\n",[16,227,228],{},"在此我會連「前言」都預先打好，畢竟這是我寫文章固定的開頭，所以就先打起來放沒差。",[12,230,231],{"id":231},"草稿模式",[16,233,234,235,237,238,241,242,245,246,249,250,253],{},"在前面有看到 Hexo 其實也有草稿模式的指令，也就是 ",[26,236,142],{},"，而在草稿資料夾下的檔案就不會被編譯，但其實說真的我自己每次都記不住 ",[26,239,240],{},"draft"," 這個指令，因此這邊教你另一個小眉角，我們都知道 Hexo 不會編譯 ",[26,243,244],{},"_post"," 底下有底線「",[26,247,248],{},"_","」開頭的資料夾，所以你可以建立一個資料夾叫做「",[26,251,252],{},"_草稿","」，然後將還不想要發佈的文章丟到這裡面這樣即可。\n這樣子在這個資料夾底下的文章就不會被編譯啦~",[16,255,256,257,259],{},"這樣你也不用再浪費腦容量去記憶 ",[26,258,142],{}," 指令了。",[12,261,262],{"id":262},"markdownlint",[16,264,265],{},"之所以會推薦使用 VSCode 撰寫文章還有一個原因是因為有一個套件叫做 「markdownlint」，如果你是一位前端開發者，看到 lint 應該會覺得該不會是 ESLint 吧？！",[16,267,268],{},"沒錯，就是類似的東西！",[16,270,271],{},"以我自己在寫文章時，也會希望自己的文章可以盡可能的統一風格，例如結尾要空一行，一個頁面只能一種階層符號等等，透過一些套件來閱數自己 md 每一篇的風格以及提醒自己程式碼區塊一定要補上程式碼語言等等良好的習慣，因此在此也推薦給各位。",[16,273,274,275],{},"下載連結：",[276,277,278],"a",{"href":278,"rel":279},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=DavidAnson.vscode-markdownlint",[280],"nofollow",[16,282,283],{},"(我自從裝了這個套件之後都不太敢去看自己之前的文章，因為會各種黃毛毛蟲...)",[12,285,287],{"id":286},"vscode-即時預覽","VSCode 即時預覽",[16,289,290,291,294],{},"最後的最後介紹這個簡單的功能就好，有時候我們不會開啟 ",[26,292,293],{},"hexo s"," 模擬伺服器來看當前文章寫的狀況，但我們又會希望文章可以所見即所得，所以這時候你只要點一下以下圖片箭頭所指處",[16,296,297],{},[298,299],"img",{"alt":300,"src":301},"開啟預覽 MD","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F28-%E8%A9%A6%E8%91%97%E5%AD%B8-Hexo-%E5%A5%87%E6%B7%AB%E6%8A%80%E5%B7%A7-%E5%AF%AB%E4%BD%9C%E7%9A%84%E5%B0%8F%E7%9C%89%E8%A7%92_md_%E2%80%94_WelcomeWebWorld.png",[16,303,304],{},"當你點了之後 VSCode 右側就會開啟所見即所得囉~",[16,306,307],{},[298,308],{"alt":309,"src":310},"所見即所得","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-09-18%2022.26.35.png",[16,312,313,314,318],{},"最後，如果你真的很猶豫是否開始架設自己的部落格，那麼我會推薦你看我先前撰寫的這一篇「",[276,315,317],{"href":316},"\u002Flearnexp\u002F20190723\u002F2343571780\u002F","關於寫部落格的心法","」",[16,320,321],{},"那麼這一篇寫作的小眉角就先到這邊結束囉~",[323