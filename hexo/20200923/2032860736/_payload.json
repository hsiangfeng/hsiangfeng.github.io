[{"data":1,"prerenderedAt":688},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20200923\u002F2032860736\u002F":3,"page:\u002Fhexo\u002F20200923\u002F2032860736\u002F":4,"alt:\u002Fhexo\u002F20200923\u002F2032860736\u002F":3,"prev-next:\u002Fhexo\u002F20200923\u002F2032860736\u002F":665,"related:\u002Fhexo\u002F20200923\u002F2032860736\u002F":674},"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F23\u002Flearn-hexo-10-adding-pages\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":649,"date":650,"description":18,"extension":295,"lang":651,"meta":652,"navigation":653,"path":654,"readingMinutes":655,"seo":656,"standalone":657,"stem":658,"tags":659,"tldr":662,"updated":662,"url":663,"__hash__":664},"content\u002F試著學 Hexo\u002F10-試著學-Hexo-新增頁面.md","(10) 試著學 Hexo - 新增頁面","2032860736",{"type":9,"value":10,"toc":644},"minimark",[11,15,19,22,30,47,54,57,66,77,84,90,95,101,104,107,113,279,282,288,291,319,322,551,554,560,563,574,634,637,640],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來讓我們了解該如何在 Hexo 新增一些頁面。",[12,20,21],{"id":21},"新增頁面",[16,23,24,25,29],{},"首先，先講講為什麼要新增頁面，這時候先讓我們開啟一下前面我們所建立的 Hexo，為了避免讀者 ",[26,27,28],"del",{},"金魚腦"," 忘記指令，所以我們開啟 Hexo 之後要在終端機輸入以下指令",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-cmd shiki shiki-themes github-light github-light github-dark-high-contrast","hexo s\n","cmd","",[38,39,40],"code",{"__ignoreMap":36},[41,42,45],"span",{"class":43,"line":44},"line",1,[41,46,34],{},[16,48,49,50,53],{},"模擬伺服器開啟之後，通常我們一個部落格都會有關於作者的介紹，也就是 about 頁面，因此你會發現頁面上並沒有這個頁面，不論你是透過 ",[38,51,52],{},"http:\u002F\u002Flocalhost:4000\u002Fabout\u002F"," 都是相同的狀況。",[16,55,56],{},"所以我們先停止模擬伺服器，然後在終端機底下輸入以下指令",[31,58,60],{"className":33,"code":59,"language":35,"meta":36,"style":36},"hexo new page about\n",[38,61,62],{"__ignoreMap":36},[41,63,64],{"class":43,"line":44},[41,65,59],{},[16,67,68,69,72,73,76],{},"這時候 Hexo 就會在 ",[38,70,71],{},"source"," 底下建立 ",[38,74,75],{},"about\u002Findex.md"," 檔案，這個就是你將來 about 頁面。",[16,78,79],{},[80,81],"img",{"alt":82,"src":83},"about","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-08-03%2013.34.57.png",[16,85,86,87,89],{},"接下來我們再重新啟動模擬伺服器，這時候你一樣在 Url 處輸入 ",[38,88,52],{}," 就可以看到畫面出現囉~",[16,91,92],{},[80,93],{"alt":82,"src":94},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-08-03%2013.37.38.png",[16,96,97,98,100],{},"那畫面上會空白是正常的，因為你並沒有輸入相關的文字進去到 ",[38,99,75],{},"，這邊內容就留給你自由發揮。",[12,102,103],{"id":103},"去除模板",[16,105,106],{},"接下來可能會有人希望自己新增的頁面是採用自己寫的 HTML 切版切出來，這一點 Hexo 也做得到，這邊將會舉例剛剛新增的 about 頁面。",[16,108,109,110,112],{},"首先先將 ",[38,111,75],{}," 改成 index.html，然後內容全部清空，並輸入以下程式碼",[31,114,118],{"className":115,"code":116,"language":117,"meta":36,"style":36},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003C!DOCTYPE html>\n\u003Chtml lang=\"zh-Hant-TW\">\n\u003Chead>\n  \u003Cmeta charset=\"UTF-8\">\n  \u003Cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  \u003Ctitle>關於我\u003C\u002Ftitle>\n\u003C\u002Fhead>\n\u003Cbody>\n  \u003Ch1>這是標題\u003C\u002Fh1>\n\u003C\u002Fbody>\n\u003C\u002Fhtml>\n","html",[38,119,120,137,157,167,186,211,226,236,246,261,270],{"__ignoreMap":36},[41,121,122,126,130,134],{"class":43,"line":44},[41,123,125],{"class":124},"s8XSl","\u003C!",[41,127,129],{"class":128},"syv7_","DOCTYPE",[41,131,133],{"class":132},"sK3KL"," html",[41,135,136],{"class":124},">\n",[41,138,140,143,145,148,151,155],{"class":43,"line":139},2,[41,141,142],{"class":124},"\u003C",[41,144,117],{"class":128},[41,146,147],{"class":132}," lang",[41,149,150],{"class":124},"=",[41,152,154],{"class":153},"sWayO","\"zh-Hant-TW\"",[41,156,136],{"class":124},[41,158,160,162,165],{"class":43,"line":159},3,[41,161,142],{"class":124},[41,163,164],{"class":128},"head",[41,16