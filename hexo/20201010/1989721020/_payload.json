},[78,331,332],{"class":171},"init)init ssh\n",[78,334,336,339,341],{"class":80,"line":335},19,[78,337,338],{"class":163},"      run",[78,340,168],{"class":167},[78,342,344],{"class":343},"sWyjQ","|\n",[78,346,348],{"class":80,"line":347},20,[78,349,350],{"class":171},"          mkdir -p ~\u002F.ssh\u002F\n",[78,352,354],{"class":80,"line":353},21,[78,355,356],{"class":171},"          echo \"${{secrets.HEXO}}\" > ~\u002F.ssh\u002Fid_rsa\n",[78,358,360],{"class":80,"line":359},22,[78,361,362],{"class":171},"          chmod 600 ~\u002F.ssh\u002Fid_rsa\n",[78,364,366],{"class":80,"line":365},23,[78,367,368],{"class":171},"          ssh-keyscan github.com >> ~\u002F.ssh\u002Fknown_hosts\n",[78,370,372],{"class":80,"line":371},24,[78,373,374],{"class":171},"          git config --global user.name \"xxxx\"\n",[78,376,378],{"class":80,"line":377},25,[78,379,380],{"class":171},"          git config --global user.email \"xxxx@gmail.com\"\n",[78,382,384,386,388,390],{"class":80,"line":383},26,[78,385,218],{"class":167},[78,387,164],{"class":163},[78,389,168],{"class":167},[78,391,392],{"class":171},"A)npm install\n",[78,394,396,398,400],{"class":80,"line":395},27,[78,397,338],{"class":163},[78,399,168],{"class":167},[78,401,344],{"class":343},[78,403,405],{"class":80,"line":404},28,[78,406,407],{"class":171},"        npm install\n",[78,409,411,413,415,417],{"class":80,"line":410},29,[78,412,218],{"class":167},[78,414,164],{"class":163},[78,416,168],{"class":167},[78,418,419],{"class":171},"B)npm install -g hexo-cli\n",[78,421,423,425,427],{"class":80,"line":422},30,[78,424,338],{"class":163},[78,426,168],{"class":167},[78,428,344],{"class":343},[78,430,432],{"class":80,"line":431},31,[78,433,434],{"class":171},"        npm install -g hexo-cli\n",[78,436,438,440,442,444],{"class":80,"line":437},32,[78,439,218],{"class":167},[78,441,164],{"class":163},[78,443,168],{"class":167},[78,445,446],{"class":171},"C) hexo d -g\n",[78,448,450,452,454],{"class":80,"line":449},33,[78,451,338],{"class":163},[78,453,168],{"class":167},[78,455,344],{"class":343},[78,457,459],{"class":80,"line":458},34,[78,460,461],{"class":171},"        hexo d -g\n",[16,463,464],{},"接下來當你執行 push 時，就會被自動部屬，然後可以在 GitHub 的 Acionts 看到執行流程唷~",[16,466,467],{},[26,468],{"alt":469,"src":470},"Actions","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-09-16%2017.46.12.png",[12,472,473],{"id":473},"補充",[16,475,476,477,480],{},"最後如果你發現無法自動部屬，那麼原因可能是出在 ",[75,478,479],{},"hexo\u002F_config.yml"," 以下這一段",[68,482,484],{"className":154,"code":483,"language":156,"meta":73,"style":73},"deploy:\n  type: git\n  repo: https:\u002F\u002Fgithub.com\u002Fjc-eng\u002Fjc-eng.github.io.git # https:\u002F\u002Fgithub.com\u002F[你的 GitHub 帳號]\u002F[你的 GitHub 帳號].github.io.git\n  branch: master # 在這邊我是使用 mster 當作主要分支\n  message: 'ithelpt'\n",[75,485,486,493,503,516,529],{"__ignoreMap":73},[78,487,488,491],{"class":80,"line":81},[78,489,490],{"class":163},"deploy",[78,492,196],{"class":167},[78,494,495,498,500],{"class":80,"line":175},[78,496,497],{"class":163},"  type",[78,499,168],{"class":167},[78,501,502],{"class":171},"git\n",[78,504,505,508,510,513],{"class":80,"line":182},[78,506,507],{"class":163},"  repo",[78,509,168],{"class":167},[78,511,512],{"class":171},"https:\u002F\u002Fgithub.com\u002Fjc-eng\u002Fjc-eng.github.io.git",[78,514,515],{"class":185}," # https:\u002F\u002Fgithub.com\u002F[你的 GitHub 帳號]\u002F[你的 GitHub 帳號].github.io.git\n",[78,517,518,521,523,526],{"class":80,"line":189},[78,519,520],{"class":163},"  branch",[78,522,168],{"class":167},[78,524,525],{"class":171},"master",[78,527,528],{"class":185}," # 在這邊我是使用 mster 當作主要分支\n",[78,530,531,534,536],{"class":80,"line":199},[78,532,533],{"class":163},"  message",[78,535,168],{"class":167},[78,537,538],{"class":171},"'ithelpt'\n",[16,540,541],{},"這一段必須從 https 模式改成走 ssh 模式唷~\n因為 GitHub Actions 是使用 ssh 的模式在運作",[68,543,545],{"c