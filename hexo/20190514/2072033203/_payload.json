Ftags\u002F\n",[79,171,173],{"class":81,"line":172},6,[79,174,175],{},"Disallow: \u002Fvendors\u002F\n",[79,177,179],{"class":81,"line":178},7,[79,180,181],{},"Disallow: \u002Ffonts\u002F\n",[79,183,185],{"class":81,"line":184},8,[79,186,175],{},[79,188,190],{"class":81,"line":189},9,[79,191,192],{},"Disallow: \u002Ffancybox\u002F\n",[79,194,196],{"class":81,"line":195},10,[79,197,198],{},"Sitemap: https:\u002F\u002Fhsiangfeng.github.io\u002Fsitemap.xml\n",[79,200,202],{"class":81,"line":201},11,[79,203,204],{},"Sitemap: https:\u002F\u002Fhsiangfeng.github.io\u002Fbaidusitemap.xml\n",[42,206,207,210,213],{},[45,208,209],{},"Allow 代表允許",[45,211,212],{},"Disallow 代表不允許",[45,214,215],{},"Sitemap 就是網站地圖",[16,217,218],{},"補充一下為什麼要加入 robots.txt，原因是爬蟲會遵照這個檔案來爬那些內容是可以爬取，那些內容不可以爬取，所以若善用 robots.txt 也是能夠加強 SEO。",[12,220,222],{"id":221},"next主題seo","NexT主題SEO",[16,224,225,226,229,230,233],{},"由於我所使用的主題是有針對SEO做優化，但是預設為 ",[23,227,228],{},"false"," ，所以必須將其修改成 ",[23,231,232],{},"true","(目錄為主題目錄下的 _config.yml)",[16,235,236],{},[110,237],{"alt":112,"src":238},"https:\u002F\u002Fi.imgur.com\u002F3ppWDs1.png",[12,240,242],{"id":241},"hext-footer","HexT Footer",[16,244,245,246,248],{},"由於爬蟲會爬出所有連結，然後一個一個查看那這種狀況就有可能進去後就不會回來網站了，由於 footer 有一個版權宣告，所以這邊要使用一個 ",[23,247,105],{}," 技巧來協助。",[16,250,251],{},"首先尋找 HexT 的 footer.swig (通常路徑: hexo-theme-next-master\\layout_partials\\footer.swig)",[16,253,254,255],{},"1.搜尋 ",[23,256,257],{},"theme-next.org",[16,259,260],{},"將原始這一行",[70,262,264],{"className":72,"code":263,"language":74,"meta":75,"style":75},"{{ __('footer.theme') }} – {{ next_url('https:\u002F\u002Ftheme-next.org', 'NexT.' + theme.scheme, {class: 'theme-link'}) }}\n",[23,265,266],{"__ignoreMap":75},[79,267,268],{"class":81,"line":82},[79,269,263],{},[16,271,272],{},"改寫成這樣",[70,274,276],{"className":72,"code":275,"language":74,"meta":75,"style":75},"#}{{ __('footer.theme') }} – \u003Ca href='https:\u002F\u002Ftheme-next.org' class='theme-link' rel='external nofollow'> NexT.Pisces \u003C\u002Fa>{#\n",[23,277,278],{"__ignoreMap":75},[79,279,280],{"class":81,"line":82},[79,281,275],{},[16,283,284,285],{},"2.搜尋 ",[23,286,287],{},"hexo.io",[16,289,290],{},"將原本的",[70,292,294],{"className":72,"code":293,"language":74,"meta":75,"style":75},"{{ __('footer.powered', next_url('https:\u002F\u002Fhexo.io', 'Hexo', {class: 'theme-link'})) }}\n",[23,295,296],{"__ignoreMap":75},[79,297,298],{"class":81,"line":82},[79,299,293],{},[16,301,302],{},"修改成",[70,304,306],{"className":72,"code":305,"language":74,"meta":75,"style":75},"\u003Ca href='https:\u002F\u002Fhexo.io' class='theme-link' rel='external nofollow'> Hexo \u003C\u002Fa>\n",[23,307,308],{"__ignoreMap":75},[79,309,310],{"class":81,"line":82},[79,311,305],{},[16,313,314,315,318],{},"基本上只要是非友情連結都可以加上 ",[23,316,317],{},"rel=\"external nofollow\"","，避免爬蟲爬進去後就不回來了。",[37,320,321],{"id":321},"hexo-autonofollow",[16,323,324,325,327],{},"基本上若嫌修改太麻煩可以試試看 ",[23,326,321],{}," 這個插件。\n(我個人也不是很喜歡改模板，下次更新會很麻煩)",[70,329,331],{"className":72,"code":330,"language":74,"meta":75,"style":75},"npm install hexo-autonofollow --save\n",[23,332,333],{"__ignoreMap":75},[79,334,335],{"class":81,"line":82},[79,336,330],{},[16,338,339],{},"接下來在系統的主要 _config.yml 最後加入設定(系統根目錄 hexo\u002Fsource，非theme)。",[70,341,343],{"className":72,"code":342,"language":74,"meta":75,"style":75},"nofollow:\n    enable: true\n    exclude:  # 不加上 nofollow 的友情連結可以放在這邊。\n    - exclude1.com\n    - exclude2.com\n",[23,344,345,350,355,360,365],{"__ignoreMap":75},[79,346,347],{"class":81,"line":82},[79,348,349],{},"nofollow:\n",[79,351,352],{"class":81,"line":148},[79,353,354],{},"    enable: true\n",[79,356,357],{"class":81,"line":154},[79,358,359],{},"    exclude:  # 不加上 nofollow 的友情連結可以放在這邊。\n",[79,361,362],{"class":81,"line":160},[79,363,364],{},"    - exclude1.com\n",[79,366,367],{"class":81,"line":166},[79,368,369],{},"    - exclude2.com\n",[16,371,372,373,375],{},"加入完畢後可以看到非友情連結的網站都加入 ",[23,374,317],{}," 了。",[16,377,378],{},[110,379],{"alt":112,"src":380},"https:\u002F\u002Fi.imgur.com\u002FnxwpiYx.png",[16,382,383,384,387],{},"如果沒有友站可以不寫入 ",[23,385,386],{},"exclude","，只需要寫入這樣",[70,389,391],{"className":72,"code":390,"language":74,"meta":75,"style":75},"nofollow:\n    enable: true\n",[23,392,393,397],{"__ignoreMap":75},[79,394,395],{"class":81,"line":82},[79,396,349],{},[79,398,399],{"class":81,"line":148},[79,400,354],{},[12,402,404],{"id":403},"keyworddescription","keyword&description",[16,406,407],{},"雖然 Google 有說過他們的爬蟲並不看 keyword&description，但是這邊一樣看一下文章是否有正常出現 keyword&description。",[16,409,410],{},[110,411],{"alt":112,"src":412},"https:\u002F\u002Fi.imgur.com\u002FJ9qc5ls.png",[16,414,415],{},"description 方面基本上沒甚麼問題，但 keyword 就比較麻煩一點，由於 hexo 若沒有在文章內寫入 keyword，就會依照目前分類做 keyword。",[16,417,418],{},[110,419],{"alt":112,"src":420},"https:\u002F\u002Fi.imgur.com\u002Fo3ZQOvK.png",[16,422,423],{},"所以如果要讓文章可以更 SEO 化，還是要依照以下方式做撰寫。",[70,425,427],{"className":72,"code":426,"language":74,"meta":75,"style":75},"title: ###\ndate: ###\ncategories: ###\ntags: ###\nkeywords: ###\n",[23,428,429,434,439,444,449],{"__ignoreMap":75},[79,430,431],{"class":81,"line":82},[79,432,433],{},"title: ###\n",[79,435,436],{"class":81,"line":148},[79,437,438],{},"date: ###\n",[79,440,441],{"class":81,"line":154},[79,442,443],{},"categories: ###\n",[79,445,446],{"class":81,"line":160},[79,447,448],{},"tags: ###\n",[79,450,451],{"class":81,"line":166},[79,452,453],{},"keywords: ###\n",[16,455,456],{},[110,457],{"alt":112,"src":458},"https:\u002F\u002Fi.imgur.com\u002FJDH1BoZ.png",[16,460,461],{},"這樣子在瀏覽器上就可以看到正常的 keyword 了。",[16,463,464],{},[110,465],{"alt":112,"src":466},"https:\u002F\u002Fi.imgur.com\u002FVGvV1OQ.png",[16,468,469],{},"另外由於我比較懶得下 keyword，而且 Google 爬蟲並不看 keyword，所以自己並不會特別去設置 keywords。",[12,471,472],{"id":472},"文章連結",[16,474,475],{},"如果對於文章的連結不滿意(預設是年\u002F月\u002F日\u002F文章名稱)。",[16,477,478],{},[110,479],{"alt":112,"src":480},"https:\u002F\u002Fi.imgur.com\u002FxqWJjbv.png",[16,482,483],{},"可以到系統的 _config.yml 中做調整(約 18 行)",[16,485,486],{},[110,487],{"alt":112,"src":488},"https:\u002F\u002Fi.imgur.com\u002FzKUzfB4.png",[16,490,491],{},"例如我修改成",[70,493,495],{"className":72,"code":494,"language":74,"meta":75,"style":75},"permalink: :title\u002F\n",[23,496,497],{"__ignoreMap":75},[79,498,499],{"class":81,"line":82},[79,500,494],{},[16,502,503],{},"那麼路徑就會變成這樣子。",[16,505,506],{},[110,507],{"alt":112,"src":508},"https:\u002F\u002Fi.imgur.com\u002FXVFrZWS.png",[16,510,511],{},"由於我的 blog 也寫超過一個月了，隨便變動路徑其實也很不 OK，我就不做調整了。",[16,513,514],{},"那麼可以使用的變數有以下",[16,516,517],{},[110,518],{"alt":112,"src":519},"https:\u002F\u002Fi.imgur.com\u002F0ZMNwxR.png",[16,521,522,523,526,527],{},"PS.建議不要用 ",[524,525],"category",{},"，如果你分類較多的話會變成這樣 ",[23,528,529],{},"javascript\u002Fvuejs\u002F...",[16,531,532,533,26],{},"在官網也有範例可",[101,534,537],{"href":535,"rel":536},"https:\u002F\u002Fhexo.io\u002Fzh-tw\u002Fdocs\u002Fpermalinks",[105],"參考",[16,539,540],{},[110,541],{"alt":112,"src":542},"https:\u002F\u002Fi.imgur.com\u002FJl115Jv.png",[12,544,545],{"id":545},"參考文章",[16,547,548],{},[101,549,552],{"href":550,"rel":551},"https:\u002F\u002Fhexo.io",[105],"Hexo",[16,554,555],{},[101,556,559],{"href":557,"rel":558},"https:\u002F\u002Fwww.jianshu.com\u002Fp\u002F86557c34b671",[105],"Hexo Seo优化让你的博客在google搜索排名第一",[16,561,562],{},[101,563,566],{"href":564,"rel":565},"https:\u002F\u002Fhoxis.github.io\u002FHexo+Next%20SEO%E4%BC%98%E5%8C%96.html",[105],"Hexo博客Next主题SEO优化方法",[12,568,569],{"id":569},"補充",[16,571,572],{},"建議 robots 去除這兩行。",[70,574,576],{"className":72,"code":575,"language":74,"meta":75,"style":75},"Disallow: \u002Fjs\u002F\nDisallow: \u002Fcss\u002F\n",[23,577,578,583],{"__ignoreMap":75},[79,579,580],{"class":81,"line":82},[79,581,582],{},"Disallow: \u002Fjs\u002F\n",[79,584,585],{"class":81,"line":148},[79,586,587],{},"Disallow: \u002Fcss\u002F\n",[16,589,590],{},"對於 Google 爬蟲來講禁止這兩行將有可能導致掉落",[16,592,593,597],{},[101,594,545],{"href":595,"rel":596},"https:\u002F\u002Fyoast.com\u002Fdont-block-css-and-js-files\u002F",[105