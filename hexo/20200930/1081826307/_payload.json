[{"data":1,"prerenderedAt":417},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20200930\u002F1081826307\u002F":3,"page:\u002Fhexo\u002F20200930\u002F1081826307\u002F":4,"alt:\u002Fhexo\u002F20200930\u002F1081826307\u002F":3,"prev-next:\u002Fhexo\u002F20200930\u002F1081826307\u002F":394,"related:\u002Fhexo\u002F20200930\u002F1081826307\u002F":403},"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F30\u002Flearn-hexo-17-next-theme\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":375,"date":376,"description":377,"extension":378,"lang":379,"meta":380,"navigation":381,"path":382,"readingMinutes":383,"seo":384,"standalone":385,"stem":386,"tags":387,"tldr":391,"updated":391,"url":392,"__hash__":393},"content\u002F試著學 Hexo\u002F17-試著學-Hexo-NexT-主題篇-NexT.md","(17) 試著學 Hexo - NexT 主題篇 - NexT","1081826307",{"type":9,"value":10,"toc":370},"minimark",[11,15,18,23,34,41,60,66,69,72,75,78,82,85,102,113,133,140,146,149,165,168,172,179,186,226,232,247,253,260,332,339,357,363,366],[12,13,14],"p",{},"`## 前言",[12,16,17],{},"接下來這一章節將會介紹比較多人使用的 NexT 主題，而這個主題也是我個人較喜好的主題。",[19,20,22],"h2",{"id":21},"什麼是-next","什麼是 NexT",[12,24,25,26,33],{},"NexT 有分成兩種版本，基本上你在 Google 搜尋「Hexo NexT」很有可能找到較早期的 NexT 5.1.4 版並且",[27,28,32],"a",{"href":29,"rel":30},"https:\u002F\u002Ftheme-next.iissnan.com\u002F",[31],"nofollow","官網","是這一個",[12,35,36],{},[37,38],"img",{"alt":39,"src":40},"舊版官網","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-08-30%2013.22.00.png",[12,42,43,44,48,49,53,54,59],{},"而我們主要會介紹的版本是 NexT v6 以上的版本，而這個版本他的官網先前是 ",[27,45,46],{"href":46,"rel":47},"https:\u002F\u002Ftheme-next.org\u002F",[31],"，後來因為網域過期(沒記錯的話)改調整成了 ",[27,50,51],{"href":51,"rel":52},"https:\u002F\u002Ftheme-next.js.org",[31]," 這個官方網站，而主要儲存庫也是以 ",[27,55,58],{"href":56,"rel":57},"https:\u002F\u002Fgithub.com\u002Fnext-theme\u002Fhexo-theme-next",[31],"這個"," 為主",[12,61,62],{},[37,63],{"alt":64,"src":65},"新版官網","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-08-30%2013.58.02.png",[12,67,68],{},"因此在稍後下載主題時，請不要下載錯版本唷~",[12,70,71],{},"而 NexT 之所以這麼熱門的原因除了文件寫得很清楚之外，它的版面也相對非常簡潔，並且也整合了相當多的功能，因此在網路上的討論度也會很高，相信你隨便 Google 一下 「Hexo NexT 教學」就會一大票。",[12,73,74],{},"而本系列將會以 NexT 7.8.0 為主。",[12,76,77],{},"(我在寫這一篇與精稿的同時，就默默到了 NexT 8...)",[19,79,81],{"id":80},"下載-next","下載 NexT",[12,83,84],{},"前面我們已經嘗試安裝過兩三個主題，因此相信在下載主題這邊對你來講已經非常上手，但為了確保你我下載的東西是相同的，所以這邊我也提供下載指令",[86,87,92],"pre",{"className":88,"code":89,"language":90,"meta":91,"style":91},"language-cmd shiki shiki-themes github-dark-high-contrast","git clone https:\u002F\u002Fgithub.com\u002Ftheme-next\u002Fhexo-theme-next themes\u002Fnext\n","cmd","",[93,94,95],"code",{"__ignoreMap":91},[96,97,100],"span",{"class":98,"line":99},"line",1,[96,101,89],{},[12,103,104,105,108,109,112],{},"下載之後一樣到 ",[93,106,107],{},"hexo\u002F_config.yml"," 修改 ",[93,110,111],{},"theme"," 欄位",[86,114,118],{"className":115,"code":116,"language":117,"meta":91,"style":91},"language-yml shiki shiki-themes github-dark-high-contrast","theme: next\n","yml",[93,119,120],{"__ignoreMap":91},[96,121,122,125,129],{"class":98,"line":99},[96,123,111],{"class":124},"sKpQp",[96,126,128],{"class":127},"sMAXC",": ",[96,130,132],{"class":131},"sTRMh","next\n",[12,134,135,136,139],{},"最後在輸入 ",[93,137,138],{},"hexo s"," 啟動模擬伺服器就可以看到 NexT 主題囉！",[12,141,142],{},[37,143],{"alt":144,"src":145},"Hexo NexT","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-08-30%2015.39.57.png",[12,147,148],{},"而 NexT 本身有四種主題風格分別是",[150,151,152,156,159,162],"ul",{},[153,154,155],"li",{},"Muse",[153,157,158],{},"Mist",[153,160,161],{},"Pisces",[153,163,164],{},"Gemini",[12,166,167],{},"而一開始畫面的主題風格是 Muse。",[19,169,171],{"id":170},"next-的設置","NexT 的設置",[12,173,174,175,178],{},"NexT 的功能非常的多，這邊舉例 ",[93,176,177],{},"theme\u002F_config.yml"," 的行數就高達 9xx 行，所以這邊就簡單介紹一些基本的功能，詳細的部分後面再來詳談。",[12,180,181,182,185],{},"首先先講講主題切換，在前面有說到 NexT 本身支援四種風格，所以你只需要搜尋 ",[93,183,184],{},"Scheme Settings"," 就可以看到以下風格設定",[86,187,189],{"className":115,"code":188,"language":117,"meta":91,"style":91},"# Schemes\nscheme: Muse\n#scheme: Mist\n#scheme: Pisces\n#scheme: Gemini\n",[93,190,191,197,208,214,220],{"__ignoreMap":91},[96,192,193],{"class":98,"line":99},[96,194,196],{"class":195},"sQrFR","# Schemes\n",[96,198,200,203,205],{"class":98,"line":199},2,[96,201,202],{"class":124},"scheme",[96,204,128],{"class":127},[96,206,207],{"class":131},"Muse\n",[96,209,211],{"class":98,"line":210},3,[96,212,213],{"class":195},"#scheme: Mist\n",[96,215,217],{"class":98,"line":216},4,[96,218,219],{"class":195},"#scheme: Pisces\n",[96,221,223],{"class":98,"line":222},5,[96,224,225],{"class":195},"#scheme: Gemini\n",[12,227,228,229,231],{},"基本上你只需要註解掉 ",[93,230,155],{}," 然後開啟另一個風格的註解並重新啟動模擬伺服器就可以看到風格切換了。",[12,233,234,235,238,239,242,243,246],{},"除此之外目前新版 NexT 也有支援暗色模式，你只需要搜尋 ",[93,236,237],{},"Dark Mode"," 並將 ",[93,240,241],{},"darkmode: false"," 改成 ",[93,244,245],{},"darkmode: true"," 就可以囉。",[12,248,249],{},[37,250],{"alt":251,"src":252},"Gemini 暗色系","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-08-31%2021.09.52.png",[12,254,255,256,259],{},"由於初始化的 NexT 主題 menu 只有 home 跟 archives，因此若你想開啟我們先前前面所製作的 about 頁面，只需要搜尋 ",[93,257,258],{},"Menu Settings"," 並將相關註解打開就好",[86,261,263],{"className":115,"code":262,"language":117,"meta":91,"style":91},"menu:\n  home: \u002F || fa fa-home\n  about: \u002Fabout\u002F || fa fa-user\n  #tags: \u002Ftags\u002F || fa fa-tags\n  #categories: \u002Fcategories\u002F || fa fa-th\n  archives: \u002Farchives\u002F || fa fa-archive\n  #schedule: \u002Fschedule\u002F || fa fa-calendar\n  #sitemap: \u002Fsitemap.xml || fa fa-sitemap\n  #commonweal: \u002F404