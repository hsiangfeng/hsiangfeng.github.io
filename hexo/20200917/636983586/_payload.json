88%AA%E5%9C%96%202020-07-11%2021.24.06.png",[16,66,67,68,71],{},"通常來講，初次建立的 Hexo 都會是最新版，這邊可以直接透過 ",[27,69,70],{},"package.json"," 檔案中看到 Hexo 的版本",[16,73,74],{},[61,75],{"alt":76,"src":77},"Hexo 版本","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002Fhexo4.2.1.png",[12,79,80],{"id":80},"目錄結構",[16,82,83],{},"接下來讓我們打開剛剛建立的 Hexo 專案，我個人建議在撰寫部落格文章時是使用 VSCode 原因我們後面再說。",[16,85,86],{},"開啟之後就可以看到 Hexo 目錄結構",[16,88,89],{},[61,90],{"alt":80,"src":91},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-11%2021.29.10.png",[93,94,95,101,106,118,130,135,140,144],"ul",{},[96,97,98],"li",{},[27,99,100],{},"node_modules",[96,102,103],{},[27,104,105],{},"scaffolds",[96,107,108,111],{},[27,109,110],{},"source",[93,112,113],{},[96,114,115],{},[27,116,117],{},"_posts",[96,119,120,123],{},[27,121,122],{},"themes",[93,124,125],{},[96,126,127],{},[27,128,129],{},"landscape",[96,131,132],{},[27,133,134],{},"_config.yml",[96,136,137],{},[27,138,139],{},".gitignore",[96,141,142],{},[27,143,70],{},[96,145,146],{},[27,147,148],{},"package-lock.json",[12,150,100],{"id":100},[16,152,153],{},"node_modules 這個資料夾你不用想太多，把它看成你 Hexo 所需要運作的套件暫存處就對了，基本上你所有安裝的套件也都會在這裡。",[16,155,156],{},[157,158,159],"del",{},"所以它外號也叫做黑洞",[16,161,162],{},[61,163],{"alt":100,"src":164},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F%E8%A9%A6%E8%91%97%E5%AD%B8%20Hexo%20%E7%B3%BB%E5%88%97\u002F%E6%88%AA%E5%9C%96%202020-07-11%2021.39.08.png",[12,166,105],{"id":105},[16,168,169],{},"scaffolds 底下會有三個檔案",[93,171,172,177,182],{},[96,173,174],{},[27,175,176],{},"draft.md",[96,178,179],{},[27,180,181],{},"page.md",[96,183,184],{},[27,185,186],{},"post.md",[16,188,189],{},"簡單來講當你建立一篇心得文章或是頁面時，就會以這裡的檔案初始化一篇文章，後面章節會在介紹這邊的檔案。",[12,191,110],{"id":110},[16,193,194,195,198],{},"source 資料夾是主要放原始檔案的地方，舉凡 Markdown 或是 HTML 檔案都是放在這底下，假使如果你有不想要被編譯的資料夾，那麼就可以使用 ",[27,196,197],{},"_"," (下底線)來忽略，一但加上下底線之後就不會被 Hexo 編譯或是 copy 到 public 資料夾。",[16,200,201,202,205,206,208],{},"但是這邊值得一提的是，我們要編譯的文章都是放在 ",[27,203,204],{},"_post"," 底下，但是並不會因為 post 前面有一個下底線而導致不會編譯或拷貝底下的檔案，而我本身文章有習慣使用資料夾做分類，所以如果你是放在 ",[27,207,204],{}," 底下的資料夾，剛好那個資料夾可能是你還不想公開的文章，那麼就可以加上下底線避免被編譯到 public。",[16,210,211],{},"而 source 底下主要的資料夾只有一個。",[93,213,214],{},[96,215,216],{},[27,217,117],{},[12,219,122],{"id":122},[16,221,222,223,225,226,228],{},"themes 是放置 Hexo 主題的地方，預設官方就有提供一個主題 ",[27,224,129],{},"，後面會在介紹更多主題，因此目前只需要知道 Hexo 會依據放在該資料夾底下的主題與 ",[27,227,134],{}," 設置來編譯產生靜態檔案。",[93,230,231],{},[96,232,129],{},[12,234,134],{"id":235},"_configyml",[16,237,238,240,241,243,244,246],{},[27,239,134],{}," 簡單來講就是 Hexo 的主要網站設定檔，舉凡主題設置、網誌名稱等，都是在這邊調整，但是這邊比較特別需要注意的是通常 Hexo 本身會有一個 ",[27,242,134],{}," 設置檔案，而主題本身也有一個 ",[27,245,134],{}," 檔案，這兩者是不同的，這邊要注意一下。",[16,248,249,250,253,254,257],{},"後面章節如果需要修改 Hexo 的主要網站設定檔的話，我會打 ",[27,251,252],{},"hexo\u002F_config.yml","，而主題則會打 ",[27,255,256],{},"themes\u002F_config.yml","，這一點在麻煩牢記一下避免兩個檔案混淆。",[16,259,260,261,263,264,267],{},"而這邊我會建議你先修改 ",[27,262,252],{}," 中的 ",[27,265,266],{},"Site"," 相關設置",[36,269,273],{"className":270,"code":271,"language":272,"meta":41,"style":41},"language-yml shiki shiki-themes github-dark-high-contrast","# Site\ntitle: Hexo # 部落格名稱\nsubtitle: '' # 部落格小標題\ndescription: '' # 部落格描述\nkeywords: # 部落格關鍵字\nauthor: John Doe # 部落格作者\nlanguage: en # 部落格語系，這個建議要做調整，只是在本篇我會保留預設。\ntimezone: '' # 標準時間可以看個人需求設置，我自己是沒設置\n","yml",[27,274,275,281,299,313,326,337,351,365],{"__ignoreMap":41},[45,276,277],{"class":47,"line":48},[45,278,280],{"class":279},"sQrFR","# Site\n",[45,282,284,288,292,296],{"class":47,"line":283},2,[45,285,287],{"class":286},"sKpQp","title",[45,289,291],{"class":290},"sMAXC",": ",[45,293,295],{"class":294},"sTRMh","Hexo",[45,297,298],{"class":279}," # 部落格名稱\n",[45,300,302,305,307,310],{"class":47,"line":301},3,[45,303,304],{"class":286},"subtitle",[45,306,291],{"class":290},[45,308,309],{"c