[{"data":1,"prerenderedAt":475},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20191206\u002F2397475810\u002F":3,"page:\u002Fhexo\u002F20191206\u002F2397475810\u002F":4,"alt:\u002Fhexo\u002F20191206\u002F2397475810\u002F":3,"prev-next:\u002Fhexo\u002F20191206\u002F2397475810\u002F":452,"related:\u002Fhexo\u002F20191206\u002F2397475810\u002F":461},"\u002Fen\u002Fhexo\u002F2019\u002F12\u002F06\u002Fsetup-gitalk-on-hexo-next\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":436,"date":437,"description":18,"extension":438,"lang":439,"meta":440,"navigation":441,"path":442,"readingMinutes":443,"seo":444,"standalone":445,"stem":446,"tags":447,"tldr":449,"updated":449,"url":450,"__hash__":451},"content\u002FHexo\u002F十分鐘超詳細替-Hexo-Next-開啟-Gitalk-留言版.md","十分鐘超詳細替 Hexo Next 開啟 Gitalk 留言版","2397475810",{"type":9,"value":10,"toc":425},"minimark",[11,15,19,22,26,37,41,51,55,60,64,67,74,77,83,86,92,95,101,104,110,116,119,125,129,139,147,150,155,284,287,293,296,303,402,407,410,416,421],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近決定將自己使用約快一年的 Disqus 換成 GitHub Gitalk，最主要原因是 Disqus 許多人留言常常收不到通知，發現的時候都已經過兩個禮拜甚至三個月以上，所以這一篇就來介紹如何快速開啟 Gitalk 吧!",[12,20,21],{"id":21},"環境參考",[23,24,25],"h3",{"id":25},"版本與環境",[27,28,34],"pre",{"className":29,"code":31,"language":32,"meta":33},[30],"language-text","作業系統： Windows10 X64\nNodejs:：V11.7.0\nIDE：VS Code\n","text","",[35,36,31],"code",{"__ignoreMap":33},[23,38,40],{"id":39},"hexo-版本","Hexo 版本",[42,43,44,48],"ul",{},[45,46,47],"li",{},"hexo: 3.8.0",[45,49,50],{},"hexo-cli: 2.0.0",[23,52,54],{"id":53},"next-版本","NexT 版本",[42,56,57],{},[45,58,59],{},"NexT: 7.1.0",[12,61,63],{"id":62},"建立-github-oauth-app","建立 GitHub OAuth APP",[16,65,66],{},"由於要使用 Gitalk 必須有 GitHub OAuth，所以首先先開啟 GitHub → Setting",[16,68,69],{},[70,71],"img",{"alt":72,"src":73},"Setting","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-49-41.png",[16,75,76],{},"接下來選擇 Developer settings",[16,78,79],{},[70,80],{"alt":81,"src":82},"Developer settings","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-50-14.png",[16,84,85],{},"然後點 OAuth Apps",[16,87,88],{},[70,89],{"alt":90,"src":91},"OAuth Apps","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-50-53.png",[16,93,94],{},"然後點上方 New OAuth App",[16,96,97],{},[70,98],{"alt":99,"src":100},"New OAuth App","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_20-51-40.png",[16,102,103],{},"接下來依照欄位填寫即可",[27,105,108],{"className":106,"code":107,"language":32,"meta":33},[30],"Application name - 應用程式名稱\nHomepage URL - 應用程式網域 → 填你部落格網址\nApplication description - 應用程式描述\nAuthorization callback URL - 授權回應網址 → 填你部落格網址\n",[35,109,107],{"__ignoreMap":33},[16,111,112],{},[70,113],{"alt":114,"src":115},"填寫欄位","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_17-29-09.png",[16,117,118],{},"申請完之後你就會獲得這兩組 ID (Client ID、Client Secret)，請不要外流，稍後會使用到",[16,120,121],{},[70,122],{"alt":123,"src":124},"OAuth ID","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_17-29-27.png",[12,126,128],{"id":127},"gitalk","Gitalk",[16,130,131,132,138],{},"稍微介紹一下為什麼要用 Gitalk，",[133,134,128],"a",{"href":135,"rel":136},"https:\u002F\u002Fgithub.com\u002Fgitalk\u002Fgitalk",[137],"nofollow"," 是一個基於 GitHub 所開發的留言版套件，通常身為工程師都會有 GitHub 帳號，而且使用 Gitalk 留言版套件也可以使用 MD 格式，所以對於工程師來講非常的棒唷~",[16,140,141,142],{},"這邊也提供一下 Gitalk ",[133,143,146],{"href":144,"rel":145},"https:\u002F\u002Fgitalk.github.io\u002F",[137],"Demo",[16,148,149],{},"接下來就開啟 Next 佈景主題的 _config.yml，然後搜尋「Gitalk」，此時你就可以看到相關設定，只需要依照欄位填入即可",[16,151,152],{},[70,153],{"alt":128,"src":154},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_21-03-34.png",[27,156,160],{"className":157,"code":158,"language":159,"meta":33,"style":33},"language-yml shiki shiki-themes github-dark-high-contrast","gitalk:\n  enable: true\n  github_id:  # GitHub 作者帳號\n  repo: hsiangfeng.github.io # 你的 Repo 名稱，通常就是網域\n  client_id: xxxxxxxx # 剛剛申請的 Client ID\n  client_secret: xxxxxxxx # 剛剛申請的 Client Secret\n  admin_user: hsiangfeng # 管理者的帳號\n  distraction_free_mode: true # 無干擾模式\n  language: zh-TW ## 語系\n","yml",[35,161,162,174,187,200,215,229,242,256,270],{"__ignoreMap":33},[163,164,167,170],"span",{"class":165,"line":166},"line",1,[163,168,127],{"class":169},"sKpQp",[163,171,173],{"class":172},"sMAXC",":\n",[163,175,177,180,183],{"class":165,"line":176},2,[163,178,179],{"class":169},"  enable",[163,181,182],{"class":172},": ",[163,184,186],{"class":185},"sCcAr","true\n",[163,188,190,193,196],{"class":165,"line":189},3,[163,191,192],{"class":169},"  github_id",[163,194,195],{"class":172},":  ",[163,197,199],{"class":198},"sQrFR","# GitHub 作者帳號\n",[163,201,203,206,208,212],{"class":165,"line":202},4,[163,204,205],{"class":169},"  repo",[163,207,182],{"class":172},[163,209,211],{"class":210},"sTRMh","hsiangfeng.github.io",[163,213,214],{"class":198}," # 你的 Repo 名稱，通常就是網域\n",[163,216,218,221,223,226],{"class":165,"line":217},5,[163,219,220],{"class":169},"  client_id",[163,222,182],{"class":172},[163,224,225],{"class":210},"xxxxxxxx",[163,227,228],{"class":198}," # 剛剛申請的 Client ID\n",[163,230,232,235,237,239],{"class":165,"line":231},6,[163,233,234],{"class":169},"  client_secret",[163,236,182],{"class":172},[163,238,225],{"class":210},[163,240,241],{"class":198}," # 剛剛申請的 Client Secret\n",[163,243,245,248,250,253],{"class":165,"line":244},7,[163,246,247],{"class":169},"  admin_user",[163,249,182],{"class":172},[163,251,252],{"class":210},"hsiangfeng",[163,254,255],{"class":198}," # 管理者的帳號\n",[163,257,259,262,264,267],{"class":165,"line":258},8,[163,260,261],{"class":169},"  distraction_free_mode",[163,263,182],{"class":172},[163,265,266],{"class":185},"true",[163,268,269],{"class":198}," # 無干擾模式\n",[163,271,273,276,278,281],{"class":165,"line":272},9,[163,274,275],{"class":169},"  language",[163,277,182],{"class":172},[163,279,280],{"class":210},"zh-TW",[163,282,283],{"class":198}," ## 語系\n",[16,285,286],{},"接下來只需要部屬到自己的網域就可以看到留言版開啟了，此外第一次使用會需要啟用 OAuth，只需要到任一篇文章內點一下啟用即可，否則會出現請聯絡 xxx 初始化評論唷~",[16,288,289],{},[70,290],{"alt":291,"src":292},"啟用成功","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_17-40-58.png",[12,294,295],{"id":295},"額外補充",[16,297,298,299,302],{},"當有人在你的 Gitalk 留言時 Gitalk 就會在你的 GitHub repo 上開啟一個 issues，你也可以對增加一行 ",[35,300,301],{},"labels"," 來做一下分類，避免太雜亂。",[27,304,306],{"className":157,"code":305,"language":159,"meta":33,"style":33},"gitalk:\n  enable: true\n  github_id:  # GitHub 作者帳號\n  repo: hsiangfeng.github.io # 你的 Repo 名稱，通常就是網域\n  client_id: xxxxxxxx # 剛剛申請的 Client ID\n  client_secret: xxxxxxxx # 剛剛申請的 Client Secret\n  admin_user: hsiangfeng # 管理者的帳號\n  distraction_free_mode: true # 無干擾模式，簡單來講就是當有人留言時不去吵你。\n  language: zh-TW ## 語系\n  labels: Gitalk\n",[35,307,308,314,322,330,340,350,360,370,381,391],{"__ignoreMap":33},[163,309,310,312],{"class":165,"line":166},[163,311,127],{"class":169},[163,313,173],{"class":172},[163,315,316,318,320],{"class":165,"line":176},[163,317,179],{"class":169},[163,319,182],{"class":172},[163,321,186],{"class":185},[163,323,324,326,328],{"class":165,"line":189},[163,325,192],{"class":169},[163,327,195],{"class":172},[163,329,199],{"class":198},[163,331,332,334,336,338],{"class":165,"line":202},[163,333,205],{"class":169},[163,335,182],{"class":172},[163,337,211],{"class":210},[163,339,214],{"class":198},[163,341,342,344,346,348],{"class":165,"line":217},[163,343,220],{"class":169},[163,345,182],{"class":172},[163,347,225],{"class":210},[163,349,228],{"class":198},[163,351,352,354,356,358],{"class":165,"line":231},[163,353,234],{"class":169},[163,355,182],{"class":172},[163,357,225],{"class":210},[163,359,241],{"class":198},[163,361,362,364,366,368],{"class":165,"line":244},[163,363,247],{"class":169},[163,365,182],{"class":172},[163,367,252],{"class":210},[163,369,255],{"class":198},[163,371,372,374,376,378],{"class":165,"line":258},[163,373,261],{"class":169},[163,375,182],{"class":172},[163,377,266],{"class":185},[163,379,380],{"class":198}," # 無干擾模式，簡單來講就是當有人留言時不去吵你。\n",[163,382,383,385,387,389],{"class":165,"line":272},[163,384,275],{"class":169},[163,386,182],{"class":172},[163,388,280],{"class":210},[163,390,283],{"class":198},[163,392,394,397,399],{"class":165,"line":393},10,[163,395,396],{"class":169},"  labels",[163,398,182],{"class":172},[163,400,401],{"class":210},"Gitalk\n",[16,403,404],{},[70,405],{"alt":301,"src":406},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_21-23-48.png",[16,408,409],{},"此外 Gitalk 的程式碼片段是支援高亮的，所以如果你留言以下這樣",[16,411,412],{},[70,413],{"alt":414,"src":415},"程式碼高亮","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_21-23-09.png",[16,417,418],{},[70,419],{"alt":414,"src":420},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-04_21-23-19.png",[422,423,424],"style",{},"html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":33,"searchDepth":176,"depth":176,"links":426},[427,428,433,434,435],{"id":14,"depth":176,"text":14},{"id":21,"depth":176,"text":21,"childre