 2.0.0",[47,62,64],{"id":63},"next-版本","NexT 版本",[52,66,67],{},[55,68,69],{},"NexT: 7.1.0",[12,71,72],{"id":72},"事前準備",[16,74,75],{},"首先你必須對 Git、GitHub 以及 npm 有基礎的認識，如果你沒有 Git or npm 基礎，我會建議你看我先前寫的文章認識這些常用的基礎指令，這樣下面的指令你才不會覺得莫名其妙",[16,77,78],{},[79,80,82],"a",{"href":81},"\u002Fgit\u002F20190615\u002F1148594701\u002F","基礎 Git 指令",[16,84,85],{},[79,86,88],{"href":87},"\u002Fnodejs\u002F20190626\u002F1317979814\u002F","npm 安裝指令差異",[12,90,92],{"id":91},"_1進入-github-開啟-repo","1.進入 GitHub 開啟 Repo",[16,94,95],{},[22,96],{"alt":97,"src":98},"建立一個新的 Repository","https:\u002F\u002Fimgur.com\u002F0GzpwOm.png",[16,100,101],{},"Repository Name 輸入:",[33,103,106],{"className":104,"code":105,"language":38,"meta":39},[36],"自己名稱.github.io\n",[41,107,105],{"__ignoreMap":39},[16,109,110,111,114],{},"另外請不要將部落格架設在資料夾內，例如我最近最常看到的架站方式就是 ",[41,112,113],{},"自己名稱.github.io\u002Fblog"," 這種方式架站會有極高的可能性遇到一些怪問題，以下都是目前有人跟我反應的",[52,116,117,120,123],{},[55,118,119],{},"CSS & JS 出現問題",[55,121,122],{},"文章無法正常顯示",[55,124,125],{},"第三方套件無法取得正確網址路徑\n...等等問題",[16,127,128,129,135],{},"所以強烈建議部落格建立在根目錄上就好，就像我的 ",[79,130,134],{"href":131,"rel":132},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhsiangfeng.github.io",[133],"nofollow","部落格"," 一樣，這樣子你可以少踩一點雷唷",[12,137,139],{"id":138},"_2安裝-hexo","2.安裝 Hexo",[16,141,142],{},"由於 Nexo 是使用指令安裝，所以要開啟 CMD (終端機) 來輸入以下指令",[33,144,148],{"className":145,"code":146,"language":147,"meta":39,"style":39},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","npm install hexo-cli -g\n","js",[41,149,150],{"__ignoreMap":39},[151,152,155,159,163,166,168],"span",{"class":153,"line":154},"line",1,[151,156,158],{"class":157},"s8XSl","npm install hexo",[151,160,162],{"class":161},"sOudu","-",[151,164,165],{"class":157},"cli ",[151,167,162],{"class":161},[151,169,170],{"class":157},"g\n",[16,172,173],{},[22,174],{"alt":175,"src":176},"hexo-cli 安裝","https:\u002F\u002Fi.imgur.com\u002F0eziTqZ.png",[16,178,179],{},"＊指令說明:透過 npm 在 全域 (-g) 下安裝 Hexo-Cli\n輸入完畢後大概等一下下就會安裝完畢了。",[12,181,183],{"id":182},"_3建立-hexo","3.建立 Hexo",[16,185,186],{},"首先建議先到你想建立的目錄再輸入，輸入以下指令 ( projectname 換成自己的名稱)",[33,188,192],{"className":189,"code":190,"language":191,"meta":39,"style":39},"language-cmd shiki shiki-themes github-light github-light github-dark-high-contrast","hexo init projectname\n","cmd",[41,193,194],{"__ignoreMap":39},[151,195,196],{"class":153,"line":154},[151,197,190],{},[16,199,200],{},"＊指令說明:初始化 (init) 建立 Hexo",[16,202,203],{},[22,204],{"alt":205,"src":206},"初始化 Hexo","https:\u002F\u002Fi.imgur.com\u002FglBzpwE.png",[12,208,210],{"id":209},"進入-hexo-目錄","進入 Hexo 目錄",[16,212,213],{},"建立完畢後則必須進入到剛剛建立的 Hexo 中，所以必須在終端機這樣輸入",[33,215,217],{"className":189,"code":216,"language":191,"meta":39,"style":39},"cd projectname\n",[41,218,219],{"__ignoreMap":39},[151,220,221],{"class":153,"line":154},[151,222,216],{},[16,224,225],{},[22,226],{"alt":227,"src":228},"移動目錄","https:\u002F\u002Fi.imgur.com\u002FiU8R1Wa.png",[16,230,231],{},"＊指令說明: cd 代表移動",[12,233,234],{"id":234},"安裝相依套件",[16,236,237],{},"由於建立完畢的 Hexo 還必須安裝 npm 相關套件，所以必須在這個目錄下輸入",[33,239,241],{"className":145,"code":240,"language":147,"meta":39,"style":39},"npm install\n",[41,242,243],{"__ignoreMap":39},[151,244,245],{"class":153,"line":154},[151,246,240],{"class":157},[16,248,249],{},"＊指令說明: 將 package.json 相依套件下載下來",[12,251,253],{"id":252},"啟動-hexo","啟動 Hexo",[16,255,256],{},"最後一步啟動 Hexo。",[33,258,260],{"className":189,"code":259,"language":191,"meta":39,"style":39},"hexo server\n",[41,261,262],{"__ignoreMap":39},[151,263,264],{"class":153,"line":154},[151,265,259],{},[16,267,268],{},[22,269],{"alt":253,"src":270},"https:\u002F\u002Fi.imgur.com\u002FrgU1woo.png",[12,272,273],{"id":273},"主題來源",[16,275,276,277],{},"我自已本身所使用的主題是 ",[79,278,281],{"href":279,"rel":280},"https:\u002F\u002Fgithub.com\u002Ftheme-next\u002Fhexo-theme-next",[133],"Next 7.1.0",[16,283,284],{},[22,285],{"alt":286,"src":287},"NexT 主題","https:\u002F\u002Fi.imgur.com\u002FTKPGkqF.png",[16,289,290,291],{},"另一個取