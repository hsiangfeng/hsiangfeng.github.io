[{"data":1,"prerenderedAt":403},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20200914\u002F3741834499\u002F":3,"page:\u002Fhexo\u002F20200914\u002F3741834499\u002F":4,"alt:\u002Fhexo\u002F20200914\u002F3741834499\u002F":3,"prev-next:\u002Fhexo\u002F20200914\u002F3741834499\u002F":382,"related:\u002Fhexo\u002F20200914\u002F3741834499\u002F":390},"\u002Fen\u002Fhexo\u002F2020\u002F09\u002F14\u002Flearn-hexo-01-intro\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":366,"date":367,"description":18,"extension":368,"lang":369,"meta":370,"navigation":371,"path":372,"readingMinutes":373,"seo":374,"standalone":375,"stem":376,"tags":377,"tldr":380,"updated":380,"url":133,"__hash__":381},"content\u002F試著學 Hexo\u002F1-試著學-Hexo-序章.md","(1) 試著學 Hexo - 序章","3741834499",{"type":9,"value":10,"toc":359},"minimark",[11,15,19,23,26,29,57,60,85,94,97,114,117,120,126,327,330,337,343,346,353],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"為什麼要寫這個系列文章呢？比起 Hexo 選擇現成的部落格平台，不是更適合嗎？其實選擇 Hexo 來當作你的第一個架站工具是非常好上手的，你只需要掌握一些基本知識就可以快速的架設，那麼廢話不多說，讓我們來開始「試著」從零開始學習架設自己的第一個部落格吧！",[12,20,22],{"id":21},"選擇-hexo-的原因","選擇 Hexo 的原因",[16,24,25],{},"前言有提到為什麼不選擇現成的部落格平台而是選擇 Hexo 當作第一個架站工具，這邊稍微解釋一下，其主要原因是現成的部落格平台往往自己的文章、SEO 以及版面等，其實都是掌握在平台手上，因此你也很難高度客製化自己的部落格，雖然平台會幫你解決許多問題，舉凡主機、網域以及 SEO 等等，但其實這樣子等於是把自己的生命掌握在他人手上呢！",[16,27,28],{},"那麼使用 Hexo 有什麼好處呢？我這邊簡單舉例三個",[30,31,32,41,49],"ul",{},[33,34,35,36],"li",{},"部落格主題可以客製化\n",[30,37,38],{},[33,39,40],{},"＊但需掌握一定技術量。",[33,42,43,44],{},"流量可以自己決定\n",[30,45,46],{},[33,47,48],{},"＊只要懂一些基本操作或是適當加入關鍵字，也可以有相當不錯的流量。",[33,50,51,52],{},"文章掌握在自己手上\n",[30,53,54],{},[33,55,56],{},"＊假使第三方平台收掉或是變更也比較不怕辛苦寫的文章遺失。",[16,58,59],{},"這邊額外列幾個使用 Hexo 架設的網站。",[30,61,62,71,78],{},[33,63,64],{},[65,66,70],"a",{"href":67,"rel":68},"https:\u002F\u002Fvuejs.org\u002F",[69],"nofollow","Vue.js",[33,72,73],{},[65,74,77],{"href":75,"rel":76},"https:\u002F\u002Fckeditor.com\u002F",[69],"CKEditor",[33,79,80],{},[65,81,84],{"href":82,"rel":83},"https:\u002F\u002Fsocket.io\u002F",[69],"Socket.IO",[16,86,87,88,93],{},"甚至",[65,89,92],{"href":90,"rel":91},"https:\u002F\u002Fwww.hexschool.com\u002F",[69],"六角學院","的官方網站也是使用 Hexo 製作的唷~ (這真的不是葉佩雯)",[16,95,96],{},"那 Hexo 看起來好處很多，難道沒有壞處嗎？當然有。",[30,98,99,102,105,108,111],{},[33,100,101],{},"必須找空間放網頁",[33,103,104],{},"必須學習指令操作",[33,106,107],{},"要購買網域",[33,109,110],{},"SEO 要自己想辦法",[33,112,113],{},"主題要慎選\n... 等等非常多",[16,115,116],{},"哎斗，看到這裡我相信你已經準備左轉登出，因此為了解決這些問題，所以我先在這邊列出我預計會撰寫的 Hexo 大綱",[12,118,119],{"id":119},"文章大綱",[121,122,123],"blockquote",{},[16,124,125],{},"目錄最後更新時間：2020\u002F10\u002F14",[127,128,129,135,141,147,153,159,165,171,177,183,189,195,201,207,213,219,225,231,237,243,249,255,261,267,273,279,285,291,297,303,309,315,321],"ol",{},[33,130,131],{},[65,132,134],{"href":133},"\u002Fhexo\u002F20200914\u002F3741834499\u002F","試著學 Hexo - 序章",[33,136,137],{},[65,138,140],{"href":139},"\u002Fhexo\u002F20200915\u002F1337908132\u002F","試著學 Hexo - 什麼是 Hexo?",[33,142,143],{},[65,144,146],{"href":145},"\u002Fhexo\u002F20200916\u002F4257870076\u002F","試著學 Hexo - 如何安裝 Hexo",[33,148,149],{},[65,150,152],{"href":151},"\u002Fhexo\u002F20200917\u002F636983586\u002F","試著學 Hexo - 認識 Hexo 目錄結構",[33,154,155],{},[65,156,158],{"href":157},"\u002Fhexo\u002F20200918\u002F1800712118\u002F","試著學 Hexo - 你的第一篇文章",[33,160,161],{},[65,162,164],{"href":163},"\u002Fhexo\u002F20200919\u002F55362084","試著學 Hexo - 不能忘記的 Hexo 指令",[33,166,167],{},[65,168,170],{"href":169},"\u002Fhexo\u002F20200920\u002F3533580288","試著學 Hexo - 如何安裝插件",[33,172,173],{},[65,174,176],{"href":175},"\u002Fhexo\u002F20200921\u002F849819598","試著學 Hexo - 你應該懂基本的 npm 指令",[33,178,179],{},[65,180,182],{"href":181},"\u002Fhexo\u002F20200922\u002F1947671490","試著學 Hexo - 圖片空間的挑選",[33,184,185],{},[65,186,188],{"href":187},"\u002Fhexo\u002F20200923\u002F2032860736","試著學 Hexo - 新增頁面",[33,190,191],{},[65,192,194],{"href":193},"\u002Fhexo\u002F20200924\u002F2892089216","試著學 Hexo - 部署你的第一個部落格",[33,196,197],{},[65,198,200],{"href":199},"\u002Fhexo\u002F20200925\u002F16