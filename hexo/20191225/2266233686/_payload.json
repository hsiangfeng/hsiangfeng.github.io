[{"data":1,"prerenderedAt":733},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20191225\u002F2266233686\u002F":3,"page:\u002Fhexo\u002F20191225\u002F2266233686\u002F":4,"alt:\u002Fhexo\u002F20191225\u002F2266233686\u002F":3,"prev-next:\u002Fhexo\u002F20191225\u002F2266233686\u002F":710,"related:\u002Fhexo\u002F20191225\u002F2266233686\u002F":719},"\u002Fen\u002Fhexo\u002F2019\u002F12\u002F25\u002Fswitch-hexo-next-to-algolia-search\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":694,"date":695,"description":18,"extension":696,"lang":697,"meta":698,"navigation":699,"path":700,"readingMinutes":701,"seo":702,"standalone":703,"stem":704,"tags":705,"tldr":707,"updated":707,"url":708,"__hash__":709},"content\u002FHexo\u002F將-Hexo-NexT-改成-Algolia-搜尋.md","將 Hexo NexT 改成 Algolia 搜尋","2266233686",{"type":9,"value":10,"toc":674},"minimark",[11,15,19,22,26,37,41,51,55,58,66,69,85,91,94,100,103,109,112,118,121,127,130,133,139,144,147,153,157,160,174,177,343,364,368,371,378,387,391,410,413,488,492,495,510,513,516,564,567,597,604,608,615,630,633,640,643,658,661,670],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近發現文章越來越肥大，而導致 search.json 越來越肥，所以打算換成另一種搜尋方法，也就是使用 Algolia 服務。",[12,20,21],{"id":21},"環境參考",[23,24,25],"h3",{"id":25},"版本與環境",[27,28,34],"pre",{"className":29,"code":31,"language":32,"meta":33},[30],"language-text","作業系統： Windows10 X64\nNodejs:：V11.7.0\nIDE：VS Code\n","text","",[35,36,31],"code",{"__ignoreMap":33},[23,38,40],{"id":39},"hexo-版本","Hexo 版本",[42,43,44,48],"ul",{},[45,46,47],"li",{},"hexo: 3.8.0",[45,49,50],{},"hexo-cli: 2.0.0",[12,52,54],{"id":53},"algolia","Algolia",[16,56,57],{},"在前面有講到因為文章數量變多，所以 search.json 很肥大 (2.72 MB 左右，看似很小，其實每次點搜尋都要加載大概一秒左右)，也因為這個問題在開啟搜尋時其實有點慢，所以我打算換成另一個線上搜尋服務，會寫這一篇文章是因為似乎很少有比較完整的教學，所以就順手寫下來了。",[16,59,60,61,65],{},"基本上 Algolia 免費帳號就非常好用，可以記錄 10,000 條文章記錄，每個月可以搜尋 100,000 次，基本上對於一般部落客來講算是非常足夠了(",[62,63,64],"del",{},"對我自己來講",")",[23,67,68],{"id":68},"申請",[16,70,71,72,78,79,84],{},"首先先打開 ",[73,74,53],"a",{"href":75,"rel":76},"https:\u002F\u002Fwww.algolia.com\u002F",[77],"nofollow"," 然後",[73,80,83],{"href":81,"rel":82},"https:\u002F\u002Fwww.algolia.com\u002Fusers\u002Fsign_up",[77],"登入","(上方類似開機的按鈕)，接下來這邊我就直接選 GitHub 登入",[16,86,87],{},[88,89],"img",{"alt":83,"src":90},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-25_17-10-13.png",[16,92,93],{},"接下來填寫相關資料",[16,95,96],{},[88,97],{"alt":98,"src":99},"相關資料","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F1577265178107.jpg",[16,101,102],{},"選擇數據中心，預設選香港就好了",[16,104,105],{},[88,106],{"alt":107,"src":108},"數據中心","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-25_16-42-25.png",[16,110,111],{},"接下來選擇你要使用的專案類型 (SaaS)，下拉選單則選擇「As soon as possible」，因為稍後就要使用了",[16,113,114],{},[88,115],{"alt":116,"src":117},"SaaS","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-25_17-23-35.png",[16,119,120],{},"完成後點一下「Go to dashboard」",[16,122,123],{},[88,124],{"alt":125,"src":126},"Go to dashboard","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-25_17-24-19.png",[23,128,129],{"id":129},"dashboard",[16,131,132],{},"進入 dashboard，它會要求你 「Create Index」",[16,134,135],{},[88,136],{"alt":137,"src":138},"Create Index","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-25_17-28-03.png",[16,140,141],{},[88,142],{"alt":137,"src":143},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F2019-12-25_17-29-43.png",[16,145,146],{},"新增完之後要來取得 API Keys，請複製 「Application ID」、「Search-Only API Key」以及「Admin API Key」",[16,148,149],{},[88,150],{"alt":151,"src":152},"API Keys","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FHexo\u002F1577266334891.jpg",[12,154,156],{"id":155},"安裝-hexo-algoliasearch","安裝 hexo-algoliasearch",[16,158,159],{},"接下來要安裝套件",[27,161,165],{"className":162,"code":163,"language":164,"meta":33,"style":33},"language-cmd shiki shiki-themes github-dark-high-contrast","npm install hexo-algoliasearch --save\n","cmd",[35,166,167],{"__ignoreMap":33},[168,169,172],"span",{"class":170,"line":171},"line",1,[168,173,163],{},[16,175,176],{},"然後在 Hexo 系統的 config 加入以下設置",[27,178,182],{"className":179,"code":180,"language":181,"meta":33,"style":33},"language-yml shiki shiki-themes github-dark-high-contrast","algolia:\n  appId: \"\" ## 剛剛複製的 API Keys，也就是 applicationID\n  applicationID: \"\" ## 剛剛複製的 API Keys，也就是 applicationID\n  apiKey: \"\" ## 剛剛複製的 API Keys\n  adminApiKey: \"\" ## 剛剛複製的 API Keys\n  chunkSize: 5000\n  indexName: \"是 Ray 不是 Array\"\n  fields:\n    - content:strip:truncate,0,500\n    - excerpt:strip\n    - gallery\n    - permalink\n    - photos\n    - slug\n    - tags\n    - title\n","yml",[35,183,184,193,210,222,235,247,259,270,278,287,295,303,311,319,327,335],{"__ignoreMap":33},[168,185,186,189],{"class":170,"line":171},[168,187,53],{"class":188},"sKpQp",[168,190,192],{"class":191},"sMAXC",":\n",[168,194,196,199,202,206],{"class":170,"line":195},2,[168,197,198],{"class":188},"  appId",[168,200,201],{"class":191},": ",[168,203,205],{"class":204},"sTRMh","\"\"",[168,207,209],{"class":208},"sQrFR"," ## 剛剛複製的 API Keys，也就是 applicationID\n",[168,211,213,216,218,220],{"class":170,"line":212},3,[168,214,215],{"class":188},"  applicationID",[168,217,201],{"class":191},[168,219,205],{"class":204},[168,221,209],{"class":208},[168,223,225,228,230,232],{"class":170,"line":224},4,[168,226,227],{"class":188},"  apiKey",[168,229,201],{"class":191},[168,231,205],{"class":204},[168,233,234],{"class":208}," ## 剛剛複製的 API Keys\n",[168,236,238,241,243,245],{"class":170,"line":237},5,[168,239,240],{"class":188},"  adminApiKey",[168,242,201],{"class":191},[168,244,205],{"class":204},[168,246,234],{"class":208},[168,248,250,253,255],{"class":170,"line":249},6,[168,251,252],{"class":188},"  chunkSize",[168,254,201],{"class":191},[168,256,258],{"class":257},"sCcAr","5000\n",[168,260,262,265,267],{"class":170,"line":261},7,[168,263,264],{"class":188},"  indexName",[168,266,201],{"class":191},[168,268,269],{"class":204},"\"是 Ray 不是 Array\"\n",[168,271,273,276],{"class":170,"line":272},8,[168,274,275],{"class":188},"  fields",[168,277,192],{"class":191},[168,279,281,284],{"class":170,"line":280},9,[168,282,283],{"class":191},"    - ",[168,285,286],{"class":204},"content:strip:truncate,0,500\n",[168,288,290,292],{"class":170,"line":289},10,[168,291,283],{"class":191},[168,293,294],{"class":204},"excerpt:strip\n",[168,296,298,300],{"class":170,"line":297},11,[168,299,283],{"class":191},[168,301,302],{"class":204},"gallery\n",[168,304,306,308],{"class":170,"line":305},12,[168,307,283],{"class":191},[168,309,310],{"class":204},"permalink\n",[168,312,314,316],{"class":170,"line":313},13,[168,315,283],{"class":191},[168,317,318],{"class":204},"photos\n",[168,320,322,324],{"class":170,"line":321},14,[168,323,283],{"class":191},[168,325,326],{"class":204},"slug\n",[168,328,330,332],{"class":170,"line":329},15,[168,331,283],{"class":191},[168,333,334],{"class":204},"tags\n",[168,336,338,340],{"class":170,"line":337},16,[168,339,283],{"class":191},[168,341,342],{"class":204},"title\n",[16,344,345,346,349,350,353,354,356,357,360,361,363],{},"其中會用兩次 ",[35,347,348],{},"appId","、",[35,351,352],{},"applicationID"," 的原因在於 NexT 整合的 algolia-instant-search 套件是吃 ",[35,355,348],{},"，但是 ",[35,358,359],{},"hexo-algoliasearch"," 吃的是 ",[35,362,352],{}," 所以才會寫兩次唷~",[12,365,367],{"id":366},"替模板安裝-algolia-instant-search-套件","替模板安裝 algolia-instant-search 套件",[16,369,370],{},"接下來要替 NexT 安裝擴展套件，否則 algolia 是無法正常運作的。",[16,372,373,374,377],{},"進入到主題的資料夾 (",[35,375,376],{},"cd theme\u002Fnext",") 然後輸入以下指令",[27,379,381],{"className":162,"code":380,"language":164,"meta":33,"style":33},"git clone https:\u002F\u002Fgithub.com\u002Ftheme-next\u002Ftheme-next-algolia-instant-search source\u002Flib\u002Falgolia-instant-search\n",[35,382,383],{"__ignoreMap":33},[168,384,385],{"class":170,"line":171},[168,386,380],{},[12,388,390],{"id":389},"next-config-開啟-algolia","Next Config 開啟 algolia",[16,392,393,394,397,398,401,402,405,406,409],{},"打開主題的 _config.yml，搜尋 ",[35,395,396],{},"algolia_search","，將 ",[35,399,400],{},"false"," 改為 ",[35,403,404],{},"true","，若本身先前有開啟 ",[35,407,408],{},"Local search"," 請也同時關閉。",[16,411,412],{},"底下有一些資訊可以順便調整，我自己是調整以下",[27,414,416],{"className":179,"code":415,"language":181,"meta":33,"style":33},"algolia_search:\n  enable: true\n  hits:\n    per_page: 10\n  labels:\n    input_placeholder: 搜尋文章 & 內容\n    hits_empty: \"找不到您輸入的關鍵字: ${query}\"\n    hits_stats: \"找到了 ${hits} 筆結果，花了 ${time} ms\"\n",[35,417,418,424,434,441,451,458,468,478],{"__ignoreMap":33},[168,419,420,422],{"class":170,"line":171},[168,421,396],{"class":188},[168,423,192],{"class":191},[168,425,426,429,431],{"class":170,"line":195},[168,427,428],{"class":188},"  enable",[168,430,201],{"class":191},[168,432,433],{"class":257},"true\n",[168,435,436,439],{"class":170,"line":212},[168,437,438],{"class":188},"  hits",[168,440,192],{"class":191},[168,442,443,446,448],{"class":170,"line":224},[168,444,445],{"class":188},"    per_page",[168,447,201],{"class":191},[168,449,450],{"class":257},"10\n",[168,452,453,456],{"class":170,"line":237},[168,454,455],{"class":188},"  labels",[168,457,192],{"class":191},[168,459,460,463,465],{"class":170,"line":249},[168,461,462],{"class":188},"    input_placeholder",[168,464,201],{"class":191},[168,466,467],{"class":204},"搜尋文章 & 內容\n",[168,469,470,473,475],{"class":170,"line":261},[168,471,472],{"class":188},"    hits_empty",[168,474,201],{"class":191},[168,476,477],{"class":204},"\"找不到您輸入的關鍵字: ${query}\"\n",[168,479,480,483,485],{"class":170,"line":272},[168,481,482],{"class":188},"    hits_stats",[168,484,201],{"class":191},[168,486,487],{"class":204},"\"找到了 ${hits} 筆結果，花了 ${time} ms\"\n",[12,489,491],{"id":490},"algolia-上傳索引","algolia 上傳索引",[16,493,494],{},"由於 algolia 比較麻煩不能自動上傳索引，所以每次若文章有更新還是要更新所以都必須先執行以下指令",[27,496,498],{"className":162,"code":497,"language":164,"meta":33,"style":33},"hexo clean\nhexo algolia\n",[35,499,500,505],{"__ignoreMap":33},[168,501,502],{"class":170,"line":171},[168,503,504],{},"hexo clean\n",[168,506,507],{"class":170,"line":195},[168,508,509],{},"hexo algolia\n",[12,511,512],{"id":512},"批量執行指令",[16,514,515],{},"為了解決這個問題，可以寫一些腳本來解決，例如 .bat",[27,517,521],{"className":518,"code":519,"language":520,"meta":33,"style":33},"language-js shiki shiki-themes github-dark-high-contrast","@echo off\ncd 'D:\\WelcomeWebWorld' \u002F\u002F 請輸入你的部落格專案路徑\nhexo clean\nhexo generate\nhexo algolia\nhexo deploy\n","js",[35,522,523,528,546,550,555,559],{"__ignoreMap":33},[168,524,525],{"class":170,"line":171},[168,526,527],{"class":191},"@echo off\n",[168,529,530,533,536,540,543],{"class":170,"line":195},[168,531,532],{"class":191},"cd ",[168,534,535],{"class":204},"'D:",[168,537,539],{"class":538},"sWyjQ","\\W",[168,541,542],{"class":204},"elcomeWebWorld'",[168,544,545],{"class":208}," \u002F\u002F 請輸入你的部落格專案路徑\n",[168,547,548],{"class":170,"line":212},[168,549,504],{"class":191},[168,551,552],{"class":170,"line":224},[168,553,554],{"class":191},"hexo generate\n",[168,556,557],{"class":170,"line":237},[168,558,509],{"class":191},[168,560,561],{"class":170,"line":249},[168,562,563],{"class":191},"hexo deploy\n",[16,565,566],{},"但是這邊其實我們可以利用 npm 特性來直接解決這個問題，打開 packages.json 加入以下指令即可",[27,568,572],{"className":569,"code":570,"language":571,"meta":33,"style":33},"language-json shiki shiki-themes github-dark-high-contrast","\"scripts\": {\n  \"start\": \"hexo clean && hexo generate && hexo algolia && hexo deploy\"\n},\n","json",[35,573,574,582,592],{"__ignoreMap":33},[168,575,576,579],{"class":170,"line":171},[168,577,578],{"class":204},"\"scripts\"",[168,580,581],{"class":191},": {\n",[168,583,584,587,589],{"class":170,"line":195},[168,585,586],{"class":188},"  \"start\"",[168,588,201],{"class":191},[168,590,591],{"class":204},"\"hexo clean && hexo generate && hexo algolia && hexo deploy\"\n",[168,593,594],{"class":170,"line":212},[168,595,596],{"class":191},"},\n",[16,598,599,600,603],{},"所以當我們要部屬 hexo 的時候只需要輸入 ",[35,601,602],{},"npm start"," 就可以一次批量完成指令囉~",[23,605,607],{"id":606},"意思","&& 意思",[16,609,610,611,614],{},"另外補充一下 ",[35,612,613],{},"&&"," 的意思",[42,616,617,624],{},[45,618,619,620,623],{},"一個 ",[35,621,622],{},"&"," 代表「同時執行」，",[45,625,626,627,629],{},"兩個 ",[35,628,613],{}," 代表「順序執行」意旨第一個執行完畢後才往下一個執行。",[12,631,632],{"id":632},"補充",[16,634,635,636,639],{},"過程可能會發生 ",[35,637,638],{},"algolia settings are invalid."," 的問題這部分有可能是套件少安裝又或者是忘記替主題擴展套件，也有可能是忘記在 Hexo 的 _config.yml 加入相關設置，基本上只要依照文章內操作，大致上問題應該是可以解決的。",[16,641,642],{},"提醒一下，由於 algolia 會使用到比較極機密的 Keys，所以會建議不要將部落格專案公開給別人或者是要替金鑰加密，重點是在於 adminApiKey 不要給別人。",[16,644,645,646,649,650,653,654,657],{},"最後請注意一定要先 ",[35,647,648],{},"hexo generate"," 後才能夠 ",[35,651,652],{},"hexo algolia"," 否則你將會一直出現 ",[35,655,656],{},"There is no post to index.","，而導致無法更新索引唷~",[12,659,660],{"id":660},"參考文獻",[42,662,663],{},[45,664,665],{},[73,666,669],{"href":667,"rel":668},"https:\u002F\u002Fchentging.github.io\u002F2018\u002F05\u002F16\u002Fhexo%EF%BC%9A%EF%BC%88%E4%B8%89%EF%BC%89hexo-Next-%E4%B8%BB%E9%A2%98%E9%85%8D%E7%BD%AE-%E8%A1%A5%E5%85%85-Algolia-%E6%90%9C%E7%B4%A2\u002F",[77],"hexo：（三）hexo Next 主题配置---补充---Algolia 搜索",[671,672,673],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html 