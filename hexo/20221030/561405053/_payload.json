[{"data":1,"prerenderedAt":349},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20221030\u002F561405053\u002F":3,"page:\u002Fhexo\u002F20221030\u002F561405053\u002F":4,"alt:\u002Fhexo\u002F20221030\u002F561405053\u002F":3,"prev-next:\u002Fhexo\u002F20221030\u002F561405053\u002F":326,"related:\u002Fhexo\u002F20221030\u002F561405053\u002F":335},"\u002Fen\u002Fhexo\u002F2022\u002F10\u002F30\u002Ffix-hexo-updated-date-on-ci-deploy\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":309,"date":310,"description":18,"extension":189,"lang":311,"meta":312,"navigation":285,"path":313,"readingMinutes":314,"seo":315,"standalone":316,"stem":317,"tags":318,"tldr":323,"updated":310,"url":324,"__hash__":325},"content\u002FHexo\u002F解決-Hexo-更新系統或使用-CI-部署後文章出現更新日期的問題.md","解決 Hexo 更新系統或使用 CI 部署後文章出現更新日期的問題","561405053",{"type":9,"value":10,"toc":304},"minimark",[11,15,19,22,25,28,36,42,45,48,56,75,153,156,176,182,185,197,204,211,294,300],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最新更新 Hexo 的時候發現一些問題就是文章莫名其妙通通全部被加上更新時間，因此這一篇記錄一下該如何解決這個問題，否則明明沒有更新的文章卻全部標記更新，這樣對於讀者來講會非常困擾。",[12,20,21],{"id":21},"事發原因",[16,23,24],{},"最近剛好在更新 Hexo",[16,26,27],{},"Hexo 5.4.0 -> Hexo 6.3.0\nNexT 8.5.0 -> Next 8.13.1",[16,29,30,31,35],{},"結果就發生了很奇怪的狀況，明明文章都沒有更新，但是在重新部署後卻會出現「",[32,33,34],"strong",{},"更新時間","」",[16,37,38],{},[39,40],"img",{"alt":34,"src":41},"https:\u002F\u002Fi.imgur.com\u002FvroWvL0.png",[16,43,44],{},"那這樣子對於讀者來講非常困擾，因為明明沒有更新的文章卻全部標記更新，所以這一篇就記錄一下問題原因以及怎麼解決。",[12,46,47],{"id":47},"解決方式",[16,49,50,51,55],{},"首先 Hexo 預設在抓取更新時間的方式是基於檔案的最後修改時間，那麼當我們更新系統時通常是直接將整個 ",[52,53,54],"code",{},"source"," 複製貼到新 Hexo 系統內，而這個行為對於檔案的最後修改時間就會造成影響，因此我們需要將這個功能關閉。",[16,57,58,59,62,63,66,67,70,71,74],{},"首先打開 Hexo 的 ",[52,60,61],{},"_config.yml"," 檔案，找到 ",[52,64,65],{},"updated_option"," 這個設定，將原本的 ",[52,68,69],{},"mtime"," 改成 ",[52,72,73],{},"date"," 即可。",[76,77,82],"pre",{"className":78,"code":79,"language":80,"meta":81,"style":81},"language-yml shiki shiki-themes github-dark-high-contrast","# Date \u002F Time format\n## Hexo uses Moment.js to parse and display date\n## You can customize the date format as defined in\n## http:\u002F\u002Fmomentjs.com\u002Fdocs\u002F#\u002Fdisplaying\u002Fformat\u002F\ndate_format: YYYY-MM-DD\ntime_format: HH:mm:ss\n## updated_option supports 'mtime', 'date', 'empty'\nupdated_option: 'date'\n","yml","",[52,83,84,93,99,105,111,126,137,143],{"__ignoreMap":81},[85,86,89],"span",{"class":87,"line":88},"line",1,[85,90,92],{"class":91},"sQrFR","# Date \u002F Time format\n",[85,94,96],{"class":87,"line":95},2,[85,97,98],{"class":91},"## Hexo uses Moment.js to parse and display date\n",[85,100,102],{"class":87,"line":101},3,[85,103,104],{"class":91},"## You can customize the date format as defined in\n",[85,106,108],{"class":87,"line":107},4,[85,109,110],{"class":91},"## http:\u002F\u002Fmomentjs.com\u002Fdocs\u002F#\u002Fdisplaying\u002Fformat\u002F\n",[85,112,114,118,122],{"class":87,"line":113},5,[85,115,117],{"class":116},"sKpQp","date_format",[85,119,121],{"class":120},"sMAXC",": ",[85,123,125],{"class":124},"sTRMh","YYYY-MM-DD\n",[85,127,129,132,134],{"class":87,"line":128},6,[85,130,131],{"class":116},"time_format",[85,133,121],{"class":120},[85,135,136],{"class":124},"HH:mm:ss\n",[85,138,140],{"class":87,"line":139},7,[85,141,142],{"class":91},"## updated_option supports 'mtime', 'date', 'empty'\n",[85,144,146,148,150],{"class":87,"line":145},8,[85,147,65],{"class":116},[85,149,121],{"class":120},[85,151,152],{"class":124},"'date'\n",[16,154,155],{},"這邊也列一個每個參數的意思",[157,158,159,165,170],"ul",{},[160,161,162,164],"li",{},[52,163,69],{},": 使用檔案最後修改時間",[160,166,167,169],{},[52,168,73],{},": 使用文章的日期",[160,171,172,175],{},[52,173,174],{},"empty",": 不顯示更新時間",[16,177,178,179,181],{},"那麼由於我們不可能不顯示更新時間，所以這邊會建議選擇 ",[52,180,73],{}," 這個選項。",[16,183,184],{},"接著你就會看到「更新時間」都消失了，但卻也延伸另一個問題，我們更新文章後無法出現「更新時間」，那麼解決這個問題的方式很簡單只需要在文章上方增加一個屬性",[76,186,190],{"className":187,"code":188,"language":189,"meta":81,"style":81},"language-md shiki shiki-themes github-dark-high-contrast","updated: \n","md",[52,191,192],{"__ignoreMap":81},[85,193,194],{"class":87,"line":88},[85,195,196],{"class":120},"updated:\n",[16,198,199,200,203],{},"未來你的文章若有更新時，就可以自己手動更改，雖然這個方式有點笨，但是卻也可以避免一些常見的問題，像是 CI 自動部署導致全部文章都顯示「更新時間」的問題，因為 CI 在運行時會先執行 ",[52,201,202],{},"git clone"," 指令，而這時候文章就會被拷貝建立，因此就會變成更新時間。",[16,205,206,207,210],{},"最後你也可以打開 Hexo 的 scaffold 檔案，將 ",[52,208,209],{},"updated"," 這個屬性加入到預設的文章中，這樣子未來你新增文章時就會自動加入這個屬性，以我的為舉例就會是如下",[76,212,214],{"className":187,"code":213,"language":189,"meta":81,"style":81},"---\ntitle: {{ title }}\ndate: {{ date }}\nupdated: {{ date }}\ntags:\ncategories:\ndescription:\n---\n\n## 前言\n",[52,215,216,221,234,244,254,262,269,276,280,287],{"__ignoreMap":81},[85,217,218],{"class":87,"line":88},[85,219,220],{"class":120},"---\n",[85,222,223,226,229,231],{"class":87,"line":95},[85,224,225],{"class":116},"title",[85,227,228],{"class":120},": {{ ",[85,230,225],{"class":124},[85,232,233],{"class":120}," }}\n",[85,235,236,238,240,242],{"class":87,"line":101},[85,237,73],{"class":116},[85,239,228],{"class":120},[85,241,73],{"class":124},[85,243,233],{"class":120},[85,245,246,248,250,252],{"class":87,"line":107},[85,247,209],{"class":116},[85,249,228],{"class":120},[85,251,73],{"class":124},[85,253,233],{"class":120},[85,255,256,259],{"class":87,"line":113},[85,257,258],{"class":116},"tags",[85,260,261],{"class":120},":\n",[85,263,264,267],{"class":87,"line":128},[85,265,266],{"class":116},"categories",[85,268,261],{"class":120},[85,270,271,274],{"class":87,"line":139},[85,272,273],{"class":116},"description",[85,275,261],{"class":120},[85,277,278],{"class":87,"line":145},[85,279,220],{"class":120},[85,281,283],{"class":87,"line":282},9,[85,284,286],{"emptyLinePlaceholder":285},true,"\n",[85,288,290],{"class":87,"line":289},10,[85,291,293],{"class":292},"s-VM4","## 前言\n",[16,295,296,297,299],{},"這樣子預設 ",[52,298,209],{}," 就會吃建立時間，而你的文章若有更新時，就可以自己手動更改。",[301,302,303],"style",{},"html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s-VM4, html code.shiki .s-VM4{--shiki-default:#91CBFF;--shiki-default-font-weight:bold}",{"title":81,"searchDepth":95,"depth":95,"links":305},[306,307,308],{"id":14,"depth":95,"text":14},{"id":21,"depth":95,"text":21},{"id":47,"depth":95,"text":47},"Hexo","2022-10-30 11:52:35","zh-Hant",{},"\u002Fhexo\u002Fhexo-ci","2",{"title":6,"description":18},false,"Hexo\u002F解決-Hexo-更新系統或使用-CI-部署後文章出現更新日期的問題",[309,319,320,321,322],"CI","Git","GitHub","障礙排除",null,"\u002Fhexo\u002F20221030\u002F561405053\u002F","SatwP2nnQNWCTuZEy6UAEdotxbsZEhO3-PdK2G_eBb8",{"newer":327,"older":331},{"url":328,"title":329,"date":330},"\u002Fgsap\u002F20221109\u002F986425046\u002F","(1)前端好好玩用 GSAP3 做一個特效 - 誰是 GSAP？","2022-11-09 08:23:00",{"url":332,"title":333,"date":334},"\u002Freact\u002F20221014\u002F3383337781\u002F","終究都要學 React 何不現在學呢？ - 鐵人賽後記 - 目錄 - (30)","2022-10-14 00:00:01",[336,341,345],{"url":337,"title":338,"date":339,"readingMinutes":340},"\u002Fhexo\u002F20201101\u002F60919\u002F","(33)試著學 Hexo-番外篇之更新 NexT 主題","2020-11-01 13:21:00","3",{"url":342,"title":343,"date":344,"readingMinutes":314},"\u002Fhexo\u002F20201031\u002F2194088152\u002F","(32)試著學 Hexo-番外篇之更新 Hexo","2020-10-31 14:01:51",{"url":346,"title":347,"date":348,"readingMinut