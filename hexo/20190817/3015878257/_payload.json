[{"data":1,"prerenderedAt":350},["ShallowReactive",2],{"header-locale:\u002Fhexo\u002F20190817\u002F3015878257\u002F":3,"page:\u002Fhexo\u002F20190817\u002F3015878257\u002F":4,"alt:\u002Fhexo\u002F20190817\u002F3015878257\u002F":3,"prev-next:\u002Fhexo\u002F20190817\u002F3015878257\u002F":326,"related:\u002Fhexo\u002F20190817\u002F3015878257\u002F":335},"\u002Fen\u002Fhexo\u002F2019\u002F08\u002F17\u002Fhexo-add-word-count\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":310,"date":311,"description":18,"extension":312,"lang":313,"meta":314,"navigation":315,"path":316,"readingMinutes":317,"seo":318,"standalone":319,"stem":320,"tags":321,"tldr":323,"updated":323,"url":324,"__hash__":325},"content\u002FHexo\u002F替-Hexo-增加字數統計.md","替 Hexo NexT 增加字數統計","3015878257",{"type":9,"value":10,"toc":299},"minimark",[11,15,19,22,27,37,41,46,49,56,97,101,104,176,183,186,190,193,199,204,283,286,289,295],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"有時候自己會需要翻一下自己某一篇文章寫得字數以及大約閱讀所需要的時間，所以這一篇就來記錄一下該如何替 Hexo NexT 安裝字數統計以及閱讀時間吧",[12,20,21],{"id":21},"本文撰寫環境",[23,24,26],"h3",{"id":25},"hexo-版本","Hexo 版本",[28,29,30,34],"ul",{},[31,32,33],"li",{},"hexo: 3.8.0",[31,35,36],{},"hexo-cli: 2.0.0",[23,38,40],{"id":39},"next-版本","NexT 版本",[28,42,43],{},[31,44,45],{},"NexT: 7.1.0",[12,47,48],{"id":48},"起手式",[16,50,51,52],{},"首先我們要先安裝一個外掛叫做 ",[53,54,55],"code",{},"hexo-symbols-count-time",[57,58,63],"pre",{"className":59,"code":60,"language":61,"meta":62,"style":62},"language-js shiki shiki-themes github-dark-high-contrast","npm install --save hexo-symbols-count-time\n","js","",[53,64,65],{"__ignoreMap":62},[66,67,70,74,78,81,84,87,89,92,94],"span",{"class":68,"line":69},"line",1,[66,71,73],{"class":72},"sMAXC","npm install ",[66,75,77],{"class":76},"sWyjQ","--",[66,79,80],{"class":72},"save hexo",[66,82,83],{"class":76},"-",[66,85,86],{"class":72},"symbols",[66,88,83],{"class":76},[66,90,91],{"class":72},"count",[66,93,83],{"class":76},[66,95,96],{"class":72},"time\n",[12,98,100],{"id":99},"修改-hexo-_config","修改 Hexo _config",[16,102,103],{},"接下來打開 Hexo 的站點配置 _config.yml，並將以下加入到最後",[57,105,109],{"className":106,"code":107,"language":108,"meta":62,"style":62},"language-yml shiki shiki-themes github-dark-high-contrast","symbols_count_time:\n # 文章是否顯示字數統計以及閱讀時間\n  symbols: true\n  time: true\n # 網頁底部是否顯示字數統計以及閱讀時間\n  total_symbols: true\n  total_time: true\n","yml",[53,110,111,120,127,140,150,156,166],{"__ignoreMap":62},[66,112,113,117],{"class":68,"line":69},[66,114,116],{"class":115},"sKpQp","symbols_count_time",[66,118,119],{"class":72},":\n",[66,121,123],{"class":68,"line":122},2,[66,124,126],{"class":125},"sQrFR"," # 文章是否顯示字數統計以及閱讀時間\n",[66,128,130,133,136],{"class":68,"line":129},3,[66,131,132],{"class":115},"  symbols",[66,134,135],{"class":72},": ",[66,137,139],{"class":138},"sCcAr","true\n",[66,141,143,146,148],{"class":68,"line":142},4,[66,144,145],{"class":115},"  time",[66,147,135],{"class":72},[66,149,139],{"class":138},[66,151,153],{"class":68,"line":152},5,[66,154,155],{"class":125}," # 網頁底部是否顯示字數統計以及閱讀時間\n",[66,157,159,162,164],{"class":68,"line":158},6,[66,160,161],{"class":115},"  total_symbols",[66,163,135],{"class":72},[66,165,139],{"class":138},[66,167,169,172,174],{"class":68,"line":168},7,[66,170,171],{"class":115},"  total_time",[66,173,135],{"class":72},[66,175,139],{"class":138},[16,177,178],{},[179,180],"img",{"alt":181,"src":182},"_config.yml","https:\u002F\u002Fi.imgur.com\u002FuOreQKl.png",[16,184,185],{},"接下來就可以直接重啟啦~",[12,187,189],{"id":188},"next-調整","NexT 調整",[16,191,192],{},"基本上如果你是使用 NexT 是不用修改模板的，因為本身就已經內建這個功能，只是需要安裝套件以及增加 symbols_count_time 設置而已。",[16,194,195,196,198],{},"如果你想要調整 NexT 的相關設置，只需要打開 NexT 的 _config.yml，然後搜尋 ",[53,197,116],{}," 就可以看到相關設置了",[16,200,201],{},[179,202],{"alt":116,"src":203},"https:\u002F\u002Fi.imgur.com\u002FuXQOYaU.png",[57,205,207],{"className":106,"code":206,"language":108,"meta":62,"style":62},"symbols_count_time:\n  separated_meta: true  # false 時只會顯示單行\n  item_text_post: true  # 若為 false 只會顯示圖標和數字，不會顯示所需閱讀時間&文章字數\n  item_text_total: true # footer 是否顯示 總字數文字與閱讀時間的文字\n  ## 以下我沒調整過，依照預設即可。\n  awl: 4 # 計算字數\n  wpm: 275 # 一分鐘閱讀的字數\n",[53,208,209,215,228,240,252,257,270],{"__ignoreMap":62},[66,210,211,213],{"class":68,"line":69},[66,212,116],{"class":115},[66,214,119],{"class":72},[66,216,217,220,222,225],{"class":68,"line":122},[66,218,219],{"class":115},"  separated_meta",[66,221,135],{"class":72},[66,223,224],{"class":138},"true",[66,226,227],{"class":125},"  # false 時只會顯示單行\n",[66,229,230,233,235,237],{"class":68,"line":129},[66,231,232],{"class":115},"  item_text_post",[66,234,135],{"class":72},[66,236,224],{"class":138},[66,238,239],{"class":125},"  # 若為 false 只會顯示圖標和數字，不會顯示所需閱讀時間&文章字數\n",[66,241,242,245,247,249],{"class":68,"line":142},[66,243,244],{"class":115},"  item_text_total",[66,246,135],{"class":72},[66,248,224],{"class":138},[66,250,251],{"class":125}," # footer 是否顯示 總字數文字與閱讀時間的文字\n",[66,253,254],{"class":68,"line":152},[66,255,256],{"class":125},"  ## 以下我沒調整過，依照預設即可。\n",[66,258,259,262,264,267],{"class":68,"line":158},[66,260,261],{"class":115},"  awl",[66,263,135],{"class":72},[66,265,266],{"class":138},"4",[66,268,269],{"class":125}," # 計算字數\n",[66,271,272,275,277,280],{"class":68,"line":168},[66,273,274],{"class":115},"  wpm",[66,276,135],{"class":72},[66,278,279],{"class":138},"275",[66,281,282],{"class":125}," # 一分鐘閱讀的字數\n",[12,284,285],{"id":285},"修改結果",[16,287,288],{},"那麼以下就是修改結果哩~",[16,290,291],{},[179,292],{"alt":293,"src":294},"沒想到我寫了 40 多萬字阿...","https:\u002F\u002Fi.imgur.com\u002FWqUMlay.png",[296,297,298],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki 