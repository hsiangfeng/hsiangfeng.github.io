[{"data":1,"prerenderedAt":21},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F7-1-%E8%A8%AD%E8%A8%88%E6%A8%A1%E5%BC%8F\u002F":3,"tag-page:zh-Hant:7-1-設計模式:1":4,"author-stats:zh-Hant:full":18},null,{"tag":5,"slug":6,"posts":7,"total":17,"totalPages":17},"7+1 設計模式","7-1-設計模式",[8],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fcss\u002F20200523\u002F116058774\u002F","淺談 CSS 設計模式系列-Sass 7-1 Pattern 篇","2020-05-23 21:00:52","CSS",[14,5,12],"CSS 設計模式","7+1 的設計模式主要是在講目錄結構的區分，早期開發 CSS 時只能將所有檔案放在同一個地方，那麼這樣就會導致維護上的困擾，因此在開發 Sass 時就可以搭配 @import 然後使用資料夾區分相關檔案，也就是所謂的 Sass 7-1 Pattern。","2",1,{"postCount":19,"tagCount":20},1035,1009,1784010309497]