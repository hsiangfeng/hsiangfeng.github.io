[{"data":1,"prerenderedAt":77},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FNode-js\u002Fpage\u002F2\u002F":3,"tag-page:zh-Hant:Node-js:2":4,"author-stats:zh-Hant:full":74},null,{"tag":5,"slug":6,"posts":7,"total":72,"totalPages":73},"Node.js","Node-js",[8,17,23,30,36,42,48,54,60,66],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fnodejs\u002F20231015\u002F3466588754\u002F","Day31 - 目錄與補充資源","2023-10-15 00:00:01","Nodejs",[5,14],"《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","今天打算做一個總結了，所以這一篇主要就以回顧的方式來做一個總結哩～","3",{"url":18,"title":19,"date":20,"updated":20,"category":12,"tags":21,"description":15,"readingMinutes":22},"\u002Fnodejs\u002F20231014\u002F27552363\u002F","Day30-旅途告一個段落","2023-10-14 00:00:01",[5,14],"2",{"url":24,"title":25,"date":26,"updated":26,"category":12,"tags":27,"description":28,"readingMinutes":29},"\u002Fnodejs\u002F20231013\u002F3280561145\u002F","Day29-關於 JWT 驗證","2023-10-13 00:00:01",[5,14],"接下來這一篇將會來介紹 JWT 的驗證，畢竟前面一直都沒提到，可是實戰上來講卻是非常重要的一環哩。","5",{"url":31,"title":32,"date":33,"updated":33,"category":12,"tags":34,"description":35,"readingMinutes":16},"\u002Fnodejs\u002F20231012\u002F3543796485\u002F","Day28-Google Extension 與 Google Apps Script 蹦再一起","2023-10-12 00:00:01",[5,14],"為了讓我們熟悉 Google Apps Script 的環境，那麼最快的方式就是實作，因此這邊就來整合 Google Extension 吧～",{"url":37,"title":38,"date":39,"updated":39,"category":12,"tags":40,"description":41,"readingMinutes":16},"\u002Fnodejs\u002F20231011\u002F1771923912\u002F","Day27-遇見 Google Apps Script","2023-10-11 00:00:01",[5,14],"OMG，這又是什麼新玩意了，接下來這一篇我們會稍微輕鬆一點來認識 Google Apps Script 是什麼東西，而且實戰上來講，也是非常的方便，因此我們就來看看 Google Apps Script 是什麼東西吧！",{"url":43,"title":44,"date":45,"updated":45,"category":12,"tags":46,"description":47,"readingMinutes":29},"\u002Fnodejs\u002F20231010\u002F3798507505\u002F","Day26-Google Extension 與 Vite","2023-10-10 00:00:01",[5,14],"前一篇我們對於 Google Extension 有了初步的認識，但我們實際開發上來講，必定會使用到人家開發好的套件，所以這一篇就會來使用 Vite 來開發 Google Extension。",{"url":49,"title":50,"date":51,"updated":51,"category":12,"tags":52,"description":53,"readingMinutes":16},"\u002Fnodejs\u002F20231009\u002F609773828\u002F","Day25-Google Extension","2023-10-09 00:00:01",[5,14],"又進入新的章節了，這章節我們要來介紹 Google Extension，那麼 Google Extension 是什麼呢？這一篇就讓我們來簡單的認識一下吧！",{"url":55,"title":56,"date":57,"updated":57,"category":12,"tags":58,"description":59,"readingMinutes":29},"\u002Fnodejs\u002F20231008\u002F2016996949\u002F","Day24-部署到 Zeabur","2023-10-08 00:00:01",[5,14],"前一面我們對於伺服器有基本概念後，接下來當然是要實際部署專案到伺服器上囉～",{"url":61,"title":62,"date":63,"updated":63,"category":12,"tags":64,"description":65,"readingMinutes":16},"\u002Fnodejs\u002F20231007\u002F3219221834\u002F","Day23 - 關於伺服器","2023-10-07 00:00:01",[5,14],"我們介紹了許多知識點，並且也將爬蟲整合進去 Discord Bot 中，但是實際上來講我們不可能都用本地端來啟動 Discord Bot，所以接下來將會來介紹一些關於伺服器與主機的知識點，所以這一篇會相對比較簡單，也算是讓腦袋放鬆一下。",{"url":67,"title":68,"date":69,"updated":69,"category":12,"tags":70,"description":71,"readingMinutes":29},"\u002Fnodejs\u002F20231006\u002F4255357825\u002F","Day22 - Discord Bot 整合","2023-10-06 00:00:01",[5,14],"前一篇對於 Discord 已經具有一定基礎後，當然要來做一點小東西了，當然不會太難，大多都是前面所寫過跟使用過的東西哩。",177,18,{"postCount":75,"tagCount":76},1035,1009,1784010311704]