[{"data":1,"prerenderedAt":80},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FNode-js\u002Fpage\u002F12\u002F":3,"tag-page:zh-Hant:Node-js:12":4,"author-stats:zh-Hant:full":77},null,{"tag":5,"slug":6,"posts":7,"total":75,"totalPages":76},"Node.js","Node-js",[8,17,24,31,38,45,51,57,63,69],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fnodejs\u002F20190708\u002F3972209423\u002F","全端勇士之路 Node.js 基礎學習-會員機制(4)","2019-07-08 10:40:48","Nodejs",[5,14],"全端勇士之路 Node.js","前面已經記錄了許多會員註冊 & 登入以及判定，但是如果今天不希望讓使用者直接透過網址列跳到 user 頁面呢?那麼就要使用到 middleware","1",{"url":18,"title":19,"date":20,"updated":3,"category":12,"tags":21,"description":22,"readingMinutes":23},"\u002Fnodejs\u002F20190708\u002F2743242184\u002F","全端勇士之路 Node.js 基礎學習-會員機制(3)","2019-07-08 10:12:15",[5,14],"上一章節已經大致上介紹登入時要使用哪個 API，後面就介紹了一下加入 Flash 及 欄位擴充，這章節就來認真講一下登入相關","2",{"url":25,"title":26,"date":27,"updated":3,"category":12,"tags":28,"description":29,"readingMinutes":30},"\u002Fnodejs\u002F20190707\u002F3130637449\u002F","全端勇士之路 Node.js 基礎學習-會員機制(2)","2019-07-07 20:46:58",[5,14],"在前面已經製作完註冊帳號得邏輯功能，所以接下來就是要做登入得功能","3",{"url":32,"title":33,"date":34,"updated":3,"category":12,"tags":35,"description":36,"readingMinutes":37},"\u002Fnodejs\u002F20190707\u002F2444554058\u002F","全端勇士之路 Node.js 基礎學習-會員機制(1)","2019-07-07 11:18:03",[5,14],"接下來將會來講如何設置會員機制，但是這邊將會使用到的是 firebase 的會員驗證機制","4",{"url":39,"title":40,"date":41,"updated":3,"category":12,"tags":42,"description":44,"readingMinutes":16},"\u002Fnodejs\u002F20190704\u002F184223391\u002F","解決使用 nodemailer 一直出現 Error: Invalid login: 534-5.7.14 問題","2019-07-04 22:30:43",[5,43],"障礙排除","在實作 Nodejs 使用 nodemailer 的時候一直跳 Invalid login 534-5.7.14，所以這邊紀錄一下該如何解決",{"url":46,"title":47,"date":48,"updated":3,"category":12,"tags":49,"description":50,"readingMinutes":23},"\u002Fnodejs\u002F20190704\u002F3969699783\u002F","全端勇士之路 Node.js 基礎學習-實作發送電子郵件並且部屬 HeroKu(3)","2019-07-04 21:42:22",[5,14],"接下來就是準備將自己寫好的發送信件應用部屬到 Heroku 囉",{"url":52,"title":53,"date":54,"updated":3,"category":12,"tags":55,"description":56,"readingMinutes":30},"\u002Fnodejs\u002F20190704\u002F4119330438\u002F","全端勇士之路 Node.js 基礎學習-實作發送電子郵件並且部屬 HeroKu(2)","2019-07-04 20:21:56",[5,14],"前面基本 UI 及 Rotue 已經建立完畢，所以現在就要來準備將剛剛安裝的套件給加入至 app.js 中",{"url":58,"title":59,"date":60,"updated":3,"category":12,"tags":61,"description":62,"readingMinutes":16},"\u002Fnodejs\u002F20190704\u002F3735727429\u002F","全端勇士之路 Node.js 基礎學習-實作發送電子郵件並且部屬 HeroKu(1)","2019-07-04 19:57:35",[5,14],"這一篇開始將會實作前面所學的電子郵件功能並且部屬到 Heroku",{"url":64,"title":65,"date":66,"updated":3,"category":12,"tags":67,"description":68,"readingMinutes":16},"\u002Fnodejs\u002F20190704\u002F2266633239\u002F","全端勇士之路 Node.js 基礎學習-後端傳送提示訊息","2019-07-04 19:42:01",[5,14],"有時候某些欄位會是透過後端傳送提示訊息過來，但是這些提示訊息通常只會顯示一次，所以這邊就會使用一個套件 connect-flash",{"url":70,"title":71,"date":72,"updated":3,"category":12,"tags":73,"description":74,"readingMinutes":23},"\u002Fnodejs\u002F20190704\u002F2336420619\u002F","全端勇士之路 Node.js 基礎學習-CSRF 篇","2019-07-04 16:03:36",[5,14],"CSRF 中文又稱為跨站請求偽造，這是一個非常常見的攻擊手法，如果沒有謹慎處理，是有可能導致系統掛掉的",177,18,{"postCount":78,"tagCount":79},1035,1009,1784010311661]