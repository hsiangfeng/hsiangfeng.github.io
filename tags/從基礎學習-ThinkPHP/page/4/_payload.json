[{"data":1,"prerenderedAt":24},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%BE%9E%E5%9F%BA%E7%A4%8E%E5%AD%B8%E7%BF%92-ThinkPHP\u002Fpage\u002F4\u002F":3,"tag-page:zh-Hant:從基礎學習-ThinkPHP:4":4,"author-stats:zh-Hant:full":21},null,{"tag":5,"slug":6,"posts":7,"total":19,"totalPages":20},"從基礎學習 ThinkPHP","從基礎學習-ThinkPHP",[8],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":17,"readingMinutes":18},"\u002Fphp\u002F20190902\u002F536097622\u002F","Day1-從基礎學習 ThinkPHP-介紹","2019-09-02 11:28:58","PHP",[12,14,15,5,16],"MySQL","ThinkPHP 5.1","第 11 屆 iT邦幫忙鐵人賽","ThinkPHP 算是比較少見的框架，我會挑選 ThinkPHP 當作是一個挑戰是因為先前有寫過(被打)，但是當時寫的版本是 3.2.4，而目前版本是 5.1，這段過程 ThinkPHP 其實有非常大的改變，光系統架構上就差非常多，那麼廢話就不多說讓我們從基礎來學習 ThinkPHP 5.1 吧!","3",31,4,{"postCount":22,"tagCount":23},1036,1011,1784087381630]