[{"data":1,"prerenderedAt":21},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E6%96%87%E5%AD%97%E5%B0%8D%E8%A9%B1%E8%97%9D%E8%A1%93\u002F":3,"tag-page:zh-Hant:文字對話藝術:1":4,"author-stats:zh-Hant:full":18},null,{"tag":5,"slug":5,"posts":6,"total":17,"totalPages":17},"文字對話藝術",[7],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fother\u002F20191028\u002F864994619\u002F","軟體工程師必學的文字對話藝術","2019-10-28 21:28:54","雜談",[13,14,5],"其他","軟體工程師","文字交流上其實有許多非常需要注意的事情，看似單純幾個中文字，但真正傳遞的感受是不同的，尤其是身為軟體工程師這個行業更不用說最常使用文字與他人溝通，所以這一篇將會來集中討論關於文字對話上的藝術。","5",1,{"postCount":19,"tagCount":20},1035,1009,1784020406905]