[{"data":1,"prerenderedAt":76},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript\u002Fpage\u002F27\u002F":3,"tag-page:zh-Hant:JavaScript:27":4,"author-stats:zh-Hant:full":73},null,{"tag":5,"slug":5,"posts":6,"total":71,"totalPages":72},"JavaScript",[7,14,19,26,34,41,47,54,60,66],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":12,"readingMinutes":13},"\u002Fjavascript\u002F20190530\u002F3821927811\u002F","JavaScript 非同步與同步事件之 async","2019-05-30 12:03:13",[5],"上一章節已經講完 await 後接下來當然是 async 啦，有同步就有非同步，所以這邊來記錄一下 async。","2",{"url":15,"title":16,"date":10,"updated":3,"category":5,"tags":17,"description":18,"readingMinutes":13},"\u002Fjavascript\u002F20190530\u002F2986904348\u002F","JavaScript 非同步與同步事件之 await",[5],"前面已經講解完 Promise 所以接下來就是講 async 與 await 是什麼東西，但是我會將這兩個東西拆開來講解做紀錄，首先先講講 await。",{"url":20,"title":21,"date":22,"updated":3,"category":5,"tags":23,"description":24,"readingMinutes":25},"\u002Fjavascript\u002F20190530\u002F3337676145\u002F","JavaScript 非同步與同步事件之 Promise","2019-05-30 10:30:13",[5],"async 與 await 是 JavaScript 中常見的東西，其中也與 Promise 也有關係，所以這邊也會先講一下 Promise 是什麼。","3",{"url":27,"title":28,"date":29,"updated":3,"category":30,"tags":31,"description":33,"readingMinutes":25},"\u002Fjsweirdworld\u002F20190527\u002F1292017914\u002F","[JS奇怪的世界]No.? 閉包番外篇","2019-05-27 13:50:04","克服JS奇怪的部分系列",[5,32],"JavaScript 全攻略:克服JS奇怪的部分","首先在前面已經有講過閉包這個東西，但是這個東西自己還是似懂非懂的，所以我將閉包這區塊給挪出來做一個番外篇紀錄。",{"url":35,"title":36,"date":37,"updated":3,"category":30,"tags":38,"description":39,"readingMinutes":40},"\u002Fjsweirdworld\u002F20190525\u002F3343743369\u002F","[JS奇怪的世界]No.68 JavaScript奇怪的部分","2019-05-25 16:36:00",[5,32],"終於結束 JavaScript 奇怪的部分也算是對自己有了一個交代，就是持續的學習，但是結束永遠代表著另一個開始，所以或許我會回頭在重新上一次將自己比較不清楚的地方挑出來特別做紀錄。","1",{"url":42,"title":43,"date":44,"updated":3,"category":30,"tags":45,"description":46,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190525\u002F1608378606\u002F","[JS奇怪的世界]No.67 增加jQuery的支援","2019-05-25 16:19:00",[5,32],"接下來就是要在我們所寫的框架中使用 jQuery。",{"url":48,"title":49,"date":50,"updated":3,"category":30,"tags":51,"description":52,"readingMinutes":53},"\u002Fjsweirdworld\u002F20190525\u002F2052051852\u002F","[JS奇怪的世界]No.66 屬性與可鏈結方法","2019-05-25 13:40:00",[5,32],"接下來將替 Greeter 新增一些功能增加一點屬性等等，所以也會設定一些基本設定進去 Greeter。","4",{"url":55,"title":56,"date":57,"updated":3,"category":30,"tags":58,"description":59,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190524\u002F3919196006\u002F","[JS奇怪的世界]No.65 我們的物件與其原型","2019-05-24 21:45:00",[5,32],"接下來要準備設定 Greeter 的物件，這樣子才能夠盡可能設定成類似 jQuery 的樣子，但是這需要一點訣竅。",{"url":61,"title":62,"date":63,"updated":3,"category":30,"tags":64,"description":65,"readingMinutes":40},"\u002Fjsweirdworld\u002F20190524\u002F3460524416\u002F","[JS奇怪的世界]No.63 需求","2019-05-24 21:30:00",[5,32],"在前面章節已經大致上瞭解 jQuery 之後當然就是要準備親手動手做做看自己的框架。",{"url":67,"title":68,"date":63,"updated":3,"category":30,"tags":69,"description":70,"readingMinutes":40},"\u002Fjsweirdworld\u002F20190524\u002F4036699386\u002F","[JS奇怪的世界]No.64 打造安全的程式",[5,32],"接下來我們需求弄好了，那就要來準備用安全的方式可以在任何的 JavaScript 環境下重複使用。",345,35,{"postCount":74,"tagCount":75},1036,1011,1784087376317]