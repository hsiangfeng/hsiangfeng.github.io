[{"data":1,"prerenderedAt":83},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript\u002Fpage\u002F34\u002F":3,"tag-page:zh-Hant:JavaScript:34":4,"author-stats:zh-Hant:full":80},null,{"tag":5,"slug":5,"posts":6,"total":78,"totalPages":79},"JavaScript",[7,16,23,33,39,45,52,58,65,72],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":14,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190515\u002F3276113437\u002F","[JS奇怪的世界]No.2 觀念小提醒:名稱 and 值配對與物件","2019-05-15 10:54:35","克服JS奇怪的部分系列",[5,13],"JavaScript 全攻略:克服JS奇怪的部分","簡單來講一個名稱只會配對一個唯一的值，觀念就像一個變數只會配一個值，而名稱可以被定義及變換值很多次，但是一般狀況下名稱只會對上一個值。","1",{"url":17,"title":18,"date":19,"updated":3,"category":11,"tags":20,"description":21,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190515\u002F2002773604\u002F","[JS奇怪的世界]No.1 觀念小提醒:語法解析器、執行環境、詞彙環境","2019-05-15 09:54:35",[5,13],"接下來將會開始一系列的 JS 奇怪的部分，主要是為了深入了解人稱世界上誤會最大的程式語言 JavaScript，也希望藉由這次的筆記能夠讓自己成長。","2",{"url":24,"title":25,"date":26,"updated":3,"category":27,"tags":28,"description":31,"readingMinutes":32},"\u002Fvue\u002F20190513\u002F948497494\u002F","Vuejs部屬GitHub Pages","2019-05-13 19:34:56","Vue",[5,27,29,30],"Git","GitHub","開發 Vue.js 結束後接下來就是部屬上 GitHub，這邊紀錄一下指令該如何部屬到 GitHub Pages 吧~","3",{"url":34,"title":35,"date":36,"updated":3,"category":5,"tags":37,"description":38,"readingMinutes":22},"\u002Fjavascript\u002F20190511\u002F638155277\u002F","JavaScript基礎閉包觀念","2019-05-11 18:51:54",[5],"JavaScript 中有一個閉包的觀念，滿時常聽人家在講閉包閉包，稍微查了一下相關文章這邊也做一下筆記。",{"url":40,"title":41,"date":42,"updated":3,"category":27,"tags":43,"description":44,"readingMinutes":22},"\u002Fvue\u002F20190510\u002F1766915506\u002F","props與emit的傳遞方式","2019-05-10 19:04:33",[5,27],"這幾天自己突然又開始使用 Vue 來製作一個小東西，因為我都是用 components 來製作，所以勢必要了解 props 與 emit 之間是如何傳遞的。",{"url":46,"title":47,"date":48,"updated":49,"category":27,"tags":50,"description":51,"readingMinutes":22},"\u002Fvue\u002F20190510\u002F86469050\u002F","Vue 的 @（小老鼠）符號是什麼？src 路徑別名與 .. 的差異","2019-05-10 10:30:35","2026-06-11 09:00:00",[5,27],"在 Vue 專案的 import 路徑常看到 @ 這個小老鼠符號，它其實是 Vue CLI 幫你設定好的 src 路徑別名（alias）。這篇講清楚 @ 跟相對路徑 .. 的差異，以及 Vue CLI 2 與 3 的設定位置在哪。",{"url":53,"title":54,"date":55,"updated":3,"category":27,"tags":56,"description":57,"readingMinutes":15},"\u002Fvue\u002F20190508\u002F40080850\u002F","vuejs(cli)中使用wowjs","2019-05-08 22:10:45",[5,27],"最近正在製作一個小作品，因為是使用 Vue Cli 開發，這邊紀錄一下該如何在 Vue Cli 中使用 WOWJS",{"url":59,"title":60,"date":61,"updated":3,"category":5,"tags":62,"description":63,"readingMinutes":64},"\u002Fjavascript\u002F20190507\u002F3500556123\u002F","JavaScript全域變數與區域變數的差別","2019-05-07 15:33:37",[5],"JavaScript 中真的滿多坑可以撲倒新手的，一個不小心就踩到地雷，所以這一篇來講講全域變數及區域變數的差異吧~","4",{"url":66,"title":67,"date":68,"updated":3,"category":5,"tags":69,"description":70,"readingMinutes":71},"\u002Fjavascript\u002F20190505\u002F1432256317\u002F","JavaScript 製作分頁功能(使用 Fetch APIs)","2019-05-05 15:06:43",[5],"開網站會很長需要使用到分頁的功能，有些是在後端處理之後往前端丟，這種通常比較不擔心那麼多，只需要在資料庫做好相關設置就好了，可是如果今天後端將所有資料一次往前端丟那麼就要自己來刻分頁邏輯，所以寫一篇文章加強自己的分頁邏輯撰寫。","7",{"url":73,"title":74,"date":75,"updated":3,"category":5,"tags":76,"description":77,"readingMinutes":32},"\u002Fjavascript\u002F20190426\u002F1966510488\u002F","關於 Array.prototype.sort() 排序這件不小的小事","2019-04-26 10:04:22",[5],"先前寫了一篇關於 JavaScript 陣列 20 種操作的方法，其中就有朋友對於 sort() 有點疑問不清楚原理，在被詢問時我自己也突然疑惑了一下，所以決定自己針對 sort() 來做一下研究了解原理。",345,35,{"postCount":81,"tagCount":82},1035,1009,1784020403376]