[{"data":1,"prerenderedAt":84},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript\u002Fpage\u002F18\u002F":3,"tag-page:zh-Hant:JavaScript:18":4,"author-stats:zh-Hant:full":81},null,{"tag":5,"slug":5,"posts":6,"total":79,"totalPages":80},"JavaScript",[7,18,27,33,39,48,54,60,66,72],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20200601\u002F1513414542\u002F","PixiJS V5 教學 (17) - Text+HP","2020-06-01 08:38:23",[12,13,5,14,15],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","前一篇我們學會如何製作血條，但是文字呢?所以這一篇就來介紹如何補上文字~","1",{"url":19,"title":20,"date":21,"updated":3,"category":5,"tags":22,"description":25,"readingMinutes":26},"\u002Fjavascript\u002F20200531\u002F3571534372\u002F","JavaScript 核心觀念(9)-執行環境與作用域-執行緒與同步、非同步","2020-05-31 22:09:11",[5,23,24],"JavaScript 核心篇","執行環境與作用域","這個章節開始是 JavaScript 中的重點觀念，也就是常見的 JavaScript 非同步、同步以及單執行緒的問題。","2",{"url":28,"title":29,"date":30,"updated":3,"category":5,"tags":31,"description":32,"readingMinutes":17},"\u002Fjavascript\u002F20200525\u002F1127214799\u002F","PixiJS V5 教學 (16) - Game HP","2020-05-25 09:00:08",[12,13,5,14,15],"前一篇開始我們開始有那麼一點像是在製作遊戲，所以接下來會來介紹一下遊戲中的血條該如何製作。",{"url":34,"title":35,"date":36,"updated":3,"category":5,"tags":37,"description":38,"readingMinutes":26},"\u002Fjavascript\u002F20200524\u002F995184384\u002F","JavaScript 核心觀念(8)-執行環境與作用域-記憶體存放與釋放","2020-05-24 10:56:06",[5,23,24],"接下來講一下記憶體的回收機制。",{"url":40,"title":41,"date":42,"updated":3,"category":43,"tags":44,"description":47,"readingMinutes":26},"\u002Fvue\u002F20200522\u002F1986801509\u002F","如何替 Vue Cli 加入 ESLint","2020-05-22 23:48:14","Vue",[5,43,45,46],"Vue Cli","ESLint","實際開發專案時我們為了確保程式碼的品質，通常都會加入程式碼風格管理器，也就是 ESLint，但在 Vue Cli 中該如何正確加入呢？",{"url":49,"title":50,"date":51,"updated":3,"category":5,"tags":52,"description":53,"readingMinutes":26},"\u002Fjavascript\u002F20200518\u002F1745009932\u002F","PixiJS V5 教學 (15) - Bump","2020-05-18 08:20:50",[12,13,5,14,15],"前一篇我們學習如何使用 PIXI 建立幾何圖形，那麼接下來要學習 PIXI 中一個我認為滿特別的東西，也就是碰撞檢測。",{"url":55,"title":56,"date":57,"updated":3,"category":5,"tags":58,"description":59,"readingMinutes":26},"\u002Fjavascript\u002F20200511\u002F1897499725\u002F","PixiJS V5 教學 (14) - Graphics(2)","2020-05-11 07:30:15",[12,13,5,14,15],"前一篇介紹了基本的幾何圖形的繪畫，但是只介紹矩形，其實 PIXI 還有其他幾何圖形的繪畫，所以接下來就來講其他的幾何圖形囉",{"url":61,"title":62,"date":63,"updated":3,"category":5,"tags":64,"description":65,"readingMinutes":26},"\u002Fjavascript\u002F20200510\u002F2581786882\u002F","JavaScript 核心觀念(7)-執行環境與作用域-not defined VS undefined","2020-05-10 21:27:11",[5,23,24],"not defined 以及 undefined 也是 JavaScript 中相當重要的觀念，若可以搞懂這兩者的差異，對於 debug 上是非常有幫助的。",{"url":67,"title":68,"date":69,"updated":3,"category":5,"tags":70,"description":71,"readingMinutes":26},"\u002Fjavascript\u002F20200504\u002F1045961354\u002F","PixiJS V5 教學 (13) - Graphics(1)","2020-05-04 08:10:50",[12,13,5,14,15],"接下來將會來介紹一點使用 PIXI 繪畫幾何圖形，最後會再來試著整合前面的技巧。",{"url":73,"title":74,"date":75,"updated":3,"category":5,"tags":76,"description":77,"readingMinutes":78},"\u002Fjavascript\u002F20200503\u002F1924910570\u002F","JavaScript 核心觀念(6)-執行環境與作用域-提升","2020-05-03 14:45:13",[5,23,24],"提升(Hoisting) 可以說是我最喜好的一個觀念，JavaScript 中舉凡函式、變數都有這個觀念存在。","3",345,35,{"postCount":82,"tagCount":83},1036,1011,1784087376211]