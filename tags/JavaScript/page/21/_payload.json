[{"data":1,"prerenderedAt":95},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript\u002Fpage\u002F21\u002F":3,"tag-page:zh-Hant:JavaScript:21":4,"author-stats:zh-Hant:full":92},null,{"tag":5,"slug":5,"posts":6,"total":90,"totalPages":91},"JavaScript",[7,17,24,35,42,48,54,63,76,84],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fvue\u002F20200214\u002F1055437216\u002F","一個指令快速部署 Vue Cli 到 GitHub Pages","2020-02-14 08:47:16","Vue",[5,11,13,14],"GitHub","Git","一般來說我們使用 Vue Cli 開發一個作品完畢之後都會需要部署到特定空間來展示作品，舉例來講 GitHub Pages 就是一個，那麼這一篇就來介紹該如何一個指令快速部署吧。","4",{"url":18,"title":19,"date":20,"updated":3,"category":11,"tags":21,"description":22,"readingMinutes":23},"\u002Fvue\u002F20200212\u002F3763656674\u002F","TypeError: this.getResolve is not a function","2020-02-12 08:53:36",[5,11],"最近剛好一些專案需求，所以會使用 Vue Cli2，但是在環境架設上突然發生一個錯誤，所以這一篇就來紀錄一下解決原因","1",{"url":25,"title":26,"date":27,"updated":3,"category":5,"tags":28,"description":33,"readingMinutes":34},"\u002Fjavascript\u002F20200210\u002F3949702627\u002F","PixiJS V5 教學 (1) - PixiJS 建立","2020-02-10 00:00:10",[29,30,5,31,32],"PixiJS V5 教學","PixiJS","Canvasgit","w3HexSchool","Pixi.js 是一款基於 JavaScript 的 2D 引擎所開發的框架，主要常見於開發 2D 網頁遊戲，接下來就來快速入門學習吧 :D","2",{"url":36,"title":37,"date":38,"updated":3,"category":5,"tags":39,"description":41,"readingMinutes":34},"\u002Fjavascript\u002F20200203\u002F3949702627\u002F","PixiJS V5 教學 (0) - 前言＆目錄","2020-02-03 08:36:41",[29,30,5,40,32],"Canvas","為什麼要寫一個 PixiJS V5 系列教學？這一篇是六角學院鼠年全馬鐵人挑戰的開頭文，聊聊我為什麼會踩進 PixiJS、適合用在哪些情境， 以及這個系列接下來會涵蓋哪些章節主題。",{"url":43,"title":44,"date":45,"updated":3,"category":5,"tags":46,"description":47,"readingMinutes":34},"\u002Fjavascript\u002F20200117\u002F3217748743\u002F","JavaScript 的 if 跟 switch 效能","2020-01-17 13:28:36",[5],"該使用 if 還是 switch 一直以來都是一個話題，所以這時候就來驗證一下這兩者差異以及效能上的差別。",{"url":49,"title":50,"date":51,"updated":3,"category":11,"tags":52,"description":53,"readingMinutes":23},"\u002Fvue\u002F20200116\u002F2632567429\u002F","Vue-Cli2 區域網路共享","2020-01-16 15:05:30",[5,11],"我們時常在開發的時候可能會需要與他人共享網頁畫面，但是在 Vue Cli 2 就需要特別設置一下，否則你無法透過區域網路共享給他人你的網頁。",{"url":55,"title":56,"date":57,"updated":3,"category":5,"tags":58,"description":61,"readingMinutes":62},"\u002Fjavascript\u002F20191209\u002F1271823341\u002F","世界上誤解最大的語言 JavaScript 之 JS 到底是同步與非同步語言?!","2019-12-09 10:38:53",[5,59,60],"Asynchronous","Synchronous","許多網路文章都可以看到大家都說 JavaScript 是一個非同步語言，但是經過一些事情觀念驗證後才發現，這個誤解可大了，所以這一篇就來講一下 JavaScript 到底是非同步語言還是同步語言。","3",{"url":64,"title":65,"date":66,"updated":3,"category":5,"tags":67,"description":74,"readingMinutes":75},"\u002Fjavascript\u002F20191119\u002F2727084611\u002F","有點長的淺談 JavaScript function 函式","2019-11-19 21:11:19",[5,68,69,70,71,72,11,73],"Function","Named Function","Anonymous Function","Arrow Function","IIFE","ES6","昨天在六角學院做了線上直播的介紹，過程真的是緊張到爆炸，我知道自己其實滿容易健忘的，所以不寫文章筆記心裡有點過意不去，因此這一篇 「有點長的淺談 JavaScript function 函式」就誕生了。","7",{"url":77,"title":78,"date":79,"updated":3,"category":5,"tags":80,"description":83,"readingMinutes":23},"\u002Fjavascript\u002F20191015\u002F2914844070\u002F","RE：從零開始的學習 JS 生活-番外篇之結尾心得","2019-10-15 00:00:05",[5,81,82],"RE：從零開始的學習 JS 生活","第 11 屆 iT邦幫忙鐵人賽","這一篇主要是講參賽結束的結尾心得。",{"url":85,"title":86,"date":87,"updated":3,"category":5,"tags":88,"description":89,"readingMinutes":34},"\u002Fjavascript\u002F20191015\u002F3030913854\u002F","EP.30 RE：從零開始的學習 JS 生活-第三十日-最後一日之函式建構子","2019-10-15 00:00:01",[5,81,82],"轉生第三十日，最後一天來稍微簡單補充一個東西，也就是關於 new 與函式建構子。",345,35,{"postCount":93,"tagCount":94},1035,1009,1784020403264]