[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript\u002Fpage\u002F8\u002F":3,"tag-page:zh-Hant:JavaScript:8":4,"author-stats:zh-Hant:full":78},null,{"tag":5,"slug":5,"posts":6,"total":76,"totalPages":77},"JavaScript",[7,16,26,33,39,45,51,57,63,69],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fjavascript\u002F20210914\u002F473800036\u002F","who is self?又跟 this 有何差異?","2021-09-14 15:12:01",[12,13,5],"self","this","實際開發上來講，其實是有機會看到這個單字，所以就來了解一下 self 是什麼以及它與 this 有何差異。","2",{"url":17,"title":18,"date":19,"updated":3,"category":20,"tags":21,"description":24,"readingMinutes":25},"\u002Fpython\u002F20210914\u002F50563447\u002F","從 JavaScript 角度學 Python(13) - 輸出入資料","2021-09-14 00:00:10","Python",[20,5,22,23],"從 JavaScript 角度學 Python","第 13 屆 iT邦幫忙鐵人賽","接下來講一點比較互動性質的東西，其實也是為了下一個章節鋪陳，不然我真的快沒梗了 QQ","4",{"url":27,"title":28,"date":29,"updated":3,"category":20,"tags":30,"description":31,"readingMinutes":32},"\u002Fpython\u002F20210913\u002F3862334805\u002F","從 JavaScript 角度學 Python(12) - 運算子","2021-09-13 00:00:10",[20,5,22,23],"運算子是一個非常常用的方式，因此在基礎觀念中也是絕對閃不了的。","5",{"url":34,"title":35,"date":36,"updated":3,"category":20,"tags":37,"description":38,"readingMinutes":32},"\u002Fpython\u002F20210912\u002F1574142266\u002F","從 JavaScript 角度學 Python(11) - 串列 20 種操作的方法","2021-09-12 00:00:10",[20,5,22,23],"前面簡單聊了字典與串列之後，接下來我想額外拉一篇輕鬆無負擔的章節來描述與紀錄一下關於 Python 的串列處理。",{"url":40,"title":41,"date":42,"updated":3,"category":20,"tags":43,"description":44,"readingMinutes":25},"\u002Fpython\u002F20210911\u002F2055044636\u002F","從 JavaScript 角度學 Python(10) - 容器型別(下)","2021-09-11 00:00:10",[20,5,22,23],"前一篇我們聊了一些字典有趣的取值方式，所以接下來我想接著繼續聊關於字典的部分。",{"url":46,"title":47,"date":48,"updated":3,"category":20,"tags":49,"description":50,"readingMinutes":25},"\u002Fpython\u002F20210910\u002F399833258\u002F","從 JavaScript 角度學 Python(9) - 容器型別(上)","2021-09-10 00:00:10",[20,5,22,23],"BMI 作業做得還好嗎？不知道你有沒有完成，但是這邊時間不等人，所以我們就接著聊聊下一個主題吧。",{"url":52,"title":53,"date":54,"updated":3,"category":20,"tags":55,"description":56,"readingMinutes":32},"\u002Fpython\u002F20210909\u002F656720009\u002F","從 JavaScript 角度學 Python(8) - BMI 計算(1)","2021-09-09 00:00:10",[20,5,22,23],"接下來這一篇算是收割前面幾個章節的章節小練習，基本上我是規劃每過幾個章節就有一些小作業，最主要是希望這個系列不只是學習 Python 而是希望透過實際一些小練習來讓加深印象。",{"url":58,"title":59,"date":60,"updated":3,"category":20,"tags":61,"description":62,"readingMinutes":32},"\u002Fpython\u002F20210908\u002F1210445172\u002F","從 JavaScript 角度學 Python(7) - 條件與迴圈","2021-09-08 00:00:10",[20,5,22,23],"接下來是聊條件與迴圈的部分，畢竟寫程式這兩個東西非常常使用到。",{"url":64,"title":65,"date":66,"updated":3,"category":20,"tags":67,"description":68,"readingMinutes":25},"\u002Fpython\u002F20210907\u002F3189637583\u002F","從 JavaScript 角度學 Python(6) - 變數作用域","2021-09-07 00:00:10",[20,5,22,23],"前一篇介紹了函式與變數，那麼接下來要來回頭補充一下關於前面所沒聊到的變數作用域。",{"url":70,"title":71,"date":72,"updated":3,"category":20,"tags":73,"description":74,"readingMinutes":75},"\u002Fpython\u002F20210906\u002F2707850273\u002F","從 JavaScript 角度學 Python(5) - 函式","2021-09-06 00:00:10",[20,5,22,23],"前一篇聊了關於型別與變數的部分，所以這一篇就閃不了要聊聊關於函式，函式對於許多新手來講是一個很痛的痛點，所以這一篇我也會分享一些什麼時候該用函式的簡單概念與如何練習。","6",345,35,{"postCount":79,"tagCount":80},1035,1009,1784020403431]