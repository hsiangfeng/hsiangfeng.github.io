[{"data":1,"prerenderedAt":84},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript\u002Fpage\u002F20\u002F":3,"tag-page:zh-Hant:JavaScript:20":4,"author-stats:zh-Hant:full":81},null,{"tag":5,"slug":5,"posts":6,"total":79,"totalPages":80},"JavaScript",[7,18,24,31,37,46,54,61,67,73],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20200323\u002F2334412373\u002F","PixiJS V5 教學 (7) - Ticker","2020-03-23 09:01:18",[12,13,5,14,15],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","前面已經學會引入圖片，那麼單純只是引入圖片有點無聊，所以來試著移動圖片吧~","2",{"url":19,"title":20,"date":21,"updated":3,"category":5,"tags":22,"description":23,"readingMinutes":17},"\u002Fjavascript\u002F20200316\u002F2334412373\u002F","PixiJS V5 教學 (6) - Texture(2)","2020-03-16 08:39:30",[12,13,5,14,15],"上一篇介紹了使用 new PIXI.Loader(); 的方式來渲染圖片，這一篇則會介紹另一種寫法。",{"url":25,"title":26,"date":27,"updated":3,"category":5,"tags":28,"description":30,"readingMinutes":17},"\u002Fjavascript\u002F20200313\u002F3743352418\u002F","淺談 JavaScript 中的 Debug 神器 Console","2020-03-13 10:51:48",[5,29],"console","在寫 JavaScript 時，其實我們會很長使用 console 來 debug，所以這一篇來淺談一下 console 吧。",{"url":32,"title":33,"date":34,"updated":3,"category":5,"tags":35,"description":36,"readingMinutes":17},"\u002Fjavascript\u002F20200309\u002F2684951958\u002F","PixiJS V5 教學 (5) - Texture","2020-03-09 08:15:00",[12,13,5,14,15],"有引入文字那麼就會有引入圖片啦~而 PIXI 會使用 GPU 以及 WebGL 來渲染圖片，而圖片需要經過處理才能夠使用的，而通常處理好的圖片都會稱為 Texture。",{"url":38,"title":39,"date":40,"updated":3,"category":5,"tags":41,"description":44,"readingMinutes":45},"\u002Fjavascript\u002F20200308\u002F3384986223\u002F","Fetch API 到底是 ESMAScript6 還是 Web APIs?","2020-03-08 12:07:26",[5,42,43],"ESMAScript6","Fetch API","Fetch API 是一個很多人會誤解的一個語法，最大誤解大概就是無法區分這一個語法到底是屬於 ECMAScript6 還是 Web APIs，所以這一篇來詳解一下吧。","3",{"url":47,"title":48,"date":49,"updated":3,"category":5,"tags":50,"description":53,"readingMinutes":45},"\u002Fjavascript\u002F20200307\u002F1405700237\u002F","JavaScript 核心觀念(1)-執行環境與作用域-JavaScript 運作方式","2020-03-07 21:37:04",[5,51,52],"JavaScript 核心篇","執行環境與作用域","第一篇將會來了解 JavaScript 的運作模式，",{"url":55,"title":56,"date":57,"updated":3,"category":5,"tags":58,"description":59,"readingMinutes":60},"\u002Fjavascript\u002F20200307\u002F318160061\u002F","JavaScript 核心觀念(0)-目錄及前言","2020-03-07 21:27:49",[5,51],"JavaScript 核心篇是基於六角學院的線上影音課程而撰寫的系列文章，雖然自己本身已經有上過 JavaScript 奇怪的部份，但每一位講者都有屬於他的講解方式，所以這一篇也來開始做一次紀錄以及學習囉。","4",{"url":62,"title":63,"date":64,"updated":3,"category":5,"tags":65,"description":66,"readingMinutes":17},"\u002Fjavascript\u002F20200302\u002F3104976087\u002F","PixiJS V5 教學 (4) - Text","2020-03-02 09:00:10",[12,13,5,14,15],"前一篇介紹了 Container，接下來要來看介紹前一篇所使用到的語法，也就是 new PIXI.Text()。",{"url":68,"title":69,"date":70,"updated":3,"category":5,"tags":71,"description":72,"readingMinutes":17},"\u002Fjavascript\u002F20200224\u002F4132682256\u002F","PixiJS V5 教學 (3) - Container","2020-02-24 08:17:13",[12,13,5,14,15],"前面基本知識也算是講得差不多，接下來將會介紹 PIXI 中的一個重要的東西，也就是 Container。",{"url":74,"title":75,"date":76,"updated":3,"category":5,"tags":77,"description":78,"readingMinutes":17},"\u002Fjavascript\u002F20200217\u002F4014508881\u002F","PixiJS V5 教學 (2) - WebGL 以及 Renderer","2020-02-17 00:05:28",[12,13,5,14,15],"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",345,35,{"postCount":82,"tagCount":83},1035,1009,1784012810577]