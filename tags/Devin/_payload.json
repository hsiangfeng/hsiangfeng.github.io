[{"data":1,"prerenderedAt":25},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FDevin\u002F":3,"tag-page:zh-Hant:Devin:1":4,"author-stats:zh-Hant:full":22},null,{"tag":5,"slug":5,"posts":6,"total":21,"totalPages":21},"Devin",[7],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":19,"readingMinutes":20},"\u002Fai\u002F20260410\u002F2748391056\u002F","AI Agent 不再是統稱了？認識 Coding Agent 與各類 AI Agent 的差異","2026-04-10 13:30:00","AI",[11,13,14,15,16,17,18,5],"AI Agent","Coding Agent","Code Agent","Claude Code","Cursor","GitHub Copilot","之前在介紹 AI 名詞的時候，AI Agent 就是一個統稱，泛指那些可以自己理解任務、拆解步驟、操作工具來完成事情的 AI 系統。可是到了 2026 年的現在，AI Agent 這個詞已經開始被進一步細分了，其中最成熟的子分類就是 Coding Agent（也有人叫 Code Agent）。這篇就來聊聊這些分類到底是怎麼回事，以及它們之間的差異。","5",1,{"postCount":23,"tagCount":24},1036,1011,1784087374444]