[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Ftags\u002Fw3HexSchool\u002Fpage\u002F4\u002F":3,"tag-page:zh-Hant:w3HexSchool:4":4,"author-stats:zh-Hant:full":76},null,{"tag":5,"slug":5,"posts":6,"total":74,"totalPages":75},"w3HexSchool",[7,18,25,31,37,43,49,55,61,67],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20200413\u002F360008009\u002F","PixiJS V5 教學(10) - 鍵盤控制","2020-04-13 08:40:22","JavaScript",[13,14,11,15,5],"PixiJS V5 教學","PixiJS","Canvas","接下來這一篇將會來介紹如何使用鍵盤來控制圖片，讓目前 PIXI 更像一個遊戲。","1",{"url":19,"title":20,"date":21,"updated":3,"category":11,"tags":22,"description":23,"readingMinutes":24},"\u002Fjavascript\u002F20200406\u002F213668506\u002F","PixiJS V5 教學 (9) - speeds","2020-04-06 08:30:23",[13,14,11,15,5],"接下來也是與圖片移動相關，但是這一次要介紹的是速度。","2",{"url":26,"title":27,"date":28,"updated":3,"category":11,"tags":29,"description":30,"readingMinutes":17},"\u002Fjavascript\u002F20200330\u002F363291611\u002F","PixiJS V5 教學 (8) - Ticker(2)","2020-03-30 08:20:14",[13,14,11,15,5],"前面終於讓圖片動起來了，接下來這一篇就輕鬆一點試著了解一下剛剛移動圖片的 API 還有哪些吧~",{"url":32,"title":33,"date":34,"updated":3,"category":11,"tags":35,"description":36,"readingMinutes":24},"\u002Fjavascript\u002F20200323\u002F2334412373\u002F","PixiJS V5 教學 (7) - Ticker","2020-03-23 09:01:18",[13,14,11,15,5],"前面已經學會引入圖片，那麼單純只是引入圖片有點無聊，所以來試著移動圖片吧~",{"url":38,"title":39,"date":40,"updated":3,"category":11,"tags":41,"description":42,"readingMinutes":24},"\u002Fjavascript\u002F20200316\u002F2334412373\u002F","PixiJS V5 教學 (6) - Texture(2)","2020-03-16 08:39:30",[13,14,11,15,5],"上一篇介紹了使用 new PIXI.Loader(); 的方式來渲染圖片，這一篇則會介紹另一種寫法。",{"url":44,"title":45,"date":46,"updated":3,"category":11,"tags":47,"description":48,"readingMinutes":24},"\u002Fjavascript\u002F20200309\u002F2684951958\u002F","PixiJS V5 教學 (5) - Texture","2020-03-09 08:15:00",[13,14,11,15,5],"有引入文字那麼就會有引入圖片啦~而 PIXI 會使用 GPU 以及 WebGL 來渲染圖片，而圖片需要經過處理才能夠使用的，而通常處理好的圖片都會稱為 Texture。",{"url":50,"title":51,"date":52,"updated":3,"category":11,"tags":53,"description":54,"readingMinutes":24},"\u002Fjavascript\u002F20200302\u002F3104976087\u002F","PixiJS V5 教學 (4) - Text","2020-03-02 09:00:10",[13,14,11,15,5],"前一篇介紹了 Container，接下來要來看介紹前一篇所使用到的語法，也就是 new PIXI.Text()。",{"url":56,"title":57,"date":58,"updated":3,"category":11,"tags":59,"description":60,"readingMinutes":24},"\u002Fjavascript\u002F20200224\u002F4132682256\u002F","PixiJS V5 教學 (3) - Container","2020-02-24 08:17:13",[13,14,11,15,5],"前面基本知識也算是講得差不多，接下來將會介紹 PIXI 中的一個重要的東西，也就是 Container。",{"url":62,"title":63,"date":64,"updated":3,"category":11,"tags":65,"description":66,"readingMinutes":24},"\u002Fjavascript\u002F20200217\u002F4014508881\u002F","PixiJS V5 教學 (2) - WebGL 以及 Renderer","2020-02-17 00:05:28",[13,14,11,15,5],"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",{"url":68,"title":69,"date":70,"updated":3,"category":11,"tags":71,"description":73,"readingMinutes":24},"\u002Fjavascript\u002F20200210\u002F3949702627\u002F","PixiJS V5 教學 (1) - PixiJS 建立","2020-02-10 00:00:10",[13,14,11,72,5],"Canvasgit","Pixi.js 是一款基於 JavaScript 的 2D 引擎所開發的框架，主要常見於開發 2D 網頁遊戲，接下來就來快速入門學習吧 :D",41,5,{"postCount":77,"tagCount":78},1035,1009,1784012813009]