[{"data":1,"prerenderedAt":78},["ShallowReactive",2],{"header-locale:\u002Ftags\u002Fw3HexSchool\u002F":3,"tag-page:zh-Hant:w3HexSchool:1":4,"author-stats:zh-Hant:full":75},null,{"tag":5,"slug":5,"posts":6,"total":73,"totalPages":74},"w3HexSchool",[7,18,24,31,37,43,49,55,61,67],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20201111\u002F331254690\u002F","PixiJS V5 教學 (40) - 終章","2020-11-11 09:09:43","JavaScript",[13,14,11,15,5],"PixiJS V5 教學","PixiJS","Canvas","這一篇是一整個 Pixi 的結尾，所以來做一個結尾吧。","1",{"url":19,"title":20,"date":21,"updated":3,"category":11,"tags":22,"description":23,"readingMinutes":17},"\u002Fjavascript\u002F20201102\u002F3342018158\u002F","PixiJS V5 教學 (39) - 音樂","2020-11-02 08:20:28",[13,14,11,15,5],"接下來這一篇來介紹開發一個遊戲非常重要的元素，也就是音樂。",{"url":25,"title":26,"date":27,"updated":3,"category":11,"tags":28,"description":29,"readingMinutes":30},"\u002Fjavascript\u002F20201031\u002F3727169327\u002F","PixiJS V5 教學 (38) - TexturePacker","2020-10-31 14:56:47",[13,14,11,15,5],"通常來講大多遊戲的素材都會將許多圖片放在一張大圖中，然後透過一個工具去生成 json 減少載入次數。","2",{"url":32,"title":33,"date":34,"updated":3,"category":11,"tags":35,"description":36,"readingMinutes":30},"\u002Fjavascript\u002F20201021\u002F1504709600\u002F","PixiJS V5 教學 (37) - 加入 stats.js","2020-10-21 15:25:20",[13,14,11,15,5],"接下來針對 stats.js 介紹一下，順便換一個範本作為參考會比較好，因為寶藏獵人其實所需要的效能問題看不太出來。",{"url":38,"title":39,"date":40,"updated":3,"category":11,"tags":41,"description":42,"readingMinutes":30},"\u002Fjavascript\u002F20201012\u002F1084963489\u002F","PixiJS V5 教學 (36) - FPS","2020-10-12 00:02:10",[13,14,11,15,5],"寶藏獵人我們也算是製作了一個段落，所以現在來講講 PIXI 一直在講的東西，也就是 FPS 吧。",{"url":44,"title":45,"date":46,"updated":3,"category":11,"tags":47,"description":48,"readingMinutes":30},"\u002Fjavascript\u002F20201005\u002F1803970914\u002F","PixiJS V5 教學 (35) - 優化細節","2020-10-05 08:25:53",[13,14,11,15,5],"最後這一篇來抓一下這個寶藏獵人還可以優化那些細節。",{"url":50,"title":51,"date":52,"updated":3,"category":11,"tags":53,"description":54,"readingMinutes":17},"\u002Fjavascript\u002F20200928\u002F1922914339\u002F","PixiJS V5 教學 (34) - 整合碰撞函數","2020-09-28 14:56:15",[13,14,11,15,5],"接下來這邊當冒險者碰到寶箱的時候，寶箱必須會跟著使用者移動，並接下來往門移動後就顯示過關成功。",{"url":56,"title":57,"date":58,"updated":3,"category":11,"tags":59,"description":60,"readingMinutes":17},"\u002Fjavascript\u002F20200921\u002F1037881060\u002F","PixiJS V5 教學 (33) - 製作怪物","2020-09-21 00:07:56",[13,14,11,15,5],"接下來我們要來製作怪物的部分，目前史萊姆只有一隻，所以要讓他變多且自動移動。",{"url":62,"title":63,"date":64,"updated":3,"category":11,"tags":65,"description":66,"readingMinutes":17},"\u002Fjavascript\u002F20200914\u002F617086885\u002F","PixiJS V5 教學 (32) - 重新開始製作","2020-09-14 08:40:30",[13,14,11,15,5],"這一篇稍微輕鬆鬆一點接續上一篇，所以這一篇就來製作重新開始遊戲的方法。",{"url":68,"title":69,"date":70,"updated":3,"category":11,"tags":71,"description":72,"readingMinutes":17},"\u002Fjavascript\u002F20200907\u002F267037798\u002F","PixiJS V5 教學 (31) - 文字訊息","2020-09-07 08:49:56",[13,14,11,15,5],"接下來我們要來製作一下當碰撞死亡後出現的文字訊息。",41,5,{"postCount":76,"tagCount":77},1035,1009,1784012812991]