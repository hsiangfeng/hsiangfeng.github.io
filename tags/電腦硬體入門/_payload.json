[{"data":1,"prerenderedAt":34},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E9%9B%BB%E8%85%A6%E7%A1%AC%E9%AB%94%E5%85%A5%E9%96%80\u002F":3,"tag-page:zh-Hant:電腦硬體入門:1":4,"author-stats:zh-Hant:full":31},null,{"tag":5,"slug":5,"posts":6,"total":29,"totalPages":30},"電腦硬體入門",[7,20],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":18,"readingMinutes":19},"\u002Flearnexp\u002F20250912\u002F676253939\u002F","【Day 12】第一次升級電腦：從被禁止上網咖到學會 HDD、SSD 與 RAM","2025-09-12 00:00:01","2026-05-07 21:00:00","學習經驗",[14,15,16,17,5],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","HDD SSD 差異","電腦升級教學","記憶體容量建議","從「不准上網咖」到接手舊電腦的升級實記：認識 HDD\u002FSSD 差異與介面、TBW 壽命觀念，補上 RAM 容量與頻率重點，附常見情境的容量建議，作為規劃升級的參考。","5",{"url":21,"title":22,"date":23,"updated":11,"category":12,"tags":24,"description":28,"readingMinutes":19},"\u002Flearnexp\u002F20250903\u002F827596012\u002F","【Day 3】主機板上的迷宮探險：打開電腦殼的第一次震撼教育","2025-09-03 00:00:01",[14,5,25,26,27],"主機板結構","Flash 遊戲回憶","Windows 98","我爸從公司搬了一台電腦回來，我人生的第一台電腦就此誕生。從興奮到摸不著頭緒，再到電腦壞掉，我第一次打開機殼，進入那個叫「主機板」的神祕世界——也開始理解電腦裡的內臟構造，從 CPU 到 RAM、從硬碟到電源供應器，每個零件都是我未來工程人生的起點。",2,1,{"postCount":32,"tagCount":33},1035,1009,1784012814551]