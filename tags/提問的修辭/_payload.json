[{"data":1,"prerenderedAt":34},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E6%8F%90%E5%95%8F%E7%9A%84%E4%BF%AE%E8%BE%AD\u002F":3,"tag-page:zh-Hant:提問的修辭:1":4,"author-stats:zh-Hant:full":31},null,{"tag":5,"slug":5,"posts":6,"total":29,"totalPages":30},"提問的修辭",[7,19],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":17,"readingMinutes":18},"\u002Flearnexp\u002F20211117\u002F407591854\u002F","提高你在社群上的提問技巧","2021-11-17 16:53:59","學習經驗",[13,5,14,15,16],"提問","提問的技巧","提問的智慧","社群","這一篇其實是「掌握提問的技巧，減少欠人教訓的提問」這一篇文章的延續版，主要是針對在社群上的提問，畢竟在社群上提問是非常常見的狀況。","5",{"url":20,"title":21,"date":22,"updated":23,"category":11,"tags":24,"description":27,"readingMinutes":28},"\u002Flearnexp\u002F20200112\u002F1752686187\u002F","來聊聊那些非常欠人教訓的提問 & 發問","2020-01-12 12:33:01","2023-01-05 20:52:38",[13,5,14,15,25,26],"欠人教訓的提問 & 發問","培養良好的提問與發問","身為一名工程師在開發上遇到問題並發問是一件非常常見的事情，但是許多人都會忽略所謂的「提問的智慧」，但是「該如何提問」卻又是一門學問甚至可以說是技能，當然更不用說有些人的提問方式真的真的非常欠人教訓以及翻白眼，所以今天就來分享一篇該如何提問會比較合適。","12",2,1,{"postCount":32,"tagCount":33},1035,1009,1784012813641]