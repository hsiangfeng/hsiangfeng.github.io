[{"data":1,"prerenderedAt":39},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%89%8D%E7%AB%AF%E6%A1%86%E6%9E%B6\u002F":3,"tag-page:zh-Hant:前端框架:1":4,"author-stats:zh-Hant:full":36},null,{"tag":5,"slug":5,"posts":6,"total":34,"totalPages":35},"前端框架",[7,24],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":22,"readingMinutes":23},"\u002Fai\u002F20260427\u002F1657384902\u002F","想開始 Vibe Coding？新手推薦先搞懂的這些基礎知識","2026-04-27 14:30:00","AI",[11,13,14,15,16,17,5,18,19,20,21],"Vibe Coding","Git","GitHub","VSCode","Terminal","UI Framework","Node.js","Prompt","新手入門","最近滿多朋友都跑來問我說「我也想用 AI 開發點東西，要從哪裡開始學？」，而這背後其實就是大家最近常聽到的 Vibe Coding。這一篇就來聊一下，新手如果想要踏入 Vibe Coding 的世界，到底有哪些基礎知識是推薦先搞懂的，例如 Git、命令列、UI Framework 等等，免得你做到一半才發現自己卡關卡到不知道該怎麼跟 AI 溝通。","12",{"url":25,"title":26,"date":27,"updated":27,"category":28,"tags":29,"description":32,"readingMinutes":33},"\u002Fjavascript\u002F20251208\u002F3781527973\u002F","一個時代的王者 jQuery，為什麼沒落了？","2025-12-08 21:35:24","JavaScript",[28,30,5,31],"jQuery","網頁開發","前陣子有人問了我一下，為什麼業界都比較多推薦使用 Vue、React、Angular 這些前端框架，而不是 jQuery 了？而他實際工作上還是會使用 jQuery，所以他很好奇這個現象背後的原因是什麼？於是我就寫了這篇文章來聊聊這個話題。","5",2,1,{"postCount":37,"tagCount":38},1035,1009,1784011735658]