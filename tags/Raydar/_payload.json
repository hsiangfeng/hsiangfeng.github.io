[{"data":1,"prerenderedAt":26},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FRaydar\u002F":3,"tag-page:zh-Hant:Raydar:1":4,"author-stats:zh-Hant:full":23},null,{"tag":5,"slug":5,"posts":6,"total":22,"totalPages":22},"Raydar",[7],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":20,"readingMinutes":21},"\u002Fother\u002F20260511\u002F5847291063\u002F","RSS 是什麼？為什麼 2026 年了還要用 RSS？順便聊聊我自己寫的 Chrome 擴充套件 Raydar","2026-05-11 14:00:00","雜談",[13,14,15,5,16,17,18,19],"RSS","Atom","RSS Reader","Chrome 擴充套件","訂閱","資訊管理","OPML","這篇從 RSS 是什麼、跟訂閱電子報差在哪裡、為什麼 2026 年了還值得用 RSS、跟演算法推送的差異、Atom 是什麼，一路聊到我自己寫了一個 Chrome RSS 閱讀器擴充套件 Raydar，包含 RSS 自動偵測、一鍵訂閱、三種閱讀模式、本地優先儲存、無帳戶、OPML 匯入匯出、JSON 備份、鍵盤快捷鍵等功能，最後也會說明怎麼裝跟為什麼會想自己刻一個。","7",1,{"postCount":24,"tagCount":25},1035,1009,1784020404316]