[{"data":1,"prerenderedAt":32},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E8%BB%9F%E9%AB%94%E5%B7%A5%E7%A8%8B%E5%B8%AB\u002F":3,"tag-page:zh-Hant:軟體工程師:1":4,"author-stats:zh-Hant:full":29},null,{"tag":5,"slug":5,"posts":6,"total":27,"totalPages":28},"軟體工程師",[7,18],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Fother\u002F20230626\u002F4076164354\u002F","博弈公司的工程師生活：揭開神秘面紗，機會與挑戰並存","2023-06-26 06:42:30","雜談",[13,14,5,15],"博弈公司","工程師","軟體開發","博弈產業是一個讓每個人充滿好奇的產業，因為它的神秘感及高薪水的特性，讓許多人對於這產業會感到特別的好奇，但是同時也讓許多人對於進入這個產業充滿的害怕與恐懼，為什麼呢？這一篇我就依照自己經歷以及身邊的朋友們的經驗來跟大家分享一下，希望能夠讓大家對於這個產業有更多的了解以及該如何挑選博弈產業的公司。","8",{"url":19,"title":20,"date":21,"updated":3,"category":11,"tags":22,"description":25,"readingMinutes":26},"\u002Fother\u002F20191028\u002F864994619\u002F","軟體工程師必學的文字對話藝術","2019-10-28 21:28:54",[23,5,24],"其他","文字對話藝術","文字交流上其實有許多非常需要注意的事情，看似單純幾個中文字，但真正傳遞的感受是不同的，尤其是身為軟體工程師這個行業更不用說最常使用文字與他人溝通，所以這一篇將會來集中討論關於文字對話上的藝術。","5",2,1,{"postCount":30,"tagCount":31},1035,1009,1784011736606]