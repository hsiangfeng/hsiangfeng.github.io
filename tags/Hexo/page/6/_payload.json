[{"data":1,"prerenderedAt":55},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FHexo\u002Fpage\u002F6\u002F":3,"tag-page:zh-Hant:Hexo:6":4,"author-stats:zh-Hant:full":52},null,{"tag":5,"slug":5,"posts":6,"total":50,"totalPages":51},"Hexo",[7,16,23,31,37,43],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fhexo\u002F20190514\u002F2072033203\u002F","Hexo搜尋引擎優化","2019-05-14 08:38:25",[5,12,13],"SEO","NexT","由於自己架設計部落格之後凡事都要自己來，所以這邊紀錄一下該如何加強 Hexo 的 SEO 部分。","3",{"url":17,"title":18,"date":19,"updated":3,"category":5,"tags":20,"description":21,"readingMinutes":22},"\u002Fhexo\u002F20190506\u002F2831397096\u002F","Hexo使用特殊符號sitemap會出現錯誤","2019-05-06 20:42:07",[5],"最近在調整 Hexo 的 SEO 時發現 sitemap 竟然出現錯誤?!","1",{"url":24,"title":25,"date":26,"updated":3,"category":27,"tags":28,"description":29,"readingMinutes":30},"\u002Fanalytics\u002F20190506\u002F1879363764\u002F","如何使用GA來替自己網站作分析","2019-05-06 15:42:13","Analytics",[27,5],"這一篇主要是被朋友推坑下來做撰寫得，所以這邊會介紹該如何埋入 Analytics，就是俗稱得 GA 分析，只要你有自己的網站、部落格，我推薦要使用 GA 分析，這可以讓自己了解到自己那些文章是屬於熱門文章。","2",{"url":32,"title":33,"date":34,"updated":3,"category":5,"tags":35,"description":36,"readingMinutes":22},"\u002Fhexo\u002F20190413\u002F2508191011\u002F","Hexo側邊欄修改","2019-04-13 13:32:30",[5],"Hexo 的側邊欄的修改大多都是在 _config.yml，這邊以 NexT 為例紀錄一下該如何增加頭像，如果要讓分類功能、標籤功能有效果則必須參考另一篇文章>Hexo新增標籤及分類頁面",{"url":38,"title":39,"date":40,"updated":3,"category":5,"tags":41,"description":42,"readingMinutes":22},"\u002Fhexo\u002F20190413\u002F1568146247\u002F","Hexo新增標籤及分類頁面","2019-04-13 13:06:39",[5],"由於標籤頁面及分類頁面必須由人工生成，所以這邊紀錄一下如何生成。",{"url":44,"title":45,"date":46,"updated":3,"category":5,"tags":47,"description":48,"readingMinutes":49},"\u002Fhexo\u002F20190411\u002F932826160\u002F","架設 Hexo+GitHub","2019-04-11 11:39:13",[5],"網路上已經有許多教學如何架設 Hexo+GitHub，但是因為自己本身要建設一個純技術 Blog，所以這邊就做一下紀錄該如何架設 Hexo 並佈署 GitHub。","4",56,6,{"postCount":53,"tagCount":54},1035,1009,1784010310917]