[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FHexo\u002Fpage\u002F5\u002F":3,"tag-page:zh-Hant:Hexo:5":4,"author-stats:zh-Hant:full":78},null,{"tag":5,"slug":5,"posts":6,"total":76,"totalPages":77},"Hexo",[7,15,22,31,37,44,50,56,62,69],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":13,"readingMinutes":14},"\u002Fhexo\u002F20190730\u002F884035779\u002F","Hexo 指令失效","2019-07-30 11:51:48",[5,12],"障礙排除","今天要準備撰寫文章的時候發生一個怪事，也就是 Hexo 的指令失效了，所以這一篇來記錄一下該如何解決","1",{"url":16,"title":17,"date":18,"updated":3,"category":5,"tags":19,"description":21,"readingMinutes":14},"\u002Fhexo\u002F20190717\u002F3365093327\u002F","Hexo SEO 優化小細節-關於 404 這件小事","2019-07-17 17:37:43",[5,20],"SEO","這一篇是特別獨立出來講一下其中一個 SEO 小細節的，其中就是關於 404 頁面",{"url":23,"title":24,"date":25,"updated":3,"category":5,"tags":26,"description":29,"readingMinutes":30},"\u002Fhexo\u002F20190703\u002F893132670\u002F","替 Hexo NexT 增加 Google AdSense","2019-07-03 11:56:01",[5,27,28],"NexT","AdSense","好久不見的 Hexo 改動文章，這次要來介紹如何申請 Google AdSense，但是主要會介紹如何修改及部分申請而已，因為我已經有申請過 Google AdSense 啦~","2",{"url":32,"title":33,"date":34,"updated":3,"category":5,"tags":35,"description":36,"readingMinutes":14},"\u002Fhexo\u002F20190616\u002F2530364388\u002F","hexo-generator-search 搜尋套件 & 問題","2019-06-16 15:48:32",[5],"基本上我們的 Hexo 主題都會使用到搜尋的套件，大多都會使用 hexo-generator-search 這邊紀錄一下一些優化的設置吧。",{"url":38,"title":39,"date":40,"updated":3,"category":5,"tags":41,"description":43,"readingMinutes":14},"\u002Fhexo\u002F20190518\u002F3303379172\u002F","Hexo Next 加入 FB 留言版","2019-05-18 10:07:05",[5,27,42],"FB Comment","首先必須要先建立應用程式 FB sdk。",{"url":45,"title":46,"date":47,"updated":3,"category":5,"tags":48,"description":49,"readingMinutes":14},"\u002Fhexo\u002F20190517\u002F1811593244\u002F","Hexo 壓縮相關檔案","2019-05-17 21:05:19",[5],"當 Hexo 寫到一定程度時速度會越來越慢，這時候可以嘗試做一些壓縮的動作，舉凡壓縮js、HTML等進而減少使用者要載入的時間。",{"url":51,"title":52,"date":53,"updated":3,"category":5,"tags":54,"description":55,"readingMinutes":14},"\u002Fhexo\u002F20190517\u002F2562079032\u002F","Hexo Url優化(SEO)","2019-05-17 10:05:19",[5,20],"由於 Hexo 本身 Url 的 SEO 狀況並不是設計非常漂亮，因為在 SEO 規範中文連結遠比英文連結差，所以這邊紀錄一下該如何使用。",{"url":57,"title":58,"date":59,"updated":3,"category":5,"tags":60,"description":61,"readingMinutes":14},"\u002Fhexo\u002F20190516\u002F2710757554\u002F","NexT分類與標籤頁不要有留言板(Disqus)","2019-05-16 11:09:29",[5,27],"雖然 NexT 模板是一個非常棒的模板，但是有些地方卻很奇怪，例如 tage 及 categories 竟然會出現 Disqus 留言版，所以這邊紀錄一下該如何修改 tage 及 categories 不要出現 Disqus 留言版。",{"url":63,"title":64,"date":65,"updated":3,"category":5,"tags":66,"description":68,"readingMinutes":30},"\u002Fhexo\u002F20190515\u002F3137769270\u002F","替Hexo加入像APP一樣的通知(推播)功能","2019-05-15 13:58:15",[5,67],"iZooto","由於我們部落格都會希望加入一個通知可以提醒使用者我的部落格文章更新囉~一般來講都是使用 RSS 方式，但是現階段手機很流行的情況下這邊就要用不同於 RSS 的作法來達到通知的效果。",{"url":70,"title":71,"date":72,"updated":3,"category":5,"tags":73,"description":74,"readingMinutes":75},"\u002Fhexo\u002F20190514\u002F1899427194\u002F","NexT 實用的設定與功能","2019-05-14 16:20:41",[5,27],"這邊紀錄一下我的 NexT 修改了那些地方及一些不錯的插件安裝。","3",56,6,{"postCount":79,"tagCount":80},1035,1009,1784012810241]