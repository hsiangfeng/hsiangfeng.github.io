[{"data":1,"prerenderedAt":35},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E8%A9%A6%E8%91%97%E5%AD%B8-Hexo\u002Fpage\u002F4\u002F":3,"tag-page:zh-Hant:試著學-Hexo:4":4,"author-stats:zh-Hant:full":32},null,{"tag":5,"slug":6,"posts":7,"total":30,"totalPages":31},"試著學 Hexo","試著學-Hexo",[8,17,23],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fhexo\u002F20200916\u002F4257870076\u002F","(3) 試著學 Hexo - 如何安裝 Hexo","2020-09-16 10:47:28","Hexo",[12,5,14],"第 12 屆 iT邦幫忙鐵人賽","接下來這一篇將會介紹兩種作業系統(Window、Mac)的安裝模式，但是後面的文章介紹與操作就會主要以 Mac 為主，基本上只有安裝的時候會稍微有一點不一樣而已，其餘後面的文章就沒有什麼太大差異。","3",{"url":18,"title":19,"date":20,"updated":3,"category":12,"tags":21,"description":22,"readingMinutes":16},"\u002Fhexo\u002F20200915\u002F1337908132\u002F","(2) 試著學 Hexo - 什麼是 Hexo","2020-09-15 00:00:10",[12,5,14],"在學習 Hexo 之前讓我們先了解一下 Hexo 是什麼以及它的來龍去脈。",{"url":24,"title":25,"date":26,"updated":3,"category":12,"tags":27,"description":28,"readingMinutes":29},"\u002Fhexo\u002F20200914\u002F3741834499\u002F","(1) 試著學 Hexo - 序章","2020-09-14 20:58:06",[12,5,14],"為什麼要寫這個系列文章呢？比起 Hexo 選擇現成的部落格平台，不是更適合嗎？其實選擇 Hexo 來當作你的第一個架站工具是非常好上手的，你只需要掌握一些基本知識就可以快速的架設，那麼廢話不多說，讓我們來開始「試著」從零開始學習架設自己的第一個部落格吧！","2",33,4,{"postCount":33,"tagCount":34},1035,1009,1784012814255]