[{"data":1,"prerenderedAt":43},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FCORS\u002F":3,"tag-page:zh-Hant:CORS:1":4,"author-stats:zh-Hant:full":40},null,{"tag":5,"slug":5,"posts":6,"total":38,"totalPages":39},"CORS",[7,17,30],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fnodejs\u002F20230407\u002F1216067379\u002F","Vite 中使用 Proxy 解決 CORS 問題","2023-04-07 10:37:57","Nodejs",[13,5,14,11],"Vite","Proxy","前端開發遇到 CORS 怎麼辦？這一篇整理 Vite 內建 Proxy 兩種寫法（純字串、選項物件）並比較差別，順便示範開發環境下如何把跨域請求轉成同源請求繞過瀏覽器限制。","3",{"url":18,"title":19,"date":20,"updated":3,"category":21,"tags":22,"description":28,"readingMinutes":29},"\u002Fother\u002F20200115\u002F1138566633\u002F","API 網站列表","2020-01-15 09:57:27","雜談",[23,5,24,25,26,27],"AJAX","GitHub","Slack","Imgur","OAuth","這是一份特別整理 API 網站列表，身為一名前端工程師，時常會為了製作一些小作品尋找 API 老半天，所以就稍微整理了一下有哪些 API 網站，也避免我自己的書籤列表一直爆滿，當然底下的 API 網站我並沒有每個都練習過以及使用過，所以僅僅只是列出來僅供參考而已。","2",{"url":31,"title":32,"date":33,"updated":3,"category":34,"tags":35,"description":37,"readingMinutes":29},"\u002Fjavascript\u002F20190617\u002F3829122039\u002F","使用 Google Apps Script 解決 CORS 問題","2019-06-17 13:24:47","JavaScript",[34,36,5],"Google Apps Script","前端打 API 遇到 CORS 又沒法改後端怎麼辦？這一篇從同源政策（Same-origin policy）的概念講起，用 Google Apps Script 包一層 Proxy 把第三方 API 變成你自己的同源 API， 繞過 CORS 限制。",3,1,{"postCount":41,"tagCount":42},1035,1009,1784011731948]