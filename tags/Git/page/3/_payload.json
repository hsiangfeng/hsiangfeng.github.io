[{"data":1,"prerenderedAt":61},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FGit\u002Fpage\u002F3\u002F":3,"tag-page:zh-Hant:Git:3":4,"author-stats:zh-Hant:full":58},null,{"tag":5,"slug":5,"posts":6,"total":56,"totalPages":57},"Git",[7,17,24,31,38,44,50],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fvue\u002F20200214\u002F1055437216\u002F","一個指令快速部署 Vue Cli 到 GitHub Pages","2020-02-14 08:47:16","Vue",[13,11,14,5],"JavaScript","GitHub","一般來說我們使用 Vue Cli 開發一個作品完畢之後都會需要部署到特定空間來展示作品，舉例來講 GitHub Pages 就是一個，那麼這一篇就來介紹該如何一個指令快速部署吧。","4",{"url":18,"title":19,"date":20,"updated":3,"category":5,"tags":21,"description":22,"readingMinutes":23},"\u002Fgit\u002F20190802\u002F1198998279\u002F","GitHub 重新命名分支名稱","2019-08-02 10:52:04",[14,5],"有時候我們在開發的時候會遇到需要重新命名 GitHub 分支，但是總不能用刪除分支的方式來做處理，這樣子會導致先前的 commit 紀錄都消失，所以就來記錄一下該如何重新命名分支並 push 到 GitHub 上吧","1",{"url":25,"title":26,"date":27,"updated":3,"category":5,"tags":28,"description":29,"readingMinutes":30},"\u002Fgit\u002F20190621\u002F4239571950\u002F","GitHub 發生衝突該如何解決","2019-06-21 16:35:09",[14,5],"當參加團隊專案開發的時候，其實很容易發生程式碼衝突問題，那這邊就來講一下該如何解除衝突吧~","2",{"url":32,"title":33,"date":34,"updated":3,"category":5,"tags":35,"description":36,"readingMinutes":37},"\u002Fgit\u002F20190615\u002F4143994266\u002F","GitHub 該如何發 PR(pull request)","2019-06-15 21:33:52",[14,5],"PR 是一個很特別的 GitHub 機制，當然 Gitlab 也有相同的機制，可是我這邊主要只會介紹使用 GitHub 如何發 PR 唷。","3",{"url":39,"title":40,"date":41,"updated":3,"category":5,"tags":42,"description":43,"readingMinutes":30},"\u002Fgit\u002F20190615\u002F1148594701\u002F","基礎 Git 指令","2019-06-15 13:59:25",[5],"這篇文章其實放在我的 EverNote 很久了，但是因為要整理一下 EverNote 特別拿出來重新寫一下作為一個紀錄，也是方便自己之後查找...",{"url":45,"title":46,"date":47,"updated":3,"category":5,"tags":48,"description":49,"readingMinutes":23},"\u002Fgit\u002F20190614\u002F391412804\u002F","fatal: unable to access XXx The requested URL returned error: 403","2019-06-14 21:38:14",[14,5],"今天在使用 Git Push 的時候發生一件很奇怪的事情，一直跳 remote Permission to xxx.git denied to user，這邊紀錄一下解決方法",{"url":51,"title":52,"date":53,"updated":3,"category":11,"tags":54,"description":55,"readingMinutes":37},"\u002Fvue\u002F20190513\u002F948497494\u002F","Vuejs部屬GitHub Pages","2019-05-13 19:34:56",[13,11,5,14],"開發 Vue.js 結束後接下來就是部屬上 GitHub，這邊紀錄一下指令該如何部屬到 GitHub Pages 吧~",27,3,{"postCount":59,"tagCount":60},1035,1009,1784020402587]