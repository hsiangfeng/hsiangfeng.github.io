[{"data":1,"prerenderedAt":23},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FMCP-Server\u002F":3,"tag-page:zh-Hant:MCP-Server:1":4,"author-stats:zh-Hant:full":20},null,{"tag":5,"slug":6,"posts":7,"total":19,"totalPages":19},"MCP Server","MCP-Server",[8],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":17,"readingMinutes":18},"\u002Fai\u002F20250522\u002F3579637231\u002F","GitHub Copilot + MCP Server 串接 VSCode 打造 AI 開發流程教學","2025-05-22 09:32:47","AI",[12,14,5,15,16],"GitHub Copilot","VSCode","開發流程","近代來講，AI 開發已經成為工程師必備的技能之一，但是我們在使用 AI 工具時，總是會遇到一些狀況，如：AI 回傳的內容不如預期，或是 AI 無法理解我們的需求，這些問題都會影響我們的開發效率，所以為了解決這個問題，MCP Server 應運而生。","3",1,{"postCount":21,"tagCount":22},1035,1009,1784013099950]