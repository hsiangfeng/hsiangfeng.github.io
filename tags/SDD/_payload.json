[{"data":1,"prerenderedAt":21},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FSDD\u002F":3,"tag-page:zh-Hant:SDD:1":4,"author-stats:zh-Hant:full":18},null,{"tag":5,"slug":5,"posts":6,"total":17,"totalPages":17},"SDD",[7],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fai\u002F20251202\u002F797714546\u002F","淺談 AI Vibe Coding 當今主流的 BDD 與 SDD","2025-12-02 22:48:14","AI",[11,13,14,5],"Vibe Coding","BDD","基本上只要你有使用過 AI 來開發任何一個產品或者功能，你應該或多或少都聽過 AI 程式碼生成等詞彙。在這裡，我將這種「直接用自然語言來描述功能，由 AI 生成程式碼」的模式，稱為「Vibe Coding (直覺式開發)」。","9",1,{"postCount":19,"tagCount":20},1035,1009,1784020404488]