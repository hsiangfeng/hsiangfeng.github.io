[{"data":1,"prerenderedAt":24},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E6%92%A5%E6%8E%A5%E4%B8%8A%E7%B6%B2\u002F":3,"tag-page:zh-Hant:撥接上網:1":4,"author-stats:zh-Hant:full":21},null,{"tag":5,"slug":5,"posts":6,"total":20,"totalPages":20},"撥接上網",[7],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":18,"readingMinutes":19},"\u002Flearnexp\u002F20250902\u002F267656909\u002F","【Day 2】第一次上網就沉迷！從史萊姆之家走進網路的世界","2025-09-02 00:00:01","2026-05-07 21:00:00","學習經驗",[14,15,5,16,17],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","網路啟蒙","史萊姆的第一個家","瀏覽器發展史","在我接觸電腦的初期，它只是一台「打開來能玩遊戲的盒子」。直到某一天，我遇到了一位臉超臭的大葛格，他讓我第一次看見電腦畫面上出現了和遊戲無關的東西——那是一個網站，叫做《史萊姆的第一個家》。","8",1,{"postCount":22,"tagCount":23},1035,1009,1784013103084]