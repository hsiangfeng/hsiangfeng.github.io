[{"data":1,"prerenderedAt":77},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FVue-%E5%87%BA%E4%B8%80%E5%80%8B%E5%A5%B3%E5%8F%8B%E5%90%A7\u002F":3,"tag-page:zh-Hant:Vue-出一個女友吧:1":4,"author-stats:zh-Hant:full":74},null,{"tag":5,"slug":6,"posts":7,"total":72,"totalPages":73},"Vue 出一個女友吧","Vue-出一個女友吧",[8,16,22,29,35,42,48,54,60,67],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":14,"readingMinutes":15},"\u002Fvue\u002F20190804\u002F3203626423\u002F","Vue 出一個女友吧!-前端頁面","2019-08-04 15:27:25","Vue",[12,5],"接下來將會開始紀錄前端頁面的開發，先來講講自己的開發習慣","1",{"url":17,"title":18,"date":19,"updated":3,"category":12,"tags":20,"description":21,"readingMinutes":15},"\u002Fvue\u002F20190801\u002F1336347183\u002F","Vue 出一個女友吧!-中場休息","2019-08-01 10:54:29",[12,5],"這一篇主要是紀錄目前做了哪些功能，所以並不會有太多技術性的東西",{"url":23,"title":24,"date":25,"updated":3,"category":12,"tags":26,"description":27,"readingMinutes":28},"\u002Fvue\u002F20190729\u002F4147561982\u002F","Vue 出一個女友吧!-上傳圖片","2019-07-29 16:36:59",[12,5],"這部分是屬於我忘記寫的地方(該打)，所以這一篇來補一下產品的圖片上傳","2",{"url":30,"title":31,"date":32,"updated":3,"category":12,"tags":33,"description":34,"readingMinutes":15},"\u002Fvue\u002F20190729\u002F371929708\u002F","Vue 出一個女友吧!-製作分頁邏輯-2","2019-07-29 16:17:31",[12,5],"從上一篇就可以了解到其實前端也是可以製作分頁邏輯的，但是會相當複雜，如果後端有做好相關的分頁邏輯 API 給前端那就會不一樣囉",{"url":36,"title":37,"date":38,"updated":3,"category":12,"tags":39,"description":40,"readingMinutes":41},"\u002Fvue\u002F20190729\u002F2401395670\u002F","Vue 出一個女友吧!-製作分頁邏輯-1","2019-07-29 09:47:57",[12,5],"接下來講講製作分頁邏輯的部分，好在本身 API 就已經有判斷分頁了","5",{"url":43,"title":44,"date":45,"updated":3,"category":12,"tags":46,"description":47,"readingMinutes":15},"\u002Fvue\u002F20190727\u002F3081561859\u002F","Vue 出一個女友吧!-組件溝通 event bus","2019-07-27 17:16:15",[12,5],"接下來將會講一個東西叫做組件溝通 event bus，可是我個人比較喜歡講成元件溝通就是了...那麼 event bus 會拿來做什麼呢?來記錄一下吧",{"url":49,"title":50,"date":51,"updated":3,"category":12,"tags":52,"description":53,"readingMinutes":15},"\u002Fvue\u002F20190726\u002F2706745772\u002F","Vue 出一個女友吧!-vue-fontawesome","2019-07-26 21:09:13",[12,5],"接下來講講其中一個套件，也就是 vue-fontawesome，在前面我們已經安裝了，但是該怎麼使用呢?來記錄一下吧",{"url":55,"title":56,"date":57,"updated":3,"category":12,"tags":58,"description":59,"readingMinutes":15},"\u002Fvue\u002F20190725\u002F335001087\u002F","Vue 出一個女友吧!-loading","2019-07-25 21:43:11",[12,5],"接下來要來替產品新增、修改以及刪除時增加一個 loading 特效，這樣子對於使用者體驗也會比較好，那這邊就會使用到 vue-loading-overlay",{"url":61,"title":62,"date":63,"updated":3,"category":12,"tags":64,"description":65,"readingMinutes":66},"\u002Fvue\u002F20190725\u002F1855985718\u002F","Vue 出一個女友吧!-產品頁面","2019-07-25 20:14:34",[12,5],"接下來是製作產品相關的 API，這邊將會講到商品建立、取得商品列表、修改商品以及刪除商品","3",{"url":68,"title":69,"date":70,"updated":3,"category":12,"tags":71,"description":69,"readingMinutes":66},"\u002Fvue\u002F20190725\u002F1960407570\u002F","Vue 出一個女友吧!-Login API","2019-07-25 16:16:05",[12,5],14,2,{"postCount":75,"tagCount":76},1036,1011,1784087378836]