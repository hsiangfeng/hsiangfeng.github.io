[{"data":1,"prerenderedAt":22},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E8%A6%8F%E6%A0%BC%E9%A9%85%E5%8B%95%E9%96%8B%E7%99%BC\u002F":3,"tag-page:zh-Hant:規格驅動開發:1":4,"author-stats:zh-Hant:full":19},null,{"tag":5,"slug":5,"posts":6,"total":18,"totalPages":18},"規格驅動開發",[7],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":16,"readingMinutes":17},"\u002Fvue\u002F20251106\u002F1172686218\u002F","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","2025-11-06 13:45:34","2026-04-23 13:45:34","Vue",[12,14,15,5],"SFC","AI 開發","許多開發者都會搭配著 AI 工具（Claude Code、Gemini、Copilot 等）來協助撰寫程式碼，而在 Vue 的單檔元件（Single File Component, SFC）中，常常會遇到一些困擾，所以這邊就來分享一個不同的做法，也就是自訂一個 &lt;spec lang=\"md\"&gt; 標籤，來讓我們能夠在 SFC 中更舒服地使用 AI 工具來開發。","6",1,{"postCount":20,"tagCount":21},1035,1009,1784020407529]