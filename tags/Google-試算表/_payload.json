[{"data":1,"prerenderedAt":22},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FGoogle-%E8%A9%A6%E7%AE%97%E8%A1%A8\u002F":3,"tag-page:zh-Hant:Google-試算表:1":4,"author-stats:zh-Hant:full":19},null,{"tag":5,"slug":6,"posts":7,"total":18,"totalPages":18},"Google 試算表","Google-試算表",[8],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":16,"readingMinutes":17},"\u002Fother\u002F20220211\u002F2705866340\u002F","用 Google Apps Script 搭配 Google 試算表開一個 API","2022-02-11 09:48:18","雜談",[14,5,15],"Google Apps Script","API","有時候我們會臨時需要開一個 API 來用，但是卻又不想自己開一個後端，例如像是 Koa、Express 或是 Laravel 等等框架，因為實在太麻煩，因此這時候就可以使用 Google Apps Script 服務來達到這個需求，其中也可以用 Google Apps Script 串接 Google 試算表，將 Google 試算表當作資料庫來使用。","5",1,{"postCount":20,"tagCount":21},1035,1009,1784012810096]