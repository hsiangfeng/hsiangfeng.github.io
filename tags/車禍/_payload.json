[{"data":1,"prerenderedAt":41},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E8%BB%8A%E7%A6%8D\u002F":3,"tag-page:zh-Hant:車禍:1":4,"author-stats:zh-Hant:full":38},null,{"tag":5,"slug":5,"posts":6,"total":36,"totalPages":37},"車禍",[7,17,23,30],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Flearnexp\u002F20250104\u002F3114456994\u002F","發生車禍了怎麼辦？ - 訴訟與和解 - 4","2025-01-04 11:00:53","2024-01-04 11:00:53","學習經驗",[5,14],"其他","儘管走上法院這一條並不是每個人願意的，但是有些是不得已必須依賴法院來解決，所以這一篇我將會來說明關於訴訟與和解的一些事情。","5",{"url":18,"title":19,"date":20,"updated":20,"category":12,"tags":21,"description":22,"readingMinutes":16},"\u002Flearnexp\u002F20241221\u002F1324056530\u002F","發生車禍了怎麼辦？ - 承認與求助 - 3","2024-12-21 14:18:53",[5,14],"前一篇文章中，我們認知到了車禍後可以做哪些事情，也特別在結尾提到了「調適」這件事，因為真正整個心情崩潰的與否會是在「初判表（道路交通事故初步分析研判表）」出來時...",{"url":24,"title":25,"date":26,"updated":26,"category":12,"tags":27,"description":28,"readingMinutes":29},"\u002Flearnexp\u002F20241208\u002F87858088\u002F","發生車禍了怎麼辦？ - 面對與調整 - 2","2024-12-08 15:51:29",[5,14],"在上一篇文章中，我們已經了解了發生車禍時該如何處理，接下來我將會說明在車禍後的一些事情，這些事情可能是你沒有想過的，但是卻是很重要的。","4",{"url":31,"title":32,"date":33,"updated":33,"category":12,"tags":34,"description":35,"readingMinutes":29},"\u002Flearnexp\u002F20241205\u002F2148986526\u002F","發生車禍了怎麼辦？ - 事故處理 - 1","2024-12-05 20:01:26",[5,14],"車禍不是每個人願意的，畢竟一場車禍除了財損之外也會導致人員的受傷，可以的話我們都會盡可能地去避免這件事情發生，但是事情總是無法完全掌控，所以當你遇到車禍時，我希望我這一篇文章可以幫助到你解決一些問題。",4,1,{"postCount":39,"tagCount":40},1036,1011,1784087383146]