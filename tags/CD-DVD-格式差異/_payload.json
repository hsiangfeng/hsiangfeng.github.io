[{"data":1,"prerenderedAt":25},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FCD-DVD-%E6%A0%BC%E5%BC%8F%E5%B7%AE%E7%95%B0\u002F":3,"tag-page:zh-Hant:CD-DVD-格式差異:1":4,"author-stats:zh-Hant:full":22},null,{"tag":5,"slug":6,"posts":7,"total":21,"totalPages":21},"CD DVD 格式差異","CD-DVD-格式差異",[8],{"url":9,"title":10,"date":11,"updated":12,"category":13,"tags":14,"description":19,"readingMinutes":20},"\u002Flearnexp\u002F20250908\u002F3148680987\u002F","【Day 8】作業交了沒？快點燒進光碟裡啊！","2025-09-08 00:00:01","2026-05-07 21:00:00","學習經驗",[15,16,5,17,18],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","光碟燒錄教學","儲存單位換算","復古儲存媒體","在 USB 還沒有普及的年代，我們主要儲存資料的方式都是使用光碟，也就是 CD、VCD 與 DVD 這種光碟盤片，這些光碟片的外觀就像是飛盤一樣，圓圓的，然後上面有一層反光的材質。在早期其實也時常會被當作飛盤來玩，畢竟它的外觀跟飛盤一樣。","5",1,{"postCount":23,"tagCount":24},1035,1009,1784020401629]