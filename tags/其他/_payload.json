[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%85%B6%E4%BB%96\u002F":3,"tag-page:zh-Hant:其他:1":4,"author-stats:zh-Hant:full":78},null,{"tag":5,"slug":5,"posts":6,"total":76,"totalPages":77},"其他",[7,17,23,30,36,42,48,57,63,69],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Flearnexp\u002F20250104\u002F3114456994\u002F","發生車禍了怎麼辦？ - 訴訟與和解 - 4","2025-01-04 11:00:53","2024-01-04 11:00:53","學習經驗",[14,5],"車禍","儘管走上法院這一條並不是每個人願意的，但是有些是不得已必須依賴法院來解決，所以這一篇我將會來說明關於訴訟與和解的一些事情。","5",{"url":18,"title":19,"date":20,"updated":20,"category":12,"tags":21,"description":22,"readingMinutes":16},"\u002Flearnexp\u002F20241221\u002F1324056530\u002F","發生車禍了怎麼辦？ - 承認與求助 - 3","2024-12-21 14:18:53",[14,5],"前一篇文章中，我們認知到了車禍後可以做哪些事情，也特別在結尾提到了「調適」這件事，因為真正整個心情崩潰的與否會是在「初判表（道路交通事故初步分析研判表）」出來時...",{"url":24,"title":25,"date":26,"updated":26,"category":12,"tags":27,"description":28,"readingMinutes":29},"\u002Flearnexp\u002F20241208\u002F87858088\u002F","發生車禍了怎麼辦？ - 面對與調整 - 2","2024-12-08 15:51:29",[14,5],"在上一篇文章中，我們已經了解了發生車禍時該如何處理，接下來我將會說明在車禍後的一些事情，這些事情可能是你沒有想過的，但是卻是很重要的。","4",{"url":31,"title":32,"date":33,"updated":33,"category":12,"tags":34,"description":35,"readingMinutes":29},"\u002Flearnexp\u002F20241205\u002F2148986526\u002F","發生車禍了怎麼辦？ - 事故處理 - 1","2024-12-05 20:01:26",[14,5],"車禍不是每個人願意的，畢竟一場車禍除了財損之外也會導致人員的受傷，可以的話我們都會盡可能地去避免這件事情發生，但是事情總是無法完全掌控，所以當你遇到車禍時，我希望我這一篇文章可以幫助到你解決一些問題。",{"url":37,"title":38,"date":39,"updated":39,"category":12,"tags":40,"description":41,"readingMinutes":29},"\u002Flearnexp\u002F20211008\u002F2688902488\u002F","關於學習的本質這件事","2021-10-08 21:26:49",[5,12],"學習真的是一件痛苦的事嗎？這一篇聊聊我對「學習本質」的觀察，包含為什麼大家容易陷入焦慮、怎麼判斷自己有沒有真的學會，以及怎麼把學習變成一件比較不那麼痛苦的事。",{"url":43,"title":44,"date":45,"updated":45,"category":12,"tags":46,"description":47,"readingMinutes":29},"\u002Flearnexp\u002F20200612\u002F341747575\u002F","入職後發現技術不足怎麼辦？","2020-06-12 22:06:31",[5,12],"這幾天有幾位類似相同境遇的學員來跟我小聊一下自己工作近況，話題大多都是關於「入職後發現自己技術完全跟不上，同事開會時也幫不上忙，是不是該離職了。」",{"url":49,"title":50,"date":51,"updated":3,"category":52,"tags":53,"description":56,"readingMinutes":16},"\u002Fother\u002F20191028\u002F864994619\u002F","軟體工程師必學的文字對話藝術","2019-10-28 21:28:54","雜談",[5,54,55],"軟體工程師","文字對話藝術","文字交流上其實有許多非常需要注意的事情，看似單純幾個中文字，但真正傳遞的感受是不同的，尤其是身為軟體工程師這個行業更不用說最常使用文字與他人溝通，所以這一篇將會來集中討論關於文字對話上的藝術。",{"url":58,"title":59,"date":60,"updated":60,"category":12,"tags":61,"description":62,"readingMinutes":29},"\u002Flearnexp\u002F20191020\u002F1606493563\u002F","2019 MOPCON 一日遊記","2019-10-20 18:02:46",[5,12],"由於 MOPCON 第一天有點事情所以只去第二天，這一篇就來記錄一下 MOPCON 第二天的一日遊吧。",{"url":64,"title":65,"date":66,"updated":66,"category":12,"tags":67,"description":68,"readingMinutes":16},"\u002Flearnexp\u002F20190930\u002F236119363\u002F","被車輪戰的六角同學會","2019-09-30 12:06:42",[5,12],"在 107\u002F09\u002F29 教師節當天六角學院舉辦了六角同學會，過程有一個自由聊天時間，所以這一篇就來記錄一下我被學員們車輪戰的過程吧(?!)",{"url":70,"title":71,"date":72,"updated":72,"category":12,"tags":73,"description":74,"readingMinutes":75},"\u002Flearnexp\u002F20190918\u002F2622329192\u002F","關於接案服務的這件事","2019-09-18 12:53:13",[5,12],"最近六角學院即將推出新服務，而這個服務本身就與我目前所做的事情有點關係，所以就寫這一篇文章來談談即將推出的新服務吧!","3",18,2,{"postCount":79,"tagCount":80},1035,1009,1784013102637]