[{"data":1,"prerenderedAt":64},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%85%B6%E4%BB%96\u002Fpage\u002F2\u002F":3,"tag-page:zh-Hant:其他:2":4,"author-stats:zh-Hant:full":61},null,{"tag":5,"slug":5,"posts":6,"total":59,"totalPages":60},"其他",[7,15,22,28,34,41,47,53],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":13,"readingMinutes":14},"\u002Flearnexp\u002F20190807\u002F1019052281\u002F","邀請講師的許多不小的小細節","2019-08-07 15:21:42","學習經驗",[5,11],"這一篇主要會記錄關於我邀請講師時，許多細節部分，因為大多時候我們都會忽略這些細節","5",{"url":16,"title":17,"date":18,"updated":18,"category":11,"tags":19,"description":20,"readingMinutes":21},"\u002Flearnexp\u002F20190723\u002F2343571780\u002F","關於寫部落格的心法","2019-07-23 21:14:06",[5,11],"最近都有人在詢問撰寫部落格到底對於自己求職 & 工作有沒有幫助，也有人問說該如何起手，所以我就稍微講一下我自己的寫部落格心法囉~","3",{"url":23,"title":24,"date":25,"updated":25,"category":11,"tags":26,"description":24,"readingMinutes":27},"\u002Flearnexp\u002F20190608\u002F1415931352\u002F","學習不要預設目標及未來","2019-06-08 16:53:43",[5,11],"2",{"url":29,"title":30,"date":31,"updated":31,"category":11,"tags":32,"description":33,"readingMinutes":27},"\u002Flearnexp\u002F20190509\u002F3880255625\u002F","適當的休息也是學習的一種方式","2019-05-09 22:18:55",[5,11],"這陣子準備一個小作品同時也不停地幫忙一些私下找我聊聊的朋友們，發現有很多朋友都有一種不太好的習慣，這邊分享一下經驗:D",{"url":35,"title":36,"date":37,"updated":37,"category":11,"tags":38,"description":39,"readingMinutes":40},"\u002Flearnexp\u002F20190503\u002F3738458215\u002F","該如何制定自己的學習","2019-05-03 09:53:55",[5,11],"今天又寫了一篇心得分享，主要原因出在先前所撰寫的三篇文章該如何正確的學習前端技術&程式語言、學習心態調整及你願意犧牲多少來得到你想要的事物，很多人都來詢問該如何學習及撰寫筆記這方面的問題，所以我也寫一下我提供的建議。","6",{"url":42,"title":43,"date":44,"updated":44,"category":11,"tags":45,"description":46,"readingMinutes":21},"\u002Flearnexp\u002F20190502\u002F4023370690\u002F","你願意犧牲多少來得到你想要的事物?","2019-05-02 10:24:41",[5,11],"許多時候我們都必須去作出選擇，先前六角學院的廖老師有分享過前端求職履歷面試全攻略的影音心得，其中裡面有講到你願意為了達到目標犧牲多少?",{"url":48,"title":49,"date":50,"updated":50,"category":11,"tags":51,"description":52,"readingMinutes":21},"\u002Flearnexp\u002F20190426\u002F43778186\u002F","學習時的心態調整","2019-04-26 15:35:12",[5,11],"最近在幫忙幾位朋友解決學習上的問題時，發現很常出現幾種問題，也跟自己當初的狀況很類似，所以就乾脆寫一下自己的心得分享...",{"url":54,"title":55,"date":56,"updated":56,"category":11,"tags":57,"description":58,"readingMinutes":14},"\u002Flearnexp\u002F20190416\u002F3782185665\u002F","該如何正確的學習前端技術或程式語言","2019-04-16 22:36:38",[5,11],"先講講為什麼我會寫這一篇文章，自從加入六角學院轉行走前端工程師，陸陸續續都有朋友、網友及同學等都來請教該如何像我一樣學習前端技術，我思考了好一陣子才決定寫這一篇文章作為經驗分享。",18,2,{"postCount":62,"tagCount":63},1035,1009,1784010313783]