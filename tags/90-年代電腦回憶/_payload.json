[{"data":1,"prerenderedAt":25},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F90-%E5%B9%B4%E4%BB%A3%E9%9B%BB%E8%85%A6%E5%9B%9E%E6%86%B6\u002F":3,"tag-page:zh-Hant:90-年代電腦回憶:1":4,"author-stats:zh-Hant:full":22},null,{"tag":5,"slug":6,"posts":7,"total":21,"totalPages":21},"90 年代電腦回憶","90-年代電腦回憶",[8],{"url":9,"title":10,"date":11,"updated":12,"category":13,"tags":14,"description":19,"readingMinutes":20},"\u002Flearnexp\u002F20250901\u002F2579876145\u002F","【Day 1】第一次聽見『嗶』，我的電腦世界就此展開","2025-09-01 00:00:01","2026-05-07 21:00:00","學習經驗",[15,16,17,18,5],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","電腦啟蒙","復古電腦遊戲","程式設計入門","你還記得第一次接觸電腦是什麼時候嗎？對我來說，那是一段帶點神祕、帶點禁忌，卻又讓我熱血沸騰的回憶。從第一次聽見電腦開機的「嗶」聲，到後來學會打開 MS-DOS、進入遊戲、修改 config.sys，我從一個愛玩電腦的孩子，走上了成為軟體工程師的道路。","7",1,{"postCount":23,"tagCount":24},1035,1009,1784020401324]