[{"data":1,"prerenderedAt":24},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%85%89%E7%A2%9F%E7%87%92%E9%8C%84%E6%95%99%E5%AD%B8\u002F":3,"tag-page:zh-Hant:光碟燒錄教學:1":4,"author-stats:zh-Hant:full":21},null,{"tag":5,"slug":5,"posts":6,"total":20,"totalPages":20},"光碟燒錄教學",[7],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":18,"readingMinutes":19},"\u002Flearnexp\u002F20250908\u002F3148680987\u002F","【Day 8】作業交了沒？快點燒進光碟裡啊！","2025-09-08 00:00:01","2026-05-07 21:00:00","學習經驗",[14,5,15,16,17],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","CD DVD 格式差異","儲存單位換算","復古儲存媒體","在 USB 還沒有普及的年代，我們主要儲存資料的方式都是使用光碟，也就是 CD、VCD 與 DVD 這種光碟盤片，這些光碟片的外觀就像是飛盤一樣，圓圓的，然後上面有一層反光的材質。在早期其實也時常會被當作飛盤來玩，畢竟它的外觀跟飛盤一樣。","5",1,{"postCount":22,"tagCount":23},1035,1009,1784010313733]