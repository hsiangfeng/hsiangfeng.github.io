[{"data":1,"prerenderedAt":90},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%AD%B8%E7%BF%92%E7%B6%93%E9%A9%97\u002F":3,"tag-page:zh-Hant:學習經驗:1":4,"author-stats:zh-Hant:full":87},null,{"tag":5,"slug":5,"posts":6,"total":85,"totalPages":86},"學習經驗",[7,16,28,38,47,54,60,67,73,79],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Flearnexp\u002F20241231\u002F998165636\u002F","AI 當道，為什麼我還是推薦寫部落格？","2024-12-31 11:00:25",[12,13,5],"AI","部落格","這幾天 WebConf 剛好有幾位學生來詢問我關於 AI 的事情，他認為 AI 已經非常的普及與當道，許多都資料都可以透過 AI 來生成，那為什麼我還是推薦他寫部落格呢？所以這一篇我將會記錄一下我對於 AI 的看法，以及為什麼我還是推薦寫部落格。","5",{"url":17,"title":18,"date":19,"updated":19,"category":5,"tags":20,"description":26,"readingMinutes":27},"\u002Flearnexp\u002F20240719\u002F3445327744\u002F","關於睡眠的一些迷思以及睡眠品質的重要性","2024-07-19 10:10:36",[5,21,22,23,24,25],"睡眠品質","睡眠迷思","失眠","睡不好","疾病","其實身邊不少學生以及自己的同事都有過睡眠的問題，包含我自己身邊的人也有相關睡眠的障礙，因此自己其實做過不少功課，礙於最近滿多人一直在問，所以就稍微分享一下自己的心得跟功課。","10",{"url":29,"title":30,"date":31,"updated":31,"category":5,"tags":32,"description":36,"readingMinutes":37},"\u002Flearnexp\u002F20230315\u002F628918545\u002F","關於 ChatGPT、AI 是否會取代工程師這件事","2023-03-15 10:33:02",[5,12,33,34,35],"ChatGPT","GitHub Copilot","OpenAI","這一篇原本是分享在粉絲專頁的，但是為了能夠紀錄下來，所以就把它轉換成了文章，當然內容我也有稍微調整也比較豐富一點（畢竟要寫成文章）。","4",{"url":39,"title":40,"date":41,"updated":41,"category":5,"tags":42,"description":45,"readingMinutes":46},"\u002Flearnexp\u002F20211122\u002F1862504277\u002F","【91 極速開發+】課後心得","2021-11-22 17:34:18",[43,44,5],"91 極速開發+","課後心得","其實認真講【91 極速開發+】就是想要解決開發上總是在哀嚎的一個問題「時間不夠」，所以就被公司推坑去上了，那不免也寫一篇新的來分享課後心得。","3",{"url":48,"title":49,"date":50,"updated":50,"category":5,"tags":51,"description":53,"readingMinutes":37},"\u002Flearnexp\u002F20211008\u002F2688902488\u002F","關於學習的本質這件事","2021-10-08 21:26:49",[52,5],"其他","學習真的是一件痛苦的事嗎？這一篇聊聊我對「學習本質」的觀察，包含為什麼大家容易陷入焦慮、怎麼判斷自己有沒有真的學會，以及怎麼把學習變成一件比較不那麼痛苦的事。",{"url":55,"title":56,"date":57,"updated":57,"category":5,"tags":58,"description":59,"readingMinutes":37},"\u002Flearnexp\u002F20200612\u002F341747575\u002F","入職後發現技術不足怎麼辦？","2020-06-12 22:06:31",[52,5],"這幾天有幾位類似相同境遇的學員來跟我小聊一下自己工作近況，話題大多都是關於「入職後發現自己技術完全跟不上，同事開會時也幫不上忙，是不是該離職了。」",{"url":61,"title":62,"date":63,"updated":63,"category":5,"tags":64,"description":66,"readingMinutes":37},"\u002Flearnexp\u002F20200317\u002F2499808266\u002F","履歷該放什麼？作業還是作品？","2020-03-17 08:27:48",[65,5],"履歷","身為一名跨行轉職的新人工程師，往往都會犯一個很嚴重的錯誤，也就是將課堂上的作業當作作品集來使用。",{"url":68,"title":69,"date":70,"updated":70,"category":5,"tags":71,"description":72,"readingMinutes":37},"\u002Flearnexp\u002F20191020\u002F1606493563\u002F","2019 MOPCON 一日遊記","2019-10-20 18:02:46",[52,5],"由於 MOPCON 第一天有點事情所以只去第二天，這一篇就來記錄一下 MOPCON 第二天的一日遊吧。",{"url":74,"title":75,"date":76,"updated":76,"category":5,"tags":77,"description":78,"readingMinutes":15},"\u002Flearnexp\u002F20190930\u002F236119363\u002F","被車輪戰的六角同學會","2019-09-30 12:06:42",[52,5],"在 107\u002F09\u002F29 教師節當天六角學院舉辦了六角同學會，過程有一個自由聊天時間，所以這一篇就來記錄一下我被學員們車輪戰的過程吧(?!)",{"url":80,"title":81,"date":82,"updated":82,"category":5,"tags":83,"description":84,"readingMinutes":46},"\u002Flearnexp\u002F20190918\u002F2622329192\u002F","關於接案服務的這件事","2019-09-18 12:53:13",[52,5],"最近六角學院即將推出新服務，而這個服務本身就與我目前所做的事情有點關係，所以就寫這一篇文章來談談即將推出的新服務吧!",18,2,{"postCount":88,"tagCount":89},1035,1009,1784011735803]