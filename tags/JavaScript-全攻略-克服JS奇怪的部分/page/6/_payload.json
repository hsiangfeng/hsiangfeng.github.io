[{"data":1,"prerenderedAt":77},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript-%E5%85%A8%E6%94%BB%E7%95%A5-%E5%85%8B%E6%9C%8DJS%E5%A5%87%E6%80%AA%E7%9A%84%E9%83%A8%E5%88%86\u002Fpage\u002F6\u002F":3,"tag-page:zh-Hant:JavaScript-全攻略-克服JS奇怪的部分:6":4,"author-stats:zh-Hant:full":74},null,{"tag":5,"slug":6,"posts":7,"total":72,"totalPages":73},"JavaScript 全攻略:克服JS奇怪的部分","JavaScript-全攻略-克服JS奇怪的部分",[8,17,24,30,36,42,48,54,60,66],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fjsweirdworld\u002F20190517\u002F3849161770\u002F","[JS奇怪的世界]No.19 存在與布林值","2019-05-17 11:16:35","克服JS奇怪的部分系列",[14,5],"JavaScript","一般來講我們可以手動使用 Boolean、Number 等函數來做強制轉型的動作，但是課程也是強調不要這樣做(手動轉型)，但是用來展示效果是可以的，舉例我們將 undefined 轉換成布林值 ↓","1",{"url":18,"title":19,"date":20,"updated":3,"category":12,"tags":21,"description":22,"readingMinutes":23},"\u002Fjsweirdworld\u002F20190516\u002F803766782\u002F","[JS奇怪的世界]No.18 比較運算子","2019-05-16 21:16:35",[14,5],"將下來講講 小於運算子，讓我們試著用程式碼來講解。","2",{"url":25,"title":26,"date":27,"updated":3,"category":12,"tags":28,"description":29,"readingMinutes":16},"\u002Fjsweirdworld\u002F20190516\u002F3588659278\u002F","[JS奇怪的世界]No.17 觀念小叮嚀:強制轉型","2019-05-16 21:01:35",[14,5],"強制轉型的意思是什麼?就是將原本的型別轉換成另一種，例如 String 變成 Boolean。",{"url":31,"title":32,"date":33,"updated":3,"category":12,"tags":34,"description":35,"readingMinutes":16},"\u002Fjsweirdworld\u002F20190516\u002F3658238475\u002F","[JS奇怪的世界]No.16 運算子的優先性與相依性","2019-05-16 20:34:35",[14,5],"這兩個在 JavaScript 是一個非常重要的名詞，其實非常重要的觀念，如果能瞭解其觀念，對於 debug 上是有一定幫助的。",{"url":37,"title":38,"date":39,"updated":3,"category":12,"tags":40,"description":41,"readingMinutes":16},"\u002Fjsweirdworld\u002F20190516\u002F2821553635\u002F","[JS奇怪的世界]No.15 觀念小叮嚀:運算子","2019-05-16 20:00:35",[14,5],"運算子可以說是 JavaScript 中提供的特殊方法也可以稱之為函數，並且可以協助我們做一些計算，那怎麼寫呢?",{"url":43,"title":44,"date":45,"updated":3,"category":12,"tags":46,"description":47,"readingMinutes":23},"\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F","[JS奇怪的世界]No.14 純值","2019-05-16 19:30:35",[14,5],"前面已經針對 JavaScript 的型別做的一個簡易的介紹，而這章節課程將針對 JavaScript 動態型別瞭解以及其優缺點深入瞭解。",{"url":49,"title":50,"date":51,"updated":3,"category":12,"tags":52,"description":53,"readingMinutes":16},"\u002Fjsweirdworld\u002F20190516\u002F3276239225\u002F","[JS奇怪的世界]No.13 觀念小叮嚀-型別與JavaScript","2019-05-16 19:00:35",[14,5],"這一個章節是新的章節「型別與運算子」。",{"url":55,"title":56,"date":57,"updated":3,"category":12,"tags":58,"description":59,"readingMinutes":23},"\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F","[JS奇怪的世界]No.12 關於非同步回呼","2019-05-16 15:30:35",[14,5],"前面某一章節我有講過 JavaScipt 的同步執行，想必你也聽過很多所謂的非同步，但非同步是什麼?",{"url":61,"title":62,"date":63,"updated":3,"category":12,"tags":64,"description":65,"readingMinutes":16},"\u002Fjsweirdworld\u002F20190516\u002F2522156098\u002F","[JS奇怪的世界]No.11 範圍、ES6與let","2019-05-16 14:30:35",[14,5],"範圍所代表的意思是變數可以被取用的區域。",{"url":67,"title":68,"date":69,"updated":3,"category":12,"tags":70,"description":71,"readingMinutes":23},"\u002Fjsweirdworld\u002F20190516\u002F4036061119\u002F","[JS奇怪的世界]No.10 範圍鏈","2019-05-16 14:00:35",[14,5],"接下來要講得是「範圍鏈」，而這觀念並不會太難，因為在前面已經練習很多次了，更不用說上一章其實有講到範圍鏈(The Scope Chain)，一樣從課堂範例程式碼學習 ↓",69,7,{"postCount":75,"tagCount":76},1035,1009,1784020403078]