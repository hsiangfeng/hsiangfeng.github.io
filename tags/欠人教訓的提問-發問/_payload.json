[{"data":1,"prerenderedAt":26},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E6%AC%A0%E4%BA%BA%E6%95%99%E8%A8%93%E7%9A%84%E6%8F%90%E5%95%8F-%E7%99%BC%E5%95%8F\u002F":3,"tag-page:zh-Hant:欠人教訓的提問-發問:1":4,"author-stats:zh-Hant:full":23},null,{"tag":5,"slug":6,"posts":7,"total":22,"totalPages":22},"欠人教訓的提問 & 發問","欠人教訓的提問-發問",[8],{"url":9,"title":10,"date":11,"updated":12,"category":13,"tags":14,"description":20,"readingMinutes":21},"\u002Flearnexp\u002F20200112\u002F1752686187\u002F","來聊聊那些非常欠人教訓的提問 & 發問","2020-01-12 12:33:01","2023-01-05 20:52:38","學習經驗",[15,16,17,18,5,19],"提問","提問的修辭","提問的技巧","提問的智慧","培養良好的提問與發問","身為一名工程師在開發上遇到問題並發問是一件非常常見的事情，但是許多人都會忽略所謂的「提問的智慧」，但是「該如何提問」卻又是一門學問甚至可以說是技能，當然更不用說有些人的提問方式真的真的非常欠人教訓以及翻白眼，所以今天就來分享一篇該如何提問會比較合適。","12",1,{"postCount":24,"tagCount":25},1035,1009,1784010314293]