[{"data":1,"prerenderedAt":21},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E8%8B%B1%E6%96%87%E8%BD%89%E4%B8%AD%E6%96%87\u002F":3,"tag-page:zh-Hant:英文轉中文:1":4,"author-stats:zh-Hant:full":18},null,{"tag":5,"slug":5,"posts":6,"total":17,"totalPages":17},"英文轉中文",[7],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fother\u002F20220202\u002F3414775100\u002F","Udemy 小技巧 - 英文字幕轉中文(同步翻譯)","2022-02-02 22:41:09","雜談",[13,14,5],"Udemy","Google Translator","Udemy 可以說是很多人上課的首選，上面相當多便宜又大碗的課程，但是大多都是英語教學，因此對於英文不好的人是一個困擾，雖然可以使用翻譯工具將聽打的部分轉成中文，但播放時底下卻又是英文，因此寫一篇紀錄一下如何影音底下字幕也同步翻譯成中文。","2",1,{"postCount":19,"tagCount":20},1035,1009,1784012814155]