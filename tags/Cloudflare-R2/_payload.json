[{"data":1,"prerenderedAt":24},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FCloudflare-R2\u002F":3,"tag-page:zh-Hant:Cloudflare-R2:1":4,"author-stats:zh-Hant:full":21},null,{"tag":5,"slug":6,"posts":7,"total":20,"totalPages":20},"Cloudflare R2","Cloudflare-R2",[8],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":18,"readingMinutes":19},"\u002Fother\u002F20260420\u002F913443764\u002F","從 Firebase Storage 搬家到 Cloudflare R2，完整遷移紀錄","2026-04-20 23:00:00","雜談",[14,15,5,16,17],"Cloudflare","Firebase","Cloudflare Workers","Node.js","之前寫了一篇用 Cloudflare Workers 快取 Firebase Storage 圖片的文章，但後來想想快取終究只是在前面擋一層，Firebase 那邊的圖片還是在，帳單還是會跑，所以最後決定直接把兩個 Firebase Storage 的圖片全部搬到 Cloudflare R2，將近 4800 張圖片、2200 多個文章連結一次搞定，這篇就來記錄整個遷移過程，包含踩到的坑跟最終的架構。","7",1,{"postCount":22,"tagCount":23},1035,1009,1784010310030]