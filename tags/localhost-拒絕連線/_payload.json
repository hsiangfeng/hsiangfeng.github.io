[{"data":1,"prerenderedAt":25},["ShallowReactive",2],{"header-locale:\u002Ftags\u002Flocalhost-%E6%8B%92%E7%B5%95%E9%80%A3%E7%B7%9A\u002F":3,"tag-page:zh-Hant:localhost-拒絕連線:1":4,"author-stats:zh-Hant:full":22},null,{"tag":5,"slug":6,"posts":7,"total":21,"totalPages":21},"localhost 拒絕連線","localhost-拒絕連線",[8],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":19,"readingMinutes":20},"\u002Fother\u002F20200723\u002F3866554212\u002F","解決 Chrome 、 Firefox 或 Edge 等瀏覽器強制跳轉 HTTPS 網址問題","2020-07-23 13:56:29","雜談",[14,15,16,17,18,5],"障礙排除","瀏覽器","Chrome","Edge","Firefox","身為一名網頁工程師在開發時，往往很常使用 localhost 或是 127.0.0.1 來開發，但是有時候我們會發生一些很奇怪的狀況，例如：瀏覽器一直強制你走 https 或是出現「這個網站無法提供安全連線 localhost 傳送的回應無效。」等問題，所以這一篇就來紀錄一下如何解決。","2",1,{"postCount":23,"tagCount":24},1035,1009,1784010313246]