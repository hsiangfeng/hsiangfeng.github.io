[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FPixiJS-V5-%E6%95%99%E5%AD%B8\u002F":3,"tag-page:zh-Hant:PixiJS-V5-教學:1":4,"author-stats:zh-Hant:full":76},null,{"tag":5,"slug":6,"posts":7,"total":74,"totalPages":75},"PixiJS V5 教學","PixiJS-V5-教學",[8,19,25,32,38,44,50,56,62,68],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":17,"readingMinutes":18},"\u002Fjavascript\u002F20201111\u002F331254690\u002F","PixiJS V5 教學 (40) - 終章","2020-11-11 09:09:43","JavaScript",[5,14,12,15,16],"PixiJS","Canvas","w3HexSchool","這一篇是一整個 Pixi 的結尾，所以來做一個結尾吧。","1",{"url":20,"title":21,"date":22,"updated":3,"category":12,"tags":23,"description":24,"readingMinutes":18},"\u002Fjavascript\u002F20201102\u002F3342018158\u002F","PixiJS V5 教學 (39) - 音樂","2020-11-02 08:20:28",[5,14,12,15,16],"接下來這一篇來介紹開發一個遊戲非常重要的元素，也就是音樂。",{"url":26,"title":27,"date":28,"updated":3,"category":12,"tags":29,"description":30,"readingMinutes":31},"\u002Fjavascript\u002F20201031\u002F3727169327\u002F","PixiJS V5 教學 (38) - TexturePacker","2020-10-31 14:56:47",[5,14,12,15,16],"通常來講大多遊戲的素材都會將許多圖片放在一張大圖中，然後透過一個工具去生成 json 減少載入次數。","2",{"url":33,"title":34,"date":35,"updated":3,"category":12,"tags":36,"description":37,"readingMinutes":31},"\u002Fjavascript\u002F20201021\u002F1504709600\u002F","PixiJS V5 教學 (37) - 加入 stats.js","2020-10-21 15:25:20",[5,14,12,15,16],"接下來針對 stats.js 介紹一下，順便換一個範本作為參考會比較好，因為寶藏獵人其實所需要的效能問題看不太出來。",{"url":39,"title":40,"date":41,"updated":3,"category":12,"tags":42,"description":43,"readingMinutes":31},"\u002Fjavascript\u002F20201012\u002F1084963489\u002F","PixiJS V5 教學 (36) - FPS","2020-10-12 00:02:10",[5,14,12,15,16],"寶藏獵人我們也算是製作了一個段落，所以現在來講講 PIXI 一直在講的東西，也就是 FPS 吧。",{"url":45,"title":46,"date":47,"updated":3,"category":12,"tags":48,"description":49,"readingMinutes":31},"\u002Fjavascript\u002F20201005\u002F1803970914\u002F","PixiJS V5 教學 (35) - 優化細節","2020-10-05 08:25:53",[5,14,12,15,16],"最後這一篇來抓一下這個寶藏獵人還可以優化那些細節。",{"url":51,"title":52,"date":53,"updated":3,"category":12,"tags":54,"description":55,"readingMinutes":18},"\u002Fjavascript\u002F20200928\u002F1922914339\u002F","PixiJS V5 教學 (34) - 整合碰撞函數","2020-09-28 14:56:15",[5,14,12,15,16],"接下來這邊當冒險者碰到寶箱的時候，寶箱必須會跟著使用者移動，並接下來往門移動後就顯示過關成功。",{"url":57,"title":58,"date":59,"updated":3,"category":12,"tags":60,"description":61,"readingMinutes":18},"\u002Fjavascript\u002F20200921\u002F1037881060\u002F","PixiJS V5 教學 (33) - 製作怪物","2020-09-21 00:07:56",[5,14,12,15,16],"接下來我們要來製作怪物的部分，目前史萊姆只有一隻，所以要讓他變多且自動移動。",{"url":63,"title":64,"date":65,"updated":3,"category":12,"tags":66,"description":67,"readingMinutes":18},"\u002Fjavascript\u002F20200914\u002F617086885\u002F","PixiJS V5 教學 (32) - 重新開始製作","2020-09-14 08:40:30",[5,14,12,15,16],"這一篇稍微輕鬆鬆一點接續上一篇，所以這一篇就來製作重新開始遊戲的方法。",{"url":69,"title":70,"date":71,"updated":3,"category":12,"tags":72,"description":73,"readingMinutes":18},"\u002Fjavascript\u002F20200907\u002F267037798\u002F","PixiJS V5 教學 (31) - 文字訊息","2020-09-07 08:49:56",[5,14,12,15,16],"接下來我們要來製作一下當碰撞死亡後出現的文字訊息。",41,5,{"postCount":77,"tagCount":78},1035,1009,1784010311883]