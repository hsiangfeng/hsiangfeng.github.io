[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FPixiJS-V5-%E6%95%99%E5%AD%B8\u002Fpage\u002F3\u002F":3,"tag-page:zh-Hant:PixiJS-V5-教學:3":4,"author-stats:zh-Hant:full":76},null,{"tag":5,"slug":6,"posts":7,"total":74,"totalPages":75},"PixiJS V5 教學","PixiJS-V5-教學",[8,19,25,31,38,44,50,56,62,68],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":17,"readingMinutes":18},"\u002Fjavascript\u002F20200622\u002F389281552\u002F","PixiJS V5 教學 (20) - 碰撞邊界(2)","2020-06-22 08:25:39","JavaScript",[5,14,12,15,16],"PixiJS","Canvas","w3HexSchool","接下來我們可以試著來製作撞到牆壁後出現數字的效果。","2",{"url":20,"title":21,"date":22,"updated":3,"category":12,"tags":23,"description":24,"readingMinutes":18},"\u002Fjavascript\u002F20200615\u002F3300389376\u002F","PixiJS V5 教學 (19) - 碰撞邊界(1)","2020-06-15 08:13:50",[5,14,12,15,16],"接下來邊界相關的東西，通常來講我們在玩遊戲都會有所謂的邊界。",{"url":26,"title":27,"date":28,"updated":3,"category":12,"tags":29,"description":30,"readingMinutes":18},"\u002Fjavascript\u002F20200608\u002F3719086913\u002F","PixiJS V5 教學 (18) - boxesIntersect","2020-06-08 08:40:42",[5,14,12,15,16],"接下來稍微讓我們回顧一下前面沒講的東西，也就是 boxesIntersect 的參數。",{"url":32,"title":33,"date":34,"updated":3,"category":12,"tags":35,"description":36,"readingMinutes":37},"\u002Fjavascript\u002F20200601\u002F1513414542\u002F","PixiJS V5 教學 (17) - Text+HP","2020-06-01 08:38:23",[5,14,12,15,16],"前一篇我們學會如何製作血條，但是文字呢?所以這一篇就來介紹如何補上文字~","1",{"url":39,"title":40,"date":41,"updated":3,"category":12,"tags":42,"description":43,"readingMinutes":37},"\u002Fjavascript\u002F20200525\u002F1127214799\u002F","PixiJS V5 教學 (16) - Game HP","2020-05-25 09:00:08",[5,14,12,15,16],"前一篇開始我們開始有那麼一點像是在製作遊戲，所以接下來會來介紹一下遊戲中的血條該如何製作。",{"url":45,"title":46,"date":47,"updated":3,"category":12,"tags":48,"description":49,"readingMinutes":18},"\u002Fjavascript\u002F20200518\u002F1745009932\u002F","PixiJS V5 教學 (15) - Bump","2020-05-18 08:20:50",[5,14,12,15,16],"前一篇我們學習如何使用 PIXI 建立幾何圖形，那麼接下來要學習 PIXI 中一個我認為滿特別的東西，也就是碰撞檢測。",{"url":51,"title":52,"date":53,"updated":3,"category":12,"tags":54,"description":55,"readingMinutes":18},"\u002Fjavascript\u002F20200511\u002F1897499725\u002F","PixiJS V5 教學 (14) - Graphics(2)","2020-05-11 07:30:15",[5,14,12,15,16],"前一篇介紹了基本的幾何圖形的繪畫，但是只介紹矩形，其實 PIXI 還有其他幾何圖形的繪畫，所以接下來就來講其他的幾何圖形囉",{"url":57,"title":58,"date":59,"updated":3,"category":12,"tags":60,"description":61,"readingMinutes":18},"\u002Fjavascript\u002F20200504\u002F1045961354\u002F","PixiJS V5 教學 (13) - Graphics(1)","2020-05-04 08:10:50",[5,14,12,15,16],"接下來將會來介紹一點使用 PIXI 繪畫幾何圖形，最後會再來試著整合前面的技巧。",{"url":63,"title":64,"date":65,"updated":3,"category":12,"tags":66,"description":67,"readingMinutes":37},"\u002Fjavascript\u002F20200427\u002F658713547\u002F","PixiJS V5 教學 (12) - mousemoveEvent(2)","2020-04-27 08:59:26",[5,14,12,15,16],"接下來講講關於 PIXI 其他的滑鼠操作吧~",{"url":69,"title":70,"date":71,"updated":3,"category":12,"tags":72,"description":73,"readingMinutes":18},"\u002Fjavascript\u002F20200420\u002F208566280\u002F","PixiJS V5 教學 (11) - mousemove","2020-04-20 08:35:59",[5,14,12,15,16],"前一篇介紹了使用鍵盤來移動圖片，那麼接下來就要來介紹使用滑鼠移動。",41,5,{"postCount":77,"tagCount":78},1035,1009,1784020404052]