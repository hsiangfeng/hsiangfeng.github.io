[{"data":1,"prerenderedAt":80},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FPixiJS-V5-%E6%95%99%E5%AD%B8\u002Fpage\u002F4\u002F":3,"tag-page:zh-Hant:PixiJS-V5-教學:4":4,"author-stats:zh-Hant:full":77},null,{"tag":5,"slug":6,"posts":7,"total":75,"totalPages":76},"PixiJS V5 教學","PixiJS-V5-教學",[8,19,26,32,38,44,50,56,62,68],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":17,"readingMinutes":18},"\u002Fjavascript\u002F20200413\u002F360008009\u002F","PixiJS V5 教學(10) - 鍵盤控制","2020-04-13 08:40:22","JavaScript",[5,14,12,15,16],"PixiJS","Canvas","w3HexSchool","接下來這一篇將會來介紹如何使用鍵盤來控制圖片，讓目前 PIXI 更像一個遊戲。","1",{"url":20,"title":21,"date":22,"updated":3,"category":12,"tags":23,"description":24,"readingMinutes":25},"\u002Fjavascript\u002F20200406\u002F213668506\u002F","PixiJS V5 教學 (9) - speeds","2020-04-06 08:30:23",[5,14,12,15,16],"接下來也是與圖片移動相關，但是這一次要介紹的是速度。","2",{"url":27,"title":28,"date":29,"updated":3,"category":12,"tags":30,"description":31,"readingMinutes":18},"\u002Fjavascript\u002F20200330\u002F363291611\u002F","PixiJS V5 教學 (8) - Ticker(2)","2020-03-30 08:20:14",[5,14,12,15,16],"前面終於讓圖片動起來了，接下來這一篇就輕鬆一點試著了解一下剛剛移動圖片的 API 還有哪些吧~",{"url":33,"title":34,"date":35,"updated":3,"category":12,"tags":36,"description":37,"readingMinutes":25},"\u002Fjavascript\u002F20200323\u002F2334412373\u002F","PixiJS V5 教學 (7) - Ticker","2020-03-23 09:01:18",[5,14,12,15,16],"前面已經學會引入圖片，那麼單純只是引入圖片有點無聊，所以來試著移動圖片吧~",{"url":39,"title":40,"date":41,"updated":3,"category":12,"tags":42,"description":43,"readingMinutes":25},"\u002Fjavascript\u002F20200316\u002F2334412373\u002F","PixiJS V5 教學 (6) - Texture(2)","2020-03-16 08:39:30",[5,14,12,15,16],"上一篇介紹了使用 new PIXI.Loader(); 的方式來渲染圖片，這一篇則會介紹另一種寫法。",{"url":45,"title":46,"date":47,"updated":3,"category":12,"tags":48,"description":49,"readingMinutes":25},"\u002Fjavascript\u002F20200309\u002F2684951958\u002F","PixiJS V5 教學 (5) - Texture","2020-03-09 08:15:00",[5,14,12,15,16],"有引入文字那麼就會有引入圖片啦~而 PIXI 會使用 GPU 以及 WebGL 來渲染圖片，而圖片需要經過處理才能夠使用的，而通常處理好的圖片都會稱為 Texture。",{"url":51,"title":52,"date":53,"updated":3,"category":12,"tags":54,"description":55,"readingMinutes":25},"\u002Fjavascript\u002F20200302\u002F3104976087\u002F","PixiJS V5 教學 (4) - Text","2020-03-02 09:00:10",[5,14,12,15,16],"前一篇介紹了 Container，接下來要來看介紹前一篇所使用到的語法，也就是 new PIXI.Text()。",{"url":57,"title":58,"date":59,"updated":3,"category":12,"tags":60,"description":61,"readingMinutes":25},"\u002Fjavascript\u002F20200224\u002F4132682256\u002F","PixiJS V5 教學 (3) - Container","2020-02-24 08:17:13",[5,14,12,15,16],"前面基本知識也算是講得差不多，接下來將會介紹 PIXI 中的一個重要的東西，也就是 Container。",{"url":63,"title":64,"date":65,"updated":3,"category":12,"tags":66,"description":67,"readingMinutes":25},"\u002Fjavascript\u002F20200217\u002F4014508881\u002F","PixiJS V5 教學 (2) - WebGL 以及 Renderer","2020-02-17 00:05:28",[5,14,12,15,16],"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",{"url":69,"title":70,"date":71,"updated":3,"category":12,"tags":72,"description":74,"readingMinutes":25},"\u002Fjavascript\u002F20200210\u002F3949702627\u002F","PixiJS V5 教學 (1) - PixiJS 建立","2020-02-10 00:00:10",[5,14,12,73,16],"Canvasgit","Pixi.js 是一款基於 JavaScript 的 2D 引擎所開發的框架，主要常見於開發 2D 網頁遊戲，接下來就來快速入門學習吧 :D",41,5,{"postCount":78,"tagCount":79},1035,1009,1784020404058]