[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FJavaScript-%E6%A0%B8%E5%BF%83%E7%AF%87\u002Fpage\u002F8\u002F":3,"tag-page:zh-Hant:JavaScript-核心篇:8":4,"author-stats:zh-Hant:full":78},null,{"tag":5,"slug":6,"posts":7,"total":76,"totalPages":77},"JavaScript 核心篇","JavaScript-核心篇",[8,17,24,32,38,44,50,57,64,70],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fjavascript\u002F20200613\u002F3587770435\u002F","JavaScript 核心觀念(12)-運算子、型別與文法-ASI 自動插入分號","2020-06-13 21:16:47","JavaScript",[12,5,14],"運算子、型別與文法","JavaScript 為什麼一下子可以有「;」號一下子有沒有「;」號呢？這歸功於 JavaScript 中的一個機制 ASI。","2",{"url":18,"title":19,"date":20,"updated":3,"category":12,"tags":21,"description":22,"readingMinutes":23},"\u002Fjavascript\u002F20200607\u002F196651152\u002F","JavaScript 核心觀念(11)-運算子、型別與文法-陳述式與表達式","2020-06-07 14:08:21",[12,5,14],"陳述式 vs 表達式是最容易搞不清楚的觀念，包含我自己也是。","4",{"url":25,"title":26,"date":27,"updated":3,"category":12,"tags":28,"description":30,"readingMinutes":31},"\u002Fjavascript\u002F20200606\u002F308613948\u002F","JavaScript 核心觀念(10)-執行環境與作用域-課後練習","2020-06-06 22:33:46",[12,5,29],"執行環境與作用域","終於來到最後的課後練習，雖然課後練習中絕大部分問題都是我自己出的，但也是很值得回顧的練習，但是這邊會建議不要直接執行程式碼，而是透過觀察畫面來推敲結果答案。","5",{"url":33,"title":34,"date":35,"updated":3,"category":12,"tags":36,"description":37,"readingMinutes":16},"\u002Fjavascript\u002F20200531\u002F3571534372\u002F","JavaScript 核心觀念(9)-執行環境與作用域-執行緒與同步、非同步","2020-05-31 22:09:11",[12,5,29],"這個章節開始是 JavaScript 中的重點觀念，也就是常見的 JavaScript 非同步、同步以及單執行緒的問題。",{"url":39,"title":40,"date":41,"updated":3,"category":12,"tags":42,"description":43,"readingMinutes":16},"\u002Fjavascript\u002F20200524\u002F995184384\u002F","JavaScript 核心觀念(8)-執行環境與作用域-記憶體存放與釋放","2020-05-24 10:56:06",[12,5,29],"接下來講一下記憶體的回收機制。",{"url":45,"title":46,"date":47,"updated":3,"category":12,"tags":48,"description":49,"readingMinutes":16},"\u002Fjavascript\u002F20200510\u002F2581786882\u002F","JavaScript 核心觀念(7)-執行環境與作用域-not defined VS undefined","2020-05-10 21:27:11",[12,5,29],"not defined 以及 undefined 也是 JavaScript 中相當重要的觀念，若可以搞懂這兩者的差異，對於 debug 上是非常有幫助的。",{"url":51,"title":52,"date":53,"updated":3,"category":12,"tags":54,"description":55,"readingMinutes":56},"\u002Fjavascript\u002F20200503\u002F1924910570\u002F","JavaScript 核心觀念(6)-執行環境與作用域-提升","2020-05-03 14:45:13",[12,5,29],"提升(Hoisting) 可以說是我最喜好的一個觀念，JavaScript 中舉凡函式、變數都有這個觀念存在。","3",{"url":58,"title":59,"date":60,"updated":3,"category":12,"tags":61,"description":62,"readingMinutes":63},"\u002Fjavascript\u002F20200502\u002F1231063032\u002F","JavaScript 核心觀念(5)-執行環境與作用域-範圍鍊","2020-05-02 21:36:56",[12,5,29],"接下來講講為什麼明明宣告在外層的變數甚至是不同地方的函式，卻可以正確的呼叫與執行。","1",{"url":65,"title":66,"date":67,"updated":3,"category":12,"tags":68,"description":69,"readingMinutes":16},"\u002Fjavascript\u002F20200502\u002F2917226562\u002F","JavaScript 核心觀念(4)-執行環境與作用域-執行環境與執行堆疊","2020-05-02 15:29:53",[12,5,29],"若沒有搞清楚執行環境與執行堆疊的觀念在後續開發上其實會很混亂。",{"url":71,"title":72,"date":73,"updated":3,"category":12,"tags":74,"description":75,"readingMinutes":16},"\u002Fjavascript\u002F20200412\u002F2694164006\u002F","JavaScript 核心觀念(3)-執行環境與作用域-語法作用域","2020-04-12 11:25:17",[12,5,29],"JavaScript 採用的是語法作用域，所謂的語法作用域就是你宣告時就已經決定好他的作用域。",83,9,{"postCount":79,"tagCount":80},1035,1009,1784012810487]