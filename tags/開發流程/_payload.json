[{"data":1,"prerenderedAt":22},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E9%96%8B%E7%99%BC%E6%B5%81%E7%A8%8B\u002F":3,"tag-page:zh-Hant:開發流程:1":4,"author-stats:zh-Hant:full":19},null,{"tag":5,"slug":5,"posts":6,"total":18,"totalPages":18},"開發流程",[7],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Fai\u002F20250522\u002F3579637231\u002F","GitHub Copilot + MCP Server 串接 VSCode 打造 AI 開發流程教學","2025-05-22 09:32:47","AI",[11,13,14,15,5],"GitHub Copilot","MCP Server","VSCode","近代來講，AI 開發已經成為工程師必備的技能之一，但是我們在使用 AI 工具時，總是會遇到一些狀況，如：AI 回傳的內容不如預期，或是 AI 無法理解我們的需求，這些問題都會影響我們的開發效率，所以為了解決這個問題，MCP Server 應運而生。","3",1,{"postCount":20,"tagCount":21},1035,1009,1784020407773]