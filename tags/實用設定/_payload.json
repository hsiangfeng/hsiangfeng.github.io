[{"data":1,"prerenderedAt":40},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%AF%A6%E7%94%A8%E8%A8%AD%E5%AE%9A\u002F":3,"tag-page:zh-Hant:實用設定:1":4,"author-stats:zh-Hant:full":37},null,{"tag":5,"slug":5,"posts":6,"total":35,"totalPages":36},"實用設定",[7,17,27],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":15,"readingMinutes":16},"\u002Fvscode\u002F20230921\u002F1985180173\u002F","Visual Studio Code 自訂折疊區塊","2023-09-21 09:43:55","VSCode",[11,5,13,14],"Setting","開發","VSCode 預設可以折疊函式但不能自訂區塊？其實只要用 #region 跟 #endregion 包住程式碼就能自訂折疊範圍，這一篇示範這個少人知道但相當實用的小技巧。","2",{"url":18,"title":19,"date":20,"updated":3,"category":21,"tags":22,"description":26,"readingMinutes":16},"\u002Fother\u002F20210725\u002F2827471503\u002F","快速清除瀏覽器輸入框的舊資料或不要的 Email 歷史資訊","2021-07-25 14:56:50","雜談",[23,24,25,5],"瀏覽器","障礙排除","作業系統","瀏覽器每次輸入帳號或 Email 都會跳一堆以前留下的舊資料？這一篇教你在 Chrome、Firefox 用 Shift + Delete 快速刪掉指定的自動完成項目， 不用把整個瀏覽紀錄全清掉。",{"url":28,"title":29,"date":30,"updated":31,"category":11,"tags":32,"description":33,"readingMinutes":34},"\u002Fvscode\u002F20210512\u002F2779926364\u002F","身為開發者，我會建議你使用的 VSCode 的實用設定","2021-05-12 09:02:38","2023-04-16 20:01:00",[11,5,13,14],"工欲善必先利其器，身為長期有在 VSCode 的工程師來講，如果可以多了解自己的編輯器設定，其實可以幫助自己在實際開發上的方便性以及除錯，因此這一篇我就紀錄與分享一下有哪些 VSCode 的實用設定吧！","3",3,1,{"postCount":38,"tagCount":39},1035,1009,1784010314019]