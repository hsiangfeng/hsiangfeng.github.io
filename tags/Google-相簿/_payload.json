[{"data":1,"prerenderedAt":26},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FGoogle-%E7%9B%B8%E7%B0%BF\u002F":3,"tag-page:zh-Hant:Google-相簿:1":4,"author-stats:zh-Hant:full":23},null,{"tag":5,"slug":6,"posts":7,"total":22,"totalPages":22},"Google 相簿","Google-相簿",[8],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":20,"readingMinutes":21},"\u002Fother\u002F20260502\u002F1592048371\u002F","手機摔壞照片就沒了？拜託先去開 Google 相簿備份（iPhone 完整設定教學）","2026-05-02 00:00:00","雜談",[5,14,15,16,17,18,19],"備份","雲端","手機","iPhone","iOS","Google Photos","手機摔壞、掉到水裡、突然開不了機，這時候裡面的照片其實是最難救回來的東西。這篇就分享為什麼我會推薦把 Google 相簿備份打開，並且實際示範 iPhone 上的設定流程，包含備份畫質的選擇、15GB 免費空間怎麼用、行動數據備份要不要打開，以及 iOS 上很容易踩到的坑 — 把 APP 從多工列滑掉備份就會中斷。","4",1,{"postCount":24,"tagCount":25},1035,1009,1784010310787]