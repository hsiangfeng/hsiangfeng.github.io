[{"data":1,"prerenderedAt":39},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FAI\u002Fpage\u002F5\u002F":3,"tag-page:zh-Hant:AI:5":4,"author-stats:zh-Hant:full":36},null,{"tag":5,"slug":5,"posts":6,"total":34,"totalPages":35},"AI",[7,18,27],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Flearnexp\u002F20230315\u002F628918545\u002F","關於 ChatGPT、AI 是否會取代工程師這件事","2023-03-15 10:33:02","學習經驗",[11,5,13,14,15],"ChatGPT","GitHub Copilot","OpenAI","這一篇原本是分享在粉絲專頁的，但是為了能夠紀錄下來，所以就把它轉換成了文章，當然內容我也有稍微調整也比較豐富一點（畢竟要寫成文章）。","4",{"url":19,"title":20,"date":21,"updated":3,"category":22,"tags":23,"description":25,"readingMinutes":26},"\u002Fpython\u002F20190626\u002F2933081730\u002F","拖曳影片檔案到 CMD 圖示內透過 Python 生成影片字幕","2019-06-26 10:13:30","Python",[22,5,24],"字幕","由於先前撰寫了[使用 Python 替影片自動上字幕]的文章，後來自己在使用的時候每一次都要打開指令視窗輸入指令，對於金魚腦的我來講實在很不方便，所以這邊稍微製作 .bat 檔案，直接拖曳進去自動生成字幕。","1",{"url":28,"title":29,"date":30,"updated":3,"category":22,"tags":31,"description":32,"readingMinutes":33},"\u002Fpython\u002F20190531\u002F4077454772\u002F","使用 Python 替影片自動產生字幕 srt 檔","2019-05-31 10:44:35",[22,5,24],"有時候我們要替影片上字幕是滿麻煩的事情，因為必須重複地聽才能夠抓出時間區段，但是如果透過工具先幫我們抓出 50% 字幕區間，然後在來做調整，這樣一定會比較準確，所以這邊做一下筆記該如何使用這個套件。","2",43,5,{"postCount":37,"tagCount":38},1036,1011,1784087373785]