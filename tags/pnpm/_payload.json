[{"data":1,"prerenderedAt":41},["ShallowReactive",2],{"header-locale:\u002Ftags\u002Fpnpm\u002F":3,"tag-page:zh-Hant:pnpm:1":4,"author-stats:zh-Hant:full":38},null,{"tag":5,"slug":5,"posts":6,"total":36,"totalPages":37},"pnpm",[7,19],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":17,"readingMinutes":18},"\u002Fother\u002F20240413\u002F3177435894\u002F","Monorepo？來聊聊另一種專案管理架構吧！使用 Vite+ pnpm 建立 Vue3 Monorepo","2024-04-13 21:51:10","2026-05-12 09:00:00","雜談",[14,15,5,16],"Monorepo","Vite","Vue3","Monorepo 到底是什麼？跟 Monolith、Multi-repo 差在哪？這一篇先聊三種專案管理架構的差別，再用 Vite + pnpm 手把手帶你建一個 Vue3 Monorepo 結構出來。","6",{"url":20,"title":21,"date":22,"updated":23,"category":24,"tags":25,"description":34,"readingMinutes":35},"\u002Fnodejs\u002F20221127\u002F2847196536\u002F","一個 antfu\u002Fni 搞定安裝？！用 antfu\u002Fni 來取代你的 npm\u002Fyarn\u002Fpnpm\u002Fbun 吧！","2022-11-27 20:31:42","2025-04-07 14:03:27","Nodejs",[26,27,28,29,30,5,31,32,33],"antfu\u002Fni","ni","npm","yarn","node","bun","套件管理","套件安裝管理器","你有想過一個問題嗎？每次拿到別人開發的新專案時，到底要輸入 npm install 還是 yarn install 呢？是不是覺得套件管理安裝器超級無敵多，每次都要打開專案看才能夠知道要用哪一個呢？所以這一篇我將會介紹一個很特別的套件安裝管理器，也就是 ni。","3",2,1,{"postCount":39,"tagCount":40},1035,1009,1784010313378]