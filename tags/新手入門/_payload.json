[{"data":1,"prerenderedAt":28},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E6%96%B0%E6%89%8B%E5%85%A5%E9%96%80\u002F":3,"tag-page:zh-Hant:新手入門:1":4,"author-stats:zh-Hant:full":25},null,{"tag":5,"slug":5,"posts":6,"total":24,"totalPages":24},"新手入門",[7],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":22,"readingMinutes":23},"\u002Fai\u002F20260427\u002F1657384902\u002F","想開始 Vibe Coding？新手推薦先搞懂的這些基礎知識","2026-04-27 14:30:00","AI",[11,13,14,15,16,17,18,19,20,21,5],"Vibe Coding","Git","GitHub","VSCode","Terminal","前端框架","UI Framework","Node.js","Prompt","最近滿多朋友都跑來問我說「我也想用 AI 開發點東西，要從哪裡開始學？」，而這背後其實就是大家最近常聽到的 Vibe Coding。這一篇就來聊一下，新手如果想要踏入 Vibe Coding 的世界，到底有哪些基礎知識是推薦先搞懂的，例如 Git、命令列、UI Framework 等等，免得你做到一半才發現自己卡關卡到不知道該怎麼跟 AI 溝通。","12",1,{"postCount":26,"tagCount":27},1036,1011,1784087381917]