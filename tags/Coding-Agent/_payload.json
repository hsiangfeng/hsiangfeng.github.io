[{"data":1,"prerenderedAt":26},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FCoding-Agent\u002F":3,"tag-page:zh-Hant:Coding-Agent:1":4,"author-stats:zh-Hant:full":23},null,{"tag":5,"slug":6,"posts":7,"total":22,"totalPages":22},"Coding Agent","Coding-Agent",[8],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":20,"readingMinutes":21},"\u002Fai\u002F20260410\u002F2748391056\u002F","AI Agent 不再是統稱了？認識 Coding Agent 與各類 AI Agent 的差異","2026-04-10 13:30:00","AI",[12,14,5,15,16,17,18,19],"AI Agent","Code Agent","Claude Code","Cursor","GitHub Copilot","Devin","之前在介紹 AI 名詞的時候，AI Agent 就是一個統稱，泛指那些可以自己理解任務、拆解步驟、操作工具來完成事情的 AI 系統。可是到了 2026 年的現在，AI Agent 這個詞已經開始被進一步細分了，其中最成熟的子分類就是 Coding Agent（也有人叫 Code Agent）。這篇就來聊聊這些分類到底是怎麼回事，以及它們之間的差異。","5",1,{"postCount":24,"tagCount":25},1035,1009,1784013098211]