[{"data":1,"prerenderedAt":25},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FWindows-98\u002F":3,"tag-page:zh-Hant:Windows-98:1":4,"author-stats:zh-Hant:full":22},null,{"tag":5,"slug":6,"posts":7,"total":21,"totalPages":21},"Windows 98","Windows-98",[8],{"url":9,"title":10,"date":11,"updated":12,"category":13,"tags":14,"description":19,"readingMinutes":20},"\u002Flearnexp\u002F20250903\u002F827596012\u002F","【Day 3】主機板上的迷宮探險：打開電腦殼的第一次震撼教育","2025-09-03 00:00:01","2026-05-07 21:00:00","學習經驗",[15,16,17,18,5],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","電腦硬體入門","主機板結構","Flash 遊戲回憶","我爸從公司搬了一台電腦回來，我人生的第一台電腦就此誕生。從興奮到摸不著頭緒，再到電腦壞掉，我第一次打開機殼，進入那個叫「主機板」的神祕世界——也開始理解電腦裡的內臟構造，從 CPU 到 RAM、從硬碟到電源供應器，每個零件都是我未來工程人生的起點。","5",1,{"postCount":23,"tagCount":24},1036,1011,1784087379455]