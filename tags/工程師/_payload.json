[{"data":1,"prerenderedAt":31},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%B7%A5%E7%A8%8B%E5%B8%AB\u002F":3,"tag-page:zh-Hant:工程師:1":4,"author-stats:zh-Hant:full":28},null,{"tag":5,"slug":5,"posts":6,"total":26,"totalPages":27},"工程師",[7,18],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Fother\u002F20230626\u002F4076164354\u002F","博弈公司的工程師生活：揭開神秘面紗，機會與挑戰並存","2023-06-26 06:42:30","雜談",[13,5,14,15],"博弈公司","軟體工程師","軟體開發","博弈產業是一個讓每個人充滿好奇的產業，因為它的神秘感及高薪水的特性，讓許多人對於這產業會感到特別的好奇，但是同時也讓許多人對於進入這個產業充滿的害怕與恐懼，為什麼呢？這一篇我就依照自己經歷以及身邊的朋友們的經驗來跟大家分享一下，希望能夠讓大家對於這個產業有更多的了解以及該如何挑選博弈產業的公司。","8",{"url":19,"title":20,"date":21,"updated":21,"category":11,"tags":22,"description":25,"readingMinutes":17},"\u002Fother\u002F20230617\u002F2478456532\u002F","前端工程師的光與影：仔細思考後再踏進這個領域","2023-06-17 09:46:53",[23,5,24],"前端","資訊","現在是一個資訊大爆炸的時代，知識取得的方式越來越多且方便，但是也因為如此，我們需要更多的時間去思考，去判斷，去分辨，去選擇，去決定，去做出一個最好的選擇，更不用說現在許多人都想成為工程師。",2,1,{"postCount":29,"tagCount":30},1035,1009,1784011735840]