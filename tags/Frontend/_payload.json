[{"data":1,"prerenderedAt":35},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FFrontend\u002F":3,"tag-page:zh-Hant:Frontend:1":4,"author-stats:zh-Hant:full":32},null,{"tag":5,"slug":5,"posts":6,"total":30,"totalPages":31},"Frontend",[7,18],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":16,"readingMinutes":17},"\u002Fnodejs\u002F20260113\u002F3115395907\u002F","真是受夠開多個終端機執行多個指令了！來用 concurrently 吧","2026-01-13 09:45:28","Nodejs",[13,5,14,15],"Node.js","Workflow","concurrently","隨著手上負責的專案越來越多，我也開始需要同時開啟多個終端機視窗來執行不同的指令，例如前端專案的開發伺服器、後端 API 伺服器、資料庫服務等等。每次都要手動開啟多個終端機視窗並輸入指令，實在是非常麻煩且浪費時間，所以這一篇來介紹一下 concurrently 這個工具。","2",{"url":19,"title":20,"date":21,"updated":3,"category":22,"tags":23,"description":28,"readingMinutes":29},"\u002Fother\u002F20210722\u002F4002613152\u002F","使用 Firefox 瀏覽器當作前端開發的特色與優勢","2021-07-22 22:15:14","雜談",[24,25,26,27,5],"Firefox","Mozilla Firefox","Flex","Chrome","最近滿多人都在問我使用的瀏覽器是什麼以及為什麼我不使用 Google Chrome，那這一篇想說就來寫一點簡單介紹 Firefox 吧。","3",2,1,{"postCount":33,"tagCount":34},1035,1009,1784013098641]