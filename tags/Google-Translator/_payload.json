[{"data":1,"prerenderedAt":22},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FGoogle-Translator\u002F":3,"tag-page:zh-Hant:Google-Translator:1":4,"author-stats:zh-Hant:full":19},null,{"tag":5,"slug":6,"posts":7,"total":18,"totalPages":18},"Google Translator","Google-Translator",[8],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":16,"readingMinutes":17},"\u002Fother\u002F20220202\u002F3414775100\u002F","Udemy 小技巧 - 英文字幕轉中文(同步翻譯)","2022-02-02 22:41:09","雜談",[14,5,15],"Udemy","英文轉中文","Udemy 可以說是很多人上課的首選，上面相當多便宜又大碗的課程，但是大多都是英語教學，因此對於英文不好的人是一個困擾，雖然可以使用翻譯工具將聽打的部分轉成中文，但播放時底下卻又是英文，因此寫一篇紀錄一下如何影音底下字幕也同步翻譯成中文。","2",1,{"postCount":20,"tagCount":21},1035,1009,1784011732873]