[{"data":1,"prerenderedAt":101},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FSEO\u002F":3,"tag-page:zh-Hant:SEO:1":4,"author-stats:zh-Hant:full":98},null,{"tag":5,"slug":5,"posts":6,"total":96,"totalPages":97},"SEO",[7,20,31,40,53,64,70,76,83,90],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":18,"readingMinutes":19},"\u002Fai\u002F20260408\u002F3734112946\u002F","SEO 已經不夠了嗎？認識 AEO 答案引擎優化，讓 AI 搜尋找到你","2026-04-08 12:00:00","2026-05-26 12:00:00","AI",[12,5,14,15,16,17],"AEO","AI Search","Schema Markup","llms.txt","這一篇稍微來聊一下 AEO（Answer Engine Optimization，答案引擎優化）這個概念，隨著越來越多人開始用 ChatGPT、Perplexity 取代 Google 搜尋，傳統 SEO 的玩法可能也要跟著調整了，所以這篇就來聊聊 AEO 是什麼、跟 SEO 差在哪裡、以及實際上該怎麼做。","11",{"url":21,"title":22,"date":23,"updated":23,"category":24,"tags":25,"description":29,"readingMinutes":30},"\u002Fhtml\u002F20230613\u002F61882704\u002F","語意比你想像的還更重要，那些你不重視的 HTML 標籤","2023-06-13 15:40:32","HTML",[24,26,5,27,28],"語意","標籤","網頁","這一篇來稍微認真聊一下大家很常忽略的一個東西，那就是 HTML 標籤的語意，而這個問題就會導致出現各種問題，像是 SEO 不佳、網頁閱讀性差、維護性差等等，所以這篇就來聊聊這個問題。","7",{"url":32,"title":33,"date":34,"updated":3,"category":35,"tags":36,"description":38,"readingMinutes":39},"\u002Fother\u002F20210627\u002F3588736352\u002F","快速掌握 robots.txt 用途","2021-06-27 17:05:43","雜談",[37,5],"robots","robots.txt 究竟有什麼用，而這個對於 SEO 是否會有影響，所以這一篇就記錄一下。","3",{"url":41,"title":42,"date":43,"updated":3,"category":35,"tags":44,"description":51,"readingMinutes":52},"\u002Fother\u002F20210530\u002F1324443947\u002F","攸關 SEO 的三大核心指標 LCP、FID、CLS","2021-05-30 22:20:27",[45,46,47,5,48,49,50],"Google","Google Search Console","Chrome","LCP","FID","CLS","先寫在前面，會寫這一篇文章主要原因是發現自己網站的體驗被標注了很差，所以紀錄一下事發與原因。","4",{"url":54,"title":55,"date":56,"updated":3,"category":57,"tags":58,"description":62,"readingMinutes":63},"\u002Fhexo\u002F20201008\u002F4026232510\u002F","(25) 試著學 Hexo - SEO 篇 - SEO 觀念補充","2020-10-08 00:01:00","Hexo",[57,59,60,61,5],"試著學 Hexo","第 12 屆 iT邦幫忙鐵人賽","NexT","這一篇是最後一篇關於 SEO 的部分，我只能說 SEO 博大精深，所以這一篇最後再補充一點點關於 SEO 的觀