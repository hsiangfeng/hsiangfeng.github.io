[{"data":1,"prerenderedAt":45},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FCSS-%E8%A8%AD%E8%A8%88%E6%A8%A1%E5%BC%8F\u002F":3,"tag-page:zh-Hant:CSS-設計模式:1":4,"author-stats:zh-Hant:full":42},null,{"tag":5,"slug":6,"posts":7,"total":40,"totalPages":41},"CSS 設計模式","CSS-設計模式",[8,17,24,32],{"url":9,"title":10,"date":11,"updated":3,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fcss\u002F20200523\u002F116058774\u002F","淺談 CSS 設計模式系列-Sass 7-1 Pattern 篇","2020-05-23 21:00:52","CSS",[5,14,12],"7+1 設計模式","7+1 的設計模式主要是在講目錄結構的區分，早期開發 CSS 時只能將所有檔案放在同一個地方，那麼這樣就會導致維護上的困擾，因此在開發 Sass 時就可以搭配 @import 然後使用資料夾區分相關檔案，也就是所謂的 Sass 7-1 Pattern。","2",{"url":18,"title":19,"date":20,"updated":3,"category":12,"tags":21,"description":23,"readingMinutes":16},"\u002Fcss\u002F20200517\u002F4250484451\u002F","淺談 CSS 設計模式系列-BEM 篇","2020-05-17 15:33:48",[5,22,12],"BEM","BEM 是一個為了讓 class 有更好地維護架構 CSS 設計模式，但最主要的致命缺點就是命名長度過長，可是在實際開發上非常多人都會使用到 BEM。",{"url":25,"title":26,"date":27,"updated":3,"category":12,"tags":28,"description":30,"readingMinutes":31},"\u002Fcss\u002F20200517\u002F168089779\u002F","淺談 CSS 設計模式系列-OOCSS 篇","2020-05-17 12:53:41",[5,29,12],"OOCSS","OOCSS 是 CSS 設計模式的另一種，其中最主要代表的框架就是 Bootstrap。","3",{"url":33,"title":34,"date":35,"updated":3,"category":12,"tags":36,"description":38,"readingMinutes":39},"\u002Fcss\u002F20200516\u002F2341336904\u002F","淺談 CSS 設計模式-SMACSS 篇","2020-05-16 19:59:52",[5,37,12],"SMACSS","CSS 設計模式是一個觀念、規範以及心法，最主要就是要替我們提高開發與維護的效率。","5",4,1,{"postCount":43,"tagCount":44},1035,1009,1784020401691]