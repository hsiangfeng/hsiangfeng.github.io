[{"data":1,"prerenderedAt":55},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FNexT\u002Fpage\u002F2\u002F":3,"tag-page:zh-Hant:NexT:2":4,"author-stats:zh-Hant:full":52},null,{"tag":5,"slug":5,"posts":6,"total":50,"totalPages":51},"NexT",[7,15,23,30,36,43],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":13,"readingMinutes":14},"\u002Fhexo\u002F20190817\u002F3015878257\u002F","替 Hexo NexT 增加字數統計","2019-08-17 21:51:19","Hexo",[11,5],"有時候自己會需要翻一下自己某一篇文章寫得字數以及大約閱讀所需要的時間，所以這一篇就來記錄一下該如何替 Hexo NexT 安裝字數統計以及閱讀時間吧","1",{"url":16,"title":17,"date":18,"updated":3,"category":11,"tags":19,"description":21,"readingMinutes":22},"\u002Fhexo\u002F20190703\u002F893132670\u002F","替 Hexo NexT 增加 Google AdSense","2019-07-03 11:56:01",[11,5,20],"AdSense","好久不見的 Hexo 改動文章，這次要來介紹如何申請 Google AdSense，但是主要會介紹如何修改及部分申請而已，因為我已經有申請過 Google AdSense 啦~","2",{"url":24,"title":25,"date":26,"updated":3,"category":11,"tags":27,"description":29,"readingMinutes":14},"\u002Fhexo\u002F20190518\u002F3303379172\u002F","Hexo Next 加入 FB 留言版","2019-05-18 10:07:05",[11,5,28],"FB Comment","首先必須要先建立應用程式 FB sdk。",{"url":31,"title":32,"date":33,"updated":3,"category":11,"tags":34,"description":35,"readingMinutes":14},"\u002Fhexo\u002F20190516\u002F2710757554\u002F","NexT分類與標籤頁不要有留言板(Disqus)","2019-05-16 11:09:29",[11,5],"雖然 NexT 模板是一個非常棒的模板，但是有些地方卻很奇怪，例如 tage 及 categories 竟然會出現 Disqus 留言版，所以這邊紀錄一下該如何修改 tage 及 categories 不要出現 Disqus 留言版。",{"url":37,"title":38,"date":39,"updated":3,"category":11,"tags":40,"description":41,"readingMinutes":42},"\u002Fhexo\u002F20190514\u002F1899427194\u002F","NexT 實用的設定與功能","2019-05-14 16:20:41",[11,5],"這邊紀錄一下我的 NexT 修改了那些地方及一些不錯的插件安裝。","3",{"url":44,"title":45,"date":46,"updated":3,"category":11,"tags":47,"description":49,"readingMinutes":42},"\u002Fhexo\u002F20190514\u002F2072033203\u002F","Hexo搜尋引擎優化","2019-05-14 08:38:25",[11,48,5],"SEO","由於自己架設計部落格之後凡事都要自己來，所以這邊紀錄一下該如何加強 Hexo 的 SEO 部分。",16,2,{"postCount":53,"tagCount":54},1035,1009,17840204037