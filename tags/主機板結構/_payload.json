[{"data":1,"prerenderedAt":24},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E4%B8%BB%E6%A9%9F%E6%9D%BF%E7%B5%90%E6%A7%8B\u002F":3,"tag-page:zh-Hant:主機板結構:1":4,"author-stats:zh-Hant:full":21},null,{"tag":5,"slug":5,"posts":6,"total":20,"totalPages":20},"主機板結構",[7],{"url":8,"title":9,"date":10,"updated":11,"category":12,"tags":13,"description":18,"readingMinutes":19},"\u002Flearnexp\u002F20250903\u002F827596012\u002F","【Day 3】主機板上的迷宮探險：打開電腦殼的第一次震撼教育","2025-09-03 00:00:01","2026-05-07 21:00:00","學習經驗",[14,15,5,16,17],"Code Review 我的青春：從『嗶』聲開啟我的軟體工程師之路","電腦硬體入門","Flash 遊戲回憶","Windows 98","我爸從公司搬了一台電腦回來，我人生的第一台電腦就此誕生。從興奮到摸不著頭緒，再到電腦壞掉，我第一次打開機殼，進入那個叫「主機板」的神祕世界——也開始理解電腦裡的內臟構造，從 CPU 到 RAM、從硬碟到電源供應器，每個零件都是我未來工程人生的起點。","5",1,{"postCount":22,"tagCount":23},1035,1009,1784011735525]