[{"data":1,"prerenderedAt":64},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FSCSS\u002F":3,"tag-page:zh-Hant:SCSS:1":4,"author-stats:zh-Hant:full":61},null,{"tag":5,"slug":5,"posts":6,"total":59,"totalPages":60},"SCSS",[7,16,27,34,40,47,53],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002FSCSS\u002F20251123\u002F3919803484\u002F","SCSS 棄用 @import？！","2025-11-23 15:32:01",[5,12,13],"Sass","Dart Sass","這幾天維護老舊專案順便把老舊專案升級上去，卻出現一個錯誤訊息「Deprecation Warning [import] Sass @import rules are deprecated and will be removed in Dart Sass 3.0.0.」，所以這一篇就順便來記錄一下該如何解決吧。","3",{"url":17,"title":18,"date":19,"updated":3,"category":20,"tags":21,"description":25,"readingMinutes":26},"\u002Fgulp\u002F20190610\u002F3711816905\u002F","這是在講 Gulp 不是飲料是任務自動化工具這件事：安裝 SCSS 篇","2019-06-10 16:18:14","Gulp",[20,5,22,23,24],"Node.js","Gulp 4","這是在講 Gulp 不是飲料是任務自動化工具這件事","前面大致上也已經學會基礎的語法，接下來要來講講該如何替自己的 Gulp 加入 Sass\u002FSCSS 處理吧!","2",{"url":28,"title":29,"date":30,"updated":3,"category":5,"tags":31,"description":33,"readingMinutes":26},"\u002FSCSS\u002F20190421\u002F968240674\u002F","SCSS學習-mixin(五)","2019-04-21 07:24:30",[5,32],"SCSS 學習手冊","前一篇主要講解 @import 使用方式，這篇會慢慢結合前面所寫的教學來統整製作，接下來將會講解 mixin，mixin 又是什麼呢?我會把它當作一個 SCSS 資料庫，因為這裡面會放很多自己常用的 SCSS",{"url":35,"title":36,"date":37,"updated":3,"category":5,"tags":38,"description":39,"readingMinutes":26},"\u002FSCSS\u002F20190419\u002F947541843\u002F","SCSS學習-import(四)","2019-04-19 17:24:30",[5,32],"SCSS 中有提供一個 @import 功能，如果使用的妥當就可以開發上管理的方便。",{"url":41,"title":42,"date":43,"updated":3,"category":5,"tags":44,"description":45,"readingMinutes":46},"\u002FSCSS\u002F20190418\u002F2434021097\u002F","SCSS學習-運算子(三)","2019-04-18 17:24:30",[5,32],"預算子?加減乘除嗎? CSS 中也有提供運算子的功能，所謂的運算子就是 加(+)、 減(-)、 乘(*)、 除(\u002F)。","1",{"url":48,"title":49,"date":50,"updated":3,"category":5,"tags":51,"description":52,"readingMinutes":26},"\u002FSCSS\u002F20190417\u002F2961076508\u002F","SCSS學習-變數($)(二)","2019-04-17 12:45:50",[5,32],"從這篇開始就不會講到 SASS，讓我們來專心地了解一下如何基礎學會 SCSS。",{"url":54,"title":55,"date":56,"updated":3,"category":5,"tags":57,"description":58,"readingMinutes":26},"\u002FSCSS\u002F20190416\u002F4026443340\u002F","SCSS學習-前言(一)","2019-04-16 20:03:12",[5,32],"首先感謝六角學院- 廖洧杰校長所撰寫的 \"30天掌握 SASS 語法\" 這篇文章讓學習 SCSS 的我一直回頭學習，實在可以堪稱葵花寶典阿!!",7,1,{"postCount":62,"tagCount":63},1035,1009,1784012811653]