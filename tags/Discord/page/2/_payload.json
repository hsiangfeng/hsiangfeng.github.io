[{"data":1,"prerenderedAt":37},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FDiscord\u002Fpage\u002F2\u002F":3,"tag-page:zh-Hant:Discord:2":4,"author-stats:zh-Hant:full":34},null,{"tag":5,"slug":5,"posts":6,"total":32,"totalPages":33},"Discord",[7,16,26],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":14,"readingMinutes":15},"\u002Fother\u002F20211030\u002F2067528825\u002F","快速入門 Discord 社群通訊軟體","2021-10-30 00:07:55","雜談",[13,5],"Slack","這陣子陸續開始轉移到 Discord 使用，原本是常駐在 Slack 上，所以就寫一篇當作 Discord 的基礎操作教學吧。","3",{"url":17,"title":18,"date":19,"updated":20,"category":11,"tags":21,"description":24,"readingMinutes":25},"\u002Fother\u002F20211013\u002F4225269670\u002F","一篇教你輕鬆取得自己的 Discord ID","2021-10-13 13:12:46","2026-05-12 09:00:00",[5,22,23],"開發者模式","手機版","最近正在開發 Discord Bot 的時候發現，Discord 要取得個人的 User ID 有點麻煩且特別，而且時常會有人搞錯，所以特別來寫一篇介紹說明一下該如何正確取得，而這一篇也會包含手機版的取得方式。","2",{"url":27,"title":28,"date":29,"updated":20,"category":11,"tags":30,"description":31,"readingMinutes":25},"\u002Fother\u002F20210721\u002F186299455\u002F","Discord 身分組機器人完整教學：邀請連結自動分配身份組（Carl-bot 實作）","2021-07-21 20:49:28",[5],"想讓朋友點特定 Discord 邀請連結進來就自動拿到對應身份組？這一篇用 Invite-Role Bot（前身 Carl-bot）手把手設置：建立邀請連結、 綁定身份組、自動分配的完整流程。",13,2,{"postCount":35,"tagCount":36},1035,1009,1784020402144]