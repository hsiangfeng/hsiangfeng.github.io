[{"data":1,"prerenderedAt":80},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E3%80%8ANode-js-%E4%B8%8D%E8%B2%A0%E8%B2%AC%E7%B3%BB%E5%88%97%EF%BC%9A%E6%8A%8A%E5%89%8D%E7%AB%AF%E4%BA%BA%E5%93%A1%E7%95%B6%E4%BD%9C%E5%BE%8C%E7%AB%AF%E4%BE%86%E7%94%A8%EF%BC%8C%E5%B0%B1%E7%AE%97%E6%98%AF%E5%89%8D%E7%AB%AF%E4%B9%9F%E8%83%BD%E5%98%97%E8%A9%A6%E5%AF%AB%E7%9A%84%E5%BE%8C%E7%AB%AF%EF%BD%9E%E5%8E%9F%E4%BE%86-Node-js-%E5%8F%AF%E4%BB%A5%E5%81%9A%E9%80%99%E9%BA%BC%E5%A4%9A%E4%BA%8B%EF%BD%9E%E3%80%8B\u002Fpage\u002F3\u002F":3,"tag-page:zh-Hant:《Node-js-不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來-Node-js-可以做這麼多事～》:3":4,"author-stats:zh-Hant:full":77},null,{"tag":5,"slug":6,"posts":7,"total":75,"totalPages":76},"《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","《Node-js-不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來-Node-js-可以做這麼多事～》",[8,17,23,29,36,42,49,55,62,69],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fnodejs\u002F20230925\u002F3347882734\u002F","Day11 - Express 與 Mongoose","2023-09-25 00:00:01","Nodejs",[14,5],"Node.js","在上一篇文章中，我們初步建立了 MongoDB Atlas 的帳號，並且快速認識了 Mongoose，接下來當然就是要來整合再一起啦～","5",{"url":18,"title":19,"date":20,"updated":20,"category":12,"tags":21,"description":22,"readingMinutes":16},"\u002Fnodejs\u002F20230924\u002F3283299199\u002F","Day10 - MongoDB 與 Mongoose","2023-09-24 00:00:01",[14,5],"前一篇我們初步對於資料庫有了一點概念後，接下來當然要進入資料庫章節啦～",{"url":24,"title":25,"date":26,"updated":26,"category":12,"tags":27,"description":28,"readingMinutes":16},"\u002Fnodejs\u002F20230923\u002F264010765\u002F","Day9 - What is a database？","2023-09-23 00:00:01",[14,5],"對於一個網站或者服務來講，資料庫是不可或缺的一個元素，那麼什麼是資料庫呢？接下來我們就來聊聊什麼是資料庫。",{"url":30,"title":31,"date":32,"updated":32,"category":12,"tags":33,"description":34,"readingMinutes":35},"\u002Fnodejs\u002F20230922\u002F299784561\u002F","Day8 - 再續 Express.js","2023-09-22 00:00:01",[14,5],"前面我們介紹了 Express 以及 Middleware 的概念，這一篇我們將會繼續介紹 Express.js。","6",{"url":37,"title":38,"date":39,"updated":39,"category":12,"tags":40,"description":41,"readingMinutes":35},"\u002Fnodejs\u002F20230921\u002F766511846\u002F","Day7 - Web Framework to Express.js","2023-09-21 00:00:01",[14,5],"前一篇我們嘗試用 Node.js 建立了 HTTP API，我相信你應該學到相當的多，但是實戰上來講，我們並不會直接使用 Node.js 來建立 HTTP API，因為這樣會太麻煩了，因此我們會使用一些框架來幫助我們建立 HTTP API，而這邊我們就來介紹一個非常熱門的框架，也就是 Express.js。",{"url":43,"title":44,"date":45,"updated":45,"category":12,"tags":46,"description":47,"readingMinutes":48},"\u002Fnodejs\u002F20230920\u002F2057349059\u002F","Day6 - 建立 HTTP API","2023-09-20 00:00:01",[14,5],"接下來這一篇我們將會來嘗試用純 Node.js 建立 HTTP API，基本上會使用到前面的知識點，所以前面的許多知識點都非常的重要唷～","8",{"url":50,"title":51,"date":52,"updated":52,"category":12,"tags":53,"description":54,"readingMinutes":35},"\u002Fnodejs\u002F20230919\u002F1426601281\u002F","Day5 - Node.js Modules","2023-09-19 00:00:01",[14,5],"前一篇我們認識了一些內置模組，接下來這一篇我們要來認識一個有點特別但又好像不怎麼特別的 Modules",{"url":56,"title":57,"date":58,"updated":58,"category":12,"tags":59,"description":60,"readingMinutes":61},"\u002Fnodejs\u002F20230918\u002F3279535859\u002F","Day4 - Node.js 內置模組","2023-09-18 00:00:01",[14,5],"上一篇我們講了一大推東西，終於撰寫了第一個簡單的 Node.js 專案（雖然範例是透過 Node.js 官方提供的），接下來我們會針對 Node.js 的內置模組來做一些介紹。","10",{"url":63,"title":64,"date":65,"updated":65,"category":12,"tags":66,"description":67,"readingMinutes":68},"\u002Fnodejs\u002F20230917\u002F3753839802\u002F","Day3 - 第一個 Node.js 專案","2023-09-17 00:00:01",[14,5],"花了兩天現在才正要準備進入建立第一個 Node.js 專案，但是我相信你對於 Node.js 的基本觀念都有一定的了解了，所以我們也可以比較放心的開始建立第一個 Node.js 專案。","7",{"url":70,"title":71,"date":72,"updated":72,"category":12,"tags":73,"description":74,"readingMinutes":16},"\u002Fnodejs\u002F20230916\u002F1389040602\u002F","Day2 - Node.js 基礎","2023-09-16 00:00:01",[14,5],"前一篇我們終於認識並透過 Node.js 安裝管理工具安裝 Node.js，接下來就要來認識一下一些 Node.js 的基礎囉。",31,4,{"postCount":78,"tagCount":79},1035,1009,1784010313610]