[{"data":1,"prerenderedAt":80},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E3%80%8ANode-js-%E4%B8%8D%E8%B2%A0%E8%B2%AC%E7%B3%BB%E5%88%97%EF%BC%9A%E6%8A%8A%E5%89%8D%E7%AB%AF%E4%BA%BA%E5%93%A1%E7%95%B6%E4%BD%9C%E5%BE%8C%E7%AB%AF%E4%BE%86%E7%94%A8%EF%BC%8C%E5%B0%B1%E7%AE%97%E6%98%AF%E5%89%8D%E7%AB%AF%E4%B9%9F%E8%83%BD%E5%98%97%E8%A9%A6%E5%AF%AB%E7%9A%84%E5%BE%8C%E7%AB%AF%EF%BD%9E%E5%8E%9F%E4%BE%86-Node-js-%E5%8F%AF%E4%BB%A5%E5%81%9A%E9%80%99%E9%BA%BC%E5%A4%9A%E4%BA%8B%EF%BD%9E%E3%80%8B\u002Fpage\u002F2\u002F":3,"tag-page:zh-Hant:《Node-js-不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來-Node-js-可以做這麼多事～》:2":4,"author-stats:zh-Hant:full":77},null,{"tag":5,"slug":6,"posts":7,"total":75,"totalPages":76},"《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","《Node-js-不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來-Node-js-可以做這麼多事～》",[8,17,24,30,36,43,49,57,63,69],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":15,"readingMinutes":16},"\u002Fnodejs\u002F20231005\u002F1512925992\u002F","Day21 - Discord 基礎","2023-10-05 00:00:01","Nodejs",[14,5],"Node.js","在前一篇我們準備好了 Discord 基本的一些東西與設定，接下來當然要繼續聊 Discord 的部分囉～","4",{"url":18,"title":19,"date":20,"updated":20,"category":12,"tags":21,"description":22,"readingMinutes":23},"\u002Fnodejs\u002F20231004\u002F1031795777\u002F","Day20 - Discord Bot？","2023-10-04 00:00:01",[14,5],"除了爬蟲之外，Node.js 可以做的事情其實非常多，所以接下來將會介紹一些其他的應用的實作，也就是 Bot。","3",{"url":25,"title":26,"date":27,"updated":27,"category":12,"tags":28,"description":29,"readingMinutes":16},"\u002Fnodejs\u002F20231003\u002F1830434204\u002F","Day19 - Crontab + Node.js","2023-10-03 00:00:01",[14,5],"前一篇我們對於 Crontab 已經有一個基本的概念，接下來當然要套用到實戰上，不然認識了也沒用，所以這一篇我們就來實作一個 Crontab + Node.js 的範例。",{"url":31,"title":32,"date":33,"updated":33,"category":12,"tags":34,"description":35,"readingMinutes":23},"\u002Fnodejs\u002F20231002\u002F2297973079\u002F","Day18 - 初識 Crontab","2023-10-02 00:00:01",[14,5],"看到現在，你也應該學了不少知識了，你應該會發現有些系統好像都會「自動」去做某些事情，所以接下來將會來介紹例行性工作排程 (crontab) 這個東西。",{"url":37,"title":38,"date":39,"updated":39,"category":12,"tags":40,"description":41,"readingMinutes":42},"\u002Fnodejs\u002F20231001\u002F2119244773\u002F","Day17 - 續談爬蟲（下）","2023-10-01 00:00:01",[14,5],"這一篇將會接續前一篇的文章內容，繼續把前一篇沒講完的爬蟲內容給補完。","6",{"url":44,"title":45,"date":46,"updated":46,"category":12,"tags":47,"description":48,"readingMinutes":42},"\u002Fnodejs\u002F20230930\u002F4076915411\u002F","Day16 - 續談爬蟲（上）","2023-09-30 00:00:01",[14,5],"接下來這一篇也是針對爬蟲來介紹，但是會去撈一些比較複雜的資料。",{"url":50,"title":51,"date":52,"updated":53,"category":12,"tags":54,"description":55,"readingMinutes":56},"\u002Fnodejs\u002F20230929\u002F3878806252\u002F","Day15 - 第一個爬蟲","2023-09-29 00:00:01","2023-11-19 00:00:01",[14,5],"前一篇我們對於爬蟲應該有一些基本的概念與認知了，接下來當然就是要來實作一下囉。","5",{"url":58,"title":59,"date":60,"updated":60,"category":12,"tags":61,"description":62,"readingMinutes":23},"\u002Fnodejs\u002F20230928\u002F2824059455\u002F","Day14 - 網頁爬蟲？","2023-09-28 00:00:01",[14,5],"這一篇基本上我打算輕鬆一點介紹爬蟲就好，所以這一篇的篇幅或許會比以往前面少很多，主要也是讓大腦可以輕鬆一點。",{"url":64,"title":65,"date":66,"updated":66,"category":12,"tags":67,"description":68,"readingMinutes":16},"\u002Fnodejs\u002F20230927\u002F4133508926\u002F","Day13 - 替你的 Express 戴上頭盔吧！","2023-09-27 00:00:01",[14,5],"前面介紹了 CORS 跟 Env 可以說是基本的基本，接下來要來介紹一個很特別的東西，叫做 Helmet。",{"url":70,"title":71,"date":72,"updated":72,"category":12,"tags":73,"description":74,"readingMinutes":42},"\u002Fnodejs\u002F20230926\u002F1829302614\u002F","Day12 - 關於 CORS 與 Env","2023-09-26 00:00:01",[14,5],"前一篇我們完成了 Express + Mongoose 的整合，接下來我們要來處理一些環境變數的問題，以及 CORS 的問題。",31,4,{"postCount":78,"tagCount":79},1035,1009,1784020406115]