[{"data":1,"prerenderedAt":27},["ShallowReactive",2],{"header-locale:\u002Ftags\u002FChrome-%E6%93%B4%E5%85%85%E5%A5%97%E4%BB%B6\u002F":3,"tag-page:zh-Hant:Chrome-擴充套件:1":4,"author-stats:zh-Hant:full":24},null,{"tag":5,"slug":6,"posts":7,"total":23,"totalPages":23},"Chrome 擴充套件","Chrome-擴充套件",[8],{"url":9,"title":10,"date":11,"updated":11,"category":12,"tags":13,"description":21,"readingMinutes":22},"\u002Fother\u002F20260511\u002F5847291063\u002F","RSS 是什麼？為什麼 2026 年了還要用 RSS？順便聊聊我自己寫的 Chrome 擴充套件 Raydar","2026-05-11 14:00:00","雜談",[14,15,16,17,5,18,19,20],"RSS","Atom","RSS Reader","Raydar","訂閱","資訊管理","OPML","這篇從 RSS 是什麼、跟訂閱電子報差在哪裡、為什麼 2026 年了還值得用 RSS、跟演算法推送的差異、Atom 是什麼，一路聊到我自己寫了一個 Chrome RSS 閱讀器擴充套件 Raydar，包含 RSS 自動偵測、一鍵訂閱、三種閱讀模式、本地優先儲存、無帳戶、OPML 匯入匯出、JSON 備份、鍵盤快捷鍵等功能，最後也會說明怎麼裝跟為什麼會想自己刻一個。","7",1,{"postCount":25,"tagCount":26},1035,1009,1784012809211]