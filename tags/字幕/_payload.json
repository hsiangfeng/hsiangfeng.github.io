[{"data":1,"prerenderedAt":28},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E5%AD%97%E5%B9%95\u002F":3,"tag-page:zh-Hant:字幕:1":4,"author-stats:zh-Hant:full":25},null,{"tag":5,"slug":5,"posts":6,"total":23,"totalPages":24},"字幕",[7,16],{"url":8,"title":9,"date":10,"updated":3,"category":11,"tags":12,"description":14,"readingMinutes":15},"\u002Fpython\u002F20190626\u002F2933081730\u002F","拖曳影片檔案到 CMD 圖示內透過 Python 生成影片字幕","2019-06-26 10:13:30","Python",[11,13,5],"AI","由於先前撰寫了[使用 Python 替影片自動上字幕]的文章，後來自己在使用的時候每一次都要打開指令視窗輸入指令，對於金魚腦的我來講實在很不方便，所以這邊稍微製作 .bat 檔案，直接拖曳進去自動生成字幕。","1",{"url":17,"title":18,"date":19,"updated":3,"category":11,"tags":20,"description":21,"readingMinutes":22},"\u002Fpython\u002F20190531\u002F4077454772\u002F","使用 Python 替影片自動產生字幕 srt 檔","2019-05-31 10:44:35",[11,13,5],"有時候我們要替影片上字幕是滿麻煩的事情，因為必須重複地聽才能夠抓出時間區段，但是如果透過工具先幫我們抓出 50% 字幕區間，然後在來做調整，這樣一定會比較準確，所以這邊做一下筆記該如何使用這個套件。","2",2,1,{"postCount":26,"tagCount":27},1035,1009,1784012813425]