[{"data":1,"prerenderedAt":25},["ShallowReactive",2],{"header-locale:\u002Ftags\u002F%E6%89%8B%E6%A9%9F\u002F":3,"tag-page:zh-Hant:手機:1":4,"author-stats:zh-Hant:full":22},null,{"tag":5,"slug":5,"posts":6,"total":21,"totalPages":21},"手機",[7],{"url":8,"title":9,"date":10,"updated":10,"category":11,"tags":12,"description":19,"readingMinutes":20},"\u002Fother\u002F20260502\u002F1592048371\u002F","手機摔壞照片就沒了？拜託先去開 Google 相簿備份（iPhone 完整設定教學）","2026-05-02 00:00:00","雜談",[13,14,15,5,16,17,18],"Google 相簿","備份","雲端","iPhone","iOS","Google Photos","手機摔壞、掉到水裡、突然開不了機，這時候裡面的照片其實是最難救回來的東西。這篇就分享為什麼我會推薦把 Google 相簿備份打開，並且實際示範 iPhone 上的設定流程，包含備份畫質的選擇、15GB 免費空間怎麼用、行動數據備份要不要打開，以及 iOS 上很容易踩到的坑 — 把 APP 從多工列滑掉備份就會中斷。","4",1,{"postCount":23,"tagCount":24},1035,1009,1784011735938]