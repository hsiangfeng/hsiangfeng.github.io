38,"line":165},23,[36,167,168],{},"COPY --from=builder \u002Froot\u002F.volta \u002Froot\u002F.volta\n",[36,170,172],{"class":38,"line":171},24,[36,173,174],{},"COPY --from=builder \u002Fapp \u002Fapp\n",[36,176,178],{"class":38,"line":177},25,[36,179,49],{"emptyLinePlaceholder":48},[36,181,183],{"class":38,"line":182},26,[36,184,107],{},[36,186,188],{"class":38,"line":187},27,[36,189,118],{},[36,191,193],{"class":38,"line":192},28,[36,194,84],{},[36,196,198],{"class":38,"line":197},29,[36,199,49],{"emptyLinePlaceholder":48},[36,201,203],{"class":38,"line":202},30,[36,204,205],{},"CMD [ \"npm\", \"run\", \"start\" ]\n",[16,207,208,209,216,217,221],{},"這一份來源是我先前分享的開源專案 ",[210,211,215],"a",{"href":212,"rel":213},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fhermione",[214],"nofollow","妙麗·格蘭傑"," 的範例，如果你好奇的話，可以參考這一篇文章 ",[210,218,220],{"href":219},"\u002Fnodejs\u002F20221215\u002F2411869749\u002F","用 OpenAI GPT-3 建立一個 Discord 聊天機器人","。",[16,223,224,225,229],{},"那麼拉回正題，這邊我們要做的事情就是去替這些指令增加註解描述說明，底下我也會附上答案，所以你可以自己嘗試補上註解描述一下每一行在做的行為，當然你可能會看不懂部分指令，因為這一份 Dockerfile 有使用到一些我們之前沒有提過的指令，而且這事由 ",[210,226,228],{"href":227},"\u002Fother\u002F20221216\u002F786812101\u002F","fly.io"," 自動生成的，所以部分指令可能看不懂是正常的。",[16,231,232],{},"如果沒有問題的話，你就來試試看吧！",[16,234,235],{},"底下這邊我也附上我的解答",[12,237,238],{"id":238},"作業解答",[26,240,242],{"className":28,"code":241,"language":30,"meta":31,"style":31},"# 指定使用環境基底為 Debian，並將環境名稱指定為 builder\nFROM debian:bullseye as builder\n\n# 建立一個 Docker 變數名稱為 NODE_VERSION 並版本是 16.15.0\nARG NODE_VERSION=16.15.0\n\n# 執行更新套件並安裝 CURL\nRUN apt-get update; apt install -y curl\n\n# 執行 CURL 指令下載 Volta 安裝腳本\nRUN curl https:\u002F\u002Fget.volta.sh | bash\n\n# 建立一個環境變數名稱為 VOLTA_HOME 並指定為 \u002Froot\u002F.volta\nENV VOLTA_HOME \u002Froot\u002F.volta\n\n# 建立一個環境變數名稱為 PATH 並指定為 \u002Froot\u002F.volta\u002Fbin:$PATH\nENV PATH \u002Froot\u002F.volta\u002Fbin:$PATH\n\n# 執行 Volta 安裝 Node.js 版本為 16.15.0\nRUN volta install node@${NODE_VERSION}\n\n# 建立一個目錄名稱為 \u002Fapp\nRUN mkdir \u002Fapp\n\n# 指定工作目錄為 \u002Fapp\nWORKDIR \u002Fapp\n\n# 建立一個環境變數名稱為 NODE_ENV 並指定為 production\nENV NODE_ENV production\n\n# 複製當前目錄下的所有檔案到 \u002Fapp\nCOPY . .\n\n# 執行 npm install\nRUN npm install\n\n# 指定使用環境基底為 Debian\nFROM debian:bullseye\n\n# 建立一個 LABEL 名稱為 fly_launch_runtime 並指定為 nodejs\nLABEL fly_launch_runtime=\"nodejs\"\n\n# 複製 builder 環境下的 \u002Froot\u002F.volta 到 \u002Froot\u002F.volta\nCOPY --from=builder \u002Froot\u002F.volta \u002Froot\u002F.volta\n\n# 複製 builder 環境下的 \u002Fapp 到 \u002Fapp\nCOPY --from=builder \u002Fapp \u002Fapp\n\n# 指定工作目錄為 \u002Fapp\nWORKDIR \u002Fapp\n\n# 建立一個環境變數名稱為 NODE_ENV 並指定為 production\nENV NODE_ENV production\n\n# 建立一個環境變數名稱為 PATH 並指定為 \u002Froot\u002F.volta\u002Fbin:$PATH\nENV PATH \u002Froot\u002F.volta\u002Fbin:$PATH\n\n# 執行 npm run start\nCMD [ \"npm\", \"run\", \"start\" ]\n",[33,243,244,249,253,257,262,266,270,275,279,283,288,292,296,301,305,309,314,318,322,327,331,335,340,344,348,353,357,361,366,370,374,380,385,390,396,401,406,412,417,422,428,433,438,444,449,454,460,465,470,475,480,485,490,495,500,505,510,515,521],{"__ignoreMap":31},[36,245,246],{"class":38,"line":39},[36,247,248],{},"# 指定使用環境基底為 Debian，並將環境名稱指定為 builder\n",[36,250,251],{"class":38,"line":45},[36,252,42],{},[36,254,255],{"class":38,"line":52},[36,256,49],{"emptyLinePlaceholder":48},[36,258,259],{"class":38,"line":58},[36,260,261],{},"# 建立一個 Docker 變數名稱為 NODE_VERSION 並版本是 16.15.0\n",[36,263,264],{"class":38,"line":63},[36,265,55],{},[36,267,268],{"class":38,"line":69},[36,269,49],{"emptyLinePlaceholder":48},[36,271,272],{"class":38,"line":75},[36,273,274],{},"# 執行更新套件並安裝 CURL\n",[36,276,277],{"class":38,"line":81},[36,278,66],{},[36,280,281],{"class":38,"line":87},[36,282,49],{"emptyLinePlaceholder":48},[36,284,285],{"class":38,"line":93},[36,286,287],{},"# 執行 CURL 指令下載 Volta 安裝腳本\n",[36,289,290],{"class":38,"line":98},[36,291,72],{},[36,293,294],{"class":38,"line":104},[36,295,49],{"emptyLinePlaceholder":48},[36,297,298],{"class":38,"line":110},[36,299,300],{},"