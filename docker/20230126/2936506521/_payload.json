80,81],{},"docker restart","：重新啟動 Docker 容器",[32,84,86,41,88,91],{"className":85},[35],[37,87],{"disabled":39,"type":40},[43,89,90],{},"docker ps","：查看 Docker 容器列表",[32,93,95,41,97,100],{"className":94},[35],[37,96],{"disabled":39,"type":40},[43,98,99],{},"docker exec","：進入 Docker 容器",[32,102,104,41,106,109],{"className":103},[35],[37,105],{"disabled":39,"type":40},[43,107,108],{},"docker logs","：查看 Docker 容器的日誌",[16,111,112],{},"(打勾的代表我們已經介紹過了，沒打勾的代表我們還沒介紹過)",[16,114,115],{},"接下來將會來介紹還沒介紹過的指令。",[12,117,81],{"id":118},"docker-restart",[16,120,121],{},"這個指令相對簡單，其實就只是重新啟動 Docker 容器",[123,124,129],"pre",{"className":125,"code":126,"language":127,"meta":128,"style":128},"language-bash shiki shiki-themes github-dark-high-contrast","docker restart [container name]\n","bash","",[43,130,131],{"__ignoreMap":128},[132,133,136,140,144,148],"span",{"class":134,"line":135},"line",1,[132,137,139],{"class":138},"s_sBn","docker",[132,141,143],{"class":142},"sTRMh"," restart",[132,145,147],{"class":146},"sMAXC"," [container ",[132,149,150],{"class":142},"name]\n",[16,152,153,154,157],{},"假使容器 ID 是 ",[43,155,156],{},"00c86b3fe0ca","，那麼就可以這樣使用",[123,159,161],{"className":125,"code":160,"language":127,"meta":128,"style":128},"docker restart 00c86b3fe0ca\n",[43,162,163],{"__ignoreMap":128},[132,164,165,167,169],{"class":134,"line":135},[132,166,139],{"class":138},[132,168,143],{"class":142},[132,170,171],{"class":142}," 00c86b3fe0ca\n",[16,173,174],{},"這樣子就可以重新啟動容器。",[12,176,90],{"id":177},"docker-ps",[16,179,180],{},"這個指令在前面我們有稍微使用過，它可以查看 Docker 容器列表",[123,182,184],{"className":125,"code":183,"language":127,"meta":128,"style":128},"docker ps [options]\n",[43,185,186],{"__ignoreMap":128},[132,187,188,190,193],{"class":134,"line":135},[132,189,139],{"class":138},[132,191,192],{"class":142}," ps",[132,194,195],{"class":146}," [options]\n",[16,197,198,199,201,202,205],{},"請注意，再輸入這個指令時，如果你只是單純的輸入 ",[43,200,90],{},"，那麼你只會看到正在運行的容器，如果你想要看到所有的容器，那麼你可以加上 ",[43,203,204],{},"-a"," 這個參數",[123,207,209],{"className":125,"code":208,"language":127,"meta":128,"style":128},"docker ps -a\n",[43,210,211],{"__ignoreMap":128},[132,212,213,215,217],{"class":134,"line":135},[132,214,139],{"class":138},[132,216,192],{"class":142},[132,218,220],{"class":219},"sCcAr"," -a\n",[16,222,223],{},"這樣子就可以看到包含啟動與停止的容器，否則一般狀況下只會看到正在運行的容器。",[16,225,226,227,229,230,232,233,235,236,243],{},"當然 ",[43,228,90],{}," 除了 ",[43,231,204],{}," 之外還有許多參數可以使用，而這邊我們就只介紹 ",[43,234,204],{}," 這個參數，其他的參數可以參考 ",[237,238,242],"a",{"href":239,"rel":240},"https:\u002F\u002Fdocs.docker.com\u002Fengine\u002Freference\u002Fcommandline\u002Fps\u002F",[241],"nofollow","Docker 官方文件","。",[12,245,99],{"id":246},"docker-exec",[16,248,249],{},"這個指令可以讓我們進入已經啟動的 Docker 容器內",[123,251,253],{"className":125,"code":252,"language":127,"meta":128,"style":128},"docker exec [options] [container name] [command]\n",[43,254,255],{"__ignoreMap":128},[132,256,257,259,262],{"class":134,"line":135},[132,258,139],{"class":138},[132,260,261],{"class":142}," exec",[132,263,264],{"class":146}," [options] [container name] [command]\n",[16,266,153,267,157],{},[43,268,156],{},[123,270,272],{"className":125,"code":271,"language":127,"meta":128,"style":128},"docker exec -it 962636806cb9 \u002Fbin\u002Fbash\n",[43,273,274],{"__ignoreMap":128},[132,275,276,278,280,283,286],{"class":134,"line":135},[132,277,139],{"class":138},[132,279,261],{"class":142},[132,281,282],{"class":219}," -it",[132,284,285],{"class":142}," 962636806cb9",[132,287,288],{"class":142}," \u002Fbin\u002Fbash\n",[16,290,291,292,295,296,299,300,303,304,306,307,309,310,313,314,317],{},"上面的指令撇除 ",[43,293,294],{},"-it"," 跟 ",[43,297,298],{},"962636806cb9"," 之外，你應該會很好奇 ",[43,301,302],{},"\u002Fbin\u002Fbash"," 是什麼意思，",[43,305,302],{}," 其實是 Linux 中的終端機指令，因此當你輸入這個指令後，你就會進入到容器內的終端機當中，而這個終端機就是 ",[43,308,302],{},"，而這個環境下你就可以輸入 ",[43,311,312],{},"ls","、",[43,315,316],{},"cd"," 等等的指令。",[12,319,108],{"id":320},"docker-logs",[16,322,323],{},"這個指令可以讓我們查看 Docker 容器的日誌",[123,325,327],{"cla