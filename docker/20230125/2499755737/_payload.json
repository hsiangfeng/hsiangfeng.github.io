r 指令，接下來就來看看這些指令的使用方式吧！",[12,83,35],{"id":84},"docker-run",[16,86,87,89],{},[33,88,35],{}," 指令可以用來建立\u002F執行 Docker 容器，而這個指令的使用方式如下：",[91,92,97],"pre",{"className":93,"code":94,"language":95,"meta":96,"style":96},"language-bash shiki shiki-themes github-dark-high-contrast","docker run [OPTIONS] IMAGE[:TAG|@DIGEST] [COMMAND] [ARG...]\n","bash","",[33,98,99],{"__ignoreMap":96},[100,101,104,108,112,116,120],"span",{"class":102,"line":103},"line",1,[100,105,107],{"class":106},"s_sBn","docker",[100,109,111],{"class":110},"sTRMh"," run",[100,113,115],{"class":114},"sMAXC"," [OPTIONS] IMAGE[:TAG",[100,117,119],{"class":118},"sWyjQ","|",[100,121,122],{"class":114},"@DIGEST] [COMMAND] [ARG...]\n",[16,124,125,126,129,130,133],{},"看到這一串相信感覺到很混亂很可怕，實際上我們只需要關注兩個東西，也就是 ",[33,127,128],{},"[OPTIONS]"," 跟 ",[33,131,132],{},"IMAGE[:TAG|@DIGEST]","，而這兩個東西的意思如下：",[27,135,136,142],{},[30,137,138,141],{},[100,139,140],{},"OPTIONS"," 代表的是指令的選項，也就是我們可以在指令後面加上一些選項",[30,143,144,145,151],{},"IMAGE",[100,146,147,150],{},[148,149],"tag",{},"|@DIGEST"," 代表的是我們要使用的 Docker Image",[16,153,154,155,157,158,161,162,164],{},"接著我們要來嘗試一下 ",[33,156,35],{}," 的指令，那麼在前面我們有嘗試使用 ",[33,159,160],{},"docker pull node"," 來下載 Node.js 的 Docker Image，那麼我們就可以使用 ",[33,163,35],{}," 來建立\u002F執行 Node.js 的 Docker 容器，而指令如下：",[91,166,168],{"className":93,"code":167,"language":95,"meta":96,"style":96},"docker run -it node\n",[33,169,170],{"__ignoreMap":96},[100,171,172,174,176,180],{"class":102,"line":103},[100,173,107],{"class":106},[100,175,111],{"class":110},[100,177,179],{"class":178},"sCcAr"," -it",[100,181,182],{"class":110}," node\n",[16,184,185,186,189,190,192,193,196],{},"那麼 ",[33,187,188],{},"-it"," 是什麼呢？",[33,191,188],{}," 的意思是指我們要進入 Docker 容器的互動模式，而 ",[33,194,195],{},"node"," 則是我們要使用的 Docker Image，而這個指令的意思就是我們要進入 Node.js 的 Docker 容器的互動模式，而這個指令執行後會看到如下的畫面：",[16,198,199],{},[200,201],"img",{"alt":202,"src":203},"Node","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002Fd7QmS1O.png",[16,205,206],{},"這時候你應該就看到了我們所熟悉的 Node.js 環境了",[16,208,209,210,212],{},"那麼其實 ",[33,211,188],{}," 是兩個指令，分別是",[27,214,215,225],{},[30,216,217,220,221,224],{},[33,218,219],{},"-i","：代表的是 ",[33,222,223],{},"interactive"," 我們要進入 Docker 容器的互動模式",[30,226,227,220,230,233],{},[33,228,229],{},"-t",[33,231,232],{},"tty"," 分配一個虛擬終端機",[16,235,236,237,239],{},"通常我們會比較常使用 ",[33,238,188],{}," 就是了。",[12,241,41],{"id":242},"docker-start",[16,244,245,247],{},[33,246,41],{}," 指令可以用來啟動 Docker 容器，而這個指令的使用方式如下：",[91,249,251],{"className":93,"code":250,"language":95,"meta":96,"style":96},"docker start [OPTIONS] CONTAINER [CONTAINER...]\n",[33,252,253],{"__ignoreMap":96},[100,254,255,257,260],{"class":102,"line":103},[100,256,107],{"class":106},[100,258,259],{"class":110}," start",[100,261,262],{"class":114}," [OPTIONS] CONTAINER [CONTAINER...]\n",[16,264,265,266,268,269,271,272,274],{},"使用方式與 ",[33,267,35],{}," 有一點雷同，雖然都是啟動一個 Docker 容器，但是要注意的是 ",[33,270,35],{}," 是建立並同時啟動 Docker 容器，因此 ",[33,273,35],{}," 真正用途是用於啟動被停起的 Docker 容器。",[16,276,277,278,280,281,283],{},"什麼意思呢？當我們輸入 ",[33,279,35],{}," 的時候會去依據我們的 Docker Image 建立出一個 Docker 容器，因此如果你每一次都用 ",[33,282,35],{}," 當作啟動 Docker 的指令的話，那麼就有可能發生一些問題，其中最明顯的就是會很難管理，因此還是會建議區分一下指令較好。",[16,285,286,287,289],{},"假設你很興奮的去輸入類似 ",[33,288,35],{}," 的指令",[91,291,293],{"className":93,"code":292,"language":95,"meta":96,"style":96},"docker start -it node\n",[33,294,295],{"__ignoreMap":96},[100,296,297,299,301,303],{"class":102,"line":103},[100,298,107],{"class":106},[100,300,259],{"class":110},[100,302,179],{"class":178},[100,304,182],{"class":110},[16,306,307],{},"那麼你會接收到一段錯誤訊息",[91,309,311],{"className":93,"code":310,"language":95,"meta":96,"style":96},"unknown shorthand flag: 't' in -t\nSee 'docker start --help'.\n",[33,312,313,333],{"__ignoreMap":96},[100,314,315,318,321,324,327,330],{"class":102,"line":103},[100,316,317],{"class":106},"unknown",[100,319,320],{"class":110}," shorthand",[100,322,323],{"class":110}," flag:",[100,325,326],{"class":110}," 't'",[100,328,329],{"class":110}," in",[100,331,332],{"class":178}," -t\n",[100,334,336,339],{"class":102,"line":335},2,[100,337,338],{"class":106},"See",[100,340,341],{"class":110}," 'docker start --help'.\n",[16,343,344,345,347,348,350,351,353,354,356,357,359,360,362],{},"這是因為 ",[33,346,41],{}," 指令並沒有 ",[33,349,229],{}," 的選項，而 ",[33,352,229],{}," 的選項是用於 ",[33,355,35],{}," 的，因此我們要使用 ",[33,358,41],{}," 時就不需要 ",[33,361,229],{},"，除此之外，如果你輸入以下指令",[91,364,366],{"className":93,"code":365,"language":95,"meta":96,"style":96},"docker start -i node\n",[33,367,368],{"__ignoreMap":96},[100,369,370,372,374,377],{"class":102,"line":103},[100,371,107],{"class":106},[100,373,259],{"class":110},[100,375,376],{"class":178}," -i",[100,378,182],{"class":110},[16,380,381],{},"你也會得到以下錯誤訊息",[91,383,385],{"className":93,"code":384,"language":95,"meta":96,"style":96},"Error: No such container: node\n",[33,386,387],{"__ignoreMap":96},[100,388,389,392,395,398,401],{"class":102,"line":103},[100,390,391],{"class":106},"Error:",[100,393,394],{"class":110}," No",[100,396,397],{"class":110}," such",[100,399,400],{"class":110}," container:",[100,402,182],{"class":110},[16,404,405,406,409],{},"你可能會想說，為什麼會這樣呢？我們不是 ",[33,407,408],{},"docker pull"," node 環境了嗎？而且剛剛不是也運行起來了嗎？為什麼會找不到 node 容器呢？",[16,411,412,413,416,417,419,420,422],{},"這是因為當我們使用 ",[33,414,415],{},"docker run -it node"," 時，會建立一個新的 Docker 容器，並同時進入 Node 的互動模式，而這個 Docker 容器的名稱是隨機產生的，因此我們無法使用 ",[33,418,41],{}," 來啟動這個容器，因為 ",[33,421,41],{}," 必須帶入類似容器 ID 的東西，而不是 Image 名稱。",[16,424,425],{},"這邊稍微有一點複雜，請記住一個原則",[27,427,428,433],{},[30,429,430,432],{},[33,431,35],{},"：建立並同時啟動 Docker 容器，但是輸入的名稱會是 Docker Image 名稱",[30,434,435,437],{},[33,436,41],{},"：啟動 Docker 容器，但是名稱會是 Docker 容器 ID",[16,439,440],{},"除此之外一個是建立容器，一個是啟動容器，因此要注意指令的區分",[16,442,443,444,446,447,450],{},"那麼正確該怎麼使用 ",[33,445,41],{}," 呢？\n首先，先輸入 ",[33,448,449],{},"docker ps -a"," 來查看所有的 Docker 容器，並找到你要啟動的容器 ID",[16,452,453],{},[200,454],{"alt":449,"src":455},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002F7MC8f5g.png",[16,457,458,459,462,463,466],{},"上方圖中有一段 ",[33,460,461],{},"CONTAINER ID","，這就是我們要找的容器 ID，接著我們就可以輸入以下指令來啟動容器，請注意這個 Node 的容器在你輸入 ",[33,464,465],{},"docker start 00c86b3fe0ca"," 之後會立刻結束，因為我們沒有進入互動模式，因此正確的指令要輸入以下",[91,468,470],{"className":93,"code":469,"language":95,"meta":96,"style":96},"docker start 00c86b3fe0ca\n",[33,471,472],{"__ignoreMap":96},[100,473,474,476,478],{"class":102,"line":103},[100,475,107],{"class":106},[100,477,259],{"class":110},[100,479,480],{"class":110}," 00c86b3fe0ca\n",[16,482,483,484],{},"那我們要如何進入互動模式呢？這邊需要輸入一個還沒介紹到的指令，也就是 ",[33,485,71],{},[91,487,489],{"className":93,"code":488,"language":95,"meta":96,"style":96},"docker exec -it 00c86b3fe0ca \u002Fbin\u002Fbash\n",[33,490,491],{"__ignoreMap":96},[100,492,493,495,498,500,503],{"class":102,"line":103},[100,494,107],{"class":106},[100,496,497],{"class":110}," exec",[100,499,179],{"class":178},[100,501,502],{"class":110}," 00c86b3fe0ca",[100,504,505],{"class":110}," \u002Fbin\u002Fbash\n",[16,507,508],{},"這時候你會進入到一個很奇怪的畫面，會顯示著...",[91,510,512],{"className":93,"code":511,"language":95,"meta":96,"style":96},"root@00c86b3fe0ca:\u002F#\n",[33,513,514],{"__ignoreMap":96},[100,515,516],{"class":102,"line":103},[100,517,511],{"class":106},[16,519,520,521,524,525,528],{},"其實這是因為我們進入到了 Docker 容器中，而且是以 root 的身份，因此你可以輸入 ",[33,522,523],{},"ls"," 來查看目前的檔案，或是輸入 ",[33,526,527],{},"exit"," 來離開互動模式。",[16,530,531,532,534],{},"那麼由於我們要回到 Node 互動模式，所以接著輸入 ",[33,533,195],{}," 就可以回到 Node 的互動模式囉~",[16,536,537,538,540],{},"關於前面的 ",[33,539,71],{}," 不用怕，我們在後面章節會再來介紹。",[12,542,47],{"id":543},"docker-stop",[16,545,546,548],{},[33,547,47],{}," 是用來停止 Docker 容器的指令，只需要輸入以下指令",[91,550,552],{"className":93,"code":551,"language":95,"meta":96,"style":96},"docker stop [CONTAINER ID]\n",[33,553,554],{"__ignoreMap":96},[100,555,556,558,561,564],{"class":102,"line":103},[100,557,107],{"class":106},[100,559,560],{"class":110}," stop",[100,562,563],{"class":114}," [CONTAINER ",[100,565,566],{"class":110},"ID]\n",[16,568,569],{},"就可以停止 Docker 容器了，以前面的 Node 為例，我們可以輸入以下指令來停止 Node 容器",[91,571,573],{"className":93,"code":572,"language":95,"meta":96,"style":96},"docker stop 00c86b3fe0ca\n",[33,574,575],{"__ignoreMap":96},[100,576,577,579,581],{"class":102,"line":103},[100,578,107],{"class":106},[100,580,560],{"class":110},[100,582,480],{"class":110},[12,584,53],{"id":585},"docker-rm",[16,587,588,590],{},[33,589,53],{}," 是用來刪除 Docker 容器的指令，只需要輸入以下指令",[91,592,594],{"className":93,"code":593,"language":95,"meta":96,"style":96},"docker rm [CONTAINER ID]\n",[33,595,596],{"__ignoreMap":96},[100,597,598,600,603,605],{"class":102,"line":103},[100,599,107],{"class":106},[100,601,602],{"class":110}," rm",[100,604,563],{"class":114},[100,606,566],{"class":110},[16,608,609,610,612],{},"什麼意思呢？簡單來講就是刪除透過 ",[33,611,35],{}," 建立的 Docker 容器，以前面的 Node 為例，我們可以輸入以下指令來刪除 Node 容器",[91,614,616],{"className":93,"code":615,"language":95,"meta":96,"style":96},"docker rm 00c86b3fe0ca\n",[33,617,618],{"__ignoreMap":96},[100,619,620,622,624],{"class":102,"line":103},[100,621,107],{"class":106},[100,623,602],{"class":110},[100,625,480],{"class":110},[16,627,628],{},"超簡單的吧！",[16,630,631],{},"請注意，如果你要刪除的 Docker 容器是正在運行的，那麼就會出現以下錯誤",[91,633,635],{"className":93,"code":634,"language":95,"meta":96,"style":96},"Error response from daemon: You cannot remove a running container 00c86b3fe0ca. Stop the container before attempting removal or force remove\n",[33,636,637],{"__ignoreMap":96},[100,638,639,642,645,648,651,654,657,660,663,666,669,672,675,678,680,683,686,689,692,695],{"class":102,"line":103},[100,640,641],{"class":106},"Error",[100,643,644],{"class":110}," response",[100,646,647],{"class":110}," from",[100,649,650],{"class":110}," daemon:",[100,652,653],{"class":110}," You",[100,655,656],{"class":110}," cannot",[100,658,659],{"class":110}," remove",[100,661,662],{"class":110}," a",[100,664,665],{"class":110}," running",[100,667,668],{"class":110}," container",[100,670,671],{"class":110}," 00c86b3fe0ca.",[100,673,674],{"class":110}," Stop",[100,676,677],{"class":110}," the",[100,679,668],{"class":110},[100,681,682],{"class":110}," before",[100,684,685],{"class":110}," attempting",[100,687,688],{"class":110}," removal",[100,690,691],{"class":110}," or",[100,693,694],{"class":110}," force",[100,696,697],{"class":110}," remove\n",[16,699,700,701,704],{},"因此，如果你要刪除的 Docker 容器是正在運行的，那麼就必須先停止它(",[33,702,703],{},"docker stop 00c86b3fe0ca",")，才能刪除它",[16,706,707],{},"那麼這一篇就先到這邊，下一篇我們再繼續針對 Docker 的指令來進行介紹。",[709,710,711],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":96,"searchDepth":335,"depth":335,"links":713},[714,715,716,717,718,719],{"id":14,"depth":335,"text":14},{"id":21,"depth":335,"text":22},{"id":84,"depth":335,"text":35},{"id":242,"depth":335,"text":41},{"id":543,"depth":335,"text":47},{"id":585,"depth":335,"text":53},"2023-01-25 20:20:00","md","zh-Hant",{},true,"\u002Fdocker\u002F5-docker-docker","4",{"title":6,"description":18},false,"一步步掌握基礎 Docker\u002F5-一步步掌握基礎-Docker-Docker-常見指令",[107,731,732],"Docker Container