[{"data":1,"prerenderedAt":327},["ShallowReactive",2],{"header-locale:\u002Fdocker\u002F20220423\u002F196903828\u002F":3,"page:\u002Fdocker\u002F20220423\u002F196903828\u002F":4,"alt:\u002Fdocker\u002F20220423\u002F196903828\u002F":3,"prev-next:\u002Fdocker\u002F20220423\u002F196903828\u002F":303,"related:\u002Fdocker\u002F20220423\u002F196903828\u002F":312},"\u002Fen\u002Fdocker\u002F2022\u002F04\u002F23\u002Fdocker-denied-requested-access-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":286,"date":287,"description":288,"extension":289,"lang":290,"meta":291,"navigation":292,"path":293,"readingMinutes":294,"seo":295,"standalone":296,"stem":297,"tags":298,"tldr":300,"updated":300,"url":301,"__hash__":302},"content\u002FDocker\u002F關於-docker-出現-denied-requested-access-to-the-resource-is-denied-解決方式.md","關於 docker 出現 denied: requested access to the resource is denied 解決方式","196903828",{"type":9,"value":10,"toc":276},"minimark",[11,15,19,22,30,107,114,117,120,127,141,145,152,158,164,170,179,182,186,189,198,216,222,228,232,238,244,250,256,259,272],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近要上傳 Docker 的時候不知道為什麼一直出現「denied: requested access to the resource is denied」的錯誤訊息，所以記錄一下有哪些解決方式。",[12,20,21],{"id":21},"問題狀況",[16,23,24,25,29],{},"首先當我輸入 ",[26,27,28],"code",{},"docker push localImageName"," 的時候就會出現以下狀況",[31,32,37],"pre",{"className":33,"code":34,"language":35,"meta":36,"style":36},"language-cmd shiki shiki-themes github-dark-high-contrast","Using default tag: latest\nThe push refers to repository [docker.io\u002Flibrary\u002Ftest]\nd8deea6aacf6: Preparing \nd31b1b3688ec: Preparing \n859d050b8423: Preparing \n5f70bf18a086: Preparing \n9164c306cc0a: Preparing \n8396c878c66c: Waiting \n3ee39e78fd25: Waiting \n138331e9552c: Waiting \ndenied: requested access to the resource is denied\n","cmd","",[26,38,39,47,53,59,65,71,77,83,89,95,101],{"__ignoreMap":36},[40,41,44],"span",{"class":42,"line":43},"line",1,[40,45,46],{},"Using default tag: latest\n",[40,48,50],{"class":42,"line":49},2,[40,51,52],{},"The push refers to repository [docker.io\u002Flibrary\u002Ftest]\n",[40,54,56],{"class":42,"line":55},3,[40,57,58],{},"d8deea6aacf6: Preparing \n",[40,60,62],{"class":42,"line":61},4,[40,63,64],{},"d31b1b3688ec: Preparing \n",[40,66,68],{"class":42,"line":67},5,[40,69,70],{},"859d050b8423: Preparing \n",[40,72,74],{"class":42,"line":73},6,[40,75,76],{},"5f70bf18a086: Preparing \n",[40,78,80],{"class":42,"line":79},7,[40,81,82],{},"9164c306cc0a: Preparing \n",[40,84,86],{"class":42,"line":85},8,[40,87,88],{},"8396c878c66c: Waiting \n",[40,90,92],{"class":42,"line":91},9,[40,93,94],{},"3ee39e78fd25: Waiting \n",[40,96,98],{"class":42,"line":97},10,[40,99,100],{},"138331e9552c: Waiting \n",[40,102,104],{"class":42,"line":103},11,[40,105,106],{},"denied: requested access to the resource is denied\n",[16,108,109],{},[110,111],"img",{"alt":112,"src":113},"requested access to the resource is denied","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202022-04-23%2021.51.26.png",[12,115,116],{"id":116},"解決方向",[16,118,119],{},"接下來這邊就稍微記錄一下全部的解決流程。",[16,121,122,123,126],{},"首先我們在上傳 Docker Image 到 DockerHub 的時候指令通常是 ",[26,124,125],{},"docker push","，而若你要上傳你的 image 的話則必須是 username\u002Fimages。",[16,128,129,130,133,134,136,137,140],{},"舉例來講你的 local image 可能叫做 test，而你 DockerHub 可能是 ",[26,131,132],{},"hsiangfeng","，那麼在輸入 ",[26,135,125],{}," 的時候就要打 ",[26,138,139],{},"docker push hsiangfeng\u002Ftest","，所以接下來繼續紀錄 Docker denied: requested access to the resource is denied 錯誤訊息幫。",[142,143,144],"h3",{"id":144},"登入狀態",[16,146,147,148,151],{},"首先可以先試著輸入 ",[26,149,150],{},"docker login"," 確定自己 Docker 帳號是否已經登入成功並驗證通過",[16,153,154],{},[110,155],{"alt":156,"src":157},"Login Succeeded","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202022-04-23%2021.53.12.png",[16,159,160,161],{},"如果有登入的話，可以先試著登出在登入 ",[26,162,163],{},"docker logout",[16,165,166],{},[110,167],{"alt":168,"src":169},"logout","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202022-04-23%2021.55.08.png",[16,171,172,173,175,176,178],{},"接下來再重新登入 ",[26,174,150],{}," 再去重新 ",[26,177,28],{},"。",[16,180,181],{},"滿多人都說這個時候就可以解決了。",[142,183,185],{"id":184},"tag-name-忘記改","tag name 忘記改",[16,187,188],{},"有一種特殊狀況是自己忘記改 tag name，因為 Docker 是用 tag 去辨別上傳的，因此遠端的 DockerHub 帳號必須與 local Image Name 相同，假設你的 local Image Name 叫做 test，那麼就要輸入以下指令改成以下",[31,190,192],{"className":33,"code":191,"language":35,"meta":36,"style":36},"docker tag test username\u002Ftest\n",[26,193,194],{"__ignoreMap":36},[40,195,196],{"class":42,"line":43},[40,197,191],{},[16,199,200,201,203,204,207,208,211,212,215],{},"以我的 DockerHub 帳號是「",[26,202,132],{},"」來講，那就要改成 ",[26,205,206],{},"docker tag test hsiangfeng\u002Ftest","，屆時輸入 ",[26,209,210],{},"docker images"," 應該就會看到 ",[26,213,214],{},"hsiangfeng\u002Ftest"," 的 images",[16,217,218],{},[110,219],{"alt":220,"src":221},"images","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E8%B2%BC%E4%B8%8A%E7%9A%84%E5%BD%B1%E5%83%8F_2022_4_23_22_02.png",[16,223,224,225,227],{},"接下來再去試著 ",[26,226,139],{}," 看看。",[12,229,231],{"id":230},"忘記建立-repositories","忘記建立 Repositories",[16,233,234,235,237],{},"最後一個算是滿蠢的問題，要注意當你輸入 ",[26,236,139],{}," 的時候，docker 並不會幫你自動建立 Repositories，因此請記得到 DockerHub 新增一個儲存庫，並且名稱要與你要上傳的相同",[16,239,240],{},[110,241],{"alt":242,"src":243},"Create","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202022-04-23%2022.27.47.png",[16,245,246,247,249],{},"接下來新增之後就可以在試著輸入一次 ",[26,248,139],{}," 了，通常到這一步基本上就可以成功了。",[16,251,252],{},[110,253],{"alt":254,"src":255},"成功畫面","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202022-04-23%2022.29.02.png",[12,257,258],{"id":258},"參考文獻",[260,261,262],"ul",{},[263,264,265],"li",{},[266,267,271],"a",{"href":268,"rel":269},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F43858398\u002Fdocker-push-error-denied-requested-access-to-the-resource-is-denied",[270],"nofollow","docker push error \"denied: requested access to the resource is denied\"",[273,274,275],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":36,"searchDepth":49,"depth":49,"links":277},[278,279,280,284,285],{"id":14,"depth":49,"text":14},{"id":21,"depth":49,"text":21},{"id":116,"depth":49,"text":116,"children":281},[282,283],{"id":144,"depth":55,"text":144},{"id":184,"depth":55,"text":185},{"id":230,"depth":49,"text":231},{"id":258,"depth":49,"text":258},"docker","2022-04-23 21:43:26","執行 docker push 上傳 image 卻一直被 Docker Hub 噴「denied: requested access to the resource is denied」 ？這一篇整理所有解法：image 命名是不是少了 username\u002F、有沒有 login、tag 是不是寫對。","md","zh-Hant",{},true,"\u002Fdocker\u002Fdocker-denied-requested-access-to-the-resource-is-denied","2",{"title":6,"description":288},false,"Docker\u002F關於-docker-出現-denied-requested-access-to-the-resource-is-denied-解決方式",[286,299],"障礙排除",null,"\u002Fdocker\u002F20220423\u002F196903828\u002F","ZAi_awp3YbnPub-7RCNnWaPTDYXu5GYZEdfyjgo2Om0",{"newer":304,"older":308},{"url":305,"title":306,"date":307},"\u002Fother\u002F20220428\u002F1571298383\u002F","Discord 新手教學：從入門到上手完整指南","2022-04-28 21:00:46",{"url":309,"title":310,"date":311},"\u002Fjavascript\u002F20220417\u002F1632354479\u002F","JavaScript 核心觀念(76) - Promise - 鏈接技巧","2022-04-17 19:38:51",[313,318,323],{"url":314,"title":315,"date":316,"readingMinutes":317},"\u002Fdocker\u002F20241219\u002F2070727594\u002F","如何將 Vite+Vue 封裝到 Docker 並運行？","2024-12-19 16:36:18","3",{"url":319,"title":320,"date":321,"readingMinutes":322},"\u002Fdocker\u002F20230129\u002F1926467390\u002F","(11)一步步掌握基礎 Docker - 目錄","2023-01-29 15:22:19","1",{"url":324,"title":325,"date":326,"readingMinutes":322},"\u002Fdocker\u002F20230129\u002F345996692\u002F","(10)一步步掌握基礎 Docker - Docker GUI","2023-01-29 15:20:19",1784020342699]