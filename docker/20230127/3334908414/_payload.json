[{"data":1,"prerenderedAt":569},["ShallowReactive",2],{"header-locale:\u002Fdocker\u002F20230127\u002F3334908414\u002F":3,"page:\u002Fdocker\u002F20230127\u002F3334908414\u002F":4,"alt:\u002Fdocker\u002F20230127\u002F3334908414\u002F":3,"prev-next:\u002Fdocker\u002F20230127\u002F3334908414\u002F":546,"related:\u002Fdocker\u002F20230127\u002F3334908414\u002F":555},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F27\u002Fstep-by-step-docker-image-build\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":290,"date":528,"description":18,"extension":529,"lang":530,"meta":531,"navigation":188,"path":532,"readingMinutes":533,"seo":534,"standalone":535,"stem":536,"tags":537,"tldr":542,"updated":543,"url":544,"__hash__":545},"content\u002F一步步掌握基礎 Docker\u002F7-一步步掌握基礎-Docker-Docker-Image-製作.md","(7)一步步掌握基礎 Docker - Docker Image 製作","3334908414",{"type":9,"value":10,"toc":521},"minimark",[11,15,19,23,26,29,40,43,50,53,57,66,69,77,93,100,116,123,132,135,144,147,156,163,172,175,241,244,255,262,265,268,272,275,278,337,348,367,370,376,383,395,400,403,407,413,437,447,453,459,465,471,484,487,505,508,514,517],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面章節我們認識了不少 Docker 的指令，這一篇將會介紹 Docker Image 的製作。",[12,20,22],{"id":21},"docker-image","Docker Image",[16,24,25],{},"前面我們提了不少東西，包含 Docker Hub 指令、Docker Cotainer 指令，但是我們還沒有提到 Docker Image， 雖然前面有提到 Docker Image 是啟動 Docker Container 的基礎。",[16,27,28],{},"那麼如果我們想要自己製作 Docker Image 來使用，該怎麼做呢？其實很簡單，就是我們在前面章節所提到的 Dockerfile，這個檔案就是用來製作 Docker Image 的，而在前面我們只是單純的介紹 Dockerfile 的指令而沒有去真的封裝成 Docker Image，這一篇就來介紹如何封裝自己的 Docker Image。",[16,30,31,32,39],{},"首先這邊我們會需要一個預計要製作成 Docker Image 的檔案，這邊我將會使用 Express.js 來製作，如果你沒有這個環境的話，你可以",[33,34,38],"a",{"href":35,"rel":36},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002F2022-express-example",[37],"nofollow","點這個","連結來下載 Express。",[16,41,42],{},"因此你目前的專案打開來應該是長這樣",[16,44,45],{},[46,47],"img",{"alt":48,"src":49},"Express","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002FHAGrQjH.png",[16,51,52],{},"非常的單純、簡單。",[12,54,56],{"id":55},"建立-dockerfile","建立 Dockerfile",[16,58,59,60,65],{},"接下來我們要來建立 Dockerfile，這邊我們會使用 VSCode 來建立，如果你沒有安裝 VSCode 的話，你可以",[33,61,64],{"href":62,"rel":63},"https:\u002F\u002Fcode.visualstudio.com\u002F",[37],"點這裡","來安裝。",[16,67,68],{},"首先在專案的根目錄下建立一個 Dockerfile 檔案(請注意大小寫)，接下來我們要來開始撰寫 Dockerfile。",[16,70,71,72,76],{},"那麼要寫什麼呢？通常第一行會去寫 ",[73,74,75],"code",{},"FROM","，因為我們要指定我們 Express 要在哪個環境下運行，假設是 16.15.0，那麼就這樣寫",[78,79,84],"pre",{"className":80,"code":81,"language":82,"meta":83,"style":83},"language-dockerfile shiki shiki-themes github-dark-high-contrast","FROM node:16.15.0\n","dockerfile","",[73,85,86],{"__ignoreMap":83},[87,88,91],"span",{"class":89,"line":90},"line",1,[87,92,81],{},[16,94,95,96,99],{},"選擇環境後，通常我們會建立工作目錄，通常是 ",[73,97,98],{},"\u002Fapp","，並會將所有檔案複製到工作目錄下，所以我們要在 Dockerfile 中寫入",[78,101,103],{"className":80,"code":102,"language":82,"meta":83,"style":83},"WORKDIR \u002Fapp\nCOPY . .\n",[73,104,105,110],{"__ignoreMap":83},[87,106,107],{"class":89,"line":90},[87,108,109],{},"WORKDIR \u002Fapp\n",[87,111,113],{"class":89,"line":112},2,[87,114,115],{},"COPY . .\n",[16,117,118,119,122],{},"接著我們要執行 ",[73,120,121],{},"npm install","，因為我們要安裝 Express.js 的相依套件，所以我們要在 Dockerfile 中寫入",[78,124,126],{"className":80,"code":125,"language":82,"meta":83,"style":83},"RUN [\"npm\",\"install\"]\n",[73,127,128],{"__ignoreMap":83},[87,129,130],{"class":89,"line":90},[87,131,125],{},[16,133,134],{},"當我們安裝完相依套件後，我們可以去設置一個環境變數指定我們的埠號，這邊我們設置為 3000",[78,136,138],{"className":80,"code":137,"language":82,"meta":83,"style":83},"ENV PORT 3000\n",[73,139,140],{"__ignoreMap":83},[87,141,142],{"class":89,"line":90},[87,143,137],{},[16,145,146],{},"指定完之後，我們還要跟 Docker Container 告知我們將會使用哪個埠號，所以我們要在 Dockerfile 中寫入",[78,148,150],{"className":80,"code":149,"language":82,"meta":83,"style":83},"EXPOSE 3000\n",[73,151,152],{"__ignoreMap":83},[87,153,154],{"class":89,"line":90},[87,155,149],{},[16,157,158,159,162],{},"最後就要執行的指令，這邊我們要執行 ",[73,160,161],{},"npm start","，所以我們要在 Dockerfile 中寫入",[78,164,166],{"className":80,"code":165,"language":82,"meta":83,"style":83},"CMD [\"npm\",\"start\"]\n",[73,167,168],{"__ignoreMap":83},[87,169,170],{"class":89,"line":90},[87,171,165],{},[16,173,174],{},"最後我們的 Dockerfile 就長這樣",[78,176,178],{"className":80,"code":177,"language":82,"meta":83,"style":83},"FROM node:16.15.0\n\nWORKDIR \u002Fapp\nCOPY . .\n\nENV PORT=3000\n\nRUN [\"npm\",\"install\"]\n\nEXPOSE 3000\n\nCMD [\"npm\",\"start\"]\n",[73,179,180,184,190,195,200,205,211,216,221,226,231,236],{"__ignoreMap":83},[87,181,182],{"class":89,"line":90},[87,183,81],{},[87,185,186],{"class":89,"line":112},[87,187,189],{"emptyLinePlaceholder":188},true,"\n",[87,191,193],{"class":89,"line":192},3,[87,194,109],{},[87,196,198],{"class":89,"line":197},4,[87,199,115],{},[87,201,203],{"class":89,"line":202},5,[87,204,189],{"emptyLinePlaceholder":188},[87,206,208],{"class":89,"line":207},6,[87,209,210],{},"ENV PORT=3000\n",[87,212,214],{"class":89,"line":213},7,[87,215,189],{"emptyLinePlaceholder":188},[87,217,219],{"class":89,"line":218},8,[87,220,125],{},[87,222,224],{"class":89,"line":223},9,[87,225,189],{"emptyLinePlaceholder":188},[87,227,229],{"class":89,"line":228},10,[87,230,149],{},[87,232,234],{"class":89,"line":233},11,[87,235,189],{"emptyLinePlaceholder":188},[87,237,239],{"class":89,"line":238},12,[87,240,165],{},[16,242,243],{},"比起第二天的章節來講，是不是相對簡單超級多呢？",[16,245,246,247,250,251,254],{},"那麼上方比較疑惑的點應該是 ",[73,248,249],{},"WORKDIR"," 跟 ",[73,252,253],{},"COPY","，這邊我們來解釋一下，為什麼要建立工作目錄，並且將所有檔案複製到工作目錄下。",[16,256,257,258,261],{},"首先，因為 Docker 在預設狀況下指令操作都是在根目錄下，也就是 ",[73,259,260],{},"\u002F","，那麼這樣子是會發生一些問題的，你可以思考一下，我們再輸入某些終端機指令時，都是在根目錄下，因此如果你沒有建立工作目錄，而是直接將所有檔案複製到根目錄下，那麼就有可能發生一些問題。",[16,263,264],{},"所以我們就會需要建立工作目錄，並且將所有檔案複製到工作目錄下，這樣子就可以避免一些問題。",[16,266,267],{},"到目前為止，我們已經完成了 Dockerfile 的撰寫，接下來我們要來建立 Docker Image。",[12,269,271],{"id":270},"建立-docker-image","建立 Docker Image",[16,273,274],{},"在建立 Docker Image 之前，請務必確認一下你的 Dockerfile 是否有寫錯，因為如果有寫錯，那麼就會發生一些問題唷。",[16,276,277],{},"那麼我們該怎麼建立呢？首先我們要先進入到 Dockerfile 所在的目錄下，並且輸入以下指令",[78,279,283],{"className":280,"code":281,"language":282,"meta":83,"style":83},"language-bash shiki shiki-themes github-dark-high-contrast","docker build -t \u003Cimage-name>:\u003Ctag> \u003Cpath-to-dockerfile>\n","bash",[73,284,285],{"__ignoreMap":83},[87,286,287,291,295,299,303,306,310,313,316,319,322,325,327,329,332,334],{"class":89,"line":90},[87,288,290],{"class":289},"s_sBn","docker",[87,292,294],{"class":293},"sTRMh"," build",[87,296,298],{"class":297},"sCcAr"," -t",[87,300,302],{"class":301},"sWyjQ"," \u003C",[87,304,305],{"class":293},"image-nam",[87,307,309],{"class":308},"sMAXC","e",[87,311,312],{"class":301},">",[87,314,315],{"class":293},":",[87,317,318],{"class":301},"\u003C",[87,320,321],{"class":293},"ta",[87,323,324],{"class":308},"g",[87,326,312],{"class":301},[87,328,302],{"class":301},[87,330,331],{"class":293},"path-to-dockerfil",[87,333,309],{"class":308},[87,335,336],{"class":301},">\n",[16,338,339,340,343,344,347],{},"接著舉例來講，我們的 Image 名稱叫做 ",[73,341,342],{},"docker-express-example"," 然後是第一版，並且 Dockerfile 所在的目錄是 ",[73,345,346],{},".","，所以我們要輸入",[78,349,351],{"className":280,"code":350,"language":282,"meta":83,"style":83},"docker build -t docker-express-example:v1 .\n",[73,352,353],{"__ignoreMap":83},[87,354,355,357,359,361,364],{"class":89,"line":90},[87,356,290],{"class":289},[87,358,294],{"class":293},[87,360,298],{"class":297},[87,362,363],{"class":293}," docker-express-example:v1",[87,365,366],{"class":293}," .\n",[16,368,369],{},"輸入完畢後，你就會看到 Docker 開始建立 Image，這個過程會花費一些時間，所以請耐心等待。",[16,371,372],{},[46,373],{"alt":374,"src":375},"Docker Build","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002Ffhbrpri.png",[16,377,378,379,382],{},"建立完畢後，我們可以輸入 ",[73,380,381],{},"docker images"," 來查看我們建立的 Image",[78,384,386],{"className":280,"code":385,"language":282,"meta":83,"style":83},"docker images\n",[73,387,388],{"__ignoreMap":83},[87,389,390,392],{"class":89,"line":90},[87,391,290],{"class":289},[87,393,394],{"class":293}," images\n",[16,396,397],{},[46,398],{"alt":381,"src":399},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002FY2FX84N.png",[16,401,402],{},"恭喜你，你已經完成了 Docker Image 的建立囉！",[12,404,406],{"id":405},"建立-docker-container-並且執行","建立 Docker Container 並且執行",[16,408,409,410,412],{},"接著我們要來嘗試將我們的 Image 轉換成 Container 並執行，首先我們的 Docker Image 名稱是 ",[73,411,342],{},"，請注意我們必須指定 Image 名稱以及 Tag，因為 Docker 會將同名的 Image 都列出來，所以我們必須要指定。",[78,414,416],{"className":280,"code":415,"language":282,"meta":83,"style":83},"docker run -p 3000:3000 -d docker-express-example:v1\n",[73,417,418],{"__ignoreMap":83},[87,419,420,422,425,428,431,434],{"class":89,"line":90},[87,421,290],{"class":289},[87,423,424],{"class":293}," run",[87,426,427],{"class":297}," -p",[87,429,430],{"class":293}," 3000:3000",[87,432,433],{"class":297}," -d",[87,435,436],{"class":293}," docker-express-example:v1\n",[16,438,439,440,250,443,446],{},"上面你應該會看到幾個前面沒介紹過的指令跟參數，分別是 ",[73,441,442],{},"-p",[73,444,445],{},"-d","，這邊我們來解釋一下。",[16,448,449,450,452],{},"首先，",[73,451,442],{}," 是用來指定 Port 的，我們可以透過這個指令來將 Container 的 Port 與我們自己電腦的 Host Port 進行連結，這樣子我們就可以透過 Host 的 Port 來連接到 Container 的 Port，白話文來講就是，讓你可以直接透過你的電腦來連接到 Container 中的 Express Server。",[16,454,455,456,458],{},"而 ",[73,457,445],{}," 則是用來讓 Container 在背景執行，也就是說，我們可以在 Container 執行的同時，還可以繼續使用我們的電腦，而不會被 Container 所阻擋，如果沒有這個參數，那麼我們的電腦就會被 Container 所阻擋，直到 Container 停止運行，如下圖",[16,460,461],{},[46,462],{"alt":463,"src":464},"卡住","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002FbJB0k1z.png",[16,466,467,468,470],{},"你會發現終端機整個被卡死，因此才會建議要補上 ",[73,469,445],{}," 參數。",[472,473,474],"blockquote",{},[16,475,476,480,481,483],{},[477,478,479],"strong",{},"Warning","\n請注意，如果你沒有設定 ",[73,482,442],{}," 參數的話，你是無法訪問 Docker Container 裡面的 Express 哦！",[16,485,486],{},"那麼到這邊為止，我們已經製作好自己的 Docker Image 並且成功執行也可以訪問，當如果你想進去看 Docker Container 的 API 請求紀錄，你可以輸入以下指令",[78,488,490],{"className":280,"code":489,"language":282,"meta":83,"style":83},"docker logs -f 24ebf5e42977e4469c8602a448f72d0b5e89f8fcbc8dc7f46e71af30ab28cb91\n",[73,491,492],{"__ignoreMap":83},[87,493,494,496,499,502],{"class":89,"line":90},[87,495,290],{"class":289},[87,497,498],{"class":293}," logs",[87,500,501],{"class":297}," -f",[87,503,504],{"class":293}," 24ebf5e42977e4469c8602a448f72d0b5e89f8fcbc8dc7f46e71af30ab28cb91\n",[16,506,507],{},"這樣子你就可以持續看到 Container 的 API 請求紀錄，如下圖",[16,509,510],{},[46,511],{"alt":512,"src":513},"Docker logs","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Fdocker\u002F%E4%B8%80%E6%AD%A5%E6%AD%A5%E6%8E%8C%E6%8F%A1%E5%9F%BA%E7%A4%8E-Docker\u002FRAVJaj8.png",[16,515,516],{},"那麼我們下一篇見囉",[518,519,520],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}",{"title":83,"searchDepth":112,"depth":112,"links":522},[523,524,525,526,527],{"id":14,"depth":112,"text":14},{"id":21,"depth":112,"text":22},{"id":55,"depth":112,"text":56},{"id":270,"depth":112,"text":271},{"id":405,"depth":112,"text":406},"2023-01-27 21:16:19","md","zh-Hant",{},"\u002Fdocker\u002F7-docker-docker-image","3",{"title":6,"description":18},false,"一步步掌握基礎 Docker\u002F7-一步步掌握基礎-Docker-Docker-Image-製作",[290,538,22,539,540,541],"一步步掌握基礎 Docker","Dockerfile","Express.js","Docker Container",null,"2023-02-13 15:30:00","\u002Fdocker\u002F20230127\u002F3334908414\u002F","OyG-zrF3-EcA6XXeNWHciyxutxwoc_w-UhEwfekaA6A",{"newer":547,"older":551},{"url":548,"title":549,"date":550},"\u002Fdocker\u002F20230128\u002F919353162\u002F","(8)一步步掌握基礎 Docker - Docker 常見 Image 指令","2023-01-28 12:38:00",{"url":552,"title":553,"date":554},"\u002Fdocker\u002F20230126\u002F2936506521\u002F","(6)一步步掌握基礎 Docker - Docker 常見容器指令(續)","2023-01-26 20:51:00",[556,560,565],{"url":557,"title":558,"date":559,"readingMinutes":533},"\u002Fdocker\u002F20241219\u002F2070727594\u002F","如何將 Vite+Vue 封裝到 Docker 並運行？","2024-12-19 16:36:18",{"url":561,"title":562,"date":563,"readingMinutes":564},"\u002Fdocker\u002F20230129\u002F1926467390\u002F","(11)一步步掌握基礎 Docker - 目錄","2023-01-29 15:22:19","1",{"url":566,"title":567,"date":568,"readingMinutes":564},"\u002Fdocker\u002F20230129\u002F345996692\u002F","(10)一步步掌握基礎 Docker - Docker GUI","2023-01-29 15:20:19",1784011691435]