[{"data":1,"prerenderedAt":608},["ShallowReactive",2],{"header-locale:\u002Fdocker\u002F20230128\u002F919353162\u002F":3,"page:\u002Fdocker\u002F20230128\u002F919353162\u002F":4,"alt:\u002Fdocker\u002F20230128\u002F919353162\u002F":3,"prev-next:\u002Fdocker\u002F20230128\u002F919353162\u002F":584,"related:\u002Fdocker\u002F20230128\u002F919353162\u002F":593},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F28\u002Fstep-by-step-docker-common-image-commands\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":153,"date":568,"description":18,"extension":569,"lang":570,"meta":571,"navigation":39,"path":572,"readingMinutes":573,"seo":574,"standalone":575,"stem":576,"tags":577,"tldr":580,"updated":581,"url":582,"__hash__":583},"content\u002F一步步掌握基礎 Docker\u002F8-一步步掌握基礎-Docker-Docker-常見-Image-指令.md","(8)一步步掌握基礎 Docker - Docker 常見 Image 指令","919353162",{"type":9,"value":10,"toc":556},"minimark",[11,15,19,23,26,104,121,128,131,136,175,178,182,189,207,214,228,236,239,253,257,260,272,275,279,282,302,312,329,333,336,361,370,388,391,395,398,417,423,438,441,444,541,552],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面章節其實有介紹到 Docker Container 常見的指令，但卻沒介紹到 Docker Image 常見的指令，這一篇就來介紹一下 Docker Image 常見的指令。",[12,20,22],{"id":21},"docker-常見-image-指令","Docker 常見 Image 指令",[16,24,25],{},"其實我們在前面章節很早就有介紹過 Docker Image 的指令，只是我把它區分成了 Docker Hub 的指令而已",[27,28,31,51,65,78,91],"ul",{"className":29},[30],"contains-task-list",[32,33,36,41,42,46],"li",{"className":34},[35],"task-list-item",[37,38],"input",{"checked":39,"disabled":39,"type":40},true,"checkbox"," ",[43,44,45],"code",{},"docker login",[27,47,48],{},[32,49,50],{},"登入 Docker Hub",[32,52,54,56,57,60],{"className":53},[35],[37,55],{"checked":39,"disabled":39,"type":40},"  ",[43,58,59],{},"docker logout",[27,61,62],{},[32,63,64],{},"登出 Docker Hub",[32,66,68,56,70,73],{"className":67},[35],[37,69],{"checked":39,"disabled":39,"type":40},[43,71,72],{},"docker search",[27,74,75],{},[32,76,77],{},"搜尋 Docker Hub 上的 Image",[32,79,81,56,83,86],{"className":80},[35],[37,82],{"checked":39,"disabled":39,"type":40},[43,84,85],{},"docker pull",[27,87,88],{},[32,89,90],{},"從 Docker Hub 上拉取 Image",[32,92,94,56,96,99],{"className":93},[35],[37,95],{"checked":39,"disabled":39,"type":40},[43,97,98],{},"docker push",[27,100,101],{},[32,102,103],{},"將 Image 推送到 Docker Hub",[16,105,106,107,109,110,112,113,115,116,109,118,120],{},"其中裡面的 ",[43,108,72],{},"、",[43,111,85],{},"、 ",[43,114,98],{}," 就是跟 Docker Image 相關的指令，而 ",[43,117,45],{},[43,119,59],{}," 則是跟 Docker Hub 相關的指令。",[16,122,123,124,127],{},"而前一章節我們嘗試打包自己的 Image 中也有使用 ",[43,125,126],{},"docker build"," 這個指令，這個指令也是跟 Docker Image 相關的指令。",[12,129,126],{"id":130},"docker-build",[16,132,133,135],{},[43,134,126],{}," 指令是用來建立 Docker Image 的指令，而它的語法如下：",[137,138,143],"pre",{"className":139,"code":140,"language":141,"meta":142,"style":142},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","docker build [OPTIONS] PATH | URL | -\n","bash","",[43,144,145],{"__ignoreMap":142},[146,147,150,154,158,162,166,169,172],"span",{"class":148,"line":149},"line",1,[146,151,153],{"class":152},"smYoP","docker",[146,155,157],{"class":156},"sWayO"," build",[146,159,161],{"class":160},"s8XSl"," [OPTIONS] PATH ",[146,163,165],{"class":164},"sOudu","|",[146,167,168],{"class":152}," URL",[146,170,171],{"class":164}," |",[146,173,174],{"class":152}," -\n",[16,176,177],{},"這個指令在前一章節，我們其實已經有使用過了，因此這邊就不額外多花時間介紹。",[12,179,181],{"id":180},"docker-rmi","docker rmi",[16,183,184,185,188],{},"這個指令與 ",[43,186,187],{},"docker rm"," 類似，只是這個指令是專門用來刪除 Docker Image 的指令，而它的語法如下：",[137,190,192],{"className":139,"code":191,"language":141,"meta":142,"style":142},"docker rmi [IMAGE ID]\n",[43,193,194],{"__ignoreMap":142},[146,195,196,198,201,204],{"class":148,"line":149},[146,197,153],{"class":152},[146,199,200],{"class":156}," rmi",[146,202,203],{"class":160}," [IMAGE ",[146,205,206],{"class":156},"ID]\n",[16,208,209,210,213],{},"假設我們要刪除 ID 為 ",[43,211,212],{},"58bfbd37b174"," 的 Image，則可以使用下面的指令：",[137,215,217],{"className":139,"code":216,"language":141,"meta":142,"style":142},"docker rmi 58bfbd37b174\n",[43,218,219],{"__ignoreMap":142},[146,220,221,223,225],{"class":148,"line":149},[146,222,153],{"class":152},[146,224,200],{"class":156},[146,226,227],{"class":156}," 58bfbd37b174\n",[229,230,233],"callout",{"title":231,"type":232},"Warning","warning",[16,234,235],{},"如果你要刪除的 Image 有被其他的 Container 使用，那麼就會刪除失敗。",[16,237,238],{},"當然，你也可以直接針對 Image 的名稱來刪除，例如：",[137,240,242],{"className":139,"code":241,"language":141,"meta":142,"style":142},"docker rmi docker-express-example\n",[43,243,244],{"__ignoreMap":142},[146,245,246,248,250],{"class":148,"line":149},[146,247,153],{"class":152},[146,249,200],{"class":156},[146,251,252],{"class":156}," docker-express-example\n",[12,254,256],{"id":255},"docker-images","docker images",[16,258,259],{},"這個指令是用來查看目前 Docker 環境中有哪些 Image，而它的語法如下：",[137,261,263],{"className":139,"code":262,"language":141,"meta":142,"style":142},"docker images\n",[43,264,265],{"__ignoreMap":142},[146,266,267,269],{"class":148,"line":149},[146,268,153],{"class":152},[146,270,271],{"class":156}," images\n",[16,273,274],{},"這樣就會列出你當前電腦內的所有 Image",[12,276,278],{"id":277},"docker-tag","docker tag",[16,280,281],{},"這個指令是用來將 Image 打上 Tag 的指令，而它的語法如下：",[137,283,285],{"className":139,"code":284,"language":141,"meta":142,"style":142},"docker tag [IMAGE ID] [TAG]\n",[43,286,287],{"__ignoreMap":142},[146,288,289,291,294,296,299],{"class":148,"line":149},[146,290,153],{"class":152},[146,292,293],{"class":156}," tag",[146,295,203],{"class":160},[146,297,298],{"class":156},"ID]",[146,300,301],{"class":160}," [TAG]\n",[16,303,304,305,307,308,311],{},"假設我們要將 ID 為 ",[43,306,212],{}," 的 Image 打上 ",[43,309,310],{},"v1.0.0"," 的 Tag，則可以使用下面的指令：",[137,313,315],{"className":139,"code":314,"language":141,"meta":142,"style":142},"docker tag 58bfbd37b174 docker-express-example:v1.0.0\n",[43,316,317],{"__ignoreMap":142},[146,318,319,321,323,326],{"class":148,"line":149},[146,320,153],{"class":152},[146,322,293],{"class":156},[146,324,325],{"class":156}," 58bfbd37b174",[146,327,328],{"class":156}," docker-express-example:v1.0.0\n",[12,330,332],{"id":331},"docker-save","docker save",[16,334,335],{},"這個指令是用來將 Image 儲存成檔案的指令，而它的語法如下：",[137,337,339],{"className":139,"code":338,"language":141,"meta":142,"style":142},"docker save [IMAGE ID] > [FILE NAME]\n",[43,340,341],{"__ignoreMap":142},[146,342,343,345,348,350,352,355,358],{"class":148,"line":149},[146,344,153],{"class":152},[146,346,347],{"class":156}," save",[146,349,203],{"class":160},[146,351,298],{"class":156},[146,353,354],{"class":164}," >",[146,356,357],{"class":160}," [FILE ",[146,359,360],{"class":156},"NAME]\n",[16,362,304,363,365,366,369],{},[43,364,212],{}," 的 Image 儲存成 ",[43,367,368],{},"docker-express-example.tar"," 的檔案，則可以使用下面的指令：",[137,371,373],{"className":139,"code":372,"language":141,"meta":142,"style":142},"docker save 58bfbd37b174 > docker-express-example.tar\n",[43,374,375],{"__ignoreMap":142},[146,376,377,379,381,383,385],{"class":148,"line":149},[146,378,153],{"class":152},[146,380,347],{"class":156},[146,382,325],{"class":156},[146,384,354],{"class":164},[146,386,387],{"class":156}," docker-express-example.tar\n",[16,389,390],{},"打包後的路徑通常會在你當前的目錄下。",[12,392,394],{"id":393},"docker-load","docker load",[16,396,397],{},"這個指令是用來將檔案還原成 Image 的指令，而它的語法如下：",[137,399,401],{"className":139,"code":400,"language":141,"meta":142,"style":142},"docker load \u003C [FILE NAME]\n",[43,402,403],{"__ignoreMap":142},[146,404,405,407,410,413,415],{"class":148,"line":149},[146,406,153],{"class":152},[146,408,409],{"class":156}," load",[146,411,412],{"class":164}," \u003C",[146,414,357],{"class":160},[146,416,360],{"class":156},[16,418,419,420,422],{},"假設我們要將 ",[43,421,368],{}," 的檔案還原成 Image，則可以使用下面的指令：",[137,424,426],{"className":139,"code":425,"language":141,"meta":142,"style":142},"docker load \u003C docker-express-example.tar\n",[43,427,428],{"__ignoreMap":142},[146,429,430,432,434,436],{"class":148,"line":149},[146,431,153],{"class":152},[146,433,409],{"class":156},[146,435,412],{"class":164},[146,437,387],{"class":156},[12,439,440],{"id":440},"其它指令",[16,442,443],{},"目前為止，我們也已經學會了 Docker Image 相關的指令",[27,445,447,458,469,481,493,505,517,529],{"className":446},[30],[32,448,450,56,452,454],{"className":449},[35],[37,451],{"checked":39,"disabled":39,"type":40},[43,453,85],{},[27,455,456],{},[32,457,90],{},[32,459,461,56,463,465],{"className":460},[35],[37,462],{"checked":39,"disabled":39,"type":40},[43,464,98],{},[27,466,467],{},[32,468,103],{},[32,470,472,41,474,476],{"className":471},[35],[37,473],{"checked":39,"disabled":39,"type":40},[43,475,126],{},[27,477,478],{},[32,479,480],{},"建立 Docker Image",[32,482,484,41,486,488],{"className":483},[35],[37,485],{"checked":39,"disabled":39,"type":40},[43,487,181],{},[27,489,490],{},[32,491,492],{},"刪除 Docker Image",[32,494,496,41,498,500],{"className":495},[35],[37,497],{"checked":39,"disabled":39,"type":40},[43,499,256],{},[27,501,502],{},[32,503,504],{},"查看目前 Docker 環境中有哪些 Image",[32,506,508,41,510,512],{"className":507},[35],[37,509],{"checked":39,"disabled":39,"type":40},[43,511,278],{},[27,513,514],{},[32,515,516],{},"將 Image 打上 Tag",[32,518,520,41,522,524],{"className":519},[35],[37,521],{"checked":39,"disabled":39,"type":40},[43,523,332],{},[27,525,526],{},[32,527,528],{},"將 Image 儲存成檔案",[32,530,532,41,534,536],{"className":531},[35],[37,533],{"checked":39,"disabled":39,"type":40},[43,535,394],{},[27,537,538],{},[32,539,540],{},"將檔案還原成 Image",[16,542,543,544,551],{},"當然如果 Docker Image 還有其他的指令，這邊你也可以到 ",[545,546,550],"a",{"href":547,"rel":548},"https:\u002F\u002Fdocs.docker.com\u002Fengine\u002Freference\u002Fcommandline\u002Fimage\u002F",[549],"nofollow","Docker 官方文件"," 中查看。",[553,554,555],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shik