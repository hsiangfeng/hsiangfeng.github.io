[{"data":1,"prerenderedAt":610},["ShallowReactive",2],{"header-locale:\u002Fdocker\u002F20230128\u002F919353162\u002F":3,"page:\u002Fdocker\u002F20230128\u002F919353162\u002F":4,"alt:\u002Fdocker\u002F20230128\u002F919353162\u002F":3,"prev-next:\u002Fdocker\u002F20230128\u002F919353162\u002F":586,"related:\u002Fdocker\u002F20230128\u002F919353162\u002F":595},"\u002Fen\u002Fdocker\u002F2023\u002F01\u002F28\u002Fstep-by-step-docker-common-image-commands\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":153,"date":570,"description":18,"extension":571,"lang":572,"meta":573,"navigation":39,"path":574,"readingMinutes":575,"seo":576,"standalone":577,"stem":578,"tags":579,"tldr":582,"updated":583,"url":584,"__hash__":585},"content\u002F一步步掌握基礎 Docker\u002F8-一步步掌握基礎-Docker-Docker-常見-Image-指令.md","(8)一步步掌握基礎 Docker - Docker 常見 Image 指令","919353162",{"type":9,"value":10,"toc":558},"minimark",[11,15,19,23,26,104,121,128,131,136,175,178,182,189,207,214,228,238,241,255,259,262,274,277,281,284,304,314,331,335,338,363,372,390,393,397,400,419,425,440,443,446,543,554],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面章節其實有介紹到 Docker Container 常見的指令，但卻沒介紹到 Docker Image 常見的指令，這一篇就來介紹一下 Docker Image 常見的指令。",[12,20,22],{"id":21},"docker-常見-image-指令","Docker 常見 Image 指令",[16,24,25],{},"其實我們在前面章節很早就有介紹過 Docker Image 的指令，只是我把它區分成了 Docker Hub 的指令而已",[27,28,31,51,65,78,91],"ul",{"className":29},[30],"contains-task-list",[32,33,36,41,42,46],"li",{"className":34},[35],"task-list-item",[37,38],"input",{"checked":39,"disabled":39,"type":40},true,"checkbox"," ",[43,44,45],"code",{},"docker login",[27,47,48],{},[32,49,50],{},"登入 Docker Hub",[32,52,54,56,57,60],{"className":53},[35],[37,55],{"checked":39,"disabled":39,"type":40},"  ",[43,58,59],{},"docker logout",[27,61,62],{},[32,63,64],{},"登出 Docker Hub",[32,66,68,56,70,73],{"className":67},[35],[37,69],{"checked":39,"disabled":39,"type":40},[43,71,72],{},"docker search",[27,74,75],{},[32,76,77],{},"搜尋 Docker Hub 上的 Image",[32,79,81,56,83,86],{"className":80},[35],[37,82],{"checked":39,"disabled":39,"type":40},[43,84,85],{},"docker pull",[27,87,88],{},[32,89,90],{},"從 Docker Hub 上拉取 Image",[32,92,94,56,96,99],{"className":93},[35],[37,95],{"checked":39,"disabled":39,"type":40},[43,97,98],{},"docker push",[27,100,101],{},[32,102,103],{},"將 Image 推送到 Docker Hub",[16,105,106,107,109,110,112,113,115,116,109,118,120],{},"其中裡面的 ",[43,108,72],{},"、",[43,111,85],{},"、 ",[43,114,98],{}," 就是跟 Docker Image 相關的指令，而 ",[43,117,45],{},[43,119,59],{}," 則是跟 Docker Hub 相關的指令。",[16,122,123,124,127],{},"而前一章節我們嘗試打包自己的 Image 中也有使用 ",[43,125,126],{},"docker build"," 這個指令，這個指令也是跟 Docker Image 相關的指令。",[12,129,126],{"id":130},"docker-build",[16,132,133,135],{},[43,134,126],{}," 指令是用來建立 Docker Image 的指令，而它的語法如下：",[137,138,143],"pre",{"className":139,"code":140,"language":141,"meta":142,"style":142},"language-bash shiki shiki-themes github-dark-high-contrast","docker build [OPTIONS] PATH | URL | -\n","bash","",[43,144,145],{"__ignoreMap":142},[146,147,150,154,158,162,166,169,172],"span",{"class":148,"line":149},"line",1,[146,151,153],{"class":152},"s_sBn","docker",[146,155,157],{"class":156},"sTRMh"," build",[146,159,161],{"class":160},"sMAXC"," [OPTIONS] PATH ",[146,163,165],{"class":164},"sWyjQ","|",[146,167,168],{"class":152}," URL",[146,170,171],{"class":164}," |",[146,173,174],{"class":152}," -\n",[16,176,177],{},"這個指令在前一章節，我們其實已經有使用過了，因此這邊就不額外多花時間介紹。",[12,179,181],{"id":180},"docker-rmi","docker rmi",[16,183,184,185,188],{},"這個指令與 ",[43,186,187],{},"docker rm"," 類似，只是這個指令是專門用來刪除 Docker Image 的指令，而它的語法如下：",[137,190,192],{"className":139,"code":191,"language":141,"meta":142,"style":142},"docker rmi [IMAGE ID]\n",[43,193,194],{"__ignoreMap":142},[146,195,196,198,201,204],{"class":148,"line":149},[146,197,153],{"class":152},[146,199,200],{"class":156}," rmi",[146,202,203],{"class":160}," [IMAGE ",[146,205,206],{"class":156},"ID]\n",[16,208,209,210,213],{},"假設我們要刪除 ID 為 ",[43,211,212],{},"58bfbd37b174"," 的 Image，則可以使用下面的指令：",[137,215,217],{"className":139,"code":216,"language":141,"meta":142,"style":142},"docker rmi 58bfbd37b174\n",[43,218,219],{"__ignoreMap":142},[146,220,221,223,225],{"class":148,"line":149},[146,222,153],{"class":152},[146,224,200],{"class":156},[146,226,227],{"class":156}," 58bfbd37b174\n",[229,230,231],"blockquote",{},[16,232,233,237],{},[234,235,236],"strong",{},"Warning","\n如果你要刪除的 Image 有被其他的 Container 使用，那麼就會刪除失敗。",[16,239,240],{},"當然，你也可以直接針對 Image 的名稱來刪除，例如：",[137,242,244],{"className":139,"code":243,"language":141,"meta":142,"style":142},"docker rmi docker-express-example\n",[43,245,246],{"__ignoreMap":142},[146,247,248,250,252],{"class":148,"line":149},[146,249,153],{"class":152},[146,251,200],{"class":156},[146,253,254],{"class":156}," docker-express-example\n",[12,256,258],{"id":257},"docker-images","docker images",[16,260,261],{},"這個指令是用來查看目前 Docker 環境中有哪些 Image，而它的語法如下：",[137,263,265],{"className":139,"code":264,"language":141,"meta":142,"style":142},"docker images\n",[43,266,267],{"__ignoreMap":142},[146,268,269,271],{"class":148,"line":149},[146,270,153],{"class":152},[146,272,273],{"class":156}," images\n",[16,275,276],{},"這樣就會列出你當前電腦內的所有 Image",[12,278,280],{"id":279},"docker-tag","docker tag",[16,282,283],{},"這個指令是用來將 Image 打上 Tag 的指令，而它的語法如下：",[137,285,287],{"className":139,"code":286,"language":141,"meta":142,"style":142},"docker tag [IMAGE ID] [TAG]\n",[43,288,289],{"__ignoreMap":142},[146,290,291,293,296,298,301],{"class":148,"line":149},[146,292,153],{"class":152},[146,294,295],{"class":156}," tag",[146,297,203],{"class":160},[146,299,300],{"class":156},"ID]",[146,302,303],{"class":160}," [TAG]\n",[16,305,306,307,309,310,313],{},"假設我們要將 ID 為 ",[43,308,212],{}," 的 Image 打上 ",[43,311,312],{},"v1.0.0"," 的 Tag，則可以使用下面的指令：",[137,315,317],{"className":139,"code":316,"language":141,"meta":142,"style":142},"docker tag 58bfbd37b174 docker-express-example:v1.0.0\n",[43,318,319],{"__ignoreMap":142},[146,320,321,323,325,328],{"class":148,"line":149},[146,322,153],{"class":152},[146,324,295],{"class":156},[146,326,327],{"class":156}," 58bfbd37b174",[146,329,330],{"class":156}," docker-express-example:v1.0.0\n",[12,332,334],{"id":333},"docker-save","docker save",[16,336,337],{},"這個指令是用來將 Image 儲存成檔案的指令，而它的語法如下：",[137,339,341],{"className":139,"code":340,"language":141,"meta":142,"style":142},"docker save [IMAGE ID] > [FILE NAME]\n",[43,342,343],{"__ignoreMap":142},[146,344,345,347,350,352,354,357,360],{"class":148,"line":149},[146,346,153],{"class":152},[146,348,349],{"class":156}," save",[146,351,203],{"class":160},[146,353,300],{"class":156},[146,355,356],{"class":164}," >",[146,358,359],{"class":160}," [FILE ",[146,361,362],{"class":156},"NAME]\n",[16,364,306,365,367,368,371],{},[43,366,212],{}," 的 Image 儲存成 ",[43,369,370],{},"docker-express-example.tar"," 的檔案，則可以使用下面的指令：",[137,373,375],{"className":139,"code":374,"language":141,"meta":142,"style":142},"docker save 58bfbd37b174 > docker-express-example.tar\n",[43,376,377],{"__ignoreMap":142},[146,378,379,381,383,385,387],{"class":148,"line":149},[146,380,153],{"class":152},[146,382,349],{"class":156},[146,384,327],{"class":156},[146,386,356],{"class":164},[146,388,389],{"class":156}," docker-express-example.tar\n",[16,391,392],{},"打包後的路徑通常會在你當前的目錄下。",[12,394,396],{"id":395},"docker-load","docker load",[16,398,399],{},"這個指令是用來將檔案還原成 Image 的指令，而它的語法如下：",[137,401,403],{"className":139,"code":402,"language":141,"meta":142,"style":142},"docker load \u003C [FILE NAME]\n",[43,404,405],{"__ignoreMap":142},[146,406,407,409,412,415,417],{"class":148,"line":149},[146,408,153],{"class":152},[146,410,411],{"class":156}," load",[146,413,414],{"class":164}," \u003C",[146,416,359],{"class":160},[146,418,362],{"class":156},[16,420,421,422,424],{},"假設我們要將 ",[43,423,370],{}," 的檔案還原成 Image，則可以使用下面的指令：",[137,426,428],{"className":139,"code":427,"language":141,"meta":142,"style":142},"docker load \u003C docker-express-example.tar\n",[43,429,430],{"__ignoreMap":142},[146,431,432,434,436,438],{"class":148,"line":149},[146,433,153],{"class":152},[146,435,411],{"class":156},[146,437,414],{"class":164},[146,439,389],{"class":156},[12,441,442],{"id":442},"其它指令",[16,444,445],{},"目前為止，我們也已經學會了 Docker Image 相關的指令",[27,447,449,460,471,483,495,507,519,531],{"className":448},[30],[32,450,452,56,454,456],{"className":451},[35],[37,453],{"checked":39,"disabled":39,"type":40},[43,455,85],{},[27,457,458],{},[32,459,90],{},[32,461,463,56,465,467],{"className":462},[35],[37,464],{"checked":39,"disabled":39,"type":40},[43,466,98],{},[27,468,469],{},[32,470,103],{},[32,472,474,41,476,478],{"className":473},[35],[37,475],{"checked":39,"disabled":39,"type":40},[43,477,126],{},[27,479,480],{},[32,481,482],{},"建立 Docker Image",[32,484,486,41,488,490],{"className":485},[35],[37,487],{"checked":39,"disabled":39,"type":40},[43,489,181],{},[27,491,492],{},[32,493,494],{},"刪除 Docker Image",[32,496,498,41,500,502],{"className":497},[35],[37,499],{"checked":39,"disabled":39,"type":40},[43,501,258],{},[27,503,504],{},[32,505,506],{},"查看目前 Docker 環境中有哪些 Image",[32,508,510,41,512,514],{"className":509},[35],[37,511],{"checked":39,"disabled":39,"type":40},[43,513,280],{},[27,515,516],{},[32,517,518],{},"將 Image 打上 Tag",[32,520,522,41,524,526],{"className":521},[35],[37,523],{"checked":39,"disabled":39,"type":40},[43,525,334],{},[27,527,528],{},[32,529,530],{},"將 Image 儲存成檔案",[32,532,534,41,536,538],{"className":533},[35],[37,535],{"checked":39,"disabled":39,"type":40},[43,537,396],{},[27,539,540],{},[32,541,542],{},"將檔案還原成 Image",[16,544,545,546,553],{},"當然如果 Docker Image 還有其他的指令，這邊你也可以到 ",[547,548,552],"a",{"href":549,"rel":550},"https:\u002F\u002Fdocs.docker.com\u002Fengine\u002Freference\u002Fcommandline\u002Fimage\u002F",[551],"nofollow","Docker 官方文件"," 中查看。",[555,556,557],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sMAXC, html 