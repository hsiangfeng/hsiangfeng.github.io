0],{},"然後依照選項去調整即可，這邊我也提供我的選項",[33,62,64],{"className":35,"code":63,"language":37,"meta":38,"style":38},"✔ 請輸入專案名稱： … vue-project-docker\n✔ 是否使用 TypeScript？ … 否 \u002F 是\n✔ 是否啟用 JSX 支援？ … 否 \u002F 是\n✔ 是否引入 Vue Router 進行單頁應用程式開發？ … 否 \u002F 是\n✔ 是否引入 Pinia 用於狀態管理？ … 否 \u002F 是\n✔ 是否引入 Vitest 用於單元測試 … 否 \u002F 是\n✔ 是否要引入一款端對端（End to End）測試工具？ › 不需要\n✔ 是否引入 ESLint 用於程式碼品質檢測？ › 否\n",[40,65,66,80,102,124,149,170,191,211],{"__ignoreMap":38},[43,67,68,71,74,77],{"class":45,"line":46},[43,69,70],{"class":49},"✔",[43,72,73],{"class":53}," 請輸入專案名稱：",[43,75,76],{"class":53}," …",[43,78,79],{"class":53}," vue-project-docker\n",[43,81,83,85,88,91,93,96,99],{"class":45,"line":82},2,[43,84,70],{"class":49},[43,86,87],{"class":53}," 是否使用",[43,89,90],{"class":53}," TypeScript？",[43,92,76],{"class":53},[43,94,95],{"class":53}," 否",[43,97,98],{"class":53}," \u002F",[43,100,101],{"class":53}," 是\n",[43,103,105,107,110,113,116,118,120,122],{"class":45,"line":104},3,[43,106,70],{"class":49},[43,108,109],{"class":53}," 是否啟用",[43,111,112],{"class":53}," JSX",[43,114,115],{"class":53}," 支援？",[43,117,76],{"class":53},[43,119,95],{"class":53},[43,121,98],{"class":53},[43,123,101],{"class":53},[43,125,127,129,132,135,138,141,143,145,147],{"class":45,"line":126},4,[43,128,70],{"class":49},[43,130,131],{"class":53}," 是否引入",[43,133,134],{"class":53}," Vue",[43,136,137],{"class":53}," Router",[43,139,140],{"class":53}," 進行單頁應用程式開發？",[43,142,76],{"class":53},[43,144,95],{"class":53},[43,146,98],{"class":53},[43,148,101],{"class":53},[43,150,152,154,156,159,162,164,166,168],{"class":45,"line":151},5,[43,153,70],{"class":49},[43,155,131],{"class":53},[43,157,158],{"class":53}," Pinia",[43,160,161],{"class":53}," 用於狀態管理？",[43,163,76],{"class":53},[43,165,95],{"class":53},[43,167,98],{"class":53},[43,169,101],{"class":53},[43,171,173,175,177,180,183,185,187,189],{"class":45,"line":172},6,[43,174,70],{"class":49},[43,176,131],{"class":53},[43,178,179],{"class":53}," Vitest",[43,181,182],{"class":53}," 用於單元測試",[43,184,76],{"class":53},[43,186,95],{"class":53},[43,188,98],{"class":53},[43,190,101],{"class":53},[43,192,194,196,199,202,205,208],{"class":45,"line":193},7,[43,195,70],{"class":49},[43,197,198],{"class":53}," 是否要引入一款端對端（End",[43,200,201],{"class":53}," to",[43,203,204],{"class":53}," End）測試工具？",[43,206,207],{"class":53}," ›",[43,209,210],{"class":53}," 不需要\n",[43,212,214,216,218,221,224,226],{"class":45,"line":213},8,[43,215,70],{"class":49},[43,217,131],{"class":53},[43,219,220],{"class":53}," ESLint",[43,222,223],{"class":53}," 用於程式碼品質檢測？",[43,225,207],{"class":53},[43,227,228],{"class":53}," 否\n",[20,230,232],{"id":231},"dockerfile","Dockerfile",[12,234,235],{},"接下來要建立一個 Dockerfile，在終端機輸入以下指令",[33,237,239],{"className":35,"code":238,"language":37,"meta":38,"style":38},"touch Dockerfile\n",[40,240,241],{"__ignoreMap":38},[43,242,243,246],{"class":45,"line":46},[43,244,245],{"class":49},"touch",[43,247,248],{"class":53}," Dockerfile\n",[12,250,251],{},"而這個 Dockerfile 是用來告訴 Docker 要怎麼建立我們的環境，以下是我的 Dockerfile：",[33,253,256],{"className":254,"code":255,"language":231,"meta":38,"style":38},"language-dockerfile shiki shiki-themes github-dark-high-contrast","FROM node:20 AS builder\nWORKDIR \u002Fapp\nCOPY package*.json .\u002F\nRUN npm install\nCOPY . .\nRUN npm run build\n\nFROM nginx:alpine\nCOPY --from=builder \u002Fapp\u002Fdist \u002Fusr\u002Fshare\u002Fnginx\u002Fhtml\nEXPOSE 80\nCMD [\"nginx\", \"-g\", \"daemon off;\"]\n",[40,257,258,263,268,273,278,283,288,294,299,305,311],{"__ignoreMap":38},[43,259,260],{"class":45,"line":46},[43,261,262],{},"FROM node:20 AS builder\n",[43,264,265],{"class":45,"line":82},[43,266,267],{},"WORKDIR \u002Fapp\n",[43,269,270],{"class":45,"line":104},[43,271,272],{},"COPY package*.json .\u002F\n",[43,274,275],{"class":45,"line":126},[43,276,277],{},"RUN npm install\n",[43,279,280],{"class":45,"line":151},[43,281,282],{},"COPY . .\n",[43,284,285],{"class":45,"line":172},[43,286,287],{},"RUN npm run build\n",[43,289,290],{"class":45,"line":193},[43,291,293],{"emptyLinePlaceholder":292},true,"\n",[43,295,296],{"class":45,"line":213},[43,297,298],{},"FROM nginx:alpine\n",[43,300,302],{"class":45,"line":301},9,[43,303,304],{},"COPY --from=builder \u002Fapp\u002Fdist \u002Fusr\u002Fshare\u002Fnginx\u002Fhtml\n",[43,306,308],{"class":45,"line":307},10,[43,309,310],{},"EXPOSE 80\n",[43,312,314],{"class":45,"line":313},11,[43,315,316],{},"CMD [\"nginx\", \"-g\", \"daemon off;\"]\n",[12,318,319],{},"這邊我也針對每一行做一些解釋：",[321,322,323,337,351,368,384,393],"ol",{},[324,325,326,329,330,333,334,336],"li",{},[40,327,328],{},"FROM node:20 AS builder","：這行是告訴 Docker 我們要使用 Node.js 20 作為基底，並且取名為 ",[40,331,332],{},"builder","，因此 Docker 就會在這個電腦上安裝 Node.js 20，而取名為 ",[40,335,332],{}," 是因為我們把行為區分成了兩個階段，這個階段是用來建立我們的專案。",[324,338,339,342,343,346,347,350],{},[40,340,341],{},"WORKDIR \u002Fapp","：我們把電腦的工作目錄設置到 ",[40,344,345],{},"\u002Fapp"," 上，你可以想像成新增建立一個資料夾叫 ",[40,348,349],{},"app","，然後接下來的指令都會在這個資料夾下執行。",[324,352,353,356,357,360,361,364,365,367],{},[40,354,355],{},"COPY package*.json .\u002F","：這行是把我們的 ",[40,358,359],{},"package.json"," 和 ",[40,362,363],{},"package-lock.json"," 複製到 ",[40,366,345],{}," 資料夾下。",[324,369,370,373,374,377,378,381,382,367],{},[40,371,372],{},"RUN npm install","：這行是執行 ",[40,375,376],{},"npm install","，這樣就會安裝我們的專案所需的套件，安裝完畢後 ",[40,379,380],{},"node_modules"," 資料夾就會出現在 ",[40,383,345],{},[324,385,386,389,390,392],{},[40,387,388],{},"COPY . .","：這行是把我們的專案複製到 ",[40,391,345],{}," 資料夾下，這樣子 Docker 就可以使用我們的專案。",[324,394,395,373,398,401],{},[40,396,397],{},"RUN npm run build",[40,399,400],{},"npm run build","，這行指令就是在把我們的專案編譯成靜態檔案。",[12,403,404,405,407],{},"到這邊為止，我們就把為 ",[40,406,332],{}," 的階段就完成了，接下來我們要建立一個新的階段，這個階段是用來執行我們的專案。",[321,409,410,423,443,449],{},[324,411,412,415,416,419,420,422],{},[40,413,414],{},"FROM nginx:alpine","：這行是告訴 Docker 我們要使用 Nginx 作為基底，並且使用 ",[40,417,418],{},"alpine"," 版本，而 ",[40,421,418],{}," 版本是一個輕量的版本。",[324,424,425,428,429,431,432,435,436,439,440,442],{},[40,426,427],{},"COPY --from=builder \u002Fapp\u002Fdist \u002Fusr\u002Fshare\u002Fnginx\u002Fhtml","：這行是把 ",[40,430,332],{}," 階段的 ",[40,433,434],{},"\u002Fapp\u002Fdist"," 資料夾複製到 ",[40,437,438],{},"\u002Fusr\u002Fshare\u002Fnginx\u002Fhtml"," 資料夾下，在 Nginx 中，這個資料夾（",[40,441,438],{},"）預設是對外開放提供服務的資料夾。",[324,444,445,448],{},[40,446,447],{},"EXPOSE 80","：這行是告訴 Docker 我們要對外開放 80 Port，這樣子外部的人才可以透過 80 Port 來訪問我們的網站。",[324,450,451,454],{},[40,452,453],{},"CMD [\"nginx\", \"-g\", \"daemon off;\"]","：這行是告訴 Docker 當啟動容器時要執行的指令，這行指令是啟動 Nginx 並且讓 Nginx 在前景運行，這樣 Docker 就不會在啟動後立刻關閉。",[20,456,458],{"id":457},"建立-docker-image","建立 Docker Image",[12,460,461,462,465],{},"接下來就要封裝 Docker Image 了，這邊我們要使用 ",[40,463,464],{},"docker build"," 指令，這個指令是用來建立 Docker Image 的，而我們要在專案的根目錄下執行以下指令：",[33,467,469],{"className":35,"code":468,"language":37,"meta":38,"style":38},"docker build -t vue-project-docker:v1 .\n",[40,470,471],{"__ignoreMap":38},[43,472,473,476,479,483,486],{"class":45,"line":46},[43,474,475],{"class":49},"docker",[43,477,478],{"class":53}," build",[43,480,482],{"class":481},"sCcAr"," -t",[43,484,485],{"class":53}," vue-project-docker:v1",[43,487,488],{"class":53}," .\n",[12,490,491],{},"封裝的過程會稍微需要一點時間",[12,493,494],{},[15,495],{"alt":496,"src":497},"封裝中","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202024-12-19%2016.53.40.png",[12,499,500],{},"等待封裝完成後，我們就可以使用以下指令來查看我們的 Docker Image：",[33,502,504],{"className":35,"code":503,"language":37,"meta":38,"style":38},"docker images\n",[40,505,506],{"__ignoreMap":38},[43,507,508,510],{"class":45,"line":46},[43,509,475],{"class":49},[43,511,512],{"class":53}," images\n",[12,514,515],{},"如果當你有看到你的 Docker Image，那就代表封裝成功了",[20,517,519],{"id":518},"建立-docker-container","建立 Docker Container",[12,521,522,523,526],{},"最後一步驟就是建立 Docker Container，這邊我們要使用 ",[40,524,525],{},"docker run"," 指令，這個指令是用來建立 Docker Container 的，而我們要在專案的根目錄下執行以下指令：",[33,528,530],{"className":35,"code":529,"language":37,"meta":38,"style":38},"docker run -d -p 8080:80 vue-project-docker:v1\n",[40,531,532],{"__ignoreMap":38},[43,533,534,536,539,542,545,548],{"class":45,"line":46},[43,535,475],{"class":49},[43,537,538],{"class":53}," run",[43,540,541],{"class":481}," -d",[43,543,544],{"class":481}," -p",[43,546,547],{"class":53}," 8080:80",[43,549,550],{"class":53}," vue-project-docker:v1\n",[12,552,553],{},"只要你出現以下訊息，就代表你的 Docker Container 並且運行成功了！",[12,555,556],{},[15,557],{"alt":558,"src":559},"運行成功","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fdocker\u002F%E6%88%AA%E5%9C%96%202024-12-19%2016.57.00.png",[12,561,562,563,566],{},"這時候你就可以直接透過 ",[40,564,565],{},"http:\u002F\u002Flocalhost:8080"," 來訪問你的網站囉～",[568,569,570],"blockquote",{},[12,571,572,576,579,580,582,583,586,587,589],{},[573,574,575],"strong",{},"Note",[40,577,578],{},"8080"," 的 Port 是你在 ",[40,581,525],{}," 指令中所指定的 Port，如果你有改 Port，那你就要改成你所指定的 Port，而 ",[40,584,585],{},"80"," 是 Nginx 的 Port，如果你想要改 Nginx 的 Port，你可以去修改 Dockerfile 中的 ",[40,588,447],{},"。",[20,591,593],{"id":592},"停止-docker-container","停止 Docker Container",[12,595,596],{},"如果你想要停止 Docker Container，你可以使用以下指令：",[33,598,600],{"className":35,"code":599,"language":37,"meta":38,"style":38},"docker stop containerId\n",[40,601,602],{"__ignoreMap":38},[43,603,604,606,609],{"class":45,"line":46},[43,605,475],{"class":49},[43,607,608],{"class":53}," stop",[43,610,611],{"class":53}," containerId\n",[568,613,614],{},[12,615,616,618,621,622,625],{},[573,617,575],{},[40,619,620],{},"containerId"," 是你的 Docker Container 的 ID，你可以透過 ",[40,623,624],{},"docker ps"," 來查看你的 Docker Container 的 ID。",[627,628,629],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decorat