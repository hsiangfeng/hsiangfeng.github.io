558,560,561,564,565,567,568,570,571],{},"如果使用 ",[35,557,485],{},[35,559,286],{}," 的資料，那麼當我們執行 ",[35,562,563],{},"setTodoList(JSON.parse(localStorage.getItem('todoList')) || []);"," 時，那麼 ",[35,566,138],{}," 就會有變化，這就會再次觸發 ",[35,569,485],{},"，這樣就會造成無限迴圈的狀況，因此基於這個狀況並不適合使用 ",[35,572,485],{},[261,574,577],{"height":263,"style":264,"scrolling":265,"title":575,"src":576,"frameBorder":265,"loading":268,"allowTransparency":269,"allowFullScreen":269},"(92) React ToDoList (下) - ","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FWNJbxjy?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNJbxjy\">\n  (92) React ToDoList (下) - \u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,579,580,581,583],{},"現在我們不論是重新整理、新增或是更新資料等行為都會被寫入到 ",[35,582,286],{}," 中，我們也活用了前面所學的一些技巧哩。",[16,585,586,587,594],{},"最後也一樣提供完整版 ",[588,589,593],"a",{"href":590,"rel":591},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNJbxjy",[592],"nofollow","React - TodoList CodePen"," 的連結。",[16,596,597,598,603],{},"不免俗也提供 Vue 版本的 ",[588,599,602],{"href":600,"rel":601},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FeYrmzVw",[592],"Vue - TodoList CodePen"," 可以讓你比較一下兩者的差異。",[12,605,606],{"id":606},"後記",[16,608,609],{},"本文將會同步更新到我的部落格",[611,612,613],"ul",{},[542,614,615],{},[588,616,619],{"href":617,"rel":618},"https:\u002F\u002Fisraynotarray.com\u002F",[592],"是 Ray 不是 Array",[621,622,623],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shik