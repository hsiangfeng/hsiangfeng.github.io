7,1091,1093],{"class":39,"line":1092},38,[37,1094,822],{},[37,1096,1098],{"class":39,"line":1097},39,[37,1099,651],{},[37,1101,1103],{"class":39,"line":1102},40,[37,1104,657],{},[37,1106,1108],{"class":39,"line":1107},41,[37,1109,663],{},[37,1111,1113],{"class":39,"line":1112},42,[37,1114,79],{"emptyLinePlaceholder":78},[37,1116,1118],{"class":39,"line":1117},43,[37,1119,669],{},[37,1121,1123],{"class":39,"line":1122},44,[37,1124,675],{},[16,1126,1127,1128,1131,1132,1134,1135,1137],{},"雖然畫面是有正常顯示且排序，但這樣做其實並不是一件好事，因為我們每次點擊按鈕都會觸發 ",[34,1129,1130],{},"filterUsers","，而 ",[34,1133,1130],{}," 會去重新排序，這樣就會造成效能上的浪費，因為我們只是想要重新排序，而不是重新渲染，所以我們可以使用 ",[34,1136,499],{}," 來優化這個問題",[16,1139,1140,1141,1143,1144,1147,1148,1151,1152,1154,1155,1158],{},"這邊也題外話一下，你可能會注意到 ",[34,1142,1130],{}," 中的 ",[34,1145,1146],{},"setUsers"," 我是重新做陣列展開的方式 ",[34,1149,1150],{},"setUsers([...newUser]);","，這邊會這樣寫的原因是因爲 ",[34,1153,912],{}," 會直接修改原本的陣列，因此如果你是直接 ",[34,1156,1157],{},"setUsers(newUser);"," 的話，你會發現畫面並不會重新渲染，因為我們並沒有修改資料，所以 React 在認知上就不會重新渲染，所以我們必須要做陣列展開的方式，讓 React 認知到我們有修改資料，才會重新渲染。",[16,1160,1161,1162,1164,1165,1167,1168,1171,1172],{},"接著讓我們來看一下 ",[34,1163,499],{}," 這個 Hook，那該怎麼寫，其實很簡單就把它當作在寫 Vue 的 ",[34,1166,63],{}," 就好，只是我們會特別監聽 ",[34,1169,1170],{},"state"," 這個值有變化時才去觸發 ",[34,1173,499],{},[27,1175,1177],{"className":514,"code":1176,"language":516,"meta":32,"style":32},"const App = () => {\n  const [ users, setUsers ] = React.useState([]);;\n  const [ state, setState ] = React.useState(false);\n\n  const getUsers = async() => {\n    const { data } = await axios.get('https:\u002F\u002Frandomuser.me\u002Fapi\u002F?results=10');\n    setUsers(data.results);\n  }\n\n  React.useEffect(() => {\n    getUsers();\n  }, []);\n\n  const filterUsers = React.useMemo(() => {\n    return users.sort((a, b) =>  {\n      if(state) {\n        return a.dob.age \u003C b.dob.age ? 1 : -1\n      }\n      return a.dob.age > b.dob.age ? 1 : -1\n    });\n  }, [ state ])\n\n  return (\n    \u003Cdiv>\n      \u003Cbutton onClick={ () => setState(true) } className=\"border-4 border-indigo-500\">年齡大到小\u003C\u002Fbutton>\n      \u003Cbutton onClick={ () => setState(false) }className=\"border-4 border-indigo-500 ml-4\">年齡小到大\u003C\u002Fbutton>\n      \u003Chr className=\"my-4\"\u002F>\n      \u003Cul>\n        {\n          filterUsers.map((user, index) => (\n            \u003Cli key={ user.email }>\n              { `Name：${user.name.title}.${user.name.first } ${user.name.last}, Age：${user.dob.age}` }\n            \u003C\u002Fli>\n          ))\n        }\n      \u003C\u002Ful>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[34,1178,1179,1183,1187,1191,1195,1199,1203,1207,1211,1215,1219,1223,1227,1231,1236,1241,1245,1249,1253,1257,1261,1266,1270,1274,1278,1283,1288,1292,1296,1300,1305,1309,1313,1317,1321,1325,1329,1333,1337,1341,1345,1349],{"__ignoreMap":32},[37,1180,1181],{"class":39,"line":40},[37,1182,523],{},[37,1184,1185],{"class":39,"line":75},[37,1186,927],{},[37,1188,1189],{"class":39,"line":82},[37,1190,932],{},[37,1192,1193],{"class":39,"line":100},[37,1194,79],{"emptyLinePlaceholder":78},[37,1196,1197],{"class":39,"line":109},[37,1198,941],{},[37,1200,1201],{"class":39,"line":132},[37,1202,737],{},[37,1204,1205],{"class":39,"line":163},[37,1206,742],{},[37,1208,1209],{"class":39,"line":169},[37,1210,193],{},[37,1212,1213],{"class":39,"line":178},[37,1214,79],{"emptyLinePlaceholder":78},[37,1216,1217],{"class":39,"line":184},[37,1218,755],{},[37,1220,1221],{"class":39,"line":190},[37,1222,966],{},[37,1224,1225],{"class":39,"line":196},[37,1226,765],{},[37,1228,1229],{"class":39,"line":202},[37,1230,79],{"emptyLinePlaceholder":78},[37,1232,1233],{"class":39,"line":207},[37,1234,1235],{},"  const filterUsers = React.useMemo(() => {\n",[37,1237,1238],{"class":39,"line":412},[37,1239,1240],{},"    return users.sort((a, b) =>  {\n",[37,1242,1243],{"class":39,"line":417},[37,1244,989],{},[37,1246,