  \u003Cbutton onClick={ () => filterUsers(true) } className=\"border-4 border-indigo-500\">年齡大到小\u003C\u002Fbutton>\n      \u003Cbutton onClick={ () => filterUsers(false) }className=\"border-4 border-indigo-500 ml-4\">年齡小到大\u003C\u002Fbutton>\n      \u003Chr className=\"my-4\"\u002F>\n      \u003Cul>\n        {\n          users.map((user) =>(\n            \u003Cli key={ user.email }>\n              { `Name：${user.name.title}.${user.name.first } ${user.name.last}, Age：${user.dob.age}` }\n            \u003C\u002Fli>\n          ))\n        }\n      \u003C\u002Ful>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[34,918,919,923,928,933,937,942,946,950,954,958,962,967,971,975,980,985,990,995,1000,1005,1010,1014,1019,1023,1027,1031,1035,1040,1045,1050,1054,1058,1063,1069,1075,1080,1085,1090,1095,1100,1105,1110,1115,1120],{"__ignoreMap":32},[37,920,921],{"class":39,"line":40},[37,922,523],{},[37,924,925],{"class":39,"line":75},[37,926,927],{},"  const [ users, setUsers ] = React.useState([]);;\n",[37,929,930],{"class":39,"line":82},[37,931,932],{},"  const [ state, setState ] = React.useState(false);\n",[37,934,935],{"class":39,"line":100},[37,936,79],{"emptyLinePlaceholder":78},[37,938,939],{"class":39,"line":109},[37,940,941],{},"  const getUsers = async() => {\n",[37,943,944],{"class":39,"line":132},[37,945,737],{},[37,947,948],{"class":39,"line":163},[37,949,742],{},[37,951,952],{"class":39,"line":169},[37,953,193],{},[37,955,956],{"class":39,"line":178},[37,957,79],{"emptyLinePlaceholder":78},[37,959,960],{"class":39,"line":184},[37,961,755],{},[37,963,964],{"class":39,"line":190},[37,965,966],{},"    getUsers();\n",[37,968,969],{"class":39,"line":196},[37,970,765],{},[37,972,973],{"class":39,"line":202},[37,974,79],{"emptyLinePlaceholder":78},[37,976,977],{"class":39,"line":207},[37,978,979],{},"  const filterUsers = (state) => {\n",[37,981,982],{"class":39,"line":412},[37,983,98