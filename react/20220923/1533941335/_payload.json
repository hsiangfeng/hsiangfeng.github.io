 {\n    window.alert(`你已成功購買 ${data.title}`);\n  }\n\n  return (\n    \u003Cbutton type=\"button\" onClick={ pay }>點我購買({ data.price } $)\u003C\u002Fbutton>\n  )\n}\n\n\u002F\u002F ...略\n",[37,710,711,715,719,724,729,734,738,742,746,750,754,758,762,766,770],{"__ignoreMap":57},[61,712,713],{"class":63,"line":64},[61,714,576],{},[61,716,717],{"class":63,"line":70},[61,718,92],{"emptyLinePlaceholder":91},[61,720,721],{"class":63,"line":76},[61,722,723],{},"const Button = () => {\n",[61,725,726],{"class":63,"line":82},[61,727,728],{},"  const data = React.useContent(DataContext);\n",[61,730,731],{"class":63,"line":88},[61,732,733],{},"  \n",[61,735,736],{"class":63,"line":95},[61,737,73],{},[61,739,740],{"class":63,"line":101},[61,741,79],{},[61,743,744],{"class":63,"line":107},[61,745,85],{},[61,747,748],{"class":63,"line":113},[61,749,92],{"emptyLinePlaceholder":91},[61,751,752],{"class":63,"line":119},[61,753,98],{},[61,755,756],{"class":63,"line":124},[61,757,104],{},[61,759,760],{"class":63,"line":130},[61,761,110],{},[61,763,764],{"class":63,"line":135},[61,765,116],{},[61,767,768],{"class":63,"line":141},[61,769,92],{"emptyLinePlaceholder":91},[61,771,772],{"class":63,"line":147},[61,773,576],{},[16,775,776,777,779],{},"這樣子就可以做跨元件傳遞了，你可以發現 Button 不再透過 Props 方式接收而是透過 ",[37,778,365],{}," 來接收並取代。",[333,781,688],{"height":335,"style":336,"scrolling":337,"title":686,"src":687,"frameBorder":337,"loading":340,"allowTransparency":341,"allowFullScreen":341},[16,783,784],{},"接著讓我們看一張圖了解一下目前資料是怎麼傳遞的",[16,786,787],{},[29,788],{"alt":535,"src":789},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Fithelp2022-react\u002F202209040119.png",[16,791,792,793,795,796,798],{},"透過上方圖片我們可以看到資料直接跨過了 ",[37,794,565],{}," 傳遞到 ",[37,797,43],{}," 元件。",[16,800,801],{},"而這個概念基本上與 Vue 的 Provide \u002F Inject 非常雷同，你可以隨時自己決定何時要 Inject，在後面我們會來進入一些簡單的開發，讓前面知識點可以貫穿起來。",[16,803,804,805,807,808,810,811,814],{},"這邊有一個小小注意事項要注意，使用 ",[37,806,527],{}," 的時候它能接收的只有 ",[37,809,535]