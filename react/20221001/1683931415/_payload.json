[{"data":1,"prerenderedAt":746},["ShallowReactive",2],{"header-locale:\u002Freact\u002F20221001\u002F1683931415\u002F":3,"page:\u002Freact\u002F20221001\u002F1683931415\u002F":4,"alt:\u002Freact\u002F20221001\u002F1683931415\u002F":3,"prev-next:\u002Freact\u002F20221001\u002F1683931415\u002F":722,"related:\u002Freact\u002F20221001\u002F1683931415\u002F":731},"\u002Fen\u002Freact\u002F2022\u002F10\u002F01\u002Freact-day-17-custom-hooks\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":706,"date":707,"description":18,"extension":708,"lang":709,"meta":710,"navigation":233,"path":711,"readingMinutes":712,"seo":713,"standalone":714,"stem":715,"tags":716,"tldr":719,"updated":719,"url":720,"__hash__":721},"content\u002F終究都要學 React 何不現在學呢？\u002F17-終究都要學-React-何不現在學呢？-React-進階-Custom-Hook.md","終究都要學 React 何不現在學呢？ - React 進階 - Custom Hook - (17)","1683931415",{"type":9,"value":10,"toc":699},"minimark",[11,15,19,23,26,29,32,38,46,81,87,90,94,100,103,247,258,268,276,295,308,378,384,422,427,430,434,444,514,519,534,552,567,576,586,653,658,661,677,680,683,686,695],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"我們在前面章節認識到了許多 React Hooks，但是這些 Hooks 都是由 React 官方所提供的，那如果我們想自訂自己的 Hooks 可不可以？所以這一篇就要來認識 React Hook 中的 Custom Hook。",[12,20,22],{"id":21},"custom-hook","Custom Hook",[16,24,25],{},"那麼什麼是 Custom Hook？再提 Custom Hook 之前我們先提提另一件事情。",[16,27,28],{},"實際開發的時候往往會遇到重複性的邏輯，那麼當遇到重複性的邏輯時我們就會將這一段重複性的邏輯抽出來變成一個函式，以便我們重複的使用以及維護。",[16,30,31],{},"那麼為什麼要提到這件事情呢？因為 React 的 Custom Hook 就是在幫我們做這件事情，這時候你應該會有一個疑問點「Custom Hook 到底是什麼東西？」",[16,33,34],{},[35,36,37],"strong",{},"其實就只是一個 JavaScript Function 而已，只是裡面有使用到 React Hook，就是這麼簡單。",[16,39,40,41,45],{},"那麼在使用 Custom Hook 時需要遵守一個基本的規則，也就是函式的名稱 (Function Name) 必須為 「",[42,43,44],"code",{},"use","」 開頭，並且通常後方的函式名稱會是首字大寫，如同前面章節所認識到的其他 Hook 一樣",[47,48,49,55,60,65,70,75],"ul",{},[50,51,52],"li",{},[42,53,54],{},"useState",[50,56,57],{},[42,58,59],{},"useEffect",[50,61,62],{},[42,63,64],{},"useCallback",[50,66,67],{},[42,68,69],{},"useReducer",[50,71,72],{},[42,73,74],{},"useMemo",[50,76,77,80],{},[42,78,79],{},"useRef","\n...",[16,82,83,84,86],{},"你可以看到前面舉例的 React Hook 通通都是 ",[42,85,44],{}," + 首字大寫名稱，那麼我們在撰寫 Custom Hook 的時候也是要遵守這個規則。",[16,88,89],{},"那麼接下來會舉例一些 Custom Hook 的簡單應用，這樣子可以讓你更加的了解 Custom Hook 的撰寫與應用。",[12,91,93],{"id":92},"usekeydown","useKeyDown",[16,95,96,97,99],{},"那麼第一個 Custom Hook 範例就讓我們來實作一個 ",[42,98,93],{}," 的 Custom Hook 吧！",[16,101,102],{},"首先目前底下程式碼是當你按下鍵盤上任一按鍵時，將會在畫面上顯示出你按下的按鍵",[104,105,110],"pre",{"className":106,"code":107,"language":108,"meta":109,"style":109},"language-jsx shiki shiki-themes github-light github-light github-dark-high-contrast","const App = () => {\n  const [keyDown, setKeyDown] = React.useState('');\n  \n  React.useEffect(() => {\n    document.addEventListener('keydown', (event) => {\n      setKeyDown(event.key);\n    });\n    return () => {\n      document.removeEventListener('keydown', ()=> {\n        setKeyDown('');\n      });\n    }\n  }, []);\n  return (\n    \u003Cdiv>\n      \u003Ch1>你目前按下的按鈕是：{ keyDown }\u003C\u002Fh1>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n","jsx","",[42,111,112,120,126,132,138,144,150,156,162,168,174,180,186,192,198,204,210,216,222,228,235,241],{"__ignoreMap":109},[113,114,117],"span",{"class":115,"line":116},"line",1,[113,118,119],{},"const App = () => {\n",[113,121,123],{"class":115,"line":122},2,[113,124,125],{},"  const [keyDown, setKeyDown] = React.useState('');\n",[113,127,129],{"class":115,"line":128},3,[113,130,131],{},"  \n",[113,133,135],{"class":115,"line":134},4,[113,136,137],{},"  React.useEffect(() => {\n",[113,139,141],{"class":115,"line":140},5,[113,142,143],{},"    document.addEventListener('keydown', (event) => {\n",[113,145,147],{"class":115,"line":146},6,[113,148,149],{},"      setKeyDown(event.key);\n",[113,151,153],{"class":115,"line":152},7,[113,154,155],{},"    });\n",[113,157,159],{"class":115,"line":158},8,[113