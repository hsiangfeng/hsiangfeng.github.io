en\u003C\u002Fa>.\n",[771,955,769],{"id":956},"只能用於-function-component",[16,958,959],{},"React Hooks 本身是基於 Function Component 所設計的，因此就只能在 Function Component 中使用，是不能在 Class Components 中使用的。",[30,961,963],{"className":32,"code":962,"language":34,"meta":35,"style":35},"class App extends React.Component {\n  constructor(props) {\n    const [count, setCount] = React.useState(0);\n    super(props);\n    this.state = {\n      count: 0,\n    };\n  }\n\n  sayHi() {\n    window.alert('Hello Ray.');\n  }\n  \n  render() {\n    return (\n      \u003Cdiv>\n        \u003Cbutton type=\"button\" onClick={ this.sayHi }>打招呼\u003C\u002Fbutton>\n      \u003C\u002Fdiv>\n    );\n  }\n}\n",[37,964,965,969,973,977,981,985,989,993,997,1001,1005,1009,1013,1017,1021,1025,1029,1033,1037,1041,1045],{"__ignoreMap":35},[40,966,967],{"class":42,"line":43},[40,968,46],{},[40,970,971],{"class":42,"line":49},[40,972,52],{},[40,974,975],{"class":42,"line":55},[40,976,802],{},[40,978,979],{"class":42,"line":61},[40,980,58],{},[40,982,983],{"class":42,"line":67},[40,984,64],{},[40,986,987],{"class":42,"line":73},[40,988,70],{},[40,990,991],{"class":42,"line":79},[40,992,76],{},[40,994,995],{"class":42,"line":86},[40,996,95],{},[40,998,999],{"class":42,"line":92},[40,1000,83],{"emptyLinePlaceholder":82},[40,1002,1003],{"class":42,"line":98},[40,1004,106],{},[40,1006,1007],{"class":42,"line":103},[40,1008,112],{},[40,1010,1011],{"class":42,"line":109},[40,1012,95],{},[40,1014,1015],{"class":42,"line":115},[40,1016,123],{},[40,1018,1019],{"class":42,"line":120},[40,1020,163],{},[40,1022,1023],{"class":42,"line":126},[40,1024,169],{},[40,1026,1027],{"class":42,"line":132},[40,1028,175],{},[40,1030,1031],{"class":42,"line":138},[40,1032,205],{},[40,1034,1035],{"class":42,"line":144},[40,1036,211],{},[40,1038,1039],{"class":42,"line":150},[40,1040,217],{},[40,1042,1043],{"class":42,"line":155},[40,1044,95],{},[40,1046,1047],{"class":42,"line":160},[40,1048,228],{},[247,1050,1053],{"height":249,"style":250,"scrolling":251,"title":1051,"src":1052,"frameBorder":251,"loading":254,"allowTransparency":255,"allowFullScreen":255},"(15) React Hooks Good","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FZExqYqv?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FZExqYqv\">\n  (15) React Hooks Good\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,1055,1056],{},"其實也不用特別去記，因為如果你真的做這種事情的話，你也可以在 Console 看到以下提示訊息：",[30,1058,1062],{"className":1059,"code":1060,"language":1061,"meta":35,"style":35},"language-cmd shiki shiki-themes github-dark-high-contrast","Uncaught Error: Invalid hook call. Hooks can only be called inside of the body of a function component. This could happen for one of the following reasons:\n1. You might have mismatching versions of React and the renderer (such as React DOM)\n2. You might be breaking the Rules of Hooks\n3. You might have more than one copy of React in the same app\nSee https:\u002F\u002Freactjs.org\u002Flink\u002Finvalid-hook-call for tips about how to debug and fix this problem.\n","cmd",[37,1063,1064,1069,1074,1079,1084],{"__ignoreMap":35},[40,1065,1066],{"class":42,"line":43},[40,1067,1068],{},"Uncaught Error: Invalid hook call. Hooks can only be called inside of the body of a function component. This could happen for one of the following reasons:\n",[40,1070,1071],{"class":42,"line":49},[40,1072,1073],{},"1. You might have mismatching versions of React and the renderer (such as React DOM)\n",[40,1075,1076],{"class":42,"line":55},[40,1077,1078],{},"2. You might be breaking the Rules of Hooks\n",[40,1080,1081],{"class":42,"line":61},[40,1082,1083],{},"3. You might have more than one copy of React in the same app\n",[40,1085,1086],{"class":42,"line":67},[40,1087,1088],{},"See https:\u002F\u002Freactjs.org\u002Flink\u002Finvalid-hook-call for tips about how to debug and fix this problem.\n",[16,1090,1091],{},"除此之外 React Hooks 與 Vue3 composition API 一樣都是向後兼容的，因此是可以一個專案內同時擁有 Class Component 跟 Function Component 寫法。",[16,1093,1094,1095,1102],{},"這時候你可能會延伸一個問題「那我該用 Class Component 開發還是 Function Component？還是兩者一起？」其實這個問題在官方文件就有提到，所以就直接擷取",[1096,1097,1101],"a",{"href":1098,"rel":1099},"https:\u002F\u002Fzh-hant.reactjs.org\u002Fdocs\u002Fhooks-faq.html#should-i-use-hooks-classes-or-a-mix-of-both",[1100],"nofollow","官方文件","的說明",[1104,1105,1106],"blockquote",{},[16,1107,1108],{},"當你準備好時，我們鼓勵開始使用 Hook 撰寫你新的 component。確保你團隊的成員們使用 Hook 並熟悉本文件。我們並不鼓勵你重寫現有的 class component 成 Hook，除非你已經計劃重寫它們（例如：修正 bug）。\n你不可以在 class component 內使用 Hook，但你絕對可以在單個 tree 中將 class 和 function component 與 Hook 混合使用。無論是 class 或 function component，使用 Hook 是該 component 實作的細節。從長遠來看，我們期待 Hook 可以是大家撰寫 React component 的主要方式。",[16,1110,1111],{},"因此其實看得出來 React Hooks 必定會成為主流，畢竟官方比較期望你使用 React Hooks。",[12,1113,1114],{"id":1114},"後記",[16,1116,1117],{},"本文將會同步更新到我的部落格",[761,1119,1120],{},[764,1121,1122],{},[1096,1123,1126],{"href":1124,"rel":1125},"https:\u002F\u002Fisraynotarray.com\u002F",[1100],"是 Ray 不是 Array",[1128,1129,1130],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{-