ps:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FQWmYRqy?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FQWmYRqy\">\n  (55)Vue Nested Components\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,209,210,211,213],{},"透過 ",[27,212,37],{}," 指令就可以輕鬆達到修改資料，並同時觸發 re-render 的行為刷新畫面，而這就是所謂的雙向綁定機制，如果你對於這一塊雙向綁定機制有興趣的話，可以閱讀我先前寫的文章",[215,216,217,227],"ul",{},[218,219,220],"li",{},[221,222,226],"a",{"href":223,"rel":224},"https:\u002F\u002Fisraynotarray.com\u002Fvue\u002F20210607\u002F665675438\u002F",[225],"nofollow","淺談 Vue2 雙向綁定的概念與實作",[218,228,229],{},[221,230,233],{"href":231,"rel":232},"https:\u002F\u002Fisraynotarray.com\u002Fvue\u002F20210627\u002F555169856\u002F",[225],"淺談 Vue3 雙向綁定的概念與實作",[16,235,236,237,240,241,244],{},"請注意 Vue2 與 Vue3 的底層實作分為 ",[27,238,239],{},"Object.defineProperty"," 跟 ES6 ",[27,242,243],{},"Proxy","，因此是有差異的。",[16,246,247],{},"那麼 React 呢？React 也是類似的嗎？所以接著讓我們看 React 在針對資料上是如何處理的。",[12,249,251],{"id":250},"react-state","React State",[16,253,254],{},"前面章節我們聊了許多 React 的東西，也稍微提到了 Vue 的雙向綁定機制，但是其實我們並沒有真正開始進入 React Hook 的介紹，一個 Hook 都沒有。",[16,256,257],{},"所以接著就要來介紹第一個 Hook，也就是 State Hook。",[16,259,260,261,263,264,266],{},"那麼 State 中文就是狀態的意思，是什麼的狀態呢？意指的資料狀態，因此其實與 Vue 的 ",[27,262,29],{},"、",[27,265,33],{}," 非常相像，因為我們會需要傳入一個初始值給予 State 作為監聽使用。",[16,268,269,270,273],{},"但在 React 中稍微有一點不同，React Hook 的 State Hook 其實是在指 ",[27,271,272],{},"useState"," 這個函式，而基本的寫法如下：",[40,275,279],{"className":276,"code":277,"language":278,"meta":45,"style":45},"language-jsx shiki shiki-themes github-light github-light github-dark-high-contrast","const [myName, setMyName] = React.useState('Ray');\n","jsx",[27,280,281],{"__ignoreMap":45},[49,282,283],{"class":51,"line":52},[49,284,277],{},[16,286,287,289,290,294],{},[27,288,272],{}," 函式會回傳一個陣列，通常我們會使用 ",[291,292,293],"strong",{},"陣列解構"," 取出兩個變數，第一個變數會作為渲染顯示用、單純的資料，第二個則是告知 React 資料有變化，所以要重新 re-render。",[16,296,297,298,301],{},"舉例來講當畫面有一顆按鈕，點擊後觸發替換內容，如果你不是使用 ",[27,299,300],{},"setMyName"," 的話是不會有任何效果的",[40,303,305],{"className":276,"code":304,"language":278,"meta":45,"style":45},"const App = () => {\n  let [myName, setMyName] = React.useState('Ray');\n \n  return (\n    \u003Cdiv>\n      { myName }\n      \u003Cbutton type=\"button\" onClick={ () => myName = 'QQ' }>改名\u003C\u002Fbutton>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n",[27,306,307,312,317,322,327,332,337,342,347,352,357,361,366,371],{"__ignoreMap":45},[49,308,309],{"class":51,"line":52},[49,310,311],{},"const App = () => {\n",[49,313,314],{"class":51,"line":81},[49,315,316],{},"  let [myName, setMyName] = React.useState('Ray');\n",[49,318,319],{"class":51,"line":88},[49,320,321],{}," \n",[49,323,324],{"class":51,"line":106},[49,325,326],{},"  return (\n",[49,328,329],{"class":51,"line":115},[49,330,331],{},"    \u003Cdiv>\n",[49,333,334],{"class":51,"line":139},[49,335,336],{},"      { myName }\n",[49,338,339],{"class":51,"line":145},[49,340,341],{},"      \u003Cbutton type=\"button\" onClick={ () => myName = 'QQ' }>改名\u003C\u002Fbutton>\n",[49,343,344],{"class":51,"line":154},[49,345,346],{},"    \u003C\u002Fdiv>\n",[49,348,349],{"class":51,"line":160},[49,350,351],{},"  )\n",[49,353,354],{"class":51,"line":166},[49,355,356],{},"}\n",[49,358,359],{"class":51,"line":172},[49,360,85],{"emptyLinePlaceholder":84},[49,362,363],{"class":51,"line":178},[49,364,365],{},"const app = document.querySelector('#app');\n",[49,367,368],{"class":51,"line":183},[49,369,370],{},"const root = ReactDOM.createRoot(app);\n",[49,372,374],{"class":51,"line":373},14,[49,375,376],{},"root.render(\u003CApp \u002F>);\n",[198,378,381],{"height":200,"style":201,"scrolling":202,"title":379,"src":380,"frameBorder":202,"loading":205,"allowTransparency":206,"allowFullScreen":206},"(64) React State Hook","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FeYMxwpr?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FeYMxwpr\">\n  (64) React State Hook\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,383,384],{},"主要原因是，如果你要修改變數的資料是必須使用第二個解構出來的變數才是正確姿勢，只是這邊要注意一件事情第二個解構出來的變數，會是一個函式",[40,386,388],{"className":276,"code":387,"language":278,"meta":45,"style":45},"const App = () => {\n  let [myName, setMyName] = React.useState('Ray');\n \n  return (\n    \u003Cdiv>\n      { myName }\n      \u003Cbutton type=\"button\" onClick={ () => setMyName('QQ') }>改名\u003C\u002Fbutton>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n",[27,389,390,394,398,402,406,410,414,419,423,427,431,435,439,443],{"__ignoreMap":45},[49,391,392],{"class":51,"line":52},[49,393,311],{},[49,395,396],{"class":51,"line":81},[49,397,316],{},[49,399,400],{"class":51,"line":88},[49,401,321],{},[49,403,404],{"class":51,"line":106},[49,405,326],{},[49,407,408],{"class":51,"line":115},[49,409,331],{},[49,411,412],{"class":51,"line":139},[49,413,336],{},[49,415,416],{"class":51,"line":145},[49,417,418],{},"      \u003Cbutton type=\"button\" onClick={ () => setMyName('QQ') }>改名\u003C\u002Fbutton>\n",[49,420,421],{"class":51,"line":154},[49,422,346],{},[49,424,425],{"class":51,"line":160},[49,426,351],{},[49,428,429],{"class":51,"line":166},[49,430,356],{},[49,432,433],{"class":51,"line":172},[49,434,85],{"emptyLinePlaceholder":84},[49,436,437],{"class":51,"line":178},[49,438,365],{},[49,440,441],{"class":51,"line":183},[49,442,370],{},[49,444,445],{"class":51,"line":373},[49,446,376],{},[198,448,450],{"height":200,"style":201,"scrolling":202,"title":379,"src":449,"frameBorder":202,"loading":205,"allowTransparency":206,"allowFullScreen":206},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FWNzPqrj?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FWNzPqrj\">\n  (64) React State Hook\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,452,453,454,457],{},"透過這個方式，我們可以發現在 React 裡面我們必須自己去 ",[291,455,456],{},"決定觸發函式的時機","，這樣子畫面才會 re-render。",[16,459,460,461,463],{},"而第二個參數(",[27,462,300],{},")就是在專門觸發 re-render 的，與我們在 Vue 時開發是不同的狀況，因為我們在撰寫 Vue 時，基本上是屬於即改即更新，而 React 則是可以自己決定何時更新畫面，這也是為什麼 React 會被說是資料屬於單向綁定，因為我們只是單純的把資料綁定畫面上，但資料就算更新了，我們也可以決定不更新，因此只要你不呼叫特定函式，那麼畫面也不會更新，反之 Vue 則是只要資料只要有變化，那麼畫面就必定會更新(除非你沒寫好或者踩雷了)。",[16,465,466],{},"在開始撰寫 Hook 之前，請切記前面章節所提的 React Hook 的規則：",[215,468,469,472],{},[218,470,471],{},"只能在函式頂層使用",[218,473,474],{},"只能用於 Function Component",[16,476,477],{},"因為這件事情很重要！\n因為這件事情很重要！\n因為這件事情很重要！",[16,479,480,481,483,484,486,487],{},"拉回到 ",[27,482,272],{}," 的部分，那麼 ",[27,485,272],{}," 做了什麼事情呢？我們傳入了一個字串之後，它會回傳一個陣列，裡面是 ",[27,488,489],{},"Array [ \"Ray\", dispatchSetState() ]",[16,491,492],{},[493,494],"img",{"alt":272,"src":495},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Fithelp2022-react\u002F%E6%88%AA%E5%9C%96%202022-08-21%2021.31.35.png",[16,497,498,499,502,503,506],{},"就如同前面所言，陣列解構的第一個會是一個單純的值，也就是你傳入的值，第二個則是一個函式，而 ",[27,500,501],{},"dispatchSetState"," 函式就是用來觸發 re-render 用的，因此當 ",[27,504,505],{},"myName"," 的值被更新時就會觸發畫面更新",[40,508,510],{"className":276,"code":509,"language":278,"meta":45,"style":45},"const App = () => {\n  const [myName, setMyName] = React.useState('Ray');\n  \n  return (\n    \u003Cdiv>\n      { myName }\n      \u003Cbutton type=\"button\" onClick={ () => setMyName('QQ 先生') }>更改名字\u003C\u002Fbutton>\n    \u003C