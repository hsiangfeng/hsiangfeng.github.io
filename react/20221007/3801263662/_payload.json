2Fexample-vite-react\u002F","，這樣就可以確保本地端開發的時候不會發生奇怪的問題。",[33,565,569],{"className":566,"code":567,"language":568,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","import { defineConfig } from 'vite'\nimport react from '@vitejs\u002Fplugin-react'\n\n\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\nexport default defineConfig({\n  base: process.env.NODE_ENV === 'production' ? '\u002Fexample-vite-react\u002F' : '\u002F',\n  plugins: [react()]\n})\n","js",[40,570,571,588,600,604,610,626,656,667],{"__ignoreMap":38},[43,572,573,577,581,584],{"class":45,"line":46},[43,574,576],{"class":575},"sWyjQ","import",[43,578,580],{"class":579},"sMAXC"," { defineConfig } ",[43,582,583],{"class":575},"from",[43,585,587],{"class":586},"sTRMh"," 'vite'\n",[43,589,590,592,595,597],{"class":45,"line":52},[43,591,576],{"class":575},[43,593,594],{"class":579}," react ",[43,596,583],{"class":575},[43,598,599],{"class":586}," '@vitejs\u002Fplugin-react'\n",[43,601,602],{"class":45,"line":59},[43,603,56],{"emptyLinePlaceholder":55},[43,605,606],{"class":45,"line":65},[43,607,609],{"class":608},"sQrFR","\u002F\u002F https:\u002F\u002Fvitejs.dev\u002Fconfig\u002F\n",[43,611,612,615,618,622],{"class":45,"line":70},[43,613,614],{"class":575},"export",[43,616,617],{"class":575}," default",[43,619,621],{"class":620},"sj_SG"," defineConfig",[43,623,625],{"class":624},"s_sBn","({\n",[43,627,628,631,635,638,641,644,647,650,653],{"class":45,"line":76},[43,629,630],{"class":579},"  base: process.env.",[43,632,634],{"class":633},"sCcAr","NODE_ENV",[43,636,637],{"class":575}," ===",[43,639,640],{"class":586}," 'production'",[43,642,643],{"class":575}," ?",[43,645,646],{"class":586}," '\u002Fexample-vite-react\u002F'",[43,648,649],{"class":575}," :",[43,651,652],{"class":586}," '\u002F'",[43,654,655],{"class":624},",\n",[43,657,658,661,664],{"class":45,"line":82},[43,659,660],{"class":579},"  plugins: [",[43,662,663],{"class":620},"react",[43,665,666],{"class":579},"()]\n",[43,668,669],{"class":45,"line":87},[43,670,671],{"class":624},"})\n",[16,673,674,675,678],{},"接著建立一個叫做 ",[40,676,677],{},"deploy.sh"," 的檔案，並且輸入以下內容（這邊以我的儲存庫當作範例）",[33,680,684],{"className":681,"code":682,"language":683,"meta":38,"style":38},"language-sh shiki shiki-themes github-dark-high-contrast","#!\u002Fusr\u002Fbin\u002Fenv sh\n\n# 發生錯誤時執行終止指令\nset -e\n\n# 打包編譯\nnpm run build\n\n# 移動到打包資料夾下，若你有調整的話打包後的資料夾請務必調整\ncd dist\n\n# 部署到自定義網域\n# echo 'www.example.com' > CNAME\n\ngit init\ngit add -A\ngit commit -m 'deploy'\n\n# 部署到 https:\u002F\u002F\u003CUSERNAME>.github.io\n# git push -f git@github.com:\u003CUSERNAME>\u002F\u003CUSERNAME>.github.io.git master\n\n# 部署到 https:\u002F\u002F\u003CUSERNAME>.github.io\u002F\u003CREPO>\n# git push -f git@github.com:\u003CUSERNAME>\u002F\u003CREPO>.git master:gh-pages\n# 以這個專案來講就要改成這樣以下這樣，下面是走 ssh 模式\ngit push -f git@github.com:hsiangfeng\u002Fexample-vite-react.git master:gh-pages\n# 除此之外，也可以改走 HTTPS 模式\n# git push -f https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-vite-react master:gh-pages\n\ncd -\n","sh",[40,685,686,691,695,700,708,712,717,728,732,737,745,749,754,759,763,771,781,794,798,803,808,812,817,822,827,843,848,853,857],{"__ignoreMap":38},[43,687,688],{"class":45,"line":46},[43,689,690],{"class":608},"#!\u002Fusr\u002Fbin\u002Fenv sh\n",[43,692,693],{"class":45,"line":52},[43,694,56],{"emptyLinePlaceholder":55},[43,696,697],{"class":45,"line":59},[43,698,699],{"class":608},"# 發生錯誤時執行終止指令\n",[43,701,702,705],{"class":45,"line":65},[43,703,704],{"class":633},"set",[43,706,707],{"class":633}," -e\n",[43,709,710],{"class":45,"line":70},[43,711,56],{"emptyLinePlaceholder":55},[43,713,714],{"class":45,"line":76},[43,715,716],{"class":608},"# 打包編譯\n",[43,718,719,722,725],{"class":45,"line":82},[43,720,721],{"class":624},"npm",[43,723,724],{"class":586}," run",[43,726,727],{"class":586}," build\n",[43,729,730],{"class":45,"line":87},[43,731,56],{"emptyLinePlaceholder":55},[43,733,734],{"class":45,"line":