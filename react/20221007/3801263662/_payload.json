 onChange={ updateTodo } data-id={ todo.id } checked={ todo.status }\u002F>\n          { todo.name }\n        \u003C\u002Flabel>\n      \u003C\u002Fli>\n    )\n  }\n\n  return ( \u003Cul> { todoList.map((todo) => template(todo)) } \u003C\u002Ful> )\n}\n\nexport default List;\n",[40,359,360,365,369,374,379,384,389,394,398,403,408,412,417,422,426,431,436,441,446,451,456,461,466,471,475,479,484,488,492],{"__ignoreMap":38},[43,361,362],{"class":45,"line":46},[43,363,364],{},"const List = ({ todoList, setTodoList }) => {\n",[43,366,367],{"class":45,"line":52},[43,368,56],{"emptyLinePlaceholder":55},[43,370,371],{"class":45,"line":59},[43,372,373],{},"  const updateTodo = (event) => {\n",[43,375,376],{"class":45,"line":65},[43,377,378],{},"    const { id } = event.target.dataset;\n",[43,380,381],{"class":45,"line":70},[43,382,383],{},"    const newTodoList = todoList.map((todo) => {\n",[43,385,386],{"class":45,"line":76},[43,387,388],{},"      if(todo.id === Number(id)) {\n",[43,390,391],{"class":45,"line":82},[43,392,393],{},"        todo.status = !todo.status;\n",[43,395,396],{"class":45,"line":87},[43,397,132],{},[43,399,400],{"class":45,"line":93},[43,401,402],{},"      return todo;\n",[43,404,405],{"class":45,"line":99},[43,406,407],{},"    });\n",[43,409,410],{"class":45,"line":105},[43,411,56],{"emptyLinePlaceholder":55},[43,413,414],{"class":45,"line":111},[43,415,416],{},"    setTodoList([ ...newTodoList ]);\n",[43,418,419],{"class":45,"line":117},[43,420,421],{},"  }\n",[43,423,424],{"class":45,"line":123},[43,425,56],{"emptyLinePlaceholder":55},[43,427,428],{"class":45,"line":129},[43,429,430],{},"  const template = (todo) => {\n",[43,432,433],{"class":45,"line":135},[43,434,435],{},"    return (\n",[43,437,438],{"class":45,"line":141},[43,439,440],{},"      \u003Cli className=\"py-4\" key={ todo.id }>\n",[43,442,443],{"class":45,"line":147},[43,444,445],{},"        \u003Clabel className={ todo.status ? 'line-through' : ''}>\n",[43,447,448],{"class":45,"line":1