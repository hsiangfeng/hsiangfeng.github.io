[{"data":1,"prerenderedAt":279},["ShallowReactive",2],{"header-locale:\u002Freact\u002F20220630\u002F2836098051\u002F":3,"page:\u002Freact\u002F20220630\u002F2836098051\u002F":4,"alt:\u002Freact\u002F20220630\u002F2836098051\u002F":3,"prev-next:\u002Freact\u002F20220630\u002F2836098051\u002F":255,"related:\u002Freact\u002F20220630\u002F2836098051\u002F":264},"\u002Fen\u002Freact\u002F2022\u002F06\u002F30\u002Fcreate-react-app-behind-latest-release-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":239,"date":240,"description":18,"extension":241,"lang":242,"meta":243,"navigation":60,"path":244,"readingMinutes":245,"seo":246,"standalone":247,"stem":248,"tags":249,"tldr":252,"updated":252,"url":253,"__hash__":254},"content\u002FReact\u002F安裝-CRA-出現-You-are-running-create-react-app-which-is-behind-the-latest-release.md","安裝 CRA 出現 You are running create-react-app, which is behind the latest release","2836098051",{"type":9,"value":10,"toc":234},"minimark",[11,15,19,22,25,42,45,113,120,131,146,155,166,169,188,191,200,209,212,215,230],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近在弄一點東西所以需要使用 React CRA(create-react-app)，但卻出現一個錯誤，所以這一篇記錄一下解決方式。",[12,20,21],{"id":21},"錯誤原因",[16,23,24],{},"目前來講最新版本 React CRA 是 5.0.3，但我只要使用 npx 指定版本安裝",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-cmd shiki shiki-themes github-dark-high-contrast","npx create-react-app@4.0.3 my-app\n","cmd","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40],"span",{"class":38,"line":39},"line",1,[36,41,29],{},[16,43,44],{},"接下來就會出現一個錯誤",[26,46,48],{"className":28,"code":47,"language":30,"meta":31,"style":31},"You are running `create-react-app` 4.0.3, which is behind the latest release (5.0.1).\n\nWe no longer support global installation of Create React App.\n\nPlease remove any global installs with one of the following commands:\n\n- npm uninstall -g create-react-app\n- yarn global remove create-react-app\n\nThe latest instructions for creating a new app can be found here:\nhttps:\u002F\u002Fcreate-react-app.dev\u002Fdocs\u002Fgetting-started\u002F\n",[33,49,50,55,62,68,73,79,84,90,96,101,107],{"__ignoreMap":31},[36,51,52],{"class":38,"line":39},[36,53,54],{},"You are running `create-react-app` 4.0.3, which is behind the latest release (5.0.1).\n",[36,56,58],{"class":38,"line":57},2,[36,59,61],{"emptyLinePlaceholder":60},true,"\n",[36,63,65],{"class":38,"line":64},3,[36,66,67],{},"We no longer support global installation of Create React App.\n",[36,69,71],{"class":38,"line":70},4,[36,72,61],{"emptyLinePlaceholder":60},[36,74,76],{"class":38,"line":75},5,[36,77,78],{},"Please remove any global installs with one of the following commands:\n",[36,80,82],{"class":38,"line":81},6,[36,83,61],{"emptyLinePlaceholder":60},[36,85,87],{"class":38,"line":86},7,[36,88,89],{},"- npm uninstall -g create-react-app\n",[36,91,93],{"class":38,"line":92},8,[36,94,95],{},"- yarn global remove create-react-app\n",[36,97,99],{"class":38,"line":98},9,[36,100,61],{"emptyLinePlaceholder":60},[36,102,104],{"class":38,"line":103},10,[36,105,106],{},"The latest instructions for creating a new app can be found here:\n",[36,108,110],{"class":38,"line":109},11,[36,111,112],{},"https:\u002F\u002Fcreate-react-app.dev\u002Fdocs\u002Fgetting-started\u002F\n",[16,114,115],{},[116,117],"img",{"alt":118,"src":119},"錯誤","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-06-30%2023.44.25.png",[16,121,122,123,126,127,130],{},"那麼這邊就算依照畫面上的提示輸入 ",[33,124,125],{},"npm uninstall -g create-react-app"," 或是 ",[33,128,129],{},"yarn global remove create-react-app"," 也都沒有辦法讓我安裝舊版的 CRA。",[16,132,133,134,141,142,145],{},"一開始我也有懷疑可能是我 Node.js 版本過高的關係，因此我使用的 nvm 切換到 Node.js 14.15.0 的版本嘗試依然無解，後來找到這一篇",[135,136,140],"a",{"href":137,"rel":138},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F70358643\u002Fyou-are-running-create-react-app-4-0-3-which-is-behind-the-latest-release-5-0",[139],"nofollow","You are running create-react-app 4.0.3 which is behind the latest release (5.0.0)","，說可以使用「",[33,143,144],{},"clear-npx-cache","」 嘗試解決，因為有可能是 npx cache 導致的問題",[26,147,149],{"className":28,"code":148,"language":30,"meta":31,"style":31},"npx clear-npx-cache\n",[33,150,151],{"__ignoreMap":31},[36,152,153],{"class":38,"line":39},[36,154,148],{},[16,156,157,158,161,162,165],{},"但我使用 ",[33,159,160],{},"npx clear-npx-cache"," 之後其實還是無法透過 ",[33,163,164],{},"npx create-react-app@4.0.3 my-app"," 安裝舊版 CRA。",[16,167,168],{},"看了滿多討論都是以下做法",[26,170,172],{"className":28,"code":171,"language":30,"meta":31,"style":31},"npm uninstall -g create-react-app\nnpx clear-npx-cache\nnpx create-react-app my-app\n",[33,173,174,179,183],{"__ignoreMap":31},[36,175,176],{"class":38,"line":39},[36,177,178],{},"npm uninstall -g create-react-app\n",[36,180,181],{"class":38,"line":57},[36,182,148],{},[36,184,185],{"class":38,"line":64},[36,186,187],{},"npx create-react-app my-app\n",[16,189,190],{},"可是上方的解法就等於直接安裝最新版的 CRA，可是我就是不想使用新版的(純粹要測一些東西)。",[16,192,193,194,199],{},"所以後來從官方 issues 找到",[135,195,198],{"href":196,"rel":197},"https:\u002F\u002Fgithub.com\u002Ffacebook\u002Fcreate-react-app\u002Fissues\u002F11816",[139],"相關","討論串中找到答案，正確來講如果要安裝以前的版本的話，要輸入以下指令才對",[26,201,203],{"className":28,"code":202,"language":30,"meta":31,"style":31},"npx create-react-app --scripts-version 4.0.3\n",[33,204,205],{"__ignoreMap":31},[36,206,207],{"class":38,"line":39},[36,208,202],{},[16,210,211],{},"這樣就成功安裝舊版的 CRA 囉~",[12,213,214],{"id":214},"參考文獻",[216,217,218,225],"ul",{},[219,220,221],"li",{},[135,222,224],{"href":196,"rel":223},[139],"You are running create-react-app 4.0.3, which is behind the latest release (5.0.0).",[219,226,227],{},[135,228,140],{"href":137,"rel":229},[139],[231,232,233],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":31,"searchDepth":57,"depth":57,"links":235},[236,237,238],{"id":14,"depth":57,"text":14},{"id":21,"depth":57,"text":21},{"id":214,"depth":57,"text":214},"React","2022-06-30 23:42:15","md","zh-Hant",{},"\u002Freact\u002Fcra-you-are-running-create-react-app-which-is-behind-the-latest-release","2",{"title":6,"description":18},false,"React\u002F安裝-CRA-出現-You-are-running-create-react-app-which-is-behind-the-latest-release",[239,250,251],"CRA","Create React App",null,"\u002Freact\u002F20220630\u002F2836098051\u002F","iz5j4FJWgQDLkumMO6865l-FJOiEQFJCugiDyI3NTR4",{"newer":256,"older":260},{"url":257,"title":258,"date":259},"\u002Ftailwindcss\u002F20220702\u002F88023210\u002F","讓 VSCode 的 Tailwind CSS IntelliSense 套件可以用於 React JSX","2022-07-02 21:32:31",{"url":261,"title":262,"date":263},"\u002Fnodejs\u002F20220623\u002F2852057115\u002F","統一管理 Dotenv 的服務 Dotenv Vault！","2022-06-23 10:55:15",[265,269,274],{"url":266,"title":267,"date":268,"readingMinutes":245},"\u002Freact\u002F20221014\u002F3383337781\u002F","終究都要學 React 何不現在學呢？ - 鐵人賽後記 - 目錄 - (30)","2022-10-14 00:00:01",{"url":270,"title":271,"date":272,"readingMinutes":273},"\u002Freact\u002F20221013\u002F1993947189\u002F","終究都要學 React 何不現在學呢？ - React Redux - Redux 與快速入門 - (29)","2022-10-13 00:00:01","5",{"url":275,"title":276,"date":277,"readingMinutes":278},"\u002Freact\u002F20221012\u002F622986263\u002F","終究都要學 React 何不現在學呢？ - React Router - Lazy Loading - (28)","2022-10-12 00:00:01","4",1784020400726]