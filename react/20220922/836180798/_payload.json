[{"data":1,"prerenderedAt":1448},["ShallowReactive",2],{"header-locale:\u002Freact\u002F20220922\u002F836180798\u002F":3,"page:\u002Freact\u002F20220922\u002F836180798\u002F":4,"alt:\u002Freact\u002F20220922\u002F836180798\u002F":3,"prev-next:\u002Freact\u002F20220922\u002F836180798\u002F":1424,"related:\u002Freact\u002F20220922\u002F836180798\u002F":1433},"\u002Fen\u002Freact\u002F2022\u002F09\u002F22\u002Freact-08-useeffect\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1408,"date":1409,"description":18,"extension":1410,"lang":1411,"meta":1412,"navigation":223,"path":1413,"readingMinutes":1414,"seo":1415,"standalone":1416,"stem":1417,"tags":1418,"tldr":1421,"updated":1421,"url":1422,"__hash__":1423},"content\u002F終究都要學 React 何不現在學呢？\u002F8-終究都要學-React-何不現在學呢？-React-基礎-useEffect.md","終究都要學 React 何不現在學呢？ - React 基礎 - useEffect - (8)","836180798",{"type":9,"value":10,"toc":1396},"minimark",[11,15,19,23,31,34,37,40,56,59,66,69,119,122,137,148,151,157,163,166,174,184,346,357,369,374,380,486,491,500,509,513,522,605,610,623,627,641,658,786,791,807,810,829,834,840,844,850,865,929,949,1230,1235,1249,1263,1272,1276,1288,1370,1375,1378,1381,1392],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來我們要來認識一個新的 React Hook，也就是 useEffect，那麼單看這個名子會覺得有一點特別，因為直接翻譯成中文來講是「使用效果」，那麼這是什麼東西呢？我們就來認識一下吧。",[12,20,22],{"id":21},"side-effect","Side Effect",[16,24,25,26,30],{},"開始 ",[27,28,29],"code",{},"useEffect"," 之前我們要先來認識一個東西，也就是 Side Effect(副作用)，那什麼是 Side Effect 呢？",[16,32,33],{},"最常見的形容詞就是醫生開的「藥」。",[16,35,36],{},"沒有錯，就是你想的那一個藥，醫生開給你的處方簽，你試想一下，你在感冒後拿到的藥袋上往往都會寫著「副作用」，而這個副作用可能會有過敏反應、嗜睡、腸胃不適等狀況。",[16,38,39],{},"雖然不得不承認「副作用」，這個中文很容易讓人覺得都是壞的，但是其實副作用也同時代表著有幫助、有益處的，讓我們來看一段簡易的描述...",[41,42,47],"pre",{"className":43,"code":44,"language":45,"meta":46,"style":46},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","你吃完藥之後身體會好轉，但相伴的就會是腸胃不適的反應\n","txt","",[27,48,49],{"__ignoreMap":46},[50,51,54],"span",{"class":52,"line":53},"line",1,[50,55,44],{},[16,57,58],{},"上面描述中，其實就包含了兩個 Side Effect，分別是「身體好轉」與「腸胃不適」，因此 Side Effect 並不全然都是壞的。",[16,60,61,62,65],{},"那麼為什麼要提到這個呢？其實像是我們常見的 AJAX、DOM 操作，甚至是 ",[27,63,64],{},"console.log"," 都是屬於 Side Effect 的一種，而我們實際開發上也時常仰賴著 Side Effect，因此了解 Side Effect 是有助於避免寫出一些危險的程式碼。",[16,67,68],{},"那以程式碼世界來講 Side Effect 是什麼樣的狀況呢？舉例來講，重新賦予的行為也是一種 Side Effect",[41,70,74],{"className":71,"code":72,"language":73,"meta":46,"style":46},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","var myName = 'Ray';\n... \u002F\u002F 幾千行之後\nmyName = 'Array';\n","js",[27,75,76,96,106],{"__ignoreMap":46},[50,77,78,82,86,89,93],{"class":52,"line":53},[50,79,81],{"class":80},"sOudu","var",[50,83,85],{"class":84},"s8XSl"," myName ",[50,87,88],{"class":80},"=",[50,90,92],{"class":91},"sWayO"," 'Ray'",[50,94,95],{"class":84},";\n",[50,97,99,102],{"class":52,"line":98},2,[50,100,101],{"class":80},"...",[50,103,105],{"class":104},"sGBqm"," \u002F\u002F 幾千行之後\n",[50,107,109,112,114,117],{"class":52,"line":108},3,[50,110,111],{"class":84},"myName ",[50,113,88],{"class":80},[50,115,116],{"class":91}," 'Array'",[50,118,95],{"class":84},[16,120,121],{},"相信你應該沒想到重新賦予值也算是 Side Effect 的一種吧。",[16,123,124,125,128,129,132,133,136],{},"沒有錯，只要你會修改到原始值就算是 Side Effect 的一種，我們可以看到上面範例的原始值是 ",[27,126,127],{},"'Ray'","，後來不知道幾百、幾千行之後我們將 ",[27,130,131],{},"myName"," 重新賦予成 ",[27,134,135],{},"'Array'","，而這過程就有可能會導致一些我們不可預期且難以排除的錯誤。",[16,138,139,140,147],{},"當然這邊只是大概了解一下而已，如果你對這一塊很感興趣的話，可以考慮參考看我先前寫的「",[141,142,146],"a",{"href":143,"rel":144},"https:\u002F\u002Fisraynotarray.com\u002Fother\u002F20211219\u002F3830068067\u002F",[145],"nofollow","簡單趣談 Functional Programming in JavaScript","」會更詳細。",[16,149,150],{},"這邊只是簡單談到什麼是 Side Effect 而已，畢竟 React 官網有一段是這樣：",[152,153,154],"blockquote",{},[16,155,156],{},"資料 fetch、設定 subscription、或手動改變 React component 中的 DOM 都是 side effect 的範例。",[16,158,159,160,162],{},"那麼大概了解什麼是 Side Effect 後，我們就準備來認識 ",[27,161,29],{}," 吧。",[12,164,29],{"id":165},"useeffect",[16,167,168,170,171,173],{},[27,169,29],{}," 主要大多用途都是在於我們畫面 render 之後要做某些事情，其實也就是在跟 React 說等一下 render 後要記得執行裡面的某些事情，通常放在這裡面的東西大多都跟 SideEffect 有關係，因此基本上會產生 Side Effect 的行為都會建議在 ",[27,172,29],{}," 裡面，像是前面所提到的 AJAX 行為、修改 DOM 操作等。",[16,175,176,177,179,180,183],{},"那如果放到 Vue 中的話 ",[27,178,29],{}," 類似什麼呢？類似 Composition API 的 ",[27,181,182],{},"onMounted","。",[41,185,187],{"className":71,"code":186,"language":73,"meta":46,"style":46},"const { createApp, ref, onMounted } = Vue;\n\nconst app = createApp({\n  setup() {\n    const text = ref('Hello Ray.');\n    \n    onMounted(() => {\n      console.log(text.value)\n    })\n  }\n});\n\napp.mount('#app');\n",[27,188,189,219,225,242,251,274,280,295,307,313,319,325,330],{"__ignoreMap":46},[50,190,191,194,197,201,204,207,209,211,214,216],{"class":52,"line":53},[50,192,193],{"class":80},"const",[50,195,196],{"class":84}," { ",[50,198,200],{"class":199},"stw71","createApp",[50,202,203],{"class":84},", ",[50,205,206],{"class":199},"ref",[50,208,203],{"class":84},[50,210,182],{"class":199},[50,212,213],{"class":84}," } ",[50,215,88],{"class":80},[50,217,218],{"class":84}," Vue;\n",[50,220,221],{"class":52,"line":98},[50,222,224],{"emptyLinePlaceholder":223},true,"\n",[50,226,227,229,232,235,239],{"class":52,"line":108},[50,228,193],{"class":80},[50,230,231],{"class":199}," app",[50,233,234],{"class":80}," =",[50,236,238],{"class":237},"scAaK"," createApp",[50,240,241],{"class":84},"({\n",[50,243,245,248],{"class":52,"line":244},4,[50,246,247],{"class":237},"  setup",[50,249,250],{"class":84},"() {\n",[50,252,254,257,260,262,265,268,271],{"class":52,"line":253},5,[50,255,256],{"class":80},"    const",[50,258,259],{"class":199}," text",[50,261,234],{"class":80},[50,263,264],{"class":237}," ref",[50,266,267],{"class":84},"(",[50,269,270],{"class":91},"'Hello Ray.'",[50,272,273],{"class":84},");\n",[50,275,277],{"class":52,"line":276},6,[50,278,279],{"class":84},"    \n",[50,281,283,286,289,292],{"class":52,"line":282},7,[50,284,285],{"class":237},"    onMounted",[50,287,288],{"class":84},"(() ",[50,290,291],{"class":80},"=>",[50,293,294],{"class":84}," {\n",[50,296,298,301,304],{"class":52,"line":297},8,[50,299,300],{"class":84},"      console.",[50,302,303],{"class":237},"log",[50,305,306],{"class":84},"(text.value)\n",[50,308,310],{"class":52,"line":309},9,[50,311,312],{"class":84},"    })\n",[50,314,316],{"class":52,"line":315},10,[50,317,318],{"class":84},"  }\n",[50,320,322],{"class":52,"line":321},11,[50,323,324],{"class":84},"});\n",[50,326,328],{"class":52,"line":327},12,[50,329,224],{"emptyLinePlaceholder":223},[50,331,333,336,339,341,344],{"class":52,"line":332},13,[50,334,335],{"class":84},"app.",[50,337,338],{"class":237},"mount",[50,340,267],{"class":84},[50,342,343],{"class":91},"'#app'",[50,345,273],{"class":84},[347,348,356],"iframe",{"height":349,"style":350,"scrolling":351,"title":352,"src":353,"frameBorder":351,"loading":354,"allowTransparency":355,"allowFullScreen":355},300,"width: 100%;","no","(63)Vue v-model","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FyLKmjQp?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FyLKmjQp\">\n  (63)Vue v-model\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,358,359,360,362,363,365,366,368],{},"雖然前面有提到 ",[27,361,29],{}," 就是「等一下 render 後要記得執行裡面的某些事情」，但 ",[27,364,29],{}," 基本上是會傳入兩個參數的，分別是函式跟陣列，第二個陣列主要是選填，因此隨著你的使用方式不同而也會得到不同的結果，因此讓我們接著認識一下 ",[27,367,29],{}," 各種做法吧。",[370,371,373],"h3",{"id":372},"after-ever-render每次渲染之後執行","After Ever Render（每次渲染之後執行）",[16,375,376,377,379],{},"首先先讓我們看看第一種 ",[27,378,29],{}," 的範例程式碼",[41,381,385],{"className":382,"code":383,"language":384,"meta":46,"style":46},"language-jsx shiki shiki-themes github-light github-light github-dark-high-contrast","function App (){\n  const [count, setCount] = React.useState(0);\n\n  React.useEffect(() => {\n    console.log('render');\n  })\n  \n  return (\n    \u003Cdiv>\n      \u003Cbutton type=\"button\" onClick={() => setCount(count + 1)}>\n        Count is: { count }\n      \u003C\u002Fbutton>\n    \u003C\u002Fdiv>\n  )\n}\n\nconst app = document.querySelector('#app');\nconst root = ReactDOM.createRoot(app);\nroot.render(\u003CApp \u002F>);\n","jsx",[27,386,387,392,397,401,406,411,416,421,426,431,436,441,446,451,457,463,468,474,480],{"__ignoreMap":46},[50,388,389],{"class":52,"line":53},[50,390,391],{},"function App (){\n",[50,393,394],{"class":52,"line":98},[50,395,396],{},"  const [count, setCount] = React.useState(0);\n",[50,398,399],{"class":52,"line":108},[50,400,224],{"emptyLinePlaceholder":223},[50,402,403],{"class":52,"line":244},[50,404,405],{},"  React.useEffect(() => {\n",[50,407,408],{"class":52,"line":253},[50,409,410],{},"    console.log('render');\n",[50,412,413],{"class":52,"line":276},[50,414,415],{},"  })\n",[50,417,418],{"class":52,"line":282},[50,419,420],{},"  \n",[50,422,423],{"class":52,"line":297},[50,424,425],{},"  return (\n",[50,427,428],{"class":52,"line":309},[50,429,430],{},"    \u003Cdiv>\n",[50,432,433],{"class":52,"line":315},[50,434,435],{},"      \u003Cbutton type=\"button\" onClick={() => setCount(count + 1)}>\n",[50,437,438],{"class":52,"line":321},[50,439,440],{},"        Count is: { count }\n",[50,442,443],{"class":52,"line":327},[50,444,445],{},"      \u003C\u002Fbutton>\n",[50,447,448],{"class":52,"line":332},[50,449,450],{},"    \u003C\u002Fdiv>\n",[50,452,454],{"class":52,"line":453},14,[50,455,456],{},"  )\n",[50,458,460],{"class":52,"line":459},15,[50,461,462],{},"}\n",[50,464,466],{"class":52,"line":465},16,[50,467,224],{"emptyLinePlaceholder":223},[50,469,471],{"class":52,"line":470},17,[50,472,473],{},"const app = document.querySelector('#app');\n",[50,475,477],{"class":52,"line":476},18,[50,478,479],{},"const root = ReactDOM.createRoot(app);\n",[50,481,483],{"class":52,