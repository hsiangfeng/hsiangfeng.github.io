 Child = () => {\n  const [state, dispatch] = React.useContext(CountContext);\n  return (\n    \u003Cdiv>\n      Child Count: {state.count}\n      \u003Cbr \u002F>\n      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"decrement\" })}>Decrement\u003C\u002Fbutton>｜\n      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"increment\" })}>Increment\u003C\u002Fbutton>\n    \u003C\u002Fdiv>\n  );\n}\n\nconst App = () => {\n  const countReducer = React.useReducer(reducer, initialState);\n\n  return (\n    \u003Cdiv>\n      App Count: {countReducer[0].count}\n      \u003Cbr \u002F>\n      \u003CCountContext.Provider value={countReducer}>\n        \u003CChild \u002F>\n      \u003C\u002FCountContext.Provider>\n    \u003C\u002Fdiv>\n  );\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[20,908,909,914,918,922,926,931,936,941,945,950,954,959,963,967,971,976,980,984,988,992,996,1000,1004,1008,1013,1018,1022,1026,1032,1037,1042,1047,1052,1057,1062,1067,1072,1078,1083,1088,1093,1099,1104,1110,1116,1122,1127,1132,1137,1142,1147],{"__ignoreMap":78},[82,910,911],{"class":84,"line":85},[82,912,913],{},"const CountContext = React.createContext();\n",[82,915,916],{"class":84,"line":209},[82,917,586],{"emptyLinePlaceholder":585},[82,919,920],{"class":84,"line":221},[82,921,252],{},[82,923,924],{"class":84,"line":339},[82,925,561],{},[82,927,928],{"class":84,"line":353},[82,929,930],{},"    case 'increment':\n",[82,932,933],{"class":84,"line":359},[82,934,935],{},"      return {\n",[82,937,938],{"class":84,"line":582},[82,939,940],{},"        count: state.count + 1\n",[82,942,943],{"class":84,"line":589},[82,944,806],{},[82,946,947],{"class":84,"line":595},[82,948,949],{},"    case 'decrement':\n",[82,951,952],{"class":84,"line":601},[82,953,935],{},[82,955,956],{"class":84,"line":606}