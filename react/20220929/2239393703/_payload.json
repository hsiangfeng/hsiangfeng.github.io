\n  }\n}\n\nconst initialState = {\n  count: 0,\n};\n\nconst Child = () => {\n  const [state, dispatch] = React.useContext(CountContext);\n  return (\n    \u003Cdiv>\n      Child Count: {state.count}\n      \u003Cbr \u002F>\n      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"decrement\" })}>Decrement\u003C\u002Fbutton>｜\n      \u003Cbutton type=\"button\" className=\"bg-blue-400 p-4 text-white hover:bg-blue-700\" onClick={() => dispatch({ type: \"increment\" })}>Increment\u003C\u002Fbutton>\n    \u003C\u002Fdiv>\n  );\n}\n\nconst App = () => {\n  const countReducer = React.useReducer(reducer, initialState);\n\n  return (\n    \u003Cdiv>\n      App Count: {countReducer[0].count}\n      \u003Cbr \u002F>\n      \u003CCountContext.Provider value={countReducer}>\n        \u003CChild \u002F>\n      \u003C\u002FCountContext.Provider>\n    \u003C\u002Fdiv>\n  );\n}\n\nconst root = ReactDOM.createRoot(document.querySelector('#root'));\nroot.render(\u003CApp \u002F>);\n",[20,909,910,915,919,923,927,932,937,942,946,951,955,960,964,968,972,977,981,985,989,993,997,1001,1005,1009,1014,1019,1023,1027,1033,1038,1043,1048,1053,1058,1063,1068,1073,1079,1084,1089,1094,1100,1105,1111,1117,1123,1128,1133,1138,1143,1148],{"__ignoreMap":78},[82,911,912],{"class":84,"line":85},[82,913,914],{},"const CountContext = React.createContext();\n",[82,916,917],{"class":84,"line":209},[82,918,587],{"emptyLinePlaceholder":586},[82,920,921],{"class":84,"line":221},[82,922,252],{},[82,924,925],{"class":84,"line":339},[82,926,562],{},[82,928,929],{"class":84,"line":353},[82,930,931],{},"    case 'increment':\n",[82,933,934],{"class":84,"line":359},[82,935,936],{},"      return {\n",[82,938,939],{"class":84,"line":583},[82,940,941],{},"        count: state.count + 1\n",[82,943,944],{"class":84,"line":590},[82,945,807],{},[82,947,948],{"class":84,"line":596},[82,949,950],{},"    case 'decrement':\n",[82,952,953],{"class":84,"lin