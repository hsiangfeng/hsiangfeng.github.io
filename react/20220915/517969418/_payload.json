     count: 0,\n    };\n\n    this.handleClick = this.handleClick.bind(this);\n  }\n\n  sayHi() {\n    window.alert('Hello Ray.');\n  }\n  \n  handleClick() {\n    this.setState((prevState) => ({\n      count: prevState.count += 1,\n    }));\n  }\n  \n  render() {\n    return (\n      \u003Cdiv>\n        \u003Cbutton onClick={this.handleClick}>\n          Count is: { this.state.count }\n        \u003C\u002Fbutton>\n        \u003Chr \u002F>\n        \u003Cbutton type=\"button\" onClick={ this.sayHi }>打招呼\u003C\u002Fbutton>\n      \u003C\u002Fdiv>\n    );\n  }\n}\n\nconst app = ReactDOM.createRoot(document.getElementById('app'));\napp.render(\u003CApp \u002F>);\n","jsx",[121,486,487,492,497,502,507,512,516,520,525,530,534,539,544,548,553,558,563,569,575,580,585,591,597,603,609,615,621,627,633,639,645,650,656,661,667],{"__ignoreMap":180},[184,488,489],{"class":186,"line":187},[184,490,491],{},"class App extends React.Component {\n",[184,493,494],{"class":186,"line":211},[184,495,496],{},"  constructor(props) {\n",[184,498,499],{"class":186,"line":218},[184,500,501],{},"    super(props);\n",[184,503,504],{"class":186,"line":236},[184,505,506],{},"    this.state = {\n",[184,508,509],{"class":186,"line":245},[184,510,511],{},"      count: 0,\n",[184,513,514],{"class":186,"line":254},[184,515,269],{},[184,517,518],{"class":186,"line":266},[184,519,215],{"emptyLinePlaceholder":214},[184,521,522],{"class":186,"line":272},[184,523,524],{},"    this.handleClick = this.handleClick.bind(this);\n",[184,526,527],{"class":186,"line":278},[184,528,529],{},"  }\n",[184,531,532],{"class":186,"line":284},[184,533,215],{"emptyLinePlaceholder":214},[184,535,536],{"class":186,"line":292},[184,537,538],{},"  sayHi() {\n",[184,540,541],{"class":186,"line":311},[184,542,543],{},"    window.alert('Hello Ray.');\n",[184,545,546],{"class":186,"line":317},[184,547,529],{},[184,549,550],{"class":186,"line":322},[184,551,552],{},"  \n",[184,554,555],{"class":186,"line":328},[184,556,557],{},"  han