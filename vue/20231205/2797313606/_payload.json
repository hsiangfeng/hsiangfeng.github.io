[{"data":1,"prerenderedAt":485},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20231205\u002F2797313606\u002F":3,"page:\u002Fvue\u002F20231205\u002F2797313606\u002F":4,"alt:\u002Fvue\u002F20231205\u002F2797313606\u002F":3,"prev-next:\u002Fvue\u002F20231205\u002F2797313606\u002F":461,"related:\u002Fvue\u002F20231205\u002F2797313606\u002F":470},"\u002Fen\u002Fvue\u002F2023\u002F12\u002F05\u002Fvue3-dompurify-xss-prevention\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":446,"date":447,"description":448,"extension":449,"lang":450,"meta":451,"navigation":325,"path":452,"readingMinutes":453,"seo":454,"standalone":455,"stem":456,"tags":457,"tldr":458,"updated":447,"url":459,"__hash__":460},"content\u002FVue\u002FVue3-中使用-DOMParser-避免-XSS-攻擊.md","Vue3 中使用 DOMPurify 避免 XSS 攻擊","2797313606",{"type":9,"value":10,"toc":440},"minimark",[11,19,23,31,35,38,58,86,93,113,122,134,140,144,163,179,236,239,243,253,257,269,273,286,343,349,352,366,372,379,393,402,406,409,430,436],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"XSS","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002FDOMPurify\u002Fisray_notarray_Web_XSS_--stylize_750_--v_5.2_9a3e0823-169f-42dc-acf0-aa97f5e448c6.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25,26,30],{},"在 Vue 中，我們可以使用 ",[27,28,29],"code",{},"v-html"," 來將 HTML 字串轉換成 DOM 元素，但是這樣會有一個問題，就是容易受到 XSS 攻擊，因為我們無法確保使用者輸入的內容是否安全，所以我們需要對使用者輸入的內容進行過濾，避免惡意的腳本被執行。",[20,32,34],{"id":33},"dompurify","DOMPurify",[12,36,37],{},"在 Vue 中，總共有三種渲染資料的方式，分別是：",[39,40,41,49,54],"ul",{},[42,43,44,45,48],"li",{},"mustache interpolations，也就是 ",[27,46,47],{},"{{ myName }}"," 的方式",[42,50,51],{},[27,52,53],{},"v-text",[42,55,56],{},[27,57,29],{},[12,59,60,61,63,64,66,67,69,70,72,73,76,77,79,80,82,83,85],{},"其中，",[27,62,47],{}," 和 ",[27,65,53],{}," 都是將資料轉換成純文字，而 ",[27,68,29],{}," 則是將資料轉換成 HTML 元素，而這個 ",[27,71,29],{}," 類似於 ",[27,74,75],{},"innerHTML","，但本質上不是 ",[27,78,75],{},"，因為 ",[27,81,29],{}," 是具備雙向綁定能力的，而 ",[27,84,75],{}," 則不具備雙向綁定能力。",[87,88],"code-pen",{"default-tab":89,"height":90,"slug":91,"title":29,"user":92},"result",300,"MWLZpyW","hsiangfeng",[12,94,95,96,98,99,106,107,109,110,112],{},"我們都知道使用 ",[27,97,75],{}," 直接將 HTML 渲染出來是一件很危險的事情，是有可能發生 ",[100,101,105],"a",{"href":102,"rel":103},"https:\u002F\u002Fisraynotarray.com\u002Fjavascript\u002F20190717\u002F3117322084\u002F",[104],"nofollow","XSS 攻擊","的，雖然使用 mustache interpolations or ",[27,108,53],{}," 指令是可以避免這個問題存在，因為框架本身就會幫我們過濾掉 HTML 標籤，但是有時候我們還是需要使用 ",[27,111,29],{}," 來渲染 HTML。",[12,114,115,116,118,119,121],{},"那...什麼狀況下會需要使用 ",[27,117,29],{}," 呢？比較常見就是讓使用者可以輸入 HTML 內容的場景，最常見的功能就是 Editor，像是部落格、留言板等等，這時候我們就需要使用 ",[27,120,29],{}," 來渲染使用者輸入的 HTML 內容。",[12,123,124,125,127,128,130,131,133],{},"這時候我們就可以使用 ",[27,126,34],{}," 來避免 XSS 攻擊，",[27,129,34],{}," 是可以將危險的標籤給過濾掉的套件，所以我們可以使用 ",[27,132,34],{}," 來過濾掉危險的標籤，避免惡意的腳本被執行。",[12,135,136,137,139],{},"首先我先寫一個範例，假裝當使用者輸入了一個惡意的腳本，然後我們使用 ",[27,138,29],{}," 來渲染這個腳本，看看會發生什麼事情",[87,141],{"default-tab":89,"height":90,"slug":142,"title":143,"user":92},"xxMMKEY","v-html ajax",[12,145,146,147,150,151,154,155,158,159,162],{},"上方的範例是一個 Vue3 Composition API，當你點下 ",[27,148,149],{},"Get Data"," 的按鈕後，接著過五秒後會將資料渲染到畫面上，這時候你會發現畫面上出現了一個 ",[27,152,153],{},"Image"," 的標籤，但是這個標籤卻是一個惡意的腳本，因為這個標籤的圖片並不會出現，因此就會觸發了 ",[27,156,157],{},"onerror"," 事件，接著就會執行 ",[27,160,161],{},"alert","，這就是一個 XSS 攻擊。",[12,164,165,166,168,169,172,173,176,177,48],{},"那我們要怎麼避免這個問題呢？前面有提到我們將會使用 ",[27,167,34],{}," 來過濾掉危險的標籤，所以安裝方式有兩種，一種是使用 ",[27,170,171],{},"npm"," 安裝，另一種是使用 ",[27,174,175],{},"CDN","，這邊為了方便使用以及介紹，所以我會使用 ",[27,178,175],{},[180,181,186],"pre",{"className":182,"code":183,"language":184,"meta":185,"style":185},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript src='https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002Fdompurify\u002F3.0.6\u002Fpurify.min.js' integrity='sha512-H+rglffZ6f5gF7UJgvH4Naa+fGCgjrHKMgoFOGmcPTRwR6oILo5R+gtzNrpDp7iMV3udbymBVjkeZGNz1Em4rQ==' crossorigin='anonymous'>\u003C\u002Fscript>\n","html","",[27,187,188],{"__ignoreMap":185},[189,190,193,197,201,205,208,212,215,217,220,223,225,228,231,233],"span",{"class":191,"line":192},"line",1,[189,194,196],{"class":195},"sMAXC","\u003C",[189,198,200],{"class":199},"sKpQp","script",[189,202,204],{"class":203},"sCcAr"," src",[189,206,207],{"class":195},"=",[189,209,211],{"class":210},"sTRMh","'https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002Fdompurify\u002F3.0.6\u002Fpurify.min.js'",[189,213,214],{"class":203}," integrity",[189,216,207],{"class":195},[189,218,219],{"class":210},"'sha512-H+rglffZ6f5gF7UJgvH4Naa+fGCgjrHKMgoFOGmcPTRwR6oILo5R+gtzNrpDp7iMV3udbymBVjkeZGNz1Em4rQ=='",[189,221,222],{"class":203}," crossorigin",[189,224,207],{"class":195},[189,226,227],{"class":210},"'anonymous'",[189,229,230],{"class":195},">\u003C\u002F",[189,232,200],{"class":199},[189,234,235],{"class":195},">\n",[12,237,238],{},"底下我也提供一個範例 CodePen，方便你可以 Fork 回家使用：",[87,240],{"default-tab":89,"height":90,"slug":241,"title":242,"user":92},"rNPPBKp","v-html ajax XSS",[12,244,245,246,249,250,252],{},"那麼該如何使用 DOMPurify 呢？其實非常簡單，你只需要使用 ",[27,247,248],{},"sanitize"," 這個方法，然後將你要過濾的 HTML 字串傳入，就可以得到一個過濾過的 HTML 字串，接著你就可以使用 ",[27,251,29],{}," 來渲染這個字串，這樣就可以避免 XSS 攻擊了",[87,254],{"default-tab":89,"height":90,"slug":255,"title":256,"user":92},"WNPPeKG","v-html DOMPurify",[12,258,259,260,262,263,265,266,268],{},"上方範例你可以發現當你點下 ",[27,261,149],{}," 按鈕後，雖然還是會出現死圖，但是卻不會觸發 ",[27,264,157],{}," 事件，因此就不會有 XSS 攻擊的問題了，而這就是 ",[27,267,34],{}," 的功用。",[20,270,272],{"id":271},"關於-dompurify-其他的用法","關於 DOMPurify 其他的用法",[12,274,275,276,278,279,282,283,285],{},"這時候你就好奇了，那我要怎麼知道 ",[27,277,34],{}," 過濾掉了哪些標籤呢？其實你可以使用 ",[27,280,281],{},"DOMPurify.removed"," 來得知，這個屬性會回傳一個陣列，裡面包含了被過濾掉的標籤，這樣你就可以知道 ",[27,284,34],{}," 到底過濾掉了哪些標籤了。",[180,287,291],{"className":288,"code":289,"language":290,"meta":185,"style":185},"language-js shiki shiki-themes github-dark-high-contrast","const clean = DOMPurify.sanitize('\u003Cimg src=\"x\" onerror=\"alert(1)\">');\n\nconsole.log(DOMPurify.removed); \u002F\u002F [{...}]\n","js",[27,292,293,320,327],{"__ignoreMap":185},[189,294,295,299,302,305,308,311,314,317],{"class":191,"line":192},[189,296,298],{"class":297},"sWyjQ","const",[189,300,301],{"class":203}," clean",[189,303,304],{"class":297}," =",[189,306,307],{"class":195}," DOMPurify.",[189,309,248],{"class":310},"sj_SG",[189,312,313],{"class":195},"(",[189,315,316],{"class":210},"'\u003Cimg src=\"x\" onerror=\"alert(1)\">'",[189,318,319],{"class":195},");\n",[189,321,323],{"class":191,"line":322},2,[189,324,326],{"emptyLinePlaceholder":325},true,"\n",[189,328,330,333,336,339],{"class":191,"line":329},3,[189,331,332],{"class":195},"console.",[189,334,335],{"class":310},"log",[189,337,338],{"class":195},"(DOMPurify.removed); ",[189,340,342],{"class":341},"sQrFR","\u002F\u002F [{...}]\n",[12,344,345],{},[15,346],{"alt":347,"src":348},"過濾的標籤","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002FDOMPurify\u002F%E6%88%AA%E5%9C%96%202023-12-06%2022.23.04.png",[12,350,351],{},"我們可以看到陣列中包含了一個物件，然後物件中有兩個屬性，分別是",[39,353,354,360],{},[42,355,356,359],{},[27,357,358],{},"attribute","：被過濾掉的屬性",[42,361,362,365],{},[27,363,364],{},"from","：被過濾後的 HTML 標籤",[12,367,368,369,371],{},"但要稍微注意一下 ",[27,370,281],{}," 這屬性只是讓你看一下而已，如官方文件所說，請不要使用這個屬性作為你的程式邏輯。",[12,373,374,375,378],{},"通常我們實戰開發上一定不會通通過濾掉，可能會有一些標籤是可以被接受的，這時候我們就可以使用 ",[27,376,377],{},"DOMPurify.sanitize"," 來自訂過濾的規則，這個方法可以接受兩個參數，分別是：",[39,380,381,387],{},[42,382,383,386],{},[27,384,385],{},"dirty","：要過濾的 HTML 字串",[42,388,389,392],{},[27,390,391],{},"config","：過濾的規則",[12,394,395,396,401],{},"那麼這部分就滿多的，我就不多做介紹建議直接觀看 ",[100,397,400],{"href":398,"rel":399},"https:\u002F\u002Fgithub.com\u002Fcure53\u002FDOMPurify#control-our-allow-lists-and-block-lists",[104],"官方文件"," 為主哩~",[20,403,405],{"id":404},"什麼時候該使用-dompurify","什麼時候該使用 DOMPurify？",[12,407,408],{},"其實使用的場景比較常見於，資料是由使用者輸入的，像是 Editor、留言板等等，如同前面所講的，現今的框架都具備基本的 XSS 防禦機制，並且我們將資料儲存到資料庫時，後端也會對資料進行過濾。",[12,410,411,412,414,415,417,418,420,421,423,424,426,427,429],{},"那竟然後端以及前端框架都有防禦機制，那我們還需要使用 ",[27,413,34],{}," 嗎？其實這取決於使用場景，以 Vue 來講，如果你渲染資料的方式是使用 ",[27,416,47],{}," 或是 ",[27,419,53],{},"，那其實就不需要使用 ",[27,422,34],{}," 了，因為 Vue 會幫你過濾掉 HTML 標籤，但是如果你使用 ",[27,425,29],{}," 來渲染資料，那就需要使用 ",[27,428,34],{}," 來過濾掉危險的標籤。",[12,431,432,433,435],{},"所以簡單來講，如果你的功能如果是需要直接渲染 HTML 字串，那就會建議你在前端使用 ",[27,434,34],{}," 來過濾掉危險的標籤，這樣子就可以避免惡意的腳本被執行哩",[437,438,439],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":185,"searchDepth":322,"depth":322,"links":441},[442,443,444,445],{"id":22,"depth":322,"text":22},{"id":33,"depth":322,"text":34},{"id":271,"depth":322,"text":272},{"id":404,"depth":322,"text":405},"Vue","2023-12-05 15:42:43","在 Vue 中，我們可以使用 v-html 來將 HTML 字串轉換成 DOM 元素，但是這樣會有一個問題，就是容易受到 XSS 攻擊，因為我們無法確保使用者輸入的內容是否安全，所以我們需要對使用者輸入的內容進行過濾，避免惡意的腳本被執行。","md","zh-Hant",{},"\u002Fvue\u002Fvue3-domparser-xss","3",{"title":6,"description":448},false,"Vue\u002FVue3-中使用-DOMParser-避免-XSS-攻擊",[446,17,34],null,"\u002Fvue\u002F20231205\u002F2797313606\u002F","8UhvZrz05R-fYt7qzNdRD5lfEBDjqaSHBKRwCdcxSao",{