[{"data":1,"prerenderedAt":1576},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20230330\u002F238425903\u002F":3,"page:\u002Fvue\u002F20230330\u002F238425903\u002F":4,"alt:\u002Fvue\u002F20230330\u002F238425903\u002F":3,"prev-next:\u002Fvue\u002F20230330\u002F238425903\u002F":1553,"related:\u002Fvue\u002F20230330\u002F238425903\u002F":1562},"\u002Fen\u002Fvue\u002F2023\u002F03\u002F30\u002Fimporting-images-in-vue\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1536,"date":1537,"description":18,"extension":1538,"lang":1539,"meta":1540,"navigation":454,"path":1541,"readingMinutes":1542,"seo":1543,"standalone":1544,"stem":1545,"tags":1546,"tldr":1550,"updated":1537,"url":1551,"__hash__":1552},"content\u002FVue\u002FVue-的圖片引入方式.md","Vue 的圖片引入方式","238425903",{"type":9,"value":10,"toc":1518},"minimark",[11,15,19,22,25,28,31,41,49,94,97,100,122,125,151,154,180,183,186,193,217,222,225,267,270,300,311,314,318,321,339,344,354,602,620,651,654,658,661,687,690,694,697,723,726,784,790,793,819,822,846,850,861,878,885,911,917,943,952,964,968,971,985,989,996,1109,1113,1116,1192,1196,1199,1213,1217,1293,1298,1374,1378,1388,1392,1398,1457,1460,1514],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這邊稍微記錄一下該如何正確地在 Vue Cli 或 Vite 中引入圖片，因為這個問題其實很常見也很容易搞錯，所以就乾脆寫一篇記錄一下。",[12,20,21],{"id":21},"什麼是靜態資源與非靜態資源",[16,23,24],{},"往下介紹之前，我想先解釋一下何謂靜態資源與非靜態資源的意思",[16,26,27],{},"那麼由於後面我們會講到 Vue Cli，所以這邊就先以 Vue Cli 作為舉例說明這兩者差異。",[16,29,30],{},"Vue Cli 本身是基於 Webpack 所製作的，因此引入圖片必須區分為兩種",[32,33,34,38],"ul",{},[35,36,37],"li",{},"靜態資源",[35,39,40],{},"非靜態資源",[16,42,43,44,48],{},"什麼是靜態資源呢？你還記得 Vue Cli 專案底下有一個 public 資料夾嗎？那個資料夾就是專門放靜態資源的，而所謂的靜態資源就是",[45,46,47],"strong",{},"不會被 Webpack 打包\u002F編譯的資源","，因此你可以直接在 HTML 中引入，例如：",[50,51,56],"pre",{"className":52,"code":53,"language":54,"meta":55,"style":55},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cimg src=\"\u002Fimg\u002Flogo.png\" alt=\"logo\" \u002F>\n","html","",[57,58,59],"code",{"__ignoreMap":55},[60,61,64,68,72,76,79,83,86,88,91],"span",{"class":62,"line":63},"line",1,[60,65,67],{"class":66},"sMAXC","\u003C",[60,69,71],{"class":70},"sKpQp","img",[60,73,75],{"class":74},"sCcAr"," src",[60,77,78],{"class":66},"=",[60,80,82],{"class":81},"sTRMh","\"\u002Fimg\u002Flogo.png\"",[60,84,85],{"class":74}," alt",[60,87,78],{"class":66},[60,89,90],{"class":81},"\"logo\"",[60,92,93],{"class":66}," \u002F>\n",[16,95,96],{},"而你的 logo.png 圖片位置就是在 public\u002Fimg\u002Flogo.png。",[16,98,99],{},"那麼非靜態資源就是會透過 Webpack 打包\u002F編譯的資源，因此你必須透過 import 的方式引入，例如：",[50,101,105],{"className":102,"code":103,"language":104,"meta":55,"style":55},"language-js shiki shiki-themes github-dark-high-contrast","import logo from '.\u002Fimg\u002Flogo.png'\n","js",[57,106,107],{"__ignoreMap":55},[60,108,109,113,116,119],{"class":62,"line":63},[60,110,112],{"class":111},"sWyjQ","import",[60,114,115],{"class":66}," logo ",[60,117,118],{"class":111},"from",[60,120,121],{"class":81}," '.\u002Fimg\u002Flogo.png'\n",[16,123,124],{},"接著你就要這樣在 HTML 中引入：",[50,126,128],{"className":52,"code":127,"language":54,"meta":55,"style":55},"\u003Cimg :src=\"logo\" alt=\"logo\" \u002F>\n",[57,129,130],{"__ignoreMap":55},[60,131,132,134,136,139,141,143,145,147,149],{"class":62,"line":63},[60,133,67],{"class":66},[60,135,71],{"class":70},[60,137,138],{"class":74}," :src",[60,140,78],{"class":66},[60,142,90],{"class":81},[60,144,85],{"class":74},[60,146,78],{"class":66},[60,148,90],{"class":81},[60,150,93],{"class":66},[16,152,153],{},"編譯出來會跟靜態資源不一樣",[50,155,157],{"className":52,"code":156,"language":54,"meta":55,"style":55},"\u003Cimg src=\"\u002Fimg\u002Flogo.1a2b3c.png\" alt=\"logo\" \u002F>\n",[57,158,159],{"__ignoreMap":55},[60,160,161,163,165,167,169,172,174,176,178],{"class":62,"line":63},[60,162,67],{"class":66},[60,164,71],{"class":70},[60,166,75],{"class":74},[60,168,78],{"class":66},[60,170,171],{"class":81},"\"\u002Fimg\u002Flogo.1a2b3c.png\"",[60,173,85],{"class":74},[60,175,78],{"class":66},[60,177,90],{"class":81},[60,179,93],{"class":66},[16,181,182],{},"你會看到類似這樣的路徑，這就是 Webpack 打包\u002F編譯後的路徑。",[12,184,185],{"id":185},"引入圖片的方式",[16,187,188,189,192],{},"前面有提到靜態資源的引入方式，其實相對就很簡單，只要放在 ",[57,190,191],{},"public"," 資料夾就可以直接引入",[50,194,195],{"className":52,"code":53,"language":54,"meta":55,"style":55},[57,196,197],{"__ignoreMap":55},[60,198,199,201,203,205,207,209,211,213,215],{"class":62,"line":63},[60,200,67],{"class":66},[60,202,71],{"class":70},[60,204,75],{"class":74},[60,206,78],{"class":66},[60,208,82],{"class":81},[60,210,85],{"class":74},[60,212,78],{"class":66},[60,214,90],{"class":81},[60,216,93],{"class":66},[16,218,219,220,192],{},"而 SCSS、CSS 也是一樣的道理，只要放在 ",[57,221,191],{},[16,223,224],{},"SCSS：",[50,226,230],{"className":227,"code":228,"language":229,"meta":55,"style":55},"language-scss shiki shiki-themes github-dark-high-contrast",".logo {\n  background-image: url('\u002Fimg\u002Flogo.png');\n}\n","scss",[57,231,232,240,261],{"__ignoreMap":55},[60,233,234,237],{"class":62,"line":63},[60,235,236],{"class":74},".logo",[60,238,239],{"class":66}," {\n",[60,241,243,246,249,252,255,258],{"class":62,"line":242},2,[60,244,245],{"class":74},"  background-image",[60,247,248],{"class":66},": ",[60,250,251],{"class":74},"url",[60,253,254],{"class":66},"(",[60,256,257],{"class":81},"'\u002Fimg\u002Flogo.png'",[60,259,260],{"class":66},");\n",[60,262,264],{"class":62,"line":263},3,[60,265,266],{"class":66},"}\n",[16,268,269],{},"CSS：",[50,271,274],{"className":272,"code":228,"language":273,"meta":55,"style":55},"language-css shiki shiki-themes github-dark-high-contrast","css",[57,275,276,282,296],{"__ignoreMap":55},[60,277,278,280],{"class":62,"line":63},[60,279,236],{"class":74},[60,281,239],{"class":66},[60,283,284,286,288,290,292,294],{"class":62,"line":242},[60,285,245],{"class":74},[60,287,248],{"class":66},[60,289,251],{"class":74},[60,291,254],{"class":66},[60,293,257],{"class":81},[60,295,260],{"class":66},[60,297,298],{"class":62,"line":263},[60,299,266],{"class":66},[1