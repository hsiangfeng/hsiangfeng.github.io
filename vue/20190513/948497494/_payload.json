],{},"然後輸入以下指令",[84,192,194],{"className":86,"code":193,"language":74,"meta":88,"style":88},"git remote add origin https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FGittest.git\n",[23,195,196],{"__ignoreMap":88},[92,197,198],{"class":94,"line":95},[92,199,193],{},[201,202,203,210,216],"ul",{},[204,205,206,209],"li",{},[23,207,208],{},"git remote"," - 遠端",[204,211,212,215],{},[23,213,214],{},"add"," - 意思是加入",[204,217,218,221],{},[23,219,220],{},"origin"," - 基本上就只是一個名詞而已(?) 也可以改別的名稱，但是預設就好了。",[16,223,224],{},"輸入遠端節點之後基本上畫面不會有什麼動作這是正常狀況。",[16,226,227],{},[50,228],{"alt":229,"src":230},"新增遠端分支","https:\u002F\u002Fi.imgur.com\u002F05kY6E6.png",[16,232,233],{},"最後就是要 push 出去啦，只要輸入以下資料就可以了",[84,235,237],{"className":86,"code":236,"language":74,"meta":88,"style":88},"git push -u origin master\n",[23,238,239],{"__ignoreMap":88},[92,240,241],{"class":94,"line":95},[92,242,236],{},[16,244,245],{},[50,246],{"alt":177,"src":247},"https:\u002F\u002Fi.imgur.com\u002F7ah9RUL.png",[16,249,250,251,254,255,257,258,260,261,264],{},"(圖中指令我少打了 ",[23,252,253],{},"-u","，最好在第一次 ",[23,256,177],{}," 的時候要打 ",[23,259,253],{},"，避免一些麻煩事情，如果你是使用 ",[23,262,263],{},"Clone"," 的話就可以忽略。)",[16,266,267,269],{},[23,268,177],{}," 出去之後我們也能夠在 GitHub 上看到檔案哩~",[16,271,272],{},[50,273],{"alt":274,"src":275},"GitHub","https:\u002F\u002Fi.imgur.com\u002F6OsVPvn.png",[12,277,279],{"id":278},"vuejs-push-到-pages","Vue.js Push 到 Pages",[16,281,282,283,286,287],{},"※接下來的步驟建議已經針對前面的檔案做過 ",[23,284,285],{},"git init"," 比較好唷 ",[288,289],"d",{},[16,291,292],{},"※ Vue Cli2 & 3 皆可使用。",[16,294,295,296,298],{},"首先要先做網站編譯，編譯出伺服器可以用的檔案，所以輸入以下指令(注意要記得先 ",[23,297,81],{}," 到專案資料夾下)。",[84,300,302],{"className":86,"code":301,"language":74,"meta":88,"style":88},"npm run build\n",[23,303,304],{"__ignoreMap":88},[92,305,306],{"class":94,"line":95},[92,307,301],{},[16,309,310],{},"編譯完會像這樣子",[16,312,313],{},[50,314],{"alt":315,"src":316},"編譯完","https:\u002F\u002Fi.imgur.com\u002FbCijwxL.png",[16,318,319],{},"編譯出來的檔案通常都在 dits 底下，所以我們要移動至 dist 資料夾",[84,321,323],{"className":86,"code":322,"language":74,"meta":88,"style":88},"cd dist\n",[23,324,325],{"__ignoreMap":88},[92,326,327],{"class":94,"line":95},[92,328,322],{},[16,330,331],{},"接下來一樣要做 GitHub 初始化",[84,333,334],{"className":86,"code":113,"language":74,"meta":88,"style":88},[23,335,336],{"__ignoreMap":88},[92,337,338],{"class":94,"line":95},[92,339,113],{},[16,341,342,343],{},"然後將 dist 裡面的所有檔案加入版本控制，並輸入 ",[23,344,345],{},"commit message",[84,347,349],{"className":86,"code":348,"language":74,"meta":88,"style":88},"git add .\ngit commit -m 'first'\n",[23,350,351,355],{"__ignoreMap":88},[92,352,353],{"class":94,"line":95},[92,354,137],{},[92,356,358],{"class":94,"line":357},2,[92,359,360],{},"git commit -m 'first'\n",[16,362,363],{},"接下來一樣需要設置遠端分支",[84,365,367],{"className":86,"code":366,"language":74,"meta":88,"style":88},"git push -f '遠端 repos' master:gh-pages\n",[23,368,369],{"__ignoreMap":88},[92,370,371],{"class":94,"line":95},[92,372,366],{},[16,374,375],{},"這一篇範例來講就是這樣",[84,377,379],{"className":86,"code":378,"language":74,"meta":88,"style":88},"git push -f https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FGittest.git master:gh-pages\n",[23,380,381],{"__ignoreMap":88},[92,382,383],{"class":94,"line":95},[92,384,378],{},[16,386,387],{},"另外也可以發現 GitHub 已經幫我們把 gh-pages 開好了 (setting，滑到下方有一個 GitHub Pages)",[16,389,390],{},[50,391],{"alt":392,"src":393},"gh-pages","https:\u002F\u002Fi.imgur.com\u002FIWHg6ql.png",[16,395,396],{},"補充:\nGitHub Pages 網址綠色區塊若是呈現藍色，代表準備中，綠色代表可以正常運行網站。",[12,398,399],{"id":399},"補充幾個已知的雷點",[16,401,402,403,406,407,410,411,414,415,418],{},"Vue Cli2:\n1.檔案路徑\n由於預設 Vue 檔案讀取路徑是 ",[23,404,405],{},"assetsPublicPath: '\u002F'","，建議修改成 ",[23,408,409],{},"assetsPublicPath: '.\u002F'","，修改位子在 ",[23,412,413],{},"config\u002Findex.js"," 中。\n2.config\u002Fprod.env.js\n如果你有寫一些自定義變數放在 dev.env.js 中，一定要記得東西放進來這支JS，否則會出現錯誤。\n3. build\u002Futils.js\n如果CSS中有撰寫這種>",[23,416,417],{},"backgroud-image: url(..\u002F..\u002Fassets\u002Fimg\u002Fxxx.jp