" 函式每一行程式碼進行解釋：",[36,1949,1951],{"className":844,"code":1950,"language":846,"meta":41,"style":41},"\u002F\u002F 引入淺層的 shallowRef 跟 強制觸發更新的 triggerRef API\nimport { shallowRef, triggerRef } from 'vue'\n\n\u002F\u002F 建立一個函式叫做 createSignal，並傳入兩個參數，分別是 value 跟 options\n\u002F\u002F options 是一個物件，裡面有一個 equals 的屬性\nfunction createSignal(value, options) {\n  \u002F\u002F 將 value 透過 shallowRef 進行監聽\n  const r = shallowRef(value) \n  \u002F\u002F 取得 r 的值並回傳，這邊會是只有你在呼叫 get 時才會取得 r 的值，而非一開始就取得值\n  const get = () => r.value\n  \u002F\u002F 設定 r 的值，並接收一個參數 v\n  const set = (v) => {\n    \u002F\u002F 如果 v 是一個函式的話，就將 r 的值傳入函式中，否則就直接將 v 設定給 r\n    r.value = typeof v === 'function' ? v(r.value) : v\n    \u002F\u002F 如果 options?.equals 是 false 的話，就強制觸發 r 的更新\n    if (options?.equals === false) triggerRef(r)\n  }\n\n  \u002F\u002F 回傳一個陣列，裡面有兩個函式，分別是 get 跟 set\n  return [get, set]\n}\n",[27,1952,1953,1958,1968,1972,1977,1982,1998,2003,2016,2021,2035,2040,2058,2063,2087,2092,2108,2112,2116,2121,2127],{"__ignoreMap":41},[45,1954,1955],{"class":47,"line":48},[45,1956,1957],{"class":1736},"\u002F\u002F 引入淺層的 shallowRef 跟 強制觸發更新的 triggerRef API\n",[45,1959,1960,1962,1964,1966],{"class":47,"line":62},[45,1961,158],{"class":157},[45,1963,562],{"class":51},[45,1965,164],{"class":157},[45,1967,167],{"class":103},[45,1969,1970],{"class":47,"line":73},[45,1971,138],{"emptyLinePlaceholder":137},[45,1973,1974],{"class":47,"line":88},[45,1975,1976],{"class":1736},"\u002F\u002F 建立一個函式叫做 createSignal，並傳入兩個參數，分別是 value 跟 options\n",[45,1978,1979],{"class":47,"line":114},[45,1980,1981],{"class":1736},"\u002F\u002F options 是一個物件，裡面有一個 equals 的屬性\n",[45,1983,1984,1986,1988,1990,1992,1994,1996],{"class":47,"line":124},[45,1985,208],{"class":157},[45,1987,577],{"class":187},[45,1989,191],{"class":51},[45,1991,583],{"class":582},[45,1993,586],{"class":51},[45,1995,589],{"class":582},[45,1997,592],{"class":51},[45,1999,2000],{"class":47,"line":134},[45,2001,2002],{"class":1736},"  \u002F\u002F 將 value 透過 sha