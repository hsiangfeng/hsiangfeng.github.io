015012\u002F",[432],"nofollow","遲早你會面對的問題，Vue3 Composition API 的 ref 與 reactive 差異是什麼？",[16,435,436],{},"那麼為什麼突然提到變數宣告呢？因為某一天朋友在抱怨...",[16,438,439,440,443,444,447],{},"「前陣子我們在維護專案的時候，不小心有一個同事在 ",[27,441,442],{},".value"," 補了 ",[27,445,446],{},"= null","，後來查才知道是同事的 VSCode 自動補全功能幫他補的，結果因為這行為導致了一個功能異常，真的是太可怕了！」",[16,449,450],{},"可能會有人認為這件事情可以透過 Code Review 來避免，但是這樣的事情真的是有可能發生，所以我就想到了 Vue 官方文件中有一個有趣的區塊，也就是「深入響應式系統」頁面底下有一個「與信號（Signal）的關係」...",[12,452,454],{"id":453},"信號signal","信號（Signal）",[16,456,457],{},"其實前陣子 React 圈有在討論這個議題，但這邊我們並沒有打算深入探討 React 或是 Signal 這個議題，所以讓我們拉回到 Vue 的世界。",[16,459,460],{},"首先先讓我們來看一下範例：",[462,463],"code-pen",{"default-tab":464,"height":465,"slug":466,"title":467,"user":468},"result",300,"RwORBXG","Vue Signal","hsiangfeng",[36,470,472],{"className":38,"code":471,"language":40,"meta":41,"style":41},"\u003Ctemplate>\n  \u003Cdiv>\n    \u003Cp>{{ name() }}\u003C\u002Fp>\n    \u003Cbutton @click=\"changeName\">點我改名字\u003C\u002Fbutton>\n  \u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\n\u003Cscript setup>\nimport { shallowRef, triggerRef } from 'vue'\n\nfunction createSignal(value, options) {\n  const r = shallowRef(value)\n  const get = () => r.value\n  const set = (v) => {\n    r.value = typeof v === 'function' ? v(r.value) : v\n    if (options?.equals === false) triggerRef(r)\n  }\n  return [get, set]\n}\n  \n  \nconst [ name, setName ] = createSignal('你是誰？')\n\nconst changeName = () => {\n  setName('我是 Ray')\n}\n\u003C\u002Fscript>\n",[27,473,474,482,490,503,521,529,537,541,545,555,566,570,592,608,626,649,683,704,709,718,723,729,734,764,769,784,797,802],{"__ignoreMap":41},[45,475,476,478,480],{"class":47,"line":48},[45,477,52],{"class":51},[45,479,56],{"class":55},[45,481,59],{"class":51},[45,483,484,486,488],{"class":47,"line":62},[45,485,65],{"class":51},[45,487,68],{"class":55},[45,489,59],{"class":51},[45,491,492,494,496,499,501],{"class":47,"line":73},[45,493,76],{"class":51},[45,495,16],{"class":55},[45,497,498],{"class":51},">{{ name() }}\u003