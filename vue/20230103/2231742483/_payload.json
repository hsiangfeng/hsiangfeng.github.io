[{"data":1,"prerenderedAt":1938},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20230103\u002F2231742483\u002F":3,"page:\u002Fvue\u002F20230103\u002F2231742483\u002F":4,"alt:\u002Fvue\u002F20230103\u002F2231742483\u002F":3,"prev-next:\u002Fvue\u002F20230103\u002F2231742483\u002F":1914,"related:\u002Fvue\u002F20230103\u002F2231742483\u002F":1923},"\u002Fen\u002Fvue\u002F2023\u002F01\u002F03\u002Fvue3-veevalidate-getinspectortree-error-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1897,"date":1898,"description":1899,"extension":1900,"lang":1901,"meta":1902,"navigation":127,"path":1903,"readingMinutes":1904,"seo":1905,"standalone":1906,"stem":1907,"tags":1908,"tldr":1911,"updated":1898,"url":1912,"__hash__":1913},"content\u002FVue\u002F解決-Vue3-中使用-VeeValidate-時發生的-getInspectorTree-錯誤.md","解決 Vue3 中使用 VeeValidate 時發生的 'getInspectorTree' 錯誤","2231742483",{"type":9,"value":10,"toc":1888},"minimark",[11,15,28,32,35,42,45,188,191,195,198,527,533,543,562,827,830,833,839,845,1123,1130,1136,1139,1145,1149,1152,1494,1509,1515,1518,1541,1872,1875,1881,1884],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,23,24,27],"p",{},"這一篇會記錄一下使用 VeeValidate 時遇到的「",[20,21,22],"code",{},"An error occurred in hook 'getInspectorTree' with payload","」該如何解決，順便記錄一下 VeeValidate 另一個奇妙的錯誤，也就是同名的 ",[20,25,26],{},"name"," 屬性問題。",[12,29,31],{"id":30},"backendjs-an-error-occurred-in-hook-getinspectortree-with-payload","backend.js: An error occurred in hook 'getInspectorTree' with payload",[16,33,34],{},"首先這個錯誤比較有點讓人茫然，而且普通狀況下你可能不會發生，因為這個錯誤是只有在你啟用 Vue Devtools 的 VeeValidate 之後才會發生的，如果你沒發生的話，那就是你沒有啟用 Vue Devtools 或者你沒有點一下 VeeValidate 的標籤，如下：",[16,36,37],{},[38,39],"img",{"alt":40,"src":41},"VeeValidate","https:\u002F\u002Fi.imgur.com\u002FlPbgr5e.png",[16,43,44],{},"當你點了之後再回到 Console 就會發現一推錯誤",[46,47,52],"pre",{"className":48,"code":49,"language":50,"meta":51,"style":51},"language-bash shiki shiki-themes github-dark-high-contrast","An error occurred in hook 'getInspectorTree' with payload: {inspectorId: 'vee-validate-inspector', app: {…}, filter: '', rootNodes: Array(0)}\n\nDOMException: Failed to execute 'btoa' on 'Window': The string to be encoded contains characters outside of the Latin1 range.\n","bash","",[20,53,54,122,129],{"__ignoreMap":51},[55,56,59,63,67,70,73,76,79,82,85,88,91,94,97,100,103,106,109,113,116,119],"span",{"class":57,"line":58},"line",1,[55,60,62],{"class":61},"s_sBn","An",[55,64,66],{"class":65},"sTRMh"," error",[55,68,69],{"class":65}," occurred",[55,71,72],{"class":65}," in",[55,74,75],{"class":65}," hook",[55,77,78],{"class":65}," 'getInspectorTree'",[55,80,81],{"class":65}," with",[55,83,84],{"class":65}," payload:",[55,86,87],{"class":65}," {inspectorId:",[55,89,90],{"class":65}," 'vee-validate-inspector',",[55,92,93],{"class":65}," app:",[55,95,96],{"class":65}," {…},",[55,98,99],{"class":65}," filter:",[55,101,102],{"class":65}," '',",[55,104,105],{"class":65}," rootNodes:",[55,107,108],{"class":65}," Array",[55,110,112],{"class":111},"sMAXC","(",[55,114,115],{"class":61},"0",[55,117,118],{"class":111},")",[55,120,121],{"class":65},"}\n",[55,123,125],{"class":57,"line":124},2,[55,126,128],{"emptyLinePlaceholder":127},true,"\n",[55,130,132,135,138,141,144,147,150,153,156,159,161,164,167,170,173,176,179,182,185],{"class":57,"line":131},3,[55,133,134],{"class":61},"DOMException:",[55,136,137],{"class":65}," Failed",[55,139,140],{"class":65}," to",[55,142,143],{"class":65}," execute",[55,145,146],{"class":65}," 'btoa'",[55,148,149],{"class":65}," on",[55,151,152],{"class":65}," 'Window':",[55,154,155],{"class":65}," The",[55,157,158],{"class":65}," string",[55,160,140],{"class":65},[55,162,163],{"class":65}," be",[55,165,166],{"class":65}," encoded",[55,168,169],{"class":65}," contains",[55,171,172],{"class":65}," characters",[55,174,175],{"class":65}," outside",[55,177,178],{"class":65}," of",[55,180,181],{"class":65}," the",[55,183,184],{"class":65}," Latin1",[55,186,187],{"class":65}," range.\n",[16,189,190],{},"下意識你可能會將錯誤訊息複製下來，然後去 Google 一下，但是你發現你找不到解決的方式因此這一邊我就來記錄一下解決方法。",[192,193,194],"h3",{"id":194},"解決方式",[16,196,197],{},"首先先來看一下我們範例程式碼目前是怎麼樣",[46,199,203],{"className":200,"code":201,"language":202,"meta":51,"style":51},"language-html shiki shiki-themes github-dark-high-contrast","\u003Ctemplate>\n  \u003CVForm v-slot=\"{ errors }\">\n    \u003Cdiv>\n      \u003Clabel for=\"account\">帳號\u003C\u002Flabel>\n      \u003CVField\n        id=\"account\"\n        v-model.trim=\"user.account\"\n        name=\"帳號\"\n        type=\"email\"\n        :class=\"{ 'is-invalid': errors['帳號'] }\"\n        rules=\"required|email\"\n      \u002F>\n      \u003CErrorMessage name=\"帳號\" \u002F>\n    \u003C\u002Fdiv>\n    \u003Cdiv>\n      \u003Clabel for=\"password\">密碼\u003C\u002Flabel>\n      \u003CVField\n        id=\"password\"\n        v-model.trim=\"user.password\"\n        name=\"密碼\"\n        type=\"password\"\n        :class=\"{ 'is-invalid': errors['密碼'] }\"\n        rules=\"required\"\n      \u002F>\n      \u003CErrorMessage name=\"密碼\" \u002F>\n    \u003C\u002Fdiv>\n  \u003C\u002FVForm>\n\u003C\u002Ftemplate>\n","html",[20,204,205,217,238,248,272,280,291,302,313,324,335,346,352,371,381,390,411,418,428,438,448,457,467,477,482,498,507,517],{"__ignoreMap":51},[55,206,207,210,214],{"class":57,"line":58},[55,208,209],{"class":111},"\u003C",[55,211,213],{"class":212},"sKpQp","template",[55,215,216],{"class":111},">\n",[55,218,219,222,226,230,233,236],{"class":57,"line":124},[55,220,221],{"class":111},"  \u003C",[55,223,225],{"class":224},"szH_Z","VForm",[55,227,229],{"class":228},"sCcAr"," v-slot",[55,231,232],{"class":111},"=",[55,234,235],{"class":65},"\"{ errors }\"",[55,237,216],{"class":111},[55,239,240,243,246],{"class":57,"line":131},[55,241,242],{"class":111},"    \u003C",[55,244,245],{"class":212},"div",[55,247,216],{"class":111},[55,249,251,254,257,260,262,265,268,270],{"class":57,"line":250},4,[55,252,253],{"class":111},"      \u003C",[55,255,256],{"class":212},"label",