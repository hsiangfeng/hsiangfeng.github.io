[{"data":1,"prerenderedAt":503},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20190510\u002F1766915506\u002F":3,"page:\u002Fvue\u002F20190510\u002F1766915506\u002F":4,"alt:\u002Fvue\u002F20190510\u002F1766915506\u002F":3,"prev-next:\u002Fvue\u002F20190510\u002F1766915506\u002F":479,"related:\u002Fvue\u002F20190510\u002F1766915506\u002F":488},"\u002Fen\u002Fvue\u002F2019\u002F05\u002F10\u002Fvue-props-and-emit-data-passing\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":463,"date":464,"description":18,"extension":465,"lang":466,"meta":467,"navigation":468,"path":469,"readingMinutes":470,"seo":471,"standalone":472,"stem":473,"tags":474,"tldr":476,"updated":476,"url":477,"__hash__":478},"content\u002FVue\u002Fprops與emit的傳遞方式.md","props與emit的傳遞方式","1766915506",{"type":9,"value":10,"toc":457},"minimark",[11,15,19,22,25,33,40,43,48,51,57,60,65,68,73,76,112,115,150,157,162,165,170,173,176,186,191,194,199,202,205,210,221,321,326,329,354,359,362,367,370,395,398,403,406,426,429,434,437,442,445,448,453],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這幾天自己突然又開始使用 Vue 來製作一個小東西，因為我都是用 components 來製作，所以勢必要了解 props 與 emit 之間是如何傳遞的。",[16,20,21],{},"以下範例環境皆是 Vue Cli 3。",[12,23,24],{"id":24},"props",[16,26,27,28,32],{},"一開始我們建立好 Vue Cli 3專案時可以先開啟 ",[29,30,31],"code",{},"src\u002Fviews\u002FHome.vue","。",[16,34,35],{},[36,37],"img",{"alt":38,"src":39},"圖片","https:\u002F\u002Fi.imgur.com\u002FVFKOnTv.png",[16,41,42],{},"開啟後可以看到約程式碼第四行。",[16,44,45],{},[36,46],{"alt":38,"src":47},"https:\u002F\u002Fi.imgur.com\u002F68blNtc.png",[16,49,50],{},"其實預設初始環境下就已經有一個 props 範例可以參考。",[16,52,53,54,32],{},"從文字上來分析就是 Home.vue 引入了 HelloWorld 的 components，然後再 HelloWorld 標籤上新增了一個叫 msg 的東東，並在後面帶入 ",[29,55,56],{},"Welcome to Your Vue.js App",[16,58,59],{},"那這個動作就是 props 向內傳(向組件 or components)傳遞資料，用圖片大概圖解會像這樣子。",[16,61,62],{},[36,63],{"alt":38,"src":64},"https:\u002F\u002Fi.imgur.com\u002FJQ0Y4xp.png",[16,66,67],{},"接下來傳到 HelloWorld 的 components 就必須有一個方法來接收剛剛傳過來的 msg，而這個方法就是 props，這邊一樣觀看預設給的範例。",[16,69,70],{},[36,71],{"alt":38,"src":72},"https:\u002F\u002Fi.imgur.com\u002FLHfN7d5.png",[16,74,75],{},"在這邊一般常見的 props 如範例一樣。",[77,78,83],"pre",{"className":79,"code":80,"language":81,"meta":82,"style":82},"language-js shiki shiki-themes github-dark-high-contrast","props: {\n    msg: String,\n},\n","js","",[29,84,85,97,106],{"__ignoreMap":82},[86,87,90,93],"span",{"class":88,"line":89},"line",1,[86,91,24],{"class":92},"s_sBn",[86,94,96],{"class":95},"sMAXC",": {\n",[86,98,100,103],{"class":88,"line":99},2,[86,101,102],{"class":92},"    msg",[86,104,105],{"class":95},": String,\n",[86,107,109],{"class":88,"line":108},3,[86,110,111],{"class":95},"},\n",[16,113,114],{},"當然也有另一種寫法",[77,116,118],{"className":79,"code":117,"language":81,"meta":82,"style":82},"props: {\n    msg: {\n      type: String,\n  },\n},\n",[29,119,120,126,132,139,145],{"__ignoreMap":82},[86,121,122,124],{"class":88,"line":89},[86,123,24],{"class":92},[86,125,96],{"class":95},[86,127,128,130],{"class":88,"line":99},[86,129,102],{"class":92},[86,131,96],{"class":95},[86,133,134,137],{"class":88,"line":108},[86,135,136],{"class":92},"      type",[86,138,105],{"class":95},[86,140,142],{"class":88,"line":141},4,[86,143,144],{"class":95},"  },\n",[86,146,148],{"class":88,"line":147},5,[86,149,111],{"class":95},[16,151,152,153,156],{},"那裡面的 type 只是確保傳進來的值是甚麼類型，假設如果我將 HelloWorld 中的 msg 修改成 Number 會發生什麼事情呢?(注意，我這邊並沒有更動 src\u002Fviews\u002FHome.vue 傳入的值，一樣是 ",[29,154,155],{},"msg=Welcome to Your Vue.js App",")",[16,158,159],{},[36,160],{"alt":38,"src":161},"https:\u002F\u002Fi.imgur.com\u002FMVod6cP.png",[16,163,164],{},"你會發現畫面很正常啊，我是不是騙你不寫 type 根本沒差吧?這時候你就錯了，試著打開 F12 > console，你就會發現一條紅紅的錯誤等著你(我所使用的開發環境為 Firefox 66)。",[16,166,167],{},[36,168],{"alt":38,"src":169},"https:\u002F\u002Fi.imgur.com\u002FQKChZti.png",[16,171,172],{},"這一段紅字大意就是\"你傳入的並不是一個數值，而是一個字串，而這錯誤的值是Welcome to Your Vue.js App\"。",[16,174,175],{},"所以我們替 props 設置 type 是有一定的好處，可以避免我們傳入錯誤的資料。",[16,177,178,179,182,183,32],{},"這邊還要注意一件事情，若 components 中，若沒有設置與傳入相同參數名就會出現錯誤，舉例先回到src\u002Fviews\u002FHome.vue中，將 ",[29,180,181],{},"msg=\"Welcome to Your Vue.js App\""," 修改成 ",[29,184,185],{},"hello=\"Welcome to Your Vue.js App\"",[16,187,188],{},[36,189],{"alt":38,"src":190},"https:\u002F\u002Fi.imgur.com\u002FKZU6q1E.png",[16,192,193],{},"此時你會發現畫面上沒有你傳入的 Welcome to Your Vue.js App，更不用說 console 也不會跳出提示訊息唷(這邊已經將型別修正為 String)。",[16,195,196],{},[36,197],{"alt":38,"src":198},"https:\u002F\u002Fi.imgur.com\u002FzFRaU4p.png",[12,200,201],{"id":201},"emit",[16,203,204],{},"接下來 emit 是比較常讓人家搞混的一個觀念，在前面有講到 props 是向內傳(向組件 or components)傳遞資料，那 emit 就 向外傳(向組件外 or components外)傳遞資料，圖解如下。",[16,206,207],{},[36,208],{"alt":38,"src":209},"https:\u002F\u002Fi.imgur.com\u002F0xWgeXS.png",[16,211,212,213,216,217,220],{},"那該如何使用 ",[29,214,215],{},"$emit"," 傳遞資料給 HOME 呢，首先我們先進去 ",[29,218,219],{},"src\u002Fcomponents\u002FHello.vue"," 做一下資料調整。",[77,222,224],{"className":79,"code":223,"language":81,"meta":82,"style":82},"export default {\n  name: 'HelloWorld',\n  props: {\n    msg: String,\n  },\n  data() {\n    return {\n      exampleMsg: 'Hello emit!',\n    }\n  },\n};\n",[29,225,226,238,250,255,260,267,280,288,299,305,312],{"__ignoreMap":82},[86,227,228,232,235],{"class":88,"line":89},[86,229,231],{"class":230},"sWyjQ","export",[86,233,234],{"class":230}," default",[86,236,237],{"class":92}," {\n",[86,239,240,243,247],{"class":88,"line":99},[86,241,242],{"class":95},"  name: ",[86,244,246],{"class":245},"sTRMh","'HelloWorld'",[86,248,249],{"class":92},",\n",[86,251,252],{"class":88,"line":108},[86,253,254],{"class":95},"  props: {\n",[86,256,257],{"class":88,"line":141},[86,258,259],{"class":95},"    msg: String,\n",[86,261,262,265],{"class":88,"line":147},[86,263,264],{"class":95},"  }",[86,266,249],{"class":92},[86,268,270,274,277],{"class":88,"line":269},6,[86,271,273],{"class":272},"sj_SG","  data",[86,275,276],{"class":92},"() ",[86,278,279],{"class":95},"{\n",[86,281,283,286],{"class":88,"line":282},7,[86,284,285],{"class":230},"    return",[86,287,237],{"class":95},[86,289,291,294,297],{"class":88,"line":290},8,[86,292,293],{"class":95},"      exampleMsg: ",[86,295,296],{"class":245},"'Hello emit!'",[86,298,249],{"class":95},[86,300,302],{"class":88,"line":301},9,[86,303,304],{"class":95},"    }\n",[86,306,308,310],{"class":88,"line":307},10,[86,309,264],{"class":95},[86,311,249],{"class":92},[86,313,315,318],{"class":88,"line":314},11,[86,316,317],{"class":92},"}",[86,319,320],{"class":95},";\n",[16,322,323],{},[36,324],{"alt":38,"src":325},"https:\u002F\u002Fi.imgur.com\u002Fz6eWY5Q.png",[16,327,328],{},"接下來在裡面寫一個生命週期 (created)，那 $emit 的撰寫方式如下。",[77,330,332],{"className":79,"code":331,"language":81,"meta":82,"style":82},"this.$emit('自訂傳遞的名稱', 要傳遞的資料);\n",[29,333,334],{"__ignoreMap":82},[86,335,336,340,343,345,348,351],{"class":88,"line":89},[86,337,339],{"class":338},"sCcAr","this",[86,341,342],{"class":95},".",[86,344,215],{"class":272},[86,346,347],{"class":95},"(",[86,349,350],{"class":245},"'自訂傳遞的名稱'",[86,352,353],{"class":95},", 要傳遞的資料);\n",[16,355,356],{},[36,357],{"alt":38,"src":358},"https:\u002F\u002Fi.imgur.com\u002Fwmkwazz.png",[16,360,361],{},"這樣子就已經準備好要像外傳的 emit 了，接下來到要接收的值得地方去做處理(src\u002Fview\u002FHome.vue)，首先我們已經了解到 props 是這樣傳遞",[16,363,364],{},[36,365],{"alt":38,"src":366},"https:\u002F\u002Fi.imgur.com\u002FEpizSKS.png",[16,368,369],{},"而向外傳遞時我們要在組件上寫上我們剛剛自訂要傳遞的名稱，以及即將接收函示即可，但是這邊要注意不可以用縮寫(@)，要寫完整個 v-on，所以正確寫法是這樣子。",[77,371,373],{"className":79,"code":372,"language":81,"meta":82,"style":82},"v-on:example='xxx'\n",[29,374,375],{"__ignoreMap":82},[86,376,377,380,383,386,389,392],{"class":88,"line":89},[86,378,379],{"class":95},"v",[86,381,382],{"class":230},"-",[86,384,385],{"class":92},"on",[86,387,388],{"class":95},":example",[86,390,391],{"class":230},"=",[86,393,394],{"class":245},"'xxx'\n",[16,396,397],{},"傳遞出來之後我們必須要有一個函式可以接收值，所以下面 Home 的資料也要調整一下。",[16,399,400],{},[36,401],{"alt":38,"src":402},"https:\u002F\u002Fi.imgur.com\u002FimcJLbE.png",[16,404,405],{},"接下來再將函式寫上去即可。",[77,407,409],{"className":79,"code":408,"language":81,"meta":82,"style":82},"v-on:example='exampleEmit'\n",[29,410,411],{"__ignoreMap":82},[86,412,413,415,417,419,421,423],{"class":88,"line":89},[86,414,379],{"class":95},[86,416,382],{"class":230},[86,418,385],{"class":92},[86,420,388],{"class":95},[86,422,391],{"class":230},[86,424,425],{"class":245},"'exampleEmit'\n",[16,427,428],{},"這時候在打開瀏覽器，就可以看到 由內部向外傳地的資料哩。",[16,430,431],{},[36,432],{"alt":38,"src":433},"https:\u002F\u002Fi.imgur.com\u002FDcubqwZ.png",[16,435,436],{},"那傳遞的圖解如下",[16,438,439],{},[36,440],{"alt":38,"src":441},"https:\u002F\u002Fi.imgur.com\u002FpgLx3k8.png",[12,443,444],{"id":444},"結語",[16,446,447],{},"基本上 props 與 emit 的觀念常常會搞混，所以這可以看這張圖快速了解 props 與 emit 的傳遞方式，只要了解傳遞原理基本上製作就比較不會有問題。",[16,449,450],{},[36,451],{"alt":38,"src":452},"https:\u002F\u002Fi.imgur.com\u002F7tCaRHy.png",[454,455,456],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":82,"searchDepth":99,"depth":99,"links":458},[459,460,461,462],{"id":14,"depth":99,"text":14},{"id":24,"depth":99,"text":24},{"id":201,"depth":99,"text":201},{"id":444,"depth":99,"text":444},"Vue","2019-05-10 19:04:33","md","zh-Hant",{},true,"\u002Fvue\u002Fpropsemit","2",{"title":6,"description":18},false,"Vue\u002Fprops與emit的傳遞方式",[475,463],"JavaScript",null,"\u002Fvue\u002F20190510\u002F1766915506\u002F","93p65CZMAePboNnc--RC_JMGuy0Cf948unb-liJJD0g",{"newer":480,"older":484},{"url":481,"title":482,"date":483},"\u002Fjavascript\u002F20190511\u002F638155277\u002F","JavaScript基礎閉包觀念","2019-05-11 18:51:54",{"url":485,"title":486,"date":487},"\u002Fvue\u002F20190510\u002F86469050\u002F","Vue 的 @（小老鼠）符號是什麼？src 路徑別名與 .. 的差異","2019-05-10 10:30:35",[489,494,498],{"url":490,"title":491,"date":492,"readingMinutes":493},"\u002Fvue\u002F20251204\u002F754692240\u002F","思考 Vue\u002FNuxt 專案架構：如何選擇適合團隊的目錄結構？","2025-12-04 11:40:56","6",{"url":495,"title":496,"date":497,"readingMinutes":493},"\u002Fvue\u002F20251106\u002F1172686218\u002F","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","2025-11-06 13:45:34",{"url":499,"title":500,"date":501,"readingMinutes":502},"\u002Fvue\u002F20250216\u002F532019259\u002F","不同於 ref 的 shallowRef 宣告","2025-02-16 19:32:58","4",1784020408333]