[{"data":1,"prerenderedAt":897},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20221202\u002F2131448011\u002F":3,"page:\u002Fvue\u002F20221202\u002F2131448011\u002F":4,"alt:\u002Fvue\u002F20221202\u002F2131448011\u002F":3,"prev-next:\u002Fvue\u002F20221202\u002F2131448011\u002F":873,"related:\u002Fvue\u002F20221202\u002F2131448011\u002F":882},"\u002Fen\u002Fvue\u002F2022\u002F12\u002F02\u002Ffix-vue-mustache-flicker-with-v-cloak\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":857,"date":858,"description":18,"extension":859,"lang":860,"meta":861,"navigation":587,"path":862,"readingMinutes":708,"seo":863,"standalone":864,"stem":865,"tags":866,"tldr":870,"updated":858,"url":871,"__hash__":872},"content\u002FVue\u002F解決-Vue-渲染太慢而導致看到-Mustache-雙花括號-的問題.md","解決 Vue 渲染太慢而導致看到 Mustache (雙花括號)的問題","2131448011",{"type":9,"value":10,"toc":849},"minimark",[11,15,19,23,26,33,36,44,47,58,69,72,78,81,87,90,93,98,105,109,114,225,228,265,268,273,286,289,298,332,344,357,370,374,383,465,819,822,826,829,845],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"有時候我們會因為網路太慢導致 Vue 的渲染速度太慢，而導致看到 Mustache (雙花括號)的問題，這個狀況其實並不是很好看，所以這一篇就記錄一下如何解決吧。",[12,20,22],{"id":21},"什麼原因導致會看到-mustache-雙花括號","什麼原因導致會看到 Mustache (雙花括號)",[16,24,25],{},"其實這個問題很有趣，在正常狀況下，你很難會看到以下這張圖",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"Vue 尚未 Instance 導致看到 Mustache","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.42.32.png",[16,34,35],{},"那麼這個問題是怎麼發生的呢？其主要原因是網路太慢導致 Vue 的 JavaScript 檔案還沒有下載完成導致的。",[16,37,38,39,43],{},"因為在一般的狀況下 HTML 檔案通常會優先被下載完畢，因此你會先看到 HTML 的內容，當我們瀏覽器開始渲染 HTML 檔案時，就會由上往下開始依序渲染，當遇到 ",[40,41,42],"code",{},"\u003Cscript>"," 標籤時，就會開始下載 JavaScript 檔案，JavaScript 檔案下載完成後，就會開始執行 JavaScript 檔案，而這就是一個簡單的渲染流程。",[12,45,46],{"id":46},"如何實現問題",[16,48,49,50,57],{},"其實實現方式很簡單，底下我這邊有一個 ",[51,52,56],"a",{"href":53,"rel":54},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FPopawrR?editors=1010",[55],"nofollow","CodePen"," 的範例，你可以試著將網路速度調慢，然後觀察一下。",[59,60,68],"iframe",{"height":61,"style":62,"scrolling":63,"title":64,"src":65,"frameBorder":63,"loading":66,"allowTransparency":67,"allowFullScreen":67},300,"width: 100%;","no","Vue3 Composition API","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FPopawrR?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FPopawrR\">\n  Vue3 Composition API\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,70,71],{},"以 Firefox 來講，限速位置底下圖片所示",[16,73,74],{},[29,75],{"alt":76,"src":77},"網路","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.51.19.png",[16,79,80],{},"下拉後你可以選取網路的速度",[16,82,83],{},[29,84],{"alt":85,"src":86},"速度","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.51.26.png",[16,88,89],{},"你只需要選擇 2G Good 或是 3G Good 就可以並重新整理該 CodePen 畫面就可以看到 Mustache (雙花括號)的問題了。",[16,91,92],{},"如果是 Chrome 的話，也是相同位置",[16,94,95],{},[29,96],{"alt":76,"src":97},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.53.34.png",[16,99,100,101,104],{},"所以為了解決這問題，我們就要使用 Vue 的 ",[40,102,103],{},"v-cloak"," 指令來解決這個問題。",[12,106,108],{"id":107},"v-cloak-指令","v-cloak 指令",[16,110,111,112],{},"其實解決方式非常簡單，只需要在標籤上補上 ",[40,113,103],{},[115,116,121],"pre",{"className":117,"code":118,"language":119,"meta":120,"style":120},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cdiv id=\"app\">\n  \u003Cp v-cloak>\n    我的名字是：{{ myName }}\n  \u003C\u002Fp>\n  \u003Cbr>\n  \u003Cinput type=\"text\" v-model=\"myName\">\n\u003C\u002Fdiv>\n","html","",[40,122,123,150,163,169,179,189,215],{"__ignoreMap":120},[124,125,128,132,136,140,143,147],"span",{"class":126,"line":127},"line",1,[124,129,131],{"class":130},"s8XSl","\u003C",[124,133,135],{"class":134},"syv7_","div",[124,137,139],{"class":138},"sK3KL"," id",[124,141,142],{"class":130},"=",[124,144,146],{"class":145},"sWayO","\"app\"",[124,148,149],{"class":130},">\n",[124,151,153,156,158,161],{"class":126,"line":152},2,[124,154,155],{"class":130},"  \u003C",[124,157,16],{"class":134},[124,159,160],{"class":138}," v-cloak",[124,162,149],{"class":130},[124,164,166],{"class":126,"line":165},3,[124,167,168],{"class":130},"    我的名字是：{{ myName }}\n",[124,170,172,175,177],{"class":126,"line":171},4,[124,173,174],{"class":130},"  \u003C\u002F",[124,176,16],{"class":134},[124,178,149],{"class":130},[124,180,182,184,187],{"class":126,"line":181},5,[124,183,155],{"class":130},[124,185,186],{"class":134},"br",[124,188,149],{"class":130},[124,190,192,194,197,200,202,205,208,210,213],{"class":126,"line":191},6,[124,193,155],{"class":130},[124,195,196],{"class":134},"input",[124,198,199],{"class":138}," type",[124,201,142],{"class":130},[124,203,204],{"class":145},"\"text\"",[124,206,207],{"class":138}," v-model",[124,209,142],{"class":130},[124,211,212],{"class":145},"\"myName\"",[124,214,149],{"class":130},[124,216,218,221,223],{"class":126,"line":217},7,[124,219,220],{"class":130},"\u003C\u002F",[124,222,135],{"class":134},[124,224,149],{"class":130},[16,226,227],{},"接著撰寫一點點的 CSS",[115,229,233],{"className":230,"code":231,"language":232,"meta":120,"style":120},"language-css shiki shiki-themes github-light github-light github-dark-high-contrast","[v-cloak] {\n  display: none;\n}\n","css",[40,234,235,245,260],{"__ignoreMap":120},[124,236,237,240,242],{"class":126,"line":127},[124,238,239],{"class":130},"[",[124,241,103],{"class":138},[124,243,244],{"class":130},"] {\n",[124,246,247,251,254,257],{"class":126,"line":152},[124,248,250],{"class":249},"stw71","  display",[124,252,253],{"class":130},": ",[124,255,256],{"class":249},"none",[124,258,259],{"class":130},";\n",[124,261,262],{"class":126,"line":165},[124,263,264],{"class":130},"}\n",[16,266,267],{},"這樣子就可以解決這個問題",[59,269,272],{"height":61,"style":62,"scrolling":63,"title":270,"src":271,"frameBorder":63,"loading":66,"allowTransparency":67,"allowFullScreen":67},"v-cloak example","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FyLERxRY?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FyLERxRY\">\n  v-cloak example\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,274,275,276,278,279,281,282,285],{},"但是你會發現使用這個方式稍微有一點蠢，因為你會因此被迫還要替一個簡單的文字補上 HTML 標籤，如 ",[40,277,16],{}," 標籤，這樣子就會讓你的 HTML 程式碼變得很醜，因此你是可以將 ",[40,280,103],{}," 放在 ",[40,283,284],{},"#app"," 上面，這樣子就可以達到同樣的效果。",[16,287,288],{},"那麼你可能會想說...",[16,290,291,292,294,295,297],{},"「",[40,293,103],{}," 是 Vue 的指令嗎？前面不是說是因為 Vue 還沒加載完畢才導致渲染很慢嗎？那為什麼可以使用 ",[40,296,103],{},"？」",[16,299,300,301,304,305,308,309,311,312,315,316,318,319,321,322,324,325,327,328,331],{},"沒有錯，這是 Vue 的指令之一，但是其實核心原理只是單純使用到了 CSS 的 ",[40,302,303],{},"display: none"," 屬性，這個屬性是可以讓你的元素不顯示在畫面上，接著使用 CSS 選取器的 ",[40,306,307],{},"[v-cloak]"," 來選取所有有 ",[40,310,103],{}," 的 HTML 元素，並將其 ",[40,313,314],{},"display"," 設為 ",[40,317,256],{},"，當 Vue 加載完畢後，Vue 就會自動移除 ",[40,320,103],{},"，這樣子畫面就會正常顯示，因此你可以說是 Vue 的指令，但是其實是使用 CSS 的 ",[40,323,303],{}," 屬性來達到這個效果，只是你的名稱必須為 ",[40,326,103],{}," 而不是 ",[40,329,330],{},"v-hide"," 或是其他的名稱。",[16,333,334,335,337,338,343],{},"而關於 ",[40,336,103],{}," 其實在 Vue ",[51,339,342],{"href":340,"rel":341},"https:\u002F\u002Fcn.vuejs.org\u002Fapi\u002Fbuilt-in-directives.html#v-cloak",[55],"官方文件","上面有提到，底下我也截取部分說明",[345,346,347],"blockquote",{},[16,348,349,350,352,353,356],{},"用于隐藏尚未完成编译的 DOM 模板。\n当使用直接在 DOM 中书写的模板时，可能会出现一种叫做“未编译模板闪现”的情况：用户可能先看到的是还没编译完成的双大括号标签，直到挂载的组件将它们替换为实际渲染的内容。\nv-cloak 会保留在所绑定的元素上，直到相关组件实例被挂载后才移除。配合像 ",[124,351,103],{}," { display: none } 这样的 CSS 规则，它可以在组件编译完毕前隐藏原始模板。\n直到编译完成前，",[40,354,355],{},"\u003Cdiv>"," 将不可见。",[16,358,359,360,363,364,366,367,369],{},"如果你腦袋正在想著是不是使用 ",[40,361,362],{},"v-if"," 可不可以解決這問題的話，我只能跟你說，不可以，因為 ",[40,365,362],{}," 要能夠被使用也要等 Vue 的加載完畢，所以你是無法使用 ",[40,368,362],{}," 來解決這個問題的。",[12,371,373],{"id":372},"優化-v-cloak","優化 v-cloak",[16,375,376,377,379,380,382],{},"雖然我們可以使用 ",[40,378,303],{}," 來達到 ",[40,381,103],{}," 的效果，但是這樣子會導致畫面白一塊，在使用者體驗上是非常不好的，因此你可以考慮撰寫一點點的 CSS Loading 效果，讓使用者在等待 Vue 的加載時，至少可以看到一點點的東西，這樣子使用者體驗會比較好，這邊我也提供一下簡單版的 CSS Loading 效果",[115,384,386],{"className":117,"code":385,"language":119,"meta":120,"style":120},"\u003Cdiv id=\"app\" v-cloak>\n  我的名字是：{{ myName }}\n  \u003Cbr>\n  \u003Cinput type=\"text\" v-model=\"myName\">\n\u003C\u002Fdiv>\n\u003Cdiv id=\"loader\">\u003C\u002Fdiv>\n",[40,387,388,404,409,417,437,445],{"__ignoreMap":120},[124,389,390,392,394,396,398,400,402],{"class":126,"line":127},[124,391,131],{"class":130},[124,393,135],{"class":134},[124,395,139],{"class":138},[124,397,142],{"class":130},[124,399,146],{"class":145},[124,401,160],{"class":138},[124,403,149],{"class":130},[124,405,406],{"class":126,"line":152},[124,407,408],{"class":130},"  我的名字是：{{ myName }}\n",[124,410,411,413,415],{"class":126,"line":165},[124,412,155],{"class":130},[124,414,186],{"class":134},[124,416,149],{"class":130},[124,418,419,421,423,425,427,429,431,433,435],{"class":126,"line":171},[124,420,155],{"class":130},[124,422,196],{"class":134},[124,424,199],{"class":138},[124,426,142],{"class":130},[124,428,204],{"class":145},[124,430,207],{"class":138},[124,432,142],{"class":130},[124,434,212],{"class":145},[124,436,149],{"class":130},[124,438,439,441,443],{"class":126,"line":181},[124,440,220],{"class":130},[124,442,135],{"class":134},[124,444,149],{"class":130},[124,446,447,449,451,453,455,458,461,463],{"class":126,"line":191},[124,448,131],{"class":130},[124,450,135],{"class":134},[124,452,139],{"class":138},[124,454,142],{"class":130