[{"data":1,"prerenderedAt":896},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20221202\u002F2131448011\u002F":3,"page:\u002Fvue\u002F20221202\u002F2131448011\u002F":4,"alt:\u002Fvue\u002F20221202\u002F2131448011\u002F":3,"prev-next:\u002Fvue\u002F20221202\u002F2131448011\u002F":872,"related:\u002Fvue\u002F20221202\u002F2131448011\u002F":881},"\u002Fen\u002Fvue\u002F2022\u002F12\u002F02\u002Ffix-vue-mustache-flicker-with-v-cloak\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":856,"date":857,"description":18,"extension":858,"lang":859,"meta":860,"navigation":586,"path":861,"readingMinutes":707,"seo":862,"standalone":863,"stem":864,"tags":865,"tldr":869,"updated":857,"url":870,"__hash__":871},"content\u002FVue\u002F解決-Vue-渲染太慢而導致看到-Mustache-雙花括號-的問題.md","解決 Vue 渲染太慢而導致看到 Mustache (雙花括號)的問題","2131448011",{"type":9,"value":10,"toc":848},"minimark",[11,15,19,23,26,33,36,44,47,58,69,72,78,81,87,90,93,98,105,109,114,225,228,264,267,272,285,288,297,331,343,356,369,373,382,464,818,821,825,828,844],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"有時候我們會因為網路太慢導致 Vue 的渲染速度太慢，而導致看到 Mustache (雙花括號)的問題，這個狀況其實並不是很好看，所以這一篇就記錄一下如何解決吧。",[12,20,22],{"id":21},"什麼原因導致會看到-mustache-雙花括號","什麼原因導致會看到 Mustache (雙花括號)",[16,24,25],{},"其實這個問題很有趣，在正常狀況下，你很難會看到以下這張圖",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"Vue 尚未 Instance 導致看到 Mustache","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.42.32.png",[16,34,35],{},"那麼這個問題是怎麼發生的呢？其主要原因是網路太慢導致 Vue 的 JavaScript 檔案還沒有下載完成導致的。",[16,37,38,39,43],{},"因為在一般的狀況下 HTML 檔案通常會優先被下載完畢，因此你會先看到 HTML 的內容，當我們瀏覽器開始渲染 HTML 檔案時，就會由上往下開始依序渲染，當遇到 ",[40,41,42],"code",{},"\u003Cscript>"," 標籤時，就會開始下載 JavaScript 檔案，JavaScript 檔案下載完成後，就會開始執行 JavaScript 檔案，而這就是一個簡單的渲染流程。",[12,45,46],{"id":46},"如何實現問題",[16,48,49,50,57],{},"其實實現方式很簡單，底下我這邊有一個 ",[51,52,56],"a",{"href":53,"rel":54},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FPopawrR?editors=1010",[55],"nofollow","CodePen"," 的範例，你可以試著將網路速度調慢，然後觀察一下。",[59,60,68],"iframe",{"height":61,"style":62,"scrolling":63,"title":64,"src":65,"frameBorder":63,"loading":66,"allowTransparency":67,"allowFullScreen":67},300,"width: 100%;","no","Vue3 Composition API","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FPopawrR?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FPopawrR\">\n  Vue3 Composition API\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,70,71],{},"以 Firefox 來講，限速位置底下圖片所示",[16,73,74],{},[29,75],{"alt":76,"src":77},"網路","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.51.19.png",[16,79,80],{},"下拉後你可以選取網路的速度",[16,82,83],{},[29,84],{"alt":85,"src":86},"速度","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.51.26.png",[16,88,89],{},"你只需要選擇 2G Good 或是 3G Good 就可以並重新整理該 CodePen 畫面就可以看到 Mustache (雙花括號)的問題了。",[16,91,92],{},"如果是 Chrome 的話，也是相同位置",[16,94,95],{},[29,96],{"alt":76,"src":97},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202022-12-02%2016.53.34.png",[16,99,100,101,104],{},"所以為了解決這問題，我們就要使用 Vue 的 ",[40,102,103],{},"v-cloak"," 指令來解決這個問題。",[12,106,108],{"id":107},"v-cloak-指令","v-cloak 指令",[16,110,111,112],{},"其實解決方式非常簡單，只需要在標籤上補上 ",[40,113,103],{},[115,116,121],"pre",{"className":117,"code":118,"language":119,"meta":120,"style":120},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cdiv id=\"app\">\n  \u003Cp v-cloak>\n    我的名字是：{{ myName }}\n  \u003C\u002Fp>\n  \u003Cbr>\n  \u003Cinput type=\"text\" v-model=\"myName\">\n\u003C\u002Fdiv>\n","html","",[40,122,123,150,163,169,179,189,215],{"__ignoreMap":120},[124,125,128,132,136,140,143,147],"span",{"class":126,"line":127},"line",1,[124,129,131],{"class":130},"sMAXC","\u003C",[124,133,135],{"class":134},"sKpQp","div",[124,137,139],{"class":138},"sCcAr"," id",[124,141,142],{"class":130},"=",[124,144,146],{"class":145},"sTRMh","\"app\"",[124,148,149],{"class":130},">\n",[124,151,153,156,158,161],{"class":126,"line":152},2,[124,154,155],{"class":130},"  \u003C",[124,157,16],{"class":134},[124,159,160],{"class":138}," v-cloak",[124,162,149],{"class":130},[124,164,166],{"class":126,"line":165},3,[124,167,168],{"class":130},"    我的名字是：{{ myName }}\n",[124,170,172,175,177],{"class":126,"line":171},4,[124,173,174],{"class":130},"  \u003C\u002F",[124,176,16],{"class":134},[124,178,149],{"class":130},[124,180,182,184,187],{"class":126,"line":181},5,[124,183,155],{"class":130},[124,185,186],{"class":134},"br",[124,188,149],{"class":130},[124,190,192,194,197,200,202,205,208,210,213],{"class":126,"line":191},6,[124,193,155],{"class":130},[124,195,196],{"class":134},"input",[124,198,199],{"class":138}," type",[124,201,142],{"class":130},[124,203,204],{"class":145},"\"text\"",[124,206,207],{"class":138}," v-model",[124,209,142],{"class":130},[124,211,212],{"class":145},"\"myName\"",[124,214,149],{"class":130},[124,216,218,221,223],{"class":126,"line":217},7,[124,219,220],{"class":130},"\u003C\u002F",[124,222,135],{"class":134},[124,224,149],{"class":130},[16,226,227],{},"接著撰寫一點點的 CSS",[115,229,233],{"className":230,"code":231,"language":232,"meta":120,"style":120},"language-css shiki shiki-themes github-dark-high-contrast","[v-cloak] {\n  display: none;\n}\n","css",[40,234,235,245,259],{"__ignoreMap":120},[124,236,237,240,242],{"class":126,"line":127},[124,238,239],{"class":130},"[",[124,241,103],{"class":138},[124,243,244],{"class":130},"] {\n",[124,246,247,250,253,256],{"class":126,"line":152},[124,248,249],{"class":138},"  display",[124,251,252],{"class":130},": ",[124,254,255],{"class":138},"none",[124,257,258],{"class":130},";\n",[124,260,261],{"class":126,"line":165},[124,262,263],{"class":130},"}\n",[16,265,266],{},"這樣子就可以解決這個問題",[59,268,271],{"height":61,"style":62,"scrolling":63,"title":269,"src":270,"frameBorder":63,"loading":66,"allowTransparency":67,"allowFullScreen":67},"v-cloak example","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FyLERxRY?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FyLERxRY\">\n  v-cloak example\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,273,274,275,277,278,280,281,284],{},"但是你會發現使用這個方式稍微有一點蠢，因為你會因此被迫還要替一個簡單的文字補上 HTML 標籤，如 ",[40,276,16],{}," 標籤，這樣子就會讓你的 HTML 程式碼變得很醜，因此你是可以將 ",[40,279,103],{}," 放在 ",[40,282,283],{},"#app"," 上面，這樣子就可以達到同樣的效果。",[16,286,287],{},"那麼你可能會想說...",[16,289,290,291,293,294,296],{},"「",[40,292,103],{}," 是 Vue 的指令嗎？前面不是說是因為 Vue 還沒加載完畢才導致渲染很慢嗎？那為什麼可以使用 ",[40,295,103],{},"？」",[16,298,299,300,303,304,307,308,310,311,314,315,317,318,320,321,323,324,326,327,330],{},"沒有錯，這是 Vue 的指令之一，但是其實核心原理只是單純使用到了 CSS 的 ",[40,301,302],{},"display: none"," 屬性，這個屬性是可以讓你的元素不顯示在畫面上，接著使用 CSS 選取器的 ",[40,305,306],{},"[v-cloak]"," 來選取所有有 ",[40,309,103],{}," 的 HTML 元素，並將其 ",[40,312,313],{},"display"," 設為 ",[40,316,255],{},"，當 Vue 加載完畢後，Vue 就會自動移除 ",[40,319,103],{},"，這樣子畫面就會正常顯示，因此你可以說是 Vue 的指令，但是其實是使用 CSS 的 ",[40,322,302],{}," 屬性來達到這個效果，只是你的名稱必須為 ",[40,325,103],{}," 而不是 ",[40,328,329],{},"v-hide"," 或是其他的名稱。",[16,332,333,334,336,337,342],{},"而關於 ",[40,335,103],{}," 其實在 Vue ",[51,338,341],{"href":339,"rel":340},"https:\u002F\u002Fcn.vuejs.org\u002Fapi\u002Fbuilt-in-directives.html#v-cloak",[55],"官方文件","上面有提到，底下我也截取部分說明",[344,345,346],"blockquote",{},[16,347,348,349,351,352,355],{},"用于隐藏尚未完成编译的 DOM 模板。\n当使用直接在 DOM 中书写的模板时，可能会出现一种叫做“未编译模板闪现”的情况：用户可能先看到的是还没编译完成的双大括号标签，直到挂载的组件将它们替换为实际渲染的内容。\nv-cloak 会保留在所绑定的元素上，直到相关组件实例被挂载后才移除。配合像 ",[124,350,103],{}," { display: none } 这样的 CSS 规则，它可以在组件编译完毕前隐藏原始模板。\n直到编译完成前，",[40,353,354],{},"\u003Cdiv>"," 将不可见。",[16,357,358,359,362,363,365,366,368],{},"如果你腦袋正在想著是不是使用 ",[40,360,361],{},"v-if"," 可不可以解決這問題的話，我只能跟你說，不可以，因為 ",[40,364,361],{}," 要能夠被使用也要等 Vue 的加載完畢，所以你是無法使用 ",[40,367,361],{}," 來解決這個問題的。",[12,370,372],{"id":371},"優化-v-cloak","優化 v-cloak",[16,374,375,376,378,379,381],{},"雖然我們可以使用 ",[40,377,302],{}," 來達到 ",[40,380,103],{}," 的效果，但是這樣子會導致畫面白一塊，在使用者體驗上是非常不好的，因此你可以考慮撰寫一點點的 CSS Loading 效果，讓使用者在等待 Vue 的加載時，至少可以看到一點點的東西，這樣子使用者體驗會比較好，這邊我也提供一下簡單版的 CSS Loading 效果",[115,383,385],{"className":117,"code":384,"language":119,"meta":120,"style":120},"\u003Cdiv id=\"app\" v-cloak>\n  我的名字是：{{ myName }}\n  \u003Cbr>\n  \u003Cinput type=\"text\" v-model=\"myName\">\n\u003C\u002Fdiv>\n\u003Cdiv id=\"loader\">\u003C\u002Fdiv>\n",[40,386,387,403,408,416,436,444],{"__ignoreMap":120},[124,388,389,391,393,395,397,399,401],{"class":126,"line":127},[124,390,131],{"class":130},[124,392,135],{"class":134},[124,394,139],{"class":138},[124,396,142],{"class":130},[124,398,146],{"class":145},[124,400,160],{"class":138},[124,402,149],{"class":130},[124,404,405],{"class":126,"line":152},[124,406,407],{"class":130},"  我的名字是：{{ myName }}\n",[124,409,410,412,414],{"class":126,"line":165},[124,411,155],{"class":130},[124,413,186],{"class":134},[124,415,149],{"class":130},[124,417,418,420,422,424,426,428,430,432,434],{"class":126,"line":171},[124,419,155],{"class":130},[124,421,196],{"class":134},[124,423,199],{"class":138},[124,425,142],{"class":130},[124,427,204],{"class":145},[124,429,207],{"class":138},[124,431,142],{"class":130},[124,433,212],{"class":145},[124,435,149],{"class":130},[124,437,438,440,442],{"class":126,"line":181},[124,439,220],{"class":130},[124,441,135],{"class":134},[124,443,149],{"class":130},[124,445,446,448,450,452,454,457,460,462],{"class":126,"line":191},[124,447,131],{"class":130},[124,449,135],{"class":134},[124,451,139],{"class":138},[124,453,142],{"class":130},[124,455,456],{"class":145},"\"loader\"",[124,458,459],{"c