没有完全遵循 MVVM 模型，但是 Vue 的设计也受到了它的启发。因此在文档中经常会使用 vm (ViewModel 的缩写) 这个变量名表示 Vue 实例",[16,64,65,66,69],{},"所以我們以往常看到的 ",[20,67,68],{},"const vm = this;"," 就是在講 ViewModel。",[16,71,72],{},"這邊也稍微稍微提一下由於 Vue 3 區分成了 Option API 與 Composition API 兩種寫法，而 HTMl 撰寫方式並沒有任何改變：",[74,75,80],"pre",{"className":76,"code":77,"language":78,"meta":79,"style":79},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cdiv id=\"app\">\n  我的名字是：{{ myName }}\n  \u003Cbr>\n  \u003Cinput type=\"text\" v-model=\"myName\">\n\u003C\u002Fdiv>\n","html","",[20,81,82,109,115,126,152],{"__ignoreMap":79},[83,84,87,91,95,99,102,106],"span",{"class":85,"line":86},"line",1,[83,88,90],{"class":89},"s8XSl","\u003C",[83,92,94],{"class":93},"syv7_","div",[83,96,98],{"class":97},"sK3KL"," id",[83,100,101],{"class":89},"=",[83,103,105],{"class":104},"sWayO","\"app\"",[83,107,108],{"class":89},">\n",[83,110,112],{"class":85,"line":111},2,[83,113,114],{"class":89},"  我的名字是：{{ myName }}\n",[83,116,118,121,124],{"class":85,"line":117},3,[83,119,120],{"class":89},"  \u003C",[83,122,123],{"class":93},"br",[83,125,108],{"class":89},[83,127,129,131,134,137,139,142,145,147,150],{"class":85,"line":128},4,[83,130,120],{"class":89},[83,132,133],{"class":93},"input",[83,135,136],{"class":97}," type",[83,138,101],{"class":89},[83,140,141],{"class":104},"\"text\"",[83,143,144],{"class":97}," v-model",[83,146,101],{"class":89},[83,148,149],{"class":104},"\"myName\"",[83,151,108],{"class":89},[83,153,155,158,160],{"class":85,"line":154},5,[83,156,157],{"class":89},"\u003C\u002F",[83,159,94],{"class":93},[83,161,108],{"class":89},[16,163,164],{},"但是在 Vue 3 Option API 就是原本 Vue 2 的開發模式：",[74,166,170],{"className":167,"code":168,"language":169,"meta":79,"style":79},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","var app = new Vue({\n  el: '#app',\n  data: {\n    myName: 'Ray',\n  },\n});\n","js",[20,171,172,193,204,209,219,224],{"__ignoreMap":79},[83,173,174,