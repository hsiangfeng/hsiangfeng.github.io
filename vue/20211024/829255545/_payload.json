code":524,"language":169,"meta":36,"style":36},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      console.log(this);\n      setTimeout(() => {\n        console.log('新增成功！');\n        this.myName = this.$options.data().myName\n        console.log('資料變成初始了：', this.myName);\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[26,526,527,535,541,547,553,557,561,565,571,584,594,606,624,641,649,653,658],{"__ignoreMap":36},[40,528,529,531,533],{"class":42,"line":43},[40,530,176],{"class":46},[40,532,180],{"class":179},[40,534,183],{"class":46},[40,536,537,539],{"class":42,"line":68},[40,538,188],{"class":179},[40,540,191],{"class":46},[40,542,543,545],{"class":42,"line":74},[40,544,197],{"class":196},[40,546,200],{"class":46},[40,548,549,551],{"class":42,"line":102},[40,550,205],{"class":46},[40,552,208],{"class":61},[40,554,555],{"class":42,"line":116},[40,556,213],{"class":46},[40,558,559],{"class":42,"line":126},[40,560,218],{"class":46},[40,562,563],{"class":42,"line":157},[40,564,223],{"class":46},[40,566,567,569],{"class":42,"line":226},[40,568,229],{"class":179},[40,570,191],{"class":46},[40,572,573,576,578,580,582],{"class":42,"line":234},[40,574,575],{"class":46},"      console.",[40,577,254],{"class":179},[40,579,257],{"class":46},[40,581,281],{"class":54},[40,583,263],{"class":46},[40,585,586,588,590,592],{"class":42,"line":248},[40,587,237],{"class":179},[40,589,240],{"class":46},[40,591,243],{"class":196},[40,593,200],{"class":46},[40,595,596,598,600,602,604],{"class":42,"line":266},[40,597,251],{"class":46},[40,599,254],{"class":179},[40,601,257],{"class":46},[40,603,260],{"class":61},[40,605,263],{"class":46},[40,607,608,610,612,614,617,619,621],{"class":42,"line":287},[40,609,419],{"class":54},[40,611,422],{"class":46},[40,613,58],{"class":196},[40,615,616],{"class":54}," this",[40,618,476],{"class":46},[40,620,479],{"class":179},[40,622,623],{"class":46},"().myName\n",[40,625,626,628,630,632,635,637,