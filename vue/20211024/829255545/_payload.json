一個函式，所以你必須使用呼叫的方式，因此你就可以將上方改寫成以下",[31,524,526],{"className":167,"code":525,"language":169,"meta":36,"style":36},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      console.log(this);\n      setTimeout(() => {\n        console.log('新增成功！');\n        this.myName = this.$options.data().myName\n        console.log('資料變成初始了：', this.myName);\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[26,527,528,536,542,548,554,558,562,566,572,585,595,607,625,642,650,654,659],{"__ignoreMap":36},[40,529,530,532,534],{"class":42,"line":43},[40,531,176],{"class":46},[40,533,180],{"class":179},[40,535,183],{"class":46},[40,537,538,540],{"class":42,"line":68},[40,539,188],{"class":179},[40,541,191],{"class":46},[40,543,544,546],{"class":42,"line":74},[40,545,197],{"class":196},[40,547,200],{"class":46},[40,549,550,552],{"class":42,"line":102},[40,551,205],{"class":46},[40,553,208],{"class":61},[40,555,556],{"class":42,"line":116},[40,557,213],{"class":46},[40,559,560],{"class":42,"line":126},[40,561,218],{"class":46},[40,563,564],{"class":42,"line":157},[40,565,223],{"class":46},[40,567,568,570],{"class":42,"line":226},[40,569,229],{"class":179},[40,571,191],{"class":46},[40,573,574,577,579,581,583],{"class":42,"line":234},[40,575,576],{"class":46},"      console.",[40,578,254],{"class":179},[40,580,257],{"class":46},[40,582,282],{"class":281},[40,584,263],{"class":46},[40,586,587,589,591,593],{"class":42,"line":248},[40,588,237],{"class":179},[40,590,240],{"class":46},[40,592,243],{"class":196},[40,594,200],{"class":46},[40,596,597,599,601,603,605],{"class":42,"line":266},[40,598,251],{"class":46},[40,600,254],{"class":179},[40,602,257],{"class":46},[40,604,260],{"class":61},[40,606,263],{"class":46},[40,608,609,611,613,615,618,620,622],{"class":42,"line":288},[40,610,420],{"class":281},[40,612,423],{"class":46},[40,614,58],{"class":196},[40,616,617],{"class":281}," this",[40,619,477],{"class":46},[40,621,480],{"class":179},[40,