",[491],"Set and reset a reactive object",[16,718,719,720,723],{},"因此我們就知道可以透過 ",[26,721,722],{},"Object.assign"," 來做到類似重設的效果，透過上面討論的話我們可以改成以下",[31,725,727],{"className":167,"code":726,"language":169,"meta":36,"style":36},"Vue.createApp({\n  setup() {\n    const initialData = {\n      myName: '',\n    }\n    const data = Vue.reactive({ ...initialData });\n    \n    const ajax = () => {\n        setTimeout(() => {\n          console.log('新增成功！');\n          Object.assign(data, initialData);\n          console.log('資料變成初始了：', data.myName);\n        }, 1500);\n    }\n\n    return {\n       data,\n       ajax\n    }\n  }\n}).mount('#app');\n",[26,728,729,737,744,757,767,771,795,800,816,827,840,851,864,873,877,883,889,894,900,905,910],{"__ignoreMap":36},[40,730,731,733,735],{"class":42,"line":43},[40,732,176],{"class":46},[40,734,180],{"class":179},[40,736,183],{"class":46},[40,738,739,742],{"class":42,"line":68},[40,740,741],{"class":179},"  setup",[40,743,191],{"class":46},[40,745,746,749,752,755],{"class":42,"line":74},[40,747,748],{"class":196},"    const",[40,750,751],{"class":281}," initialData",[40,753,754],{"class":196}," =",[40,756,200],{"class":46},[40,758,759,761,764],{"class":42,"line":102},[40,760,205],{"class":46},[40,762,763],{"class":61},"''",[40,765,766],{"class":46},",\n",[40,768,769],{"class":42,"line":116},[40,770,213],{"class":46},[40,772,773,775,778,780,783,786,789,792],{"class":42,"line":126},[40,774,748],{"class":196},[40,776,777],{"class":281}," data",[40,779,754],{"class":196},[40,781,782],{"class":46}," Vue.",[40,784,785],{"class":179},"reactive",[40,787,788],{"class":46},"({ ",[40,790,791],{"class":196},"...",[40,793,794],{"class":46},"initialData });\n",[40,796,797],{"class":42,"line":157},[40,798,799],{"class":46},"    \n",[40,801,802,804,807,809,812,814],{"class":42,"line":226},[40,803,748],{"class":196},[40,805,806],{"class":179}," ajax",[40,808,754],{"class":196},[40,810,811],{"class":46}," () ",[40,813,243],{"class":196},[40,815,200],{"c