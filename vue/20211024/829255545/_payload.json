,323,263],{"class":46},[16,325,326],{},"你可以試著點以下 Codepen 試試看",[328,329,337],"iframe",{"height":330,"style":331,"scrolling":332,"title":333,"src":334,"frameBorder":332,"loading":335,"allowTransparency":336,"allowFullScreen":336},300,"width: 100%;","no","Untitled","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FXWapZja?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FXWapZja\">\n  Untitled\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[12,339,341],{"id":340},"reset-options-api-data","Reset Options API Data",[16,343,344],{},"那麼為了達到這個需求，通常我們可能這樣做，在 AJAX 之後重新賦予空值：",[31,346,348],{"className":167,"code":347,"language":169,"meta":36,"style":36},"Vue.createApp({\n  data() {\n    return {\n      myName: ''\n    }\n  },\n  methods: {\n    ajax() {\n      setTimeout(() => {\n        console.log('新增成功！');\n        this.myName = '';\n      }, 1500);\n    }\n  }\n}).mount('#app');\n",[26,349,350,358,364,370,376,380,384,388,394,404,416,432,440,444,448],{"__ignoreMap":36},[40,351,352,354,356],{"class":42,"line":43},[40,353,176],{"class":46},[40,355,180],{"class":179},[40,357,183],{"class":46},[40,359,360,362],{"class":42,"line":68},[40,361,188],{"class":179},[40,363,191],{"class":46},[40,365,366,368],{"class":42,"line":74},[40,367,197],{"class":196},[40,369,200],{"class":46},[40,371,372,374],{"class":42,"line":102},[40,373,205],{"class":46},[40,375,208],{"class":61},[40,377,378],{"class":42,"line":116},[40,379,213],{"class":46},[40,381,382],{"class":42,"line":126},[40,383,218],{"class":46},[40,385,386],{"class":42,"line":157},[40,387,223],{"class":46},[40,389,390,392],{"class":42,"line":226},[40,391,229],{"class":179},[40,393,191],{"class":46},[40,395,396,398,400,402],{"class":42,"line":234},[40,397,237],{"class":179},[40,399,240],{"class":46},[40