[{"data":1,"prerenderedAt":338},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20190729\u002F371929708\u002F":3,"page:\u002Fvue\u002F20190729\u002F371929708\u002F":4,"alt:\u002Fvue\u002F20190729\u002F371929708\u002F":3,"prev-next:\u002Fvue\u002F20190729\u002F371929708\u002F":314,"related:\u002Fvue\u002F20190729\u002F371929708\u002F":323},"\u002Fen\u002Fvue\u002F2019\u002F07\u002F29\u002Fvue-girlfriend-pagination-2\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":299,"date":300,"description":18,"extension":301,"lang":302,"meta":303,"navigation":111,"path":304,"readingMinutes":305,"seo":306,"standalone":307,"stem":308,"tags":309,"tldr":311,"updated":311,"url":312,"__hash__":313},"content\u002FVue 出一個女友吧!\u002FVue-出一個女友吧-製作分頁邏輯-2.md","Vue 出一個女友吧!-製作分頁邏輯-2","371929708",{"type":9,"value":10,"toc":293},"minimark",[11,15,19,22,25,28,195,198,205,212,215,221,224,266,269,274,277,283,286,289],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"從上一篇就可以了解到其實前端也是可以製作分頁邏輯的，但是會相當複雜，如果後端有做好相關的分頁邏輯 API 給前端那就會不一樣囉",[12,20,21],{"id":21},"模板",[16,23,24],{},"由於這邊要保留原本的分頁邏輯，所以就不動 Products.vue 這邊改用 Coupons.vue 來製作",[16,26,27],{},"首先先建立一個檔案叫 Pagination_2.vue，內容模板如下",[29,30,35],"pre",{"className":31,"code":32,"language":33,"meta":34,"style":34},"language-pug shiki shiki-themes github-dark-high-contrast","\u003Ctemplate lang=\"pug\">\n  div\n    nav(aria-label='Page navigation example')\n      ul.pagination.justify-content-center\n        li.page-item(:class=\"{'disabled': !paginationService.has_pre}\")\n          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page - 1)', tabindex='-1') Previous\n        li.page-item(v-for='pages in paginationService.total_pages', :key='pages', :class=\"{'active': paginationService.current_page === pages}\")\n          a.page-link(href='#', @click.prevent='getPagesService(pages)') {{ pages }}\n        li.page-item(:class=\"{'disabled': !paginationService.has_next}\")\n          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page + 1)') Next\n\u003C\u002Ftemplate>\n\n\u003Cscript>\nexport default {\n  props: {\n    paginationService: {\n      type: Object,\n    },\n  },\n  methods: {\n    getPagesService(item) {\n      this.$emit('pageService', item);\n    },\n  },\n};\n\u003C\u002Fscript>\n","pug","",[36,37,38,46,52,58,64,70,76,82,88,94,100,106,113,119,125,131,137,143,149,155,161,167,173,178,183,189],"code",{"__ignoreMap":34},[39,40,43],"span",{"class":41,"line":42},"line",1,[39,44,45],{},"\u003Ctemplate lang=\"pug\">\n",[39,47,49],{"class":41,"line":48},2,[39,50,51],{},"  div\n",[39,53,55],{"class":41,"line":54},3,[39,56,57],{},"    nav(aria-label='Page navigation example')\n",[39,59,61],{"class":41,"line":60},4,[39,62,63],{},"      ul.pagination.justify-content-center\n",[39,65,67],{"class":41,"line":66},5,[39,68,69],{},"        li.page-item(:class=\"{'disabled': !paginationService.has_pre}\")\n",[39,71,73],{"class":41,"line":72},6,[39,74,75],{},"          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page - 1)', tabindex='-1') Previous\n",[39,77,79],{"class":41,"line":78},7,[39,80,81],{},"        li.page-item(v-for='pages in paginationService.total_pages', :key='pages', :class=\"{'active': paginationService.current_page === pages}\")\n",[39,83,85],{"class":41,"line":84},8,[39,86,87],{},"          a.page-link(href='#', @click.prevent='getPagesService(pages)') {{ pages }}\n",[39,89,91],{"class":41,"line":90},9,[39,92,93],{},"        li.page-item(:class=\"{'disabled': !paginationService.has_next}\")\n",[39,95,97],{"class":41,"line":96},10,[39,98,99],{},"          a.page-link(href='#', @click.prevent='getPagesService(paginationService.current_page + 1)') Next\n",[39,101,103],{"class":41,"line":102},11,[39,104,105],{},"\u003C\u002Ftemplate>\n",[39,107,109],{"class":41,"line":108},12,[39,110,112],{"emptyLinePlaceholder":111},true,"\n",[39,114,116],{"class":41,"line":115},13,[39,117,118],{},"\u003Cscri