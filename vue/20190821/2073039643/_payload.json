[{"data":1,"prerenderedAt":237},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20190821\u002F2073039643\u002F":3,"page:\u002Fvue\u002F20190821\u002F2073039643\u002F":4,"alt:\u002Fvue\u002F20190821\u002F2073039643\u002F":3,"prev-next:\u002Fvue\u002F20190821\u002F2073039643\u002F":213,"related:\u002Fvue\u002F20190821\u002F2073039643\u002F":222},"\u002Fen\u002Fvue\u002F2019\u002F08\u002F21\u002Fnuxt-window-or-document-undefined-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":196,"date":197,"description":18,"extension":198,"lang":199,"meta":200,"navigation":201,"path":202,"readingMinutes":203,"seo":204,"standalone":205,"stem":206,"tags":207,"tldr":210,"updated":210,"url":211,"__hash__":212},"content\u002FVue\u002FNuxt-出現-window-or-document-undefined-window-is-not-defined.md","Nuxt 出現 window or document undefined(window is not defined)","2073039643",{"type":9,"value":10,"toc":190},"minimark",[11,15,19,22,25,55,58,65,68,100,103,106,109,136,139,164,167,170,179,186],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近開發 Nuxt.js 在引入套件的時候發生 window is not defined 的錯誤訊息，所以這一篇來記錄一下該如何解決",[12,20,21],{"id":21},"解決方式",[16,23,24],{},"由於 Nuxt 在打包的時候會將放在 plugins 一起打包進去 server，那麼就會導致某些外掛是不能正常運作(因為要取得 window)，這邊舉例一個套件就很明顯，當你直接在 plugins 資料夾內新增一個 owlCarousel.js，並輸入以下內容",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-js shiki shiki-themes github-dark-high-contrast","require('owl.carousel');\n","js","",[33,34,35],"code",{"__ignoreMap":31},[36,37,40,44,48,52],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sj_SG","require",[36,45,47],{"class":46},"sMAXC","(",[36,49,51],{"class":50},"sTRMh","'owl.carousel'",[36,53,54],{"class":46},");\n",[16,56,57],{},"你會得到一個錯誤訊息",[16,59,60],{},[61,62],"img",{"alt":63,"src":64},"window is not defined","https:\u002F\u002Fi.imgur.com\u002FHOTPJWC.png",[16,66,67],{},"要解決這個方式就是要讓 Nuxt 在打包的時候，不要將 owl.carousel 打包進去 server，那麼解決方式很簡單只需要這樣就可以解決了",[26,69,71],{"className":28,"code":70,"language":30,"meta":31,"style":31},"if (process.client) {\n  require('owl.carousel');\n}\n",[33,72,73,82,94],{"__ignoreMap":31},[36,74,75,79],{"class":38,"line":39},[36,76,78],{"class":77},"sWyjQ","if",[36,80,81],{"class":46}," (process.client) {\n",[36,83,85,88,90,92],{"class":38,"line":84},2,[36,86,87],{"class":42},"  require",[36,89,47],{"class":46},[36,91,51],{"class":50},[36,93,54],{"class":46},[36,95,97],{"class":38,"line":96},3,[36,98,99],{"class":46},"}\n",[16,101,102],{},"意思簡單來講就是只在 client 下引入這個套件",[12,104,105],{"id":105},"結尾",[16,107,108],{},"如果是引入 bootstrap 的話也是一樣，但是網路上有兩種做法",[26,110,112],{"className":28,"code":111,"language":30,"meta":31,"style":31},"if (process.browser) {\n  require('bootstrap');\n}\n",[33,113,114,121,132],{"__ignoreMap":31},[36,115,116,118],{"class":38,"line":39},[36,117,78],{"class":77},[36,119,120],{"class":46}," (process.browser) {\n",[36,122,123,125,127,130],{"class":38,"line":84},[36,124,87],{"class":42},[36,126,47],{"class":46},[36,128,129],{"class":50},"'bootstrap'",[36,131,54],{"class":46},[36,133,134],{"class":38,"line":96},[36,135,99],{"class":46},[16,137,138],{},"另一種則是",[26,140,142],{"className":28,"code":141,"language":30,"meta":31,"style":31},"if (process.client) {\n  require('bootstrap');\n}\n",[33,143,144,150,160],{"__ignoreMap":31},[36,145,146,148],{"class":38,"line":39},[36,147,78],{"class":77},[36,149,81],{"class":46},[36,151,152,154,156,158],{"class":38,"line":84},[36,153,87],{"class":42},[36,155,47],{"class":46},[36,157,129],{"class":50},[36,159,54],{"class":46},[36,161,162],{"class":38,"line":96},[36,163,99],{"class":46},[16,165,166],{},"以上這兩種我都有測試過都可以正常運作，但是依照如果是比較正式一點的話，後者應該會比較適合，畢竟官方文件有寫到這個方式",[12,168,169],{"id":169},"參考文獻",[16,171,172],{},[173,174,178],"a",{"href":175,"rel":176},"https:\u002F\u002Fzh.nuxtjs.org\u002Ffaq\u002Fwindow-document-undefined\u002F",[177],"nofollow","Window 或 Document 对象未定义？",[16,180,181],{},[173,182,185],{"href":183,"rel":184},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt.js\u0