[{"data":1,"prerenderedAt":340},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20200522\u002F1986801509\u002F":3,"page:\u002Fvue\u002F20200522\u002F1986801509\u002F":4,"alt:\u002Fvue\u002F20200522\u002F1986801509\u002F":3,"prev-next:\u002Fvue\u002F20200522\u002F1986801509\u002F":316,"related:\u002Fvue\u002F20200522\u002F1986801509\u002F":325},"\u002Fen\u002Fvue\u002F2020\u002F05\u002F22\u002Fadd-eslint-to-vue-cli\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":298,"date":299,"description":18,"extension":300,"lang":301,"meta":302,"navigation":303,"path":304,"readingMinutes":305,"seo":306,"standalone":307,"stem":308,"tags":309,"tldr":313,"updated":313,"url":314,"__hash__":315},"content\u002FVue\u002F如何替-VueCli-加入-ESLint.md","如何替 Vue Cli 加入 ESLint","1986801509",{"type":9,"value":10,"toc":291},"minimark",[11,15,19,23,26,43,46,55,58,65,68,74,78,89,99,139,145,162,190,203,209,213,220,236,247,254,271,274,287],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"實際開發專案時我們為了確保程式碼的品質，通常都會加入程式碼風格管理器，也就是 ESLint，但在 Vue Cli 中該如何正確加入呢？",[12,20,22],{"id":21},"vue-cli-加入方式","Vue Cli 加入方式",[16,24,25],{},"其實在官方文件中就有提供一個正確加入的方式，你只需要在該 Vue Cli 專案輸入以下指令",[27,28,33],"pre",{"className":29,"code":30,"language":31,"meta":32,"style":32},"language-cmd shiki shiki-themes github-dark-high-contrast","vue add eslint\n","cmd","",[34,35,36],"code",{"__ignoreMap":32},[37,38,41],"span",{"class":39,"line":40},"line",1,[37,42,30],{},[16,44,45],{},"或是第二種指令輸入方式",[27,47,49],{"className":29,"code":48,"language":31,"meta":32,"style":32},"vue add @vue\u002Fcli-plugin-eslint\n",[34,50,51],{"__ignoreMap":32},[37,52,53],{"class":39,"line":40},[37,54,48],{},[16,56,57],{},"這邊舉例來講我在開發時都是使用 Airbnb 的風格來撰寫(若你對於 JavaScript 還沒有很熟悉我會建議你選擇 Standard，挫折感比較不會那麼重)",[16,59,60],{},[61,62],"img",{"alt":63,"src":64},"Pick an ESLint config","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVue\u002F%E6%88%AA%E5%9C%96%202020-05-22%2023.59.02.png",[16,66,67],{},"通常在「Pick additional lint features」我會兩個都選，你可以只選第一個就好。",[16,69,70],{},[61,71],{"alt":72,"src":73},"Pick additional lint features","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FVue\u002F%E6%88%AA%E5%9C%96%202020-05-23%2000.01.04.png",[12,75,77],{"id":76},"eslint-加入差異","ESLint 加入差異",[16,79,80,81,84,85,88],{},"接下來讓我們看一下使用官方所提供的 ",[34,82,83],{},"vue add eslint"," 跟一般常見的 ",[34,86,87],{},"eslint --init"," 差別在哪裡吧",[16,90,91,92,94,95,98],{},"首先先講講 ",[34,93,83],{}," 的差異，在 ESLint 的撰寫規則中你可以看到 ",[34,96,97],{},"extends"," 底下有這兩行",[27,100,104],{"className":101,"code":102,"language":103,"meta":32,"style":32},"language-js shiki shiki-themes github-dark-high-contrast","extends: [\n  'plugin:vue\u002Fessential',\n  '@vue\u002Fairbnb',\n],\n","js",[34,105,106,115,125,133],{"__ignoreMap":32},[37,107,108,111],{"class":39,"line":40},[37,109,97],{"class":110},"s_sBn",[37,112,114],{"class":113},"sMAXC",": [\n",[37,116,118,122],{"class":39,"line":117},2,[37,119,121],{"class":120},"sTRMh","  'plugin:vue\u002Fessential'",[37,123,124],{"class":113},",\n",[37,126,128,131],{"class":39,"line":127},3,[37,129,130],{"class":120},"  '@vue\u002Fairbnb'",[37,132,124],{"class":113},[37,134,136],{"class":39,"line":135},4,[37,137,138],{"class":113},"],\n",[16,140,141,144],{},[34,142,143],{},"plugin:vue\u002Fessentia"," 這一行我們等等再講，先來講講第二行。",[16,146,147,148,151,152,155,156,158,159,161],{},"我們可以看到 ",[34,149,150],{},"airbnb"," 前面有一個 ",[34,153,154],{},"@vue","，其主要原因在於這是針對 Vue 所客製化的 ESLint，若你不是透過 ",[34,157,83],{}," 加入而是使用 ",[34,160,87],{}," 的話，通常來講你會看到的形式是這樣子",[27,163,165],{"className":101,"code":164,"language":103,"meta":32,"style":32},"extends: [\n  'plugin:vue\u002Fessential',\n  'airbnb-base',\n],\n",[34,166,167,173,179,186],{"__ignoreMap":32},[37,168,169,171],{"class":39,"line":40},[37,170,97],{"class":110},[37,172,114],{"class":113},[37,174,175,177],{"class":39,"line":117},[37,176,121],{"class":120},[37,178,124],{"class":113},[37,180,181,184],{"class":39,"line":127},[37,182,183],{"class":120},"  'airbnb-base'",[37,185,124],{"class":113},[37,187,188],{"class":39,"line":135},[37,189,138],{"class":113},[16,191,192,193,195,196,199,200,202],{},"你會發現第二行會不太一樣，那這兩者差異會在哪裡？簡單來講就是「規則不同」，因此若你是使用 ",[34,194,87],{}," 加入 ESLint 的話，你會發現不管你怎麼修正錯誤永遠都似乎無法修正一樣，最明顯的錯誤就是 ",[34,197,198],{},"Unable to resolve path to module","，而這個錯誤是因為使用 ",[34,201,87],{}," 加入 ESLint 之後他並沒有針對 Vue Cli 客製化一些規則，因此你會有修不完的錯誤。",[16,204,205,206,208],{},"因此在這邊會強烈建議你若要對 Vue Cli 加入 ESLint 規範，請一定要透過 ",[34,207,83],{}," 加入唷。",[12,210,212],{"id":211},"plugin-的-essential","plugin 的 essential",[16,214,215,216,219],{},"這一段 ",[34,217,218],{},"plugin:vue\u002Fessential"," 其實是 Vue 官方所推出的風格規則，主要有分為四種",[221,222,223,227,230,233],"ul",{},[224,225,226],"li",{},"base - 基礎規範",[224,228,229],{},"essential - 預設規範",[224,231,232],{},"strongly-recommended - 推薦規範",[224,234,235],{},"recommended - 最嚴謹的規範",[16,237,238,239,242,243,246],{},"若你想要修改風格規則的話，只需要調整 ",[34,240,241],{},"vue\u002F"," 之後英文即可，例如修改成 ",[34,244,245],{},"plugin:vue\u002Fstrongly-recommended","。",[16,248,249,250,253],{},"但是在這邊我會建議你使用預設規範即可，因為使用 ",[34,251,252],{},"essential"," 風格你就可以達到良好的程式碼品質，所以並不建議你調整成其他的。",[16,255,256,257,264,265,270],{},"詳細的細節規範你可以看",[258,259,263],"a",{"href":260,"rel":261},"https:\u002F\u002Feslint.vuejs.org\u002Frules\u002F",[262],"nofollow","官方文件","、",[258,266,269],{"href":267,"rel":268},"https:\u002F\u002Fcn.vuejs.org\u002Fv2\u002Fstyle-guide\u002Findex.html",[262],"風格指南"," 官方都有一些相當好的範例可以看。",[12,272,273],{"id":273},"參考文獻",[221,275,276,282],{},[224,277,278],{},[258,279,281],{"href":260,"rel":280},[262],"eslint-plugin-vue",[224,283,284],{},[258,285,269],{"href":267,"rel":286},[262],[288,289,290],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(-