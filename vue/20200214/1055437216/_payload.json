[{"data":1,"prerenderedAt":904},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20200214\u002F1055437216\u002F":3,"page:\u002Fvue\u002F20200214\u002F1055437216\u002F":4,"alt:\u002Fvue\u002F20200214\u002F1055437216\u002F":3,"prev-next:\u002Fvue\u002F20200214\u002F1055437216\u002F":881,"related:\u002Fvue\u002F20200214\u002F1055437216\u002F":890},"\u002Fen\u002Fvue\u002F2020\u002F02\u002F14\u002Fone-command-deploy-vue-cli-to-github-pages\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":864,"date":865,"description":18,"extension":866,"lang":867,"meta":868,"navigation":50,"path":869,"readingMinutes":870,"seo":871,"standalone":872,"stem":873,"tags":874,"tldr":878,"updated":878,"url":879,"__hash__":880},"content\u002FVue\u002F一個指令快速部署-VueCli-到-GitHub-Pages.md","一個指令快速部署 Vue Cli 到 GitHub Pages","1055437216",{"type":9,"value":10,"toc":854},"minimark",[11,15,19,22,33,42,51,54,87,94,317,320,331,334,341,350,353,359,363,366,370,376,382,385,388,391,402,408,710,715,726,729,732,735,807,810,833,839,842,850],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"一般來說我們使用 Vue Cli 開發一個作品完畢之後都會需要部署到特定空間來展示作品，舉例來講 GitHub Pages 就是一個，那麼這一篇就來介紹該如何一個指令快速部署吧。",[12,20,21],{"id":21},"範例程式碼",[16,23,24,25,32],{},"這邊將會使用我先前做的一個串接 API 範例作品，也就是「",[26,27,31],"a",{"href":28,"rel":29},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FHexfootMusic",[30],"nofollow","六腳音樂大平台","」",[16,34,35,36,41],{},"這個範例作品是我先前在",[26,37,40],{"href":38,"rel":39},"https:\u002F\u002Fwww.hexschool.com\u002F",[30],"六角學院","的線上問答會所介紹的範例作品，如果你對於 KKBOX OPEN API 非常感興趣的話也歡迎你可以參考這一支 Youtube 影片，這邊我就直接放上影片。",[43,44],"iframe",{"width":45,"height":46,"src":47,"frameBorder":48,"allow":49,"allowFullScreen":50},560,315,"https:\u002F\u002Fwww.youtube.com\u002Fembed\u002FaVVLs2mlf8k","0","accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture",true,[12,52,53],{"id":53},"一鍵部署基礎教學",[16,55,56,57,61,62,65,66,69,70,73,74,78,79,81,82,86],{},"首先我們通常要部署一個專案之前都會先輸入 ",[58,59,60],"code",{},"npm run build","，然後就會打包編譯出 ",[58,63,64],{},"dist"," 這個資料夾，如果你是用原始的方式，例如：",[58,67,68],{},"cd dist"," ... ",[58,71,72],{},"git init"," 次數多了其實也會煩，先前我的",[26,75,77],{"href":76},"\u002Fvue\u002F20190513\u002F948497494\u002F","Vuejs部屬GitHub Pages 教學文章","就是教你這樣做，但是開發時我們通常會很長 ",[58,80,60],{},"，所以接下來就會教如何",[83,84,85],"strong",{},"一個指令部署到 GitHub pages","。",[16,88,89,90,93],{},"首先我們先在專案底下建立一個叫做 ",[58,91,92],{},"deploy.sh"," 的檔案，然後內容是以下",[95,96,101],"pre",{"className":97,"code":98,"language":99,"meta":100,"style":100},"language-sh shiki shiki-themes github-dark-high-contrast","#!\u002Fusr\u002Fbin\u002Fenv sh\n\n# 發生錯誤時執行終止指令\nset -e\n\n# 打包編譯\nnpm run build\n\n# 移動到打包資料夾下，若你有調整的話打包後的資料夾請務必調整\ncd dist\n\n# 部署到自定義網域\n# echo 'www.example.com' > CNAME\n\ngit init\ngit add -A\ngit commit -m 'deploy'\n\n# 部署到 https:\u002F\u002F\u003CUSERNAME>.github.io\n# git push -f git@github.com:\u003CUSERNAME>\u002F\u003CUSERNAME>.github.io.git master\n\n# 部署到 https:\u002F\u002F\u003CUSERNAME>.github.io\u002F\u003CREPO>\n# git push -f git@github.com:\u003CUSERNAME>\u002F\u003CREPO>.git master:gh-pages\n# 以這個專案來講就要改成這樣以下這樣，下面是走 ssh 模式\ngit push -f git@github.com:hsiangfeng\u002FHexfootMusic.git master:gh-pages\n# 除此之外，也可以改走 HTTPS 模式\n# git push -f https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FHexfootMusic.git master:gh-pages\n\ncd -\n","sh","",[58,102,103,112,118,124,134,139,145,159,164,170,179,184,190,196,201,210,221,235,240,246,252,257,263,269,275,292,298,304,309],{"__ignoreMap":100},[104,105,108],"span",{"class":106,"line":107},"line",1,[104,109,111],{"class":110},"sQrFR","#!\u002Fusr\u002Fbin\u002Fenv sh\n",[104,113,115],{"class":106,"line":114},2,[104,116,117],{"emptyLinePlaceholder":50},"\n",[104,119,121],{"class":106,"line":120},3,[104,122,123],{"class":110},"# 發生錯誤時執行終止指令\n",[104,125,127,131],{"class":106,"line":126},4,[104,128,130],{"class":129},"sCcAr","set",[104,132,133],{"class":129}," -e\n",[104,135,137],{"class":106,"line":136},5,[104,138,117],{"emptyLinePlaceholder":50},[104,140,142],{"class":106,"line"