[{"data":1,"prerenderedAt":1530},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20251204\u002F754692240\u002F":3,"page:\u002Fvue\u002F20251204\u002F754692240\u002F":4,"alt:\u002Fvue\u002F20251204\u002F754692240\u002F":3,"prev-next:\u002Fvue\u002F20251204\u002F754692240\u002F":1506,"related:\u002Fvue\u002F20251204\u002F754692240\u002F":1515},"\u002Fen\u002Fvue\u002F2025\u002F12\u002F04\u002Fvue-nuxt-project-folder-structure\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1487,"date":1488,"description":24,"extension":1489,"lang":1490,"meta":1491,"navigation":1200,"path":1492,"readingMinutes":1493,"seo":1494,"standalone":1495,"stem":1496,"tags":1497,"tldr":1503,"updated":1488,"url":1504,"__hash__":1505},"content\u002FVue\u002F思考-Vue-Nuxt-專案架構-如何選擇適合團隊的目錄結構.md","思考 Vue\u002FNuxt 專案架構：如何選擇適合團隊的目錄結構？","754692240",{"type":9,"value":10,"toc":1478},"minimark",[11,18,22,25,28,36,81,84,401,404,477,480,484,491,563,566,578,582,589,592,609,612,740,751,754,848,868,871,976,979,982,986,989,996,1128,1135,1298,1304,1421,1428,1431,1435,1453,1456,1465,1468,1471,1474],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fproject-file-structrue\u002Fvue_nuxt_architecture_cover_1764830335781.png",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"一個專案的目錄結構其實非常的重要，為什麼呢？對於你管理與維護專案來說，良好的結構可以讓你知道什麼東西該放哪、什麼東西該怎麼找，接著搭配 README.md 文件的說明，就可以有效讓其他開發者快速上手你的專案，這也是變相管制程式碼品質的一種方式。",[19,26,27],{"id":27},"專案結構",[12,29,30,31,35],{},"首先，這邊我們先來看一個最基本的 Vue 專案結構，這邊我將會以 ",[32,33,34],"code",{},"npm create vue@latest"," 建立出來的專案為範例，因此相關資訊如下：",[37,38,39,43,46,75,78],"ul",{},[40,41,42],"li",{},"create-vue 版本：3.18.3",[40,44,45],{},"Node.js 版本：22.18.0",[40,47,48,49],{},"包含的功能（這邊全選）：\n",[37,50,51,54,57,60,63,66,69,72],{},[40,52,53],{},"TypeScript",[40,55,56],{},"JSX 支援",[40,58,59],{},"Router（單頁應用程式開發）",[40,61,62],{},"Pinia（狀態管理）",[40,64,65],{},"Vitest（單元測試）",[40,67,68],{},"端對端測試",[40,70,71],{},"ESLint（錯誤預防）",[40,73,74],{},"Prettier（程式碼格式化）",[40,76,77],{},"端對端測試框架：Playwright",[40,79,80],{},"試驗特性：Oxlint",[12,82,83],{},"接著你應該會看到以下專案結構：",[85,86,91],"pre",{"className":87,"code":88,"language":89,"meta":90,"style":90},"language-plaintext shiki shiki-themes github-dark-high-contrast","vue-example\u002F\n├── .vscode\u002F                    # VSCode 編輯器設定\n│   ├── extensions.json\n│   └── settings.json\n├── e2e\u002F                        # E2E 測試（Playwright）\n│   ├── tsconfig.json\n│   └── vue.spec.ts\n├── public\u002F                     # 靜態資源\n│   └── favicon.ico\n├── src\u002F                        # 原始碼目錄\n│   ├── assets\u002F                 # 資源文件\n│   │   ├── base.css\n│   │   ├── logo.svg\n│   │   └── main.css\n│   ├── components\u002F             # Vue 元件\n│   │   ├── __tests__\u002F          # 元件測試\n│   │   │   └── HelloWorld.spec.ts\n│   │   ├── icons\u002F              # icons 元件\n│   │   │   ├── IconCommunity.vue\n│   │   │   ├── IconDocumentation.vue\n│   │   │   ├── IconEcosystem.vue\n│   │   │   ├── IconSupport.vue\n│   │   │   └── IconTooling.vue\n│   │   ├── HelloWorld.vue\n│   │   ├── TheWelcome.vue\n│   │   └── WelcomeItem.vue\n│   ├── router\u002F                 # Vue Router 路由設定\n│   │   └── index.ts\n│   ├── stores\u002F                 # Pinia 狀態管理\n│   │   └── counter.ts\n│   ├── views\u002F                  # 頁面元件\n│   │   ├── AboutView.vue\n│   │   └── HomeView.vue\n│   ├── App.vue                 # 根元件\n│   └── main.ts                 # 應用入口\n├── .editorconfig               # 編輯器設定\n├── .gitattributes              # Git 屬性設定\n├── .gitignore                  # Git 忽略文件\n├── .prettierrc.json            # Prettier 格式化設定\n├── env.d.ts                    # TypeScript 環境類型定義\n├── eslint.config.ts            # ESLint 設定\n├── index.html                  # HTML 入口文件\n├── package.json                # 專案依賴和腳本\n├── playwright.config.ts        # Playwright E2E 測試設定\n├── README.md                   # 專案說明文件\n├── tsconfig.app.json           # TypeScript 設定\n├── tsconfig.json               # 主 TypeScript 設定\n├── tsconfig.node.json          # Node.js TypeScript 設定\n├── tsconfig.vitest.json        # Vitest 測試 TypeScript 設定\n├── vite.config.ts              # Vite 建構工具設定\n└── vitest.config.ts            # Vitest 測試設定\n","plaintext","",[32,92,93,101,107,113,119,125,131,137,143,149,155,161,167,173,179,185,191,197,203,209,215,221,227,233,239,245,251,257,263,269,275,281,287,293,299,305,311,317,323,329,335,341,347,353,359,365,371,377,383,389,395],{"__ignoreMap":90},[94,95,98],"span",{"class":96,"line":97},"line",1,[94,99,100],{},"vue-example\u002F\n",[94,102,104],{"class":96,"line":103},2,[94,105,106],{},"├── .vscode\u002F                    # VSCode 編輯器設定\n",[94,108,110],{"class":96,"line":109},3,[94,111,112],{},"│   ├── extensions.json\n",[94,114,116],{"class":96,"line":115},4,[94,117,118],{},"│   └── settings.json\n",[94,120,122],{"class":96,"line":121},5,[94,123,124],{},"├── e2e\u002F                        # E2E 測試（Playwright）\n",[94,126,128],{"class":96,"line":127},6,[94,129,130],{},"│   ├── tsconfig.json\n",[94,132,134],{"class":96,"line":133},7,[94,135,136],{},"│   └── vue.spec.ts\n",[94,138,140],{"class":96,"line":139},8,[94,141,142],{},"├── public\u002F                     # 靜態資源\n",[94,144,146],{"class":96,"line":145},9,[94,147,148],{},"│   └── favicon.ico\n",[94,150,152],{"class":96,"line":151},10,[94,153,154],{},"├── src\u002F                        # 原始碼目錄\n",[94,156,158],{"class":96,"line":157},11,[94,159,160],{},"│   ├── assets\u002F                 # 資源文件\n",[94,162,164],{"class":96,"line":163},12,[94,165,166],{},"│   │   ├── base.css\n",[94,168,170],{"class":96,"line":169},13,[94,171,172],{},"│   │   ├── logo.svg\n",[94,174,176],{"class":96,"line":175},14,[94,177,178],{},"│   │   └── main.css\n",[94,180,182],{"class":96,"line":181},15,[94,183,184],{},"│   ├── components\u002F             # Vue 元件\n",[94,186,188],{"class":96,"line":187},16,[94,189,190],{},"│   │   ├── __tests__\u002F          # 元件測試\n",[94,192,194],{"class":96,"line":193}