],{"class":1152}," =",[94,1215,1216],{"class":1156}," [\n",[94,1218,1219,1222],{"class":96,"line":133},[94,1220,1221],{"class":1152},"  ...",[94,1223,1224],{"class":1156},"moduleARoutes,\n",[94,1226,1227,1229],{"class":96,"line":139},[94,1228,1221],{"class":1152},[94,1230,1231],{"class":1156},"moduleBRoutes,\n",[94,1233,1234],{"class":96,"line":145},[94,1235,1236],{"class":1146},"  \u002F\u002F 其他全域路由\n",[94,1238,1239],{"class":96,"line":151},[94,1240,1241],{"class":1156},"];\n",[94,1243,1244],{"class":96,"line":157},[94,1245,1201],{"emptyLinePlaceholder":1200},[94,1247,1248,1250,1253,1255,1259],{"class":96,"line":163},[94,1249,1206],{"class":1152},[94,1251,1252],{"class":1209}," router",[94,1254,1213],{"class":1152},[94,1256,1258],{"class":1257},"sj_SG"," createRouter",[94,1260,1261],{"class":1156},"({\n",[94,1263,1264,1267,1270],{"class":96,"line":169},[94,1265,1266],{"class":1156},"  history: ",[94,1268,1269],{"class":1257},"createWebHistory",[94,1271,1272],{"class":1156},"(),\n",[94,1274,1275],{"class":96,"line":175},[94,1276,1277],{"class":1156},"  routes,\n",[94,1279,1280],{"class":96,"line":181},[94,1281,1282],{"class":1156},"});\n",[94,1284,1285],{"class":96,"line":187},[94,1286,1201],{"emptyLinePlaceholder":1200},[94,1288,1289,1292,1295],{"class":96,"line":193},[94,1290,1291],{"class":1152},"export",[94,1293,1294],{"class":1152}," default",[94,1296,1297],{"class":1156}," router;\n",[12,1299,1300,1301,1303],{},"然後 ",[32,1302,1133],{}," 裡面就只需要定義該模組的路由即可：",[85,1305,1307],{"className":1137,"code":1306,"language":1139,"meta":90,"style":90},"\u002F\u002F src\u002Fmodules\u002FmoduleA\u002Frouter\u002Findex.ts\nimport { RouteRecordRaw } from 'vue-router';\n\nconst moduleARoutes: RouteRecordRaw[] = [\n  {\n    path: '\u002F',\n    name: 'ModuleAHome',\n    component: () => import('..\u002Fcomponents\u002FModuleAHome.vue'),\n  }\n]\nexport default moduleARoutes;\n",[32,1308,1309,1314,1327,1331,1353,1358,1369,1379,1402,1407,1412],{"__ignoreMap":90},[94,1310,1311],{"class":96,"line":97},[94,1312,1313],{"class":1146},"\u002F\u002F src\u002Fmodules\u002FmoduleA\u002Frouter\u002Findex.ts\n",[94,1315,1316,1318,1321,1323,1325],{"class":96,"line":103},[94,1317,1153],{"class":1152},[94,1319,1320],{"class":1156}," { RouteRecordRaw } ",[94,1322,1160],{"class":1152},[94,1324,1164],{"class":1163},[94,1326,1167],{"class":1156},[94,1328,1329],{"class":96,"line":109},[94,1330,1201],{"emptyLinePlaceholder":1200},[94,1332,1333,1335,1338,1341,1345,1348,1351],{"class":96,"line":115},[94,1334,1206],{"class":1152},[94,1336,1337],{"class":1209}," moduleARoutes",[94,1339,1340],{"class":1152},":",[94,1342,1344],{"class":1343},"s_sBn"," RouteRecordRaw",[94,1346,1347],{"class":1156},"[] ",[94,1349,1350],{"class":1152},"=",[94,1352,1216],{"class":1156},[94,1354,1355],{"class":96,"line":121},[94,1356,1357],{"class":1156},"  {\n",[94,1359,1360,1363,1366],{"class":96,"line":127},[94,1361,1362],{"class":1156},"    path: ",[94,1364,1365],{"class":1163},"'\u002F'",[94,1367,1368],{"class":1156},",\n",[94,1370,1371,1374,1377],{"class":96,"line":133},[94,1372,1373],{"class":1156},"    name: ",[94,1375,1376],{"class":1163},"'ModuleAHome'",[94,1378,1368],{"class":1156},[94,1380,1381,1384,1387,1390,1393,1396,1399],{"class":96,"line":139},[94,1382,1383],{"class":1257},"    component",[94,1385,1386],{"class":1156},": () ",[94,1388,1389],{"class":1152},"=>",[94,1391,1392],{"class":1152}," import",[94,1394,1395],{"class":1156},"(",[94,1397,1398],{"class":1163},"'..\u002Fcomponents\u002FModuleAHome.vue'",[94,1400,1401],{"class":1156},"),\n",[94,1403,1404],{"class":96,"line":145},[94,1405,1406],{"class":1156},"  }\n",[94,1408,1409],{"class":96,"line":151},[94,1410,1411],{"class":1156},"]\n",[94,1413,1414,1416,1418],{"class":96,"line":157},[94,1415,1291],{"class":1152},[94,1417,1294],{"class":1152},[94,1419,1420],{"class":1156}," moduleARoutes;\n",[12,1422,1423,1424,1427],{},"這時候你應該發現一件事情了，當有其他專案有相同模組需求的時候，你只需要把 ",[32,1425,1426],{},"modules\u002FmoduleA\u002F"," 這個資料夾整個搬過去就可以了，完全不需要擔心其他模組會影響到這個模組。",[12,1429,1430],{},"模組化結構最大問題就是巢狀過深，當模組越來越多的時候，專案結構會變得非常複雜，這時候就需要靠良好的命名規則來維持專案的可讀性。",[19,1432,1434],{"id":1433},"nuxt-呢","Nuxt 呢？",[12,1436,1437,1438,657,1441,657,1443,657,1446,657,1449,1452],{},"其實這邊算是沒特別講到 Nuxt 的專案結構，因為 Nuxt 本身就有一套自己的專案結構，像是 ",[32,1439,1440],{},"pages\u002F",[32,1442,853],{},[32,1444,1445],{},"layouts\u002F",[32,1447,1448],{},"plugins\u002F",[32,1450,1451],{},"middleware\u002F"," 等等，這些都是 Nuxt 幫你規劃好的。",[12,1454,1455],{},"除此之外，也有 Auto Import 的功能，讓你不需要手動匯入元件、組件、插件等等，這樣可以大幅減少你在專案結構上的負擔。",[12,1457,1458,1459,1464],{},"當然你也可以使用 Nuxt 所提供的『",[744,1460,1463],{"href":1461,"rel":1462},"https:\u002F\u002Fnuxt.com\u002Fdocs\u002F4.x\u002Fgetting-started\u002Flayers",[748],"Nuxt Layers","』功能來達成模組化結構，這樣就可以讓你在 Nuxt 專案中使用模組化結構。",[19,1466,1467],{"id":1467},"結論",[12,1469,1470],{},"其實不論選擇哪一個專案結構，最重要的還是要符合你的專案需求，像是專案的規模、團隊人數、開發流程等等，這些都是需要考量的因素，並不是因為你喜歡某一種結構就一定要使用，如果團隊對於 Modular Structure 不熟悉的話，強行使用反而會讓專案變得更複雜。",[12,1472,1473],{},"當然這些專案結構並不是絕對的標準，你可以根據你的需求進行調整，像是結合 Atomic Structure 跟 Modular Structure，或是根據功能來劃分資料夾，又或者自己變體出自己一套適合團隊的專案結構，這些都是可以的。",[1475,1476,1477],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}",{"title":90,"searchDepth":103,"depth":103,"links":1479},[1480,1481,1482,1483,1484,1485,1486],{"id":21,"depth":103,"text":21},{"id":27,"depth":103,"text":27},{"id":482,"depth":103,"text":483},{"id":580,"depth":103,"text":581},{"id":984,"depth":103,"text":985},{"id":1433,"depth":103,"text":1434},{"id":1467,"depth":103,"text":1467},"Vue","2025-12-04 11:40:56","md","zh-Hant",{},"\u002Fvue\u002Fvue-nuxt","6",{"title":6,"description":24},false,"Vue\u002F思考-Vue-Nuxt-專案架構-如何選擇適合團隊的目錄結構",[1487,1498,1499,1500,1501,1502],"Nuxt","專案架構","Flat Structure","Atomic Structure","Modular Structure",null,"\u002Fvue\u002F20251204\u002F754692240\u002F","7jG3bzqpyvGHPl_1NTD_yyeOp6cU8V-uzBNwr0rneWw",{"newer":1507,"older":1511},{"url":1508,"title":1509,"date":1510},"\u002Fjavascript\u002F20251205\u002F3653220664\u002F","什麼是 JavaScript 的 Generator Functions (function*)？","2025-12-05 13:40:31",{"url":1512,"title":1513,"date":1514},"\u002Fai\u002F20251202\u002F797714546\u002F","淺談 AI Vibe Coding 當今主流的 BDD 與 SDD","2025-12-02 22:48:14",[1516,1520,1525],{"url":1517,"title":1518,"date":1519,"readingMinutes":1493},"\u002Fvue\u002F20251106\u002F1172686218\u002F","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","2025-11-06 13:45:34",{"url":1521,"title":1522,"date":1523,"readingMinutes":1524},"\u002Fvue\u002F20250216\u002F532019259\u002F","不同於 ref 的 shallowRef 宣告","2025-02-16 19:32:58","4",{"url":1526,"title":1527,"date":1528,"readingMinutes":1529},"\u002Fvue\u002F20240313\u002F2699146388\u002F","來聊聊 Vue3 Composition API 變數宣告的另一種設計","2024-03-13 11:17:37","5",1784012815634]