[{"data":1,"prerenderedAt":1536},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20251106\u002F1172686218\u002F":3,"page:\u002Fvue\u002F20251106\u002F1172686218\u002F":4,"alt:\u002Fvue\u002F20251106\u002F1172686218\u002F":3,"prev-next:\u002Fvue\u002F20251106\u002F1172686218\u002F":1512,"related:\u002Fvue\u002F20251106\u002F1172686218\u002F":1521},"\u002Fen\u002Fvue\u002F2025\u002F11\u002F06\u002Fvue-sfc-spec-block-for-ai-development\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1493,"date":1494,"description":1495,"extension":1496,"lang":1497,"meta":1498,"navigation":171,"path":1499,"readingMinutes":1500,"seo":1501,"standalone":1502,"stem":1503,"tags":1504,"tldr":1508,"updated":1509,"url":1510,"__hash__":1511},"content\u002FVue\u002F用-spec-lang-md-標籤在-Vue-中舒服的使用-SFC-搭配-AI-開發.md","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","1172686218",{"type":9,"value":10,"toc":1481},"minimark",[11,19,23,31,35,38,51,54,62,65,68,71,88,91,94,97,100,106,120,362,368,374,385,388,644,647,703,709,712,1009,1012,1184,1190,1193,1213,1220,1225,1240,1330,1336,1340,1343,1356,1362,1369,1372,1375,1378,1398,1404,1413,1416,1431,1434,1440,1443,1446,1449,1478],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"用 \u003Cspec lang=\"md\"> 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fai-spec-tag\u002FGemini_Generated_Image_85e8id85e8id85e8_1280x714.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25,26,30],{},"許多開發者都會搭配著 AI 工具（Claude Code、Gemini、Copilot 等）來協助撰寫程式碼，而在 Vue 的單檔元件（Single File Component, SFC）中，常常會遇到一些困擾，所以這邊就來分享一個不同的做法，也就是自訂一個 ",[27,28,29],"code",{},"\u003Cspec lang=\"md\">"," 標籤，來讓我們能夠在 SFC 中更舒服地使用 AI 工具來開發。",[20,32,34],{"id":33},"ai-開發模式","AI 開發模式",[12,36,37],{},"現在使用 AI 開發的模式基本上有這幾種：",[39,40,41,45,48],"ul",{},[42,43,44],"li",{},"SDD（Specification Driven Development，規格驅動開發）：先撰寫規格文件，然後讓 AI 根據規格文件來產生程式碼。",[42,46,47],{},"BDD（Behavior Driven Development，行為驅動開發）：先撰寫行為描述，然後讓 AI 根據行為描述來產生程式碼。",[42,49,50],{},"TDD（Test Driven Development，測試驅動開發）：先撰寫測試案例，然後讓 AI 根據測試案例來產生程式碼。",[12,52,53],{},"其中 SDD 是最多人使用的模式，只要可以把規格描述清楚，那麼 AI 就能夠幫助我們產生出符合需求的程式碼，但這邊我們不深入探討怎麼使用跟寫 SDD。",[12,55,56,57,61],{},"但問題來了，什麼叫做 ",[58,59,60],"strong",{},"「把規格描述清楚」"," 呢？",[12,63,64],{},"我認為這件事情很有趣，我們光描述自己的問題就有一定的難度，更不用說 AI 只會依照我們講的內容、資訊去產出程式碼了，更不用說沒有一個標準可以去衡量我們的描述是否足夠清楚、應該要包含哪些內容。",[12,66,67],{},"通常我們再請 AI 開始撰寫程式碼之前，都會請它先初步的專案分析，並產生一個專案規格文件，下一次我們開啟專案請 AI 撰寫程式碼時，就可以直接把這份規格文件貼給 AI，讓它根據這份文件來撰寫程式碼。",[12,69,70],{},"所以就有可能會變成有這些文件：",[39,72,73,76,79,82,85],{},[42,74,75],{},"*.spec.md：專案規格文件",[42,77,78],{},"*.test.md：測試案例文件",[42,80,81],{},"*.guide.md：開發指南文件",[42,83,84],{},"*.task.md：任務清單文件",[42,86,87],{},"README.md：專案說明文件\n...",[12,89,90],{},"等等之類的文件，其中可能還會把程式碼拆出來說明。",[12,92,93],{},"可想而知，開發文件會越來越多，而且我們還要不斷的更新這些文件，為了讓它們能夠跟程式碼\u002F需求保持一致。",[12,95,96],{},"雖然你可能會認為「反正這些文件都是給 AI 用的，沒關係啦」，但事實上這些文件也會影響到我們開發的效率，因為我們也需要花時間去維護這些文件，你不可能不看這些文件就直接請 AI 幫你寫程式碼。",[12,98,99],{},"更不用說，AI 的 Context Window（上下文視窗）是有限的。",[20,101,103,104],{"id":102},"在-vue-sfc-中使用-spec-langmd","在 Vue SFC 中使用 ",[27,105,29],{},[12,107,108,109,112,113,112,116,119],{},"Vue 的 SFC 中，我們知道有 ",[27,110,111],{},"\u003Ctemplate>","、",[27,114,115],{},"\u003Cscript>",[27,117,118],{},"\u003Cstyle>"," 等標籤來分別撰寫模板、邏輯和樣式，但其實 Vue 也支援自訂區塊（Custom Blocks），我們可以利用這個特性來加入我們的規格文件，導入之後類似於這樣：",[121,122,127],"pre",{"className":123,"code":124,"language":125,"meta":126,"style":126},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript setup>\nimport { ref } from 'vue'\n\nconst message = ref('Hello World')\n\u003C\u002Fscript>\n\n\u003Ctemplate>\n  \u003Cdiv>{{ message }}\u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\u003Cstyle scoped>\ndiv {\n  color: blue;\n}\n\u003C\u002Fstyle>\n\n\u003Cspec lang=\"md\">\n- 這是一個簡單的 Vue 元件，顯示一個藍色的 \"Hello World\" 訊息。\n- 使用了 Vue 3 的 Composition API 來定義響應式變數 `message`。\n- 樣式使用了 scoped，確保樣式只作用於此元件。\n- `message` 的文字顏色設定為藍色。\n\u003C\u002Fspec>\n","html","",[27,128,129,149,166,173,198,208,213,223,239,248,253,266,274,289,295,304,309,329,335,341,347,353],{"__ignoreMap":126},[130,131,134,138,142,146],"span",{"class":132,"line":133},"line",1,[130,135,137],{"class":136},"sMAXC","\u003C",[130,139,141],{"class":140},"sKpQp","script",[130,143,145],{"class":144},"sCcAr"," setup",[130,147,148],{"class":136},">\n",[130,150,152,156,159,162],{"class":132,"line":151},2,[130,153,155],{"class":154},"sWyjQ","import",[130,157,158],{"class":136}," { ref } ",[130,160,161],{"class":154},"from",[130,163,165],{"class":164},"sTRMh"," 'vue'\n",[130,167,169],{"class":132,"line":168},3,[130,170,172],{"emptyLinePlaceholder":171},true,"\n",[130,174,176,179,182,185,189,192,195],{"class":132,"line":175},4,[130,177,178],{"class":154},"const",[130,180,181],{"class":144}," message",[130,183,184],{"class":154}," =",[130,186,188],{"class":187},"sj_SG"," ref",[130,190,191],{"class":136},"(",[130,193,194],{"class":164},"'Hello World'",[130,196,197],{"class":136},")\n",[130,199,201,204,206],{"class":132,"line":200},5,[130,202,203],{"class":136},"\u003C\u002F",[130,205,141],{"class":140},[130,207,148],{"class":136},[130,209,211],{"class":132,"line":210},6,[130,212,172],{"emptyLinePlaceholder":171},[130,214,216,218,221],{"class":132,"line":215},7,[130,217,137],{"class":136},[130,219,220],{"class":140},"template",[130,222,148],{"class":136},[130,224,226,229,232,235,237],{"class":132,"line":225},8,[130,227,228],{"class":136},"  \u003C",[130,230,231],{"class":140},"div",[130,233,234],{"class":136},">{{ message }}\u003C\u002F",[130,236,231],{"class":140},[130,238,148],{"class":136},[130,240,242,244,246],{"class":132,"line":241},9,[130,243,203],{"class":136},[130,245,220],{"class":140},[130,247,148],{"class":136},[130,249,251],{"class":132,"line":250},10,[130,252,172],{"emptyLinePlaceholder":171},[130,254,256,258,261,264],{"class":132,"line":255},11,[130,257,137],{"class":136},[130,259,260],{"class":140},"style",[130,262,263],{"class":144}," scoped",[130,265,148],{"class":136},[130,267,269,271],{"class":132,"line":268},12,[130,270,231],{"class":140},[130,272,273],{"class":136}," {\n",[130,275,277,280,283,286],{"class":132,"line":276},13,[130,278,279],{"class":144},"  color",[130,281,282],{"class":136},": ",[130,284,285],{"class":144},"blue",[130,287,288],{"class":136},";\n",[130,290,292],{"class":132,"line":291},14,[130,293,294],{"class":136},"}\n",[130,296,298,300,302],{"class":132,"line":297},15,[130,299,203],{"class":136},[130,301,260],{"class":140},[130,303,148],{"class":136},[130,305,307],{"class":132,"line":306},16,[130,308,172],{"emptyLinePlaceholder":171},[130,310,312,314,318,321,324,327],{"class":132,"line":311},17,[130,313,137],{"class":136},[130,315,317],{"class":316},"szH_Z","spec",[130,319,320],{"class":144}," lang",[130,322,323],{"class":136},"=",[130,325,326],{"class":164},"\"md\"",[130,328,148],{"class":136},[130,330,332],{"class":132,"line":331},18,[130,333,334],{"class":136},"- 這是一個簡單的 Vue 元件，顯示一個藍色的 \"Hello World\" 訊息。\n",[130,336,338],{"class":132,"line":337},19,[130,339,340],{"class":136},"- 使用了 Vue 3 的 Composition API 來定義響應式變數 `message`。\n",[130,342,344],{"class":132,"line":343},20,[130,345,346],{"class":136},"- 樣式使用了 scoped，確保樣式只作用於此元件。\n",[130,348,350],{"class":132,"line":349},21,[130,351,352],{"class":136},"- `message` 的文字顏色設定為藍色。\n",[130,354,356,358,360],{"class":132,"line":355},22,[130,357,203],{"class":136},[130,359,317],{"class":316},[130,361,148],{"class":136},[12,363,364],{},[15,365],{"alt":366,"src":367},"修改前","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fvue-spec-plugin\u002F20251106142007.png",[12,369,370],{},[15,371],{"alt":372,"src":373},"修改後","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fvue-spec-plugin\u002F20251106142014.png",[12,375,376,377,384],{},"那該怎麼做到這件事情呢？其實官方文件中有提到自訂區塊的使用方式，可以參考這篇文章：",[378,379,383],"a",{"href":380,"rel":381},"https:\u002F\u002Fvuejs.org\u002Fguide\u002Fscaling-up\u002Ftooling.html#sfc-custom-block-integrations",[382],"nofollow","SFC Custom Block Integrations","。",[12,386,387],{},"其中文章中，就有舉例 i18n 的自訂區塊：",[121,389,393],{"className":390,"code":391,"language":392,"meta":126,"style":126},"language-js shiki shiki-themes github-dark-high-contrast","import vue from '@vitejs\u002Fplugin-vue'\nimport yaml from 'js-yaml'\n\nconst vueI18nPlugin = {\n  name: 'vue-i18n',\n  transform(code, id) {\n    \u002F\u002F if .vue file don't have \u003Ci18n> block, just return\n    if (!\u002Fvue&type=i18n\u002F.test(id)) {\n      return\n    }\n    \u002F\u002F parse yaml\n    if (\u002F\\.ya?ml$\u002F.test(id)) {\n      code = JSON.stringify(yaml.load(code.trim()))\n    }\n    \u002F\u002F mount the value on the i18n property of the component instance\n    return `export default Comp => {\n      Comp.i18n = ${code}\n    }`\n  },\n}\n\nexport default {\n  plugins: [vue(), vueI18nPlugin],\n}\n","js",[27,394,395,407,419,423,434,445,464,470,493,498,503,508,541,571,575,580,588,597,602,607,611,615,625,639],{"__ignoreMap":126},[130,396,397,399,402,404],{"class":132,"line":133},[130,398,155],{"class":154},[130,400,401],{"class":136}," vue ",[130,403,161],{"class":154},[130,405,406],{"class":164}," '@vitejs\u002Fplugin-vue'\n",[130,408,409,411,414,416],{"class":132,"line":151},[130,410,155],{"class":154},[130,412,413],{"class":136}," yaml ",[130,415,161],{"class":154},[130,417,418],{"class":164}," 'js-yaml'\n",[130,420,421],{"class":132,"line":168},[130,422,172],{"emptyLinePlaceholder":171},[130,424,425,427,430,432],{"class":132,"line":175},[130,426,178],{"class":154},[130,428,429],{"class":144}," vueI18nPlugin",[130,431,184],{"class":154},[130,433,273],{"class":136},[130,435,436,439,442],{"class":132,"line":200},[130,437,438],{"class":136},"  name: ",[130,440,441],{"class":164},"'vue-i18n'",[130,443,444],{"class":136},",\n",[130,446,447,450,452,455,458,461],{"class":132,"line":210},[130,448,449],{"class":187},"  transform",[130,451,191],{"class":136},[130,453,27],{"class":454},"s_sBn",[130,456,457],{"class":136},", ",[130,459,460],{"class":454},"id",[130,462,463],{"class":136},") {\n",[130,