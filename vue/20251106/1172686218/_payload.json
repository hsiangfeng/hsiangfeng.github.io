BDC4CC}html pre.shiki code .sIdya, html code.shiki .sIdya{--shiki-light:#22863A;--shiki-light-font-weight:bold;--shiki-default:#22863A;--shiki-default-font-weight:bold;--shiki-dark:#72F088;--shiki-dark-font-weight:bold}html pre.shiki code .sTzn1, html code.shiki .sTzn1{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#FFB757}html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}",{"title":126,"searchDepth":151,"depth":151,"links":1485},[1486,1487,1488,1492,1493,1494,1495],{"id":22,"depth":151,"text":22},{"id":33,"depth":151,"text":34},{"id":102,"depth":151,"text":1489,"children":1490},"在 Vue SFC 中使用 \u003Cspec lang=\"md\">",[1491],{"id":1225,"depth":168,"text":1226},{"id":1341,"depth":151,"text":1342},{"id":1377,"depth":151,"text":1377},{"id":1436,"depth":151,"text":1436},{"id":1451,"depth":151,"text":1451},"Vue","2025-11-06 13:45:34","許多開發者都會搭配著 AI 工具（Claude Code、Gemini、Copilot 等）來協助撰寫程式碼，而在 Vue 的單檔元件（Single File Component, SFC）中，常常會遇到一些困擾，所以這邊就來分享一個不同的做法，也就是自訂一個 &lt;spec lang=\"md\"&gt; 標籤，來讓我們能夠在 SFC 中更舒服地使用 AI 工具來開發。","md","zh-Hant",{},"\u002Fvue\u002Fspec-lang-md-vue-sfc-ai","6",{"title":6,"description":1498},false,"Vue\u002F用-spec-lang-md-標籤在-Vue-中舒服的使用-SFC-搭配-AI-開發",[1496,1508,1509,1510],"SFC","AI 開發","規格驅動開發",null,"2026-04-23 13:45:34","\u002Fvue\u002F20251106\u002F1172686218\u002F","DDa-OTbT9BmorQ0feGaMDs9Mc0IL5shAwqwjpNyKhoM",{"newer":1516,"older":1520},{"url":1517,"title":1518,"date":1519},"\u002Fai\u002F20251112\u002F978259833\u002F","生成式人工智慧與機器學習導論（2） - AI Agent 背後的關鍵技術 Context Engineering","2025-11-12 00:51:29",{"url":1521,"title":1522,"date":1523},"\u002Fai\u002F20251102\u002F2069630219\u002F","生成式人工智慧與機器學習導論（1） - 其實都是文字接龍","2025-11-02 04:39:25",[1525,1529,1534],{"url":1526,"title":1527,"date":1528,"readingMinutes":1503},"\u002Fvue\u002F20251204\u002F754692240\u002F","思考 Vue\u002FNuxt 專案架構：如何選擇適合團隊的目錄結構？","2025-12-04 11:40:56",{"url":1530,"title":1531,"date":1532,"readingMinutes":1533},"\u002Fvue\u002F20250216\u002F532019259\u002F","不同於 ref 的 shallowRef 宣告","2025-02-16 19:32:58","4",{"url":1535,"title":1536,"date":1537,"readingMinutes":1538},"\u002Fvue\u002F20240313\u002F2699146388\u002F","來聊聊 Vue3 Composition API 變數宣告的另一種設計","2024-03-13 11:17:37","5",1784087387754]