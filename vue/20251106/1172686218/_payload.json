[{"data":1,"prerenderedAt":1539},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20251106\u002F1172686218\u002F":3,"page:\u002Fvue\u002F20251106\u002F1172686218\u002F":4,"alt:\u002Fvue\u002F20251106\u002F1172686218\u002F":3,"prev-next:\u002Fvue\u002F20251106\u002F1172686218\u002F":1515,"related:\u002Fvue\u002F20251106\u002F1172686218\u002F":1524},"\u002Fen\u002Fvue\u002F2025\u002F11\u002F06\u002Fvue-sfc-spec-block-for-ai-development\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1496,"date":1497,"description":1498,"extension":1499,"lang":1500,"meta":1501,"navigation":171,"path":1502,"readingMinutes":1503,"seo":1504,"standalone":1505,"stem":1506,"tags":1507,"tldr":1511,"updated":1512,"url":1513,"__hash__":1514},"content\u002FVue\u002F用-spec-lang-md-標籤在-Vue-中舒服的使用-SFC-搭配-AI-開發.md","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","1172686218",{"type":9,"value":10,"toc":1484},"minimark",[11,19,23,31,35,38,51,54,62,65,68,71,88,91,94,97,100,106,120,363,369,375,386,389,646,649,705,711,714,1011,1014,1186,1192,1195,1215,1222,1227,1242,1333,1339,1343,1346,1359,1365,1372,1375,1378,1381,1401,1407,1416,1419,1434,1437,1443,1446,1449,1452,1481],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"用 \u003Cspec lang=\"md\"> 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fai-spec-tag\u002FGemini_Generated_Image_85e8id85e8id85e8_1280x714.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25,26,30],{},"許多開發者都會搭配著 AI 工具（Claude Code、Gemini、Copilot 等）來協助撰寫程式碼，而在 Vue 的單檔元件（Single File Component, SFC）中，常常會遇到一些困擾，所以這邊就來分享一個不同的做法，也就是自訂一個 ",[27,28,29],"code",{},"\u003Cspec lang=\"md\">"," 標籤，來讓我們能夠在 SFC 中更舒服地使用 AI 工具來開發。",[20,32,34],{"id":33},"ai-開發模式","AI 開發模式",[12,36,37],{},"現在使用 AI 開發的模式基本上有這幾種：",[39,40,41,45,48],"ul",{},[42,43,44],"li",{},"SDD（Specification Driven Development，規格驅動開發）：先撰寫規格文件，然後讓 AI 根據規格文件來產生程式碼。",[42,46,47],{},"BDD（Behavior Driven Development，行為驅動開發）：先撰寫行為描述，然後讓 AI 根據行為描述來產生程式碼。",[42,49,50],{},"TDD（Test Driven Development，測試驅動開發）：先撰寫測試案例，然後讓 AI 根據測試案例來產生程式碼。",[12,52,53],{},"其中 SDD 是最多人使用的模式，只要可以把規格描述清楚，那麼 AI 就能夠幫助我們產生出符合需求的程式碼，但這邊我們不深入探討怎麼使用跟寫 SDD。",[12,55,56,57,61],{},"但問題來了，什麼叫做 ",[58,59,60],"strong",{},"「把規格描述清楚」"," 呢？",[12,63,64],{},"我認為這件事情很有趣，我們光描述自己的問題就有一定的難度，更不用說 AI 只會依照我們講的內容、資訊去產出程式碼了，更不用說沒有一個標準可以去衡量我們的描述是否足夠清楚、應該要包含哪些內容。",[12,66,67],{},"通常我們再請 AI 開始撰寫程式碼之前，都會請它先初步的專案分析，並產生一個專案規格文件，下一次我們開啟專案請 AI 撰寫程式碼時，就可以直接把這份規格文件貼給 AI，讓它根據這份文件來撰寫程式碼。",[12,69,70],{},"所以就有可能會變成有這些文件：",[39,72,73,76,79,82,85],{},[42,74,75],{},"*.spec.md：專案規格文件",[42,77,78],{},"*.test.md：測試案例文件",[42,80,81],{},"*.guide.md：開發指南文件",[42,83,84],{},"*.task.md：任務清單文件",[42,86,87],{},"README.md：專案說明文件\n...",[12,89,90],{},"等等之類的文件，其中可能還會把程式碼拆出來說明。",[12,92,93],{},"可想而知，開發文件會越來越多，而且我們還要不斷的更新這些文件，為了讓它們能夠跟程式碼\u002F需求保持一致。",[12,95,96],{},"雖然你可能會認為「反正這些文件都是給 AI 用的，沒關係啦」，但事實上這些文件也會影響到我們開發的效率，因為我們也需要花時間去維護這些文件，你不可能不看這些文件就直接請 AI 幫你寫程式碼。",[12,98,99],{},"更不用說，AI 的 Context Window（上下文視窗）是有限的。",[20,101,103,104],{"id":102},"在-vue-sfc-中使用-spec-langmd","在 Vue SFC 中使用 ",[27,105,29],{},[12,107,108,109,112,113,112,116,119],{},"Vue 的 SFC 中，我們知道有 ",[27,110,111],{},"\u003Ctemplate>","、",[27,114,115],{},"\u003Cscript>",[27,117,118],{},"\u003Cstyle>"," 等標籤來分別撰寫模板、邏輯和樣式，但其實 Vue 也支援自訂區塊（Custom Blocks），我們可以利用這個特性來加入我們的規格文件，導入之後類似於這樣：",[121,122,127],"pre",{"className":123,"code":124,"language":125,"meta":126,"style":126},"language-html shiki shiki-themes github-light github-light github-dark-high-contrast","\u003Cscript setup>\nimport { ref } from 'vue'\n\nconst message = ref('Hello World')\n\u003C\u002Fscript>\n\n\u003Ctemplate>\n  \u003Cdiv>{{ message }}\u003C\u002Fdiv>\n\u003C\u002Ftemplate>\n\n\u003Cstyle scoped>\ndiv {\n  color: blue;\n}\n\u003C\u002Fstyle>\n\n\u003Cspec lang=\"md\">\n- 這是一個簡單的 Vue 元件，顯示一個藍色的 \"Hello World\" 訊息。\n- 使用了 Vue 3 的 Composition API 來定義響應式變數 `message`。\n- 樣式使用了 scoped，確保樣式只作用於此元件。\n- `message` 的文字顏色設定為藍色。\n\u003C\u002Fspec>\n","html","",[27,128,129,149,166,173,199,209,214,224,240,249,254,267,275,290,296,305,310,330,336,342,348,354],{"__ignoreMap":126},[130,131,134,138,142,146],"span",{"class":132,"line":133},"line",1,[130,135,137],{"class":136},"s8XSl","\u003C",[130,139,141],{"class":140},"syv7_","script",[130,143,145],{"class":144},"sK3KL"," setup",[130,147,148],{"class":136},">\n",[130,150,152,156,159,162],{"class":132,"line":151},2,[130,153,155],{"class":154},"sOudu","import",[130,157,158],{"class":136}," { ref } ",[130,160,161],{"class":154},"from",[130,163,165],{"class":164},"sWayO"," 'vue'\n",[130,167,169],{"class":132,"line":168},3,[130,170,172],{"emptyLinePlaceholder":171},true,"\n",[130,174,176,179,183,186,190,193,196],{"class":132,"line":175},4,[130,177,178],{"class":154},"const",[130,180,182],{"class":181},"stw71"," message",[130,184,185],{"class":154}," =",[130,187,189],{"class":188},"scAaK"," ref",[130,191,192],{"class":136},"(",[130,194,195],{"class":164},"'Hello World'",[130,197,198],{"class":136},")\n",[130,200,202,205,207],{"class":132,"line":201},5,[130,203,204],{"class":136},"\u003C\u002F",[130,206,141],{"class":140},[130,208,148],{"class":136},[130,210,212],{"class":132,"line":211},6,[130,213,172],{"emptyLinePlaceholder":171},[130,215,217,219,222],{"class":132,"line":216},7,[130,218,137],{"class":136},[130,220,221],{"class":140},"template",[130,223,148],{"class":136},[130,225,227,230,233,236,238],{"class":132,"line":226},8,[130,228,229],{"class":136},"  \u003C",[130,231,232],{"class":140},"div",[130,234,235],{"class":136},">{{ message }}\u003C\u002F",[130,237,232],{"class":140},[130,239,148],{"class":136},[130,241,243,245,247],{"class":132,"line":242},9,[130,244,204],{"class":136},[130,246,221],{"class":140},[130,248,148],{"class":136},[130,250,252],{"class":132,"line":251},10,[130,253,172],{"emptyLinePlaceholder":171},[130,255,257,259,262,265],{"class":132,"line":256},11,[130,258,137],{"class":136},[130,260,261],{"class":140},"style",[130,263,264],{"class":144}," scoped",[130,266,148],{"class":136},[130,268,270,272],{"class":132,"line":269},12,[130,271,232],{"class":140},[130,273,274],{"class":136}," {\n",[130,276,278,281,284,287],{"class":132,"line":277},13,[130,279,280],{"class":181},"  color",[130,282,283],{"class":136},": ",[130,285,286],{"class":181},"blue",[130,288,289],{"class":136},";\n",[130,291,293],{"class":132,"line":292},14,[130,294,295],{"class":136},"}\n",[130,297,299,301,303],{"class":132,"line":298},15,[130,300,204],{"class":136},[130,302,261],{"class":140},[130,304,148],{"class":136},[130,306,308],{"class":132,"line":307},16,[130,309,172],{"emptyLinePlaceholder":171},[130,311,313,315,319,322,325,328],{"class":132,"line":312},17,[130,314,137],{"class":136},[130,316,318],{"class":317},"s37k-","spec",[130,320,321],{"class":144}," lang",[130,323,324],{"class":136},"=",[130,326,327],{"class":164},"\"md\"",[130,329,148],{"class":136},[130,331,333],{"class":132,"line":332},18,[130,334,335],{"class":136},"- 這是一個簡單的 Vue 元件，顯示一個藍色的 \"Hello World\" 訊息。\n",[130,337,339],{"class":132,"line":338},19,[130,340,341],{"class":136},"- 使用了 Vue 3 的 Composition API 來定義響應式變數 `message`。\n",[130,343,345],{"class":132,"line":344},20,[130,346,347],{"class":136},"- 樣式使用了 scoped，確保樣式只作用於此元件。\n",[130,349,351],{"class":132,"line":350},21,[130,352,353],{"class":136},"- `message` 的文字顏色設定為藍色。\n",[130,355,357,359,361],{"class":132,"line":356},22,[130,358,204],{"class":136},[130,360,318],{"class":317},[130,362,148],{"class":136},[12,364,365],{},[15,366],{"alt":367,"src":368},"修改前","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fvue-spec-plugin\u002F20251106142007.png",[12,370,371],{},[15,372],{"alt":373,"src":374},"修改後","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fvue\u002Fvue-spec-plugin\u002F20251106142014.png",[12,376,377,378,385],{},"那該怎麼做到這件事情呢？其實官方文件中有提到自訂區塊的使用方式，可以參考這篇文章：",[379,380,384],"a",{"href":381,"rel":382},"https:\u002F\u002Fvuejs.org\u002Fguide\u002Fscaling-up\u002Ftooling.html#sfc-custom-block-integrations",[383],"nofollow","SFC Custom Block Integrations","。",[12,387,388],{},"其中文章中，就有舉例 i18n 的自訂區塊：",[121,390,394],{"className":391,"code":392,"language":393,"meta":126,"style":126},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","import vue from '@vitejs\u002Fplugin-vue'\nimport yaml from 'js-yaml'\n\nconst vueI18nPlugin = {\n  name: 'vue-i18n',\n  transform(code, id) {\n    \u002F\u002F if .vue file don't have \u003Ci18n> block, just return\n    if (!\u002Fvue&type=i18n\u002F.test(id)) {\n      return\n    }\n    \u002F\u002F parse yaml\n    if (\u002F\\.ya?ml$\u002F.test(id)) {\n      code = JSON.stringify(yaml.load(code.trim()))\n    }\n    \u002F\u002F mount the value on the i18n property of the component instance\n    return `export default Comp => {\n      Comp.i18n = ${code}\n    }`\n  },\n}\n\nexport default {\n  plugins: [vue(), vueI18nPlugin],\n}\n","js",[27,395,396,408,420,424,435,446,465,471,494,499,504,509,542,572,576,581,589,598,603,608,612,616,627,641],{"__ignoreMap":126},[130,397,398,400,403,405],{"class":132,"line":133},[130,399,155],{"class":154},[130,401,402],{"class":136}," vue ",[130,404,161],{"class":154},[130,406,407],{"class":164}," '@vitejs\u002Fplugin-vue'\n",[130,409,410,412,415,417],{"class":132,"line":151},[130,411,155],{"class":154},[130,413,414],{"class":136}," yaml ",[130,416,161],{"class":154},[130,418,419],{"class":164}," 'js-yaml'\n",[130,421,422],{"class":132,"line":168},[130,423,172],{"emptyLinePlaceholder":171},[130,425,426,428,431,433],{"class":132,"line":175},[130,427,178],{"class":154},[130,429,430],{"class":181}," vueI18nPlugin",[130,432,185],{"class":154},[130,434,274],{"class":136},[130,436,437,440,443],{"class":132,"line":201},[130,438,439],{"class":136},"  name: ",[130,441,442],{"class":164},"'vue-i18n'",[130,444,445],{"class":136},",\n",[130,447,448,451,453,456,459,462],{"class":132,"line":211},[130,449,450],{"class":188},"  transform",[130,452,192],{"class":136},[130,454,27],{"class":455},"syBk-",[130,457,458],{"class":136},", ",[130,460,461],