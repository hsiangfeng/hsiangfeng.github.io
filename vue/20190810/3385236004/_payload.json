[{"data":1,"prerenderedAt":255},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20190810\u002F3385236004\u002F":3,"page:\u002Fvue\u002F20190810\u002F3385236004\u002F":4,"alt:\u002Fvue\u002F20190810\u002F3385236004\u002F":3,"prev-next:\u002Fvue\u002F20190810\u002F3385236004\u002F":233,"related:\u002Fvue\u002F20190810\u002F3385236004\u002F":240},"\u002Fen\u002Fvue\u002F2019\u002F08\u002F10\u002Fsetting-up-routes-in-nuxt\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":217,"date":218,"description":18,"extension":219,"lang":220,"meta":221,"navigation":222,"path":223,"readingMinutes":224,"seo":225,"standalone":226,"stem":227,"tags":228,"tldr":230,"updated":230,"url":231,"__hash__":232},"content\u002FVue\u002FNuxt-Route-設置.md","Nuxt Route 設置","3385236004",{"type":9,"value":10,"toc":206},"minimark",[11,15,19,22,25,32,36,39,46,49,57,63,66,72,75,81,84,87,90,96,99,105,112,118,121,125,128,133,136,139,145,151,156,159,164,170,175,178,181,195,198],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"Nuxt 生成 route 的方式比較不太一樣，這邊實作順便記錄一下",[12,20,21],{"id":21},"起手式",[16,23,24],{},"在講解之前，先建立一下 Nuxt 專案吧，如果不會建立可以參考我這一篇文章",[16,26,27],{},[28,29,31],"a",{"href":30},"\u002Fvue\u002F20190809\u002F3851611159\u002F","建立一個 NuxtJS 專案吧!",[12,33,35],{"id":34},"route","Route",[16,37,38],{},"在寫 Vue-Cli 的時候我們都必須去 router.js 去設置 router，如下",[16,40,41],{},[42,43],"img",{"alt":44,"src":45},"範例是 RagnarokShopV3","https:\u002F\u002Fi.imgur.com\u002FdIQq0I5.png",[16,47,48],{},"但是在 Nuxt 就不太一樣了，router 是自動生成的，完全不需要去動到 router.js，讓我們來看範例吧",[16,50,51,52,56],{},"首先當我們執行 ",[53,54,55],"code",{},"npm run dev"," 的時候，Nuxt 會建立一個 .nuxt 資料夾",[16,58,59],{},[42,60],{"alt":61,"src":62},".nuxt","https:\u002F\u002Fi.imgur.com\u002FGyVnFv9.png",[16,64,65],{},"底下可以看到一個 router.js",[16,67,68],{},[42,69],{"alt":70,"src":71},"router.js","https:\u002F\u002Fi.imgur.com\u002FUUISimR.png",[16,73,74],{},"接下來打開 router.js 並滾到下方，可以看到自動生成的 router (紅字請忽略)",[16,76,77],{},[42,78],{"alt":79,"src":80},"自動生成","https:\u002F\u002Fi.imgur.com\u002FLKbqygn.png",[16,82,83],{},"那麼它的原理是怎麼生成的呢?",[12,85,86],{"id":86},"生成原理",[16,88,89],{},"首先 Nuxt 會去讀取 pages 底下的 .vue 檔案，當前 pages 只有一個 index.vue，所以 Nuxt 只會生成一個 router",[16,91,92],{},[42,93],{"alt":94,"src":95},"router","https:\u002F\u002Fi.imgur.com\u002FcrXTiD0.png",[16,97,98],{},"由此可知我們可以在底下建立一個 pages.vue 看看會發生什麼事情",[16,100,101],{},[42,102],{"alt":103,"src":104},"pages.vue","https:\u002F\u002Fi.imgur.com\u002F63ZDVFX.png",[16,106,107,108,111],{},"讓我們在打開 ",[53,109,110],{},"\u002F.nuxt\u002Frouter.js"," 檔案看看發生何事",[16,113,114],{},[42,115],{"alt":116,"src":117},"Image","https:\u002F\u002Fi.imgur.com\u002FcF94XEB.png",[16,119,120],{},"你會發現它自動幫你生出了 router，有沒有超神奇呢?",[12,122,124],{"id":123},"巢狀-route","巢狀 Route",[16,126,127],{},"巢狀 Route 是我們非常常使用的技巧之一，我們都會使用 childern 來指定巢狀",[16,129,130],{},[42,131],{"alt":44,"src":132},"https:\u002F\u002Fi.imgur.com\u002FkJUx9rO.png",[16,134,135],{},"那麼在 Nuxt 該怎麼做到巢狀 router?手動寫嗎?不對，在 Nuxt 會建議盡可能讓它自動生成，不建議手動去調整，因為手動撰寫在 Nuxt 是非常麻煩的，假設我希望 pages 底下有巢狀 router，並且有 index.vue (主頁)、about.vue、pages.vue 呢?",[16,137,138],{},"那麼可以這樣做，直接在底下建立一個資料夾叫 pages，並在底下建立 index.vue、about.vue、pages.vue",[16,140,141],{},[42,142],{"alt":143,"src":144},"pages","https:\u002F\u002Fi.imgur.com\u002FILIQTCQ.png",[16,146,147,148,150],{},"這時候我在看一下 ",[53,149,110],{}," 變成甚麼樣子",[16,152,153],{},[42,154],{"alt":70,"src":155},"https:\u002F\u002Fi.imgur.com\u002Fwb2op5C.png",[16,157,158],{},"我們可以看到成功建立了巢狀 router，但是這邊有一個地方要注意在 pages 的資料夾根目錄上還有一個相同名稱的 pages.vue",[16,160,161],{},[42,162],{"alt":103,"src":163},"https:\u002F\u002Fi.imgur.com\u002FTltnxKn.png",[16,165,166,167,169],{},"資料夾名稱必須與根目錄的 pages.vue 相同，否則會出現問題，例如我根目錄刪除 pages.vue，這時候再來看 ",[53,168,110],{}," 會變成什麼樣子",[16,171,172],{},[42,173],{"alt":70,"src":174},"https:\u002F\u002Fi.imgur.com\u002FCtIg5IL.png",[16,176,177],{},"我們可以看到這已經不是巢狀 router 了，所以這邊要記得如果要製作巢狀 router，必須建立一個與巢狀相同的 XXX.vue。",[12,179,180],{"id":180},"結尾",[16,182,183,184,187,188,191,192],{},"最後補充一個重點，在 nuxt 會建議你使用 ",[53,185,186],{},"\u003Cnuxt-link to=\"\u002F\">首頁\u003C\u002Fnuxt-link>"," 切換 router，當如果你是使用 ",[53,189,190],{},"\u003Cnuxt-link to=\"{name: 'xxx'}\">首頁\u003C\u002Fnuxt-link>","，請務必帶上巢狀 router 的資料夾，以上面為範例就是 ",[53,193,194],{},"\u003Cnuxt-link to=\"{name: 'pages-about'}\">首頁\u003C\u002Fnuxt-link>",[12,196,197],{"id":197},"參考文獻",[16,199,200],{},[28,201,205],{"href":202,"rel":203},"https:\u002F\u002Fzh.nuxtjs.org\u002Fguide\u002Frouting\u002F",[204],"nofollow","基础路由",{"title":207,"searchDepth":208,"depth":208,"links":209},"",2,[210,211,212,213,214,215,216],{"id":14,"depth":208,"text":14},{"id":21,"depth":208,"text":21},{"id":34,"depth":208,"text":35},{"id":86,"depth":208,"text":86},{"id":123,"depth":208,"text":124},{"id":180,"depth":208,"text":180},{"id":197,"depth":208,"text":197},"Vue","2019-08-10 22:29:02","md","zh-Hant",{},true,"\u002Fvue\u002Fnuxt-route","2",{"title":6,"description":18},false,"Vue\u002FNuxt-Route-設置",[217,229],"Nuxt",null,"\u002Fvue\u002F20190810\u002F3385236004\u002F","gu2QpF62M23n5cST264G1l2DHYfsspNfQZLZ9r0zSvI",{"newer":234,"older":238},{"url":235,"title":236,"date":237},"\u002Fvue\u002F20190816\u002F3627128539\u002F","Nuxt.js 導航守衛","2019-08-16 13:01:13",{"url":30,"title":31,"date":239},"2019-08-09 15:49:13",[241,246,250],{"url":242,"title":243,"date":244,"readingMinutes":245},"\u002Fvue\u002F20251204\u002F754692240\u002F","思考 Vue\u002FNuxt 專案架構：如何選擇適合團隊的目錄結構？","2025-12-04 11:40:56","6",{"url":247,"title":248,"date":249,"readingMinutes":245},"\u002Fvue\u002F20251106\u002F1172686218\u002F","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","2025-11-06 13:45:34",{"url":251,"title":252,"date":253,"readingMinutes":254},"\u002Fvue\u002F20250216\u002F532019259\u002F","不同於 ref 的 shallowRef 宣告","2025-02-16 19:32:58","4",1784011737552]