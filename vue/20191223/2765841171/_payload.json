[{"data":1,"prerenderedAt":109},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20191223\u002F2765841171\u002F":3,"page:\u002Fvue\u002F20191223\u002F2765841171\u002F":4,"alt:\u002Fvue\u002F20191223\u002F2765841171\u002F":3,"prev-next:\u002Fvue\u002F20191223\u002F2765841171\u002F":85,"related:\u002Fvue\u002F20191223\u002F2765841171\u002F":94},"\u002Fen\u002Fvue\u002F2019\u002F12\u002F23\u002Fvue-node-sass-binding-not-found-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":69,"date":70,"description":18,"extension":71,"lang":72,"meta":73,"navigation":74,"path":75,"readingMinutes":76,"seo":77,"standalone":78,"stem":79,"tags":80,"tldr":82,"updated":82,"url":83,"__hash__":84},"content\u002FVue\u002FVue-專案出現-Node-Sass-could-not-find-a-binding-for-your-current-environment.md","Vue 專案出現 Node Sass could not find a binding for your current environment","2765841171",{"type":9,"value":10,"toc":62},"minimark",[11,15,19,22,30,40,43,50,53],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近在弄 Vue Cli 2 專案的時候突然發生一個錯誤，Node Sass could not find a binding for your current environment，所以這一篇記錄一下該如何解決。",[12,20,21],{"id":21},"問題",[16,23,24,25,29],{},"由於該專案是 Vue Cli 2，所以當我執行 ",[26,27,28],"code",{},"npm start"," 時卻出現以下錯誤",[31,32,38],"pre",{"className":33,"code":35,"language":36,"meta":37},[34],"language-text","Module build failed: Error: Missing binding D:\\vue\\node_modules\\node-sass\\vendor\\win32-x64-67\\binding.node\nNode Sass could not find a binding for your current environment: Windows 64-bit with Node.js 11.x\n\nFound bindings for the following environments:\n  - OS X 64-bit with Node.js 12.x\n\nThis usually happens because your environment has changed since running `npm install`.\nRun `npm rebuild node-sass` to download the binding for your current environment.\n","text","",[26,39,35],{"__ignoreMap":37},[12,41,42],{"id":42},"解決方法",[16,44,45,46,49],{},"解決方法其實很簡單 ，只需要在該專案下執行 ",[26,47,48],{},"npm rebuild node-sass"," 就可以了，至於問題點是 node-sass 版本安裝上的錯誤導致。",[12,51,52],{"id":52},"參考文獻",[16,54,55],{},[56,57,61],"a",{"href":58,"rel":59},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F37986800\u002Fnode-sass-couldnt-find-a-binding-for-your-current-environment",[60],"nofollow","Node Sass couldn't find a binding for your current environment",{"title":37,"searchDepth":63,"depth":63,"links":64},2,[65,66,67,68],{"id":14,"depth":63,"text":14},{"id":21,"depth":63,"text":21},{"id":42,"depth":63,"text":42},{"id":52,"depth":63,"text":52},"Vue","2019-12-23 10:16:07","md","zh-Hant",{},true,"\u002Fvue\u002Fvue-node-sass-could-not-find-a-binding-for-your-current-environment","1",{"title":6,"description":18},false,"Vue\u002FVue-專案出現-Node-Sass-could-not-find-a-binding-for-your-current-environment",[69,81],"障礙排除",null,"\u002Fvue\u002F20191223\u002F2765841171\u002F","9-Dlfoi3TIPjvZ3VO7tPcmRBPsh2VxglIrd5RBGIwoE",{"newer":86,"older":90},{"url":87,"title":88,"date":89},"\u002Fhexo\u002F20191225\u002F2266233686\u002F","將 Hexo NexT 改成 Algolia 搜尋","2019-12-25 16:58:13",{"url":91,"title":92,"date":93},"\u002Fgulp\u002F20191220\u002F1507807439\u002F","Gulp deploy 發生 TypeError: Cannot read property 0 of null","2019-12-20 14:48:05",[95,100,104],{"url":96,"title":97,"date":98,"readingMinutes":99},"\u002Fvue\u002F20251204\u002F754692240\u002F","思考 Vue\u002FNuxt 專案架構：如何選擇適合團隊的目錄結構？","2025-12-04 11:40:56","6",{"url":101,"title":102,"date":103,"readingMinutes":99},"\u002Fvue\u002F20251106\u002F1172686218\u002F","用 &lt;spec lang=\"md\"&gt; 標籤在 Vue 中舒服的使用 SFC 搭配 AI 開發","2025-11-06 13:45:34",{"url":105,"title":106,"date":107,"readingMinutes":108},"\u002Fvue\u002F20250216\u002F532019259\u002F","不同於 ref 的 shallowRef 宣告","2025-02-16 19:32:58","4",1784087386994]