[{"data":1,"prerenderedAt":2184},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20230208\u002F3309208839\u002F":3,"page:\u002Fvue\u002F20230208\u002F3309208839\u002F":4,"alt:\u002Fvue\u002F20230208\u002F3309208839\u002F":3,"prev-next:\u002Fvue\u002F20230208\u002F3309208839\u002F":2161,"related:\u002Fvue\u002F20230208\u002F3309208839\u002F":2170},"\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":2144,"date":2145,"description":2146,"extension":2147,"lang":2148,"meta":2149,"navigation":252,"path":2150,"readingMinutes":2151,"seo":2152,"standalone":2153,"stem":2154,"tags":2155,"tldr":2157,"updated":2158,"url":2159,"__hash__":2160},"content\u002FVue\u002FVue3-VeeValidate-v4-x-引入教學.md","Vue3 VeeValidate v4.x 引入教學","3309208839",{"type":9,"value":10,"toc":2127},"minimark",[11,15,19,23,30,33,36,39,42,68,82,85,91,94,138,141,147,151,154,169,172,186,189,192,206,210,213,217,227,592,595,760,763,769,772,775,1046,1049,1052,1055,1058,1068,1110,1114,1128,1209,1212,1243,1400,1413,1417,1435,1705,1708,1728,1904,1916,2104,2111,2114,2124],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇會簡單記錄一下如何在 Vue3 中引入 VeeValidate v4.x。",[12,20,22],{"id":21},"veevalidate-v4x","VeeValidate v4.x",[16,24,25],{},[26,27],"img",{"alt":28,"src":29},"VeeValidate","https:\u002F\u002Fi.imgur.com\u002FG6I37Km.png",[16,31,32],{},"首先這一篇將會基於 VeeValidate v4.x 來進行，那麼什麼是 VeeValidate 呢？",[16,34,35],{},"VeeValidate 是一個 Vue.js 的表單驗證套件，它讓我們可以在 Vue.js 中輕鬆達到表單驗證的功能，除此之外，它本身也有提供一些預設的驗證規則及錯誤訊息，讓我們可以快速的使用，當然它也支援自訂驗證規則及錯誤訊息，最方便的地方在於還有支援多國語系。",[12,37,38],{"id":38},"起手式",[16,40,41],{},"接下來這一篇範例將會使用 Vite 來建立 Vue3 的專案，請開啟終端機並輸入以下",[43,44,49],"pre",{"className":45,"code":46,"language":47,"meta":48,"style":48},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","npm create vue@3\n","bash","",[50,51,52],"code",{"__ignoreMap":48},[53,54,57,61,65],"span",{"class":55,"line":56},"line",1,[53,58,60],{"class":59},"smYoP","npm",[53,62,64],{"class":63},"sWayO"," create",[53,66,67],{"class":63}," vue@3\n",[69,70,73],"callout",{"title":71,"type":72},"Note","note",[16,74,75,78,79],{},[50,76,77],{},"npm create vue@3"," 指令是 Vue 官方所提供的 Vite 起手指令，若要改安裝 Vue2 版本則請改輸入 ",[50,80,81],{},"npm create vue@2",[16,83,84],{},"選項就不多述了，依照自己需求調整即可，底下我也附圖提供參考。",[16,86,87],{},[26,88],{"alt":89,"src":90},"選項","https:\u002F\u002Fi.imgur.com\u002FE545RDa.png",[16,92,93],{},"接著打開終端機輸入以下指令",[43,95,97],{"className":45,"code":96,"language":47,"meta":48,"style":48},"cd \u003C專案名稱>\nnpm install\nnpm run dev\n",[50,98,99,119,127],{"__ignoreMap":48},[53,100,101,105,109,112,116],{"class":55,"line":56},[53,102,104],{"class":103},"stw71","cd",[53,106,108],{"class":107},"sOudu"," \u003C",[53,110,111],{"class":63},"專案名",[53,113,115],{"class":114},"s8XSl","稱",[53,117,118],{"class":107},">\n",[53,120,122,124],{"class":55,"line":121},2,[53,123,60],{"class":59},[53,125,126],{"class":63}," install\n",[53,128,130,132,135],{"class":55,"line":129},3,[53,131,60],{"class":59},[53,133,134],{"class":63}," run",[53,136,137],{"class":63}," dev\n",[16,139,140],{},"接下來你就可以打開瀏覽器看到 Vue 初始畫面",[16,142,143],{},[26,144],{"alt":145,"src":146},"初始畫面","https:\u002F\u002Fi.imgur.com\u002FoPSxW1C.png",[12,148,150],{"id":149},"安裝-veevalidate","安裝 VeeValidate",[16,152,153],{},"接下來我們要來安裝 VeeValidate，請打開終端機並輸入以下指令",[43,155,157],{"className":45,"code":156,"language":47,"meta":48,"style":48},"npm install vee-validate\n",[50,158,159],{"__ignoreMap":48},[53,160,161,163,166],{"class":55,"line":56},[53,162,60],{"class":59},[53,164,165],{"class":63}," install",[53,167,168],{"class":63}," vee-validate\n",[16,170,171],{},"這邊要注意一下，目前我們安裝的 VeeValidate 並沒有包含驗證規則，因此我們必須額外安裝 VeeValidate 的驗證規則套件，請打開終端機並輸入以下指令",[43,173,175],{"className":45,"code":174,"language":47,"meta":48,"style":48},"npm install @vee-validate\u002Frules\n",[50,176,177],{"__ignoreMap":48},[53,178,179,181,183],{"class":55,"line":56},[53,180,60],{"class":59},[53,182,165],{"class":63},[53,184,185],{"class":63}," @vee-validate\u002Frules\n",[16,187,188],{},"那麼為什麼會這樣呢？因為 VeeValidate 本身是一個驗證套件，因此你可以自己撰寫驗證規則，但是 VeeValidate 也有提供一些預設的驗證規則，只是它並沒有包含在 VeeValidate 中，因此我們必須額外安裝驗證規則套件。",[16,190,191],{},"除此之外，這邊我們也順便引入 VeeValidate 的 i18n 套件，請打開終端機並輸入以下指令",[43,193,195],{"className":45,"code":194,"language":47,"meta":48,"style":48},"npm install @vee-validate\u002Fi18n\n",[50,196,197],{"__ignoreMap":48},[53,198,199,201,203],{"class":55,"line":56},[53,200,60],{"class":59},[53,202,165],{"class":63},[53,204,205],{"class":63}," @vee-validate\u002Fi18n\n",[12,207,209],{"id":208},"引入-veevalidate","引入 VeeValidate",[16,211,212],{},"接下來我們要來引入 VeeValidate，那麼引入方式有兩種，一種是全域引入，另一種是局部引入，這邊我們先來看看全域引入的方式。",[214,215,216],"h3",{"id":216},"全域引入",[16,218,219,220,223,224,226],{},"首先我們要先在 ",[50,221,222],{},"main.js"," 中引入 VeeValidate，請打開 ",[50,225,222],{}," 並修改如下（底下我都有註解說明）",[43,228,232],{"className":229,"code":230,"language":231,"meta":48,"style":48},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","import { createApp } from 'vue'\n\n\u002F\u002F 引入 VeeValidate 元件跟功能\nimport {\n  Field, Form, ErrorMessage, defineRule, configure,\n} from 'vee-validate';\n\u002F\u002F 引入 VeeValidate 的驗證規則\nimport AllRules from '@vee-validate\u002Frules';\n\u002F\u002F 引入 VeeValidate 的 i18n 功能\nimport { localize, setLocale } from '@vee-validate\u002Fi18n';\n\u002F\u002F 引入 VeeValidate 的繁體中文語系檔\nimport zhTW from '@vee-validate\u002Fi18n\u002Fdist\u002Flocale\u002Fzh_TW.json';\n\nimport App from '.\u002FApp.vue'\n\n\u002F\u002F 使用 Object.keys 將 AllRules 轉為陣列並使用 forEach 迴圈將驗證規則加入 VeeValidate\nObject.keys(AllRules).forEach((rule) => {\n  defineRule(rule, AllRules[rule]);\n});\n\n\u002F\u002F 將當前 VeeValidate 的語系設定為繁體中文\nconfigure({\n  generateMessage: localize({ zh_TW: zhTW }),\n  validateOnInput: true,\n});\nsetLocale('zh_TW');\n\nconst app = createApp(App);\n\n\u002F\u002F 掛載 Global 的 VeeValidate 元件\napp.component('VField', Field);\napp.component('VForm', Form);\napp.component('ErrorMessage', ErrorMessage);\n\napp.mount('#app')\n","js",[50,233,234,248,254,260,268,274,288,294,309,315,330,336,351,356,369,374,380,411,420,426,431,437,446,458,470,475,490,495,513,518,524,541,556,571,576],{"__ignoreMap":48},[53,235,236,239,242,245],{"class":55,"line":56},[53,237,238],{"class":107},"import",[53,240,241],{"class":114}," { createApp } ",[53,243,244],{"class":107},"from",[53,246,247],{"class":63}," 'vue'\n",[53,249,250],{"class":55,"line":121},[53,251,253],{"emptyLinePlaceholder":252},true,"\n",[53,255,256],{"class":55,"line":129},[53,257,259],{"class":258},"sGBqm","\u002F\u002F 引入 VeeValidate 元件跟功能\n",[53,261,263,265],{"class":55,"line":262},4,[53,264,238],{"class":107},[53,266,267],{"class":114}," {\n",[53,269,271],{"class":55,"line":270},5,[53,272,273],{"class":114},"  Field, Form, ErrorMessage, defineRule, configure,\n",[53,275,277,280,282,285],{"class":55,"line":276},6,[53,278,279],{"class":114},"} ",[53,281,244],{"class":107},[53,283,284],{"class":63}," 'vee-validate'",[53,286,287],{"class":114},";\n",[53,289,291],{"class":55,"line":290},7,[53,292,293],{"class":258},"\u002F\u002F 引入 VeeValidate 的驗證規則\n",[53,295,297,299,302,304,307],{"class":55,"line":296},8,[53,298,238],{"class":107},[53,300,301],{"class":114}," AllRules ",[53,303,244],{"class":107},[53,305,306],{"class":63}," '@vee-validate\u002Frules'",[53,308,287],{"class":114},[53,310,312],{"class":55,"line":311},9,[53,313,314],{"class":258},"\u002F\u002F 引入 VeeValidate 的 i18n 功能\n",[53,316,318,320,323,325,328],{"class":55,"line":317},10,[53,319,238],{"class":107},[53,321,322],{"class":114}," { localize, setLocale } ",[53,324,244],{"class":107},[53,326,327],{"class":63}," '@vee-validate\u002Fi18n'",[53,329,287],{"class":114},[53,331,333],{"class":55,"line":332},11,[53,334,335],{"class":258},"\u002F\u002F 引入 VeeValidate 的繁體中文語系檔\n",[53,337,339,341,344,346,349],{"class":55,"line":338},12,[53,340,238],{"class":107},[53,342,343],{"class":114}," zhTW ",[53,345,244],{"class":107},[53,347,3