[{"data":1,"prerenderedAt":2184},["ShallowReactive",2],{"header-locale:\u002Fvue\u002F20230208\u002F3309208839\u002F":3,"page:\u002Fvue\u002F20230208\u002F3309208839\u002F":4,"alt:\u002Fvue\u002F20230208\u002F3309208839\u002F":3,"prev-next:\u002Fvue\u002F20230208\u002F3309208839\u002F":2161,"related:\u002Fvue\u002F20230208\u002F3309208839\u002F":2170},"\u002Fen\u002Fvue\u002F2023\u002F02\u002F08\u002Fvue3-veevalidate-v4-setup\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":2144,"date":2145,"description":2146,"extension":2147,"lang":2148,"meta":2149,"navigation":254,"path":2150,"readingMinutes":2151,"seo":2152,"standalone":2153,"stem":2154,"tags":2155,"tldr":2157,"updated":2158,"url":2159,"__hash__":2160},"content\u002FVue\u002FVue3-VeeValidate-v4-x-引入教學.md","Vue3 VeeValidate v4.x 引入教學","3309208839",{"type":9,"value":10,"toc":2127},"minimark",[11,15,19,23,30,33,36,39,42,68,84,87,93,96,140,143,149,153,156,171,174,188,191,194,208,212,215,219,229,593,596,760,763,769,772,775,1046,1049,1052,1055,1058,1068,1110,1114,1128,1209,1212,1243,1400,1413,1417,1435,1705,1708,1728,1904,1916,2104,2111,2114,2124],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇會簡單記錄一下如何在 Vue3 中引入 VeeValidate v4.x。",[12,20,22],{"id":21},"veevalidate-v4x","VeeValidate v4.x",[16,24,25],{},[26,27],"img",{"alt":28,"src":29},"VeeValidate","https:\u002F\u002Fi.imgur.com\u002FG6I37Km.png",[16,31,32],{},"首先這一篇將會基於 VeeValidate v4.x 來進行，那麼什麼是 VeeValidate 呢？",[16,34,35],{},"VeeValidate 是一個 Vue.js 的表單驗證套件，它讓我們可以在 Vue.js 中輕鬆達到表單驗證的功能，除此之外，它本身也有提供一些預設的驗證規則及錯誤訊息，讓我們可以快速的使用，當然它也支援自訂驗證規則及錯誤訊息，最方便的地方在於還有支援多國語系。",[12,37,38],{"id":38},"起手式",[16,40,41],{},"接下來這一篇範例將會使用 Vite 來建立 Vue3 的專案，請開啟終端機並輸入以下",[43,44,49],"pre",{"className":45,"code":46,"language":47,"meta":48,"style":48},"language-bash shiki shiki-themes github-dark-high-contrast","npm create vue@3\n","bash","",[50,51,52],"code",{"__ignoreMap":48},[53,54,57,61,65],"span",{"class":55,"line":56},"line",1,[53,58,60],{"class":59},"s_sBn","npm",[53,62,64],{"class":63},"sTRMh"," create",[53,66,67],{"class":63}," vue@3\n",[69,70,71],"blockquote",{},[16,72,73,77,80,81],{},[74,75,76],"strong",{},"Note",[50,78,79],{},"npm create vue@3"," 指令是 Vue 官方所提供的 Vite 起手指令，若要改安裝 Vue2 版本則請改輸入 ",[50,82,83],{},"npm create vue@2",[16,85,86],{},"選項就不多述了，依照自己需求調整即可，底下我也附圖提供參考。",[16,88,89],{},[26,90],{"alt":91,"src":92},"選項","https:\u002F\u002Fi.imgur.com\u002FE545RDa.png",[16,94,95],{},"接著打開終端機輸入以下指令",[43,97,99],{"className":45,"code":98,"language":47,"meta":48,"style":48},"cd \u003C專案名稱>\nnpm install\nnpm run dev\n",[50,100,101,121,129],{"__ignoreMap":48},[53,102,103,107,111,114,118],{"class":55,"line":56},[53,104,106],{"class":105},"sCcAr","cd",[53,108,110],{"class":109},"sWyjQ"," \u003C",[53,112,113],{"class":63},"專案名",[53,115,117],{"class":116},"sMAXC","稱",[53,119,120],{"class":109},">\n",[53,122,124,126],{"class":55,"line":123},2,[53,125,60],{"class":59},[53,127,128],{"class":63}," install\n",[53,130,132,134,137],{"class":55,"line":131},3,[53,133,60],{"class":59},[53,135,136],{"class":63}," run",[53,138,139],{"class":63}," dev\n",[16,141,142],{},"接下來你就可以打開瀏覽器看到 Vue 初始畫面",[16,144,145],{},[26,146],{"alt":147,"src":148},"初始畫面","https:\u002F\u002Fi.imgur.com\u002FoPSxW1C.png",[12,150,152],{"id":151},"安裝-veevalidate","安裝 VeeValidate",[16,154,155],{},"接下來我們要來安裝 VeeValidate，請打開終端機並輸入以下指令",[43,157,159],{"className":45,"code":158,"language":47,"meta":48,"style":48},"npm install vee-validate\n",[50,160,161],{"__ignoreMap":48},[53,162,163,165,168],{"class":55,"line":56},[53,164,60],{"class":59},[53,166,167],{"class":63}," install",[53,169,170],{"class":63}," vee-validate\n",[16,172,173],{},"這邊要注意一下，目前我們安裝的 VeeValidate 並沒有包含驗證規則，因此我們必須額外安裝 VeeValidate 的驗證規則套件，請打開終端機並輸入以下指令",[43,175,177],{"className":45,"code":176,"language":47,"meta":48,"style":48},"npm install @vee-validate\u002Frules\n",[50,178,179],{"__ignoreMap":48},[53,180,181,183,185],{"class":55,"line":56},[53,182,60],{"class":59},[53,184,167],{"class":63},[53,186,187],{"class":63}," @vee-validate\u002Frules\n",[16,189,190],{},"那麼為什麼會這樣呢？因為 VeeValidate 本身是一個驗證套件，因此你可以自己撰寫驗證規則，但是 VeeValidate 也有提供一些預設的驗證規則，只是它並沒有包含在 VeeValidate 中，因此我們必須額外安裝驗證規則套件。",[16,192,193],{},"除此之外，這邊我們也順便引入 VeeValidate 的 i18n 套件，請打開終端機並輸入以下指令",[43,195,197],{"className":45,"code":196,"language":47,"meta":48,"style":48},"npm install @vee-validate\u002Fi18n\n",[50,198,199],{"__ignoreMap":48},[53,200,201,203,205],{"class":55,"line":56},[53,202,60],{"class":59},[53,204,167],{"class":63},[53,206,207],{"class":63}," @vee-validate\u002Fi18n\n",[12,209,211],{"id":210},"引入-veevalidate","引入 VeeValidate",[16,213,214],{},"接下來我們要來引入 VeeValidate，那麼引入方式有兩種，一種是全域引入，另一種是局部引入，這邊我們先來看看全域引入的方式。",[216,217,218],"h3",{"id":218},"全域引入",[16,220,221,222,225,226,228],{},"首先我們要先在 ",[50,223,224],{},"main.js"," 中引入 VeeValidate，請打開 ",[50,227,224],{}," 並修改如下（底下我都有註解說明）",[43,230,234],{"className":231,"code":232,"language":233,"meta":48,"style":48},"language-js shiki shiki-themes github-dark-high-contrast","import { createApp } from 'vue'\n\n\u002F\u002F 引入 VeeValidate 元件跟功能\nimport {\n  Field, Form, ErrorMessage, defineRule, configure,\n} from 'vee-validate';\n\u002F\u002F 引入 VeeValidate 的驗證規則\nimport AllRules from '@vee-validate\u002Frules';\n\u002F\u002F 引入 VeeValidate 的 i18n 功能\nimport { localize, setLocale } from '@vee-validate\u002Fi18n';\n\u002F\u002F 引入 VeeValidate 的繁體中文語系檔\nimport zhTW from '@vee-validate\u002Fi18n\u002Fdist\u002Flocale\u002Fzh_TW.json';\n\nimport App from '.\u002FApp.vue'\n\n\u002F\u002F 使用 Object.keys 將 AllRules 轉為陣列並使用 forEach 迴圈將驗證規則加入 VeeValidate\nObject.keys(AllRules).forEach((rule) => {\n  defineRule(rule, AllRules[rule]);\n});\n\n\u002F\u002F 將當前 VeeValidate 的語系設定為繁體中文\nconfigure({\n  generateMessage: localize({ zh_TW: zhTW }),\n  validateOnInput: true,\n});\nsetLocale('zh_TW');\n\nconst app = createApp(App);\n\n\u002F\u002F 掛載 Global 的 VeeValidate 元件\napp.component('VField', Field);\napp.component('VForm', Form);\napp.component('ErrorMessage', ErrorMessage);\n\napp.moun