[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F87\u002F":3,"archive-page:zh-Hant:87":4,"author-stats:zh-Hant:full":77},null,{"posts":5,"total":75,"totalPages":76},[6,14,22,29,35,41,47,54,62,69],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":12,"readingMinutes":13},"\u002Fjavascript\u002F20190624\u002F604717444\u002F","嘗試了解 JavaScript 的原型鏈","2019-06-24 12:28:48","JavaScript",[10],"這一篇其實我一直猶豫該不該寫，因為我深怕一個地方紀錄錯了會導致其他看的人也跟著錯，但是想一想我當初撰寫 Hexo 部落格的初衷是做自己的筆記後就又好點了，這一篇來記錄一下 JavaScript 的原型鏈這個主題","3",{"url":15,"title":16,"date":17,"updated":3,"category":18,"tags":19,"description":21,"readingMinutes":13},"\u002FTypeScript\u002F20190623\u002F3262185960\u002F","TypeScript 基礎入門-Class","2019-06-23 11:43:56","TypeScript",[20,10,18],"TypeScript 基礎入門","類別(class)這個是在 ES6 引入的，而這個功能又有何用處呢?讓我們來研究一下",{"url":23,"title":24,"date":25,"updated":3,"category":18,"tags":26,"description":27,"readingMinutes":28},"\u002FTypeScript\u002F20190622\u002F2385966784\u002F","TypeScript 基礎入門-Array","2019-06-22 22:27:26",[20,10,18],"接下來講到陣列的撰寫方式，其實與撰寫變數是太大的差異，這邊就來了解一下 TypeScript 中應該怎麼寫陣列吧","1",{"url":30,"title":31,"date":32,"updated":3,"category":18,"tags":33,"description":34,"readingMinutes":28},"\u002FTypeScript\u002F20190622\u002F3741788460\u002F","TypeScript 基礎入門-Function","2019-06-22 22:14:41",[20,10,18],"寫 JavaScript 的時候會非常撰寫 function，但 TypeScript 也有它的撰寫方式，讓我們來了解一下",{"url":36,"title":37,"date":38,"updated":3,"category":18,"tags":39,"description":40,"readingMinutes":28},"\u002FTypeScript\u002F20190622\u002F2982589304\u002F","TypeScript 基礎入門-混和型別","2019-06-22 21:56:38",[20,10,18],"前面講到 TypeScript 有所謂的型別推論的能力，在這邊再來講一個東西混和型別，這個東西又是什麼呢?讓我們來了解一下",{"url":42,"title":43,"date":44,"updated":3,"category":18,"tags":45,"description":46,"readingMinutes":28},"\u002FTypeScript\u002F20190622\u002F2739569432\u002F","TypeScript 基礎入門-型別推論","2019-06-22 15:49:05",[20,10,18],"前面已經了解該如何設置變數型別的方式，但是尾段其實也有講到如果不設置型別也是會編譯成功，但是實際上真的是這樣子嗎?這邊就來講講 TypeScript 裡面有一個很特別的東西，叫做型別推論，就算你不宣告型別 TypeScript 也會自己判定，來了解看看吧~",{"url":48,"title":49,"date":50,"updated":3,"category":18,"tags":51,"description":52,"readingMinutes":53},"\u002FTypeScript\u002F20190622\u002F3955309115\u002F","TypeScript 基礎入門-變數篇","2019-06-22 15:06:22",[20,10,18],"身邊滿多前端工程師都會接觸到 TypeScript，所以這邊紀錄一下 TypeScript 基礎入門","2",{"url":55,"title":56,"date":57,"updated":3,"category":58,"tags":59,"description":61,"readingMinutes":53},"\u002Fgit\u002F20190621\u002F4239571950\u002F","GitHub 發生衝突該如何解決","2019-06-21 16:35:09","Git",[60,58],"GitHub","當參加團隊專案開發的時候，其實很容易發生程式碼衝突問題，那這邊就來講一下該如何解除衝突吧~",{"url":63,"title":64,"date":65,"updated":3,"category":10,"tags":66,"description":68,"readingMinutes":28},"\u002Fjavascript\u002F20190621\u002F538821393\u002F","CoffeeScript 三元運算子","2019-06-21 11:49:07",[10,67],"CoffeeScript","這邊紀錄一下 CoffeeScript 的三元運算子該如何撰寫",{"url":70,"title":71,"date":72,"updated":3,"category":10,"tags":73,"description":74,"readingMinutes":28},"\u002Fjavascript\u002F20190621\u002F4177225789\u002F","CoffeeScript event 沒有反應","2019-06-21 10:19:54",[10,67],"撰寫 CoffeeScript 的時候發生一件怪事情，event 事件竟然無法使用，所以這邊紀錄一下我曾經做過哪些事情以及解決方式",1035,104,{"postCount":75,"tagCount":78},1009,1784013044136]