[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F102\u002F":3,"archive-page:zh-Hant:102":4,"author-stats:zh-Hant:full":79},null,{"posts":5,"total":77,"totalPages":78},[6,15,25,32,38,44,51,58,64,70],{"url":7,"title":8,"date":9,"updated":9,"category":10,"tags":11,"description":13,"readingMinutes":14},"\u002Flearnexp\u002F20190503\u002F3738458215\u002F","該如何制定自己的學習","2019-05-03 09:53:55","學習經驗",[12,10],"其他","今天又寫了一篇心得分享，主要原因出在先前所撰寫的三篇文章該如何正確的學習前端技術&程式語言、學習心態調整及你願意犧牲多少來得到你想要的事物，很多人都來詢問該如何學習及撰寫筆記這方面的問題，所以我也寫一下我提供的建議。","6",{"url":16,"title":17,"date":18,"updated":3,"category":19,"tags":20,"description":23,"readingMinutes":24},"\u002Fnodejs\u002F20190503\u002F2483499053\u002F","nodejs出現錯誤代碼500","2019-05-03 09:06:26","Nodejs",[21,22],"Node.js","障礙排除","昨天在弄 nodejs 的時候發生一件很奇妙的事情，前一天使用 ajax 還很正常，昨天突然 ajax 掛掉了...最後今天發現原因紀錄一下自己多白癡。","1",{"url":26,"title":27,"date":28,"updated":28,"category":10,"tags":29,"description":30,"readingMinutes":31},"\u002Flearnexp\u002F20190502\u002F4023370690\u002F","你願意犧牲多少來得到你想要的事物?","2019-05-02 10:24:41",[12,10],"許多時候我們都必須去作出選擇，先前六角學院的廖老師有分享過前端求職履歷面試全攻略的影音心得，其中裡面有講到你願意為了達到目標犧牲多少?","3",{"url":33,"title":34,"date":35,"updated":3,"category":19,"tags":36,"description":37,"readingMinutes":24},"\u002Fnodejs\u002F20190429\u002F1130866276\u002F","nodejs神奇的兩次Request","2019-04-29 20:06:34",[21,22],"由於最近再進修 Nodejs + firebase ，所以也挪不太出時間來寫文章，但是練習 Nodejs 過程中遇到一個很低級&智障問題，結果因此卡了三天，所以這邊做一下紀錄。",{"url":39,"title":40,"date":41,"updated":41,"category":10,"tags":42,"description":43,"readingMinutes":31},"\u002Flearnexp\u002F20190426\u002F43778186\u002F","學習時的心態調整","2019-04-26 15:35:12",[12,10],"最近在幫忙幾位朋友解決學習上的問題時，發現很常出現幾種問題，也跟自己當初的狀況很類似，所以就乾脆寫一下自己的心得分享...",{"url":45,"title":46,"date":47,"updated":3,"category":48,"tags":49,"description":50,"readingMinutes":31},"\u002Fjavascript\u002F20190426\u002F1966510488\u002F","關於 Array.prototype.sort() 排序這件不小的小事","2019-04-26 10:04:22","JavaScript",[48],"先前寫了一篇關於 JavaScript 陣列 20 種操作的方法，其中就有朋友對於 sort() 有點疑問不清楚原理，在被詢問時我自己也突然疑惑了一下，所以決定自己針對 sort() 來做一下研究了解原理。",{"url":52,"title":53,"date":54,"updated":3,"category":19,"tags":55,"description":56,"readingMinutes":57},"\u002Fnodejs\u002F20190425\u002F3663458445\u002F","Express自訂SASS\u002FSCSS路徑","2019-04-25 13:57:16",[21,22],"前面有撰寫一篇如何Nodejs-Express中撰寫SCSS，剛寫完就遇到一個問題...所以這邊果斷再寫一篇該如何自訂 SASS\u002FSCSS 路徑","2",{"url":59,"title":60,"date":61,"updated":3,"category":19,"tags":62,"description":63,"readingMinutes":24},"\u002Fnodejs\u002F20190425\u002F1258950236\u002F","Nodejs-Express中撰寫SCSS","2019-04-25 12:29:13",[21],"最近正在學習 Nodejs-Express 開發，礙於自己本身所學習是 SCSS 預處理器，可是網路上好像找不到相關解決方式，所以這邊紀錄一下...",{"url":65,"title":66,"date":67,"updated":3,"category":48,"tags":68,"description":69,"readingMinutes":57},"\u002Fjavascript\u002F20190424\u002F2772517253\u002F","JavaScript奇妙的題目","2019-04-24 20:41:32",[48],"JavaScript 在很多地方都非常的奇妙又好玩，過陣子也準備進入 js 奇妙的章節...先來做一下記錄前陣子在學院中人家的 js 問題。",{"url":71,"title":72,"date":73,"updated":3,"category":48,"tags":74,"description":75,"readingMinutes":76},"\u002Fjavascript\u002F20190421\u002F1216566123\u002F","關於 JavaScript 陣列 20 種操作的方法","2019-04-21 11:56:53",[48],"這篇文章主要是觀看了偷米騎巴哥]操作JS陣列的20種方式而撰寫的，因為覺得這張圖真的是精華","7",1036,104,{"postCount":77,"tagCount":80},1011,1784087306876]