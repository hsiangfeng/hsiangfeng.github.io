[{"data":1,"prerenderedAt":78},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F16\u002F":3,"archive-page:zh-Hant:16":4,"author-stats:zh-Hant:full":76},null,{"posts":5,"total":74,"totalPages":75},[6,15,25,31,38,44,50,56,62,68],{"url":7,"title":8,"date":9,"updated":9,"category":10,"tags":11,"description":13,"readingMinutes":14},"\u002Fjavascript\u002F20231021\u002F985189338\u002F","關於封裝 localStorage 的小技巧","2023-10-21 12:58:58","JavaScript",[10,12],"localStorage","在開發網頁時，常常會需要使用到 localStorage 來儲存資料，但是 localStorage 本身的 API 並不是很好用，所以我們可以透過封裝的方式來讓它更好用。","6",{"url":16,"title":17,"date":18,"updated":18,"category":19,"tags":20,"description":23,"readingMinutes":24},"\u002Fnodejs\u002F20231015\u002F3466588754\u002F","Day31 - 目錄與補充資源","2023-10-15 00:00:01","Nodejs",[21,22],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","今天打算做一個總結了，所以這一篇主要就以回顧的方式來做一個總結哩～","3",{"url":26,"title":27,"date":28,"updated":28,"category":19,"tags":29,"description":23,"readingMinutes":30},"\u002Fnodejs\u002F20231014\u002F27552363\u002F","Day30-旅途告一個段落","2023-10-14 00:00:01",[21,22],"2",{"url":32,"title":33,"date":34,"updated":34,"category":19,"tags":35,"description":36,"readingMinutes":37},"\u002Fnodejs\u002F20231013\u002F3280561145\u002F","Day29-關於 JWT 驗證","2023-10-13 00:00:01",[21,22],"接下來這一篇將會來介紹 JWT 的驗證，畢竟前面一直都沒提到，可是實戰上來講卻是非常重要的一環哩。","5",{"url":39,"title":40,"date":41,"updated":41,"category":19,"tags":42,"description":43,"readingMinutes":24},"\u002Fnodejs\u002F20231012\u002F3543796485\u002F","Day28-Google Extension 與 Google Apps Script 蹦再一起","2023-10-12 00:00:01",[21,22],"為了讓我們熟悉 Google Apps Script 的環境，那麼最快的方式就是實作，因此這邊就來整合 Google Extension 吧～",{"url":45,"title":46,"date":47,"updated":47,"category":19,"tags":48,"description":49,"readingMinutes":24},"\u002Fnodejs\u002F20231011\u002F1771923912\u002F","Day27-遇見 Google Apps Script","2023-10-11 00:00:01",[21,22],"OMG，這又是什麼新玩意了，接下來這一篇我們會稍微輕鬆一點來認識 Google Apps Script 是什麼東西，而且實戰上來講，也是非常的方便，因此我們就來看看 Google Apps Script 是什麼東西吧！",{"url":51,"title":52,"date":53,"updated":53,"category":19,"tags":54,"description":55,"readingMinutes":37},"\u002Fnodejs\u002F20231010\u002F3798507505\u002F","Day26-Google Extension 與 Vite","2023-10-10 00:00:01",[21,22],"前一篇我們對於 Google Extension 有了初步的認識，但我們實際開發上來講，必定會使用到人家開發好的套件，所以這一篇就會來使用 Vite 來開發 Google Extension。",{"url":57,"title":58,"date":59,"updated":59,"category":19,"tags":60,"description":61,"readingMinutes":24},"\u002Fnodejs\u002F20231009\u002F609773828\u002F","Day25-Google Extension","2023-10-09 00:00:01",[21,22],"又進入新的章節了，這章節我們要來介紹 Google Extension，那麼 Google Extension 是什麼呢？這一篇就讓我們來簡單的認識一下吧！",{"url":63,"title":64,"date":65,"updated":65,"category":19,"tags":66,"description":67,"readingMinutes":37},"\u002Fnodejs\u002F20231008\u002F2016996949\u002F","Day24-部署到 Zeabur","2023-10-08 00:00:01",[21,22],"前一面我們對於伺服器有基本概念後，接下來當然是要實際部署專案到伺服器上囉～",{"url":69,"title":70,"date":71,"updated":71,"category":19,"tags":72,"description":73,"readingMinutes":24},"\u002Fnodejs\u002F20231007\u002F3219221834\u002F","Day23 - 關於伺服器","2023-10-07 00:00:01",[21,22],"我們介紹了許多知識點，並且也將爬蟲整合進去 Discord Bot 中，但是實際上來講我們不可能都用本地端來啟動 Discord Bot，所以接下來將會來介紹一些關於伺服器與主機的知識點，所以這一篇會相對比較簡單，也算是讓腦袋放鬆一下。",1036,104,{"postCount":74,"tagCount":77},1011,1784087307107]