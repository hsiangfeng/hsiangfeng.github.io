[{"data":1,"prerenderedAt":75},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F16\u002F":3,"archive-page:zh-Hant:16":4,"author-stats:zh-Hant:full":73},null,{"posts":5,"total":71,"totalPages":72},[6,16,22,29,35,41,47,53,59,65],{"url":7,"title":8,"date":9,"updated":9,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20231015\u002F3466588754\u002F","Day31 - 目錄與補充資源","2023-10-15 00:00:01","Nodejs",[12,13],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","今天打算做一個總結了，所以這一篇主要就以回顧的方式來做一個總結哩～","3",{"url":17,"title":18,"date":19,"updated":19,"category":10,"tags":20,"description":14,"readingMinutes":21},"\u002Fnodejs\u002F20231014\u002F27552363\u002F","Day30-旅途告一個段落","2023-10-14 00:00:01",[12,13],"2",{"url":23,"title":24,"date":25,"updated":25,"category":10,"tags":26,"description":27,"readingMinutes":28},"\u002Fnodejs\u002F20231013\u002F3280561145\u002F","Day29-關於 JWT 驗證","2023-10-13 00:00:01",[12,13],"接下來這一篇將會來介紹 JWT 的驗證，畢竟前面一直都沒提到，可是實戰上來講卻是非常重要的一環哩。","5",{"url":30,"title":31,"date":32,"updated":32,"category":10,"tags":33,"description":34,"readingMinutes":15},"\u002Fnodejs\u002F20231012\u002F3543796485\u002F","Day28-Google Extension 與 Google Apps Script 蹦再一起","2023-10-12 00:00:01",[12,13],"為了讓我們熟悉 Google Apps Script 的環境，那麼最快的方式就是實作，因此這邊就來整合 Google Extension 吧～",{"url":36,"title":37,"date":38,"updated":38,"category":10,"tags":39,"description":40,"readingMinutes":15},"\u002Fnodejs\u002F20231011\u002F1771923912\u002F","Day27-遇見 Google Apps Script","2023-10-11 00:00:01",[12,13],"OMG，這又是什麼新玩意了，接下來這一篇我們會稍微輕鬆一點來認識 Google Apps Script 是什麼東西，而且實戰上來講，也是非常的方便，因此我們就來看看 Google Apps Script 是什麼東西吧！",{"url":42,"title":43,"date":44,"updated":44,"category":10,"tags":45,"description":46,"readingMinutes":28},"\u002Fnodejs\u002F20231010\u002F3798507505\u002F","Day26-Google Extension 與 Vite","2023-10-10 00:00:01",[12,13],"前一篇我們對於 Google Extension 有了初步的認識，但我們實際開發上來講，必定會使用到人家開發好的套件，所以這一篇就會來使用 Vite 來開發 Google Extension。",{"url":48,"title":49,"date":50,"updated":50,"category":10,"tags":51,"description":52,"readingMinutes":15},"\u002Fnodejs\u002F20231009\u002F609773828\u002F","Day25-Google Extension","2023-10-09 00:00:01",[12,13],"又進入新的章節了，這章節我們要來介紹 Google Extension，那麼 Google Extension 是什麼呢？這一篇就讓我們來簡單的認識一下吧！",{"url":54,"title":55,"date":56,"updated":56,"category":10,"tags":57,"description":58,"readingMinutes":28},"\u002Fnodejs\u002F20231008\u002F2016996949\u002F","Day24-部署到 Zeabur","2023-10-08 00:00:01",[12,13],"前一面我們對於伺服器有基本概念後，接下來當然是要實際部署專案到伺服器上囉～",{"url":60,"title":61,"date":62,"updated":62,"category":10,"tags":63,"description":64,"readingMinutes":15},"\u002Fnodejs\u002F20231007\u002F3219221834\u002F","Day23 - 關於伺服器","2023-10-07 00:00:01",[12,13],"我們介紹了許多知識點，並且也將爬蟲整合進去 Discord Bot 中，但是實際上來講我們不可能都用本地端來啟動 Discord Bot，所以接下來將會來介紹一些關於伺服器與主機的知識點，所以這一篇會相對比較簡單，也算是讓腦袋放鬆一下。",{"url":66,"title":67,"date":68,"updated":68,"category":10,"tags":69,"description":70,"readingMinutes":28},"\u002Fnodejs\u002F20231006\u002F4255357825\u002F","Day22 - Discord Bot 整合","2023-10-06 00:00:01",[12,13],"前一篇對於 Discord 已經具有一定基礎後，當然要來做一點小東西了，當然不會太難，大多都是前面所寫過跟使用過的東西哩。",1035,104,{"postCount":71,"tagCount":74},1009,1784012758066]