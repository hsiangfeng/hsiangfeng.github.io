[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F75\u002F":3,"archive-page:zh-Hant:75":4,"author-stats:zh-Hant:full":79},null,{"posts":5,"total":77,"totalPages":78},[6,18,26,33,39,45,51,57,65,71],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":16,"readingMinutes":17},"\u002Fphp\u002F20190916\u002F2939346668\u002F","Day15-從基礎學習 ThinkPHP-Model 基礎操作(3)","2019-09-16 00:01:10","PHP",[10,12,13,14,15],"MySQL","ThinkPHP 5.1","從基礎學習 ThinkPHP","第 11 屆 iT邦幫忙鐵人賽","前一篇我們學習透過 Model 來新增資料，那麼查詢呢?查詢資料該怎麼做呢?所以這一篇將會來講該如何使用 Model 做查詢動作。","3",{"url":19,"title":20,"date":21,"updated":3,"category":22,"tags":23,"description":25,"readingMinutes":17},"\u002Fjavascript\u002F20190915\u002F57691927\u002F","EP.0 RE：從零開始的學習 JS 生活-轉生之目錄","2019-09-15 11:06:12","JavaScript",[22,24,15],"RE：從零開始的學習 JS 生活","這一系列是我挑戰同時期鐵人賽的第二篇系列文章，最主要是要講 JavaScript 的部分，但是會比較著重於初心者，嘛都說是從零開始了。",{"url":27,"title":28,"date":29,"updated":3,"category":10,"tags":30,"description":31,"readingMinutes":32},"\u002Fphp\u002F20190915\u002F2341995377\u002F","Day14-從基礎學習 ThinkPHP-Model 基礎操作(2)","2019-09-15 11:04:01",[10,12,13,14,15],"前一篇我們已經將 Model 所需要的起手式給準備得差不多了，接下來將會開始寫一些基礎的資料操作。","2",{"url":34,"title":35,"date":36,"updated":3,"category":10,"tags":37,"description":38,"readingMinutes":32},"\u002Fphp\u002F20190914\u002F278976166\u002F","Day13-從基礎學習 ThinkPHP-Model 基礎操作(1)","2019-09-14 00:09:41",[10,12,13,14,15],"接下來這一篇開始會稍微結合一下前面一些的知識來做 Model 的基礎操作，所以這邊將會結合 Controller 和 Route。",{"url":40,"title":41,"date":42,"updated":3,"category":10,"tags":43,"description":44,"readingMinutes":32},"\u002Fphp\u002F20190913\u002F1270939931\u002F","Day12-從基礎學習 ThinkPHP-Route","2019-09-13 00:01:52",[10,12,13,14,15],"前面了解基礎的 MVC 架構與基本的定義，這邊就來實際操作一下，但是在那之前還要再了解一個東西，也就是 Route，對於現今的開發來講 Route 是非常重要的基礎",{"url":46,"title":47,"date":48,"updated":3,"category":10,"tags":49,"description":50,"readingMinutes":32},"\u002Fphp\u002F20190912\u002F1469012740\u002F","Day11-從基礎學習 ThinkPHP-Model","2019-09-12 00:03:18",[10,12,13,14,15],"這一章節會稍微短一點，主要是介紹基礎的 Model 定義，但是在一般開發下是不太會針對 Model 做太多的設置，所以你會發現這一章節真的比較沒有什麼。",{"url":52,"title":53,"date":54,"updated":3,"category":10,"tags":55,"description":56,"readingMinutes":17},"\u002Fphp\u002F20190911\u002F2404668874\u002F","Day10-從基礎學習 ThinkPHP-View","2019-09-11 00:01:36",[10,12,13,14,15],"接下來這一篇將會介紹 MVC 中的 View，也就是視圖，前一篇我們學習了 Controller 基礎定義，那麼接下來我們就會來學習 View，最後再來學 Model，當然這邊我們也會學習一點點的 HTML Template 唷!",{"url":58,"title":59,"date":60,"updated":3,"category":61,"tags":62,"description":64,"readingMinutes":17},"\u002Fhexo\u002F20190910\u002F3668677278\u002F","自動化部屬 Hexo 文章","2019-09-10 09:12:37","Hexo",[61,63],"Travis CI","最近在部屬文章上感覺越來越麻煩，所以乾脆索性將 Hexo 的部屬改成全自動化的方式。",{"url":66,"title":67,"date":68,"updated":3,"category":10,"tags":69,"description":70,"readingMinutes":32},"\u002Fphp\u002F20190910\u002F533664939\u002F","Day9-從基礎學習 ThinkPHP-Controller","2019-09-10 00:07:30",[10,12,13,14,15],"前面了解了 MVC 架構之後，我們就要準備來撰寫程式碼，首先會寫的是 Controller 的部分，但是在那之前會有一些地方要先改一下設置，這樣才能方便我們開發。",{"url":72,"title":73,"date":74,"updated":3,"category":10,"tags":75,"description":76,"readingMinutes":32},"\u002Fphp\u002F20190909\u002F3519693707\u002F","Day8-從基礎學習 ThinkPHP-MVC 模式","2019-09-09 08:27:39",[10,12,13,14,15],"在準備學習後面章節之前，我必須先說一聲抱歉，我又要卡一下，最主要我們必須先了解何謂 MVC(Model-View-Controller) 架構，所以這章節將會稍微介紹一下 MVC 架構是什麼，那這個觀念有助於我們後面的開發。",1035,104,{"postCount":77,"tagCount":80},1009,1784020335151]