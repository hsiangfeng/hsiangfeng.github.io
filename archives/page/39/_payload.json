[{"data":1,"prerenderedAt":109},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F39\u002F":3,"archive-page:zh-Hant:39":4,"author-stats:zh-Hant:full":107},null,{"posts":5,"total":105,"totalPages":106},[6,16,27,44,54,66,72,79,87,96],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fjavascript\u002F20211208\u002F1819989996\u002F","JavaScript 核心觀念(73) - Promise - 為什麼需要 Promise","2021-12-08 21:34:53","JavaScript",[10,12,13],"JavaScript 核心篇","Promise","接下來將會介紹 Promise 的部分，實戰開發上或許你已經有在使用，只是不知道那是使用 Promise 包裝而已。","1",{"url":17,"title":18,"date":19,"updated":3,"category":20,"tags":21,"description":25,"readingMinutes":26},"\u002Fother\u002F20211207\u002F427026\u002F","跟著我一起快速入門 Postman 吧！","2021-12-07 09:24:48","雜談",[22,23,24],"Postman","Postman 基礎","Postman 教學","Postman 在開發上是非常常使用的工具，畢竟很多時候我們會先使用 Postman 測試 API 是否正常，否則實際接上 API 後才發現問題，那麼就會非常花時間在 debug 上，因此就誕生了這一篇 Postman 教學。","4",{"url":28,"title":29,"date":30,"updated":3,"category":31,"tags":32,"description":42,"readingMinutes":43},"\u002Fnuxt\u002F20211205\u002F3240380460\u002F","Nuxt.js 2.x 實戰手冊(5) - 生命週期(lifecycle)","2021-12-05 15:18:00","Nuxt",[33,34,35,36,37,38,39,40,41],"Vue.js","Nuxt.js","Nuxt.js 2.x","lifecycle","nuxtServerInit","middleware","validate","asyncData","fetch","接下來要聊一下 Nuxt.js 中很重要的東西，也就是生命週期，而這個生命週期是會大大影響你的 SSR 結果與 SEO 的。","3",{"url":45,"title":46,"date":47,"updated":3,"category":20,"tags":48,"description":52,"readingMinutes":53},"\u002Fother\u002F20211204\u002F2579354992\u002F","究竟有哪些實用的擴充外掛(Browser extension)？","2021-12-04 21:49:43",[49,50,51],"Browser extension","Chrome extension","Firefox extension","瀏覽器的擴充套件類型非常的多，那麼對於一名工程師來講又有哪些實用的擴充套件呢？所以這一篇就介紹一下我本身有安裝的擴充套件有哪些，那麼由於我主要使用 Firefox 瀏覽器，但我也會盡可能同步提供 Chrome 的擴充套件連結。","2",{"url":55,"title":56,"date":57,"updated":3,"category":10,"tags":58,"description":64,"readingMinutes":65},"\u002Fjavascript\u002F20211128\u002F2950137358\u002F","JavaScript 中的 Promise 是什麼？以及為什麼你要懂 Promise","2021-11-28 16:19:37",[13,59,60,10,61,62,63,41],"Async","Await","ES7","ES6","axios","那麼這一篇會來談談什麼是 Promise 以及 Async\u002FAwait 語法。","6",{"url":67,"title":68,"date":69,"updated":3,"category":31,"tags":70,"description":71,"readingMinutes":15},"\u002Fnuxt\u002F20211127\u002F4244409331\u002F","Nuxt.js 2.x 實戰手冊(4) - Nuxt.js 運作","2021-11-27 23:09:42",[33,34,35],"接下來這一篇會簡單聊一下關於 Nuxt.js 的運作。",{"url":73,"title":74,"date":75,"updated":3,"category":10,"tags":76,"description":78,"readingMinutes":43},"\u002Fjavascript\u002F20211126\u002F12988607\u002F","JavaScript 錯誤類型(JavaScript Error Reference)","2021-11-26 21:19:42",[10,77],"Error Reference","這一篇稍微整理一下 JavaScript 中各種錯誤的訊息，畢竟開發上我們是很常看到紅色的錯誤訊息，若能夠快速掌握錯誤訊息的類型的話，其實也可以幫助我們 debug。",{"url":80,"title":81,"date":82,"updated":3,"category":20,"tags":83,"description":86,"readingMinutes":43},"\u002Fother\u002F20211125\u002F356203095\u002F","淺談 API 與 RESTful API","2021-11-25 21:38:05",[84,85],"RESTful API","API","RESTful API 可以說是非常常聽到的一個名詞，身為前端開發者來講更是容易接觸到，那什麼是 RESTful API 呢？這一篇就讓我們來聊聊什麼是 RESTful API 吧。",{"url":88,"title":89,"date":90,"updated":3,"category":91,"tags":92,"description":95,"readingMinutes":15},"\u002Fvscode\u002F20211123\u002F335355052\u002F","將 VSCode 的程式碼行數改成相對(值)行數","2021-11-23 14:29:07","VSCode",[93,94,91],"Vim","Vi","最近開始已經慢慢在嘗試使用 vim\u002Fvi 在 VSCode 上面開發以及撰寫文章，所以這邊就順便紀錄一下如何開啟 VSCode 的相對行數顯示。",{"url":97,"title":98,"date":99,"updated":99,"category":100,"tags":101,"description":104,"readingMinutes":43},"\u002Flearnexp\u002F20211122\u002F1862504277\u002F","【91 極速開發+】課後心得","2021-11-22 17:34:18","學習經驗",[102,103,100],"91 極速開發+","課後心得","其實認真講【91 極速開發+】就是想要解決開發上總是在哀嚎的一個問題「時間不夠」，所以就被公司推坑去上了，那不免也寫一篇新的來分享課後心得。",1035,104,{"postCount":105,"tagCount":108},1009,1784020333151]