[{"data":1,"prerenderedAt":86},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F77\u002F":3,"archive-page:zh-Hant:77":4,"author-stats:zh-Hant:full":84},null,{"posts":5,"total":82,"totalPages":83},[6,15,24,30,36,45,52,59,67,73],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":13,"readingMinutes":14},"\u002Fhexo\u002F20190817\u002F3015878257\u002F","替 Hexo NexT 增加字數統計","2019-08-17 21:51:19","Hexo",[10,12],"NexT","有時候自己會需要翻一下自己某一篇文章寫得字數以及大約閱讀所需要的時間，所以這一篇就來記錄一下該如何替 Hexo NexT 安裝字數統計以及閱讀時間吧","1",{"url":16,"title":17,"date":18,"updated":3,"category":19,"tags":20,"description":22,"readingMinutes":23},"\u002Fvue\u002F20190816\u002F3627128539\u002F","Nuxt.js 導航守衛","2019-08-16 13:01:13","Vue",[19,21],"Nuxt","這一篇將會記錄該如何製作導航守衛，由於一般情況下 Nuxt 做法與在 Vue 下是不同的，所以就記錄一下該如何製作 Nuxt 導航守衛吧","2",{"url":25,"title":26,"date":27,"updated":3,"category":19,"tags":28,"description":29,"readingMinutes":23},"\u002Fvue\u002F20190810\u002F3385236004\u002F","Nuxt Route 設置","2019-08-10 22:29:02",[19,21],"Nuxt 生成 route 的方式比較不太一樣，這邊實作順便記錄一下",{"url":31,"title":32,"date":33,"updated":3,"category":19,"tags":34,"description":35,"readingMinutes":23},"\u002Fvue\u002F20190809\u002F3851611159\u002F","建立一個 NuxtJS 專案吧!","2019-08-09 15:49:13",[19,21],"由於最近在接觸 NuxtJS 的專案，所以這邊紀錄一下該如何起手建立專案",{"url":37,"title":38,"date":39,"updated":39,"category":40,"tags":41,"description":43,"readingMinutes":44},"\u002Flearnexp\u002F20190807\u002F1019052281\u002F","邀請講師的許多不小的小細節","2019-08-07 15:21:42","學習經驗",[42,40],"其他","這一篇主要會記錄關於我邀請講師時，許多細節部分，因為大多時候我們都會忽略這些細節","5",{"url":46,"title":47,"date":48,"updated":3,"category":19,"tags":49,"description":51,"readingMinutes":14},"\u002Fvue\u002F20190804\u002F3203626423\u002F","Vue 出一個女友吧!-前端頁面","2019-08-04 15:27:25",[19,50],"Vue 出一個女友吧","接下來將會開始紀錄前端頁面的開發，先來講講自己的開發習慣",{"url":53,"title":54,"date":55,"updated":3,"category":56,"tags":57,"description":58,"readingMinutes":14},"\u002Fcss\u002F20190803\u002F1860685658\u002F","純 CSS 愛心繪畫方式","2019-08-03 16:40:36","CSS",[56],"由於在製作 Vue 出一個女友的練習發現有一個 CSS 不會寫，所以這邊紀錄一下該如何用 CSS 寫出一個愛心~",{"url":60,"title":61,"date":62,"updated":3,"category":63,"tags":64,"description":66,"readingMinutes":14},"\u002Fgit\u002F20190802\u002F1198998279\u002F","GitHub 重新命名分支名稱","2019-08-02 10:52:04","Git",[65,63],"GitHub","有時候我們在開發的時候會遇到需要重新命名 GitHub 分支，但是總不能用刪除分支的方式來做處理，這樣子會導致先前的 commit 紀錄都消失，所以就來記錄一下該如何重新命名分支並 push 到 GitHub 上吧",{"url":68,"title":69,"date":70,"updated":3,"category":19,"tags":71,"description":72,"readingMinutes":14},"\u002Fvue\u002F20190801\u002F1336347183\u002F","Vue 出一個女友吧!-中場休息","2019-08-01 10:54:29",[19,50],"這一篇主要是紀錄目前做了哪些功能，所以並不會有太多技術性的東西",{"url":74,"title":75,"date":76,"updated":3,"category":77,"tags":78,"description":81,"readingMinutes":14},"\u002Fnodejs\u002F20190801\u002F449913843\u002F","無法辨識 'XXX' 詞彙是否為 Cmdlet、函數、指令檔或可執行程式的名稱","2019-08-01 10:28:33","Nodejs",[79,80],"Node.js","障礙排除","Windows PowerShell 突然每個指令都跳「無法辨識 XXX 詞彙是否為 Cmdlet」？這一篇分享我試過移除套件、重裝 Node 都無效之後， 從環境變數 Path 找到的真正解法。",1036,104,{"postCount":82,"tagCount":85},1011,1784087308835]