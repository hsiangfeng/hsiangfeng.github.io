[{"data":1,"prerenderedAt":78},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F17\u002F":3,"archive-page:zh-Hant:17":4,"author-stats:zh-Hant:full":76},null,{"posts":5,"total":74,"totalPages":75},[6,16,23,30,36,42,49,55,62,68],{"url":7,"title":8,"date":9,"updated":9,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20231006\u002F4255357825\u002F","Day22 - Discord Bot 整合","2023-10-06 00:00:01","Nodejs",[12,13],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","前一篇對於 Discord 已經具有一定基礎後，當然要來做一點小東西了，當然不會太難，大多都是前面所寫過跟使用過的東西哩。","5",{"url":17,"title":18,"date":19,"updated":19,"category":10,"tags":20,"description":21,"readingMinutes":22},"\u002Fnodejs\u002F20231005\u002F1512925992\u002F","Day21 - Discord 基礎","2023-10-05 00:00:01",[12,13],"在前一篇我們準備好了 Discord 基本的一些東西與設定，接下來當然要繼續聊 Discord 的部分囉～","4",{"url":24,"title":25,"date":26,"updated":26,"category":10,"tags":27,"description":28,"readingMinutes":29},"\u002Fnodejs\u002F20231004\u002F1031795777\u002F","Day20 - Discord Bot？","2023-10-04 00:00:01",[12,13],"除了爬蟲之外，Node.js 可以做的事情其實非常多，所以接下來將會介紹一些其他的應用的實作，也就是 Bot。","3",{"url":31,"title":32,"date":33,"updated":33,"category":10,"tags":34,"description":35,"readingMinutes":22},"\u002Fnodejs\u002F20231003\u002F1830434204\u002F","Day19 - Crontab + Node.js","2023-10-03 00:00:01",[12,13],"前一篇我們對於 Crontab 已經有一個基本的概念，接下來當然要套用到實戰上，不然認識了也沒用，所以這一篇我們就來實作一個 Crontab + Node.js 的範例。",{"url":37,"title":38,"date":39,"updated":39,"category":10,"tags":40,"description":41,"readingMinutes":29},"\u002Fnodejs\u002F20231002\u002F2297973079\u002F","Day18 - 初識 Crontab","2023-10-02 00:00:01",[12,13],"看到現在，你也應該學了不少知識了，你應該會發現有些系統好像都會「自動」去做某些事情，所以接下來將會來介紹例行性工作排程 (crontab) 這個東西。",{"url":43,"title":44,"date":45,"updated":45,"category":10,"tags":46,"description":47,"readingMinutes":48},"\u002Fnodejs\u002F20231001\u002F2119244773\u002F","Day17 - 續談爬蟲（下）","2023-10-01 00:00:01",[12,13],"這一篇將會接續前一篇的文章內容，繼續把前一篇沒講完的爬蟲內容給補完。","6",{"url":50,"title":51,"date":52,"updated":52,"category":10,"tags":53,"description":54,"readingMinutes":48},"\u002Fnodejs\u002F20230930\u002F4076915411\u002F","Day16 - 續談爬蟲（上）","2023-09-30 00:00:01",[12,13],"接下來這一篇也是針對爬蟲來介紹，但是會去撈一些比較複雜的資料。",{"url":56,"title":57,"date":58,"updated":59,"category":10,"tags":60,"description":61,"readingMinutes":15},"\u002Fnodejs\u002F20230929\u002F3878806252\u002F","Day15 - 第一個爬蟲","2023-09-29 00:00:01","2023-11-19 00:00:01",[12,13],"前一篇我們對於爬蟲應該有一些基本的概念與認知了，接下來當然就是要來實作一下囉。",{"url":63,"title":64,"date":65,"updated":65,"category":10,"tags":66,"description":67,"readingMinutes":29},"\u002Fnodejs\u002F20230928\u002F2824059455\u002F","Day14 - 網頁爬蟲？","2023-09-28 00:00:01",[12,13],"這一篇基本上我打算輕鬆一點介紹爬蟲就好，所以這一篇的篇幅或許會比以往前面少很多，主要也是讓大腦可以輕鬆一點。",{"url":69,"title":70,"date":71,"updated":71,"category":10,"tags":72,"description":73,"readingMinutes":22},"\u002Fnodejs\u002F20230927\u002F4133508926\u002F","Day13 - 替你的 Express 戴上頭盔吧！","2023-09-27 00:00:01",[12,13],"前面介紹了 CORS 跟 Env 可以說是基本的基本，接下來要來介紹一個很特別的東西，叫做 Helmet。",1036,104,{"postCount":74,"tagCount":77},1011,1784087307121]