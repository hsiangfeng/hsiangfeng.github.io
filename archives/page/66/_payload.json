[{"data":1,"prerenderedAt":89},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F66\u002F":3,"archive-page:zh-Hant:66":4,"author-stats:zh-Hant:full":87},null,{"posts":5,"total":85,"totalPages":86},[6,15,24,34,43,51,58,64,70,76],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":13,"readingMinutes":14},"\u002Fjavascript\u002F20200313\u002F3743352418\u002F","淺談 JavaScript 中的 Debug 神器 Console","2020-03-13 10:51:48","JavaScript",[10,12],"console","在寫 JavaScript 時，其實我們會很長使用 console 來 debug，所以這一篇來淺談一下 console 吧。","2",{"url":16,"title":17,"date":18,"updated":3,"category":19,"tags":20,"description":22,"readingMinutes":23},"\u002Fvscode\u002F20200312\u002F457161302\u002F","Visual Studio Code(VSCode) 1.43 高亮問題","2020-03-12 10:20:20","VSCode",[19,21],"障礙排除","這幾天 Visual Studio Code(VSCode) 更新成了 1.43，但卻發生高亮不太正常?!不知道是刻意改的還是不正常的關係，所以這一篇紀錄一下該如何解決。","1",{"url":25,"title":26,"date":27,"updated":3,"category":10,"tags":28,"description":33,"readingMinutes":14},"\u002Fjavascript\u002F20200309\u002F2684951958\u002F","PixiJS V5 教學 (5) - Texture","2020-03-09 08:15:00",[29,30,10,31,32],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","有引入文字那麼就會有引入圖片啦~而 PIXI 會使用 GPU 以及 WebGL 來渲染圖片，而圖片需要經過處理才能夠使用的，而通常處理好的圖片都會稱為 Texture。",{"url":35,"title":36,"date":37,"updated":3,"category":10,"tags":38,"description":41,"readingMinutes":42},"\u002Fjavascript\u002F20200308\u002F3384986223\u002F","Fetch API 到底是 ESMAScript6 還是 Web APIs?","2020-03-08 12:07:26",[10,39,40],"ESMAScript6","Fetch API","Fetch API 是一個很多人會誤解的一個語法，最大誤解大概就是無法區分這一個語法到底是屬於 ECMAScript6 還是 Web APIs，所以這一篇來詳解一下吧。","3",{"url":44,"title":45,"date":46,"updated":3,"category":10,"tags":47,"description":50,"readingMinutes":42},"\u002Fjavascript\u002F20200307\u002F1405700237\u002F","JavaScript 核心觀念(1)-執行環境與作用域-JavaScript 運作方式","2020-03-07 21:37:04",[10,48,49],"JavaScript 核心篇","執行環境與作用域","第一篇將會來了解 JavaScript 的運作模式，",{"url":52,"title":53,"date":54,"updated":3,"category":10,"tags":55,"description":56,"readingMinutes":57},"\u002Fjavascript\u002F20200307\u002F318160061\u002F","JavaScript 核心觀念(0)-目錄及前言","2020-03-07 21:27:49",[10,48],"JavaScript 核心篇是基於六角學院的線上影音課程而撰寫的系列文章，雖然自己本身已經有上過 JavaScript 奇怪的部份，但每一位講者都有屬於他的講解方式，所以這一篇也來開始做一次紀錄以及學習囉。","4",{"url":59,"title":60,"date":61,"updated":3,"category":10,"tags":62,"description":63,"readingMinutes":14},"\u002Fjavascript\u002F20200302\u002F3104976087\u002F","PixiJS V5 教學 (4) - Text","2020-03-02 09:00:10",[29,30,10,31,32],"前一篇介紹了 Container，接下來要來看介紹前一篇所使用到的語法，也就是 new PIXI.Text()。",{"url":65,"title":66,"date":67,"updated":3,"category":10,"tags":68,"description":69,"readingMinutes":14},"\u002Fjavascript\u002F20200224\u002F4132682256\u002F","PixiJS V5 教學 (3) - Container","2020-02-24 08:17:13",[29,30,10,31,32],"前面基本知識也算是講得差不多，接下來將會介紹 PIXI 中的一個重要的東西，也就是 Container。",{"url":71,"title":72,"date":73,"updated":3,"category":10,"tags":74,"description":75,"readingMinutes":14},"\u002Fjavascript\u002F20200217\u002F4014508881\u002F","PixiJS V5 教學 (2) - WebGL 以及 Renderer","2020-02-17 00:05:28",[29,30,10,31,32],"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",{"url":77,"title":78,"date":79,"updated":3,"category":80,"tags":81,"description":84,"readingMinutes":57},"\u002Fvue\u002F20200214\u002F1055437216\u002F","一個指令快速部署 Vue Cli 到 GitHub Pages","2020-02-14 08:47:16","Vue",[10,80,82,83],"GitHub","Git","一般來說我們使用 Vue Cli 開發一個作品完畢之後都會需要部署到特定空間來展示作品，舉例來講 GitHub Pages 就是一個，那麼這一篇就來介紹該如何一個指令快速部署吧。",1036,104,{"postCount":85,"tagCount":88},1011,1784087308514]