[{"data":1,"prerenderedAt":53},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F104\u002F":3,"archive-page:zh-Hant:104":4,"author-stats:zh-Hant:full":51},null,{"posts":5,"total":49,"totalPages":50},[6,14,22,30,36,43],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":12,"readingMinutes":13},"\u002Fhtml\u002F20190415\u002F3620209158\u002F","HTML常用標籤認識","2019-04-15 15:59:26","HTML",[10],"HTML 標籤其實非常多，所以特別寫一篇記錄一下常用的標籤有哪些，順便做一下解釋紀錄...","5",{"url":15,"title":16,"date":17,"updated":3,"category":18,"tags":19,"description":20,"readingMinutes":21},"\u002Fcss\u002F20190413\u002F2684450192\u002F","中國第五屆CSS開發者大會@張鑫旭","2019-04-13 23:10:52","CSS",[18],"今年2019年3月20日，中國在深圳舉辦了由 W3C、 W3ctech的 CSS 開發者大會，目前在 Youtube 也有影片可以觀看，在這邊作為一個紀錄練習，本文參考張鑫旭來製作撰寫。","8",{"url":23,"title":24,"date":25,"updated":3,"category":26,"tags":27,"description":28,"readingMinutes":29},"\u002Fhexo\u002F20190413\u002F2508191011\u002F","Hexo側邊欄修改","2019-04-13 13:32:30","Hexo",[26],"Hexo 的側邊欄的修改大多都是在 _config.yml，這邊以 NexT 為例紀錄一下該如何增加頭像，如果要讓分類功能、標籤功能有效果則必須參考另一篇文章>Hexo新增標籤及分類頁面","1",{"url":31,"title":32,"date":33,"updated":3,"category":26,"tags":34,"description":35,"readingMinutes":29},"\u002Fhexo\u002F20190413\u002F1568146247\u002F","Hexo新增標籤及分類頁面","2019-04-13 13:06:39",[26],"由於標籤頁面及分類頁面必須由人工生成，所以這邊紀錄一下如何生成。",{"url":37,"title":38,"date":39,"updated":3,"category":18,"tags":40,"description":41,"readingMinutes":42},"\u002Fcss\u002F20190412\u002F3562360359\u002F","六角學院-FLEXPIRATE","2019-04-12 20:39:12",[18],"六角學院是一個致力於提供學生舞台的線上教學平台，昨天開放了一個 FLEXPIRATE 遊戲，而本身就是六角學院的學生當然要去玩一下，所以在這邊做一些紀錄學習。","4",{"url":44,"title":45,"date":46,"updated":3,"category":26,"tags":47,"description":48,"readingMinutes":42},"\u002Fhexo\u002F20190411\u002F932826160\u002F","架設 Hexo+GitHub","2019-04-11 11:39:13",[26],"網路上已經有許多教學如何架設 Hexo+GitHub，但是因為自己本身要建設一個純技術 Blog，所以這邊就做一下紀錄該如何架設 Hexo 並佈署 GitHub。",1036,104,{"postCount":49,"tagCount":52},1011,1784087306963]