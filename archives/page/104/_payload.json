[{"data":1,"prerenderedAt":45},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F104\u002F":3,"archive-page:zh-Hant:104":4,"author-stats:zh-Hant:full":43},null,{"posts":5,"total":41,"totalPages":42},[6,14,22,28,35],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":12,"readingMinutes":13},"\u002Fcss\u002F20190413\u002F2684450192\u002F","中國第五屆CSS開發者大會@張鑫旭","2019-04-13 23:10:52","CSS",[10],"今年2019年3月20日，中國在深圳舉辦了由 W3C、 W3ctech的 CSS 開發者大會，目前在 Youtube 也有影片可以觀看，在這邊作為一個紀錄練習，本文參考張鑫旭來製作撰寫。","8",{"url":15,"title":16,"date":17,"updated":3,"category":18,"tags":19,"description":20,"readingMinutes":21},"\u002Fhexo\u002F20190413\u002F2508191011\u002F","Hexo側邊欄修改","2019-04-13 13:32:30","Hexo",[18],"Hexo 的側邊欄的修改大多都是在 _config.yml，這邊以 NexT 為例紀錄一下該如何增加頭像，如果要讓分類功能、標籤功能有效果則必須參考另一篇文章>Hexo新增標籤及分類頁面","1",{"url":23,"title":24,"date":25,"updated":3,"category":18,"tags":26,"description":27,"readingMinutes":21},"\u002Fhexo\u002F20190413\u002F1568146247\u002F","Hexo新增標籤及分類頁面","2019-04-13 13:06:39",[18],"由於標籤頁面及分類頁面必須由人工生成，所以這邊紀錄一下如何生成。",{"url":29,"title":30,"date":31,"updated":3,"category":10,"tags":32,"description":33,"readingMinutes":34},"\u002Fcss\u002F20190412\u002F3562360359\u002F","六角學院-FLEXPIRATE","2019-04-12 20:39:12",[10],"六角學院是一個致力於提供學生舞台的線上教學平台，昨天開放了一個 FLEXPIRATE 遊戲，而本身就是六角學院的學生當然要去玩一下，所以在這邊做一些紀錄學習。","4",{"url":36,"title":37,"date":38,"updated":3,"category":18,"tags":39,"description":40,"readingMinutes":34},"\u002Fhexo\u002F20190411\u002F932826160\u002F","架設 Hexo+GitHub","2019-04-11 11:39:13",[18],"網路上已經有許多教學如何架設 Hexo+GitHub，但是因為自己本身要建設一個純技術 Blog，所以這邊就做一下紀錄該如何架設 Hexo 並佈署 GitHub。",1035,104,{"postCount":41,"tagCount":44},1009,1784010260324]