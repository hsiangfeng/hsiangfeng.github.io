[{"data":1,"prerenderedAt":77},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F98\u002F":3,"archive-page:zh-Hant:98":4,"author-stats:zh-Hant:full":75},null,{"posts":5,"total":73,"totalPages":74},[6,14,23,30,36,42,48,55,61,67],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":12,"readingMinutes":13},"\u002Fhexo\u002F20190517\u002F1811593244\u002F","Hexo 壓縮相關檔案","2019-05-17 21:05:19","Hexo",[10],"當 Hexo 寫到一定程度時速度會越來越慢，這時候可以嘗試做一些壓縮的動作，舉凡壓縮js、HTML等進而減少使用者要載入的時間。","1",{"url":15,"title":16,"date":17,"updated":3,"category":18,"tags":19,"description":22,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190517\u002F1261168016\u002F","[JS奇怪的世界]No.23 物件與物件實體","2019-05-17 15:26:00","克服JS奇怪的部分系列",[20,21],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分","這章節準備來講解另一種建立物件的方式，還記得上一個章節我們是使用 `new Object();` 來建立物件的吧?其實這個方式對於開發者來講非常不直覺 ↓",{"url":24,"title":25,"date":26,"updated":3,"category":18,"tags":27,"description":28,"readingMinutes":29},"\u002Fjsweirdworld\u002F20190517\u002F4033482277\u002F","[JS奇怪的世界]No.22 物件與「點」","2019-05-17 14:30:00",[20,21],"接下來是一個新的章節，物件與函數，許多課程都會將 JavaScript 中的這兩個東西當成不同的主題在教導，但這其實是一個天大的錯誤，why? 在其他的程式語言裡面這兩者確實是不同的主題，但 JavaScript 世界中這兩者就非常的有相關。","2",{"url":31,"title":32,"date":33,"updated":3,"category":18,"tags":34,"description":35,"readingMinutes":29},"\u002Fjsweirdworld\u002F20190517\u002F3961604918\u002F","[JS奇怪的世界]No.21 框架小叮嚀:預設值","2019-05-17 13:22:00",[20,21],"接下來將針對框架做一個小觀念叮嚀，這邊課程講解的是 jQuery，為什麼會拿 jQuery 來講解呢呢?以前最熱門的框架非 jQuery 莫屬，舉凡動畫效果等等都是由 jQuery 一手包辦，並不用說瀏覽器適應問題，所以這章節拿 jQuery 來作範例再適合不過了。",{"url":37,"title":38,"date":39,"updated":3,"category":18,"tags":40,"description":41,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190517\u002F600418516\u002F","[JS奇怪的世界]No.20 預設值","2019-05-17 12:22:00",[20,21],"上一章節講解了強制轉型的一些特性，所以這堂課將會試著從另一個角度去利用它的特性，首先課程提供了範例程式碼 ↓",{"url":43,"title":44,"date":45,"updated":3,"category":18,"tags":46,"description":47,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190517\u002F3849161770\u002F","[JS奇怪的世界]No.19 存在與布林值","2019-05-17 11:16:35",[20,21],"一般來講我們可以手動使用 Boolean、Number 等函數來做強制轉型的動作，但是課程也是強調不要這樣做(手動轉型)，但是用來展示效果是可以的，舉例我們將 undefined 轉換成布林值 ↓",{"url":49,"title":50,"date":51,"updated":3,"category":10,"tags":52,"description":54,"readingMinutes":13},"\u002Fhexo\u002F20190517\u002F2562079032\u002F","Hexo Url優化(SEO)","2019-05-17 10:05:19",[10,53],"SEO","由於 Hexo 本身 Url 的 SEO 狀況並不是設計非常漂亮，因為在 SEO 規範中文連結遠比英文連結差，所以這邊紀錄一下該如何使用。",{"url":56,"title":57,"date":58,"updated":3,"category":18,"tags":59,"description":60,"readingMinutes":29},"\u002Fjsweirdworld\u002F20190516\u002F803766782\u002F","[JS奇怪的世界]No.18 比較運算子","2019-05-16 21:16:35",[20,21],"將下來講講 小於運算子，讓我們試著用程式碼來講解。",{"url":62,"title":63,"date":64,"updated":3,"category":18,"tags":65,"description":66,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190516\u002F3588659278\u002F","[JS奇怪的世界]No.17 觀念小叮嚀:強制轉型","2019-05-16 21:01:35",[20,21],"強制轉型的意思是什麼?就是將原本的型別轉換成另一種，例如 String 變成 Boolean。",{"url":68,"title":69,"date":70,"updated":3,"category":18,"tags":71,"description":72,"readingMinutes":13},"\u002Fjsweirdworld\u002F20190516\u002F3658238475\u002F","[JS奇怪的世界]No.16 運算子的優先性與相依性","2019-05-16 20:34:35",[20,21],"這兩個在 JavaScript 是一個非常重要的名詞，其實非常重要的觀念，如果能瞭解其觀念，對於 debug 上是有一定幫助的。",1036,104,{"postCount":73,"tagCount":76},1011,1784087309493]