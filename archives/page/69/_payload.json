[{"data":1,"prerenderedAt":95},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F69\u002F":3,"archive-page:zh-Hant:69":4,"author-stats:zh-Hant:full":93},null,{"posts":5,"total":91,"totalPages":92},[6,16,23,29,44,50,62,68,78,84],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":14,"readingMinutes":15},"\u002Fhexo\u002F20191206\u002F2397475810\u002F","十分鐘超詳細替 Hexo Next 開啟 Gitalk 留言版","2019-12-06 20:10:01","Hexo",[10,12,13],"GitHub","Gitalk","最近決定將自己使用約快一年的 Disqus 換成 GitHub Gitalk，最主要原因是 Disqus 許多人留言常常收不到通知，發現的時候都已經過兩個禮拜甚至三個月以上，所以這一篇就來介紹如何快速開啟 Gitalk 吧!","2",{"url":17,"title":18,"date":19,"updated":3,"category":20,"tags":21,"description":22,"readingMinutes":15},"\u002Fpwa\u002F20191203\u002F2841782636\u002F","Day6-PWA 初體驗 - 小試身手","2019-12-03 09:53:48","PWA",[20],"前面真的講滿多廢話的，接下來這邊就準備拿一個小專案來小試身手囉~",{"url":24,"title":25,"date":26,"updated":3,"category":20,"tags":27,"description":28,"readingMinutes":15},"\u002Fpwa\u002F20191126\u002F3955439291\u002F","Day5-PWA 初體驗 - 開發環境","2019-11-26 09:24:48",[20],"前面講那麼多東西，也認識了基本的 PWA 架構，接下來就要來準備一下開發環境了。",{"url":30,"title":31,"date":32,"updated":3,"category":33,"tags":34,"description":42,"readingMinutes":43},"\u002Fjavascript\u002F20191119\u002F2727084611\u002F","有點長的淺談 JavaScript function 函式","2019-11-19 21:11:19","JavaScript",[33,35,36,37,38,39,40,41],"Function","Named Function","Anonymous Function","Arrow Function","IIFE","Vue","ES6","昨天在六角學院做了線上直播的介紹，過程真的是緊張到爆炸，我知道自己其實滿容易健忘的，所以不寫文章筆記心裡有點過意不去，因此這一篇 「有點長的淺談 JavaScript function 函式」就誕生了。","7",{"url":45,"title":46,"date":47,"updated":3,"category":20,"tags":48,"description":49,"readingMinutes":15},"\u002Fpwa\u002F20191114\u002F405525681\u002F","Day4-PWA 初體驗 - PWA 架構(二)","2019-11-14 22:56:48",[20],"這一篇將會介紹 PWA 的核心，也就是 Service Workers。",{"url":51,"title":52,"date":53,"updated":54,"category":55,"tags":56,"description":60,"readingMinutes":61},"\u002Fother\u002F20191111\u002F1875438261\u002F","Markdown 入門教學：常見語法與範例完整整理","2019-11-11 09:48:27","2026-03-18 13:20:00","雜談",[57,58,59],"Markdown","Markdown 教學","Markdown 語法","一篇涵蓋所有常見 Markdown 語法的入門教學，從標題、粗體、清單到表格與程式碼區塊，每個語法皆附範例與對應的 HTML 標籤說明，幫助你快速上手 Markdown 寫作。","4",{"url":63,"title":64,"date":65,"updated":3,"category":20,"tags":66,"description":67,"readingMinutes":15},"\u002Fpwa\u002F20191104\u002F3071954899\u002F","Day3-PWA 初體驗 - PWA 架構(一)","2019-11-04 17:24:48",[20],"接下來這一篇將會來了解 PWA 的架構，但是這邊將會拆成兩個章節介紹。",{"url":69,"title":70,"date":71,"updated":3,"category":55,"tags":72,"description":76,"readingMinutes":77},"\u002Fother\u002F20191028\u002F864994619\u002F","軟體工程師必學的文字對話藝術","2019-10-28 21:28:54",[73,74,75],"其他","軟體工程師","文字對話藝術","文字交流上其實有許多非常需要注意的事情，看似單純幾個中文字，但真正傳遞的感受是不同的，尤其是身為軟體工程師這個行業更不用說最常使用文字與他人溝通，所以這一篇將會來集中討論關於文字對話上的藝術。","5",{"url":79,"title":80,"date":81,"updated":3,"category":20,"tags":82,"description":83,"readingMinutes":15},"\u002Fpwa\u002F20191024\u002F1480429268\u002F","Day2-PWA 初體驗 - PWA 特色","2019-10-24 19:24:48",[20],"這一篇將會來介紹如何開啟 PWA 的特色。",{"url":85,"title":86,"date":87,"updated":87,"category":88,"tags":89,"description":90,"readingMinutes":61},"\u002Flearnexp\u002F20191020\u002F1606493563\u002F","2019 MOPCON 一日遊記","2019-10-20 18:02:46","學習經驗",[73,88],"由於 MOPCON 第一天有點事情所以只去第二天，這一篇就來記錄一下 MOPCON 第二天的一日遊吧。",1036,104,{"postCount":91,"tagCount":94},1011,1784087308593]