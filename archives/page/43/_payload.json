[{"data":1,"prerenderedAt":89},["ShallowReactive",2],{"header-locale:\u002Farchives\u002Fpage\u002F43\u002F":3,"archive-page:zh-Hant:43":4,"author-stats:zh-Hant:full":87},null,{"posts":5,"total":85,"totalPages":86},[6,18,29,38,45,52,58,66,72,78],{"url":7,"title":8,"date":9,"updated":3,"category":10,"tags":11,"description":16,"readingMinutes":17},"\u002Fother\u002F20210928\u002F2005731696\u002F","Postman 如何使用 HMAC 以 TDX API 為例","2021-09-28 11:55:21","雜談",[12,13,14,15],"Postman","TDX API","HMAC","jsSHA","由於近期 The F2E 第三屆準備開跑了，那身為工程師最常用的 Postman 就會很常被拿來試戳 API，所以就紀錄一下如何使用 Postman 戳 TDX API。","2",{"url":19,"title":20,"date":21,"updated":3,"category":22,"tags":23,"description":27,"readingMinutes":28},"\u002Fpython\u002F20210928\u002F4211341551\u002F","從 JavaScript 角度學 Python(27) - 傳值？傳參考？","2021-09-28 00:00:10","Python",[22,24,25,26],"JavaScript","從 JavaScript 角度學 Python","第 13 屆 iT邦幫忙鐵人賽","已經快到鐵人賽的結尾了，但是我現在才想到我好像少講了一個東西，就是關於傳值與傳參考的部分，所以這一篇就來聊一下關於傳值與傳參考吧。","6",{"url":30,"title":31,"date":32,"updated":3,"category":33,"tags":34,"description":36,"readingMinutes":37},"\u002Fvscode\u002F20210927\u002F2674618084\u002F","VSCode terminal.integrated.shell.osx 屬性失效","2021-09-27 10:08:06","VSCode",[33,35],"障礙排除","最近 VSCode 發現終端機的 terminal.integrated.shell.osx 設置失效了，所以記錄一下問題跟解決方式。","1",{"url":39,"title":40,"date":41,"updated":3,"category":22,"tags":42,"description":43,"readingMinutes":44},"\u002Fpython\u002F20210927\u002F2772560677\u002F","從 JavaScript 角度學 Python(26) - 指定直譯器","2021-09-27 00:00:10",[22,24,25,26],"這一章節開始讓自己腦袋輕鬆一點好了，畢竟前面也學了不少的東西，所以這邊就聊點簡單的好了。","3",{"url":46,"title":47,"date":48,"updated":3,"category":22,"tags":49,"description":50,"readingMinutes":51},"\u002Fpython\u002F20210926\u002F4028850576\u002F","從 JavaScript 角度學 Python(25) - 例外處理","2021-09-26 00:00:10",[22,24,25,26],"接下來我們要聊一個非常非常重要的東西，也就是關於錯誤的處理，而這個處理又稱之為例外處理。","5",{"url":53,"title":54,"date":55,"updated":3,"category":22,"tags":56,"description":57,"readingMinutes":44},"\u002Fpython\u002F20210925\u002F2051252749\u002F","從 JavaScript 角度學 Python(24) - 繼承","2021-09-25 00:00:10",[22,24,25,26],"前一篇已經提前預告接下來將會講繼承了，所以這一篇當然就是會介紹繼承啦~(廢話)",{"url":59,"title":60,"date":61,"updated":3,"category":62,"tags":63,"description":65,"readingMinutes":37},"\u002Fgit\u002F20210924\u002F3215116351\u002F","解決 GitHub 無法指定 branch downloads 的問題","2021-09-24 09:25:15","Git",[64,62,35],"GitHub","近期 GitHub 下載程式碼的時候會無法指定 branch 下載，所以這邊紀錄一下該如何解決這個問題。",{"url":67,"title":68,"date":69,"updated":3,"category":22,"tags":70,"description":71,"readingMinutes":51},"\u002Fpython\u002F20210924\u002F2221702568\u002F","從 JavaScript 角度學 Python(23) - Class","2021-09-24 00:00:10",[22,24,25,26],"接下來算是小聊一下 Python 的 Class 語法而已，算是稍微休息一下，所以這邊簡單聊就好。",{"url":73,"title":74,"date":75,"updated":3,"category":22,"tags":76,"description":77,"readingMinutes":44},"\u002Fpython\u002F20210923\u002F885059491\u002F","從 JavaScript 角度學 Python(22) - GitHub API","2021-09-23 00:00:10",[22,24,25,26],"前面我們已經學習了不少的 Python 新知識，所以也差不多該到了實作一下前面的知識點，這樣子才能夠確實的吸收觀念。",{"url":79,"title":80,"date":81,"updated":3,"category":22,"tags":82,"description":83,"readingMinutes":84},"\u002Fpython\u002F20210922\u002F1139823147\u002F","從 JavaScript 角度學 Python(21) - Requests","2021-09-22 00:00:10",[22,24,25,26],"在 JavaScript 中 AJAX 是一個非常重要的基礎功，畢竟現在很流行前後端分離，因此這一篇也想聊聊關於 Python 的部分，Python 可以做到 AJAX 嗎？所以這一篇就來聊聊關於 Python 的 Requests 套件吧。","4",1036,104,{"postCount":85,"tagCount":88},1011,1784087307885]