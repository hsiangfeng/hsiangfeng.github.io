5000);\n});\n\nconsole.log(promise);\n","js","",[49,50,51,96,110,126,137,143,150],"code",{"__ignoreMap":47},[52,53,56,60,64,67,70,73,77,81,84,87,90,93],"span",{"class":54,"line":55},"line",1,[52,57,59],{"class":58},"sWyjQ","const",[52,61,63],{"class":62},"sCcAr"," promise",[52,65,66],{"class":58}," =",[52,68,69],{"class":58}," new",[52,71,72],{"class":62}," Promise",[52,74,76],{"class":75},"sMAXC","((",[52,78,80],{"class":79},"s_sBn","resolve",[52,82,83],{"class":75},", ",[52,85,86],{"class":79},"reject",[52,88,89],{"class":75},") ",[52,91,92],{"class":58},"=>",[52,94,95],{"class":75}," {\n",[52,97,99,103,106,108],{"class":54,"line":98},2,[52,100,102],{"class":101},"sj_SG","  setTimeout",[52,104,105],{"class":75},"(() ",[52,107,92],{"class":58},[52,109,95],{"class":75},[52,111,113,116,119,123],{"class":54,"line":112},3,[52,114,115],{"class":101},"    resolve",[52,117,118],{"class":75},"(",[52,120,122],{"class":121},"sTRMh","'true'",[52,124,125],{"class":75},");\n",[52,127,129,132,135],{"class":54,"line":128},4,[52,130,131],{"class":75},"  }, ",[52,133,134],{"class":62},"5000",[52,136,125],{"class":75},[52,138,140],{"class":54,"line":139},5,[52,141,142],{"class":75},"});\n",[52,144,146],{"class":54,"line":145},6,[52,147,149],{"emptyLinePlaceholder":148},true,"\n",[52,151,153,156,159],{"class":54,"line":152},7,[52,154,155],{"class":75},"console.",[52,157,158],{"class":101},"log",[52,160,161],{"class":75},"(promise);\n",[16,163,164],{},[26,165],{"alt":166,"src":167},"pending","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202022-04-16%2022.49.31.png",[16,169,170,171,173,174,177,178,180,181,184],{},"你會發現當你若直接執行呼叫 ",[49,172,21],{}," 函式時，JavaScript 是會呈現未確認狀態的，原因是因爲 JavaScript 是一個非同步語言，那麼在 ",[49,175,176],{},"console.log"," 執行時 ",[49,179,21],{}," 還沒有回傳任何結果，因此就會先吐一個 「",[49,182,183],{},"Promise { \u003Cstate>: \"pending\" }","」 告知你現在的 Promise 狀態是未確認的（還沒執行完畢）。",[16,186,187,188,191,192,195,196,199],{},"當 Promise 行為完成之後就會觸發將 ",[49,189,190],{},"state"," 改成 ",[49,193,194],{},"fulfilled"," 也就是實現\u002F成功，反之 ",[49,197,198],{},"rejected"," 則否決\u002F拒絕。",[16,201,202,203,205,206,208,209,211,212],{},"而上面程式碼你過五秒後再去展開內容就會看到 ",[49,204,190],{}," 變成了 ",[49,207,194],{}," 並且回傳的值也就是我們 ",[49,210,80],{}," 的 ",[49,213,214],{},"true",[16,216,217],{},[26,218],{"alt":194,"src":219},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202022-04-16%2022.51.03.png",[16,221,118,222,224],{},[49,223,176],{}," 是屬於非同步語法，因此呈現出來與展開出來必定會是不同結果。)",[16,226,227,228,231],{},"因此不管怎麼樣，如果你要確保 Promise 執行完畢後才執行特定動作的話，請務必補上 ",[49,229,230],{},".then"," 語法。",[16,233,234,235,237,238,240,241,243,244,240,247,250,251,253,254,256],{},"而在宣告 ",[49,236,22],{}," 語法時，會傳入兩個參數分別是 ",[49,239,80],{}," 與 ",[49,242,86],{},"，而這兩者對應著 ",[49,245,246],{},"then",[49,248,249],{},"catch","，因此當 Promise 成功時就會傳送到 ",[49,252,246],{}," 中，反之失敗時就會傳到 ",[49,255,249],{},"。",[16,258,259],{},"以下也提供一段範例程式碼來隨機產生失敗與成功",[42,261,263],{"className":44,"code":262,"language":46,"meta":47,"style":47},"const promise = (random) => new Promise((resolve, reject) => {\n  if(random) {\n    resolve(random);\n  } else {\n    reject(random)\n  }\n});\n\npromise(Math.floor(Math.random()*2))\n  .then((resolve) => {\n    console.log('resolve', resolve);\n  }).catch((reject) => {\n    console.log('reject', reject);\n  })\n",[49,264,265,301,309,316,326,334,339,343,348,375,393,409,427,442],{"__ignoreMap":47},[52,266,267,269,271,273,276,279,281,283,285,287,289,291,293,295,297,299],{"class":54,"line":55},[52,268,59],{"class":58},[52,270,63],{"class":101},[52,272,66],{"class":58},[52,274,275],{"class":75}," (",[52,277,278],{"class":79},"random",[52,280,89],{"class":75},[52,282,92],{"class":58},[52,284,69],{"class":58},[52,286,72],{"class":62},[52,288,76],{"class":75},[52,290,80],{"class":79},[52,292,83],{"class":75},[52,294,86],{"class":79},[52,296,8