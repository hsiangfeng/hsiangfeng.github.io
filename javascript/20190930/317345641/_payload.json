[{"data":1,"prerenderedAt":706},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190930\u002F317345641\u002F":3,"page:\u002Fjavascript\u002F20190930\u002F317345641\u002F":4,"alt:\u002Fjavascript\u002F20190930\u002F317345641\u002F":3,"prev-next:\u002Fjavascript\u002F20190930\u002F317345641\u002F":681,"related:\u002Fjavascript\u002F20190930\u002F317345641\u002F":690},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F30\u002Fre-learning-js-15-vanilla-ajax\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":664,"date":665,"description":18,"extension":666,"lang":667,"meta":668,"navigation":669,"path":670,"readingMinutes":671,"seo":672,"standalone":673,"stem":674,"tags":675,"tldr":678,"updated":678,"url":679,"__hash__":680},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-15-RE：從零開始的學習-JS-生活-第十五日.md","EP.15 RE：從零開始的學習 JS 生活-第十五日之原生 AJAX","317345641",{"type":9,"value":10,"toc":657},"minimark",[11,15,19,23,26,29,37,40,51,55,63,73,108,121,127,134,141,148,234,241,328,331,442,445,449,452,647,650,653],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第十五日，這章節將會來介紹原生的 AJAX 技術。",[12,20,22],{"id":21},"ajax","AJAX",[16,24,25],{},"AJAX 全名是 「Asynchronous JavaScript and XML」，中文是「非同步 JavaScript 和 XML」，在早期開發網頁時，居多都是採用 From 表單傳送資料到 Server，但是傳送表單之後往往會重新請求一整個畫面，那因為現階段使用者體驗越來越重要，所以 AJAX 的技術就變得不可忽視，早期作法當你送出表單後，還必須跟 Server 重新請求新的畫面，變成你要等兩個動作，所以就會看到一整個空白畫面。",[16,27,28],{},"那使用 AJAX 呢?使用 AJAX 的好處就是我們僅透過 JavaScript 傳送資訊到 Server，然後畫面保留在當前上，所以也就不用在跟後端重新請求一次畫面，而導致出現畫面空白，那麼這樣子在使用者體驗與 Server 的負擔也都會有較好的狀況。",[16,30,31,32,36],{},"所以 AJAX 最大的優點就是",[33,34,35],"strong",{},"可以在不更新使用者當前網頁畫面取得新資料 & 更新畫面","，進而達到更好的使用者體驗。",[16,38,39],{},"雖然 AJAX 並不需要仰賴什麼外掛，只需要使用者允許 JavaScript 的運作即可，故如果你將 JavaScript 給關閉就會無法運行 AJAX 唷~",[16,41,42,43,50],{},"更詳細的 AJAX 介紹我推薦可以看",[44,45,49],"a",{"href":46,"rel":47},"https:\u002F\u002Fzh.wikipedia.org\u002Fwiki\u002FAJAX",[48],"nofollow","維基百科","。",[12,52,54],{"id":53},"原生-ajax","原生 AJAX",[16,56,57,58,62],{},"現階段有非常多的 AJAX 套件，其中就我知道的就有 Axios 以及 jQuery 本身的 AJAX API，但是這些 API 都是屬於打包好的東西，所以這邊我們主要是去了解 AJAX 底層技術也就是 ",[59,60,61],"code",{},"XMLHttpRequest()","，了解底層技術也可以幫助自己對於現在 AJAX 套件有加分唷。",[16,64,65,66,68,69,72],{},"首先原生 AJAX 是使用 ",[59,67,61],{}," 方法，使用方式必須透過 ",[59,70,71],{},"new"," 實例化該方法：",[74,75,80],"pre",{"className":76,"code":77,"language":78,"meta":79,"style":79},"language-JS shiki shiki-themes github-dark-high-contrast","var xhr = new XMLHttpRequest();\n","JS","",[59,81,82],{"__ignoreMap":79},[83,84,87,91,95,98,101,105],"span",{"class":85,"line":86},"line",1,[83,88,90],{"class":89},"sWyjQ","var",[83,92,94],{"class":93},"sMAXC"," xhr ",[83,96,97],{"class":89},"=",[83,99,100],{"class":89}," new",[83,102,104],{"class":103},"sj_SG"," XMLHttpRequest",[83,106,107],{"class":93},"();\n",[16,109,110,111,113,114,117,118,120],{},"接下就會使用 ",[59,112,61],{}," 中的一個方法，也就是 ",[59,115,116],{},"open()"," 開啟要傳送 & 取得資料的 RESTful API URL(看成伺服器資料取得或傳送的路徑就好)，那 ",[59,119,116],{}," 撰寫方式就像這樣 ↓",[16,122,123],{},[124,125],"img",{"alt":116,"src":126},"https:\u002F\u002Fi.imgur.com\u002FObTlUrV.png",[16,128,129,130,133],{},"第三個參數通常會預設為非同步，也就是 ",[59,131,132],{},"false","，非同步的意思就是「我不會等你請求完資料我才做其他動作」。",[16,135,136,137,140],{},"接下來就要告知是否要傳送資料，若不用只需要寫 ",[59,138,139],{},"xhr.send(null);"," 即可。",[16,142,143,144,147],{},"最後的關鍵在這裡，請求 AJAX 行為後如果你沒有使用 ",[59,145,146],{},"xhr.onload = function () {...}"," 那就會導致錯誤，進而無法正常取得 AJAX 資料，所以完整的 XHR AJAX 行為如下：",[74,149,153],{"className":150,"code":151,"language":152,"meta":79,"style":79},"language-js shiki shiki-themes github-dark-high-contrast","var xhr = new XMLHttpRequest();\n    xhr.open('get', url);\n    xhr.send(null);\n    xhr.onload = function () {\n        ...\n    }\n","js",[59,154,155,169,188,205,222,228],{"__ignoreMap":79},[83,156,157,159,161,163,165,167],{"class":85,"line":86},[83,158,90],{"class":89},[83,160,94],{"class":93},[83,162,97],{"class":89},[83,164,100],{"class":89},[83,166,104],{"class":103},[83,168,107],{"class":93},[83,170,172,175,178,181,185],{"class":85,"line":171},2,[83,173,174],{"class":93},"    xhr.",[83,176,177],{"class":103},"open",[83,179,180],{"class":93},"(",[83,182,184],{"class":183},"sTRMh","'get'",[83,186,187],{"class":93},", url);\n",[83,189,191,193,196,198,202],{"class":85,"line":190},3,[83,192,174],{"class":93},[83,194,195],{"class":103},"send",[83,197,180],{"class":93},[83,199,201],{"class":200},"sCcAr","null",[83,203,204],{"class":93},");\n",[83,206,208,210,213,216,219],{"class":85,"line":207},4,[83,209,174],{"class":93},[83,211,212],{"class":103},"onload",[83,214,215],{"class":89}," =",[83,217,218],{"class":89}," function",[83,220,221],{"class":93}," () {\n",[83,223,225],{"class":85,"line":224},5,[83,226,227],{"class":89},"        ...\n",[83,229,231],{"class":85,"line":230},6,[83,232,233],{"class":93},"    }\n",[16,235,236,237,240],{},"另外如果要確保 AJAX 行為是成功的，那就可以使用 ",[59,238,239],{},"xhr.status"," 來判斷伺服器狀態碼，通常是判斷 200：",[74,242,244],{"className":150,"code":243,"language":152,"meta":79,"style":79},"var xhr = new XMLHttpRequest();\n    xhr.open('get', url);\n    xhr.send(null);\n    xhr.onload = function () {\n      if(xhr.status === 200) {\n        ...\n      }\n    }\n",[59,245,246,260,272,284,296,313,317,323],{"__ignoreMap":79},[83,247,248,250,252,254,256,258],{"class":85,"line":86},[83,249,90],{"class":89},[83,251,94],{"class":93},[83,253,97],{"class":89},[83,255,100],{"class":89},[83,257,104],{"class":103},[83,259,107],{"class":93},[83,261,262,264,266,268,270],{"class":85,"line":171},[83,263,174],{"class":93},[83,265,177],{"class":103},[83,267,180],{"class":93},[83,269,184],{"class":183},[83,271,187],{"class":93},[83,273,274,276,278,280,282],{"class":85,"line":190},[83,275,174],{"class":93},[83,277,195],{"class":103},[83,279,180],{"class":93},[83,281,201],{"class":200},[83,283,204],{"class":93},[83,285,286,288,290,292,294],{"class":85,"line":207},[83,287,174],{"class":93},[83,289,212],{"class":103},[83,291,215],{"class":89},[83,293,218],{"class":89},[83,295,221],{"class":93},[83,297,298,301,304,307,310],{"class":85,"line":224},[83,299,300],{"class":89},"      if",[83,302,303],{"class":93},"(xhr.status ",[83,305,306],{"class":89},"===",[83,308,309],{"class":200}," 200",[83,311,312],{"class":93},") {\n",[83,314,315],{"class":85,"line":230},[83,316,227],{"class":89},[83,318,320],{"class":85,"line":319},7,[83,321,322],{"class":93},"      }\n",[83,324,326],{"class":85,"line":325},8,[83,327,233],{"class":93},[16,329,330],{},"那麼以上就是 AJAX 的底層技術，但這是早期的做法，目前已經不堪用於現在的 web 技術，一個不小心可能就會進入 Callback Hell (回調地獄，後面會介紹)，拿我個人撰寫 AJAX 會使用第三方套件如 Axios、jQuery ajax api，如果不使用套件的話，則會使用 HTML5 後來新增的 Fetch API，撰寫方式是這樣子：",[74,332,334],{"className":150,"code":333,"language":152,"meta":79,"style":79},"fetch(url).then((respons) => {\n  return respons.json(); \u002F\u002F取的資料後將資料傳給下一個 then\n}).then((data) => {\n  ...\n}).catch((error) => { \u002F\u002F 當初出現錯誤時跑 catch\n  console.log(error);\n})\n",[59,335,336,363,381,399,404,426,437],{"__ignoreMap":79},[83,337,338,341,344,347,350,354,357,360],{"class":85,"line":86},[83,339,340],{"class":103},"fetch",[83,342,343],{"class":93},"(url).",[83,345,346],{"class":103},"then",[83,348,349],{"class":93},"((",[83,351,353],{"class":352},"s_sBn","respons",[83,355,356],{"class":93},") ",[83,358,359],{"class":89},"=>",[83,361,362],{"class":93}," {\n",[83,364,365,368,371,374,377],{"class":85,"line":171},[83,366,367],{"class":89},"  return",[83,369,370],{"class":93}," respons.",[83,372,373],{"class":103},"json",[83,375,376],{"class":93},"(); ",[83,378,380],{"class":379},"sQrFR","\u002F\u002F取的資料後將資料傳給下一個 then\n",[83,382,383,386,388,390,393,395,397],{"class":85,"line":190},[83,384,385],{"class":93},"}).",[83,387,346],{"class":103},[83,389,349],{"class":93},[83,391,392],{"class":352},"data",[83,394,356],{"class":93},[83,396,359],{"class":89},[83,398,362],{"class":93},[83,400,401],{"class":85,"line":207},[83,402,403],{"class":89},"  ...\n",[83,405,406,408,411,413,416,418,420,423],{"class":85,"line":224},[83,407,385],{"class":93},[83,409,410],{"class":103},"catch",[83,412,349],{"class":93},[83,414,415],{"class":35