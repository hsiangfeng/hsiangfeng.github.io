ndow-中找到","為什麼 let 無法從 window 中找到",[16,578,579],{},"在這邊這是一個很少很少有人提到的一件事情，首先在以往當我們輸入以下變數宣告後都可以在 window 下找到相關變數",[83,581,583],{"className":85,"code":582,"language":87,"meta":88,"style":88},"var aName = 'Ray';\nconsole.log(window);\n",[20,584,585,599],{"__ignoreMap":88},[92,586,587,589,592,594,597],{"class":94,"line":95},[92,588,22],{"class":98},[92,590,591],{"class":101}," aName ",[92,593,105],{"class":98},[92,595,596],{"class":108}," 'Ray'",[92,598,112],{"class":101},[92,600,601,603,605],{"class":94,"line":115},[92,602,264],{"class":101},[92,604,267],{"class":229},[92,606,607],{"class":101},"(window);\n",[16,609,610],{},[557,611],{"alt":612,"src":613},"window","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202020-04-26%2021.03.31.png",[16,615,616,617,619,620,622],{},"但是當我們使用了 ES6 語法，也就是 ",[20,618,26],{}," 或是 ",[20,621,178],{}," 卻無法找到這個變數",[83,624,626],{"className":85,"code":625,"language":87,"meta":88,"style":88},"let aName = 'Ray';\nconsole.log(window);\n",[20,627,628,640],{"__ignoreMap":88},[92,629,630,632,634,636,638],{"class":94,"line":95},[92,631,26],{"class":98},[92,633,591],{"class":101},[92,635,105],{"class":98},[92,637,596],{"class":108},[92,639,112],{"class":101},[92,641,642,644,646],{"class":94,"line":115},[92,643,264],{"class":101},[92,645,267],{"class":229},[92,647,607],{"class":101},[16,649,650],{},[557,651],{"alt":652,"src":653},"找不到 let 宣告的變數","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202020-04-26%2021.05.11.png",[16,655,656,657,660],{},"但這邊我們若使用 ",[20,658,659],{},"aName"," 卻又可以正確取得已經宣告的變數",[16,662,663],{},[557,664],{"alt":665,"src":666},"無法在 Window 下找到卻可以取得變數","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E6%88%AA%E5%9C%96%202020-04-26%2021.06.27.png",[16,668,669,670,672,673,676,677,680],{},"那麼這是什麼神奇的原因？在以往我們的觀念中，通常我們宣告的變數都會被加入到 window 中，但使用 ",[20,671,26],{}," 宣告的變數卻無法在 window 底下找到，可以卻又可以正確的呼叫取得該變數的值，當你嘗試使用 ",[20,674,675],{},"delete aName","，你也會得到一個 ",[20,678,679],{},"false"," 無法刪除的警告。",[16,682,683],{},"那這是魔術嗎？其實不是。",[16,685,686],{},"這個原因是出在全域執行環境(Global space) 上面，首先這個全域執行環境其實是由兩個環境所組成的",[35,688,689,692],{},[38,690,691],{},"全域物件 - Object Env",[38,693,694],{},"宣告環境 - Declare Env",[16,696,697],{},"因此全域執行環境(Global space) 其實是一個由雙環境組成的東西，一般來說我們是看不到 Declare Env 的。",[16,699,700,701,703,704,175,706,708,709,175,711,713],{},"所以 ",[20,702,22],{}," 其實是基於 ObjectEnv 宣告並加入到 Declare Env，而 ",[20,705,26],{},[20,707,178],{}," 則是只會宣告在 Declare Env 中，這也就是為什麼我們無法在 Window 上面看到由 ",[20,710,26],{},[20,712,178],{}," 宣告的變數但卻又可以正常取得到值的原因。",[12,715,716],{"id":716},"參考文獻",[35,718,719,729],{},[38,720,721],{},[48,722,725,726],{"href":723,"rel":724},"https:\u002F\u002Fstackoverflow.com\u002Fquestions\u002F39414692\u002Fa-javascript-let-global-variable-is-not-a-property-of-window-unlike-a-global",[76],"A javascript 'let' global variable is not a property of 'window' unlike a global 'var' ",[92,727,728],{},"duplicate",[38,730,731],{},[48,732,735],{"href":733,"rel":734},"https:\u002F\u002Fgithub.com\u002FAdvanced-Frontend\u002FDaily-Interview-Question\u002Fissues\u002F30",[76],"第 27 题：关于 const 和 let 声明的变量不在 window 上",[737,738,739],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .s