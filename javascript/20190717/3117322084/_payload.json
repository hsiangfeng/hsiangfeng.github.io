[{"data":1,"prerenderedAt":288},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190717\u002F3117322084\u002F":3,"page:\u002Fjavascript\u002F20190717\u002F3117322084\u002F":4,"alt:\u002Fjavascript\u002F20190717\u002F3117322084\u002F":3,"prev-next:\u002Fjavascript\u002F20190717\u002F3117322084\u002F":263,"related:\u002Fjavascript\u002F20190717\u002F3117322084\u002F":272},"\u002Fen\u002Fjavascript\u002F2019\u002F07\u002F17\u002Fjavascript-xss-attack-basics\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":248,"date":249,"description":18,"extension":250,"lang":251,"meta":252,"navigation":253,"path":254,"readingMinutes":255,"seo":256,"standalone":257,"stem":258,"tags":259,"tldr":260,"updated":260,"url":261,"__hash__":262},"content\u002FJavaScript\u002FJavaScript-關於-XSS-攻擊.md","JavaScript 關於 XSS 攻擊","3117322084",{"type":9,"value":10,"toc":241},"minimark",[11,15,19,23,31,41,44,67,111,121,158,161,164,175,178,211,214,223,230,237],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"關於 XSS 攻擊是每一位前端工程師必須知道的技術之一，這邊我也來做一下筆記何謂 XSS 攻擊",[12,20,22],{"id":21},"xss","XSS",[16,24,25,26,30],{},"XSS 全名是 Cross-Site Scripting，又稱",[27,28,29],"strong",{},"跨網站指令碼攻擊","，通常問題都是出在 JavaScript 上，比較常見的幾種手法就以下",[32,33,34,38],"ul",{},[35,36,37],"li",{},"跳轉到別人家",[35,39,40],{},"登入頁面帳號密碼送到別人伺服器去\n等等",[16,42,43],{},"那麼 XSS 又概略分為三種類型",[32,45,46,59],{},[35,47,48,49],{},"持續型 XSS (又稱儲存型 XSS)",[32,50,51],{},[35,52,53,54,58],{},"持續型 XSS 你可以簡單的來想就是在你的首頁上塞入一段 ",[55,56,57],"code",{},"while(i \u003C 10){ alert('哈哈，你被XSS攻擊囉!'); i++ }"," ，然後持續性的干擾你，但是這邊要注意是這一個 XSS 攻擊是儲存於你的資料庫內，所以在新增資料庫的時候要注意使用者所填入的資訊，否則這個 XSS 攻擊將會一直持續攻擊",[35,60,61,62],{},"反射型 XSS",[32,63,64],{},[35,65,66],{},"反射型通常發生伺服器將資料往前傳時導致的，最常發生的狀況就是 GET，前端向後端請求資料時，後端並沒有檢驗資料是否正常就直接往前端吐，那麼就會出現 XSS 攻擊，因為有可能往前吐的資料是下面這種",[68,69,74],"pre",{"className":70,"code":71,"language":72,"meta":73,"style":73},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript>alert('哈哈，你被XSS攻擊囉!');\u003C\u002Fscript>\n","html","",[55,75,76],{"__ignoreMap":73},[77,78,81,85,89,92,96,99,103,106,108],"span",{"class":79,"line":80},"line",1,[77,82,84],{"class":83},"sMAXC","\u003C",[77,86,88],{"class":87},"sKpQp","script",[77,90,91],{"class":83},">",[77,93,95],{"class":94},"sj_SG","alert",[77,97,98],{"class":83},"(",[77,100,102],{"class":101},"sTRMh","'哈哈，你被XSS攻擊囉!'",[77,104,105],{"class":83},");\u003C\u002F",[77,107,88],{"class":87},[77,109,110],{"class":83},">\n",[32,112,113],{},[35,114,115,116],{},"基於 DOM 的 XSS\n",[32,117,118],{},[35,119,120],{},"至於 DOM 的 XSS 攻擊簡單來講就是在某個 DOM 節點輸入 JavaScript 程式碼，例如:",[68,122,124],{"className":70,"code":123,"language":72,"meta":73,"style":73},"\u003Cimg src=\"#\" onerror=\"alert('哈哈，你被XSS攻擊囉!');\">\n",[55,125,126],{"__ignoreMap":73},[77,127,128,130,133,137,140,143,146,148,151,153,156],{"class":79,"line":80},[77,129,84],{"class":83},[77,131,132],{"class":87},"img",[77,134,136],{"class":135},"sCcAr"," src",[77,138,139],{"class":83},"=",[77,141,142],{"class":101},"\"#\"",[77,144,145],{"class":135}," onerror",[77,147,139],{"class":83},[77,149,150],{"class":101},"\"",[77,152,95],{"class":94},[77,154,155],{"class":101},"('哈哈，你被XSS攻擊囉!');\"",[77,157,110],{"class":83},[16,159,160],{},"(剛好公司最近被 DOM XSS 攻擊)",[12,162,163],{"id":163},"防範方法",[16,165,166,167,170,171,174],{},"通常防範 XSS 攻擊都會是前後端一起配合防範，以前端做舉例，使用 ",[55,168,169],{},"innerHTML"," 的地方就必須格外的小心，如果輸入的地方可能會有 XSS 攻擊那麼就使用 ",[55,172,173],{},"createElement"," 來製作。",[16,176,177],{},"那麼這邊也補上這兩個語法的特性說明",[32,179,180,197],{},[35,181,182,183],{},"innerHTML\n",[32,184,185,188,191,194],{},[35,186,187],{},"方法:組完字串後，傳進語法進行渲染",[35,189,190],{},"優點:效能快",[35,192,193],{},"缺點:資安風險，也就是 XSS 攻擊",[35,195,196],{},"特性:會清空HTML標籤",[35,198,199,200],{},"createElement\n",[32,201,202,205,208],{},[35,203,204],{},"方法:以DOM節點來處理",[35,206,207],{},"優點:安全性高",[35,209,210],{},"缺點:效能差",[12,212,213],{"id":213},"參考文獻",[16,215,216],{},[217,218,222],"a",{"href":219,"rel":220},"https:\u002F\u002Fzh.wikipedia.org\u002Fzh-tw\u002F%E8%B7%A8%E7%B6%B2%E7%AB%99%E6%8C%87%E4%BB%A4%E7%A