[{"data":1,"prerenderedAt":502},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190617\u002F3829122039\u002F":3,"page:\u002Fjavascript\u002F20190617\u002F3829122039\u002F":4,"alt:\u002Fjavascript\u002F20190617\u002F3829122039\u002F":3,"prev-next:\u002Fjavascript\u002F20190617\u002F3829122039\u002F":477,"related:\u002Fjavascript\u002F20190617\u002F3829122039\u002F":486},"\u002Fen\u002Fjavascript\u002F2019\u002F06\u002F17\u002Fgas-cors-proxy\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":461,"date":462,"description":463,"extension":464,"lang":465,"meta":466,"navigation":467,"path":468,"readingMinutes":469,"seo":470,"standalone":471,"stem":472,"tags":473,"tldr":474,"updated":474,"url":475,"__hash__":476},"content\u002FJavaScript\u002F使用-Google-Apps-Script-解決-CORS-問題.md","使用 Google Apps Script 解決 CORS 問題","3829122039",{"type":9,"value":10,"toc":454},"minimark",[11,15,19,23,26,32,47,50,53,56,59,63,66,74,90,99,108,113,118,123,129,139,143,146,152,155,162,335,338,344,347,353,356,362,365,371,379,382,385,391,394,402,411,414,420,426,432,438,444,450],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"在現代的前端開發中，很常使用 AJAX 取的遠端資料，但是卻也很容易取得 CORS，這邊就來記錄一下該如何使用 Google 提供的 Google Apps Script 來解決 CORS 問題",[12,20,22],{"id":21},"cors","CORS",[16,24,25],{},"使用 Google Apps Script 之前要先來科普一下 CORS 到底是什麼東西",[16,27,28],{},[29,30],"img",{"alt":22,"src":31},"https:\u002F\u002Fi.imgur.com\u002F93xABcu.png",[16,33,34,35,39,40,43,44],{},"CORS 全名是 ",[36,37,38],"strong",{},"跨來源資源共用（Cross-Origin Resource Sharing (CORS)）","，一般來講後端都會開一隻 API 給前端做 AJAX 的連結，但是如果隨意開放 API 給網路上的人使用這是會有很大的安全性隱慮，所以這邊也會牽扯到一個所謂的",[36,41,42],{},"同源政策 (Same-origin policy)"," ，讓我們試著舉例一個情境來了解什麼是",[36,45,46],{},"同源政策",[16,48,49],{},"假設你今天在家裡有冰箱、電視，你想開冰箱就可以開冰箱，你想看電視就開電視，而這觀念就是所謂的同源政策，因為這是你家你想怎樣就可以怎樣，反之，你就不能夠隨便開別人家裡冰箱、電視甚至在別人家洗澡。",[16,51,52],{},"所以在自己家裡就是同源，而你去動用別人家裡也就是不同源，那就是跨域，那就會有許多限制。",[16,54,55],{},"現在回頭講講 CORS，CORS 是一個瀏覽器的規範，它可以幫助我們透過 Web 從不同的網域來取得資料進而避免發生同源政策的問題",[16,57,58],{},"通常 CORS 最長使用的 JavaScript 方法有兩種 XMLHttpRequest 或 Fetch，通常可能有些資料是限制僅可以在同一個網域下才可以存取，所以當你如果是在不同網域，那就會出現 CORS 錯誤",[16,60,61],{},[29,62],{"alt":22,"src":31},[16,64,65],{},"基本上有許多人都會認為 CORS 是前端必備的技能之一，但是其實 CORS 大多都會與後端有比較大的關連性，因為必須透過後端來設置相關的 header。",[16,67,68,69,73],{},"那我們該如何確定該 API 是否有開放 CORS?通常 CORS 會在 hearder 中加入 ",[70,71,72],"code",{},"Access-Control-Allow-Origin","，我們可以透過這個指令來檢查",[75,76,81],"pre",{"className":77,"code":78,"language":79,"meta":80,"style":80},"language-cmd shiki shiki-themes github-dark-high-contrast","curl curl --verbose -X POST [URL]\n","cmd","",[70,82,83],{"__ignoreMap":80},[84,85,88],"span",{"class":86,"line":87},"line",1,[84,89,78],{},[75,91,93],{"className":77,"code":92,"language":79,"meta":80,"style":80},"curl --verbose -X POST \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FJSHomeWork\u002Fblob\u002Fmaster\u002FJSON\u002Fdatastore_search.json\"\n",[70,94,95],{"__ignoreMap":80},[84,96,97],{"class":86,"line":87},[84,98,92],{},[16,100,101,102,104,105],{},"如果有加入 ",[70,103,72],{},"，你就可以看到",[70,106,107],{},"Access-Control-Allow-Origin: *",[16,109,110],{},[29,111],{"alt":72,"src":112},"https:\u002F\u002Fi.imgur.com\u002FXevu85v.png",[16,114,115,116],{},"如果沒有的話就會找不到 ",[70,117,72],{},[16,119,120],{},[29,121],{"alt":72,"src":122},"https:\u002F\u002Fi.imgur.com\u002FHseHEII.png",[16,124,125,126,128],{},"所以當我們請求 (request) API 時，若回傳 (response) 沒有 ",[70,127,72],{}," 那就會出現 CORS 錯誤",[16,130,131,132],{},"如果想更了解 CORS 其實可以看看 MDN 寫的",[133,134,138],"a",{"href":135,"rel":136},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FHTTP\u002FCORS",[137],"nofollow","詳細文件",[12,140,142],{"id":141},"撰寫-google-apps-script","撰寫 Google Apps Script",[16,144,145],{},"首先進入自己的 Google 雲端硬碟，點右鍵 \"更多\" → \"Google Apps Script\"",[16,147,148],{},[29,149],{"alt":150,"src":151},"Google Apps Script","https:\u002F\u002Fi.imgur.com\u002F7T1vucU.png",[16,153,154],{},"接下來將會開啟一個類似線上寫程式的畫面，將以下程式碼貼入",[16,156,157,158,161],{},"注意 function 名稱一定要為 ",[70,159,160],{},"doGet","，否則無效。",[75,163,167],{"className":164,"code":165,"language":166,"meta":80,"style":80},"language-js shiki shiki-themes github-dark-high-contrast","function doGet(e){\n  var url = e.parameter.url; \u002F\u002F 取得傳入 URL\n  var response = UrlFetchApp.fetch(decodeURIComponent(url),{ \u002F\u002F 發出 GET 請求，並設定 hearder json\n    headers: { \"Content-type\" : \"application\u002Fjson\" }\n  });\n  var data = JSON.parse(response.getContentText()); \u002F\u002F 取得 json 資料\n  return ContentService.createTextOutput(JSON.stringify(data)).setMimeType(ContentService.MimeType.JSON); \n}\n","js",[70,168,169,190,209,236,255,261,293,329],{"__ignoreMap":80},[84,170,171,175,179,183,187],{"class":86,"line":87},[84,172,174],{"class":173},"sWyjQ","function",[84,176,178],{"class":177},"sj_SG"," doGet",[84,180,182],{"class":181},"sMAXC","(",[84,184,186],{"class":185},"s_sBn","e",[84,188,189],{"class":181},"){\n",[84,191,193,196,199,202,205],{"class":86,"line":192},2,[84,194,195],{"class":173},"  var",[84,197,198],{"class":181}," url ",[84,200,201],{"class":173},"=",[84,203,204],{"class":181}," e.parameter.url; ",[84,206,208],{"class":207},"sQrFR","\u002F\u002F 取得傳入 URL\n",[84,210,212,214,217,219,222,225,227,230,233],{"class":86,"line":211},3,[84,213,195],{"class":173},[84,215,216],{"class":181}," response ",[84,218,201],{"class":173},[84,220,221],{"class":181}," UrlFetchApp.",[84,223,224],{"class":177},"fetch",[84,226,182],{"class":181},[84,228,229],{"class":177},"decodeURIComponent",[84,231,232],{"class":181},"(url),{ ",[84,234,235],{"class":207},"\u002F\u002F 發出 GET 請求，並設定 hearder json\n",[84,237,239,242,246,249,252],{"class":86,"line":238},4,[84,240,241],{"class":181},"    headers: { ",[84,243,245],{"class":244},"sTRMh","\"Content-type\"",[84,247,248],{"class":181}," : ",[84,250,251],{"class":244},"\"application\u002Fjson\"",[84,253,254],{"class":181}," }\n",[84,256,258],{"class":86,"line":257},5,[84,259,260],{"class":181},"  });\n",[84,262,264,266,269,271,275,278,281,284,287,290],{"class":86,"line":263},6,[84,265,195],{"class":173},[84,267,268],{"class":181}," data ",[84,270,201],{"class":173},[84,272,274],{"class":273},"sCcAr"," JSON",[84,276,277],{"class":181},".",[84,279,280],{"class":177},"parse",[84,282,283],{"class":181},"(response.",[84,285,286],{"class":177},"getContentText",[84,288,289],{"class":181},"()); ",[84,291,292],{"class":207},"\u002F\u002F 取得 json 資料\n",[84,294,296,299,302,305,307,310,312,315,318,321,324,326],{"class":86,"line":295},7,[84,297,298],{"class":173},"  return",[84,300,301],{"class":181}," ContentService.",[84,303,304],{"class":177},"createTextOutput",[84,306,182],{"class":181},[84,308,309],{"class":273},"JSON",[84,311,277],{"class":181},[84,313,314],{"class":177},"stringify",[84,316,317],{"class":181},"(data)).",[84,319,320],{"class":177},"setMimeType",[84,322,323],{"class":181},"(ContentService.MimeType.",[84,325,309],{"class":273},[84,327,328],{"class":181},"); \n",[84,330,332],{"class":86,"line":331},8,[84,333,334],{"class":181},"}\n",[16,336,337],{},"接下來點選上方\"發佈\"→\"部屬為網路應用程式\"",[16,339,340],{},[29,341],{"alt":342,"src":343},"部屬為網路應用程式","https:\u002F\u002Fi.imgur.com\u002Fy6rKdJy.png",[16,345,346],{},"如果跳出要你輸入專案名稱，那就依照自己能分辨的名稱輸入吧",[16,348,349],{},[29,350],{"alt":351,"src":352},"專案名稱","https:\u002F\u002Fi.imgur.com\u002FZXAkQ3R.png",[16,354,355],{},"依照圖片做調整即可按下部屬",[16,357,358],{},[29,359],{"alt":360,"src":361},"部屬","https:\u002F\u002Fi.imgur.com\u002FCOkR4ws.png",[16,363,364],{},"部屬成功後將會取的一段網址",[16,366,367],{},[29,368],{"alt":369,"src":370},"Image","https:\u002F\u002Fi.imgur.com\u002F7Kj9ikU.png",[75,372,377],{"className":373,"code":375,"language":376,"meta":80},[374],"language-text","https:\u002F\u002Fscript.google.com\u002Fmacros\u002Fs\u002FAKfycbxybXJPnk9oV-VOf5vMAkPKoOmYn-OZ9OXeWO3khPyluXQo6ps\u002Fexec\n","text",[70,378,375],{"__ignoreMap":80},[12,380,381],{"id":381},"使用方式",[16,383,384],{},"使用方式很簡單",[75,386,389],{"className":387,"code":388,"language":376,"meta":80},[374],"部屬網址?url=AJAX網址\n",[70,390,388],{"__ignoreMap":80},[16