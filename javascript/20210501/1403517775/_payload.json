;\n",[36,74,76],{"class":38,"line":75},4,[36,77,79],{"emptyLinePlaceholder":78},true,"\n",[36,81,83,86,90,93],{"class":38,"line":82},5,[36,84,85],{"class":46},"console.",[36,87,89],{"class":88},"sj_SG","log",[36,91,92],{"class":46},"(obj); ",[36,94,96],{"class":95},"sQrFR","\u002F\u002F obj\n",[16,98,99,100,103],{},"在此其實你並沒有辦法透過 Chrome 直接看到物件的屬性特徵，所謂的屬性特徵是什麼意思呢？舉凡這個屬性能不能被新增、重新寫入或者是透過迴圈讀取等，而這個屬性特徵若要觀看的話，則必須使用一個語法才可以，也就是 ",[33,101,102],{},"Object.getOwnPropertyDescriptor","。",[16,105,106,108],{},[33,107,102],{}," 的用法並不困難，第一個參數通常是物件本身，第二個則是要查看的屬性：",[26,110,112],{"className":28,"code":111,"language":30,"meta":31,"style":31},"var obj = {\n  myName: 'Ray',\n};\n\nconsole.log(Object.getOwnPropertyDescriptor(obj, 'myName'));\n",[33,113,114,124,132,136,140],{"__ignoreMap":31},[36,115,116,118,120,122],{"class":38,"line":39},[36,117,43],{"class":42},[36,119,47],{"class":46},[36,121,50],{"class":42},[36,123,53],{"class":46},[36,125,126,128,130],{"class":38,"line":56},[36,127,59],{"class":46},[36,129,63],{"class":62},[36,131,66],{"class":46},[36,133,134],{"class":38,"line":69},[36,135,72],{"class":46},[36,137,138],{"class":38,"line":75},[36,139,79],{"emptyLinePlaceholder":78},[36,141,142,144,146,149,152,155,158],{"class":38,"line":82},[36,143,85],{"class":46},[36,145,89],{"class":88},[36,147,148],{"class":46},"(Object.",[36,150,151],{"class":88},"getOwnPropertyDescriptor",[36,153,154],{"class":46},"(obj, ",[36,156,157],{"class":62},"'myName'",[36,159,160],{"class":46},"));\n",[16,162,163],{},"基本上當你貼入到 Chrome 後應該會看到以下資訊",[26,165,167],{"className":28,"code":166,"language":30,"meta":31,"style":31},"{\n  configurable: true,\n  enumerable: true,\n  value: \"Ray\",\n  writable: true,\n}\n",[33,168,169,174,189,200,212,223],{"__ignoreMap":31},[36,170,171],{"class":38,"line":39},[36,172,173],{"class":46},"{\n",[36,175,176,180,183,187],{"class":38,"line":56},[36,177,179],{"class":178},"s_sBn","  configurable",[36,181,182],{"class":46},": ",[36,184,186],{"class":185},"sCcAr","true",[36,188,66],{"class":46},[36,190,191,194,196,198],{"class":38,"line":69},[36,192,193],{"class":178},"  enumerable",[36,195,182],{"class":46},[36,197,186],{"class":185},[36,199,66],{"class":46},[36,201,202,205,207,210],{"class":38,"line":75},[36,203,204],{"class":178},"  value",[36,206,182],{"class":46},[36,208,209],{"class":62},"\"Ray\"",[36,211,66],{"class":46},[36,213,214,217,219,221],{"class":38,"line":82},[36,215,216],{"class":178},"  writable",[36,218,182],{"class":46},[36,220,186],{"class":185},[36,222,66],{"class":46},[36,224,226],{"class":38,"line":225},6,[36,227,228],{"class":46},"}\n",[16,230,231,232,236],{},"這四個參數就是",[233,234,235],"strong",{},"物件屬性特徵","，分別為：",[238,239,240,252,263,269],"ul",{},[241,242,243,246,247],"li",{},[33,244,245],{},"configurable"," - 屬性可否被設定\n",[238,248,249],{},[241,250,251],{},"簡單來講就是這是屬性能不能被修改 or 刪除屬性。",[241,253,254,257,258],{},[33,255,256],{},"enumerable"," - 屬性可否被列舉\n",[238,259,260],{},[241,261,262],{},"最簡單來講就是，可不可以被迴圈讀取出來。",[241,264,265,268],{},[33,266,267],{},"value"," - 值",[241,270,271,274,275],{},[33,272,273],{},"writable"," - 屬性的值可否被寫入\n",[238,276,277],{},[241,278,279],{},"簡單來講就是能不能被修改屬性本身的值，例如 Ray 改成 Hello。",[16,281,282,283,286,287,289,290,293],{},"那麼前面講那麼多，我們實際上如果想針對物件的屬性調整特徵的話該怎麼做？這邊就會使用 ",[33,284,285],{},"Object.defineProperty"," 來調整屬性特徵，",[33,288,285],{}," 需要帶入的參數就有三個，第一個是要調整的物件，第二個則是要調整的屬性，第三個則是屬性特徵的調整，假使來講，我希望 ",[33,291,292],{},"myName"," 這個屬性不可以再次被調整的話，則是這樣子使用：",[26,295,297],{"className":28,"code":296,"language":30,"meta":31,"style":31},"var obj = {\n  myName: 'Ray',\n};\n\nObject.defineProperty(obj, 'myName', {\n  writable: false,\n});\n\nobj.myName = 'Hello';\n",[33,298,299,309,317,321,325,340,350,356,361],{"__ignoreMap":31},[36,300,301,303,305,307],{"class":38,"line":39},[36,302,43],{"class":42},[36,304,47],{"class":46},[36,306,50],{"class":42},[36,308,53],{"class":46},[36,310,311,313,315],{"class":38,"line":56},[36,312,59],{"class":46},[36,314,63],{"class":62},[36,316,66],{"class":46},[36,318,319],{"class":38,"line":69