],{"height":28,"style":29,"scrolling":30,"title":182,"src":183,"frameBorder":30,"allowTransparency":33,"allowFullScreen":33},"PIXI dat.GUI + Stat.js","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FpoJjyLM?height=265&theme-id=default&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FpoJjyLM'>PIXI dat.GUI + Stat.js\u003C\u002Fa> by Ray\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[16,186,187],{},"(謎之聲：因為電腦太好所以其實感受不太出來 QQ)",[12,189,191],{"id":190},"statsjs-介紹","stats.js 介紹",[16,193,194],{},"基本上 stats.js 有四種模式可以看，相信在前面章節聰明的你應該有注意到",[46,196,198],{"className":48,"code":197,"language":50,"meta":51,"style":51},"stats.showPanel(1); \u002F\u002F 0: fps, 1: ms, 2: mb, 3+: custom\n",[53,199,200],{"__ignoreMap":51},[56,201,202,205,208,210,213,216],{"class":58,"line":59},[56,203,204],{"class":70},"stats.",[56,206,207],{"class":66},"showPanel",[56,209,71],{"class":70},[56,211,212],{"class":87},"1",[56,214,215],{"class":70},"); ",[56,217,219],{"class":218},"sQrFR","\u002F\u002F 0: fps, 1: ms, 2: mb, 3+: custom\n",[16,221,222,223,230],{},"而這四種模式一次只能出現一種，這是比較可惜的地方，在",[224,225,229],"a",{"href":226,"rel":227},"https:\u002F\u002Fgithub.com\u002Fmrdoob\u002Fstats.js\u002F",[228],"nofollow","官方文件","中其實就有介紹每一種的圖表說明",[46,232,237],{"className":233,"code":235,"language":236,"meta":51},[234],"language-text","FPS Frames rendered in the last second. The higher the number the better.\nMS Milliseconds needed to render a frame. The lower the number the better.\nMB MBytes of allocated memory. (Run Chrome with --enable-precise-memory-info)\nCUSTOM User-defined panel support.\n","text",[53,238,235],{"__ignoreMap":51},[16,240,241],{},"因為都是英文，所以我稍微翻一下",[243,244,245,249,252,255],"ul",{},[246,247,248],"li",{},"FPS(影格率)，FPS 在最後一秒渲染的影格率，其中數字越高越好(以 Pixi 來講建議是在 60)。",[246,250,251],{},"MS(毫秒)，渲染 FPS 所需要的秒數，數字越低越好。",[246,253,254],{},"MB(內存)，已經分配的內存，是使用 Chrome --enable-precise-memory-info 的，如果你是使用 Chrome 之外的瀏覽器會無法看到。",[246,256,257],{},"custom，這一個我就不清楚了?不知道要自定義什麼。",[12,259,260],{"id":260},"參考文獻",[243,262,263,269],{},[246,264,265],{},[224,266,268],{"href":226,"rel":267},[228],"stats.js",[246,270,271],{},[224,272,275],{"href":273,"rel":274},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10209400",[228],"效能評估工具",[277,278,279],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":51,"searchDepth":81,"depth":81,"links":281},[282,283,284,285,286],{"id":14,"depth":81,"text":14},{"id":21,"depth":81,"text":21},{"id":37,"depth":81,"text":38},{"id":190,"depth":81,"text":191},{"id":260,"depth":81,"text":260},"JavaScript","2020-10-21 15:25:20","md","zh-Hant",{},true,"\u002Fpixijs-v5\u002Fpixijs-v5-(37)-stats.js","2",{"title":6,"description":18},false,"PixiJS V5 教學\u002FPixiJS V5 教學 (37) - 加入 stats.js",[299,300,287,301,302],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool",null,"\u002Fjavascript\u002F20201021\u002F1504709600\u002F","6oONVBaow4O7i_au_DwnYqqOPtgeQpSx79D52NaAN_M",{"newer":307,"older":311},{"url":308,"title"