69],{"class":61},"(myName); ",[55,71,73],{"class":72},"sQrFR","\u002F\u002F undefined\n",[55,75,77,80,83,86,90],{"class":57,"line":76},2,[55,78,40],{"class":79},"sWyjQ",[55,81,82],{"class":61}," myName ",[55,84,85],{"class":79},"=",[55,87,89],{"class":88},"sTRMh"," 'Ray'",[55,91,92],{"class":61},";\n",[16,94,95,96,98],{},"但這個問題並不大，主要是 ",[30,97,40],{}," 有一個滿麻煩的問題，就是若重複宣告變數，只會被覆蓋掉而不會出現錯誤：",[46,100,102],{"className":48,"code":101,"language":50,"meta":51,"style":51},"var myName = 'Ray';\nvar myName = 'Ray2';\n\nconsole.log(myName); \u002F\u002F Ray2\n",[30,103,104,116,129,136],{"__ignoreMap":51},[55,105,106,108,110,112,114],{"class":57,"line":58},[55,107,40],{"class":79},[55,109,82],{"class":61},[55,111,85],{"class":79},[55,113,89],{"class":88},[55,115,92],{"class":61},[55,117,118,120,122,124,127],{"class":57,"line":76},[55,119,40],{"class":79},[55,121,82],{"class":61},[55,123,85],{"class":79},[55,125,126],{"class":88}," 'Ray2'",[55,128,92],{"class":61},[55,130,132],{"class":57,"line":131},3,[55,133,135],{"emptyLinePlaceholder":134},true,"\n",[55,137,139,141,143,145],{"class":57,"line":138},4,[55,140,62],{"class":61},[55,142,66],{"class":65},[55,144,69],{"class":61},[55,146,147],{"class":72},"\u002F\u002F Ray2\n",[16,149,150],{},"那麼這種狀況在實際開發上是有可能養出一些蟲子，更不用說作用域的問題：",[46,152,154],{"className":48,"code":153,"language":50,"meta":51,"style":51},"for(var i = 0; i \u003C 10; i++) {\n  console.log(i); \u002F\u002F 1..2..3..4..5..\n}\nconsole.log(i); \u002F\u002F10\n",[30,155,156,193,206,211],{"__ignoreMap":51},[55,157,158,161,164,166,169,171,175,178,181,184,187,190],{"class":57,"line":58},[55,159,160],{"class":79},"for",[55,162,163],{"class":61},"(",[55,165,40],{"class":79},[55,167,168],{"class":61}," i ",[55,170,85],{"class":79},[55,172,174],{"class":173},"sCcAr"," 0",[55,176,177],{"class":61},"; i ",[55,179,180],{"class":79},"\u003C",[55,182,183],{"class":173}," 10",[55,185,186],{"class":61},"; i",[55,188,189],{"class":79},"++",[55,191,192],{"class":61},") {\n",[55,194,195,19