0],{"class":60},");\n",[50,82,84,87,91,94,98],{"class":52,"line":83},2,[50,85,86],{"class":60},"console.",[50,88,90],{"class":89},"scAaK","log",[50,92,93],{"class":60},"(",[50,95,97],{"class":96},"sWayO","'a:'",[50,99,100],{"class":60},", a);\n",[50,102,104,106,108,110,113],{"class":52,"line":103},3,[50,105,86],{"class":60},[50,107,90],{"class":89},[50,109,93],{"class":60},[50,111,112],{"class":96},"'b:'",[50,114,115],{"class":60},", b);\n",[16,117,118,119,121,122,125],{},"在往後看之前，可以先試想一下 ",[47,120,26],{}," 跟 ",[47,123,124],{},"b"," 答案是多少。",[127,128,129,138,145,153],"ol",{},[130,131,132,74,135],"li",{},[47,133,134],{},"a: 1",[47,136,137],{},"b: 2",[130,139,140,74,143],{},[47,141,142],{},"a: undefined",[47,144,137],{},[130,146,147,74,150],{},[47,148,149],{},"a: 2",[47,151,152],{},"b: 1",[130,154,155,74,157],{},[47,156,134],{},[47,158,159],{},"b: undefined",[161,162,163,167,174],"details",{},[164,165,166],"summary",{},"點我看解答(請認真思考後再看解答)",[16,168,169,170,74,172],{},"答案是 ",[47,171,142],{},[47,173,137],{},[16,175,176],{},"你猜對了嗎？",[12,178,179],{"id":179},"題目解析",[16,181,182],{},"首先我們一一來拆解這個題目。",[16,184,185,186,189,190,194,195,197],{},"首先是 ",[47,187,188],{},"var a, b"," 的部分，這一段我們可以知道它是一個多重宣告變數，什麼意思呢？在「",[26,191,193],{"href":192},"\u002Fjavascript\u002F20200726\u002F2777973914\u002F","JavaScript 核心觀念(23)-物件-額外補充：變數及物件屬性的差異","」這邊有提到過若沒有使用 ",[47,196,57],{}," 宣告的話，實質上就只是一個單純的物件新增，因此是可以被刪除的，所以我們可以嘗試這樣做",[40,199,201],{"className":42,"code":200,"language":44,"meta":45,"style":45},"var a, b\n\ndelete a; \u002F\u002F false\ndelete b; \u002F\u002F false\n",[47,202,203,210,216,228],{"__ignoreMap":45},[50,204,205,207],{"class":52,"line":53},[50,206,57],{"class":56},[50,208,209],{"class":60}," a, b\n",[50,211,212],{"class":52,"line":83},[50,213,215],{"emptyLinePlaceholder":214},true,"\n",[50,217,218,221,224],{"class":52,"line":103},[50,219,220],{"class":56},"delete",[50,222,223],{"class":60}," a; ",[50,225,227],{"class":226},"sGBqm","\u002F\u002F false\n",[50,229,231,233,236],{"class":52,"line":230},4,[50,232,220],{"class":56},[50,234,235],{"class":60}," b; ",[50,237,227],{"class":226},[16,239,240,241,121,243,245,246,249],{},"代表著 ",[47,242,26],{},[47,244,124],{}," 都是真實宣告的變數，那麼接下來看下一段 ",[47,247,248],{},"(1, 2)","，最外層是圓括號運算子，而它的用途是做什麼呢？在 MDN 中有說明：",[251,252,253],"blockquote",{},[16,254,255,256,259],{},"The grouping operator ",[47,257,258],{},"( )"," controls the precedence of evaluation in expressions.",[16,261,262],{},"簡單來講就是用於控制表達式優先性，例如：",[40,264,266],{"className":42,"code":265,"language":44,"meta":45,"style":45},"3 + 3 * 2; \u002F\u002F 9\n",[47,267,268],{"__ignoreMap":45},[50,269,270,273,276,279,282,285,288],{"class":52,"line":53},[50,271,272],{"class":70},"3",[50,274,275],{"class":56}," +",[50,277,278],{"class":70}," 3",[50,280,281],{"class":56}," *",[50,283,284],{"class":70}," 2",[50,286,287],{"class":60},"; ",[50,289,290],{"class":226},"\u002F\u002F 9\n",[16,292,293],{},"透過圓括號運算子後，就會變成：",[40,295,297],{"className":42,"code":296,"language":44,"meta":45,"style":45},"(3 + 3) * 2; \u002F\u002F 12\n",[47,298,299],{"__ignoreMap":45},[50,300,301,303,305,307,309,312,315,317,319],{"class":52,"line":53},[50,302,93],{"class":60},[50,304,272],{"class":70},[50,306,275],{"class":56},[50,308,278],{"class":70},[50,310,311],{"class":60},") ",[50,313,314],{"class":56},"*",[50,316,284],{"class":70},[50,318,287],{"class":60},[50,320,321],{"class":226},"\u002F\u002F 12\n",[16,323,324,325,330],{},"這邊 MDN 文件也有講到一個重點「precedence of evaluation in expressions」，代表著裡面的逗號是一個表達式，所以我們可以去查一下",[26,326,329],{"href":327,"rel":328},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-CN\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FOperators\u002FComma_Operator",[30],"逗號運算子","的文件，這邊 MDN 有提到關於逗號運算子的運作：",[251,332,333],{},[16,334,335],{},"The comma operator (,) evaluates each of its operands (from left to right) and returns the value of the last operand.",[16,337,338],{},"中文意思大概就是，逗號運算子會從左至右開始計算，然後回傳最後一個結尾的值，因此我們可以這樣子實測：",[40,340,342],{"className":42,"code":341,"language":44,"m