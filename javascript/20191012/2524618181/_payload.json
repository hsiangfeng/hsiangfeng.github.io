);\n",[44,86,88],{"class":46,"line":87},3,[44,89,90],{"class":64},"}\n",[16,92,93,94,96,97,99],{},"我們每次要建立一個函式的時候，都必須要打八個字，也就是 ",[26,95,28],{},"，但是我們如果我們改用 ES6 就只需要打兩個字 ",[26,98,32],{},"，所以上面這個匿名函式就可以這樣改：",[35,101,103],{"className":37,"code":102,"language":39,"meta":40,"style":40},"let myname = () => {\n  console.log('Ray');\n}\n",[26,104,105,121,133],{"__ignoreMap":40},[44,106,107,109,111,113,116,118],{"class":46,"line":47},[44,108,51],{"class":50},[44,110,55],{"class":54},[44,112,58],{"class":50},[44,114,115],{"class":64}," () ",[44,117,32],{"class":50},[44,119,120],{"class":64}," {\n",[44,122,123,125,127,129,131],{"class":46,"line":68},[44,124,71],{"class":64},[44,126,74],{"class":54},[44,128,77],{"class":64},[44,130,81],{"class":80},[44,132,84],{"class":64},[44,134,135],{"class":46,"line":87},[44,136,90],{"class":64},[16,138,139],{},"頓時你應該會覺得程式碼瞬間簡潔很多，但是原本的函式定義是這樣子：",[35,141,143],{"className":37,"code":142,"language":39,"meta":40,"style":40},"function fu () {\n  console.log('Ray');\n}\n",[26,144,145,154,166],{"__ignoreMap":40},[44,146,147,149,152],{"class":46,"line":47},[44,148,28],{"class":50},[44,150,151],{"class":54}," fu",[44,153,65],{"class":64},[44,155,156,158,160,162,164],{"class":46,"line":68},[44,157,71],{"class":64},[44,159,74],{"class":54},[44,161,77],{"class":64},[44,163,81],{"class":80},[44,165,84],{"class":64},[44,167,168],{"class":46,"line":87},[44,169,90],{"class":64},[16,171,172],{},"你並不能將原本的一般函式定義改成箭頭函式這樣：",[35,174,176],{"className":37,"code":175,"language":39,"meta":40,"style":40},"fu () => {\n  console.log('Ray');\n}\n",[26,177,178,189,201],{"__ignoreMap":40},[44,179,180,183,185,187],{"class":46,"line":47},[44,181,182],{"class":54},"fu",[44,184,115],{"class":64},[44,186,32],{"class":50},[44,188,120],{"class":64},[44,190,191,193,195,197,199],{"class":46,"line":68},[44,192,71],{"class":64},[44,194,74],{"class":54},[44,196,77],{"class":64},[44,198,81],{"class":80},[44,200,84],{"class":64},[44,202,203],{"class":46,"line":87},[44,204,90],{"class":64},[16,206,207,208,211,212,214],{},"另外箭頭函式還有一個問題，也就是 ",[26,209,210],{},"this"," 的部分，在箭頭函式的 ",[26,213,210],{}," 會與原本的傳統函式不同，這邊寫個範例舉例一下：",[16,216,217,218,222],{},"傳統函式的 this 重點在於",[219,220,221],"strong",{},"依照呼叫的方式而決定","：",[35,224,226],{"className":37,"code":225,"language":39,"meta":40,"style":40},"var myname = '我是路人';\n\nvar a = {\n  myname: 'Ray',\n  fu: function () {\n    console.log(this.myname);\n  }\n}\na.fu(); \u002F\u002F Ray\n",[26,227,228,245,251,262,273,286,302,308,313],{"__ignoreMap":40},[44,229,230,233,236,239,242],{"class":46,"line":47},[44,231,232],{"class":50},"var",[44,234,235],{"class":64}," myname ",[44,237,238],{"class":50},"=",[44,240,241],{"class":80}," '我是路人'",[44,243,244],{"class":64},";\n",[44,246,247],{"class":46,"line":68},[44,248,250],{"emptyLinePlaceholder":249},true,"\n",[44,252,253,255,258,260],{"class":46,"line":87},[44,254,232],{"class":50},[44,256,257],{"class":64}," a ",[44,259,238],{"class":50},[44,261,120],{"class":64},[44,263,265,268,270],{"class":46,"line":264},4,[44,266,267],{"class":64},"  myname: ",[44,269,81],{"class":80},[44,271,272],{"class":64},",\n",[44,274,276,279,282,284],{"class":46,"line":275},5,[44,277,278],{"class":54},"  fu",[44,280,281],{"class":64},": ",[44,283,28],{"class":50},[44,285,65],{"class":64},[44,287,289,292,294,296,299],{"class":46,"line":288},6,[44,290,291],{"class":64},"    console.",[44,293,74],{"class":54},[44,295,77],{"class":64},[44,297,210],{"class":298},"sCcAr",[44,300,301],{"class":64},".myname);\n",[44,303,305],{"class":46,"line":304},7,[44,306,307],{"class":64},"  }\n",[44,309,311],{"class":46,"line":310},8,[44,312,90],{"class":64},[44,314,316,319,321,324],{"class":46,"line":315},9,[44,317,318],{"class":64},"a.",[44,320,182],{"class":54},[44,322,323],{"class":64},"(); ",[44,325,327],{"class":326},"sQrFR","\u002F\u002F Ray\n",[16,329,330],{},"但是如果你改成箭頭函式呢?",[35,332,334],{"className":37,"code":333,"language":39,"meta":40,"style":40},"var myname = '我是路人';\n\nvar a = {\n  myname: 'Ray',\n  fu: 