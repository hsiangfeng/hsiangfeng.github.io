[{"data":1,"prerenderedAt":382},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190929\u002F3075111357\u002F":3,"page:\u002Fjavascript\u002F20190929\u002F3075111357\u002F":4,"alt:\u002Fjavascript\u002F20190929\u002F3075111357\u002F":3,"prev-next:\u002Fjavascript\u002F20190929\u002F3075111357\u002F":357,"related:\u002Fjavascript\u002F20190929\u002F3075111357\u002F":366},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F29\u002Fjs-from-zero-14-json\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":340,"date":341,"description":18,"extension":342,"lang":343,"meta":344,"navigation":345,"path":346,"readingMinutes":347,"seo":348,"standalone":349,"stem":350,"tags":351,"tldr":354,"updated":354,"url":355,"__hash__":356},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-14-RE：從零開始的學習-JS-生活-第十四日.md","EP.14 RE：從零開始的學習 JS 生活-第十四日之 JSON","3075111357",{"type":9,"value":10,"toc":335},"minimark",[11,15,19,23,26,99,102,105,162,165,173,212,215,218,234,286,293,319,325,328,331],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第十四日，這一篇將會來介紹 JSON。",[12,20,22],{"id":21},"json","JSON",[16,24,25],{},"JSON 全名是 JavaScript Object Notation，中文即 JavaScript 物件表示法，從名子來看它看起來跟 JavaScript 很有關係，從維基百科以及 MDN 來看兩者確實是有點關係，但是其實 JSON 與 JavaScript 是屬於兩種東西，其概念上概念上 JSON 是以 JavaScript 物件實字語法為基礎所發明的：",[27,28,33],"pre",{"className":29,"code":30,"language":31,"meta":32,"style":32},"language-js shiki shiki-themes github-dark-high-contrast","var object = {\n name: 'Ray',\n status: true,\n};\nconsole.log(object);\n","js","",[34,35,36,55,68,80,86],"code",{"__ignoreMap":32},[37,38,41,45,49,52],"span",{"class":39,"line":40},"line",1,[37,42,44],{"class":43},"sWyjQ","var",[37,46,48],{"class":47},"sMAXC"," object ",[37,50,51],{"class":43},"=",[37,53,54],{"class":47}," {\n",[37,56,58,61,65],{"class":39,"line":57},2,[37,59,60],{"class":47}," name: ",[37,62,64],{"class":63},"sTRMh","'Ray'",[37,66,67],{"class":47},",\n",[37,69,71,74,78],{"class":39,"line":70},3,[37,72,73],{"class":47}," status: ",[37,75,77],{"class":76},"sCcAr","true",[37,79,67],{"class":47},[37,81,83],{"class":39,"line":82},4,[37,84,85],{"class":47},"};\n",[37,87,89,92,96],{"class":39,"line":88},5,[37,90,91],{"class":47},"console.",[37,93,95],{"class":94},"sj_SG","log",[37,97,98],{"class":47},"(object);\n",[16,100,101],{},"所以當你再來看 JSON 時，就會覺得這兩者有幾分神似呢。",[16,103,104],{},"首先早期開發還沒有出現 JSON 的時，大多都是採用 XML 傳送資料，大概會像這樣：",[27,106,110],{"className":107,"code":108,"language":109,"meta":32,"style":32},"language-xml shiki shiki-themes github-dark-high-contrast","\u003Cobject>\n \u003Cname>mary\u003C\u002Fname>\n \u003Cstatus>true\u003C\u002Fstatus>\n\u003C\u002Fobject>\n","xml",[34,111,112,124,139,153],{"__ignoreMap":32},[37,113,114,117,121],{"class":39,"line":40},[37,115,116],{"class":47},"\u003C",[37,118,120],{"class":119},"sKpQp","object",[37,122,123],{"class":47},">\n",[37,125,126,129,132,135,137],{"class":39,"line":57},[37,127,128],{"class":47}," \u003C",[37,130,131],{"class":119},"name",[37,133,134],{"class":47},">mary\u003C\u002F",[37,136,131],{"class":119},[37,138,123],{"class":47},[37,140,141,143,146,149,151],{"class":39,"line":70},[37,142,128],{"class":47},[37,144,145],{"class":119},"status",[37,147,148],{"class":47},">true\u003C\u002F",[37,150,145],{"class":119},[37,152,123],{"class":47},[37,154,155,158,160],{"class":39,"line":82},[37,156,157],{"class":47},"\u003C\u002F",[37,159,120],{"class":119},[37,161,123],{"class":47},[16,163,164],{},"那麼當 XML 的資料越來越肥大時，就會變得很麻煩，因為檔案會變的很大，而且裡面會一推沒有必要的符號。",[16,166,167,168,172],{},"所以後來就有一位叫 ",[169,170,171],"strong",{},"道格拉斯·克羅克福特"," 的人，基於 JavaScript 的物件實字建立方式創造出了 JSON，畢竟如果繼續基於以前的做法，那麼當需要傳送的資料越來越多，那就會發生很非常嚴重的問題，也就是檔案會太大、太肥等問題，這樣子的下場就是使用者就必須花更多的時間 & 流量來下載資料，畢竟裡面有太多不需要的符號以及多餘且重複的符號，而這些都是影響使用者體驗的關鍵，所以道格拉斯·克羅克福特才會將 JSON 命名為 JavaScript Object Notation，那 JSON 的撰寫方式如下 ↓",[27,174,177],{"className":175,"code":176,"language":21,"meta":32,"style":32},"language-json shiki shiki-themes github-dark-high-contrast","[{\n \"name\": \"Ray\",\n \"status\": \"true\"\n}];\n",[34,178,179,184,197,207],{"__ignoreMap":32},[37,180,181],{"class":39,"line":40},[37,182,183],{"class":47},"[{\n",[37,185,186,189,192,195],{"class":39,"line":57},[37,187,188],{"class":119}," \"name\"",[37,190,191],{"class":47},": ",[37,193,194],{"class":63},"\"Ray\"",[37,196,67],{"class":47},[37,198,199,202,204],{"class":39,"line":70},[37,200,201],{"class":119}," \"status\"",[37,203,191],{"class":47},[37,205,206],{"class":63},"\"true\"\n",[37,208,209],{"class":39,"line":82},[37,210,211],{"class":47},"}];\n",[16,213,214],{},"而這也是我們目前前後端所使用的資料傳送格式，現在大多後端都已經改採用 JSON 格式往前端傳送。",[16,216,217],{},"那由於 JSON 並不是 JavaScript 的一部分，而且 JSON 是一個比較嚴格的檔案，但我們無法否認 JSON 的非常紅且好用，所以 JavaScript 提供了兩種語法可以將 JSON 格式轉換為 JavaScript 可讀取的格式以及將 JavaScript 轉換成 JSON 格式。",[219,220,221,228],"ul",{},[222,223,224,227],"li",{},[34,225,226],{},"JSON.stringify()"," - 物件實字語法轉換成 JSON 格式",[222,229,230,233],{},[34,231,232],{},"JSON.parse()"," - JSON 格式轉換成物件實字語法",[27,235,237],{"className":29,"code":236,"language":31,"meta":32,"style":32},"var object = {\n name: 'Ray',\n status: true,\n};\nJSON.stringify(object); \u002F\u002F 物件實字語法轉換成 JSON 格式\n",[34,238,239,249,257,265,269],{"__ignoreMap":32},[37,240,241,243,245,247],{"class":39,"line":40},[37,242,44],{"class":43},[37,244,48],{"class":47},[37,246,51],{"class":43},[37,248,54],{"class":47},[37,250,251,253,255],{"class":39,"line":57},[37,252,60],{"class":47},[37,254,64],{"class":63},[37,256,67],{"class":47},[37,258,259,261,263],{"class":39,"line":70},[37,260,73],{"class":47},[37,262,77],{"class":76},[37,264,67],{"class":47},[37,266,267],{"class":39,"line":82},[37,268,85],{"class":47},[37,270,271,273,276,279,282],{"class":39,"line":88},[37,272,22],{"class":76},[37,274,275],{"class":47},".",[37,277,278],{"class":94},"stringify",[37,280,281],{"class":47},"(object); ",[37,283,285],{"class":284},"sQrFR","\u002F\u002F 物件實字語法轉換成 JSON 格式\n",[16,287,288],{},[289,290],"img",{"alt":291,"src":292},"物件實字語法轉換成 JSON 格式","https:\u002F\u002Fi.imgur.com\u002Ftm1ZPfq.png",[27,294,296],{"classNa