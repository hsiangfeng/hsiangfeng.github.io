n",[36,79,81,84,87],{"class":38,"line":80},4,[36,82,83],{"class":46},"  name: ",[36,85,86],{"class":53},"'Ray'",[36,88,89],{"class":46},",\n",[36,91,93],{"class":38,"line":92},5,[36,94,95],{"class":46},"};\n",[16,97,98],{},"在上面範例中細分為兩個部分，一個是純值一個是物件，接下來我們來畫一張圖，分別代表物件與純值",[16,100,101,102,105],{},"在一開始 JavaScript 會先準備好兩個變數，並且先指向到 ",[33,103,104],{},"undefined"," (提升的觀念，所以沒有什麼太大問題)",[16,107,108],{},[109,110],"img",{"alt":111,"src":112},"指向 undefined","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-15%2022.46.57.png",[16,114,115,116,119,120,122],{},"接下來因為 JavaScript 會準備一個記憶體空間放置我們的純值，此時 ",[33,117,118],{},"a"," 會指向該記憶體空間，而這個記憶體空間可能是 0x01，因此 ",[33,121,118],{}," 其實是取得 0x01 的記憶體空間並且賦予回去而已",[16,124,125],{},[109,126],{"alt":127,"src":128},"記憶體空間","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-15%2022.53.51.png",[16,130,131,132,135,136,138,139,142],{},"接下來我們會有一個行為是 ",[33,133,134],{},"var c = a;"," 將 ",[33,137,118],{}," 複製到 ",[33,140,141],{},"c","，這邊要注意純值在賦予到其他變數時，是指向同一個記憶體空間並賦予值(複製一份過來)而已",[26,144,146],{"className":28,"code":145,"language":30,"meta":31,"style":31},"var a = 'Ray';\n\nvar c = a;\n",[33,147,148,160,164],{"__ignoreMap":31},[36,149,150,152,154,156,158],{"class":38,"line":39},[36,151,43],{"class":42},[36,153,47],{"class":46},[36,155,50],{"class":42},[36,157,54],{"class":53},[36,159,57],{"class":46},[36,161,162],{"class":38,"line":60},[36,163,64],{"emptyLinePlaceholder":63},[36,165,166,168,171,173],{"class":38,"line":67},[36,167,43],{"class":42},[36,169,170],{"class":46}," c ",[36,172,50],{"class":42},[36,174,175],{"class":46}," a;\n",[16,177,178],{},[109,179],{"alt":180,"src":181},"指向同一個記憶體空間","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-15%2023.00.07.png",[16,183,184],{},"我相信這邊已經非常混亂了，所以我用動畫呈現了一下",[16,186,187],{},[109,188],{"alt":189,"src":190},"動畫呈現","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E7%B4%94%E5%80%BC%E6%8C%87%E5%90%91.gif",[16,192,193,194,196,197,199],{},"因此你在修改 ",[33,195,141],{}," 的值時，並不會影響到 ",[33,198,118],{},"，因為他是重新指向到另一個記憶體空間叫做 0x02",[26,201,203],{"className":28,"code":202,"language":30,"meta":31,"style":31},"var a = 'Ray';\n\nvar c = a;\n\nc = '123';\n",[33,204,205,217,221,231,235],{"__ignoreMap":31},[36,206,207,209,211,213,215],{"class":38,"line":39},[36,208,43],{"class":42},[36,210,47],{"class":46},[36,212,50],{"class":42},[36,214,54],{"class":53},[36,216,57],{"class":46},[36,218,219],{"class":38,"line":60},[36,220,64],{"emptyLinePlaceholder":63},[36,222,223,225,227,229],{"class":38,"line":67},[36,224,43],{"class":42},[36,226,170],{"class":46},[36,228,50],{"class":42},[36,230,175],{"class":46},[36,232,233],{"class":38,"line":80},[36,234,64],{"emptyLinePlaceholder":63},[36,236,237,240,242,245],{"class":38,"line":92},[36,238,239],{"class":46},"c ",[36,241,50],{"class":42},[36,243,244],{"class":53}," '123'",[36,246,57],{"class":46},[16,248,249],{},[109,250],{"alt":251,"src":252},"新的記憶體空間","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-15%2023.08.00.png",[16,254,255,256,258,259,261],{},"這也是為什麼我們修改 ",[33,257,141],{}," 時並不會影響到 ",[33,260,118],{},"，因為兩者是不同的記憶體空間。",[12,263,264],{"id":264},"物件傳參考",[16,266,267,268,271],{},"接下來講講比較難的東西，也就是物件，在物件中基本上我們看到變數後面接著 ",[33,269,270],{},"{ }"," 就可以知道是一個物件",[26,273,275],{"className":28,"code":274,"language":30,"meta":31,"style":31},"var b = {\n  name: 'Ray',\n};\n",[33,276,277,287,295],{"__ignoreMap":31},[36,278,279,281,283,285],{"class":38,"line":39},[36,280,43],{"class":42},[36,282,72],{"class":46},[36,284,50],{"class":42},[36,286,77],{"class":46},[36,288,289,291,293],{"class":38,"line":60},[36,290,83],{"class":46},[36,292,86],{"class":53},[36,294,89],{"class":46},[36,296,297],{"class":38,"line":67},[36,298,95],{"class":46},[16,300,301],{},"並且我們也知道物件有一個東西叫做「物件傳參考」，顧名思義我們賦予到另一個變數之後病修改裡面的屬性，原有的屬性會被修改",[26,303,305],{"className":28,"code":304,"language":30,"meta":31,"style":31},"var b = {\n  name: 'Ray',\n};\n\nvar e = b;\n\ne.name = 'QQ';\nconsole.log(b.name); \u002F\u002F QQ\n",[33,306,307,317,325,329,333,345,350,363],{"__ignoreMap":31},[36,308,309,311,313,315],{"class":38,"line":39},[36,310,43],{"class":42},[36,312,72],{"class":46},[36,314,50],{"class":42},[36,316,77],{"class":46},[36,318,319,321,323],{"class":38,"line":60},[36,320,83],{"class":46},[36,322,86],{"class":53},[36,324,89],{"class":46},[36,326,327],{"class":38,"line":67},[36,328,95],{"class":46},[36,330,331],{"class":38,"line":80},[36,332,64],{"emptyLinePlaceholder":63},[36,334,335,337,340,342],{"class":38,"line":92},[36,336,43],{"class":42},[36,338,339],{"class":46}," e ",[36,341,50],{"class":42},[36,343,344],{"class":46}," b;\n",[36,346,348],{"class":38,"line":347},6,[36,349,64],{"emptyLinePlaceholder":63},[36,351,353,356,358,361],{"class":38,"line":352},7,[36,354,355],{"class":46},"e.name ",[36,357,50],{"class":42},[36,359,360],{"class":53}," 'QQ'",[36,362,57],{"class":46},[36,364,366,369,373,376],{"class":38,"line":365},8,[36,367,368],{"class":46},"console.",[36,370,372],{"class":371},"sj_SG","log",[36,374,375],{"class":46},"(b.name); ",[36,377,379],{"class":378},"sQrFR","\u002F\u002F QQ\n",[16,381,382,383,385,386,388],{},"那這一段在記憶體空間與指向上又是怎樣呢？首先 ",[33,384,270],{}," 一樣會建立一個記憶體空間(",[33,387,104],{}," 那一段我就不提了)假設是 0x03 並且指向賦予回來",[16,390,391],{},[109,392],{"alt":393,"src":394},"物件記憶體指向","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-15%2023.43.57.png",[16,396,397],{},"這一段基本上應該沒什麼問題，與純值那邊很像",[16,399,400,401,404],{},"但是重點是在於屬性的部分，目前屬性是一個純值概念，這些屬性都有屬於自己的記憶體空間，而 ",[33,402,403],{},"name"," 是只存活在這個 0x03 的記憶體空間底下的屬性，這個屬性也會指向另一個記憶體空間例如 0x04，這邊概念與純值得很像",[16,406,407],{},[109,408],{"alt":409,"src":410},"屬性記憶體指向","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-15%2023.52.51.png",[16,412,413],{},"我相信這邊指向概念已經很混亂了，所以也補上動畫圖",[16,415,416],{},[109,417],{"alt":418,"src":419},"記憶體指向動畫","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E7%89%A9%E4%BB%B6%E8%A8%98%E6%86%B6%E9%AB%94%E6%8C%87%E5%90%91.gif",[16,421,422,423,426,427,429,430,433,434,437],{},"那麼接下來講講為什麼當我們使用 ",[33,424,425],{},"var e = b;"," 並且修改 ",[33,428,403],{}," 屬性時，原有的物件會被修改，首先我們一樣會建立一個變數 ",[33,431,432],{},"e"," 這時候記憶體空間會指向到 ",[33,435,436],{},"b"," 的記憶體位置，這一段應該沒什麼太大問題",[16,439,440],{},[109,441],{"alt":442,"src":443},"變數 e 記憶體指向到變數 b 的記憶體空間","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-16%2000.05.38.png",[16,445,446,447,450,451,454,455,457],{},"接下來重點來了，我們可以看到上方圖片我們的記憶體空間一直是指著 0x03，因此我們在操作 ",[33,448,449],{},"e.name"," 時，其實是操作 0x03 底下 name 屬性指向的 0x04 記憶體空間，這也就是為什麼 ",[33,452,453],{},"e.name = 'Ray'"," 會影響到原有的 ",[33,456,436],{}," 物件，因為從頭到尾都是相同的指向記憶體。",[26,459,460],{"className":28,"code":304,"language":30,"meta":31,"style":31},[33,461,462,472,480,484,488,498,502,512],{"__ignoreMap":31},[36,463,464,466,468,470],{"class":38,"line":39},[36,465,43],{"class":42},[36,467,72],{"class":46},[36,469,50],{"class":42},[36,471,77],{"class":46},[36,473,474,476,478],{"class":38,"line":60},[36,475,83],{"class":46},[36,477,86],{"class":53},[36,479,89],{"class":46},[36,481,482],{"class":38,"line":67},[36,483,95],{"class":46},[36,485,486],{"class":38,"line":80},[36,487,64],{"emptyLinePlaceholder":63},[36,489,490,492,494,496],{"class":38,"line":92},[36,491,43],{"c