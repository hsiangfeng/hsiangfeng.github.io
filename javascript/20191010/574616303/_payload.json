[{"data":1,"prerenderedAt":146},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20191010\u002F574616303\u002F":3,"page:\u002Fjavascript\u002F20191010\u002F574616303\u002F":4,"alt:\u002Fjavascript\u002F20191010\u002F574616303\u002F":3,"prev-next:\u002Fjavascript\u002F20191010\u002F574616303\u002F":121,"related:\u002Fjavascript\u002F20191010\u002F574616303\u002F":130},"\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F10\u002Fjs-from-zero-25-callback-hell\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":104,"date":105,"description":18,"extension":106,"lang":107,"meta":108,"navigation":109,"path":110,"readingMinutes":111,"seo":112,"standalone":113,"stem":114,"tags":115,"tldr":118,"updated":118,"url":119,"__hash__":120},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-25-RE：從零開始的學習-JS-生活-第二十五日.md","EP.25 RE：從零開始的學習 JS 生活-第二十五日之 Callback Hell","574616303",{"type":9,"value":10,"toc":97},"minimark",[11,15,19,23,26,33,41,44,47,53,56,64,71,77,83,86],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第二十五日，這一篇主要稍微介紹一下什麼是 Callback Hell。",[12,20,22],{"id":21},"callback-hell","Callback Hell",[16,24,25],{},"Callback Hell 中文是回呼地獄，這種狀況在現階段程式開發是一件非常常見的事情，首先所謂的回呼地獄大致上常見的問題在於「我們希望事件可以依照我們要求的順序執行」，那這種時候就會發生 Callback Hell，這邊舉例一個我先前做的範例 ↓",[16,27,28],{},[29,30],"img",{"alt":31,"src":32},"RagnarokShopV3 作品其中一段 Callback Hell","https:\u002F\u002Fi.imgur.com\u002FsRZ31tr.png",[16,34,35,36,40],{},"由於我們希望程式碼可以依照我們希望的流程來跑，所以就會導致有非常多的 ",[37,38,39],"code",{},"if…if…"," 判斷式來判斷資料是否取得或是處理完畢。",[16,42,43],{},"那 Callback Hell 在 debug 上其實是非常痛苦的，其中最主要的地方在於括號真的超級多，往往一個不小心你可能就會多刪掉一個括號，導致你要一行一行找問題。",[16,45,46],{},"如果都不做處理的話就會變成像波動拳的形式 ↓",[16,48,49],{},[29,50],{"alt":51,"src":52},"波動拳!","https:\u002F\u002Fres.cloudinary.com\u002Fpracticaldev\u002Fimage\u002Ffetch\u002Fs--1ppnEIAU--\u002Fc_limit%2Cf_auto%2Cfl_progressive%2Cq_66%2Cw_880\u002Fhttps:\u002F\u002Fthepracticaldev.s3.amazonaws.com\u002Fi\u002Fa79vj0fvvdylajtcqz87.gif",[16,54,55],{},"那麼為什麼 Callback Hell 會發生呢?在 JavaScript 中這與它的語言特性有關係，所以你 Google Callback Hell 應該都會找到滿多都是在講 JavaScript 的，但是這邊要提醒一件事情 Callback Hell 並不存在於 JavaScript 世界中，而是在任何一個語言都有可能出現，這只是大家約定俗成的一種叫法而已。",[16,57,58,59,63],{},"那應該怎麼解決 Callback Hell?這邊剛好我先前有寫過關於解決 Callback Hell 的相關文章，其中裡面也會介紹 ",[60,61,62],"strong",{},"非同步與同步事件"," 的觀念，所以就直接貼上 LINK 不在寫一次了(圖畫的很累...)。",[16,65,66],{},[67,68,70],"a",{"href":69},"\u002Fjavascript\u002F20190530\u002F3337676145\u002F","JavaScript 非同步與同步事件之 Promise",[16,72,73],{},[67,74,76],{"href":75},"\u002Fjavascript\u002F20190530\u002F2986904348\u002F","JavaScript 非同步與同步事件之 await",[16,78,79],{},[67,80,82],{"href":81},"\u002Fjavascript\u002F20190530\u002F3821927811\u002F","JavaScript 非同步與同步事件之 async",[12,84,85],{"id":85},"結尾",[16,87,88,89,92,93,96],{},"下一篇的 RE：從零開始的學習 JS 生活-第二十六日 將會介紹 ES6 的 ",[37,90,91],{},"let"," & ",[37,94,95],{},"const","。",{"title":98,"searchDepth":99,"depth":99,"links":100},"",2,[101,102,103],{"id":14,"depth":99,"text":14},{"id":21,"depth":99,"text":22},{"id":85,"depth":99,"text":85},"JavaScript","2019-10-10 05:06:52","md","zh-Hant",{},true,"\u002Fre-js\u002Fep-25-re-js","1",{"title":6,"description":18},false,"RE：從零開始的學習 JS 生活\u002FEP-25-RE：從零開始的學習-JS-生活-第二十五日",[104,116,117],"RE：從零開始的學習 JS 生活","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fjavascript\u002F20191010\u002F574616303\u002F","nQBUSgMxls8iyQM0_SjvrWkDYowgiL2PJvxGGJszJ_Y",{"newer":122,"older":126},{"url":123,"title":124,"date":125},"\u002Fjavascript\u002F20191011\u002F1172259820\u002F","EP.26 RE：從零開始的學習 JS 生活-第二十六日之 ES6 變數","2019-10-11 08:40:44",{"url":127,"title":128,"date":129},"\u002Fjavascript\u002F20191009\u002F1275371038\u002F","EP.24 RE：從零開始的學習 JS 生活-第二十四日之 undefined 以及 not defined","2019-10-09 00:00:01",[131,136,141],{"url":132,"title":133,"date":134,"readingMinutes":135},"\u002Fjavascript\u002F20260310\u002F2118283166\u002F","前端加密不求人！Web Crypto API 完整教學：雜湊、AES 加解密、HMAC 簽章","2026-03-10 09:45:08","7",{"url":137,"title":138,"date":139,"readingMinutes":140},"\u002Fjavascript\u002F20251208\u002F3781527973\u002F","一個時代的王者 jQuery，為什麼沒落了？","2