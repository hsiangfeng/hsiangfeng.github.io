取得螢幕畫面高寬",[60,73,74],{},"navigator - 瀏覽器資訊",[60,76,77],{},"print - 開啟列印",[60,79,80],{},"innerHeight - 取得視窗高度",[60,82,83],{},"outerHeight - 取得瀏覽器視窗高度",[60,85,86],{},"close - 關閉當前瀏覽視窗 (目前比較少人使用了)",[16,88,89],{},"那麼接下來就來講一下實作語法怎麼寫吧~",[12,91,92],{"id":92},"history",[16,94,95,96,99,100,103],{},"上下頁的跳轉會搭配使用 ",[27,97,98],{},".back()"," 以及 ",[27,101,102],{},".forward()","。",[16,105,106],{},"上一頁：",[108,109,114],"pre",{"className":110,"code":111,"language":112,"meta":113,"style":113},"language-js shiki shiki-themes github-dark-high-contrast","window.history.back();\n","js","",[27,115,116],{"__ignoreMap":113},[117,118,121,125,129],"span",{"class":119,"line":120},"line",1,[117,122,124],{"class":123},"sMAXC","window.history.",[117,126,128],{"class":127},"sj_SG","back",[117,130,131],{"class":123},"();\n",[16,133,134],{},"下一頁：",[108,136,138],{"className":110,"code":137,"language":112,"meta":113,"style":113},"window.history.forward();\n",[27,139,140],{"__ignoreMap":113},[117,141,142,144,147],{"class":119,"line":120},[117,143,124],{"class":123},[117,145,146],{"class":127},"forward",[117,148,131],{"class":123},[16,150,151,152],{},"當然還有一個方法可以使用，也就是 ",[27,153,154],{},"go()",[16,156,106],{},[108,158,160],{"className":110,"code":159,"language":112,"meta":113,"style":113},"window.history.go(-1);\n",[27,161,162],{"__ignoreMap":113},[117,163,164,166,169,172,176,180],{"class":119,"line":120},[117,165,124],{"class":123},[117,167,168],{"class":127},"go",[117,170,171],{"class":123},"(",[117,173,175],{"class":174},"sWyjQ","-",[117,177,179],{"class":178},"sCcAr","1",[117,181,182],{"class":123},");\n",[16,184,134],{},[108,186,188],{"className":110,"code":187,"language":112,"meta":113,"style":113},"window.history.go(1);\n",[27,189,190],{"__ignoreMap":113},[117,191,192,194,196,198,200],{"class":119,"line":120},[117,193,124],{"class":123},[117,195,168],{"class":127},[117,197,171],{"class":123},[117,199,179],{"class":178},[117,201,182],{"class":123},[12,203,204],{"id":204},"location",[16,206,207,209],