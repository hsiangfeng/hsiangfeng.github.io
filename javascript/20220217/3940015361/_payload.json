[{"data":1,"prerenderedAt":616},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20220217\u002F3940015361\u002F":3,"page:\u002Fjavascript\u002F20220217\u002F3940015361\u002F":4,"alt:\u002Fjavascript\u002F20220217\u002F3940015361\u002F":3,"prev-next:\u002Fjavascript\u002F20220217\u002F3940015361\u002F":591,"related:\u002Fjavascript\u002F20220217\u002F3940015361\u002F":600},"\u002Fen\u002Fjavascript\u002F2022\u002F02\u002F17\u002Feslint-switch-style-standard-to-airbnb\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":574,"date":575,"description":18,"extension":576,"lang":577,"meta":578,"navigation":579,"path":580,"readingMinutes":581,"seo":582,"standalone":583,"stem":584,"tags":585,"tldr":588,"updated":588,"url":589,"__hash__":590},"content\u002FJavaScript\u002F如何更改-ESLint-風格.md","如何更改 ESLint 風格","3940015361",{"type":9,"value":10,"toc":569},"minimark",[11,15,19,22,31,39,46,49,55,62,91,94,103,108,114,120,126,141,144,148,163,169,175,178,422,428,471,484,489,498,534,547,555,565],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"專案開發上我們一定會使用風格管理器幫我們統一程式碼的撰寫風格，那麼以前端來講就是 ESLint，但是一開始我們風格選定之後要再更改其他風格就很麻煩，所以這邊寫一篇如何將 ESLint 風格從 Standard 變成 Airbnb。",[12,20,21],{"id":21},"普通專案",[16,23,24,25,30],{},"這邊我就不說明如何加入 ESLint 到專案內，如果你不熟悉的話建議參考",[26,27,29],"a",{"href":28},"\u002Fjavascript\u002F20210218\u002F4003233584\u002F","這一篇","。",[16,32,33,34,38],{},"當我們輸入 ",[35,36,37],"code",{},"eslint --init"," 之後會需要做一些選擇，我這邊就選擇 Standard",[16,40,41],{},[42,43],"img",{"alt":44,"src":45},"eslint init","https:\u002F\u002Fi.imgur.com\u002FN8rgYAI.png",[16,47,48],{},"安裝完畢之後 ESLint 就會幫我們建立一個 ESLint 設定檔案叫做 .eslintrc.js",[16,50,51],{},[42,52],{"alt":53,"src":54},".eslintrc.js","https:\u002F\u002Fi.imgur.com\u002FYyh2RfP.png",[16,56,57,58,61],{},"還有呢？打開 package.json，你會發現 ",[35,59,60],{},"devDependencies"," 屬性新增了幾個套件",[63,64,65,71,76,81,86],"ul",{},[66,67,68],"li",{},[35,69,70],{},"eslint",[66,72,73],{},[35,74,75],{},"eslint-config-standard",[66,77,78],{},[35,79,80],{},"eslint-plugin-import",[66,82,83],{},[35,84,85],{},"eslint-plugin-node",[66,87,88],{},[35,89,90],{},"eslint-plugin-promise",[16,92,93],{},"(有可能因為你的選擇不同而安裝不同套件。)",[16,95,96,97,99,100,102],{},"那這時候我們想將 Standard 轉換成 Airbnb 該怎麼做呢？基本上就是將 .eslintrc.js 與 ",[35,98,60],{}," 中跟 ",[35,101,70],{}," 有相關的套件都刪除",[16,104,105],{},[42,106],{"alt":60,"src":107},"https:\u002F\u002Fi.imgur.com\u002FFqoiUVc.png",[16,109,110,111,113],{},"並且也要將 node_modules 資料夾刪除，然後再重新輸入 ",[35,112,37],{}," 重新選擇你要的 ESLint 風格即可，像是我這邊就重新將 Standard 變成 Airbnb",[16,115,116],{},[42,117],{"alt":118,"src":119},"Airbnb","https:\u002F\u002Fi.imgur.com\u002F9ayAOy4.png",[16,121,122,123,125],{},"除了 .eslintrc.js 我們不看之外，你可以看看 package.json 中的 ",[35,124,60],{}," 有什麼變化，基本上變成了改安裝以下套件",[63,127,128,132,137],{},[66,129,130],{},[35,131,70],{},[66,133,134],{},[35,135,136],{},"eslint-config-airbnb-base",[66,138,139],{},[35,140,80],{},[16,142,143],{},"我們可以看到兩者安裝的風格所需要的依賴套件也跟著不同。",[12,145,147],{"id":146},"vue-cli","Vue Cli",[16,149,150,151,153,154,157,158,162],{},"在 Vue Cli or Vite 的環境下通常我們不會使用 ",[35,152,37],{}," 的指令來建立 ESLint 設定，主要是透過另一種方式，也就是 ",[35,155,156],{},"vue add eslint","，詳細可見",[26,159,161],{"href":160},"\u002Fvue\u002F20200522\u002F1986801509\u002F","這篇文章","，原因這邊就不贅述了。",[16,164,165,166,168],{},"首先我們一樣先建立一個 Vue 環境，這邊會以 Cli 當作範例，並輸入 ",[35,167,156],{}," 選擇 Standard 風格",[16,170,171],{},[42,172],{"alt":173,"src":174},"Standard","https:\u002F\u002Fi.imgur.com\u002FaY0mxiI.png",[16,176,177],{},"然後這邊我們先看一下基礎的 package.json",[179,180,185],"pre",{"className":181,"code":182,"language":183,"meta":184,"style":184},"language-json shiki shiki-themes github-dark-high-contrast","{\n  \"name\": \"cli\",\n  \"version\": \"0.1.0\",\n  \"private\": true,\n  \"scripts\": {\n    \"serve\": \"vue-cli-service serve\",\n    \"build\": \"vue-cli-service build\"\n  },\n  \"dependencies\": {\n    \"core-js\": \"^3.6.5\",\n    \"vue\": \"^3.0.0\",\n    \"vue-router\": \"^4.0.0-0\"\n  },\n  \"devDependencies\": {\n    \"@vue\u002Fcli-plugin-babel\": \"~4.5.0\",\n