[{"data":1,"prerenderedAt":706},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190712\u002F1140639545\u002F":3,"page:\u002Fjavascript\u002F20190712\u002F1140639545\u002F":4,"alt:\u002Fjavascript\u002F20190712\u002F1140639545\u002F":3,"prev-next:\u002Fjavascript\u002F20190712\u002F1140639545\u002F":681,"related:\u002Fjavascript\u002F20190712\u002F1140639545\u002F":690},"\u002Fen\u002Fjavascript\u002F2019\u002F07\u002F12\u002Fjavascript-building-freecell-solitaire-tips\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":667,"date":668,"description":18,"extension":669,"lang":670,"meta":671,"navigation":340,"path":672,"readingMinutes":673,"seo":674,"standalone":675,"stem":676,"tags":677,"tldr":678,"updated":678,"url":679,"__hash__":680},"content\u002FJavaScript\u002FJavaScript-關於新接龍的製作方法眉角.md","JavaScript 關於新接龍的製作方法眉角","1140639545",{"type":9,"value":10,"toc":654},"minimark",[11,15,19,22,30,40,56,64,66,72,77,84,87,122,125,135,139,150,153,157,160,163,166,176,183,189,201,207,213,219,228,270,276,278,281,287,290,309,320,544,547,553,556,567,570,573,578,585,590,593,601,604,607,613,616,623,629,636,643,650],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"最近要研究一下新接龍的一些小眉角作法，其中裡面將會記錄一些方向與提示~",[12,20,21],{"id":21},"起手式",[16,23,24,25,29],{},"首先關於",[26,27,28],"strong",{},"新接龍","的製作方式，在製作之前我們可以先簡單想一下主要需要先準備哪些動作",[31,32,33,37],"ul",{},[34,35,36],"li",{},"拖曳",[34,38,39],{},"隨機排序",[16,41,42,43,50,51,55],{},"關於拖曳的話，由於 JavaScript 有許多種作法，舉凡原生 JavaScript 可以透過 HTML5 所提供的 Web API ",[44,45,49],"a",{"href":46,"rel":47},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FAPI\u002FHTML_Drag_and_Drop_API",[48],"nofollow","拖曳方法","，其中 jQuery UI 也有提供相關的 API ",[44,52,49],{"href":53,"rel":54},"https:\u002F\u002Fjqueryui.com\u002Fdraggable\u002F",[48],"。",[16,57,58,59,63],{},"至於隨機產生排序的話，原理與隨機產生數字雷同，之前我有做過一個小應用是關於 ",[44,60,62],{"href":61},"\u002FRocket\u002F","火箭發射","，其中就有使用到隨機產生數字。",[12,65,36],{"id":36},[16,67,68,69,71],{},"一開始先從比較簡單的方向來製作，所以在",[26,70,36],{},"這章節將會介紹兩種方式來製作拖曳",[73,74,76],"h3",{"id":75},"第一種-使用-jquery-ui","第一種 使用 jQuery UI",[16,78,79,80],{},"jQuery UI 中就有提供一個 API 讓我們來達到拖曳的效果也就是　",[81,82,83],"code",{},"draggab()",[16,85,86],{},"寫法非常簡單，只需要這樣寫即可",[88,89,94],"pre",{"className":90,"code":91,"language":92,"meta":93,"style":93},"language-js shiki shiki-themes github-dark-high-contrast","$('#box').draggable();\n","js","",[81,95,96],{"__ignoreMap":93},[97,98,101,105,109,113,116,119],"span",{"class":99,"line":100},"line",1,[97,102,104],{"class":103},"sj_SG","$",[97,106,108],{"class":107},"sMAXC","(",[97,110,112],{"class":111},"sTRMh","'#box'",[97,114,115],{"class":107},").",[97,117,118],{"class":103},"draggable",[97,120,121],{"class":107},"();\n",[16,123,124],{},"那麼範例就直接提供在這裡~",[126,127,134],"iframe",{"height":128,"style":129,"scrolling":130,"title":131,"src":132,"frameBorder":130,"allowTransparency":133,"allowFullScreen":133},265,"width: 100%;","no","拖曳效果","\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FdBrPXJ\u002F?height=265&theme-id=0&default-tab=css,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FdBrPXJ\u002F'>拖曳效果\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[73,136,138],{"id":137},"第二種-原生-javascript","第二種 原生 JavaScript",[16,140,141,142,145,146,149],{},"原生 JavaScript 當然也可以做到拖曳效果，只是會比較麻煩一點，在這邊會使用到 HTML 中的一個 API 方法 ",[81,143,144],{},"dragstart"," 來監聽拖曳是否開始，但是這邊要注意必須替拖曳 DOM 元素添加一個屬性也就是 ",[81,147,148],{},"draggable=\"true\"","，這是在宣告說「我是一個可以拖曳的屬性」",[16,151,152],{},"範例就直接提供在這裡",[126,154,156],{"height":128,"style":129,"scrolling":130,"title":131,"src":155,"frameBorder":130,"allowTransparency":133,"allowFullScreen":133},"\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FwLZarK\u002F?height=265&theme-id=0&default-tab=js,result","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FwLZarK\u002F'>拖曳效果\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsiangfeng\u003C\u002Fa>) on \u003Ca href='https:\u002F\u002Fcodepen.io'>CodePen\u003C\u002Fa>.\n",[12,158,159],{"id":159},"隨機產生數字",[16,161,162],{},"在製作隨機排序之前我們必須先了解一個東西，也就是隨機產生數字。",[16,164,165],{},"首先一副撲克牌中有 54 張牌，但我這邊只會生出 52 張牌，因為其中 2 張是鬼牌並不會一起加入新接龍中。",[16,167,168,169,172,173,175],{},"這邊我們會使用的是 ",[81,170,171],{},"Math.random()"," 這個語法，若直接使用 ",[81,174,171],{}," 會得到這種結果",[16,177,178],{},[179,180],"img",{"alt":181,"src":182},"亂數小數點","https:\u002F\u002Fi.imgur.com\u002Fy4VFNaL.png",[16,184,185,186,55],{},"但是在製作接龍的時候，只有整數 1 ~ 13，根本不會有小數，所以就必須搭配另一個函式來解決，也就是 ",[81,187,188],{},"Math.floor()",[16,190,191,193,194,197,198],{},[81,192,188],{}," 會將所有小數無條件捨去只取最小整數，所以說如果是 ",[81,195,196],{},"0.xxxxxx"," 那個就會得到一個整數 ",[81,199,200],{},"0",[16,202,203],{},[179,204],{"alt":205,"src":206},"無條件捨去所有小數點","https:\u002F\u002Fi.imgur.com\u002FEfbNlDX.png",[16,208,209,210],{},"那麼該怎麼樣才能夠取得整數 1 ~ 13 呢？其實只需要這樣寫即可 ",[81,211,212],{},"Math.floor(Math.random() * 13)",[16,214,215],{},[179,216],{"alt":217,"src":218},"取得整數","https:\u002F\u002Fi.imgur.com\u002Frq7Fjn9.png",[16,220,221,222,224,225],{},"但是這種寫法其實還有一個問題 ",[81,223,212],{}," 它會回傳 0 ~ 12，所以正確寫法是這樣子 ",[81,226,227],{},"Math.floor(Math.random() * 13) + 1",[88,229,231],{"className":90,"code":230,"language":92,"meta":93,"style":93},"Math.floor(Math.random() * 13) + 1;\n",[81,232,233],{"__ignoreMap":93},[97,234,235,238,241,244,247,250,254,258,261,264,267],{"class":99,"line":100},[97,236,237],{"class":107},"Math.",[97,239,240],{"class":103},"floor",[97,242,243],{"class":107},"(Math.",[97,245,246],{"class":103},"random",[97,248,249],{"class":107},"() ",[97,251,253],{"class":252},"sWyjQ","*",[97,255,257],{"class":256},"sCcAr"," 13",[97,259,260],{"class":107},") ",[97,262,263],{"class":252},"+",[97,265,266],{"class":256}," 1",[97,268,269],{"class":107},";\n",[16,271,272],{},[179,273],{"alt":274,"src":275},"正確取得 1 ~ 13 的整數","https:\u00