[{"data":1,"prerenderedAt":667},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190922\u002F3135021885\u002F":3,"page:\u002Fjavascript\u002F20190922\u002F3135021885\u002F":4,"alt:\u002Fjavascript\u002F20190922\u002F3135021885\u002F":3,"prev-next:\u002Fjavascript\u002F20190922\u002F3135021885\u002F":642,"related:\u002Fjavascript\u002F20190922\u002F3135021885\u002F":651},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F22\u002Fre-learning-js-from-zero-07-functions\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":626,"date":627,"description":18,"extension":628,"lang":629,"meta":630,"navigation":210,"path":631,"readingMinutes":632,"seo":633,"standalone":634,"stem":635,"tags":636,"tldr":639,"updated":639,"url":640,"__hash__":641},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-7-RE：從零開始的學習-JS-生活-第七日.md","EP.7 RE：從零開始的學習 JS 生活-第七日之函式","3135021885",{"type":9,"value":10,"toc":621},"minimark",[11,15,19,22,25,28,255,258,261,268,280,287,290,339,342,410,417,423,438,444,447,450,454,457,463,466,560,563,608,611,614,617],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第七日，這一篇將會來介紹函式，函式是我們寫程式必須懂得知識，所以就來了解一下吧。",[12,20,21],{"id":21},"函式",[16,23,24],{},"函式是每個程式語言都會有的一個功能(方法?)，那函式的用途是什麼呢?假使來講我們有一個動作是要重複寫出 1 ~ 100，然後會在很多的地方使用，例如網頁的首頁、產品列表、交易畫面等等，如果我們不使用函式，則會變成有幾頁就要重複複製語法到這幾個頁面幾次，那麼這會導致維護上的困擾，假使今天老闆跟你講說我要改成 1 ~ 200，那你有 20 個頁面就會變成要改 20 次，那麼你就難保自己很難不會少改。",[16,26,27],{},"所以函式你可以理解成可以我們包裝我們寫好的功能，只需要呼叫執行它就可以完成我們預先準備好的功能，通常來講函式裡面大多都是重複性較高的程式碼，我們只需要在特定頁面引入該函式就可以使用，這樣講通常蠻難懂的，這邊以下是我之前撰寫練習 AJAX 的方法，最主要是我會在五六個地方使用，所以我將它包裝成一個函式：",[29,30,35],"pre",{"className":31,"code":32,"language":33,"meta":34,"style":34},"language-js shiki shiki-themes github-dark-high-contrast","function XHRCall(lineModel, url, header, sendStr, modelText) {\n    const xhr = new XMLHttpRequest();\n    xhr.open(lineModel, url);\n    xhr.setRequestHeader('Content-type', header);\n    xhr.send(sendStr);\n    xhr.onload = function () {\n        const _data = JSON.parse(xhr.responseText);\n        resultListFu(_data, modelText);\n    }\n}\n\n\u002F\u002F 重複使用\nXHRCall(...);\nXHRCall(...);\nXHRCall(...);\n","js","",[36,37,38,83,105,117,134,145,161,184,193,199,205,212,219,233,244],"code",{"__ignoreMap":34},[39,40,43,47,51,55,59,62,65,67,70,72,75,77,80],"span",{"class":41,"line":42},"line",1,[39,44,46],{"class":45},"sWyjQ","function",[39,48,50],{"class":49},"sj_SG"," XHRCall",[39,52,54],{"class":53},"sMAXC","(",[39,56,58],{"class":57},"s_sBn","lineModel",[39,60,61],{"class":53},", ",[39,63,64],{"class":57},"url",[39,66,61],{"class":53},[39,68,69],{"class":57},"header",[39,71,61],{"class":53},[39,73,74],{"class":57},"sendStr",[39,76,61],{"class":53},[39,78,79],{"class":57},"modelText",[39,81,82],{"class":53},") {\n",[39,84,86,89,93,96,99,102],{"class":41,"line":85},2,[39,87,88],{"class":45},"    const",[39,90,92],{"class":91},"sCcAr"," xhr",[39,94,95],{"class":45}," =",[39,97,98],{"class":45}," new",[39,100,101],{"class":49}," XMLHttpRequest",[39,103,104],{"class":53},"();\n",[39,106,108,111,114],{"class":41,"line":107},3,[39,109,110],{"class":53},"    xhr.",[39,112,113],{"class":49},"open",[39,115,116],{"class":53},"(lineModel, url);\n",[39,118,120,122,125,127,131],{"class":41,"line":119},4,[39,121,110],{"class":53},[39,123,124],{"class":49},"setRequestHeader",[39,126,54],{"class":53},[39,128,130],{"class":129},"sTRMh","'Content-type'",[39,132,133],{"class":53},", header);\n",[39,135,137,139,142],{"class":41,"line":136},5,[39,138,110],{"class":53},[39,140,141],{"class":49},"send",[39,143,144],{"class":53},"(sendStr);\n",[39,146,148,150,153,155,158],{"class":41,"line":147},6,[39,149,110],{"class":53},[39,151,152],{"class":49},"onload",[39,154,95],{"class":45},[39,156,157],{"class":45}," function",[39,159,160],{"class":53}," () {\n",[39,162,164,167,170,172,175,178,181],{"class":41,"line":163},7,[39,165,166],{"class":45},"        const",[39,168,169],{"class":91}," _data",[39,171,95],{"class":45},[39,173,174],{"class":91}," JSON",[39,176,177],{"class":53},".",[39,179,180],{"class":49},"parse",[39,182,183],{"class":53},"(xhr.responseText);\n",[39,185,187,190],{"class":41,"line":186},8,[39,188,189],{"class":49},"        resultListFu",[39,191,192],{"class":53},"(_data, modelText);\n",[39,194,196],{"class":41,"line":195},9,[39,197,198],{"class":53},"    }\n",[39,200,202],{"class":41,"line":201},10,[39,203,204],{"class":53},"}\n",[39,206,208],{"class":41,"line":207},11,[39,209,211],{"emptyLinePlaceholder":210},true,"\n",[39,213,215],{"class":41,"line":214},12,[39,216,218],{"class":217},"sQrFR","\u002F\u002F 重複使用\n",[39,220,222,225,227,230],{"class":41,"line":221},13,[39,223,224],{"class":49},"XHRCall",[39,226,54],{"class":53},[39,228,229],{"class":45},"...",[39,231,232],{"class":53},");\n",[39,234,236,238,240,242],{"class":41,"line":235},14,[39,237,224],{"class":49},[39,239,54],{"class":53},[39,241,229],{"class":45},[39,243,232],{"class":53},[39,245,247,249,251,253],{"class":41,"line":246},15,[39,248,224],{"class":49},[39,250,54],{"class":53},[39,252,229],{"class":45},[39,254,232],{"class":53},[16,256,257],{},"那麼我們只需要呼叫並執行它，並帶入相對應的參數就可以重複使用這個功能，而這也就是人家說的 API 功能。",[16,259,260],{},"那麼基礎的函式定義方式不外乎是這樣 ↓",[16,262,263],{},[264,265],"img",{"alt":266,"src":267},"函式定義","https:\u002F\u002Fi.imgur.com\u002FlMyVzVQ.png",[16,269,270,271,275,276,279],{},"而這種函式定義的方式就是所謂的",[272,273,274],"strong",{},"具名函式","，具名函式的意思就是具有名稱的函式，你可以透過函式名稱呼叫並執行它，當然還有另一種函式定義，也就是",[272,277,278],{},"匿名函式","，但是這邊還不會介紹它，後面章節才會介紹匿名函式。",[16,281,282,283,286],{},"通常函式定義我們可以自己決定是否帶入參數，所以留空也是完全沒有問題，但是有一種參數是可以不用傳值，就是 ",[36,284,285],{},"event","，也就是事件，那事件會發生在何處呢?讓我稍微把前面的事件章節寫法稍微改一下。",[16,288,289],{},"HTML 部分：",[29,291,295],{"className":292,"code":293,"language":294,"meta":34,"style":34},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cdiv class=\"box1\" id=\"box1\">\n  box1\n\u003C\u002Fdiv>\n","html",[36,296,297,325,330],{"__ignoreMap":34},[39,298,299,302,306,309,312,315,318,320,322],{"class":41,"line":42},[39,300,301],{"class":53},"\u003C",[39,303,305],{"class":304},"sKpQp","div",[39,307,308],{"class":91}," class",[39,310,311],{"class":53},"=",[39,313,314],{"class":129},"\"box1\"",[39,316,317],{"class":91}," id",[39,319,311],{"class":53},[39,321,314],{"class":129},[39,323,324],{"class":53},">\n",[39,326,327],{"class":41,"line":85},[39,328,329],{"class":53},"  box1\n",[39,331,332,335,337],{"class":41,"line":107},[39,333,334],{"class":53},"\u003C\u002F",[39,336,305],{"class":304},[39,338,324],{"class":53},[16,340,341],{},"JavaScript 部分：",[29,343,345],{"className":31,"code":344,"language":33,"meta":34,"style":34},"var box1 = document.getElementById('box1');\nbox1.addEventListener('click', function(e) {\n  console.log(e);\n});\n",[36,346,347,370,394,405],{"__ignoreMap":34},[39,348,349,352,355,357,360,363,365,368],{"class":41,"line":42},[39,350,351],{"class":45},"var",[39,353,354],{"class":53}," box1 ",[39,356,311],{"class":45},[39,358,359],{"class":53}," document.",[39,361,362],{"class":49},"getElementById",[39,364,54],{"class":53},[39,366,367],{"class":129},"'box1'",[39,369,232],{"class":53},[39,371,372,375,378,380,383,385,387,389,392],{"class":41,"line":85},[39,373,374],{"class":53},"box1.",[39,376,377],{"class":49},"addEventListener",[39,379,54],{"class":53},[39,381,382],{"class":129},"'click'",[39,384,61],{"class":53},[39,386,46],{"class":45},[39,388,54],{"class":53},[39,390,391],{"class":57},"e",[39,393,82],{"class":53},[39,395,396,399,402],{"class":41,"line":107},[39,397,398],{"class":53},"  console.",[39,400,401],{"class":49},"log",[39,403,404],{"class":53},"(e);\n",[39,406,407],{"class":41,"line":119},[39,408,409],{"class":53},"});\n",[16,411,412,413,416],{},"當我們點擊 ",[36,414,415],{},"box1"," 的時候會出現一個很奇怪的東西 ↓",[16,418,419],{},[264,420],{"alt":421,"src":422},"奇怪的東西","https:\u002F\u002Fi.imgur.com\u002F5pDYopg.png",[16,424,425,426,428,429,431,432,434,435,437],{},"那你可以看到事件監聽裡面的函式帶入了一個 ",[36,427,391],{}," 的參數，而這個 ",[36,430,391],{}," 代表著 ",[36,433,285],{}," 也就是事件，這裡面內容就是你剛剛的動作歷史，可以把它看到像是 Pluk 時光渠道，所以 ",[36,436,391],{}," 所代表的是事件觸發的位置、時間軸及座標等等狀態。",[16,439,440,441,443],{},"那麼為什麼這時候才講呢，因為要搭配 ",[36,442,46],{}," 一起講咩~",[16,445,446],{},"畢竟事件章節我只想專心在事件上~~(其實是忘了)~~，那一般來講在事件監聽中的第一個參數若沒有傳入任何值預設是會帶入事件(Event)。",[16,448,449],{},"讓我們回到基本的函式定義這張圖 ↓",[16,451,452],{},[264,453],{"alt":266,"src":267},[16,455,456],{},"當我們宣告函式後，若要呼叫並執行這個函式就會是這個形式 ↓",[16,458,459],{},[264,460],{"alt":461,"src":462},"執行函式","https:\u002F\u002Fi.imgur.com\u002Fdz8ReBB.png",[16,464,465],{},"所以依照這個觀念我們就可以將許多重複性較高的的程式碼包裝成一個函式，例如打招呼的程式碼包裝成一個函式並傳入名稱：",[29,467,469],{"className":31,"code":468,"language":33,"meta":34,"style":34},"function sayHi(name){\n  console.log('Hi，' + name);\n}\n\n\u002F\u002F 若是傳入字串請用單雙引號包覆\nsayHi('Ray') \u002F\u002F Hi，Ray;\nsayHi('QQ 先生') \u002F\u002F Hi，QQ 先生;\nsayHi('小明') \u002F\u002F Hi，小明;\n",[36,470,471,486,503,507,511,516,532,546],{"__ignoreMap":34},[39,472,473,475,478,480,483],{"class":41,"line":42},[39,474,46],{"class":45},[39,476,477],{"class":49}," sayHi",[39,479,54],{"class":53},[39,481,482],{"class":57},"name",[39,484,485],{"class":53},"){\n",[39,487,488,490,492,494,497,500],{"class":41,"line":85},[39,489,398],{"class":53},[39,491,401],{"class":49},[39,493,54],{"class":53},[39,495,496],{"class":129},"'Hi，'",[39,498,499],{"class":45}," +",[39,501,502],{"class":53}," name);\n",[39,504,505],{"class":41,"line":107},[39,506,204],{"class":53},[39,508,509],{"class":41,"line":119},[39,510,211],{"emptyLinePlaceholder":210},[39,512,513],{"class":41,"line":136},[39,514,515],{"class":217},"\u002F\u002F 若是傳入字串請用單雙引號包覆\n",[39,517,518,521,523,526,529],{"class":41,"line":147},[39,519,520],{"class":49},"sayHi",[39,522,54],{"class":53},[39,524,525],{"class":129},"'Ray'",[39,527,528],{"class":53},") ",[39,530,531],{"class":217},"\u002F\u002F Hi，Ray;\n",[39,533,534,536,538,541,543],{"class":41,"line":163},[39,535,520],{"class":49},[39,537,54],{"class":53},[39,539,540],{"class":129},"'QQ 先生'",[39,542,528],{"class":53},[39,544,545],{"class":217},"\u002F\u002F Hi，QQ 先生;\n",[39,547,548,550,552,555,557],{"class":41,"line":186},[39,549,520],{"class":49},[39,551,54],{"class":53},[39,553,554],{"class":129},"'小明'",[39,556,528],{"class":53},[39,558,559],{"class":217},"\u002F\u002F Hi，小明;\n",[16,561,562],{},"這樣子我們就可以重複的使用這個功能，若不使用函式來打招呼呢?那會發生何事?",[29,564,566],{"className":31,"code":565,"language":33,"meta":34,"style":34},"console.log('Hi，Ray');\nconsole.log('Hi，QQ 先生');\nconsole.log('Hi，小明');\n",[36,567,568,582,595],{"__ignoreMap":34},[39,569,570,573,575,577,580],{"class":41,"line":42},[39,571,572],{"class":53},"console.",[39,574,401],{"class":49},[39,576,54],{"class":53},[39,578,579],{"class":129},"'Hi，Ray'",[39,581,232],{"class":53},[39,583,584,586,588,590,593],{"class":41,"line":85},[39,585,572],{"class":53},[39,587,401],{"class":49},[39,589,54],{"class":53},[39,591,592],{"class":129},"'Hi，QQ 先生'",[39,594,232],{"class":53},[39,596,597,599,601,603,606],{"class":41,"line":107},[39,598,572],{"class":53},[39,600,401],{"class":49},[39,602,54],{"class":53},[39,604,605],{"class":129},"'Hi，小明'",[39,607,232],{"class":53},[16,609,610],{},"你可以發現我們要打的字變多了，而且可重複性降低許多，當你有 100 頁要使用，那當要修改打招呼的模式時，你就要改 100 個地方，雖然這個範例看不太出所以然，但是許多實務上開發都會將許多重複性較高的程式碼片段包裝成一個函式，一來可以減少我們不停重複撰寫 code，二來若要做修改時只需要修改一個地方就好了。",[12,612,613],{"id":613},"結尾",[16,615,616],{},"下一篇的 RE：從零開始的學習 JS 生活-第六日 將會介紹匿名函式與 IIFE(立即執行函式)。",[618,619,620],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);te