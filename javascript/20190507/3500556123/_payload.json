後在外層呼叫 ",[26,72,66],{}," 呢?",[31,75,77],{"className":33,"code":76,"language":35,"meta":36,"style":36},"function testFu(){\n  var item = '媽媽'\n};\nconsole.log(item);\n",[26,78,79,91,104,110],{"__ignoreMap":36},[40,80,81,84,88],{"class":42,"line":43},[40,82,83],{"class":46},"function",[40,85,87],{"class":86},"scAaK"," testFu",[40,89,90],{"class":49},"(){\n",[40,92,94,97,99,101],{"class":42,"line":93},2,[40,95,96],{"class":46},"  var",[40,98,50],{"class":49},[40,100,53],{"class":46},[40,102,103],{"class":56}," '媽媽'\n",[40,105,107],{"class":42,"line":106},3,[40,108,109],{"class":49},"};\n",[40,111,113,116,119],{"class":42,"line":112},4,[40,114,115],{"class":49},"console.",[40,117,118],{"class":86},"log",[40,120,121],{"class":49},"(item);\n",[16,123,124,125],{},"這時候可以發現它會說 ",[26,126,127],{},"item is not defined",[16,129,130],{},[131,132],"img",{"alt":133,"src":134},"圖片","https:\u002F\u002Fi.imgur.com\u002FuivXzxo.png",[16,136,137,138,140,141,143],{},"這兩個小範例基本上淺顯易懂知道問題出在哪裡，也是最基本的全域與區域變數，在 ",[26,139,83],{}," 下建立的變數通稱為\"區域變數\"，而 ",[26,142,83],{}," 之外就是全域變數。",[16,145,146],{},"有一個基本認知後來試著挑戰看看這個下面這個題目吧。",[31,148,150],{"className":33,"code":149,"language":35,"meta":36,"style":36},"var item = '全域媽媽';\nfunction name(){\n  item = '區域兒子';\n};\nconsole.log(item);\n",[26,151,152,164,173,185,189],{"__ignoreMap":36},[40,153,154,156,158,160,162],{"class":42,"line":43},[40,155,28],{"class":46},[40,157,50],{"class":49},[40,159,53],{"class":46},[40,161,57],{"class":56},[40,163,60],{"class":49},[40,165,166,168,171],{"class":42,"line":93},[40,167,83],{"class":46},[40,169,170],{"class":86}," name",[40,172,90],{"class":49},[40,174,175,178,180,183],{"class":42,"line":106},[40,176,177],{"class":49},"  item ",[40,179,53],{"class":46},[40,181,182],{"class":56}," '區域兒子'",[40,184,60],{"class":49},[40,186,187],{"class":42,"line":112},[40,188,109],{"class":49},[40,190,192,194,196],{"class":42,"line":191},5,[40,193,115],{"class":49},[40,195,118],{"class":86},[40,197,121],{"class":49},[16,199,200],{},"這