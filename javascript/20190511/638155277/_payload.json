[{"data":1,"prerenderedAt":540},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190511\u002F638155277\u002F":3,"page:\u002Fjavascript\u002F20190511\u002F638155277\u002F":4,"alt:\u002Fjavascript\u002F20190511\u002F638155277\u002F":3,"prev-next:\u002Fjavascript\u002F20190511\u002F638155277\u002F":515,"related:\u002Fjavascript\u002F20190511\u002F638155277\u002F":524},"\u002Fen\u002Fjavascript\u002F2019\u002F05\u002F11\u002Fjavascript-closures-basics-01\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":501,"date":502,"description":18,"extension":503,"lang":504,"meta":505,"navigation":77,"path":506,"readingMinutes":507,"seo":508,"standalone":509,"stem":510,"tags":511,"tldr":512,"updated":512,"url":513,"__hash__":514},"content\u002FJavaScript\u002FJavaScript基礎閉包觀念.md","JavaScript基礎閉包觀念","638155277",{"type":9,"value":10,"toc":495},"minimark",[11,15,19,23,26,29,32,171,174,342,345,453,456,459,462,465,468,477,484,491],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"JavaScript 中有一個閉包的觀念，滿時常聽人家在講閉包閉包，稍微查了一下相關文章這邊也做一下筆記。",[12,20,22],{"id":21},"閉包closure","閉包(Closure)",[16,24,25],{},"首先 MDN 文件有簡短的說明解釋【閉包（Closure）是函式以及該函式被宣告時所在的作用域環境（lexical environment）的組合。】，但是解釋文字有點文謅謅看不懂，我自己吸收觀看之後的解釋是【是指宣告再函式中的函式】，那什麼叫做【函式中的函式】?",[12,27,28],{"id":28},"範例",[16,30,31],{},"閉包的觀念主要也是與變數的作用域有關係，所以這邊寫一段範例來講解。",[33,34,39],"pre",{"className":35,"code":36,"language":37,"meta":38,"style":38},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F icash餘額初始有 1000 $\nvar icash = 1000;\n\nfunction count(price) {\n return icash = icash - price;\n \n}\n\ncount(50);\ncount(50);\nconsole.log(icash);\n","js","",[40,41,42,51,72,79,99,117,123,129,134,148,159],"code",{"__ignoreMap":38},[43,44,47],"span",{"class":45,"line":46},"line",1,[43,48,50],{"class":49},"sQrFR","\u002F\u002F icash餘額初始有 1000 $\n",[43,52,54,58,62,65,69],{"class":45,"line":53},2,[43,55,57],{"class":56},"sWyjQ","var",[43,59,61],{"class":60},"sMAXC"," icash ",[43,63,64],{"class":56},"=",[43,66,68]