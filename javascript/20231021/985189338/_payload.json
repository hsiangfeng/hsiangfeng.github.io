,"strong",{},"Note",[32,55,37],{}," 的運作以及使用方式與 ",[32,58,28],{}," 一模一樣，只是它的特性是當瀏覽器關閉時就會消失，因此我們可以透過它來儲存一些不重要的資料，例如：使用者的暫存資料等等，但有趣的是 ",[32,61,28],{}," 是可以在不同網頁上共用資料，但 ",[32,64,37],{}," 則不行，畢竟它的特性就是當瀏覽器關閉時就會消失，因此 ",[32,67,37],{}," 只能在同一個網頁上共用資料。",[12,70,71,72,74],{},"那麼 ",[32,73,28],{}," 有以下幾種方法可以使用",[76,77,78,85,91,97],"ul",{},[79,80,81,84],"li",{},[32,82,83],{},"window.localStorage.setItem(key, value)","：新增一筆資料",[79,86,87,90],{},[32,88,89],{},"window.localStorage.getItem(key)","：取得一筆資料",[79,92,93,96],{},[32,94,95],{},"window.localStorage.removeItem(key)","：刪除一筆資料",[79,98,99,102],{},[32,100,101],{},"window.localStorage.clear()","：刪除所有資料",[12,104,105,106,109],{},"當你使用 ",[32,107,108],{},"window.localStorage.setItem('myName', 'Ray')"," 之後，你可以在瀏覽器的開發者工具中的 Application 頁籤中的 Local Storage 中看到你新增的資料，如下圖",[12,111,112],{},[15,113],{"alt":114,"src":115},"Firefox","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Flocalstroage_package\u002F202310211309.jpg",[46,117,118],{},[12,119,120,122],{},[51,121,53],{},"\n各家瀏覽器呈現都差不多，由於我是使用 Firefox，因此可能會與你的瀏覽器呈現不同，但是大同小異，你可以自行嘗試。",[19,124,126],{"id":125},"windowlocalstorage-的缺點","window.localStorage 的缺點",[12,128,129,130,132],{},"那麼其實 ",[32,131,28],{}," 本身的 API 就是這麼簡單，但是它有幾個缺點，就是它的 API 其實有一些問題，什麼意思呢？",[12,134,135,136,138],{},"其實 ",[32,137,28],{}," 是可以儲存物件的，例如...",[140,141,146],"pre",{"className":142,"code":143,"language":144,"meta":145,"style":145},"language-js shiki shiki-themes github-dark-high-contrast","window.localStorage.setItem('myObj', { name: 'Ray', age: 18 })\n","js","",[32,147,148],{"__ignoreMap":145},[149,150,153,157,161,164,168,171,174,177,181],"span",{"class":151,"line":152},"line",1,[149,154,156],{"class":155},"sMAXC","window.localStorage.",[149,158,160],{"class":159},"sj_SG","setItem",[149,162,163],{"class":155},"(",[149,165,167],{"class":166},"sTRMh","'myObj'",[149,169,170],{"class":155},", { name: ",[149,172,173],{"class":166},"'Ray'",[149,175,176],{"class":155},", age: ",[149,178,180],{"class":179},"s