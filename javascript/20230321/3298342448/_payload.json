\n",[36,306,308],{"class":38,"line":307},5,[36,309,310],{"class":57},"}\n",[36,312,314],{"class":38,"line":313},6,[36,315,101],{"emptyLinePlaceholder":100},[36,317,319,322,324],{"class":38,"line":318},7,[36,320,321],{"class":107},"calc",[36,323,110],{"class":57},[36,325,114],{"class":113},[16,327,328,329,331],{},"但其實這個方式與 ",[33,330,71],{}," 一樣，也是不建議使用的，因為這個方式也會有一些安全性的問題",[26,333,335],{"className":28,"code":334,"language":30,"meta":31,"style":31},"const a = 'alert(\"是 Ray 不是 Array\")';\n\nconst calc = (val) => {\n  return new Function(`return ${val}`)();\n}\n\ncalc(a); \u002F\u002F 會跳出一個 alert 視窗，並且顯示「是 Ray 不是 Array」\n",[33,336,337,349,353,371,389,393,397],{"__ignoreMap":31},[36,338,339,341,343,345,347],{"class":38,"line":39},[36,340,43],{"class":42},[36,342,47],{"class":46},[36,344,50],{"class":42},[36,346,176],{"class":53},[36,348,58],{"class":57},[36,350,351],{"class":38,"line":97},[36,352,101],{"emptyLinePlaceholder":100},[36,354,355,357,359,361,363,365,367,369],{"class":38,"line":104},[36,356,43],{"class":42},[36,358,260],{"class":107},[36,360,50],{"class":42},[36,362,265],{"class":57},[36,364,269],{"class":268},[36,366,272],{"class":57},[36,368,275],{"class":42},[36,370,278],{"class":57},[36,372,373,375,377,379,381,383,385,387],{"class":38,"line":281},[36,374,284],{"class":42},[36,376,287],{"class":42},[36,378,290],{"class":107},[36,380,293],{"class":57},[36,382,296],{"class":53},[36,384,269],{"class":57},[36,386,301],{"class":53},[36,388,304],{"class":57},[36,390,391],{"class":38,"line":307},[36,392,310],{"class":57},[36,394,395],{"class":38,"line":313},[36,396,101],{"emptyLinePlaceholder":100},[36,398,399,401,403],{"class":38,"line":318},[36,400,321],{"class":107},[36,402,110],{"class":57},[36,404,191],{"class":113},[16,406,407],{},[195,408],{"alt":197,"src":198},[16,410,411,412,220,414,416],{},"所以 ",[33,413,219],{},[33,415,223],{}," 也是不建議使用的，那這樣的話，我們就只能想其他的方式來解決這個問題了。",[69,418,419],{"id":419},"陣列操作方法",[16,421,422,423,426],{},"這個就比較特別一點了，將會使用 ",[33,424,425],{