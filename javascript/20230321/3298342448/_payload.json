+ 3';\n\neval(a); \u002F\u002F 6\n",[33,82,83,95,102],{"__ignoreMap":31},[36,84,85,87,89,91,93],{"class":38,"line":39},[36,86,43],{"class":42},[36,88,47],{"class":46},[36,90,50],{"class":42},[36,92,54],{"class":53},[36,94,58],{"class":57},[36,96,98],{"class":38,"line":97},2,[36,99,101],{"emptyLinePlaceholder":100},true,"\n",[36,103,105,108,111],{"class":38,"line":104},3,[36,106,71],{"class":107},"sj_SG",[36,109,110],{"class":57},"(a); ",[36,112,114],{"class":113},"sQrFR","\u002F\u002F 6\n",[16,116,117,118,120,121,123,124],{},"但是通常來講 ",[33,119,71],{}," 這個函式並不建議使用，為什麼呢？來看一下 MDN 關於 ",[33,122,71],{}," 的",[125,126,130],"a",{"href":127,"rel":128},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-CN\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FGlobal_Objects\u002Feval",[129],"nofollow","描述與說明",[132,133,134],"blockquote",{},[16,135,136],{},"The eval() function evaluates JavaScript code represented as a string and returns its completion value. The source is parsed as a script.",[16,138,139],{},"上面這個描述翻譯成中文的意思是指...",[16,141,142,143,145],{},"「",[33,144,71],{}," 函式會將傳入的字串當成 JavaScript 的程式碼來執行，並回傳結果。」",[16,147,148,149,154,155,157,158,160],{},"看起來很方便對吧？如果你的專案有使用 ESLint 來去管理風格的話，基本上你會發現 ",[125,150,153],{"href":151,"rel":152},"https:\u002F\u002Fcloud.tencent.com\u002Fdeveloper\u002Fsection\u002F1135686",[129],"ESLint"," 會要求你不要去使用 ",[33,156,71],{}," 這個函式，因為這個函式會有一些安全性的問題，例如說你可以透過 ",[33,159,71],{}," 來執行一些惡意的程式碼，例如說",[26,162,164],{"className":28,"code":163,"language":30,"meta":31,"style":31},"const a = 'alert(\"是 Ray 不是 Array\")';\n\neval(a); \u002F\u002F 會跳出一個 alert 視窗，並且顯示「是 Ray 不是 Array」\n",[33,165,166,179,183],{"__ignoreMap":31},[36,167,168,170,172,174,177],{"class":38,"line":39},[36,169,43],{"class":42},[36,171,47],{"class":46},[36,173,50],{"class":42},[36,175,176],{"class":53}," 'alert(\"是 Ray 不是 Array\")'",[36,178,58],{"class":57},[36,180,181],{"class":38,"line":97},[36,182,101],{"emptyLinePlaceholder":100},[36,184,185,187,189],{"class":38,"line":104},[36,186,71],{"cla