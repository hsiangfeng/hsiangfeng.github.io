[{"data":1,"prerenderedAt":1082},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20231120\u002F805843771\u002F":3,"page:\u002Fjavascript\u002F20231120\u002F805843771\u002F":4,"alt:\u002Fjavascript\u002F20231120\u002F805843771\u002F":3,"prev-next:\u002Fjavascript\u002F20231120\u002F805843771\u002F":1057,"related:\u002Fjavascript\u002F20231120\u002F805843771\u002F":1066},"\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1041,"date":1042,"description":24,"extension":1043,"lang":1044,"meta":1045,"navigation":446,"path":1046,"readingMinutes":312,"seo":1047,"standalone":1048,"stem":1049,"tags":1050,"tldr":1054,"updated":1042,"url":1055,"__hash__":1056},"content\u002FJavaScript\u002F簡單趣談-Functional-Programming-in-JavaScript-之-Currying.md","簡單趣談 Functional Programming in JavaScript 之 Currying","805843771",{"type":9,"value":10,"toc":1036},"minimark",[11,18,22,25,29,32,35,41,44,48,51,122,129,135,142,169,187,190,193,199,205,283,286,289,318,321,371,374,517,526,529,645,648,697,700,714,846,849,1006,1013,1029,1032],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Ffp-currying\u002Fisray_notarray_Functional_Programming_--stylize_750_--v_5.2_5df82f93-316b-4019-b996-f4b4b22218dd.png",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"Functional Programming 設計模式中，還有一個很特別的概念，就叫做 Currying（柯里化），所以這一篇文章就會來介紹一下這個東西。",[19,26,28],{"id":27},"currying-是什麼","Currying 是什麼？",[12,30,31],{},"首先 Currying 中文有很多種翻譯，像是柯里化、卡瑞化或加里化，這些都是泛指 Functional Programming 設計模式中 Currying 這個概念。",[12,33,34],{},"那麼 Currying 究竟有什麼特別的呢？如果用簡單一句話來形容的話，那就是...",[36,37,38],"blockquote",{},[12,39,40],{},"Currying 是一個將多個參數的函式，轉換成一次只接受一個參數的函式，並且返回結果的一個過程。",[12,42,43],{},"可能有些人會覺得 Currying 是不是用了什麼新的語法，但實際上它只是善加利用了 JavaScript 的特性而已，也就是你所熟悉的 Closure Function 而已。",[19,45,47],{"id":46},"currying-的實作","Currying 的實作",[12,49,50],{},"接下來我們當然要來看看 Currying 的實作，首先我們先來看下方的程式碼：",[52,53,58],"pre",{"className":54,"code":55,"language":56,"meta":57,"style":57},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","function add(a, b, c) {\n  return a + b + c;\n}\n","js","",[59,60,61,96,116],"code",{"__ignoreMap":57},[62,63,66,70,74,78,82,85,88,90,93],"span",{"class":64,"line":65},"line",1,[62,67,69],{"class":68},"sOudu","function",[62,71,73],{"class":72},"scAaK"," add",[62,75,77],{"class":76},"s8XSl","(",[62,79,81],{"class":80},"syBk-","a",[62,83,84],{"class":76},", ",[62,86,87],{"class":80},"b",[62,89,84],{"class":76},[62,91,92],{"class":80},"c",[62,94,95],{"class":76},") {\n",[62,97,99,102,105,108,111,113],{"class":64,"line":98},2,[62,100,101],{"class":68},"  return",[62,103,104],{"class":76}," a ",[62,106,107],{"class":68},"+",[62,109,110],{"class":76}," b ",[62,112,107],{"class":68},[62,114,115],{"class":76}," c;\n",[62,117,119],{"class":64,"line":118},3,[62,120,121],{"class":76},"}\n",[12,123,124,125,128],{},"我們可以看到我們宣告了一個名為 ",[59,126,127],{},"add"," 的函式，這個函式接受三個參數，並且返回這三個參數的總和",[12,130,131],{},[15,132],{"alt":133,"src":134},"Function Add","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Ffp-currying\u002F%E6%88%AA%E5%9C%96%202023-11-20%2021.15.17.png",[12,136,137,138,141],{},"看似沒問題對吧？但是當你使用這個函式時，若不小心少傳入一個參數，那麼就會出現 ",[59,139,140],{},"NaN"," 的情況，例如：",[52,143,145],{"className":54,"code":144,"language":56,"meta":57,"style":57},"add(1, 2); \u002F\u002F NaN\n",[59,146,147],{"__ignoreMap":57},[62,148,149,151,153,157,159,162,165],{"class":64,"line":65},[62,150,127],{"class":72},[62,152,77],{"class":76},[62,154,156],{"class":155},"stw71","1",[62,158,84],{"class":76},[62,160,161],{"class":155},"2",[62,163,164],{"class":76},"); ",[62,166,168],{"class":167},"sGBqm","\u002F\u002F NaN\n",[170,171,174],"callout",{"title":172,"type":173},"Note","note",[12,175,176,177,179,180,183,184,186],{},"這邊的 ",[59,178,140],{}," 是因為 ",[59,181,182],{},"1 + 2 + undefined"," 會得到 ",[59,185,140],{},"。",[12,188,189],{},"雖然你可能會認為...",[12,191,192],{},"「只要替函式預設參數就好了啊？」",[12,194,195,196,198],{},"確實，這也是一種解決問題的方式，但是這樣子的話，你就必須要知道你的函式會接受多少個參數，因此每次呼叫函式的時候，都必須要傳入所有的參數，那麼這時候就有可能會漏掉導致出現 ",[59,197,140],{}," 的情況。",[12,200,201,202,204],{},"這時候我們就可以來講講 Currying 了，我們可以將上述的 ",[59,203,127],{}," 函式改寫成以下：",[52,206,208],{"className":54,"code":207,"language":56,"meta":57,"style":57},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n",[59,209,210,223,237,250,266,272,278],{"__ignoreMap":57},[62,211,212,214,217,219,221],{"class":64,"line":65},[62,213,69],{"class":68},[62,215,216],{"class":72}," curryAdd",[62,218,77],{"class":76},[62,220,81],{"class":80},[62,222,95],{"class":76},[62,224,225,227,230,233,235],{"class":64,"line":98},[62,226,101],{"class":68},[62,228,229],{"class":68}," function",[62,231,232],{"class":76}," (",[62,234,87],{"class":80},[62,236,95],{"class":76},[62,238,239,242,244,246,248],{"class":64,"line":118},[62,240,241],{"class":68},"    return",[62,243,229],{"class":68},[62,245,232],{"class":76},[62,247,92],{"class":80},[62,249,95],{"class":76},[62,251,253,256,258,260,262,264],{"class":64,"line":252},4,[62,254,255],{"class":68},"      return",[62,257,104],{"class":76},[62,259,107],{"class":68},[62,261,110],{"class":76},[62,263,107],{"class":68},[62,265,115],{"class":76},[62,267,269],{"class":64,"line":268},5,[62,270,271],{"class":76},"    };\n",[62,273,275],{"class":64,"line":274},6,[62,276,277],{"class":76},"  };\n",[62,279,281],{"class":64,"line":280},7,[62,282,121],{"class":76},[12,284,285],{},"很有趣吧？我們將原本接受三個參數的函式，改寫成了三個接受一個參數的函式，最後回傳結果。",[12,287,288],{},"當我們使用時，只需要這樣寫就可以了：",[52,290,292],{"className":54,"code":291,"language":56,"meta":57,"style":57},"curryAdd(1)(2)(3); \u002F\u002F 6\n",[59,293,294],{"__ignoreMap":57},[62,295,296,299,301,303,306,308,310,313,315],{"class":64,"line":65},[62,297,298],{"class":72},"curryAdd",[62,300,77],{"class":76},[62,302,156],{"class":155},[62,304,305],{"class":76},")(",[62,307,161],{"class":155},[62,309,305],{"class":76},[62,311,312],{"class":155},"3",[62,314,164],{"class":76},[62,316,317],{"class":167},"\u002F\u002F 6\n",[12,319,320],{},"有點難理解這一段的運作對吧？我們來看看這一段的運作流程：",[322,323,324,341,354],"ul",{},[325,326,327,328,331,332,334,335,337,338],"li",{},"第一次呼叫 ",[59,329,330],{},"curryAdd(1)","，這時候會回傳一個函式，並且將 ",[59,333,81],{}," 設定為 ",[59,336,156],{},"，也就是 ",[59,339,340],{},"function (b) { return function (c) { return 1 + b + c; }; }",[325,342,343,344,331,347,334,349,337,351],{},"第二次呼叫 ",[59,345,346],{},"curryAdd(1)(2)",[59,348,87],{},[59,350,161],{},[59,352,353],{},"function (c) { return 1 + 2 + c; }",[325,355,356,357,331,360,334,362,337,364,367,368],{},"第三次呼叫 ",[59,358,359],{},"curryAdd(1)(2)(3)",[59,361,92],{},[59,363,312],{},[59,365,366],{},"1 + 2 + 3","，最後回傳 ",[59,369,370],{},"6",[12,372,373],{},"好像沒感受到好處吧？前面有提到 Currying 其實是利用了 Closure Function 的特性，那麼透過這特性，我們可以將變數的狀態保存起來，所以我們就可以設定所謂的「預設參數」，因此就可以這樣寫",[52,375,377],{"className":54,"code":376,"language":56,"meta":57,"style":57},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n\nconst addOne = curryAdd(1);\nconst addTwo = addOne(2);\n\n\u002F\u002F ...過了一千行之後\n\naddTwo(3); \u002F\u002F 6\n",[59,378,379,391,403,415,429,433,437,441,448,469,487,492,498,503],{"__ignoreMap":57},[62,380,381,383,385,387,389],{"class":64,"line":65},[62,382,69],{"class":68},[62,384,216],{"class":72},[62,386,77],{"class":76},[62,388,81],{"class":80},[62,390,95],{"class":76},[62,392,393,395,397,399,401],{"class":64,"line":98},[62,394,101],{"class":68},[62,396,229],{"class":68},[62,398,232],{"class":76},[62,400,87],{"class":80},[62,402,95],{"class":76},[62,404,405,407,409,411,413],{"class":64,"line":118},[62,406,241],{"class":68},[62,408,229],{"class":68},[62,410,232],{"class":76},[62,412,92],{"class":80},[62,414,95],{"class":76},[62,416,417,419,421,423,425,427],{"class":64,"line":252},[62,418,255],{"class":68},[62,420,104],{"cla