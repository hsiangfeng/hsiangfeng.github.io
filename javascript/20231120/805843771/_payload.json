[{"data":1,"prerenderedAt":1083},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20231120\u002F805843771\u002F":3,"page:\u002Fjavascript\u002F20231120\u002F805843771\u002F":4,"alt:\u002Fjavascript\u002F20231120\u002F805843771\u002F":3,"prev-next:\u002Fjavascript\u002F20231120\u002F805843771\u002F":1058,"related:\u002Fjavascript\u002F20231120\u002F805843771\u002F":1067},"\u002Fen\u002Fjavascript\u002F2023\u002F11\u002F20\u002Ffunctional-programming-javascript-currying\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":1042,"date":1043,"description":24,"extension":1044,"lang":1045,"meta":1046,"navigation":447,"path":1047,"readingMinutes":313,"seo":1048,"standalone":1049,"stem":1050,"tags":1051,"tldr":1055,"updated":1043,"url":1056,"__hash__":1057},"content\u002FJavaScript\u002F簡單趣談-Functional-Programming-in-JavaScript-之-Currying.md","簡單趣談 Functional Programming in JavaScript 之 Currying","805843771",{"type":9,"value":10,"toc":1037},"minimark",[11,18,22,25,29,32,35,41,44,48,51,122,129,135,142,169,188,191,194,200,206,284,287,290,319,322,372,375,518,527,530,646,649,698,701,715,847,850,1007,1014,1030,1033],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Ffp-currying\u002Fisray_notarray_Functional_Programming_--stylize_750_--v_5.2_5df82f93-316b-4019-b996-f4b4b22218dd.png",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"Functional Programming 設計模式中，還有一個很特別的概念，就叫做 Currying（柯里化），所以這一篇文章就會來介紹一下這個東西。",[19,26,28],{"id":27},"currying-是什麼","Currying 是什麼？",[12,30,31],{},"首先 Currying 中文有很多種翻譯，像是柯里化、卡瑞化或加里化，這些都是泛指 Functional Programming 設計模式中 Currying 這個概念。",[12,33,34],{},"那麼 Currying 究竟有什麼特別的呢？如果用簡單一句話來形容的話，那就是...",[36,37,38],"blockquote",{},[12,39,40],{},"Currying 是一個將多個參數的函式，轉換成一次只接受一個參數的函式，並且返回結果的一個過程。",[12,42,43],{},"可能有些人會覺得 Currying 是不是用了什麼新的語法，但實際上它只是善加利用了 JavaScript 的特性而已，也就是你所熟悉的 Closure Function 而已。",[19,45,47],{"id":46},"currying-的實作","Currying 的實作",[12,49,50],{},"接下來我們當然要來看看 Currying 的實作，首先我們先來看下方的程式碼：",[52,53,58],"pre",{"className":54,"code":55,"language":56,"meta":57,"style":57},"language-js shiki shiki-themes github-dark-high-contrast","function add(a, b, c) {\n  return a + b + c;\n}\n","js","",[59,60,61,96,116],"code",{"__ignoreMap":57},[62,63,66,70,74,78,82,85,88,90,93],"span",{"class":64,"line":65},"line",1,[62,67,69],{"class":68},"sWyjQ","function",[62,71,73],{"class":72},"sj_SG"," add",[62,75,77],{"class":76},"sMAXC","(",[62,79,81],{"class":80},"s_sBn","a",[62,83,84],{"class":76},", ",[62,86,87],{"class":80},"b",[62,89,84],{"class":76},[62,91,92],{"class":80},"c",[62,94,95],{"class":76},") {\n",[62,97,99,102,105,108,111,113],{"class":64,"line":98},2,[62,100,101],{"class":68},"  return",[62,103,104],{"class":76}," a ",[62,106,107],{"class":68},"+",[62,109,110],{"class":76}," b ",[62,112,107],{"class":68},[62,114,115],{"class":76}," c;\n",[62,117,119],{"class":64,"line":118},3,[62,120,121],{"class":76},"}\n",[12,123,124,125,128],{},"我們可以看到我們宣告了一個名為 ",[59,126,127],{},"add"," 的函式，這個函式接受三個參數，並且返回這三個參數的總和",[12,130,131],{},[15,132],{"alt":133,"src":134},"Function Add","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Ffp-currying\u002F%E6%88%AA%E5%9C%96%202023-11-20%2021.15.17.png",[12,136,137,138,141],{},"看似沒問題對吧？但是當你使用這個函式時，若不小心少傳入一個參數，那麼就會出現 ",[59,139,140],{},"NaN"," 的情況，例如：",[52,143,145],{"className":54,"code":144,"language":56,"meta":57,"style":57},"add(1, 2); \u002F\u002F NaN\n",[59,146,147],{"__ignoreMap":57},[62,148,149,151,153,157,159,162,165],{"class":64,"line":65},[62,150,127],{"class":72},[62,152,77],{"class":76},[62,154,156],{"class":155},"sCcAr","1",[62,158,84],{"class":76},[62,160,161],{"class":155},"2",[62,163,164],{"class":76},"); ",[62,166,168],{"class":167},"sQrFR","\u002F\u002F NaN\n",[36,170,171],{},[12,172,173,177,178,180,181,184,185,187],{},[174,175,176],"strong",{},"Note","\n這邊的 ",[59,179,140],{}," 是因為 ",[59,182,183],{},"1 + 2 + undefined"," 會得到 ",[59,186,140],{},"。",[12,189,190],{},"雖然你可能會認為...",[12,192,193],{},"「只要替函式預設參數就好了啊？」",[12,195,196,197,199],{},"確實，這也是一種解決問題的方式，但是這樣子的話，你就必須要知道你的函式會接受多少個參數，因此每次呼叫函式的時候，都必須要傳入所有的參數，那麼這時候就有可能會漏掉導致出現 ",[59,198,140],{}," 的情況。",[12,201,202,203,205],{},"這時候我們就可以來講講 Currying 了，我們可以將上述的 ",[59,204,127],{}," 函式改寫成以下：",[52,207,209],{"className":54,"code":208,"language":56,"meta":57,"style":57},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n",[59,210,211,224,238,251,267,273,279],{"__ignoreMap":57},[62,212,213,215,218,220,222],{"class":64,"line":65},[62,214,69],{"class":68},[62,216,217],{"class":72}," curryAdd",[62,219,77],{"class":76},[62,221,81],{"class":80},[62,223,95],{"class":76},[62,225,226,228,231,234,236],{"class":64,"line":98},[62,227,101],{"class":68},[62,229,230],{"class":68}," function",[62,232,233],{"class":76}," (",[62,235,87],{"class":80},[62,237,95],{"class":76},[62,239,240,243,245,247,249],{"class":64,"line":118},[62,241,242],{"class":68},"    return",[62,244,230],{"class":68},[62,246,233],{"class":76},[62,248,92],{"class":80},[62,250,95],{"class":76},[62,252,254,257,259,261,263,265],{"class":64,"line":253},4,[62,255,256],{"class":68},"      return",[62,258,104],{"class":76},[62,260,107],{"class":68},[62,262,110],{"class":76},[62,264,107],{"class":68},[62,266,115],{"class":76},[62,268,270],{"class":64,"line":269},5,[62,271,272],{"class":76},"    };\n",[62,274,276],{"class":64,"line":275},6,[62,277,278],{"class":76},"  };\n",[62,280,282],{"class":64,"line":281},7,[62,283,121],{"class":76},[12,285,286],{},"很有趣吧？我們將原本接受三個參數的函式，改寫成了三個接受一個參數的函式，最後回傳結果。",[12,288,289],{},"當我們使用時，只需要這樣寫就可以了：",[52,291,293],{"className":54,"code":292,"language":56,"meta":57,"style":57},"curryAdd(1)(2)(3); \u002F\u002F 6\n",[59,294,295],{"__ignoreMap":57},[62,296,297,300,302,304,307,309,311,314,316],{"class":64,"line":65},[62,298,299],{"class":72},"curryAdd",[62,301,77],{"class":76},[62,303,156],{"class":155},[62,305,306],{"class":76},")(",[62,308,161],{"class":155},[62,310,306],{"class":76},[62,312,313],{"class":155},"3",[62,315,164],{"class":76},[62,317,318],{"class":167},"\u002F\u002F 6\n",[12,320,321],{},"有點難理解這一段的運作對吧？我們來看看這一段的運作流程：",[323,324,325,342,355],"ul",{},[326,327,328,329,332,333,335,336,338,339],"li",{},"第一次呼叫 ",[59,330,331],{},"curryAdd(1)","，這時候會回傳一個函式，並且將 ",[59,334,81],{}," 設定為 ",[59,337,156],{},"，也就是 ",[59,340,341],{},"function (b) { return function (c) { return 1 + b + c; }; }",[326,343,344,345,332,348,335,350,338,352],{},"第二次呼叫 ",[59,346,347],{},"curryAdd(1)(2)",[59,349,87],{},[59,351,161],{},[59,353,354],{},"function (c) { return 1 + 2 + c; }",[326,356,357,358,332,361,335,363,338,365,368,369],{},"第三次呼叫 ",[59,359,360],{},"curryAdd(1)(2)(3)",[59,362,92],{},[59,364,313],{},[59,366,367],{},"1 + 2 + 3","，最後回傳 ",[59,370,371],{},"6",[12,373,374],{},"好像沒感受到好處吧？前面有提到 Currying 其實是利用了 Closure Function 的特性，那麼透過這特性，我們可以將變數的狀態保存起來，所以我們就可以設定所謂的「預設參數」，因此就可以這樣寫",[52,376,378],{"className":54,"code":377,"language":56,"meta":57,"style":57},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n\nconst addOne = curryAdd(1);\nconst addTwo = addOne(2);\n\n\u002F\u002F ...過了一千行之後\n\naddTwo(3); \u002F\u002F 6\n",[59,379,380,392,404,416,430,434,438,442,449,470,488,493,499,504],{"__ignoreMap":57},[62,381,382,384,386,388,390],{"class":64,"line":65},[62,383,69],{"class":68},[62,385,217],{"class":72},[62,387,77],{"class":76},[62,389,81],{"class":80},[62,391,95],{"class":76},[62,393,394,396,398,400,402],{"class":64,"line":98},[62,395,101],{"class":68},[62,397,230],{"class":68},[62,399,233],{"class":76},[62,401,87],{"class":80},[62,403,95],{"class":76},[62,405,406,408,410,412,414],{"class":64,"line":118},[62,407,242],{"class":68},[62,409,230],{"class":68},[62,411,233],{"class":76},[62,413,92],{"class":80},[62,415,95],{"class":76},[62,417,418,420,422,424,426,428],{"class":64,"line":253},[62,419,256],{"class":68},[62,421,104],{"class":76},[62,423,107],{"class":68},[62,425,110],{"class":76},[62,427,107],{"class":68},[62,429,115],{"class":76},[62,431,432],{"class":64,"line":269},[62,433,272],{"class":76},[62,435,436],{"class":64,"line":275},[62,437,278],{"class":76},[62,439,440],{"class":64,"line":281},[62,441,121],{"class":76},[62,443,445],{"class":64,"line":444},8,[62,446,448],{"emptyLinePlaceholder":447},true,"\n",[62,450,452,455,458,461,463,465,467],{"class":64,"line":451},9,[62,453,454],{"class":68},"const",[62,456,457],{"class":155}," addOne",[62,459,460],{"class":68}," =",[62,462,217],{"class":72},[62,464,77],{"class":76},[62,466,156],{"class":155},[62,468,469],{"class":76},");\n",[62,471,473,475,478,480,482,484,486],{"class":64,"line":472},10,[62,474,454],{"class":68},[62,476,477],{"class":155}," addTwo",[62,479,460],{"class":68},[62,481,457],{"class":72},[62,483,77],{"class":76},[62,485,161],{"class":155},[62,487,469],{"class":76},[62,489,491],{"class":64,"line":490},11,[62,492,448],{"emptyLinePlaceholder":447},[62,494,496],{"class":64,"line":495},12,[62,497,498],{"class":167},"\u002F\u002F ...過了一千行之後\n",[62,500,502],{"class":64,"line":501},13,[62,503,448],{"emptyLinePlaceholder":447},[62,505,507,510,512,514,516],{"class":64,"line":506},14,[62,508,509],{"class":72},"addTwo",[62,511,77],{"class":76},[62,513,313],{"class":155},[62,515,164],{"class":76},[62,517,318],{"class":167},[12,519,520,521,523,524,526],{},"你會發現我們的 ",[59,522,81],{}," 跟 ",[59,525,87],{}," 都已經被設定好了，這樣子就不用擔心會漏掉參數的問題，我們只需要專注於傳入最後一個參數就好了。",[12,528,529],{},"當然你也不一定要拆成這樣，你也可以預設寫死兩個參數，例如：",[52,531,533],{"className":54,"code":532,"language":56,"meta":57,"style":57},"function curryAdd(a) {\n  return function (b) {\n    return function (c) {\n      return a + b + c;\n    };\n  };\n}\n\nconst addOne = curryAdd(1)(2);\n\n\u002F\u002F ...過了一千行之後\n\naddOne(3); \u002F\u002F 6\n",[59,534,535,547,559,571,585,589,593,597,601,621,625,629,633],{"__ignoreMap":57},[62,536,537,539,541,543,545],{"class":64,"line":65},[62,538,69],{"class":68},[62,540,217],{"class":72},[62,542