[{"data":1,"prerenderedAt":635},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200705\u002F3382481626\u002F":3,"page:\u002Fjavascript\u002F20200705\u002F3382481626\u002F":4,"alt:\u002Fjavascript\u002F20200705\u002F3382481626\u002F":3,"prev-next:\u002Fjavascript\u002F20200705\u002F3382481626\u002F":610,"related:\u002Fjavascript\u002F20200705\u002F3382481626\u002F":619},"\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F05\u002Fjavascript-core-19-logical-operators-default-values\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":595,"date":596,"description":18,"extension":597,"lang":598,"meta":599,"navigation":266,"path":600,"readingMinutes":601,"seo":602,"standalone":603,"stem":604,"tags":605,"tldr":607,"updated":607,"url":608,"__hash__":609},"content\u002FJavaScript 核心觀念\u002F2.運算子、型別與文法\u002FJavaScript-核心觀念-19-運算子、型別與文法-邏輯運算子及函式預設值.md","JavaScript 核心觀念(19)-運算子、型別與文法-邏輯運算子及函式預設值","3382481626",{"type":9,"value":10,"toc":590},"minimark",[11,15,19,22,25,28,41,44,50,53,130,133,182,189,192,325,328,333,336,379,382,385,433,436,494,501,565,572,575,586],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來將會來講邏輯運算子，邏輯運算子的使用若不當，其實結果也會不同唷。",[12,20,21],{"id":21},"邏輯運算子",[16,23,24],{},"前一篇了解真值與假值之後，這一段觀念是可以套用在邏輯運算子上的。",[16,26,27],{},"首先依照 MDN 文件中邏輯運算子有以下幾種",[29,30,31,35,38],"ul",{},[32,33,34],"li",{},"&& (And 運算子)，用法 expr1 && expr2",[32,36,37],{},"|| (OR 運算子)，用法 expr1 || expr2",[32,39,40],{},"! (Not 運算子)，用法 !expr",[16,42,43],{},"在 MDN 官方文件中其實也已經說明用法，這邊直接貼上",[45,46,47],"blockquote",{},[16,48,49],{},"如果 expr1 可以轉換為 false，就返回 expr1。否則返回 expr2。所以，當使用於布林值時，如果兩個運算元都為 true，&& 返回 true。否則返回 false。",[16,51,52],{},"首先先看第一段是什麼意思「如果 expr1 可以轉換為 false，就返回 expr1。否則返回 expr2。」，這一段我們直接看程式碼",[54,55,60],"pre",{"className":56,"code":57,"language":58,"meta":59,"style":59},"language-js shiki shiki-themes github-dark-high-contrast","var a = 0; \u002F\u002F false\nvar b = 1; \u002F\u002F true\nconsole.log(a && b); \u002F\u002F 0\n","js","",[61,62,63,90,108],"code",{"__ignoreMap":59},[64,65,68,72,76,79,83,86],"span",{"class":66,"line":67},"line",1,[64,69,71],{"class":70},"sWyjQ","var",[64,73,75],{"class":74},"sMAXC"," a ",[64,77,78],{"class":70},"=",[64,80,82],{"class":81},"sCcAr"," 0",[64,84,85],{"class":74},"; ",[64,87,89],{"class":88},"sQrFR","\u002F\u002F false\n",[64,91,93,95,98,100,103,105],{"class":66,"line":92},2,[64,94,71],{"class":70},[64,96,97],{"class":74}," b ",[64,99,78],{"class":70},[64,101,102],{"class":81}," 1",[64,104,85],{"class":74},[64,106,107],{"class":88},"\u002F\u002F true\n",[64,109,111,114,118,121,124,127],{"class":66,"line":110},3,[64,112,113],{"class":74},"console.",[64,115,117],{"class":116},"sj_SG","log",[64,119,120],{"class":74},"(a ",[64,122,123],{"class":70},"&&",[64,125,126],{"class":74}," b); ",[64,128,129],{"class":88},"\u002F\u002F 0\n",[16,131,132],{},"你可以發現只要第一個 expr1 可以被轉換為布林值 false，因此他就直接回傳 expr1 的值，那如果反轉呢？",[54,134,136],{"className":56,"code":135,"language":58,"meta":59,"style":59},"var a = 0; \u002F\u002F false\nvar b = 1; \u002F\u002F true\nconsole.log(b && a); \u002F\u002F 0\n",[61,137,138,152,166],{"__ignoreMap":59},[64,139,140,142,144,146,148,150],{"class":66,"line":67},[64,141,71],{"class":70},[64,143,75],{"class":74},[64,145,78],{"class":70},[64,147,82],{"class":81},[64,149,85],{"class":74},[64,151,89],{"class":88},[64,153,154,156,158,160,162,164],{"class":66,"line":92},[64,155,71],{"class":70},[64,157,97],{"class":74},[64,159,78],{"class":70},[64,161,102],{"class":81},[64,163,85],{"class":74},[64,165,107],{"class":88},[64,167,168,170,172,175,177,180],{"class":66,"line":110},[64,169,113],{"class":74},[64,171,117],{"class":116},[64,173,174],{"class":74},"(b ",[64,176,123],{"class":70},[64,178,179],{"class":74}," a); ",[64,181,129],{"class":88},[16,183,184,185,188],{},"你會發現還是回傳 ",[61,186,187],{},"0"," 這就是驗證了「如果 expr1 可以轉換為 false，就返回 expr1。否則返回 expr2。」",[16,190,191],{},"基本上 And 運算子是以第一個值是否為真值為主，假使若為真值，那就一定會回傳第二個值，若第一個值是假值，那他就會回傳第一個值",[54,193,195],{"className":56,"code":194,"language":58,"meta":59,"style":59},"console.log(1 && 10); \u002F\u002F 10\nconsole.log(1 && 15); \u002F\u002F 15\nconsole.log(1 && 2); \u002F\u002F 2\n\nconsole.log(0 && 10); \u002F\u002F 0\nconsole.log(0 && 15); \u002F\u002F 0\nconsole.log(0 && 2); \u002F\u002F 0\n",[61,196,197,221,241,261,268,287,306],{"__ignoreMap":59},[64,198,199,201,203,206,209,212,215,218],{"class":66,"line":67},[64,200,113],{"class":74},[64,202,117],{"class":116},[64,204,205],{"class":74},"(",[64,207,208],{"class":81},"1",[64,210,211],{"class":70}," &&",[64,213,214],{"class":81}," 10",[64,216,217],{"class":74},"); ",[64,219,220],{"class":88},"\u002F\u002F 10\n",[64,222,223,225,227,229,231,233,236,238],{"class":66,"line":92},[64,224,113],{"class":74},[64,226,117],{"class":116},[64,228,205],{"class":74},[64,230,208],{"class":81},[64,232,211],{"class":70},[64,234,235],{"class":81}," 15",[64,237,217],{"class":74},[64,239,240],{"class":88},"\u002F\u002F 15\n",[64,242,243,245,247,249,251,253,256,258],{"class":66,"line":110},[64,244,113],{"class":74},[64,246,117],{"class":116},[64,248,205],{"class":74},[64,250,208],{"class":81},[64,252,211],{"class":70},[64,254,255],{"class":81}," 2",[64,257,217],{"class":74},[64,259,260],{"class":88},"\u002F\u002F 2\n",[64,262,264],{"class":66,"line":263},4,[64,265,267],{"emptyLinePlaceholder":266},true,"\n",[64,269,271,273,275,277,279,281,283,285],{"class":66,"line":270},5,[64,272,113],{"class":74},[64,274,117],{"class":116},[64,276,205],{"class":74},[64,278,187],{"class":81},[64,280,211],{"class":70},[64,282,214],{"class":81},[64,284,217],{"class":74},[64,286,129],{"class":88},[64,288,290,292,294,296,298,300,302,304],{"class":66,"line":289},6,[64,291,113],{"class":74},[64,293,117],{"class":116},[64,295,205],{"class":74},[64,297,187],{"class":81},[64,299,211],{"class":70},[64,301,235],{"class":81},[64,303,217],{"class":74},[64,305,129],{"class":88},[64,307,309,311,313,315,317,319,321,323],{"class":66,"line":308},7,[64,310,113],{"class":74},[64,312,117],{"class":116},[64,314,205],{"class":74},[64,316,187],{"class":81},[64,318,211],{"class":70},[64,320,255],{"class":81},[64,322,217],{"class":74},[64,324,129],{"class":88},[16,326,327],{},"而 OR 運算子的部分也可以看一下 MDN 說明",[45,329,330],{},[16,331,332],{},"如果 expr1 可以轉換為 true，就返回 expr1。否則返回 expr2。所以，當使用於布林值時，如果其中一個運算元為 true，|| 返回 true，如果兩個運算元都為 false，就返回 false。",[16,334,335],{},"因此只要第一個是真值，那就會回傳第一個值，否則就會回傳第二個值",[54,337,339],{"className":56,"code":338,"language":58,"meta":59,"style":59},"console.log(1 || 0); \u002F\u002F 1\nconsole.log(0 || 1); \u002F\u002F 1\n",[61,340,341,361],{"__ignoreMap":59},[64,342,343,345,347,349,351,354,356,358],{"class":66,"line":67},[64,344,113],{"class":74},[64,346,117],{"class":116},[64,348,205],{"class":74},[64,350,208],{"class":81},[64,352,353],{"class":70}," ||",[64,355,82],{"class":81},[64,357,217],{"class":74},[64,359,360],{"class":88},"\u002F\u002F 1\n",[64,362,363,365,367,369,371,373,375,377],{"class":66,"line":92},[64,364,113],{"class":74},[64,366,117],{"class":116},[64,368,205],{"class":74},[64,370,187],{"class":81},[64,372,353],{"class":70},[64,374,102],{"class":81},[64,376,217],{"class":74},[64,378,360],{"class":88},[16,380,381],{},"概念也與 && 有點雷同。",[16,383,384],{},"最後一個是比較常搞混的運算子，也就是否定運算子，通常我會把它稱之為反轉結果運算子，簡單來講他會將 true 轉換為 false，而 false 變成 true，此外這個運算子也會直接回傳布林值",[54,386,388],{"className":56,"code":387,"language":58,"meta":59,"style":59},"!true; \u002F\u002F false\n!false; \u002F\u002F true\n!1; \u002F\u002F false\n!0; \u002F\u002F true\n",[61,389,390,402,413,423],{"__ignoreMap":59},[64,391,392,395,398,400],{"class":66,"line":67},[64,393,394],{"class":70},"!",[64,396,397],{"class":81},"true",[64,399,85],{"class":74},[64,401,89],{"class":88},[64,403,404,406,409,411],{"class":66,"line":92},[64,405,394],{"class":70},[64,407,408],{"class":81},"false",[64,410,85],{"class":74},[64,412,107],{"class":88},[64,414,415,417,419,421],{"class":66,"line":110},[64,416,394],{"class":70},[64,418,208],{"class":81},[64,420,85],{"class":74},[64,422,89],{"class":88},[64,424,425,427,429,431],{"class":66,"line":263},[64,426,394],{"class":70},[64,428,187],{"class":81},[64,430,85],{"class":74},[64,432,107],{"class":88},[16,434,435],{},"而這邊技巧可以使用在一些小地方，例如給予函式預設值，在早期 ES6 預設值還沒有實作時，往往我們函式如果沒有預設值，可能會發生錯誤，因此就可以這樣寫",[54,437,439],{"className":56,"code":438,"language":58,"meta":59,"style":59},"function fn(name) {\n  console.log('我是'+ name);\n}\n\nfn()\n",[61,440,441,458,477,482,486],{"__ignoreMap":59},[64,442,443,446,449,451,455],{"class":66,"line":67},[64,444,445],{"class":70},"function",[64,447,448],{"class":116}," fn",[64,450,205],{"class":74},[64,452,454],{"class":453},"s_sBn","name",[64,456,457],{"class":74},") {\n",[64,459,460,463,465,467,471,474],{"class":66,"line":92},[64,461,462],{"class":74},"  console.",[64,464,117],{"class":116},[64,466,205],{"class":74},[64,468,470],{"class":469},"sTRMh","'我是'",[64,472,473],{"class":70},"+",[64,475,476],{"class":74}," name);\n",[64,478,479],{"class":66,"line":110},[64,480,481],{"class":74},"}\n",[64,483,484],{"class":66,"line":263},[64,485,267],{"emptyLinePlaceholder":266},[64,487,488,491],{"class":66,"line":270},[64,489,490],{"class":116},"fn",[64,492,493],{"class":74},"()\n",[16,495,496,497,500],{},"上面程式碼如果沒有使用 ES6 預設值時，就會出現「",[61,498,499],{},"我是 undefined","」，但實際上我們並不希望這樣，而是希望有一個預設值，那就可以使用上面所學的其中一個技巧 OR 運算子來改寫",[54,502,504],{"className":56,"code":503,"language":58,"meta":59,"style":59},"function fn(name) {\n  name = name || 'Ray';\n  console.log('我是'+ name);\n}\n\nfn()\n",[61,505,506,518,537,551,555,559],{"__ignoreMap":59},[64,507,508,510,512,514,516],{"class":66,"line":67},[64,509,445],{"class":70},[64,511,448],{"class":116},[64,513,205],{"class":74},[64,515,454],{"class":453},[64,517,457],{"class":74},[64,519,520,523,525,528,531,534],{"class":66,"line":92},[64,521,522],{"class":74},"  name ",[64,524,78],{"class":70},[64,526,527],{"class":74}," name ",[64,529,530],{"class":70},"||",[64,532,533],{"class":469}," 'Ray'",[64,535,536],{"class":74},";\n",[64,538,539,541,543,545,547,549],{"class":66,"line":110},[64,5