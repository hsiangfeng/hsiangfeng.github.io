}," \u003C",[54,83,84],{"class":64}," 25",[54,86,87],{"class":60},"); ",[54,89,91],{"class":90},"sQrFR","\u002F\u002F true\n",[16,93,94,96,97,99,100,102],{},[26,95,42],{}," 的意思是若兩邊比較出來結果都為 ",[26,98,28],{}," 才會回傳 ",[26,101,28],{},"。",[16,104,105],{},"那麼邏輯運算子最主要有這三種：",[16,107,108],{},[109,110],"img",{"alt":21,"src":111},"https:\u002F\u002Fi.imgur.com\u002FQiwIxUV.png",[12,113,115],{"id":114},"and-運算子","AND 運算子",[16,117,118,119,121,122,124],{},"在前面有稍微示範過 AND 運算子，簡單來講，兩者結果比較若有一個為 ",[26,120,32],{},"，那邏輯運算子就會回傳 ",[26,123,32],{},"，例如：",[45,126,128],{"className":47,"code":127,"language":49,"meta":50,"style":50},"(5 > 2 && 10 \u003C 25); \u002F\u002F true\n(5 > 2 && 10 \u003C 25); \u002F\u002F true\n(5 > 2 && 10 > 25); \u002F\u002F false\n",[26,129,130,152,175],{"__ignoreMap":50},[54,131,132,134,136,138,140,142,144,146,148,150],{"class":56,"line":57},[54,133,61],{"class":60},[54,135,65],{"class":64},[54,137,69],{"class":68},[54,139,72],{"class":64},[54,141,75],{"class":68},[54,143,78],{"class":64},[54,145,81],{"class":68},[54,147,84],{"class":64},[54,149,87],{"class":60},[54,151,91],{"class":90},[54,153,155,157,159,161,163,165,167,169,171,173],{"class":56,"line":154},2,[54,156,61],{"class":60},[54,158,65],{"class":64},[54,160,69],{"class":68},[54,162,72],{"class":64},[54,164,75],{"class":68},[54,166,78],{"class":64},[54,168,81],{"class":68},[54,170,84],{"class":64},[54,172,87],{"class":60},[54,174,91],{"class":90},[54,176,178,180,182,184,186,188,190,192,194,196],{"class":56,"line":177},3,[54,179,61],{"class":60},[54,181,65],{"class":64},[54,183,69],{"class":68},[54,185,72],{"class":64},[54,187,75],{"class":68},[54,189,78],{"class":64},[54,191,69],{"class":68},[54,193,84],{"class":64},[54,195,87],{"class":60},[54,197,198],{"class":90},"\u002F\u002F false\n",[12,200,202],{"id":201},"or-運算子","OR 運算子",[16,204,205,206,208,209,211],{},"OR 運算子要理解很容易，只要有一個是 ",[26,207,28],{}," 那就會回傳 ",[26,210,28],{},"：",[45,213,215],{"className":47,"code":214,"language":49,"meta":50,"style":50},"(5 >