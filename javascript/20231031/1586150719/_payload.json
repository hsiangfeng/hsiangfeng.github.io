:64},[50,182,120],{"class":60},[50,184,117],{"class":64},[50,186,187],{"class":81},"'World'",[50,189,190],{"class":64},"));\n",[12,192,193],{},"我們可以看到兩個人撰寫的風格很明顯不同，目前來講可能沒有很大的差異，但是當專案越來越大，後續又加入了其他開發者的話，那這專案就會非常爆炸，因為我們在開發上其實都會需要維護他人的程式碼，這時候如果每個人的風格都不一樣，那閱讀起來就會非常困難，所以我們就需要一個工具來統一程式碼的風格，也就是我們這一篇要介紹的 Prettier。",[20,195,197],{"id":196},"prettier-安裝","Prettier 安裝",[12,199,200],{},"首先我們先準備一下環境與範例程式碼",[40,202,206],{"className":203,"code":204,"language":205,"meta":45,"style":45},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir prettier-example\ncd prettier-example\nnpm init -y\ntouch index.js\n","bash",[47,207,208,216,224,235],{"__ignoreMap":45},[50,209,210,213],{"class":52,"line":53},[50,211,212],{"class":68},"mkdir",[50,214,215],{"class":81}," prettier-example\n",[50,217,218,222],{"class":52,"line":75},[50,219,221],{"class":220},"sCcAr","cd",[50,223,215],{"class":81},[50,225,226,229,232],{"class":52,"line":95},[50,227,228],{"class":68},"npm",[50,230,231],{"class":81}," init",[50,233,234],{"class":220}," -y\n",[50,236,237,240],{"class":52,"line":101},[50,238,239],{"class":68},"touch",[50,241,242],{"class":81}," index.js\n",[12,244,245],{},"而 index.js 內容呢？別擔心，我也幫你準備好了，你只要複製貼上就好了",[40,247,249],{"className":42,"code":248,"language":44,"meta":45,"style":45},"function hello (name){\n  return \"Hello, \"+name+\"!\"\n}\n\nconst data = [{\n  id: 1,\n  name: 'Ray',\n  color: 'red'\n},{\n  id:2,\n  name: 'Ray2',\n  color: 'blue'\n},\n{\n  id:3,\n  name: 'Ray3',\n  color: 'green'\n},\n{\n  id:4,\n  name: 'Ray4',\n  color: 'red'\n}]\n\nfunction getRedColor(data){\n  const filterData = data.filter(function (item){\n    return item.color === 'red'\n  })\n\n  return filterData\n}\n\nconsole.log(hello(\"Ray\"))\nconsole.log(getRedColor(data))\n",[47,250,251,263,277,281,285,299,311,322,331,337,348,358,366,372,378,388,398,406,411,416,426,436,443,449,454,469,497,512,518,523,531,536,541,559],{"__ignoreMap":45},[50,252,253,255,257,259,261],{"class":52,"line":53},[50,254,57],{