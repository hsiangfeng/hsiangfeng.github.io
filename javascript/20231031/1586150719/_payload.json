:60},[50,180,117],{"class":64},[50,182,120],{"class":60},[50,184,117],{"class":64},[50,186,187],{"class":81},"'World'",[50,189,190],{"class":64},"));\n",[12,192,193],{},"我們可以看到兩個人撰寫的風格很明顯不同，目前來講可能沒有很大的差異，但是當專案越來越大，後續又加入了其他開發者的話，那這專案就會非常爆炸，因為我們在開發上其實都會需要維護他人的程式碼，這時候如果每個人的風格都不一樣，那閱讀起來就會非常困難，所以我們就需要一個工具來統一程式碼的風格，也就是我們這一篇要介紹的 Prettier。",[20,195,197],{"id":196},"prettier-安裝","Prettier 安裝",[12,199,200],{},"首先我們先準備一下環境與範例程式碼",[40,202,206],{"className":203,"code":204,"language":205,"meta":45,"style":45},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","mkdir prettier-example\ncd prettier-example\nnpm init -y\ntouch index.js\n","bash",[47,207,208,217,225,236],{"__ignoreMap":45},[50,209,210,214],{"class":52,"line":53},[50,211,213],{"class":212},"smYoP","mkdir",[50,215,216],{"class":81}," prettier-example\n",[50,218,219,223],{"class":52,"line":75},[50,220,222],{"class":221},"stw71","cd",[50,224,216],{"class":81},[50,226,227,230,233],{"class":52,"line":95},[50,228,229],{"class":212},"npm",[50,231,232],{"class":81}," init",[50,234,235],{"class":221}," -y\n",[50,237,238,241],{"class":52,"line":101},[50,239,240],{"class":212},"touch",[50,242,243],{"class":81}," index.js\n",[12,245,246],{},"而 index.js 內容呢？別擔心，我也幫你準備好了，你只要複製貼上就好了",[40,248,250],{"className":42,"code":249,"language":44,"meta":45,"style":45},"function hello (name){\n  return \"Hello, \"+name+\"!\"\n}\n\nconst data = [{\n  id: 1,\n  name: 'Ray',\n  color: 'red'\n},{\n  id:2,\n  name: 'Ray2',\n  color: 'blue'\n},\n{\n  id:3,\n  name: 'Ray3',\n  color: 'green'\n},\n{\n  id:4,\n  name: 'Ray4',\n  color: 'red'\n}]\n\nfunction getRedColor(data){\n  const filterData = data.filter(function (item){\n    return item.color === 'red'\n  })\n\n  return filterData\n}\n\nconsole.log(hello(\"Ray\"))\nconsole.log(getRedColor(data))\n",[47,251,252,264,278,282,286,300,312,323,332,338,349,359,367,373,379,389,399,407,412,417,427,437,444,450,455,470,498,513,519,524,532,537,542,560],{"__ignoreMap":45},[5