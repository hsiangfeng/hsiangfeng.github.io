: \"prettier --write .\"\n  }\n}\n",[47,662,663,667,676,687,692],{"__ignoreMap":45},[50,664,665],{"class":52,"line":53},[50,666,377],{"class":64},[50,668,669,673],{"class":52,"line":75},[50,670,672],{"class":671},"sKpQp","  \"scripts\"",[50,674,675],{"class":64},": {\n",[50,677,678,681,684],{"class":52,"line":95},[50,679,680],{"class":671},"    \"prettier\"",[50,682,683],{"class":64},": ",[50,685,686],{"class":81},"\"prettier --write .\"\n",[50,688,689],{"class":52,"line":101},[50,690,691],{"class":64},"  }\n",[50,693,694],{"class":52,"line":108},[50,695,98],{"class":64},[12,697,698,699,702],{},"接下來你只需要執行 ",[47,700,701],{},"npm run prettier"," 就可以看到程式碼被修正了！",[12,704,705],{},[15,706],{"alt":701,"src":707},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Fprettier-setting\u002FOct-31-2023%2014-11-21(1).gif",[12,709,710],{},"很方便吧？透過 Prettier 我們可以很快速的幫助我們修正程式碼。",[20,712,714],{"id":713},"prettier-設定","Prettier 設定",[12,716,717],{},"但是我們實際專案開發上，專案還是會有自己團隊的撰寫風格，那這時候該怎麼辦呢？",[12,719,720],{},"不用擔心，我們在前面不是有建立一個 .prettierrc 檔案嗎？我們就可以透過這個檔案來設定 Prettier 的風格。",[12,722,723],{},"那麼常見的設定有哪些呢？這邊我列出一些比較常見的設定調整：",[40,725,727],{"className":643,"code":726,"language":645,"meta":45,"style":45},"{\n  \"printWidth\": 80, \u002F\u002F 超過 80 個字元就換行\n  \"tabWidth\": 2, \u002F\u002F 程式碼縮排 2 個空格\n  \"useTabs\": false, \u002F\u002F 不使用 tab，預設使用空格\n  \"semi\": true, \u002F\u002F 語句結尾加上分號\n  \"singleQuote\": true, \u002F\u002F 使用單引號，預設使用雙引號\n  \"quoteProps\": \"as-needed\", \u002F\u002F 預設 'as-needed'，只有在屬性名稱包含特殊字元或空格時才會使用雙引號。否則，它將使用單引號。\n  \"trailingComma\": \"es5\", \u002F\u002F 在物件或陣列最後一個元素後面加上逗號\n  \"bracketSpacing\": true, \u002F\u002F 在物件的左右括號間加上空格\n  \"arrowParens\": \"always\", \u002F\u002F 箭頭函式只有一個參數時，也需要括號\n  \"endOfLine\": \"lf\", \u002F\u002F 換行符號，預設 lf\n}\n",[47,728,729,733,750,764,779,794,808,823,838,852,867,882],{"__ignoreMap":45},[50,730,731],{"class":52,"line":53},[50,732,377],{"class":64},[50,734,735,738,740,743,746],{"class":52,"line":75},[50,736,737],{"clas