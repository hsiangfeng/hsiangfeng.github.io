,1185,1187,1189,1191,1193,1195],{"class":52,"line":1182},36,[50,1184,111],{"class":64},[50,1186,114],{"class":60},[50,1188,117],{"class":64},[50,1190,120],{"class":60},[50,1192,117],{"class":64},[50,1194,320],{"class":81},[50,1196,190],{"class":64},[50,1198,1200,1202,1204,1206,1208],{"class":52,"line":1199},37,[50,1201,111],{"class":64},[50,1203,114],{"class":60},[50,1205,117],{"class":64},[50,1207,571],{"class":60},[50,1209,1210],{"class":64},"(data));\n",[20,1212,1213],{"id":1213},"忽略檔案",[12,1215,1216],{},"我們專案內可能有些檔案是不想要被 Prettier 修正的，例如...build 出來的檔案，這時候我們就可以在根目錄下新增一個 .prettierignore 檔案，並且在內容中加入以下內容",[40,1218,1222],{"className":1219,"code":1220,"language":1221,"meta":45,"style":45},"language-txt shiki shiki-themes github-light github-light github-dark-high-contrast","build\n","txt",[47,1223,1224],{"__ignoreMap":45},[50,1225,1226],{"class":52,"line":53},[50,1227,1220],{},[12,1229,1230],{},"這樣子就可以避免 Prettier 修正 build 出來的檔案囉！",[20,1232,1234],{"id":1233},"prettier-vscode-設定","Prettier VSCode 設定",[12,1236,1237],{},"VSCode 身為我們最常使用的開發工具，當然也要讓他支援 Prettier，這樣我們就可以在開發的時候，直接透過快捷鍵就可以修正程式碼，所以請你打開 VSCode，並且安裝以下套件：",[1239,1240,1241],"ul",{},[1242,1243,1244],"li",{},[891,1245,1248],{"href":1246,"rel":1247},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=esbenp.prettier-vscode",[895],"Prettier - Code formatter",[12,1250,1251],{},"接著打開你就可以使用快捷鍵 Option + Shift + F（Mac）或者 Alt + Shift + F（Windows）來修正程式碼囉！",[12,1253,1254],{},"如果無效的話，有兩種可能性：",[1256,1257,1258],"h3",{"id":1258},"沒有預設格式化方式",[12,1260,1261],{},"你可以到 VSCode 中搜尋「Editor: Default Formatter」並設定成「Prettier - Code formatter(esbenp.prettier-vscode)」，這樣就可以點右鍵或者使用快捷鍵修正程式碼。",[1256,1263,1264],{"id":1264},"針對語言覆寫的編輯器設定",[12,1266,1267],{},"另一種可能性是你曾經設定過以下",[40,1269,1271],{"className":642,"code":1270,"language":644,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"vscode.typescript-language-features\"\n  },\n  \u002F\u002F ... 其他設定\n}\n",[47,1272,1273,1277,1282,1289,1299,1303,1307],{"__ignoreMap":45},[50,1274,1275],{"class":52,"line":53},[50,1276,378],{"class":64},[50,1278,1279],{"class":52,"line":75},[50,1280,1281],{"class":747},"  \u002F\u002F ... 其他設定\n",[50,1283,1284,1287],{"class":52,"line":95},[50,1285,1286],{"class":670},"  \"[javascript]\"",[50,1288,674],{"class":64},[50,1290,1291,1294,1296],{"class":52,"line":101},[50,1292,1293],{"class":670},"    \"editor.defaultFormatter\"",[50,1295,682],{"class":64},[50,1297,1298],{"class":81},"\"vscode.typescript-language-features\"\n",[50,1300,1301],{"class":52,"line":108},[50,1302,1000],{"class":64},[50,1304,1305],{"class":52,"line":302},[50,1306,1281],{"class":747},[50,1308,1309],{"class":52,"line":314},[50,1310,98],{"class":64},[12,1312,1313],{},"這個設定是針對 JavaScript 語言覆寫的編輯器設定，所以你可以將他改成以下",[40,1315,1317],{"className":642,"code":1316,"language":644,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \u002F\u002F ... 其他設定\n}\n",[47,1318,1319,1323,1327,1333,1342,1346,1350],{"__ignoreMap":45},[50,1320,1321],{"class":52,"line":53},[50,1322,378],{"class":64},[50,1324,1325],{"class":52,"line":75},[50,1326,1281],{"class":747},[50,1328,1329,1331],{"class":52,"line":95},[50,1330,1286],{"class":670},[50,1332,674],{"class":64},[50,1334,1335,1337,1339],{"class":52,"line":101},[50,1336,1293],{"class":670},[50,1338,682],{"class":64},[50,1340,1341],{"class":81},"\"esbenp.prettier-vscode\"\n",[50,1343,1344],{"class":52,"line":108},[50,1345,1000],{"class":64},[50,1347,1348],{"class":52,"line":302},[50,1349,1281],{"class":747},[50,1351,1352],{"class":52,"line":314},[50,1353,98],{"class":64},[12,1355,1356],{},"這樣子你在使用快捷鍵修正程式碼就會生效囉！",[12,1358,1359],{},"如果兩者都設定之後，基本上你的 VSCode 設定會變成以下",[40,1361,1363],{"className":642,"code":1362,"language":644,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n  \u002F\u002F ... 其他設定\n}\n",[47,1364,1365,1369,1373,1379,1387,1391,1403,1407],{"__ignoreMap":45},[50,1366,1367],{"class":52,"line":53},[50,1368,378],{"class":64},[50,1370,1371],{"class":52,"line":75},[50,1372,1281],{"class":747},[50,1374,1375,1377],{"class":52,"line":95},[50,1376,1286],{"class":670},[50,1378,674],{"class":64},[50,1380,1381,1383,1385],{"class":52,"line":101},[50,1382,1293],{"class":670},[50,1384,682],{"class":64},[50,1386,1341],{"class":81},[50,1388,1389],{"class":52,"line":108},[50,1390,1000],{"class":64},[50,1392,1393,1396,1398,1401],{"class":52,"line":302},[50,1394,1395],{"class":670},"  \"editor.defaultFormatter\"",[50,1397,682],{"class":64},[50,1399,1400],{"class":81},"\"esbenp.prettier-vscode\"",[50,1402,311],{"class":64},[50,1404,1405],{"class":52,"line":314},[50,1406,1281],{"class":747},[50,1408,1409],{"class":52,"line":325},[50,1410,98],{"class":64},[1256,1412,1413],{"id":1413},"儲存時自動修正程式碼",[12,1415,1416,1417,1420],{},"每次都要按快捷鍵才格式化程式碼其實很麻煩，所以這邊我們可以在 VSCode 設定中加入另一個設定，也就是 ",[47,1418,1419],{},"formatOnSave","，加入方式也很簡單，只需要針對特定語言加入即可",[40,1422,1424],{"className":642,"code":1423,"language":644,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n    \"editor.formatOnSave\": true\n  },\n  \u002F\u002F ... 其他設定\n}\n",[47,1425,1426,1430,1434,1440,1450,1460,1464,1468],{"__ignoreMap":45},[50,1427,1428],{"class":52,"line":53},[50,1429,378],{"class":64},[50,1431,1432],{"class":52,"line":75},[50,1433,1281],{"class":747},[50,1435,1436,1438],{"class":52,"line":95},[50,1437,1286],{"class":670},[50,1439,674],{"class":64},[50,1441,1442,1444,1446,1448],{"class":52,"line":101},[50,1443,1293],{"class":670},[50,1445,682],{"class":64},[50,1447,1400],{"class":81},[50,1449,311],{"class":64},[50,1451,1452,1455,1457],{"class":52,"line":108},[50,1453,1454],{"class":670},"    \"editor.formatOnSave\"",[50,1456,682],{"class":64},[50,1458,1459],{"class":221},"true\n",[50,1461,1462],{"class":52,"line":302},[50,1463,1000],{"class":64},[50,1465,1466],{"class":52,"line":314},[50,1467,1281],{"class":747},[50,1469,1470],{"class":52,"line":325},[50,1471,98],{"class":64},[12,1473,1474],{},"這樣當你按下 Command + S（Mac）或者 Ctrl + S（Windows）時，就會自動幫你修正程式碼囉！",[20,1476,1478],{"id":1477},"prettier-與-eslint-有什麼差異","Prettier 與 ESLint 有什麼差異？",[12,1480,1481],{},"這兩者可以說是最容易被混淆的東西，因為他們都是用來幫助我們統一程式碼風格的工具，但是他們的差異在哪裡呢？",[12,1483,1484],{},"Prettier 最主要是幫助我們統一程式碼風格，而 ESLint 則是幫助我們統一程式碼的品質，因此兩者在做的事情是不同的，但有趣的是 ESLint 本身也具有格式化程式碼的規則，但也因為 ESLint 本身具有格式化程式碼的規則，而導致出現 Prettier 跟 ESLint 的風格衝突問題。",[12,1486,1487],{},"先前我就有針對這件事情寫一篇文章",[1239,1489,1490],{},[1242,1491,1492],{},[891,1493,1496],{"href":1494,"rel":1495},"https:\u002F\u002Fisraynotarray.com\u002Fvscode\u002F20210709\u002F4359299\u002F",[895],"VSCode 自動修正 ESLint 錯誤",[12,1498,1499],{},"也就是使用 Prettier ESLint 套件去解決衝突的問題，但因為後來 ESLint 官方公告一件事情",[12,1501,1502],{},[891,1503,1506],{"href":1504,"rel":1505},"https:\u002F\u002Feslint.org\u002Fblog\u002F2023\u002F10\u002Fdeprecating-formatting-rules\u002F",[895],"Deprecation of formatting rules",[12,1508,1509],{},"簡單來講就是 ESLint 要移除格式化程式碼的規則，所以我們就不需要再使用 Prettier ESLint 套件，如果需要統一撰寫風格的話就是使用 Prettier，如果需要統一程式碼品質的話就是使用 ESLint。",[12,1511,1512],{},"那麼相信滿多人應該會對於「如果需要統一撰寫風格的話就是使用 Prettier，如果需要統一程式碼品質的話就是使用 ESLint」感到疑惑，所以這邊我就額外說明一下吧！",[12,1514,1515],{},"Prettier 主要是幫助我們統一撰寫程式碼的風格，例如...",[1239,1517,1518,1521,1524,1527,1530,1533,1536,1539],{},[1242,1519,1520],{},"程式碼縮排（要用空格還是 tab）",[1242,1522,1523],{},"程式碼要不要換行（超過多少字元就換行）",[1242,1525,1526],{},"縮排要幾個空格還是使用定位點（tab）",[1242,1528,1529],{},"單引號還是雙引號（字串要用單引號還是雙引號）",[1242,1531,1532],{},"逗號（物件或陣列最後一個元素後面要不要加上逗號）",[1242,1534,1535],{},"分號（語句結尾要不要加上分號）",[1242,1537,1538],{},"箭頭函式（箭頭函式只有一個參數時，要不要加上括號）",[1242,1540,1541],{},"換行符號（換行符號要用 lf 還是 crlf）\n...等等",[12,1543,1544],{},"那 ESLint 呢？",[1239,1546,1547,1550,1555,1558,1567,1570],{},[1242,1548,1549],{},"變數、函式宣告後有沒有使用",[1242,1551,1552,1553],{},"變數宣告後有沒有重新賦值，沒有的話就改成 ",[47,1554,290],{},[1242,1556,1557],{},"使用過時的 API",[1242,1559,1560,1561,1564,1565],{},"不要使用 ",[47,1562,1563],{},"=="," 建議使用嚴格比較 ",[47,1566,509],{},[1242,1568,1569],{},"命名風格，例如變數名稱要用駝峰式還是底線式",[1242,1571,1572],{},"避免全域變數\n...等等",[12,1574,1575],{},"透過兩者的比較我想你應該會比較清楚兩者的差異了吧～",[12,1577,1578],{},"最後底下我也提供這個專案的範例檔案給你試試看唷～",[1239,1580,1581],{},[1242,1582,1583],{},[891,1584,1587],{"href":1585,"rel":1586},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fprettier-example",[895],"Prettier Example",[600,1589,1590],{"title":602,"type":603},[12,1591,1592],{},"index.bak.js 是未修正的程式碼，index.js 是修正後的程式碼。",[1594,1595,1596],"style",{},"html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .scAaK, html code.shiki .scAaK{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#DBB7FF}html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syBk-, html code.shiki .syBk-{--shiki-light:#E36209;--shiki-default:#E36209;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style)