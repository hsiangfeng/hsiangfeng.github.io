64},[50,1189,114],{"class":60},[50,1191,117],{"class":64},[50,1193,120],{"class":60},[50,1195,117],{"class":64},[50,1197,319],{"class":81},[50,1199,190],{"class":64},[50,1201,1203,1205,1207,1209,1211],{"class":52,"line":1202},37,[50,1204,111],{"class":64},[50,1206,114],{"class":60},[50,1208,117],{"class":64},[50,1210,570],{"class":60},[50,1212,1213],{"class":64},"(data));\n",[20,1215,1216],{"id":1216},"忽略檔案",[12,1218,1219],{},"我們專案內可能有些檔案是不想要被 Prettier 修正的，例如...build 出來的檔案，這時候我們就可以在根目錄下新增一個 .prettierignore 檔案，並且在內容中加入以下內容",[40,1221,1225],{"className":1222,"code":1223,"language":1224,"meta":45,"style":45},"language-txt shiki shiki-themes github-dark-high-contrast","build\n","txt",[47,1226,1227],{"__ignoreMap":45},[50,1228,1229],{"class":52,"line":53},[50,1230,1223],{},[12,1232,1233],{},"這樣子就可以避免 Prettier 修正 build 出來的檔案囉！",[20,1235,1237],{"id":1236},"prettier-vscode-設定","Prettier VSCode 設定",[12,1239,1240],{},"VSCode 身為我們最常使用的開發工具，當然也要讓他支援 Prettier，這樣我們就可以在開發的時候，直接透過快捷鍵就可以修正程式碼，所以請你打開 VSCode，並且安裝以下套件：",[1242,1243,1244],"ul",{},[1245,1246,1247],"li",{},[894,1248,1251],{"href":1249,"rel":1250},"https:\u002F\u002Fmarketplace.visualstudio.com\u002Fitems?itemName=esbenp.prettier-vscode",[898],"Prettier - Code formatter",[12,1253,1254],{},"接著打開你就可以使用快捷鍵 Option + Shift + F（Mac）或者 Alt + Shift + F（Windows）來修正程式碼囉！",[12,1256,1257],{},"如果無效的話，有兩種可能性：",[1259,1260,1261],"h3",{"id":1261},"沒有預設格式化方式",[12,1263,1264],{},"你可以到 VSCode 中搜尋「Editor: Default Formatter」並設定成「Prettier - Code formatter(esbenp.prettier-vscode)」，這樣就可以點右鍵或者使用快捷鍵修正程式碼。",[1259,1266,1267],{"id":1267},"針對語言覆寫的編輯器設定",[12,1269,1270],{},"另一種可能性是你曾經設定過以下",[40,1272,1274],{"className":643,"code":1273,"language":645,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"vscode.typescript-language-features\"\n  },\n  \u002F\u002F ... 其他設定\n}\n",[47,1275,1276,1280,1285,1292,1302,1306,1310],{"__ignoreMap":45},[50,1277,1278],{"class":52,"line":53},[50,1279,377],{"class":64},[50,1281,1282],{"class":52,"line":75},[50,1283,1284],{"class":748},"  \u002F\u002F ... 其他設定\n",[50,1286,1287,1290],{"class":52,"line":95},[50,1288,1289],{"class":671},"  \"[javascript]\"",[50,1291,675],{"class":64},[50,1293,1294,1297,1299],{"class":52,"line":101},[50,1295,1296],{"class":671},"    \"editor.defaultFormatter\"",[50,1298,683],{"class":64},[50,1300,1301],{"class":81},"\"vscode.typescript-language-features\"\n",[50,1303,1304],{"class":52,"line":108},[50,1305,1003],{"class":64},[50,1307,1308],{"class":52,"line":301},[50,1309,1284],{"class":748},[50,1311,1312],{"class":52,"line":313},[50,1313,98],{"class":64},[12,1315,1316],{},"這個設定是針對 JavaScript 語言覆寫的編輯器設定，所以你可以將他改成以下",[40,1318,1320],{"className":643,"code":1319,"language":645,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \u002F\u002F ... 其他設定\n}\n",[47,1321,1322,1326,1330,1336,1345,1349,1353],{"__ignoreMap":45},[50,1323,1324],{"class":52,"line":53},[50,1325,377],{"class":64},[50,1327,1328],{"class":52,"line":75},[50,1329,1284],{"class":748},[50,1331,1332,1334],{"class":52,"line":95},[50,1333,1289],{"class":671},[50,1335,675],{"class":64},[50,1337,1338,1340,1342],{"class":52,"line":101},[50,1339,1296],{"class":671},[50,1341,683],{"class":64},[50,1343,1344],{"class":81},"\"esbenp.prettier-vscode\"\n",[50,1346,1347],{"class":52,"line":108},[50,1348,1003],{"class":64},[50,1350,1351],{"class":52,"line":301},[50,1352,1284],{"class":748},[50,1354,1355],{"class":52,"line":313},[50,1356,98],{"class":64},[12,1358,1359],{},"這樣子你在使用快捷鍵修正程式碼就會生效囉！",[12,1361,1362],{},"如果兩者都設定之後，基本上你的 VSCode 設定會變成以下",[40,1364,1366],{"className":643,"code":1365,"language":645,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\"\n  },\n  \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n  \u002F\u002F ... 其他設定\n}\n",[47,1367,1368,1372,1376,1382,1390,1394,1406,1410],{"__ignoreMap":45},[50,1369,1370],{"class":52,"line":53},[50,1371,377],{"class":64},[50,1373,1374],{"class":52,"line":75},[50,1375,1284],{"class":748},[50,1377,1378,1380],{"class":52,"line":95},[50,1379,1289],{"class":671},[50,1381,675],{"class":64},[50,1383,1384,1386,1388],{"class":52,"line":101},[50,1385,1296],{"class":671},[50,1387,683],{"class":64},[50,1389,1344],{"class":81},[50,1391,1392],{"class":52,"line":108},[50,1393,1003],{"class":64},[50,1395,1396,1399,1401,1404],{"class":52,"line":301},[50,1397,1398],{"class":671},"  \"editor.defaultFormatter\"",[50,1400,683],{"class":64},[50,1402,1403],{"class":81},"\"esbenp.prettier-vscode\"",[50,1405,310],{"class":64},[50,1407,1408],{"class":52,"line":313},[50,1409,1284],{"class":748},[50,1411,1412],{"class":52,"line":324},[50,1413,98],{"class":64},[1259,1415,1416],{"id":1416},"儲存時自動修正程式碼",[12,1418,1419,1420,1423],{},"每次都要按快捷鍵才格式化程式碼其實很麻煩，所以這邊我們可以在 VSCode 設定中加入另一個設定，也就是 ",[47,1421,1422],{},"formatOnSave","，加入方式也很簡單，只需要針對特定語言加入即可",[40,1425,1427],{"className":643,"code":1426,"language":645,"meta":45,"style":45},"{\n  \u002F\u002F ... 其他設定\n  \"[javascript]\": {\n    \"editor.defaultFormatter\": \"esbenp.prettier-vscode\",\n    \"editor.formatOnSave\": true\n  },\n  \u002F\u002F ... 其他設定\n}\n",[47,1428,1429,1433,1437,1443,1453,1463,1467,1471],{"__ignoreMap":45},[50,1430,1431],{"class":52,"line":53},[50,1432,377],{"class":64},[50,1434,1435],{"class":52,"line":75},[50,1436,1284],{"class":748},[50,1438,1439,1441],{"class":52,"line":95},[50,1440,1289],{"class":671},[50,1442,675],{"class":64},[50,1444,1445,1447,1449,1451],{"class":52,"line":101},[50,1446,1296],{"class":671},[50,1448,683],{"class":64},[50,1450,1403],{"class":81},[50,1452,310],{"class":64},[50,1454,1455,1458,1460],{"class":52,"line":108},[50,1456,1457],{"class":671},"    \"editor.formatOnSave\"",[50,1459,683],{"class":64},[50,1461,1462],{"class":220},"true\n",[50,1464,1465],{"class":52,"line":301},[50,1466,1003],{"class":64},[50,1468,1469],{"class":52,"line":313},[50,1470,1284],{"class":748},[50,1472,1473],{"class":52,"line":324},[50,1474,98],{"class":64},[12,1476,1477],{},"這樣當你按下 Command + S（Mac）或者 Ctrl + S（Windows）時，就會自動幫你修正程式碼囉！",[20,1479,1481],{"id":1480},"prettier-與-eslint-有什麼差異","Prettier 與 ESLint 有什麼差異？",[12,1483,1484],{},"這兩者可以說是最容易被混淆的東西，因為他們都是用來幫助我們統一程式碼風格的工具，但是他們的差異在哪裡呢？",[12,1486,1487],{},"Prettier 最主要是幫助我們統一程式碼風格，而 ESLint 則是幫助我們統一程式碼的品質，因此兩者在做的事情是不同的，但有趣的是 ESLint 本身也具有格式化程式碼的規則，但也因為 ESLint 本身具有格式化程式碼的規則，而導致出現 Prettier 跟 ESLint 的風格衝突問題。",[12,1489,1490],{},"先前我就有針對這件事情寫一篇文章",[1242,1492,1493],{},[1245,1494,1495],{},[894,1496,1499],{"href":1497,"rel":1498},"https:\u002F\u002Fisraynotarray.com\u002Fvscode\u002F20210709\u002F4359299\u002F",[898],"VSCode 自動修正 ESLint 錯誤",[12,1501,1502],{},"也就是使用 Prettier ESLint 套件去解決衝突的問題，但因為後來 ESLint 官方公告一件事情",[12,1504,1505],{},[894,1506,1509],{"href":1507,"rel":1508},"https:\u002F\u002Feslint.org\u002Fblog\u002F2023\u002F10\u002Fdeprecating-formatting-rules\u002F",[898],"Deprecation of formatting rules",[12,1511,1512],{},"簡單來講就是 ESLint 要移除格式化程式碼的規則，所以我們就不需要再使用 Prettier ESLint 套件，如果需要統一撰寫風格的話就是使用 Prettier，如果需要統一程式碼品質的話就是使用 ESLint。",[12,1514,1515],{},"那麼相信滿多人應該會對於「如果需要統一撰寫風格的話就是使用 Prettier，如果需要統一程式碼品質的話就是使用 ESLint」感到疑惑，所以這邊我就額外說明一下吧！",[12,1517,1518],{},"Prettier 主要是幫助我們統一撰寫程式碼的風格，例如...",[1242,1520,1521,1524,1527,1530,1533,1536,1539,1542],{},[1245,1522,1523],{},"程式碼縮排（要用空格還是 tab）",[1245,1525,1526],{},"程式碼要不要換行（超過多少字元就換行）",[1245,1528,1529],{},"縮排要幾個空格還是使用定位點（tab）",[1245,1531,1532],{},"單引號還是雙引號（字串要用單引號還是雙引號）",[1245,1534,1535],{},"逗號（物件或陣列最後一個元素後面要不要加上逗號）",[1245,1537,1538],{},"分號（語句結尾要不要加上分號）",[1245,1540,1541],{},"箭頭函式（箭頭函式只有一個參數時，要不要加上括號）",[1245,1543,1544],{},"換行符號（換行符號要用 lf 還是 crlf）\n...等等",[12,1546,1547],{},"那 ESLint 呢？",[1242,1549,1550,1553,1558,1561,1570,1573],{},[1245,1551,1552],{},"變數、函式宣告後有沒有使用",[1245,1554,1555,1556],{},"變數宣告後有沒有重新賦值，沒有的話就改成 ",[47,1557,289],{},[1245,1559,1560],{},"使用過時的 API",[1245,1562,1563,1564,1567,1568],{},"不要使用 ",[47,1565,1566],{},"=="," 建議使用嚴格比較 ",[47,1569,508],{},[1245,1571,1572],{},"命名風格，例如變數名稱要用駝峰式還是底線式",[1245,1574,1575],{},"避免全域變數\n...等等",[12,1577,1578],{},"透過兩者的比較我想你應該會比較清楚兩者的差異了吧～",[12,1580,1581],{},"最後底下我也提供這個專案的範例檔案給你試試看唷～",[1242,1583,1584],{},[1245,1585,1586],{},[894,1587,1590],{"href":1588,"rel":1589},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fprettier-example",[898],"Prettier Example",[599,1592,1593],{},[12,1594,1595,1597],{},[604,1596,606],{},"\nindex.bak.js 是未修正的程式碼，index.js 是修正後的程式碼。",[1599,1600,1601],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":45,"searchDepth":75,"depth":75,"links":1603},[1604,1605,1606,1607,1608,1609,1614],{"id":22,"depth":75,"text":22},{"id":28,"depth":75,"text":29},{"id":196,"depth":75,"text":197},{"id":713,"depth":75,"text":714},{"id":1216,"depth":75,"text":1216},{"id":1236,"depth":75,"text":1237,"children":1610},[1611,1612,1613],{"id":1261,"depth":95,"text":1261},{"id":1267,"depth":95,"text":1267},{"id":1416,"depth":95,"text":1416},{"id":1480,"