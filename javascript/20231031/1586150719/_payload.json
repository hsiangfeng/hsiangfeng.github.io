,[50,546,111],{"class":64},[50,548,114],{"class":60},[50,550,117],{"class":64},[50,552,120],{"class":60},[50,554,117],{"class":64},[50,556,557],{"class":81},"\"Ray\"",[50,559,128],{"class":64},[50,561,563,565,567,569,572],{"class":52,"line":562},34,[50,564,111],{"class":64},[50,566,114],{"class":60},[50,568,117],{"class":64},[50,570,571],{"class":60},"getRedColor",[50,573,574],{"class":64},"(data))\n",[12,576,577],{},"接下來呢？接下來我們要安裝 Prettier 了，我們可以在官方文件中找到以下指令",[40,579,581],{"className":203,"code":580,"language":205,"meta":45,"style":45},"npm install --save-dev --save-exact prettier\n",[47,582,583],{"__ignoreMap":45},[50,584,585,587,590,593,596],{"class":52,"line":53},[50,586,229],{"class":212},[50,588,589],{"class":81}," install",[50,591,592],{"class":221}," --save-dev",[50,594,595],{"class":221}," --save-exact",[50,597,598],{"class":81}," prettier\n",[600,601,604],"callout",{"title":602,"type":603},"Note","note",[12,605,606,609,610,613,614,617],{},[47,607,608],{},"--save-exact"," 是在告知 npm 安裝該套件時，不要有版本號的變動（意指 ",[47,611,612],{},"^"," 或 ",[47,615,616],{},"~","），這樣才能確保每次安裝的版本都是一樣的，而不會因為版本號的變動而導致程式碼的不一致。",[12,619,620],{},"安裝完畢後，接著輸入以下指令建立一個 .prettierrc 檔案",[40,622,624],{"className":203,"code":623,"language":205,"meta":45,"style":45},"node --eval \"fs.writeFileSync('.prettierrc','{}\\n')\"\n",[47,625,626],{"__ignoreMap":45},[50,627,628,631,634],{"class":52,"line":53},[50,629,630],{"class":212},"node",[50,632,633],{"class":221}," --eval",[50,635,636],{"class":81}," \"fs.writeFileSync('.prettierrc','{}\\n')\"\n",[12,638,639],{},"或者你也可以直接在專案根目錄建立一個 .prettierrc 檔案，內容如下",[40,641,645],{"className":642,"code":643,"language":644,"meta":45,"style":45},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{}\n","json",[47,646,647],{"__ignoreMap":45},[50,648,649],{"class":52,"line":53},[50,650,643],{"class":64},[12,652,653],{},"（內容不用擔心，後續會介紹）",[12,655,656],{},"我們可以在 package.json 中新增一個 script 讓我們可以直接使用 Prettier 自動修正程式碼",[40,658,660],{"className":642,"code":659,"language":644,"meta":45,"style":45},"{\n  \"scripts\": {\n    \"prettier\": \"prettier --write .\"\n  }\n}\n",[47,661,662,666,675,686,691],{"__ignoreMap":45},[50,663,664],{"class":52,"line":53},[50,665,378],{"class":64},[50,667,668,672],{"class":52,"line":75},[50,669,671],{"class":670},"sWTrB","  \"scripts\"",[50,673,674],{"class":64},": {\n",[50,676,677,680,683],{"class":52,"line":95},[50,678,679],{"class":670},"    \"prettier\"",[50,681,682],{"class":64},": ",[50,684,685],{"class":81},"\"prettier --write .\"\n",[50,687,688],{"class":52,"line":101},[50,689,690],{"class":64},"  }\n",[50,692,693],{"class":52,"line":108},[50,694,98],{"class":64},[12,696,697,698,701],{},"接下來你只需要執行 ",[47,699,700],{},"npm run prettier"," 就可以看到程式碼被修正了！",[12,703,704],{},[15,705],{"alt":700,"src":706},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fjavascript\u002Fprettier-setting\u002FOct-31-2023%2014-11-21(1).gif",[12,708,709],{},"很方便吧？透過 Prettier 我們可以很快速的幫助我們修正程式碼。",[20,711,713],{"id":712},"prettier-設定","Prettier 設定",[12,715,716],{},"但是我們實際專案開發上，專案還是會有自己團隊的撰寫風格，那這時候該怎麼辦呢？",[12,718,719],{},"不用擔心，我們在前面不是有建立一個 .prettierrc 檔案嗎？我們就可以透過這個檔案來設定 Prettier 的風格。",[12,721,722],{},"那麼常見的設定有哪些呢？這邊我列出一些比較常見的設定調整：",[40,724,726],{"className":642,"code":725,"language":644,"meta":45,"style":45},"{\n  \"printWidth\": 80, \u002F\u002F 超過 80 個字元就換行\n  \"tabWidth\": 2, \u002F\u002F 程式碼縮排 2 個空格\n  \"useTabs\": false, \u002F\u002F 不使用 tab，預設使用空格\n  \"semi\": true, \u002F\u002F 語句結尾加上分號\n  \"singleQuote\": true, \u002F\u002F 使用單引號，預設使用雙引號\n  \"quoteProps\": \"as-needed\", \u002F\u002F 預設 'as-needed'，只有在屬性名稱包含特殊字元或空格時才會使用雙引號。否則，它將使用單引號。\n  \"trailingComma\": \"es5\", \u002F\u002F 在物件或陣列最後一個元素後面加上逗號\n  \"bracketSpacing\": true, \u002F\u002F 在物件的左右括號間加上空格\n  \"arrowParens\": \"always\", \u002F\u002F 箭頭函式只有一個參數時，也需要括號\n  \"endOfLine\": \"lf\", \u002F\u002F 換行符號，預設 lf\n}\n",[47,727,728,732,749,763,778,793,807,822,837,851,866,881],{"__ignoreMap":45},[50,729,730],{"class":52,"line":53},[50,731,37