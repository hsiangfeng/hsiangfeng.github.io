[{"data":1,"prerenderedAt":449},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190923\u002F3411832267\u002F":3,"page:\u002Fjavascript\u002F20190923\u002F3411832267\u002F":4,"alt:\u002Fjavascript\u002F20190923\u002F3411832267\u002F":3,"prev-next:\u002Fjavascript\u002F20190923\u002F3411832267\u002F":424,"related:\u002Fjavascript\u002F20190923\u002F3411832267\u002F":433},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F23\u002Fjs-from-zero-ep08-anonymous-functions\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":407,"date":408,"description":18,"extension":409,"lang":410,"meta":411,"navigation":412,"path":413,"readingMinutes":414,"seo":415,"standalone":416,"stem":417,"tags":418,"tldr":421,"updated":421,"url":422,"__hash__":423},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-8-RE：從零開始的學習-JS-生活-第八日.md","EP.8 RE：從零開始的學習 JS 生活-第八日之匿名函式","3411832267",{"type":9,"value":10,"toc":401},"minimark",[11,15,19,22,30,37,40,46,49,97,100,103,109,115,118,123,126,131,134,140,151,255,260,266,364,370,373,376,382,385,391,394,397],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第八日，前一篇介紹函式，所以這一篇將會介紹匿名函式。",[12,20,21],{"id":21},"匿名函式",[16,23,24,25,29],{},"匿名函式簡單來講就是",[26,27,28],"strong",{},"沒有名稱的函式","，在前一篇我們了解具名函式的定義規則是這個樣子 ↓",[16,31,32],{},[33,34],"img",{"alt":35,"src":36},"函式定義","https:\u002F\u002Fi.imgur.com\u002FlMyVzVQ.png",[16,38,39],{},"那匿名函式就顯得非常容易理解，只要沒有函式名稱的就是俗稱的匿名函式，通常比較常見的匿名函式會是使用變數儲存，那這個函式就不會有所謂的提升效果(後面章節會在介紹)，所以匿名函式常見的定義規則如下 ↓",[16,41,42],{},[33,43],{"alt":44,"src":45},"匿名函式定義","https:\u002F\u002Fi.imgur.com\u002FvThP7Zb.png",[16,47,48],{},"當然如果你想要用這種方式並使用具名函式定義也是可以的：",[50,51,56],"pre",{"className":52,"code":53,"language":54,"meta":55,"style":55},"language-js shiki shiki-themes github-dark-high-contrast","var myname = function fu() {\n  ...\n}\n","js","",[57,58,59,85,91],"code",{"__ignoreMap":55},[60,61,64,68,72,75,78,81],"span",{"class":62,"line":63},"line",1,[60,65,67],{"class":66},"sWyjQ","var",[60,69,71],{"class":70},"sj_SG"," myname",[60,73,74],{"class":66}," =",[60,76,77],{"class":66}," function",[60,79,80],{"class":70}," fu",[60,82,84],{"class":83},"sMAXC","() {\n",[60,86,88],{"class":62,"line":87},2,[60,89,90],{"class":66},"  ...\n",[60,92,94],{"class":62,"line":93},3,[60,95,96],{"class":83},"}\n",[16,98,99],{},"但是這麼做其實完全沒有意義，因為你只是讓自己多打一點字而已。",[12,101,102],{"id":102},"立即執行函式",[16,104,105,106,108],{},"那麼另一種匿名函式則稱為 IIFE，也就是所謂的",[26,107,102],{},"，這也是屬於匿名函式的一種，通常定義的方式規則是這樣 ↓",[16,110,111],{},[33,112],{"alt":113,"src":114},"立即執行函式定義","https:\u002F\u002Fi.imgur.com\u002FEPC4kuw.png",[16,116,117],{},"立即執行函式簡單來講就是程式碼一執行時，就會立刻執行該函式，而不用透過我們呼叫來執行函式，那在 IIFE 後面的立即執行括號可以放的位子並沒有一定，第一種可以這樣放 ↓",[16,119,120],{},[33,121],{"alt":113,"src":122},"https:\u002F\u002Fi.imgur.com\u002FRHQ2RVl.png",[16,124,125],{},"第二種則是放在括號內 ↓",[16,127,128],{},[33,129],{"alt":113,"src":130},"https:\u002F\u002Fi.imgur.com\u002FMkIvdxb.png",[16,132,133],{},"這兩種方式都可以使用，最主要是依照自己習慣為主，但是如果要替立即執行函式傳入值，就會像這種形式傳入 ↓",[16,135,136],{},[33,137],{"alt":138,"src":139},"傳入參數","https:\u002F\u002Fi.imgur.com\u002FgZtwDie.png",[16,141,142,143,146,147,150],{},"另外使用 IIFE 還有一個好處，也就是不會汙染到全域環境，在這裏面定義的函式都是獨一無二的，這邊舉例一個經典範例，當我們使用迴圈跑 10 次，",[57,144,145],{},"i"," 最後將會得到 ",[57,148,149],{},"10","：",[50,152,154],{"className":52,"code":153,"language":54,"meta":55,"style":55},"for(var i = 0; i \u003C 10; i++) {\n  console.log(i);\n  setTimeout(function(){\n    console.log('目前 i:' + i);\n  },2000);\n}\n",[57,155,156,194,205,218,238,250],{"__ignoreMap":55},[60,157,158,161,164,166,169,172,176,179,182,185,188,191],{"class":62,"line":63},[60,159,160],{"class":66},"for",[60,162,163],{"class":83},"(",[60,165,67],{"class":66},[60,167,168],{"class":83}," i ",[60,170,171],{"class":66},"=",[60,173,175],{"class":174},"sCcAr"," 0",[60,177,178],{"class":83},"; i ",[60,180,181],{"class":66},"\u003C",[60,183,184],{"class":174}," 10",[60,186,187],{"class":83},"; i",[60,189,190],{"class":66},"++",[60,192,193],{"class":83},") {\n",[60,195,196,199,202],{"class":62,"line":87},[60,197,198],{"class":83},"  console.",[60,200,201],{"class":70},"log",[60,203,204],{"class":83},"(i);\n",[60,206,207,210,212,215],{"class":62,"line":93},[60,208,209],{"class":70},"  setTimeout",[60,211,163],{"class":83},[60,213,214],{"class":66},"function",[60,216,217],{"class":83},"(){\n",[60,219,221,224,226,228,232,235],{"class":62,"line":220},4,[60,222,223],{"class":83},"    console.",[60,225,201],{"class":70},[60,227,163],{"class":83},[60,229,231],{"class":230},"sTRMh","'目前 i:'",[60,233,234],{"class":66}," +",[60,236,237],{"class":83}," i);\n",[60,239,241,244,247],{"class":62,"line":240},5,[60,242,243],{"class":83},"  },",[60,245,246],{"class":174},"2000",[60,248,249],{"class":83},");\n",[60,251,253],{"class":62,"line":252},6,[60,254,96],{"class":83},[16,256,257],{},[33,258],{"alt":145,"src":259},"https:\u002F\u002Fi.imgur.com\u002FmRlXI5A.png",[16,261,262,263,265],{},"但是如果我們希望 ",[57,264,145],{}," 最後不要變成 10 呢?而是 0...9 呢?那就可以使用 IIFE 來製作：",[50,267,269],{"className":52,"code":268,"language":54,"meta":55,"style":55},"for(var i = 0; i \u003C 10; i++) {\n  console.log(i);\n  (function(i){\n     setTimeout(function(){\n    console.log('目前 i:' + i);\n  },2000);\n  })(i);\n}\n",[57,270,271,297,305,320,331,345,353,359],{"__ignoreMap":55},[60,272,273,275,277,279,281,283,285,287,289,291,293,295],{"class":62,"line":63},[60,274,160],{"class":66},[60,276,163],{"class":83},[60,278,67],{"class":66},[60,280,168],{"class":83},[60,282,171],{"class":66},[60,284,175],{"class":174},[60,286,178],{"class":83},[60,288,181],{"class":66},[60,290,184],{"class":174},[60,292,187],{"class":83},[60,294,190],{"class":66},[60,296,193],{"class":83},[60,298,299,301,303],{"class":62,"line":87},[60,300,198],{"class":83},[60,302,201],{"class":70},[60,304,204],{"class":83},[60,306,307,310,312,314,317],{"class":62,"line":93},[60,308,309],{"class":83},"  (",[60,311,214],{"class":66},[60,313,163],{"class":83},[60,315,145],{"class":316},"s_sBn",[60,318,319],{"class":83},"){\n",[60,321,322,325,327,329],{"class":62,"line":220},[