[{"data":1,"prerenderedAt":819},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200607\u002F196651152\u002F":3,"page:\u002Fjavascript\u002F20200607\u002F196651152\u002F":4,"alt:\u002Fjavascript\u002F20200607\u002F196651152\u002F":3,"prev-next:\u002Fjavascript\u002F20200607\u002F196651152\u002F":795,"related:\u002Fjavascript\u002F20200607\u002F196651152\u002F":804},"\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F07\u002Fjavascript-core-11-statements-and-expressions\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":780,"date":781,"description":18,"extension":782,"lang":783,"meta":784,"navigation":224,"path":785,"readingMinutes":786,"seo":787,"standalone":788,"stem":789,"tags":790,"tldr":792,"updated":792,"url":793,"__hash__":794},"content\u002FJavaScript 核心觀念\u002F2.運算子、型別與文法\u002FJavaScript-核心觀念-11-運算子、型別與文法-陳述式與表達式.md","JavaScript 核心觀念(11)-運算子、型別與文法-陳述式與表達式","196651152",{"type":9,"value":10,"toc":769},"minimark",[11,15,19,22,28,39,42,70,73,77,92,100,115,119,130,136,145,151,162,167,184,271,276,281,284,341,346,357,398,404,407,429,435,438,441,463,469,472,475,492,506,511,515,522,550,557,584,587,617,620,651,656,659,662,671,677,683,730,743,753,756,765],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"陳述式 vs 表達式是最容易搞不清楚的觀念，包含我自己也是。",[12,20,21],{"id":21},"陳述式與表達式",[16,23,24],{},[25,26],"img",{"alt":21,"src":27},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2014.42.15.png",[16,29,30,31,38],{},"基本上你可以透過 MDN 文件了解 JavaScript 的",[32,33,37],"a",{"href":34,"rel":35},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FStatements",[36],"nofollow","陳述式","與表達式有那些，例如",[16,40,41],{},"陳述式有",[43,44,45,59,64],"ul",{},[46,47,48,52,53,52,56],"li",{},[49,50,51],"code",{},"var","、",[49,54,55],{},"let",[49,57,58],{},"const",[46,60,61],{},[49,62,63],{},"if...else",[46,65,66,69],{},[49,67,68],{},"for","\n...\n等等",[16,71,72],{},"而表達式則是因為太多無法列出，基本上表達式經常會與運算子搭配並回傳結果。",[12,74,76],{"id":75},"陳述式-statement","陳述式 (Statement)",[16,78,79,80,83,84,87,88,91],{},"基本上陳述式是不會回傳結果的，在這邊你應該會覺得很奇怪，剛才不是說表達式通常會搭配運算子並回傳結果嗎？那麼變數宣告的 ",[49,81,82],{},"var a = 1;"," 有回傳一個 ",[49,85,86],{},"undefined"," 為什麼不算是一個表達式呢？而且他也有 ",[49,89,90],{},"="," 運算子，這樣子不算是表達式嗎？",[16,93,94,95,99],{},"相信很多人對於「變數宣告」為什麼是一個陳述式感到疑惑，陳述式最簡單的觀念來自「它只會靜靜躺在那邊等你呼叫，最大特徵在於不會回傳任何的結果，但是",[96,97,98],"strong",{},"陳述式必定會先執行過一次","」，其主要原因在於它要先確定語法作用域。",[16,101,102,103,105,106,108,109,111,112,114],{},"因此若在 Chrome 上的 console 輸入 ",[49,104,82],{}," 卻會回傳 ",[49,107,86],{}," 的原因在於變數宣告時，JavaScript 會先執行過一次，因為它要替這個變數準備一個記憶體空間，並將記憶體空間與變數名稱對應，但並不會回傳結果，因此變數宣告才會回傳給你一個 ",[49,110,86],{},"，而在這邊的 ",[49,113,86],{}," 只是告訴你我已經替這個變數宣告準備好了記憶體空間而已。",[12,116,118],{"id":117},"表達式-expression","表達式 (Expression)",[16,120,121,122,125,126,129],{},"表達式又稱之為運算式，也可以稱為表示式，最間單的觀念理解在於它會回傳一個值，例如當你輸入 ",[49,123,124],{},"1+1"," 它會在底下回傳一個 ",[49,127,128],{},"2","，而這就是表達式",[16,131,132],{},[25,133],{"alt":134,"src":135},"表達式","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.12.57.png",[16,137,138,139,144],{},"在 MDN 中有說明",[32,140,143],{"href":141,"rel":142},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FJavaScript\u002FGuide\u002FExpressions_and_Operators",[36],"運算式","的幾個特徵",[146,147,148],"blockquote",{},[16,149,150],{},"算數: 解析出數字， 例如 3.14159. (通常使用 算術運算子.)\n字串: 解析出字串， 例如 \"Fred\" or \"234\"。 (通常使用 字串運算子.)\n邏輯: 解析出 True 或 False (通常與 邏輯運算子 相關。)\n主流運算式: JavaScript 基本的關鍵字及運算式。\n左側運算式: 左側是指定值的對象。",[16,152,153,154,157,158,161],{},"因此通常表達式會搭配一些運算子，但表達式最簡單的便是觀念在於「會回傳一個結果 or 一個值」，因此當我們輸入 ",[49,155,156],{},"qq = 'Ray'"," 它會回傳一個 ",[49,159,160],{},"'Ray'"," 這就是表達式。",[16,163,164],{},[25,165],{"alt":134,"src":166},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.18.28.png",[16,168,169,170,173,174,177,178,180,181,183],{},"而表達式的重點觀念在於運算子，因此等號是一個表達式，它會將值賦予到 ",[49,171,172],{},"qq"," 並回傳結果，因此我們這邊可以回顧一下變數宣告中的 ",[49,175,176],{},"var a = '11';"," 為什麼會回傳 ",[49,179,86],{},"，前面有說過變數宣告會回傳 ",[49,182,86],{}," 的原因在於它準備好一個空間給記憶體給變數使用，接下來讓我們看一下其他陳述式通常會發生什麼事情",[185,186,191],"pre",{"className":187,"code":188,"language":189,"meta":190,"style":190},"language-js shiki shiki-themes github-dark-high-contrast","if(true) {\n}\n\nfunction fu() {}\n\nfor(var i; i\u003C 10;i++) {}\n","js","",[49,192,193,213,219,226,239,244],{"__ignoreMap":190},[194,195,198,202,206,210],"span",{"class":196,"line":197},"line",1,[194,199,201],{"class":200},"sWyjQ","if",[194,203,205],{"class":204},"sMAXC","(",[194,207,209],{"class":208},"sCcAr","true",[194,211,212],{"class":204},") {\n",[194,214,216],{"class":196,"line":215},2,[194,217,218],{"class":204},"}\n",[194,220,222],{"class":196,"line":221},3,[194,223,225],{"emptyLinePlaceholder":224},true,"\n",[194,227,229,232,236],{"class":196,"line":228},4,[194,230,231],{"class":200},"function",[194,233,235],{"class":234},"sj_SG"," fu",[194,237,238],{"class":204},"() {}\n",[194,240,242],{"class":196,"line":241},5,[194,243,225],{"emptyLinePlaceholder":224},[194,245,247,249,251,253,256,259,262,265,268],{"class":196,"line":246},6,[194,248,68],{"class":200},[194,250,205],{"class":204},[194,252,51],{"class":200},[194,254,255],{"class":204}," i; i",[194,257,258],{"class":200},"\u003C",[194,260,261],{"class":208}," 10",[194,263,264],{"class":204},";i",[194,266,267],{"class":200},"++",[194,269,270],{"class":204},") {}\n",[16,272,273,274],{},"你會發現只要是陳述式它就只會回傳 ",[49,275,86],{},[16,277,278],{},[25,279],{"alt":37,"src":280},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.24.39.png",[16,282,283],{},"反之表達式就不同，表達式必定會回傳一個結果一個值",[185,285,287],{"className":187,"code":286,"language":189,"meta":190,"style":190},"aa = 'Ray';\n1+1;\na = true;\nb = function () {}\n",[49,288,289,303,315,327],{"__ignoreMap":190},[194,290,291,294,296,300],{"class":196,"line":197},[194,292,293],{"class":204},"aa ",[194,295,90],{"class":200},[194,297,299],{"class":298},"sTRMh"," 'Ray'",[194,301,302],{"class":204},";\n",[194,304,305,308,311,313],{"class":196,"line":215},[194,306,307],{"class":208},"1",[194,309,310],{"class":200},"+",[194,312,307],{"class":208},[194,314,302],{"class":204},[194,316,317,320,322,325],{"class":196,"line":221},[194,318,319],{"class":204},"a ",[194,321,90],{"class":200},[194,323,324],{"class":208}," true",[194,326,302],{"class":204},[194,328,329,332,335,338],{"class":196,"line":228},[194,330,331],{"class":234},"b",[194,333,334],{"class":200}," =",[194,336,337],{"class":200}," function",[194,339,340],{"class":204}," () {}\n",[16,342,343],{},[25,344],{"alt":134,"src":345},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.28.16.png",[16,347,348,349,352,353,356],{},"題外話一下，我們常在開發使用的 ",[49,350,351],{},"setTimeout"," 以及 ",[49,354,355],{},"setInterval"," 也是屬於表達式",[185,358,360],{"className":187,"code":359,"language":189,"meta":190,"style":190},"setTimeout(function(){}, 10000); \u002F\u002F 1000 = 1 秒\nsetInterval(function(){}, 10000);\n",[49,361,362,383],{"__ignoreMap":190},[194,363,364,366,368,370,373,376,379],{"class":196,"line":197},[194,365,351],{"class":234},[194,367,205],{"class":204},[194,369,231],{"class":200},[194,371,372],{"class":204},"(){}, ",[194,374,375],{"class":208},"10000",[194,377,378],{"class":204},"); ",[194,380,382],{"class":381},"sQrFR","\u002F\u002F 1000 = 1 秒\n",[194,384,385,387,389,391,393,395],{"class":196,"line":215},[194,386,355],{"class":234},[194,388,205],{"class":204},[194,390,231],{"class":200},[194,392,372],{"class":204},[194,394,375],{"class":208},[194,396,397],{"class":204},");\n",[16,399,400],{},[25,401],{"alt":402,"src":403},"setTimeout&setInterval","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.30.42.png",[16,405,406],{},"此外陳述式與表達式還有一個特徵可以辨別，也就是陳述式無法被變數儲存，因為陳述式不會回傳值的關係",[185,408,410],{"className":187,"code":409,"language":189,"meta":190,"style":190},"a = if (true) {};\n",[49,411,412],{"__ignoreMap":190},[194,413,414,416,418,421,424,426],{"class":196,"line":197},[194,415,319],{"class":204},[194,417,90],{"class":200},[194,419,420],{"class":200}," if",[194,422,423],{"class":204}," (",[194,425,209],{"class":208},[194,427,428],{"class":204},") {};\n",[16,430,431],{},[25,432],{"alt":433,"src":434},"陳述式無法被儲存到變數內","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.32.13.png",[12,436,437],{"id":437},"函式陳述式",[16,439,440],{},"接下來講講另一種的陳述式與表達式，函式在宣告時其實也有分為兩種廣義的宣告方式，第一種就是所謂的函式陳述式",[185,442,444],{"className":187,"code":443,"language":189,"meta":190,"style":190},"function fu() {\n\n}\n",[49,445,446,455,459],{"__ignoreMap":190},[194,447,448,450,452],{"class":196,"line":197},[194,449,231],{"class":200},[194,451,235],{"class":234},[194,453,454],{"class":204},"() {\n",[194,456,457],{"class":196,"line":215},[194,458,225],{"emptyLinePlaceholder":224},[194,460,461],{"class":196,"line":221},[194,462,218],{"class":204},[16,464,465,466,468],{},"基本上函式陳述式在宣告時，並不會回傳結果，而是與前面相同，僅會回傳 ",[49,467,86],{},"，此外上面的函式陳述式又稱之為具名函式陳述式。",[12,470,471],{"id":471},"函式表達式",[16,473,474],{},"函式表達式通常會宣告一個變數並搭配等號運算子以及一個函式，而這個就是所謂的函式表達式",[185,476,478],{"className":187,"code":477,"language":189,"meta":190,"style":190},"var fu = function() {}\n",[49,479,480],{"__ignoreMap":190},[194,481,482,484,486,488,490],{"class":196,"line":197},[194,483,51],{"class":200},[194,485,235],{"class":234},[194,487,334],{"class":200},[194,489,337],{"class":200},[194,491,238],{"class":204},[16,493,494,495,497,498,501,502,505],{},"而這個宣告函式的方式又稱之為匿名函式表達式，雖然你在 Chrome 中，輸入他一樣會回傳給你一個 ",[49,496,86],{},"，但實際上因為這個函式沒有 ",[49,499,500],{},"name"," 所以會被回傳儲存在 ",[49,503,504],{},"fu"," 的變數內，而函式表達式最大的特徵在於他不會受到提升的影響，因此若你在函式表達式之前呼叫，它就會出現錯誤訊息",[16,507,508],{},[25,509],{"alt":471,"src":510},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.43.34.png",[12,512,514],{"id":513},"block-與物件實字","block 與物件實字",[16,516,517,518,521],{},"最後額外講一個特別狀況，在 JavaScript 中有一個 block，也就是 ",[49,519,520],{},"{}","， block 在 MDN 中也是屬於陳述式，因此可以這樣寫",[185,523,525],{"className":187,"code":524,"language":189,"meta":190,"style":190},"{\n  var a = 'Ray';\n}\n",[49,526,527,532,546],{"__ignoreMap":190},[194,528,529],{"class":196,"line":197},[194,530,531],{"class":204},"{\n",[194,533,534,537,540,542,544],{"class":196,"line":215},[194,535,536],{"class":200},"  var",[194,538,539],{"class":204}," a ",[194,541,90],{"class":200},[194,543,299],{"class":298},[194,545,302],{"class":204},[194,547,548],{"class":196,"line":221},[194,549,218],{"class":204},[16,551,552,553,556],{},"但是若是改寫成物件實字則是使用「",[49,554,555],{},":","」來區分屬性與值",[185,558,560],{"className":187,"code":559,"language":189,"meta":190,"style":190},"{\n  a: 'Ray',\n}\n",[49,561,562,566,580],{"__ignoreMap":190},[194,563,564],{"class":196,"line":197},[194,565,531],{"class":204},[194,567,568,572,575,577],{"class":196,"line":215},[194,569,571],{"class":570},"s_sBn","  a",[194,573,574],{"class":204},": ",[194,576,160],{"class":298},[194,578,579],{"class":204},",\n",[194,581,582],{"class":196,"line":221},[194,583,218],{"class":204},[16,585,586],{},"而這邊兩者最大差異在於物件實字是一個表達式，因此表達式我們可以儲存進變數內中",[185,588,590],{"className":187,"code":589,"language":189,"meta":190,"style":190},"var a = {\n  a: 'Ray',\n};\n",[49,591,592,603,612],{"__ignoreMap":190},[194,593,594,596,598,600],{"class":196,"line":197},[194,595,51],{"class":200},[194,597,539],{"class":204},[194,599,90],{"class":200},[194,601,602],{"class":204}," {\n",[194,604,605,608,610],{"class":196,"line":215},[194,606,607],{"class":204},"  a: ",[194,609,160],{"class":298},[194,611,579],{"class":204},[194,613,614],{"class":196,"line":221},[194,615,616],{"class":204},"};\n",[16,618,619],{},"但若是 block 則是不行，因為他是一個陳述式",[185,621,623],{"className":187,"code":622,"language":189,"meta":190,"style":190},"var b = {\n  var a = 'Ray';\n}\n",[49,624,625,636,647],{"__ignoreMap":190},[194,626,627,629,632,634],{"class":196,"line":197},[194,628,51],{"class":200},[194,630,631],{"class":204}," b ",[194,633,90],{"class":200},[194,635,602],{"class":204},[194,637,638,641,643,645],{"class":196,"line":215},[194,639,640],{"class":204},"  var a ",[194,642,90],{"class":200},[194,644,299],{"class":298},[194,646,302],{"class":204},[194,648,649],{"class":196,"line":221},[194,650,218],{"class":204},[16,652,653],{},[25,654],{"alt":514,"src":655},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-07%2022.52.13.png",[16,657,658],{},"最後的結論就是只要會回傳結果或是值，那麼就是屬於表達式，若不會那麼就是陳述式。",[12,660,661],{"id":661},"混合式",[16,663,664,665,667,668],{},"這個名稱其實算是我自創的，主要是要說明 ",[49,666,82],{}," 與 ",[49,669,670],{},"var a = function() {}",[16,672,673,674,676],{},"相信看完上面有很多人都會說「",[49,675,82],{}," 應該算是表達式才對，怎麼會歸類為陳述式?它不是有賦值行為嗎？」",[16,678,679,680,682],{},"沒錯，所以你要說他是表達式也是正確的，其主要原因是，大多 JavaScript 都是屬於混合式(表達式 + 陳述式)，這邊舉例來講，我們知道 ",[49,681,201],{}," 判斷式是一個陳述式，但判斷式中主要是接受表達式的，因此可以這樣撰寫",[185,684,686],{"className":187,"code":685,"language":189,"meta":190,"style":190},"var a;\nif(a = true) {\n  console.log('True'); \u002F\u002F True\n}\n",[49,687,688,695,708,726],{"__ignoreMap":190},[194,689,690,692],{"class":196,"line":197},[194,691,51],{"class":200},[194,693,694],{"class":204}," a;\n",[194,696,697,699,702,704,706],{"class":196,"line":215},[194,698,201],{"class":200},[194,700,701],{"class":204},"(a ",[194,703,90],{"class":200},[194,705