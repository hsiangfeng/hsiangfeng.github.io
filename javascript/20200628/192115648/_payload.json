[{"data":1,"prerenderedAt":315},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200628\u002F192115648\u002F":3,"page:\u002Fjavascript\u002F20200628\u002F192115648\u002F":4,"alt:\u002Fjavascript\u002F20200628\u002F192115648\u002F":3,"prev-next:\u002Fjavascript\u002F20200628\u002F192115648\u002F":290,"related:\u002Fjavascript\u002F20200628\u002F192115648\u002F":299},"\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F28\u002Fjavascript-core-15-operators-types-grammar-operators\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":276,"date":277,"description":18,"extension":278,"lang":279,"meta":280,"navigation":93,"path":281,"readingMinutes":77,"seo":282,"standalone":283,"stem":284,"tags":285,"tldr":287,"updated":287,"url":288,"__hash__":289},"content\u002FJavaScript 核心觀念\u002F2.運算子、型別與文法\u002FJavaScript-核心觀念-15-運算子、型別與文法-運算子.md","JavaScript 核心觀念(15)-運算子、型別與文法-運算子","192115648",{"type":9,"value":10,"toc":271},"minimark",[11,15,19,22,28,31,61,64,67,107,110,144,153,160,163,194,197,239,246,249,252,267],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來講講運算子，運算子在各種開發狀況下是非常常使用的。",[12,20,21],{"id":21},"運算子",[16,23,24],{},[25,26],"img",{"alt":21,"src":27},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-28%2013.16.34.png",[16,29,30],{},"運算子其實本身就是 JavaScript 所提供的簡單韓式，舉例來講賦值動作中的等號就是一個等號運算子",[32,33,38],"pre",{"className":34,"code":35,"language":36,"meta":37,"style":37},"language-js shiki shiki-themes github-dark-high-contrast","name = 'Ray';\n","js","",[39,40,41],"code",{"__ignoreMap":37},[42,43,46,50,54,58],"span",{"class":44,"line":45},"line",1,[42,47,49],{"class":48},"sMAXC","name ",[42,51,53],{"class":52},"sWyjQ","=",[42,55,57],{"class":56},"sTRMh"," 'Ray'",[42,59,60],{"class":48},";\n",[16,62,63],{},"左右兩邊的又稱之為「運算元」，基本上依照運算子的數量就會變成一元、二元以及三元運算子等，但決大部分都是一元運算子。",[16,65,66],{},"基本上只要是運算子通通都是屬於表達式，因為必定會回傳一個結果",[32,68,70],{"className":34,"code":69,"language":36,"meta":37,"style":37},"1 + 1 \u002F\u002F 2\n\nname = 'Ray' \u002F\u002F Ray;\n",[39,71,72,88,95],{"__ignoreMap":37},[42,73,74,78,81,84],{"class":44,"line":45},[42,75,77],{"class":76},"sCcAr","1",[42,79,80],{"class":52}," +",[42,82,83],{"class":76}," 1",[42,85,87],{"class":86},"sQrFR"," \u002F\u002F 2\n",[42,89,91],{"class":44,"line":90},2,[42,92,94],{"emptyLinePlaceholder":93},true,"\n",[42,96,98,100,102,104],{"class":44,"line":97},3,[42,99,49],{"class":48},[42,101,53],{"class":52},[42,103,57],{"class":56},[42,105,106],{"class":86}," \u002F\u002F Ray;\n",[16,108,109],{},"依照 MDN 說明中，運算子是非常多的",[111,112,113,117,120,123,126,129,132,135,138,141],"ul",{},[114,115,116],"li",{},"賦值運算子",[114,118,119],{},"比較運算子",[114,121,122],{},"算數運算子",[114,124,125],{},"位元運算子",[114,127,128],{},"邏輯運算子",[114,130,131],{},"字串運算子",[114,133,134],{},"條件(三元)運算子",[114,136,137],{},"逗點運算子",[114,139,140],{},"一元運算子",[114,142,143],{},"關係運算子",[16,145,146],{},[147,148,152],"a",{"href":149,"rel":150},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FJavaScript\u002FGuide\u002FExpressions_and_Operators",[151],"nofollow","MDN 文件",[16,154,155,156,159],{},"而在這邊值得一提的是在前面我們很常使用的 ",[39,157,158],{},"typeof"," 也是屬於運算子，並且是一元運算子，大部分一元運算子都是以單字為開頭。",[16,161,162],{},"最後這邊講一個特別的地方，剛剛前面有講到運算子都是一個簡易的函式，因此假使這樣子寫呢？",[32,164,166],{"className":34,"code":165,"language":36,"meta":37,"style":37},"var a = +(1, 2);\n",[39,167,168],{"__ignoreMap":37},[42,169,170,173,176,178,180,183,185,188,191],{"class":44,"line":45},[42,171,172],{"class":52},"var",[42,174,175],{"class":48}," a ",[42,177,53],{"class":52},[42,179,80],{"class":52},[42,181,182],{"class":48},"(",[42,184,77],{"class":76},[42,186,187],{"class":48},", ",[42,189,190],{"class":76},"2",[42,192,193],{"class":48},");\n",[16,195,196],{},"其實並不會出現錯誤，因為運算子本身就是一個簡易的函式，因此概念就像這樣",[32,198,200],{"className":34,"code":199,"language":36,"meta":37,"style":37},"function +(a, b){\n return a + b;\n}\n",[39,201,202,221,234],{"__ignoreMap":37},[42,203,204,207,210,213,215,218],{"class":44,"line":45},[42,205,206],{"class":52},"function",[42,208,209],{"class":48}," +(",[42,211,147],{"class":212},"s_sBn",[42,214,187],{"class":48},[42,216,217],{"class":212},"b",[42,219,220],{"class":48},"){\n",[42,222,223,226,228,231],{"class":44,"line":90},[42,224,225],{"class":52}," return",[42,227,175],{"class":48},[42,229,230],{"class":52},"+",[42,232,233],{"class":48}," b;\n",[42,235,236],{"class":44,"line":97},[42,237,238],{"class":48},"}\n",[16,240,241,242,245],{},"雖然並不會出現正確的結果，它只會取得值得最後一個，這邊只是說明一個概念而已，而假使若這個方式是可以運作的，那在實際開發上這種寫法也非常麻煩，因此我們就會這樣寫運算子 ",[39,243,244],{},"1 + 1","，將加號運算子放在中間，而這種作法也有另一種名詞說明叫做「中輟表達式」，簡單來講就是將你的函式名稱寫在兩個參數中間。",[16,247,248],{},"因此運算子若放在前面稱之為前輟表達式反之放在後面則是後輟表達式。",[12,250,251],{"id":251},"參考文獻",[111,253,254,261],{},[114,255,256],{},[147,257,260],{"href":258,"rel":259},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[151],"JavaScript 核心篇",[114,262,263],{},[147,264,266],{"href":265},"\u002Fjsweirdworld\u002F20190516\u002F2821553635\u002F","[JS奇怪的世界]No.15 觀念小叮嚀:運算子",[268,269,270],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}",