[{"data":1,"prerenderedAt":687},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20191014\u002F321662173\u002F":3,"page:\u002Fjavascript\u002F20191014\u002F321662173\u002F":4,"alt:\u002Fjavascript\u002F20191014\u002F321662173\u002F":3,"prev-next:\u002Fjavascript\u002F20191014\u002F321662173\u002F":662,"related:\u002Fjavascript\u002F20191014\u002F321662173\u002F":671},"\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F14\u002Fjs-from-zero-ep29-template-string\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":645,"date":646,"description":18,"extension":647,"lang":648,"meta":649,"navigation":650,"path":651,"readingMinutes":652,"seo":653,"standalone":654,"stem":655,"tags":656,"tldr":659,"updated":659,"url":660,"__hash__":661},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-29-RE：從零開始的學習-JS-生活-第二十九日.md","EP.29 RE：從零開始的學習 JS 生活-第二十九日之 Template String","321662173",{"type":9,"value":10,"toc":640},"minimark",[11,15,19,23,31,38,41,98,101,108,144,151,167,170,426,429,627,630,633,636],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第二十九日，這一篇將會介紹 ES6 的 Template String。",[12,20,22],{"id":21},"template-string","Template String",[16,24,25,26,30],{},"Template String 的中文名稱是樣板字串，也是我個人非常喜好的一個 ES6 新功能，在早期我們開發撰寫 JS 時，都必須使用單引號或是雙引號並搭配一個 ",[27,28,29],"code",{},"+"," 號來組合字串，就像這樣 ↓",[16,32,33],{},[34,35],"img",{"alt":36,"src":37},"加號運算子","https:\u002F\u002Fi.imgur.com\u002Fs41WCev.png",[16,39,40],{},"當如果我們今天要組合的字串特別長的時候就會超級麻煩，就會像這樣：",[42,43,48],"pre",{"className":44,"code":45,"language":46,"meta":47,"style":47},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Ray';\nvar hello = 'Hello' + a + '，你好';\n","js","",[27,49,50,73],{"__ignoreMap":47},[51,52,55,59,63,66,70],"span",{"class":53,"line":54},"line",1,[51,56,58],{"class":57},"sWyjQ","var",[51,60,62],{"class":61},"sMAXC"," a ",[51,64,65],{"class":57},"=",[51,67,69],{"class":68},"sTRMh"," 'Ray'",[51,71,72],{"class":61},";\n",[51,74,76,78,81,83,86,89,91,93,96],{"class":53,"line":75},2,[51,77,58],{"class":57},[51,79,80],{"class":61}," hello ",[51,82,65],{"class":57},[51,84,85],{"class":68}," 'Hello'",[51,87,88],{"class":57}," +",[51,90,62],{"class":61},[51,92,29],{"class":57},[51,94,95],{"class":68}," '，你好'",[51,97,72],{"class":61},[16,99,100],{},"你會發現引號越來越多，加號運算子也會越來越多，當越寫越多的時候就會導致閱讀上不方便且有高度可能性會發生誤刪引號或加號的問題，並且當字串太長我們還必須再插入反斜線來做斷行。",[16,102,103,104,107],{},"那麼 ES6 的 Template String 就是為了解決組合字串的困擾而出現的功能，基本上會使用到的是兩個頓號(反引號) ``` 以及 ${}",[27,105,106],{},"，","${}` 中間則是插入變數，所以我們就可以這樣子改寫上面的範例：",[42,109,111],{"className":44,"code":110,"language":46,"meta":47,"style":47},"var a = 'Ray';\nvar hello = `Hello ${a}，你好`;\n",[27,112,113,125],{"__ignoreMap":47},[51,114,115,117,119,121,123],{"class":53,"line":54},[51,116,58],{"class":57},[51,118,62],{"class":61},[51,120,65],{"class":57},[51,122,69],{"class":68},[51,124,72],{"class":61},[51,126,127,129,131,133,136,139,142],{"class":53,"line":75},[51,128,58],{"class":57},[51,130,80],{"class":61},[51,132,65],{"class":57},[51,134,135],{"class":68}," `Hello ${",[51,137,138],{"class":61},"a",[51,140,141],{"class":68},"}，你好`",[51,143,72],{"class":61},[16,145,146,147,150],{},"你會發現好寫非常多，而 Template String 的 ",[27,148,149],{},"${}"," 你會發現與 Ruby 有點神似，那 ES6 就是參考這些其他語言好的地方而加入的，使用 Template String 的好處有以下幾個重點",[152,153,154,158,161,164],"ul",{},[155,156,157],"li",{},"少一推引號",[155,159,160],{},"不在需要使用加號運算子組合字串",[155,162,163],{},"斷行也不用在使用反斜線",[155,165,166],{},"Template String 裡面也可以寫入判斷式",[16,168,169],{},"接下來讓我們看一下實際開發的案例比較會有深刻的感受，以下程式碼是我其中一個小練習的範例：",[42,171,173],{"className":44,"code":172,"language":46,"meta":47,"style":47},"function updataList(data) {\n    str = '';\n    var len = data.length;\n    for (var i = 0; i \u003C len; i++) {\n        str += '\u003Cli class=text-center ' + 123 + '>';\n        str += '\u003Cspan>' + data[i].status + '\u003C\u002Fspan>';\n        str += '\u003Cspan>\u003Cspan>BMI\u003C\u002Fspan> ' + data[i].bmi + '\u003C\u002Fspan>';\n        str += '\u003Cspan>\u003Cspan>height\u003C\u002Fspan> ' + data[i].weight + ' kg \u003C\