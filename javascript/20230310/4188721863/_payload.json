ass":66},[60,1372,1373,1375,1377,1379],{"class":62,"line":127},[60,1374,130],{"class":66},[60,1376,133],{"class":115},[60,1378,136],{"class":66},[60,1380,249],{"class":139},[12,1382,1383],{},"那麼必定是取得不到的。",[20,1385,1387,1389,1390],{"id":1386},"queryselector-vs-getelementbyid",[26,1388,28],{}," vs ",[26,1391,32],{},[12,1393,1394,1395,29,1397,1399,1400,1402,1403,1405],{},"在前面的許多介紹中，我們可以發現 ",[26,1396,582],{},[26,1398,44],{}," 都可以拿來選取元素，但是我們可以發現 ",[26,1401,582],{}," 在選取上是比較方便且彈性的，但如果以效能來講，那麼 ",[26,1404,44],{}," 的效能會比較好。",[12,1407,1408,1409,1411,1412,1414,1415,1417],{},"為什麼呢？其主要原因是 ",[26,1410,582],{}," 大多在選取時，大多都是採用 CSS 的選取方式，因此 ",[26,1413,582],{}," 會需要先解析 CSS 的選取方式，然後再去選取元素，而 ",[26,1416,44],{}," 則是直接依照 ID 選取元素，所以在效能上就會比較好。",[12,1419,1420,1421,1423,1424,1426,1427,1429],{},"但我認為這不會是拋棄 ",[26,1422,582],{}," 的理由，因為現今電腦的效能其實都非常的強大且有過剩（？）的問題，唯一有可能必須要使用 ",[26,1425,44],{}," 的情況大概就是要選取的元素非常明確且瀏覽器版本較舊，否則一般來說，都會建議改用 ",[26,1428,582],{},"，畢竟真的比較方便。",[20,1431,1433,1435],{"id":1432},"documentqueryselector-小技巧",[26,1434,582],{}," 小技巧",[12,1437,1438,1439,1441],{},"最後也補一個使用 ",[26,1440,582],{}," 的小技巧，但這個小技巧如果要使用在團隊專案上，最好大家都要有共識會比較好，否則可能會造成開發的混亂。",[12,1443,1444],{},"首先如果假設你有使用過 jQuery 的話，你會知道 jQuery 在選取元素是這樣選取的：",[51,1446,1448],{"className":93,"code":1447,"language":95,"meta":56,"style":56},"$('.test');\n",[26,1449,1450],{"__ignoreMap":56},[60,1451,1452,1455,1457,1459],{"class":62,"line":63},[60,1453,1454],{"class":115},"$",[60,1456,118],{"class":66},[60,1458,969],{"class":81},[60,1460,124],{"class":66},[12,1462,1463,1464,1466],{},"非常的簡潔且漂亮，但是如果你要使用 ",[26,1465,582],{}," 的話，就必須要這樣寫：",[51,1468,1470],{"className":93,"code":1469,"language":95,"meta":56,"style":56},"document.querySelector('.test');\n",[26,1471,1472],{"__ignoreMap":56},[60,1473,1474,1477,1479,1481,1483],{"class":62,"line":63},[60,1475,1476],{"class":66},"document.",[60,1478,28],{"class":115},[60,1480,118],{"class":66},[60,1482,969],{"class":81},[60,1484,124],{"class":66},[12,1486,1487,1488,1490],{},"那麼相對之下就非常的冗長了，所以我們可以透過宣告一個函式來建立一個 ",[26,1489,1454],{}," 的方法，這樣就可以讓我們在選取元素時，可以像 jQuery 一樣簡潔：",[51,1492,1494],{"className":93,"code":1493,"language":95,"meta":56,"style":56},"const $ = (selector) => document.querySelector(selector);\n",[26,1495,1496],{"__ignoreMap":56},[60,1497,1498,1500,1503,1505,1508,1511,1513,1515,1517,1519],{"class":62,"line":63},[60,1499,103],{"class":102},[60,1501,1502],{"class":115}," $",[60,1504,109],{"class":102},[60,1506,1507],{"class":66}," (",[60,1509,1510],{"class":1088},"selector",[60,1512,1092],{"class":66},[60,1514,1095],{"class":102},[60,1516,112],{"class":66},[60,1518,28],{"class":115},[60,1520,1521],{"class":66},"(selector);\n",[12,1523,1524],{},"這樣就可以讓我們在選取元素時，可以像 jQuery 一樣簡潔：",[51,1526,1527],{"className":93,"code":1447,"language":95,"meta":56,"style":56},[26,1528,1529],{"__ignoreMap":56},[60,1530,1531,1533,1535,1537],{"class":62,"line":63},[60,1532,1454],{"class":115},[60,1534,118],{"class":66},[60,1536,969],{"class":81},[60,1538,124],{"class":66},[12,1540,1541,1542,1545],{},"當然你也可以掛在 ",[26,1543,1544],{},"window"," 上，這樣就可以在全域都可以使用了：",[51,1547,1549],{"className":93,"code":1548,"language":95,"meta":56,"style":56},"window.$ = (selector) => document.querySelector(selector);\n",[26,1550,1551],{"__ignoreMap":56},[60,1552,1553,1556,1558,1560,1562,1564,1566,1568,1570,1572],{"class":62,"line":63},[60,1554,1555],{"class":66},"window.",[60,1557,1454],{"class":115},[60,1559,109],{"class":102},[60,1561,1507],{"class":66},[60,1563,1510],{"class":1088},[60,1565,1092],{"class":66},[60,1567,1095],{"class":102},[60,1569,112],{"class":66},[60,1571,28],{"class":115},[60,1573,1521],{"class":66},[12,1575,1576],{},"以上就是一些小技巧的部分，可是再次強調，這個小技巧如果要用在團隊專案下，還是建議要有共識比較好，否則會使用 jQuery 的人可能會覺得很奇怪，那麼這個小技巧就不是那麼實用了，所以算是額外補充一個在自己小專案內可以使用的小技巧哩~",[1578,1579,1580],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html