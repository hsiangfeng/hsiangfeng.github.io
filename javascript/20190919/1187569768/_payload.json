8},[66,657,162],{"class":72},[66,659,616],{"class":88},[66,661,168],{"class":72},[66,663,664,666,668],{"class":68,"line":508},[66,665,590],{"class":72},[66,667,277],{"class":392},[66,669,168],{"class":72},[16,671,672],{},"所以目前顯示畫面是這樣 ↓",[16,674,675],{},[240,676],{"alt":677,"src":678},"目前顯示","https:\u002F\u002Fi.imgur.com\u002FCZKDsBc.png",[16,680,681,682,685,686,688,689,692],{},"正常來講當我們點擊任何一個 ",[30,683,684],{},"box1 ~ 2"," 都應該只會出現我們點擊的 box，但是如果我們將第三個參數改為 ",[30,687,277],{}," 並點擊 ",[30,690,691],{},"box2"," 將會發生什麼事情呢?",[16,694,695],{},[240,696],{"alt":697,"src":698},"box1 → box2","https:\u002F\u002Fi.imgur.com\u002F0tQVrSs.png",[16,700,701,702,704,705,708,709,711,712,714],{},"可以發現明明點擊的是 ",[30,703,691],{}," 但是 ",[30,706,707],{},"box1"," 卻也跳出來，那如果將第三個參數改為預設 ",[30,710,281],{}," 在點一次 ",[30,713,691],{}," 呢?",[16,716,717],{},[240,718],{"alt":719,"src":720},"box2 → box1","https:\u002F\u002Fi.imgur.com\u002FYBeUV9p.png",[16,722,723,724,726,727,729],{},"可以發現結果反過來輸出，而且還會穿透過去，所以說第三個參數的 ",[30,725,281],{}," & ",[30,728,277],{}," 分別代表著以下意思：",[731,732,733,739],"ul",{},[734,735,736,738],"li",{},[30,737,281],{}," - 從指定元素往外層觸發",[734,740,741,743],{},[30,742,277],{}," - 由外層往指定元素觸發",[16,745,746,747,749],{},"若是以圖片來範例的話就會像這樣，首先是預設的 ",[30,748,281],{}," 狀況 ↓",[16,751,752],{},[240,753],{"alt":754,"src":755},"從指定元素往外層觸發","https:\u002F\u002Fi.imgur.com\u002FHx6ZhOz.png",[16,757,758,759,761],{},"那麼 ",[30,760,277],{}," 則是反過來 ↓",[16,763,764],{},[240,765],{"alt":766,"src":767},"由外層往指定元素觸發","https:\u002F\u002Fi.imgur.com\u002FzB2q7bx.png",[16,769,770],{},"當然第三個參數是有比較正式的說法",[731,772,773,778],{},[734,774,775,777],{},[30,776,281],{}," - 事件氣泡(Event Bubbling)",[734,779,780,782],{},[30,781,277],{}," - 事件捕捉(Event capturing)",[16,784,785],{},"事件氣泡的意思，以異世界來舉例，你可以想像成你在大草原上面看著一個兔子(指定元素)，然後再往其他草原(外層)的部分尋找別的兔子。",[16,787,788],{},"那麼事件捕捉的話，則是你從大草原(外層)裡面尋找一隻兔子(指定元素)。",[16,790,791,792,795,796,798,799,236],{},"但是有時候我們會不希望發生事件氣泡 or 事件捕捉的狀況，那麼 JavaScript 就有提供一個語法幫助我們解決這個問題，也就是 ",[30,793,794],{},"stopPropagation();","，也就是阻止當前事件繼續進行捕捉（capturing）及冒泡（bubbling）階段的傳遞，當你加入後不管怎麼點 ",[30,797,691],{}," 就不會跳出 ",[30,800,707],{},[16,802,803],{},[240,804],{"alt":805,"src":806},"stopPropagation","https:\u002F\u002Fi.imgur.com\u002FdbB70hh.png",[16,808,103,809],{},[105,810,811],{"href":811,"rel":812},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FxxKYxro\u002F",[109],[111,814],{"default-tab":264,"height":114,"slug":815,"title":816,"user":117},"xxKYxro","事件氣泡",[12,818,819],{"id":819},"結尾",[16,821,822],{},"下一篇的 RE：從零開始的學習 JS 生活-第五日 將會介紹陣列與物件。",[824,825,826],"style",{},"html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syv7_, html code.shiki .syv7_{--shiki-light:#22863A;--shiki-default:#22863A;--shiki-dark:#72F088}html pre.shiki code .sK3KL, html code.shiki .sK3KL{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#91CBFF}html pre.shiki code .sOudu, html code.shiki .sOudu{--shiki-light:#D73A49;--shiki-default:#D73A49;--shiki-dark:#FF9492}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);t