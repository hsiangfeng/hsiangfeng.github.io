[{"data":1,"prerenderedAt":874},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190919\u002F1187569768\u002F":3,"page:\u002Fjavascript\u002F20190919\u002F1187569768\u002F":4,"alt:\u002Fjavascript\u002F20190919\u002F1187569768\u002F":3,"prev-next:\u002Fjavascript\u002F20190919\u002F1187569768\u002F":849,"related:\u002Fjavascript\u002F20190919\u002F1187569768\u002F":858},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F19\u002Fjs-from-zero-04-events-and-listeners\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":833,"date":834,"description":18,"extension":835,"lang":836,"meta":837,"navigation":174,"path":838,"readingMinutes":839,"seo":840,"standalone":841,"stem":842,"tags":843,"tldr":846,"updated":846,"url":847,"__hash__":848},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-4-RE：從零開始的學習-JS-生活-第四日.md","EP.4 RE：從零開始的學習 JS 生活-第四日之事件與事件監聽","1187569768",{"type":9,"value":10,"toc":826},"minimark",[11,15,19,23,26,56,98,101,110,118,121,128,131,230,237,244,250,256,262,266,269,286,289,370,373,510,513,669,672,678,692,698,714,720,729,743,749,755,761,767,770,782,785,788,800,806,812,816,819,822],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第四日，前一天了解了選取器後，接下來就必須來了解事件以及事件監聽。",[12,20,22],{"id":21},"事件-event","事件 Event",[16,24,25],{},"事件有很多種，所以這邊僅列常見的事件，而事件其實就是在講你的動作，例如你按下按鈕的動作、滑鼠拖曳的動作甚至拖曳視窗的動作，這些都統稱事件，又可以稱之為事件處理器(event handlers)，最主要是監聽使用者的任何一個操作動作，但是監聽又是另一回事。",[16,27,28,29,33,34,33,37,40,41,33,44,47,48,51,52,55],{},"一般常見的事件會有 ",[30,31,32],"code",{},"click"," 、 ",[30,35,36],{},"change",[30,38,39],{},"blur"," 等，而這些都是屬於 JavaScript 的 Event 事件，早期的網站開發你可能會看到這種事件 ",[30,42,43],{},"onclick",[30,45,46],{},"onchange"," 甚至是 ",[30,49,50],{},"onmouseover"," 等等，這些有 ",[30,53,54],{},"on"," 開頭的，居多都是都是直接寫在 HTML 上，如：",[57,58,63],"pre",{"className":59,"code":60,"language":61,"meta":62,"style":62},"language-js shiki shiki-themes github-dark-high-contrast","\u003Cbutton onclick=\"alert('Ray')\">你叫什麼？\u003C\u002Fbutton>\n","js","",[30,64,65],{"__ignoreMap":62},[66,67,70,74,78,82,86,90,93,95],"span",{"class":68,"line":69},"line",1,[66,71,73],{"class":72},"sMAXC","\u003C",[66,75,77],{"class":76},"sKpQp","button",[66,79,81],{"class":80},"sCcAr"," onclick",[66,83,85],{"class":84},"sWyjQ","=",[66,87,89],{"class":88},"sTRMh","\"alert('Ray')\"",[66,91,92],{"class":72},">你叫什麼？\u003C\u002F",[66,94,77],{"class":76},[66,96,97],{"class":72},">\n",[16,99,100],{},"以現階段開發來講比較少人使用這種方式，最主要這種寫法會導致維護上的困擾，光是修改一個事件你可能就會找老半天，所以現在大多開發者都會將事件寫在一隻 JavaScript 中，當然你還是有機會可以看到這種寫法。",[16,102,103,104],{},"codepen：",[105,106,107],"a",{"href":107,"rel":108},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FNWKyPRE",[109],"nofollow",[111,112],"code-pen",{"default-tab":113,"height":114,"slug":115,"title":116,"user":117},"html,result",265,"NWKyPRE","HTML onclick","hsiangfeng",[12,119,120],{"id":120},"事件監聽",[16,122,123,124,127],{},"事件監聽簡單來講起來就是我「請一個人盯著你特定的行為動作」，例如我盯著你何時會按下按鈕的這個動作或是你滑鼠移動的軌跡，前面有講到現在開發都會將事件監聽寫在 JavaScript 檔案中，那麼該如何撰寫事件監聽呢?使用事件監聽的語法是 ",[30,125,126],{},"addEventListener()"," 它可以將你指定的特定事件註冊至你帶入的事件中，這樣講其實滿模糊的，來看一下範例：",[16,129,130],{},"假如使用者點擊按鈕時會觸發事件並顯示跟我打招呼，那 JavaScript 就可以像以下範例這樣寫，但是我們必須先使用選取器選取你要監聽哪一個 DOM 元素，否則怎麼知道你要監聽哪一個呢？",[57,132,134],{"className":59,"code":133,"language":61,"meta":62,"style":62},"\u002F\u002F 選取欲監聽的元素\nvar clickId = document.getElementById('clickme');\n\n\u002F\u002F 第一個參數是要監聽的事件 第二個參數是觸發事件後要執行的動作 第三個後面在介紹\nclickId.addEventListener('click', function() {\n  console.log('My Name is Ray');\n}) \u002F\u002F 注意 JavaScript 的事件可以不用加上 on\n",[30,135,136,142,169,176,182,205,221],{"__ignoreMap":62},[66,137,138],{"class":68,"line":69},[66,139,141],{"class":140},"sQrFR","\u002F\u002F 選取欲監聽的元素\n",[66,143,145,148,151,153,156,160,163,166],{"class":68,"line":144},2,[66,146,147],{"class":84},"var",[66,149,150],{"class":72}," clickId ",[66,152,85],{"class":84},[66,154,155],{"class":72}," document.",[66,157,159],{"class":158},"sj_SG","getElementById",[66,161,162],{"class":72},"(",[66,164,165],{"class":88},"'clickme'",[66,167,168],{"class":72},");\n",[66,170,172],{"class":68,"line":171},3,[66,173,175],{"emptyLinePlaceholder":174},true,"\n",[66,177,179],{"class":68,"line":178},4,[66,180,181],{"class":140},"\u002F\u002F 第一個參數是要監聽的事件 第二個參數是觸發事件後要執行的動作 第三個後面在介紹\n",[66,183,185,188,191,193,196,199,202],{"class":68,"line":184},5,[66,186,187],{"class":72},"clickId.",[66,189,190],{"class":158},"addEventListener",[66,192,162],{"class":72},[66,194,195],{"class":88},"'click'",[66,197,198],{"class":72},", ",[66,200,201],{"class":84},"function",[66,203,204],{"class":72},"() {\n",[66,206,208,211,214,216,219],{"class":68,"line":207},6,[66,209,210],{"class":72},"  console.",[66,212,213],{"class":158},"log",[66,215,162],{"class":72},[66,217,218],{"class":88},"'My Name is Ray'",[66,220,168],{"class":72},[66,222,224,227],{"class":68,"line":223},7,[66,225,226],{"class":72},"}) ",[66,228,229],{"class":140},"\u002F\u002F 注意 JavaScript 的事件可以不用加上 on\n",[16,231,232,233,236],{},"那當你點擊按鈕後就會出現 ",[30,234,235],{},"My Name is Ray"," ↓",[16,238,239],{},[240,241],"img",{"alt":242,"src":243},"事件觸發","https:\u002F\u002Fi.imgur.com\u002FGPHUY91.png",[16,245,246,247,249],{},"所以 ",[30,248,126],{}," 的參數說明就像這樣 ↓",[16,251,252],{},[240,253],{"alt":254,"src":255},"addEventListener 說明","https:\u002F\u002Fi.imgur.com\u002FwcH4wDx.png",[16,257,103,258],{},[105,259,260],{"href":260,"rel":261},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FrNBJaWa",[109],[111,263],{"default-tab":264,"height":114,"slug":265,"title":120,"user":117},"js,result","rNBJaWa",[12,267,268],{"id":268},"事件流程",[16,270,271,272,274,275,278,279,282,283,285],{},"第三個參數是所謂的 ",[30,273,268],{}," 它只能夠接受 Boolean，也就是 ",[30,276,277],{},"true"," or ",[30,280,281],{},"false","，並且可以選擇是否填入或是留空，通常預設留空是 ",[30,284,281],{},"，那事件流程是什麼呢?讓我們從範例來看。",[16,287,288],{},"HTML 部分 ：",[57,290,294],{"className":291,"code":292,"language":293,"meta":62,"style":62},"language-HTML shiki shiki-themes github-dark-high-contrast","\u003Cdiv class=\"box1\" id=\"box1\">\n  box1\n  \u003Cdiv class=\"box2\" id=\"box2\">\n 