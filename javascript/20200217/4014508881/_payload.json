[{"data":1,"prerenderedAt":305},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200217\u002F4014508881\u002F":3,"page:\u002Fjavascript\u002F20200217\u002F4014508881\u002F":4,"alt:\u002Fjavascript\u002F20200217\u002F4014508881\u002F":3,"prev-next:\u002Fjavascript\u002F20200217\u002F4014508881\u002F":280,"related:\u002Fjavascript\u002F20200217\u002F4014508881\u002F":289},"\u002Fen\u002Fjavascript\u002F2020\u002F02\u002F17\u002Fpixijs-v5-tutorial-02-webgl-renderer\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":263,"date":264,"description":18,"extension":265,"lang":266,"meta":267,"navigation":168,"path":268,"readingMinutes":269,"seo":270,"standalone":271,"stem":272,"tags":273,"tldr":277,"updated":277,"url":278,"__hash__":279},"content\u002FPixiJS V5 教學\u002FPixiJS V5 教學 (2) - WebGL 以及 Renderer.md","PixiJS V5 教學 (2) - WebGL 以及 Renderer","4014508881",{"type":9,"value":10,"toc":257},"minimark",[11,15,19,23,26,29,32,35,39,42,61,64,74,77,80,83,89,92,99,102,224,232,235,253],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",[12,20,22],{"id":21},"webgl","WebGL",[16,24,25],{},"WebGL 在前面有介紹是 JavaScript 的 API 的一種，簡單講 WebGL 可以將影像、圖片處理和特效都採用 GPU 進行渲染並成為網頁 Canvas 的一部分，這時候你可能還會說「我知道 CPU，但是 GPU 是什麼?」",[16,27,28],{},"CPU 全名為 Central Processing Unit，中文是中央處理器，簡單講就是電腦的心臟啦~",[16,30,31],{},"那 GPU 呢?GPU 則是 Graphics Processing Unit，中文是圖形處理器，也就是你 PC 電腦中常見的顯示卡。",[16,33,34],{},"而 WebGL 就是使用你的顯示卡來處理 Canvas 的影像進而達到較好的體驗效果，否則使用原本的 Canvas 是有可能會較延遲。",[12,36,38],{"id":37},"renderer","Renderer",[16,40,41],{},"為什麼要特別拉回來講 WebGL 呢?",[16,43,44,45,49,50,53,54],{},"主要原因是在前面我們有使用到 ",[46,47,48],"code",{},"app.renderer.backgroundColor = 0x00CC99;","、",[46,51,52],{},"app.renderer.resize(400, 400);"," 等語法，其中 Renderer 的意思就是渲染的意思，而 PIXI Renderer 的渲染有兩種方式，讓我們翻一下 ",[55,56,60],"a",{"href":57,"rel":58},"https:\u002F\u002Fgithub.com\u002Fpixijs\u002Fpixi.js\u002Fblob\u002Fdev\u002Fpackages\u002Fcore\u002Fsrc\u002FautoDetectRenderer.js",[59],"nofollow","PIXI 原始碼",[16,62,63],{},"官方註解就有寫很多，我這邊就擷取一小段稍微弱弱的翻譯就好。",[65,66,72],"pre",{"className":67,"code":69,"language":70,"meta":71},[68],"language-text","This helper function will automatically detect which renderer you should be using.\nWebGL is the preferred renderer as it is a lot faster. If WebGL is not supported by\nthe browser then this function will return a canvas renderer\n","text","",[46,73,69],{"__ignoreMap":71},[16,75,76],{},"該功能將會幫助你自動選擇要使用哪一種渲染方式。\n而 WebGL 是首要選項，主要原因是他的速度較快，所以你可以體驗到較好的使用者體驗。\n假使若瀏覽器不支援 WebGL，將會自動改使用原生的 Canvas 來渲染。",[78,79],"hr",{},[16,81,82],{},"而主要關鍵程式碼說明在這裡",[65,84,87],{"className":85,"code":86,"language":70,"meta":71},[68],"@return {PIXI.Renderer|PIXI.CanvasRenderer} Returns WebGL renderer if available, otherwise CanvasRenderer\n",[46,88,86],{"__ignoreMap":71},[16,90,91],{},"在前一篇我們有了解到該如何查看目前版本以及使用的引擎，只需要開啟瀏覽器查看 Console devTools",[16,93,94],{},[95,96],"img",{"alt":97,"src":98},"目前版本以及使用的引擎","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F2019-12-01_21-32-06.png",[16,100,101],{},"另一種方式則是使用程式碼的方式",[65,103,107],{"className":104,"code":105,"language":106,"meta":71,"style":71},"language-js shiki shiki-themes github-dark-high-contrast","document.getElementById('webgl').textContent = `是否支援 WebGL： ${PIXI.utils.isWebGLSupported()}`;\n\n\u002F\u002F 0：unknown\n\u002F\u002F 1：WebGL\n\u002F\u002F 2：canvas\ndocument.getElementById('type').textContent = `目前模式：${app.renderer.type}`;\n","js",[46,108,109,163,170,177,183,189],{"__ignoreMap":71},[110,111,114,118,122,125,129,132,136,139,143,146,149,151,154,157,160],"span",{"class":112,"line":113},"line",1,[110,115,117],{"class":116},"sMAXC","document.",[110,119,121],{"class":120},"sj_SG","getElementById",[110,123,124],{"class":116},"(",[110,126,128],{"class":127},"sTRMh","'webgl'",[110,130,131],{"class":116},").textContent ",[110,133,135],{"class":134},"sWyjQ","=",[110,137,138],{"class":127}," `是否支援 WebGL： ${",[110,140,142],{"class":141},"sCcAr","PIXI",[110,144,145],{"class":127},".",[110,147,148],{"class":116},"utils",[110,150,145],{"class":127},[110,152,153],{"class":120},"isWebGLSupported",[110,155,156],{"class":127},"()",[110,158,159],{"class":127},"}`",[110,161,162],{"class":116},";\n",[110,164,166],{"class":112,"line":165},2,[110,167,169],{"emptyLinePlaceholder":168},true,"\n",[110,171,173],{"class":112,"line":172},3,[110,174,176],{"class":175},"sQrFR","\u002F\u002F 0：unknown\n",[110,178,180],{"class":112,"line":179},4,[110,181,182],{"class":175},"\u002F\u002F 1：WebGL\n",[110,184,186],{"class":112,"line":185},5,[110,187,188],{"class":175},"\u002F\u002F 2：canvas\n",[110,190,192,194,196,198,201,203,205,208,211,213,215,217,220,222],{"class":112,"line":191},6,[110,193,117],{"class":116},[110,195,121],{"class":120},[110,197,124],{"class":116},[110,199,200],{"class":127},"'type'",[110,202,131],{"class":116},[110,204,135],{"class":134},[110,206,207],{"class":127}," `目前模式：${",[110,209,210],{"class":116},"app",[110,212,145],{"class":127},[110,214,37],{"class":116},[110,216,145],{"class":127},[110,218,219],{"class":116},"type",[110,221,159],{"class":127},[110,223,162],{"class":116},[225,226],"code-pen",{"default-tab":227,"height":228,"slug":229,"title":230,"user":231},"js,result",265,"dyPYJVj","PIXI 查看版本(3)","hsiangfeng",[12,233,234],{"id":234},"參考文獻",[236,237,238,246],"ul",{},[239,240,241],"li",{},[55,242,245],{"href":243,"rel":244},"https:\u002F\u002Fpixijs.io\u002Fexamples\u002F",[59],"PixiJS",[239,247,248],{},[55,249,252],{"href":250,"rel":251},"http:\u002F\u002Fpixijs.download\u002Frelease\u002Fdocs\u002FPIXI.Application.html",[59],"PIXI.Application",[254,255,256],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sCcAr, html code.shiki .sCcAr