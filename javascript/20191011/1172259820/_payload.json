[{"data":1,"prerenderedAt":646},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20191011\u002F1172259820\u002F":3,"page:\u002Fjavascript\u002F20191011\u002F1172259820\u002F":4,"alt:\u002Fjavascript\u002F20191011\u002F1172259820\u002F":3,"prev-next:\u002Fjavascript\u002F20191011\u002F1172259820\u002F":621,"related:\u002Fjavascript\u002F20191011\u002F1172259820\u002F":630},"\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F11\u002Fjs-from-zero-26-es6-let-const\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":603,"date":604,"description":605,"extension":606,"lang":607,"meta":608,"navigation":609,"path":610,"readingMinutes":611,"seo":612,"standalone":613,"stem":614,"tags":615,"tldr":618,"updated":618,"url":619,"__hash__":620},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-26-RE：從零開始的學習-JS-生活-第二十六日.md","EP.26 RE：從零開始的學習 JS 生活-第二十六日之 ES6 變數","1172259820",{"type":9,"value":10,"toc":595},"minimark",[11,15,28,32,49,66,85,129,132,157,160,162,177,238,249,255,266,318,328,334,359,361,371,410,423,452,459,464,474,480,483,486,508,533,543,548,563,569,577,580,585,588,591],[12,13,14],"h2",{"id":14},"前言",[16,17,18,19,23,24,27],"p",{},"轉生第二十六日，這一篇開始將會介紹 ES6，首先是 ES6 的 ",[20,21,22],"code",{},"let"," & ",[20,25,26],{},"const","。",[12,29,31],{"id":30},"let-const","let & const",[16,33,34,35,23,37,39,40,43,44,23,46,48],{},"首先什麼是 ",[20,36,22],{},[20,38,26],{}," 呢?一般來講我們在宣告變數的時候是使用 ",[20,41,42],{},"var"," 來建立變數，後來 ES6 加入了兩個新的變數宣告方式，這個變數宣告方式其實可以改善很多開發上的 bug，基本上 ",[20,45,22],{},[20,47,26],{}," 我們可以這樣子了解",[50,51,52,61],"ul",{},[53,54,55,57,58,60],"li",{},[20,56,22],{}," - 變數與原本的 ",[20,59,42],{}," 雷同",[53,62,63,65],{},[20,64,26],{}," - 常數，意旨不能變動的值",[16,67,68,69,23,71,73,74,76,77,79,80,23,82,84],{},"基本上你在開發時，若對於 ",[20,70,22],{},[20,72,26],{}," 不清楚，可以嘗試先把原本的 ",[20,75,42],{}," 修改成 ",[20,78,22],{},"，等到後面熟悉了 ",[20,81,22],{},[20,83,26],{}," 這兩者差異，再來去做調整，所以假設原本的寫法是這樣：",[86,87,92],"pre",{"className":88,"code":89,"language":90,"meta":91,"style":91},"language-js shiki shiki-themes github-dark-high-contrast","var a = 1;\nconsole.log(a);\n","js","",[20,93,94,116],{"__ignoreMap":91},[95,96,99,102,106,109,113],"span",{"class":97,"line":98},"line",1,[95,100,42],{"class":101},"sWyjQ",[95,103,105],{"class":104},"sMAXC"," a ",[95,107,108],{"class":101},"=",[95,110,112],{"class":111},"sCcAr"," 1",[95,114,115],{"class":104},";\n",[95,117,119,122,126],{"class":97,"line":118},2,[95,120,121],{"class":104},"console.",[95,123,125],{"class":124},"sj_SG","log",[95,127,128],{"class":104},"(a);\n",[16,130,131],{},"此時你可以先修改成這樣：",[86,133,135],{"className":88,"code":134,"language":90,"meta":91,"style":91},"let a = 1;\nconsole.log(a);\n",[20,136,137,149],{"__ignoreMap":91},[95,138,139,141,143,145,147],{"class":97,"line":98},[95,140,22],{"class":101},[95,142,105],{"class":104},[95,144,108],{"class":101},[95,146,112],{"class":111},[95,148,115],{"class":104},[95,150,151,153,155],{"class":97,"line":118},[95,152,121],{"class":104},[95,154,125],{"class":124},[95,156,128],{"class":104},[16,158,159],{},"這兩者差異並不大。",[12,161,22],{"id":22},[16,163,164,165,167,168,170,171,173,174,176],{},"首先前面有講到 ",[20,166,22],{}," 與 ",[20,169,42],{}," 差異性不大，那這時候你可能會說 「差異不大那為何要改用 ",[20,172,22],{},"?」，原本我們使用 ",[20,175,42],{}," 來建立變數，是會發生一些問題出現問題出現：",[86,178,180],{"className":88,"code":179,"language":90,"meta":91,"style":91},"var a = 1;\nif(true) {\n  var a = 2;\n}\nconsole.log(a);\n",[20,181,182,194,208,223,229],{"__ignoreMap":91},[95,183,184,186,188,190,192],{"class":97,"line":98},[95,185,42],{"class":101},[95,187,105],{"class":104},[95,189,108],{"class":101},[95,191,112],{"class":111},[95,193,115],{"class":104},[95,195,196,199,202,205],{"class":97,"line":118},[95,197,198],{"class":101},"if",[95,200,201],{"class":104},"(",[95,203,204],{"class":111},"true",[95,206,207],{"class":104},") {\n",[95,209,211,214,216,218,221],{"class":97,"line":210},3,[95,212,213],{"class":101},"  var",[95,215,105],{"class":104},[95,217,108],{"class":101},[95,219,220],{"class":111}," 2",[95,222,115],{"class":104},[95,224,226],{"class":97,"line":225},4,[95,227,228],{"class":104},"}\n",[95,230,232,234,236],{"class":97,"line":231},5,[95,233,121],{"class":104},[95,235,125],{"class":124},[95,237,128],{"class":104},[16,239,240,241,244,245,248],{},"我們會發現全域變數 ",[20,242,243],{},"a"," 被修改成 ",[20,246,247],{},"2"," 了 ↓",[16,250,251],{},[252,253],"img",{"alt":247,"src":254},"https:\u002F\u002Fi.imgur.com\u002Fe0c9GYn.png",[16,256,257,258,262,263,265],{},"而這就是所謂的",[259,260,261],"strong",{},"變數汙染","，那 ",[20,264,22],{}," 呢?讓我們改寫上面範例：",[86,267,269],{"className":88,"code":268,"language":90,"meta":91,"style":91},"let a = 1;\nif(true) {\n  let a = 2;\n}\nconsole.log(a);\n",[20,270,271,283,293,306,310],{"__ignoreMap":91},[95,272,273,275,277,279,281],{"class":97,"line":98},[95,274,22],{"class":101},[95,276,105],{"class":104},[95,278,108],{"class":101},[95,280,112],{"class":111},[95,282,115],{"class":104},[95,284,285,287,289,291],{"class":97,"line":118},[95,286,198],{"class":101},[95,288,201],{"class":104},[95,290,204],{"class":111},[95,292,207],{"class":104},[95,294,295,298,300,302,304],{"class":97,"line":210},[95,296,297],{"class":101},"  let",[95,299,105],{"class":104},[95,301,108],{"class":101},[95,303,220],{"class":111},[95,305,115],{"class":104},[95,307,308],{"class":97,"line":225},[95,309,228],{"class":104},[95,311,312,314,316],{"class":97,"line":231},[95,313,121],{"class":104},[95,315,125],{"class":124},[95,317,128],{"class":104},[16,319,320,321,323,324,327],{},"你會發現 ",[20,322,243],{}," 還是 1，並沒有受到內層的 ",[20,325,326],{},"let a = 2"," 影響而改變 ↓",[16,329,330],{},[252,331],{"alt":332,"src":333},"1","https:\u002F\u002Fi.imgur.com\u002F8Z3jHd2.png",[16,335,336,337,339,340,343,344,346,347,349,350,352,353,355,356,358],{},"所以我們可以得到一個結論 ",[20,338,22],{}," 是一個區域 (block) 變數，區域 (block) 的意思是指花括號(",[20,341,342],{},"{ }",")裡面的區塊，所以使用 ",[20,345,22],{}," 的變數就只會存活於花括號內，而 ",[20,348,42],{}," 呢? ",[20,351,42],{}," 是函式 (function) 變數，函式 (function) 的意思，就是它的範圍只會在 function 內，但是其實正確來講應該是這樣解釋會比較好 ",[20,354,22],{}," 是一個 block 作用域變數，而 ",[20,357,42],{}," 是一個 function 作用域變數。",[12,360,26],{"id":26},[16,362,363,364,366,367,370],{},"那 ",[20,365,26],{}," 呢?先講講什麼是常數，常數又稱之為定數，就是在指",[259,368,369],{},"固定不變的值","，以往我們在宣告變數的時候是可以一直重複修改的：",[86,372,374],{"className":88,"code":373,"language":90,"meta":91,"style":91},"var a = 1;\na = 2;\na = 3;\n",[20,375,376,388,399],{"__ignoreMap":91},[95,377,378,380,382,384,386],{"class":97,"line":98},[95,379,42],{"class":101},[95,381,105],{"class":104},[95,383,108],{"class":101},[95,385,112],{"class":111},[95,387,115],{"class":104},[95,389,390,393,395,397],{"class":97,"line":118},[95,391,392],{"class":104},"a ",[95,394,108],{"class":101},[95,396,220],{"class":111},[95,398,115],{"class":104},[95,400,401,403,405,408],{"class":97,"line":210},[95,402,392],{"class":104},[95,404,108],{"class":101},[95,406,407],{"class":111}," 3",[95,409,115],{"class":104},[16,411,412,413,416,417,419,420,422],{},"通常這種變數宣告方式是有可能發生",[259,414,415],{},"不小心覆蓋不想覆蓋的變數值","，所以此時如果你的變數值是固定的，並且不會變動，那麼就可以使用 ",[20,418,26],{},"，如果我們一但使用 ",[20,421,26],{}," 宣告變數後卻還變更它呢?",[86,424,426],{"className":88,"code":425,"language":90,"meta":91,"style":91},"const a = 1;\na = 2;\n",[20,427,428,442],{"__ignoreMap":91},[95,429,430,432,435,438,440],{"class":97,"line":98},[95,431,26],{"class":101},[95,433,434],{"class":111}," a",[95,436,437],{"class":101}," =",[95,439,112],{"class":111},[95,441,115],{"class":104},[95,443,444,446,448,450],{"class":97,"line":118},[95,445,392],{"class":104},[95,447,108],{"class":101},[95,449,220],{"class":111},[95,451,115],{"class":104},[16,453,454,455,458],{},"此時你會出現一個錯誤訊息，也就是 ",[20,456,457],{},"Assignment to constant variable.","，簡單來講它是在跟你講說「我不給你修改這個常數」 ↓",[16,460,461],{},[252,462],{"alt":457,"src":463},"https:\u002F\u002Fi.imgur.com\u002FHUSvIVF.png",[16,465,466,467,470,471,473],{},"但是這邊最後有一個東西要注意，若你在宣告變數時，若 ",[20,468,469],{},"let a;"," 這樣是不會出現錯誤的，可是 ",[20,472,26],{}," 是必須給予值的，若你沒有賦予初始值，那麼就會得到一個錯誤 ↓",[16,475,476],{},[252,477],{"alt":478,"src":479},"Missing initializer in const declaration","https:\u002F\u002Fi.imgur.com\u002FZamj3kq.png",[16,481,482],{},"簡單來講就是 「你忘記替我賦值了」。",[12,484,485],{"id":485},"補充",[16,487,488,489,23,491,493,494,23,496,498,499,23,501,503,504,507],{},"最後稍微講一下 ",[20,490,22],{},[20,492,26],{}," 的 Hoisting，前面我們已經了解了 Hoisting 的部分，但是在 ES6 的 ",[20,495,22],{},[20,497,26],{}," 呢?它有 Hoisting 嗎?其實 ",[20,500,22],{},[20,502,26],{}," 沒有 Hoisting 而是另一種說法稱之為",[259,505,506],{},"暫時性死區","，這是什麼意思呢?讓我們看一下程式碼：",[86,509,511],{"className":88,"code":510,"language":90,"meta":91,"style":91},"console.log(a);\nlet a = 1;\n",[20,512,513,521],{"__ignoreMap":91},[95,514,515,517,519],{"class":97,"line":98},[95,516,121],{"class":104},[95,518,125],{"class":124},[95,520,128],{"class":104},[95,522,523,525,527,529,531],{"class":97,"line":118},[95,524,22],{"class":101},[95,526,105],{"class":104},[95,528,108],{"class":101},[95,530,112],{"class":111},[95,532,115],{"class":104},[16,534,535,536,539,540],{},"正常來講你應該會得到一個 ",[20,537,538],{},"undefined","，但是當你使用 ES6 變數宣告則會得到 ",[20,541,542],{},"Uncaught ReferenceError: Cannot access 'a' before initialization",[16,544,545],{},[252,546],{"alt":542,"src":547},"https:\u002F\u002Fi.imgur.com\u002FUT4ckUo.png",[16,549,550,551,554,555,23,557,559,560,562],{},"這是什麼意思呢?簡單來講就是「",[259,552,553],{},"我還沒執行這一段之前你不能使用這個變數","」，在 MDN 文件中也有說明 ",[20,556,22],{},[20,558,26],{}," 並沒有所謂的 Hoisting，而是有所謂的",[259,561,506],{},"，以下截取 MDN 部分文件內容 ↓",[564,565,566],"blockquote",{},[16,567,568],{},"In ECMAScript 2015, let bindings are not subject to Variable Hoisting, which means that let declarations do not move to the top of the current execution context. Referencing the variable in the block before the initialization results in a ReferenceError (contrary to a variable declared with var, which will just have the undefined value). The variable is in a \"temporal dead zone\" from the start of the block until the initialization is processed.",[16,570,571],{},[243,572,576],{"href":573,"rel":574},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FStatements\u002Flet#Temporal_Dead_Zone_and_errors_with_let",[575],"nofollow","原文位置",[16,578,579],{},"這一篇原文是只有講 let，但其實 const 也是一樣的，所以當你實際操作也會得到一樣結果 ↓",[16,581,582],{},[252,583],{"alt":542,"src":584},"https:\u002F\u002Fi.imgur.com\u002FE9qDMMa.png",[12,586,587],{"id":587},"結尾",[16,589,590],{},"下一篇的 RE：從零開始的學習 JS 生活-第二十七日 將會介紹 ES6 箭頭函式。",[592,593,594],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":91,"searchDepth":118,"depth":118,"links":596},[597,598,599,600,601,602],{"id":14,"depth":118,"text":14},{"id":30,"depth":118,"text":31},{"id":22,"depth":118,"text":22},{"id":26,"depth":118,"text":26},{"id":485,"depth":118,"text":485},{"id":587,"depth":118,"text":587},"JavaScript","2019-10-11 08:40:44","轉生第二十六日，這一篇開始將會介紹 ES6，首先是 ES6 的 `let` & `const`。","md","zh-Hant",{},true,"\u002Fre-js\u002Fep-26-re-js","3",{"title":6,"description":605},false,"RE：從零開始的學習 JS 生活\u002FEP-26-RE：從零開始的學習-JS-生活-第二十六日",[603,616,617],"RE：從零開始的學習 JS 生活","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fjavascript\u002F20191011\u002F1172259820\u002F","nhygXz3dm8A-dZgXEkYFdUPu7vgMTJDGMYWfIDXIpMQ",{"newer":622,"older":626},{"url":623,"title":624,"date":625},"\u002Fjavascript\u002F20191012\u002F2524618181\u002F","EP.27 RE：從零開始的學習 JS 生活-第二十七日之 ES6 箭頭函式","2019-10-12 08