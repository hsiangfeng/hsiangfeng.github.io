[{"data":1,"prerenderedAt":175},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200707\u002F621122962\u002F":3,"page:\u002Fjavascript\u002F20200707\u002F621122962\u002F":4,"alt:\u002Fjavascript\u002F20200707\u002F621122962\u002F":3,"prev-next:\u002Fjavascript\u002F20200707\u002F621122962\u002F":150,"related:\u002Fjavascript\u002F20200707\u002F621122962\u002F":159},"\u002Fen\u002Fjavascript\u002F2020\u002F07\u002F07\u002Fpixijs-v5-22-debug-datgui\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":131,"date":132,"description":18,"extension":133,"lang":134,"meta":135,"navigation":136,"path":137,"readingMinutes":138,"seo":139,"standalone":140,"stem":141,"tags":142,"tldr":147,"updated":147,"url":148,"__hash__":149},"content\u002FPixiJS V5 教學\u002FPixiJS V5 教學 (22) - debug.md","PixiJS V5 教學 (22) - debug","621122962",{"type":9,"value":10,"toc":123},"minimark",[11,15,19,22,25,28,32,42,60,63,70,79,82,91,96,99,105,108,111],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來我們來認識一下該如何在 Pixi 上 debug。",[12,20,21],{"id":21},"debug",[16,23,24],{},"其實 Pixi 在開發上要做 debug 是一件非常困難的事情，因為 Pixi 的結構與 HTML、CSS 不同，沒辦法再 devTools 上面看到 Dom 結構以及調整相關參數，所以在開發上若想調整其實是一件非常困難的事情。",[16,26,27],{},"但是這一篇主要會稍微認識一下 dat.GUI 下一篇才會來實作加入。",[12,29,31],{"id":30},"datgui","dat.GUI",[16,33,34,35,41],{},"網路搜尋一下 PIXI 相關的開發工具的調整大多都會推薦 ",[36,37,31],"a",{"href":38,"rel":39},"https:\u002F\u002Fgithub.com\u002Fdataarts\u002Fdat.gui",[40],"nofollow"," 這套工具，滿多前輩都會推薦使用這套工具來做 Pixi 的 debug 工具",[43,44,45,53],"ul",{},[46,47,48],"li",{},[36,49,52],{"href":50,"rel":51},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10206023",[40],"Day18 超好用工具dat.GUI",[46,54,55],{},[36,56,59],{"href":57,"rel":58},"https:\u002F\u002Fithelp.ithome.com.tw\u002Farticles\u002F10192142",[40],"[PixiJS - Day-16] 使用 dat.GUI 工具除錯",[16,61,62],{},"此外 dat.GUI 強大之處不只在於 Pixi、Three.js 也可以使用，最厲害的莫過於開發 VR 時也可以使用",[16,64,65],{},[66,67],"img",{"alt":68,"src":69},"官方圖源","https:\u002F\u002Fraw.githubusercontent.com\u002Fdataarts\u002Fdat.guiVR\u002Fmaster\u002Fpreview.gif",[16,71,72,73,78],{},"如果對於 dat.GUI for VR 有興趣的話可以 ",[36,74,77],{"href":75,"rel":76},"https:\u002F\u002Fgithub.com\u002Fdataarts\u002Fdat.guiVR",[40],"點這裡"," 研究一下程式碼，它是開源的。",[16,80,81],{},"dat.GUI 最大特色在於我們可以圖形化介面調整相關參數及物件，否則我們正常開發時是必須要修改一次，然後存檔重新整理畫面，多次下來是會感到煩悶進而導致我們的開發效率低落。",[16,83,84,85,90],{},"在 ",[36,86,89],{"href":87,"rel":88},"https:\u002F\u002Fworkshop.chromeexperiments.com\u002Fexamples\u002Fgui\u002F#1--Basic-Usage",[40],"官方網站"," 上我們可以看到一些範例，我們可以透過修改左邊的浮動視窗來調整畫面上的圖案，例如 Message 以及 speed 等",[16,92,93],{},[66,94],{"alt":31,"src":95},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F2020-01-08_09-18-37.png",[16,97,98],{},"透過這個 gui 介面我們可以更方便的調整 PixiJS",[16,100,101],{},[66,102],{"alt":103,"src":104},"dat.GUI 操控","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FNodejs\u002F1578446433294.gif",[16,106,107],{},"那對於 dat.GUI 基本的認識就先到這裡，下一篇我們就來看一下該如何加入 dat.GUI 吧~",[12,109,110],{"id":110},"參考文獻",[43,112,113,118],{},[46,114,115],{},[36,116,52],{"href":50,"rel":117},[40],[46,119,120],{},[36,121,59],{"href":57,"rel":122},[40],{"title":124,"searchDepth":125,"depth":125,"links":126},"",2,[127,128,129,130],{"id":14,"depth":125,"text":14},{"id":21,"depth":125,"text":21},{"id":30,"depth":125,"text":31},{"id":110,"depth":125,"text":110},"JavaScript","2020-07-07 13:29:11","md","zh-Hant",{},true,"\u002Fpixijs-v5\u002Fpixijs-v5-(22)-debug","1",{"title":6,"description":18},false,"PixiJS V5 教學\u002FPixiJS V5 教學 (22) - debug",[143,144,131,145,146],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool",null,"\u002Fjavascript\u002F20200707\u002F621122962\u002F","1nBiu-xLtsjnXv_vai8jNLoyQeCfVNWSSvN2sAYTLSU",{"newer":151,"older":155},{"url":152,"title":153,"date":154},"\u002Fjavascript\u002F20200712\u002F753837712\u002F","JavaScript 核心觀念(21)-物件-物件結構","2020-07-12 15:18:00",{"url":156,"title":157,"date":158},"\u002Fjavascript\u002F20200705\u002F1509329654\u002F","JavaScript 核心觀念(20)-運算子、型別與文法-課後練習","2020-07-05 21: