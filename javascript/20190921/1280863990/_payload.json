[{"data":1,"prerenderedAt":751},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190921\u002F1280863990\u002F":3,"page:\u002Fjavascript\u002F20190921\u002F1280863990\u002F":4,"alt:\u002Fjavascript\u002F20190921\u002F1280863990\u002F":3,"prev-next:\u002Fjavascript\u002F20190921\u002F1280863990\u002F":726,"related:\u002Fjavascript\u002F20190921\u002F1280863990\u002F":735},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F21\u002Fre-zero-learning-js-06-operators\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":711,"date":712,"description":18,"extension":713,"lang":714,"meta":715,"navigation":190,"path":716,"readingMinutes":591,"seo":717,"standalone":718,"stem":719,"tags":720,"tldr":723,"updated":723,"url":724,"__hash__":725},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-6-RE：從零開始的學習-JS-生活-第六日.md","EP.6 RE：從零開始的學習 JS 生活-第六日之運算子","1280863990",{"type":9,"value":10,"toc":703},"minimark",[11,15,19,22,67,89,95,102,104,107,280,282,293,354,357,380,417,423,426,434,447,497,509,512,518,549,552,582,593,599,629,636,643,687,693,696,699],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第六日，這一篇將會來介紹運算子，雖然前面有接觸過一些運算子，但是這一篇會針對常見的運算子做一下介紹。",[12,20,21],{"id":21},"運算子",[16,23,24,25,29,30,33,34,37,38,41,42,45,46,49,50,53,54,57,58,61,62,66],{},"一般開發上，我們最常見的基本運算子就是等號運算子(",[26,27,28],"code",{},"=",")以及點運算子(",[26,31,32],{},".",")，那麼運算子其實還有其他種，例如加號運算子(",[26,35,36],{},"+",")、減號運算子(",[26,39,40],{},"-",")、乘號運算子(",[26,43,44],{},"*",")、除號運算子(",[26,47,48],{},"\u002F",")、遞增運算子(",[26,51,52],{},"++",")、遞減運算子(",[26,55,56],{},"--",")、餘數運算子(",[26,59,60],{},"%",")等等，而上述這幾個又稱之為",[63,64,65],"strong",{},"算術運算子","。",[16,68,69,70,73,74,77,78,81,82,85,86,66],{},"當然還有另一種運算子，分別為大於運算子(",[26,71,72],{},">",")、小於運算子(",[26,75,76],{},"\u003C",")、大於等於運算子(",[26,79,80],{},">=",")、小於等於運算子(",[26,83,84],{},"\u003C=",")等等，以上這幾種運算子則是稱之為",[63,87,88],{},"比較運算子",[16,90,91],{},[92,93],"img",{"alt":21,"src":94},"https:\u002F\u002Fi.imgur.com\u002FRTjQZm3.png",[16,96,97,98,101],{},"最後還有一個運算子，叫做",[63,99,100],{},"邏輯運算子","，但是再轉生第六日暫時先不學習。",[12,103,65],{"id":65},[16,105,106],{},"算術運算子在前面已經稍作介紹過，算術運算子顧名思義就是做計算的，所以我就直接來看範例比較快：",[108,109,114],"pre",{"className":110,"code":111,"language":112,"meta":113,"style":113},"language-js shiki shiki-themes github-dark-high-contrast","10 + 10; \u002F\u002F 20\n10 - 2; \u002F\u002F 8\n10 * 2; \u002F\u002F 20\n10 \u002F 2; \u002F\u002F 5\n\n\u002F\u002F 遞增運算子必須透過變數來增加\nvar a = 10;\na++; \u002F\u002F 11 ++ 代表 +1\n\nvar b = 10;\nb--; \u002F\u002F 9 -- 代表 -1\n\n10 % 4; \u002F\u002F 2\n","js","",[26,115,116,140,156,170,185,192,198,214,227,232,246,259,264],{"__ignoreMap":113},[117,118,121,125,129,132,136],"span",{"class":119,"line":120},"line",1,[117,122,124],{"class":123},"sCcAr","10",[117,126,128],{"class":127},"sWyjQ"," +",[117,130,131],{"class":123}," 10",[117,133,135],{"class":134},"sMAXC","; ",[117,137,139],{"class":138},"sQrFR","\u002F\u002F 20\n",[117,141,143,145,148,151,153],{"class":119,"line":142},2,[117,144,124],{"class":123},[117,146,147],{"class":127}," -",[117,149,150],{"class":123}," 2",[117,152,135],{"class":134},[117,154,155],{"class":138},"\u002F\u002F 8\n",[117,157,159,161,164,166,168],{"class":119,"line":158},3,[117,160,124],{"class":123},[117,162,163],{"class":127}," *",[117,165,150],{"class":123},[117,167,135],{"class":134},[117,169,139],{"class":138},[117,171,173,175,178,180,182],{"class":119,"line":172},4,[117,174,124],{"class":123},[117,176,177],{"class":127}," \u002F",[117,179,150],{"class":123},[117,181,135],{"class":134},[117,183,184],{"class":138},"\u002F\u002F 5\n",[117,186,188],{"class":119,"line":187},5,[117,189,191],{"emptyLinePlaceholder":190},true,"\n",[117,193,195],{"class":119,"line":194},6,[117,196,197],{"class":138},"\u002F\u002F 遞增運算子必須透過變數來增加\n",[117,199,201,204,207,209,211],{"class":119,"line":200},7,[117,202,203],{"class":127},"var",[117,205,206],{"class":134}," a ",[117,208,28],{"class":127},[117,210,131],{"class":123},[117,212,213],{"class":134},";\n",[117,215,217,220,222,224],{"class":119,"line":216},8,[117,218,219],{"class":134},"a",[117,221,52],{"class":127},[117,223,135],{"class":134},[117,225,226],{"class":138},"\u002F\u002F 11 ++ 代表 +1\n",[117,228,230],{"class":119,"line":229},9,[117,231,191],{"emptyLinePlaceholder":190},[117,233,235,237,240,242,244],{"class":119,"line":234},10,[117,236,203],{"class":127},[117,238,239],{"class":134}," b ",[117,241,28],{"class":127},[117,243,131],{"class":123},[117,245,213],{"class":134},[117,247,249,252,254,256],{"class":119,"line":248},11,[117,250,251],{"class":134},"b",[117,253,56],{"class":127},[117,255,135],{"class":134},[117,257,258],{"class":138},"\u002F\u002F 9 -- 代表 -1\n",[117,260,262],{"class":119,"line":261},12,[117,263,191],{"emptyLinePlaceholder":190},[117,265,267,269,272,275,277],{"class":119,"line":266},13,[117,268,124],{"class":123},[117,270,271],{"class":127}," %",[117,273,274],{"class":123}," 4",[117,276,135],{"class":134},[117,278,279],{"class":138},"\u002F\u002F 2\n",[12,281,88],{"id":88},[16,283,284,285,288,289,292],{},"而比較運算子就是在兩者之間或複數之間做出一個比較，比較後將會回傳布林值，也就是 ",[26,286,287],{},"true"," or ",[26,290,291],{},"false","，所以這邊讓我們直接來看一下範例：",[108,294,296],{"className":110,"code":295,"language":112,"meta":113,"style":113},"10 > 5; \u002F\u002F true\n10 \u003C 5; \u002F\u002F false\n10 >= 10; \u002F\u002F true，若是 10 > 10; 則為 false\n10 \u003C= 5; \u002F\u002F false\n",[26,297,298,313,327,341],{"__ignoreMap":113},[117,299,300,302,305,308,310],{"class":119,"line":120},[117,301,124],{"class":123},[117,303,304],{"class":127}," >",[117,306,307],{"class":123}," 5",[117,309,135],{"class":134},[117,311,312],{"class":138},"\u002F\u002F true\n",[117,314,315,317,320,322,324],{"class":119,"line":142},[117,316,124],{"class":123},[117,318,319],{"class":127}," \u003C",[117,321,307],{"class":123},[117,323,135],{"class":134},[117,325,326],{"class":138},"\u002F\u002F false\n",[117,328,329,331,334,336,338],{"class":119,"line":158},[117,330,124],{"class":123},[117,332,333],{"class":127}," >=",[117,335,131],{"class":123},[117,337,135],{"class":134},[117,339,340],{"class":138},"\u002F\u002F true，若是 10 > 10; 則為 false\n",[117,342,343,345,348,350,352],{"class":119,"line":172},[117,344,124],{"class":123},[117,346,347],{"class":127}," \u003C=",[117,349,307],{"class":123},[117,351,135],{"class":134},[117,353,326],{"class":138},[16,355,356],{},"另外比較運算子中還有幾個常見的運算子，分別為",[358,359,360,371],"ul",{},[361,362,363,366,367,370],"li",{},[26,364,365],{},"=="," & ",[26,368,369],{},"==="," - 相等運算子",[361,372,373,366,376,379],{},[26,374,375],{},"!=",[26,377,378],{},"!=="," - 不相等運算子",[16,381,382,383,366,385,387,388,366,390,392,393,366,395,397,398,401,402,404,405,366,407,409,410,413,414,416],{},"那你可能會好奇等於預算子的 ",[26,384,365],{},[26,386,375],{}," 與 ",[26,389,369],{},[26,391,378],{}," 有什麼差別，簡單來講 ",[26,394,365],{},[26,396,375],{}," 就是寬鬆比對，當你輸入 ",[26,399,400],{},"1 == '1';"," 會得到 ",[26,403,287],{},"，那 ",[26,406,369],{},[26,408,378],{}," 就是嚴格比對，會連型別都替你做比對，所以當你輸入 ",[26,411,412],{},"1 === '1';"," 是會得到 ",[26,415,291],{}," 的。",[16,418,419],{},[92,420],{"alt":421,"src":422},"嚴格比對與寬鬆比對","https:\u002F\u002Fi.imgur.com\u002FCxx3LDa.png",[16,424,425],{},"實際開發也會建議使用嚴格比對取代寬鬆比對，所以我們就可以這樣子整理",[358,427,428,431],{},[361,429,430],{},"一般相等 or 不相等 (寬鬆比對)",[361,432,433],{},"嚴格相等 or 不相等 (嚴格比對)",[16,435,436,437,440,441,443,444,446],{},"另外還有另一個特別的語法，也就是 ",[26,438,439],{},"Object.is","，",[26,442,439],{}," 是 ES6 才加入的語法，但是 ",[26,445,439],{}," 是屬於嚴格比對：",[108,448,450],{"className":110,"code":449,"language":112,"meta":113,"style":113},"Object.is(1, '1'); \u002F\u002F false\nObject.is('1', '1'); \u002F\u002F true\n",[26,451,452,479],{"__ignoreMap":113},[117,453,454,457,461,464,467,470,474,477],{"class":119,"line":120},[117,455,456],{"class":134},"Object.",[117,458,460],{"class":459},"sj_SG","is",[117,462,463],{"class":134},"(",[117,465,466],{"class":123},"1",[117,468,469],{"class":134},", ",[117,471,473],{"class":472},"sTRMh","'1'",[117,475,476],{"class":134},"); ",[117,478,326],{"class":138},[117,480,481,483,485,487,489,491,493,495],{"class":119,"line":142},[117,482,456],{"class":134},[117,484,460],{"class":459},[117,486,463],{"class":134},[117,488,473],{"class":472},[117,490,469],{"class":134},[117,492,473],{"class":472},[117,494,476],{"class":134},[117,496,312],{"class":138},[16,498,499,500,502,503],{},"關於 ",[26,501,439],{}," 這個語法可以看 MDN 提供的",[219,504,508],{"href":505,"rel":506},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-CN\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FGlobal_Objects\u002FObject\u002Fis",[507],"nofollow","文件說明",[12,510,511],{"id":511},"字串相加運算子",[16,513,514,515,517],{},"最後在講一個特別的運算子，也就是加號運算子(",[26,516,36],{},")，其實加號運算子它非常特別，除了可以當作算術運算子之外，它當作字串相加運算子可以將兩個字串相加，例如：",[108,519,521],{"className":110,"code":520,"language":112,"meta":113,"style":113},"var a = 'Hello' + ' World';\na; \u002F\u002F Hello World\n",[26,522,523,541],{"__ignoreMap":113},[117,524,525,527,529,531,534,536,539],{"class":119,"line":120},[117,526,203],{"class":127},[117,528,206],{"class":134},[117,530,28],{"class":127},[117,532,533],{"class":472}," 'Hello'",[117,535,128],{"class":127},[117,537,538],{"class":472}," ' World'",[117,540,213],{"class":134},[117,542,543,546],{"class":119,"line":142},[117,544,545],{"class":134},"a; ",[117,547,548],{"class":138},"\u002F\u002F Hello World\n",[16,550,551],{},"但是有一種狀況是一個是數字型別，另一個則是字串型別的狀況，前面我們知道加號運算子可以對數字相加，但是如果是這樣子的形式會發生什麼狀況呢?",[108,553,555],{"className":110,"code":554,"language":112,"meta":113,"style":113},"var a = 1 + '1';\na; \u002F\u002F 11\n",[26,556,557,575],{"__ignoreMap":113},[117,558,559,561,563,565,568,570,573],{"class":119,"line":120},[117,560,203],{"class":127},[117,562,206],{"class":134},[117,564,28],{"class":127},[117,566,567],{"class":123}," 1",[117,569,128],{"class":127},[117,571,572],{"class":472}," '1'",[117,574,213],{"class":134},[117,576,577,579],{"class":119,"line":142},[117,578,545],{"class":134},[117,580,581],{"class":138},"\u002F\u002F 11\n",[16,583,584,585,588,589,592],{},"其實會得到 ",[26,586,587],{},"11"," 而不是 ",[26,590,591],{},"2","，理解的方式很簡單，只要裡面有字串(也就是有單引號或雙引號包覆)，那麼就一定會是字串相加。",[16,594,595,596,598],{},"但是這邊也有一個滿特別的狀況，如果你改成減號運算子(",[26,597,40],{},")，那就會變得很妙：",[108,600,604],{"className":601,"code":602,"language":603,"meta":113,"style":113},"language-JS shiki shiki-themes github-dark-high-contrast","var a = 1 - '1';\na; \u002F\u002F 0\n","JS",[26,605,606,622],{"__ignoreMap":113},[117,607,608,610,612,614,616,618,620],{"class":119,"line":120},[117,609,203],{"class":127},[117,611,206],{"class":134},[117,613,28],{"class":127},[117,615,567],{"class":123},[117,617,147],{"class":127},[117,619,572],{"class":472},[117,621,213],{"class":134},[117,623,624,626],{"class":119,"line":142},[117,625,545],{"class":134},[117,627,628],{"class":138},"\u002F\u002F 0\n",[16,630,631,632,635],{},"你會發現竟然會得到答案 ",[26,633,634],{},"0","，那這部分與 JavaScript 的自動轉換型別有關係，後面會在介紹這個東西。",[16,637,638,639,642],{},"最後如果你嘗試使用字串與字串做乘法的動作，只會得到一個錯誤訊息，也就是 ",[26,640,641],{},"NaN","，而這意思是指 not a number 就是在說這不是一個數字：",[108,644,646],{"className":110,"code":645,"language":112,"meta":113,"style":113},"var a = 'qq';\nvar b = 'aa';\na * b; \u002F\u002F NaN\n",[26,647,648,661,674],{"__ignoreMap":113},[117,649,650,652,654,656,659],{"class":119,"line":120},[117,651,203],{"class":127},[117,653,206],{"class":134},[117,655,28],{"class":127},[117,657,658],{"class":472}," 'qq'",[117,660,213],{"class":134},[117,662,663,665,667,669,672],{"class":119,"line":142},[117,664,203],{"class":127},[117,666,239],{"class":134},[117,668,28],{"class":127},[117,670,671],{"class":472}," 'aa'",[117,673,213],{"class":134},[117,675,676,679,681,684],{"class":119,"line":158},[117,677,678],{"class":134},"a ",[117,680,44],{"class":127},[117,682,683],{"class":134}," b; ",[117,685,686],{"class":138},"\u002F\u002F NaN\n",[16,688,689],{},[92,690],{"alt":691,"src":692},"not a number","https:\u002F\u002Fi.imgur.com\u002Fonyaybn.png",[12,694,695],{"id":695},"結尾",[16,697,698],{},"下一篇的 RE：從零開始的學習 JS 生活-第六日 將會介紹函式。",[700,701,702],"style",{},"html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}ht