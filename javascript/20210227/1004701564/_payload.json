,"line":389},[37,998,392],{"class":43},[37,1000,395],{"class":51},[37,1002,72],{"class":43},[37,1004,400],{"class":43},[37,1006,188],{"class":47},[37,1008,52],{"class":51},[37,1010,407],{"class":75},[37,1012,196],{"class":51},[37,1014,412],{"class":75},[37,1016,196],{"class":51},[37,1018,417],{"class":75},[37,1020,170],{"class":51},[16,1022,1023],{},"首先我們在一開始的 bibi (實體) 時有說到，當它向上查找會找到 Dog 的原型",[27,1025,1027],{"className":29,"code":1026,"language":31,"meta":32,"style":32},"bibi.__proto__ === Dog.prototype; \u002F\u002F true\n",[34,1028,1029],{"__ignoreMap":32},[37,1030,1031,1034,1036,1039,1041,1043,1045,1047],{"class":39,"line":40},[37,1032,1033],{"class":51},"bibi.",[37,1035,461],{"class":65},[37,1037,1038],{"class":43}," ===",[37,1040,188],{"class":65},[37,1042,127],{"class":51},[37,1044,130],{"class":65},[37,1046,101],{"class":51},[37,1048,1049],{"class":104},"\u002F\u002F true\n",[16,1051,1052,1053,1056,1057,1060],{},"這邊要注意請不要輸入 ",[34,1054,1055],{},"bibi.__proto__ === Dog;"," 這樣除了結果會是 ",[34,1058,1059],{},"false"," 之外，最主要原因是，你是指向到這個函式，而不是狗的原型",[16,1062,1063],{},"那麼接下來我們還可以向上查找",[27,1065,1067],{"className":29,"code":1066,"language":31,"meta":32,"style":32},"bibi.__proto__.__proto__ === Animal.prototype; \u002F\u002F true\n",[34,1068,1069],{"__ignoreMap":32},[37,1070,1071,1073,1075,1077,1079,1081,1083,1085,1087,1089],{"class":39,"line":40},[37,1072,1033],{"class":51},[37,1074,461],{"class":65},[37,1076,127],{"class":51},[37,1078,461],{"class":65},[37,1080,1038],{"class":43},[37,1082,48],{"class":65},[37,1084,127],{"class":51},[37,1086,130],{"class":65},[37,1088,101],{"class":51},[37,1090,1049],{"class":104},[16,1092,1093,1094,1097,1098,1101,1102,1104,1105],{},"而目前 bibi 已經向上爬了兩層，因此你可以將第一層 ",[34,1095,1096],{},"bibi.__proto__"," 看成 ",[34,1099,1100],{},"Dog.prototype.__proto__ === Animal.prototype \u002F\u002F true","，而這邊我們也可以驗證繼承來的 ",[34,1103,326],{}," 是否就等於 Animal 的 ",[34,1106,326],{},[27,1108,1110],{"className":29,"code":1109,"language":31,"meta":32,"style":32},"bibi.__proto__.__proto__.constructor === Animal; \u002F\u002F true\n",[34,1111,1112],{"__ignoreMap":32},[37,1113,1114,1116,1118,1120,1122,1124,1126,1128,1131],{"class":39,"line":40},[37,1115,1033],{"class":51},[37,1117,461],{"class":65},[37,1119,127],{"class":51},[37,1121,461],{"class":65},[37,1123,127],{"class":51},[37,1125,326],{"class":65},[37,1127,1038],{"class":43},[37,1129,1130],{"class":51}," Animal; ",[37,1132,1049],{"class":104},[16,1134,1135,1136,1138],{},"最後我們再來驗證如果再持續向上查找原型會找到 ",[34,1137,628],{}," 的原始型別這個觀念",[27,1140,1142],{"className":29,"code":1141,"language":31,"meta":32,"style":32},"\u002F\u002F 第一層是 Dog -> bibi.__proto__ -> Dog.prototype\n\u002F\u002F 第二層是 Animal -> bibi.__proto__.__proto__ -> Animal.prototype\n\u002F\u002F 第三層是 Object -> bibi.__proto__.__proto__.__proto__ -> Object.prototype\nbibi.__proto__.__proto__.__proto__.__proto__ === null; \u002F\u002F true\n",[34,1143,1144,1149,1154,1159],{"__ignoreMap":32},[37,1145,1146],{"class":39,"line":40},[37,1147,1148],{"class":104},"\u002F\u002F 第一層是 Dog -> bibi.__proto__ -> Dog.prototype\n",[37,1150,1151],{"class":39,"line":62},[37,1152,1153],{"class":104},"\u002F\u002F 第二層是 Animal -> bibi.__proto__.__proto__ -> Animal.prototype\n",[37,1155,1156],{"class":39,"line":82},[37,1157,1158],{"class":104},"\u002F\u002F 第三層是 Object -> bibi.__proto__.__proto__.__proto__ -> Object.prototype\n",[37,1160,1161,1163,1165,1167,1169,1171,1173,1175,1177,1179,1182,1184],{"class":39,"line":108},[37,1162,1033],{"class":51},[37,1164,461],{"class":65},[37,1166,127],{"class":51},[37,1168,461],{"class":65},[37,1170,127],{"class":51},[37,1172,461],{"class":65},[37,1174,127],{"class":51},[37,1176,461],{"class":65},[37,1178,1038],{"class":43},[37,1180,1181],{"class":65}," null",[37,1183,101],{"class":51},[37,1185,1049],{"class":104},[16,1187,1188],{},"而這邊函式的部分就不再次說明，直接提供程式碼看結果",[27,1190,1192],{"className":29,"code":1191,"language":31,"meta":32,"style":32},"Dog.__proto__ === Function.prototype; \u002F\u002F true\nAnimal.__proto__ === Function.prototype; \u002F\u002F true\nObject.__proto__ === Function.prototype; \u002F\u002F true\n",[34,1193,1194,1214,1233],{"__ignoreMap":32},[37,1195,1196,1199,1201,1203,1206,1208,1210,1212],{"class":39,"line":40},[37,1197,1198],{"class":51},"Dog.",[37,1200,461],{"class":65},[37,1202,1038],{"class":43},[37,1204,1205],{"class":65}," Function",[37,1207,127],{"class":51},[37,1209,130],{"class":65},[37,1211,101],{"class":51},[37,1213,1049],{"class":104},[37,1215,1216,1219,1221,1223,1225,1227,1229,1231],{"class":39,"line":62},[37,1217,1218],{"class":51},"Animal.",[37,1220,461],{"class":65},[37,1222,1038],{"class":43},[37,1224,1205],{"class":65},[37,1226,127],{"class":51},[37,1228,130],{"class":65},[37,1230,101],{"class":51},[37,1232,1049],{"class":104},[37,1234,1235,1238,1240,1242,1244,1246,1248,1250],{"class":39,"line":82},[37,1236,1237],{"class":51},"Object.",[37,1239,461],{"class":65},[37,1241,1038],{"class":43},[37,1243,1205],{"class":65},[37,1245,127],{"class":51},[37,1247,130],{"class":65},[37,1249,101],{"class":51},[37,1251,1049],{"class":104},[16,1253,1254,1255,1257],{},"因此函式可以使用 ",[34,1256,130],{}," 都是來是 Function 的原型",[16,1259,1260,1261,1263],{},"最後的最後 ",[34,1262,702],{}," 本身也是繼承於物件",[27,1265,1267],{"className":29,"code":1266,"language":31,"meta":32,"style":32},"Function.__proto__.__proto__ === Object.prototype; \u002F\u002F true\n",[34,1268,1269],{"__ignoreMap":32},[37,1270,1271,1274,1276,1278,1280,1282,1285,1287,1289,1291],{"class":39,"line":40},[37,1272,1273],{"class":51},"Function.",[37,1275,461],{"class":65},[37,1277,127],{"class":51},[37,1279,461],{"class":65},[37,1281,1038],{"class":43},[37,1283,1284],{"class":65}," Object",[37,1286,127],{"class":51},[37,1288,130],{"class":65},[37,1290,101],{"class":51},[37,1292,1049],{"class":104},[12,1294,1295],{"id":1295},"參考文獻",[1297,1298,1299],"ul",{},[1300,1301,1302],"li",{},[1303,1304,1308],"a",{"href":1305,"rel":1306},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[1307],"nofollow","J