[{"data":1,"prerenderedAt":186},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200803\u002F1097420950\u002F":3,"page:\u002Fjavascript\u002F20200803\u002F1097420950\u002F":4,"alt:\u002Fjavascript\u002F20200803\u002F1097420950\u002F":3,"prev-next:\u002Fjavascript\u002F20200803\u002F1097420950\u002F":161,"related:\u002Fjavascript\u002F20200803\u002F1097420950\u002F":170},"\u002Fen\u002Fjavascript\u002F2020\u002F08\u002F03\u002Fpixijs-v5-26-treasure-hunter\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":142,"date":143,"description":18,"extension":144,"lang":145,"meta":146,"navigation":147,"path":148,"readingMinutes":149,"seo":150,"standalone":151,"stem":152,"tags":153,"tldr":158,"updated":158,"url":159,"__hash__":160},"content\u002FPixiJS V5 教學\u002FPixiJS V5 教學 (26) - 寶藏獵人.md","PixiJS V5 教學 (26) - 寶藏獵人","1097420950",{"type":9,"value":10,"toc":132},"minimark",[11,15,19,22,33,36,44,51,57,63,69,75,78,84,93,96,99,102,115,118],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來我們將會開始整合一些前面的技巧來製作一個小遊戲。",[12,20,21],{"id":21},"素材來源",[16,23,24,25,32],{},"接下來所有遊戲素材將會來至 ",[26,27,31],"a",{"href":28,"rel":29},"https:\u002F\u002Fgithub.com\u002FZainking\u002FLearningPixi",[30],"nofollow","LearningPixi"," 這一份中文 PIXI 教學文件，不可否認這是一份非常棒的教學文件，我所撰寫的這個系列中許多地方也次參考這一份，所以就會直接使用該專案提供的現成遊戲素材製作。",[12,34,35],{"id":35},"素材",[16,37,38,39,43],{},"素材主要都是放在 ",[40,41,42],"code",{},"examples\\images"," 底下，主要會使用到的素材有這幾張",[16,45,46],{},[47,48],"img",{"alt":49,"src":50},"blob.png - 怪物","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Flearnexp\u002FLearningPixi\u002Fblob.png",[16,52,53],{},[47,54],{"alt":55,"src":56},"door.png - 門","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Flearnexp\u002FLearningPixi\u002Fdoor.png",[16,58,59],{},[47,60],{"alt":61,"src":62},"dungeon.png - 背景","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Flearnexp\u002FLearningPixi\u002Fdungeon.png",[16,64,65],{},[47,66],{"alt":67,"src":68},"explorer.png - 玩家","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Flearnexp\u002FLearningPixi\u002Fexplorer.png",[16,70,71],{},[47,72],{"alt":73,"src":74},"treasure.png - 寶藏","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Flearnexp\u002FLearningPixi\u002Ftreasure.png",[16,76,77],{},"最後還有一個整合的大圖",[16,79,80],{},[47,81],{"alt":82,"src":83},"treasureHunter.png - 寶藏獵人","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002Flearnexp\u002FLearningPixi\u002FtreasureHunter.png",[16,85,86,87,92],{},"另外作者的文章也有提到，若你想挑戰其他素質也可以到原文作者的 ",[26,88,91],{"href":89,"rel":90},"https:\u002F\u002Fopengameart.org\u002Fusers\u002Fsharm",[30],"Lanea Zimmerman 工作室"," 取得。",[12,94,95],{"id":95},"其他檔案",[16,97,98],{},"在準備素材期間我們可以注意到一件事情，examples 的 images 底下我們還可以發現有一個 treasureHunter.json，treasureHunter.json 的用途是為了方面我們去對應 treasureHunter.png 每一張圖的位子，假使若我們今天開發的遊戲是一個非常龐大且複雜，那麼一張一張載入圖片是非常麻煩的行為，所以通常來講都會使用 JSON 格式去加載圖片，將來若需要調整一些細節也只需要調整這個 JSON 即可。",[12,100,101],{"id":101},"結尾",[16,103,104,105,108,109,114],{},"OK，我相信你應該已經覺得複雜了，所以我們先暫停一下，先來做一些基礎練習，在 ",[26,106,31],{"href":28,"rel":107},[30]," 也有提供簡單的 ",[26,110,113],{"href":111,"rel":112},"https:\u002F\u002Fgithub.com\u002FZainking\u002FLearningPixi#%E4%BB%8E%E7%B2%BE%E7%81%B5%E5%9B%BE%E9%9B%AA%E7%A2%A7%E5%9B%BE%E4%B8%AD%E5%88%9B%E5%BB%BA%E7%B2%BE%E7%81%B5%E4%B8%BA%E4%BA%86%E9%98%B2%E6%AD%A2%E4%B8%8E%E7%B2%BE%E7%81%B5%E6%B7%B7%E6%B7%86%E6%88%91%E5%9C%A8%E4%B9%8B%E5%90%8E%E7%9A%84%E8%AF%91%E6%96%87%E4%B8%AD%E9%83%BD%E5%B0%86%E9%87%87%E7%94%A8%E9%9B%AA%E7%A2%A7%E5%9B%BE%E8%BF%99%E4%B8%80%E8%AF%91%E6%B3%95",[30],"練習","，雖然我們在前面已經知道該如何單張及多張圖片的加載，但是透過 JSON 來加載卻沒有練習到，所以接下來我們會先來練習如何透過一張圖片並使用 JSON 加載圖片吧!",[12,116,117],{"id":117},"參考文獻",[119,120,121,127],"ul",{},[122,123,124],"li",{},[26,125,31],{"href":28,"rel":126},[30],[122,128,129],{},[26,130,91],{"href":89,"rel":131},[30],{"title":133,"searchDepth":134,"depth":134,"links":135},"",2,[136,137,138,139,140,141],{"id":14,"depth":134,"text":14},{"id":21,"depth":134,"text":21},{"id":35,"depth":134,"text"