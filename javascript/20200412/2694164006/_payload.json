[{"data":1,"prerenderedAt":493},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200412\u002F2694164006\u002F":3,"page:\u002Fjavascript\u002F20200412\u002F2694164006\u002F":4,"alt:\u002Fjavascript\u002F20200412\u002F2694164006\u002F":3,"prev-next:\u002Fjavascript\u002F20200412\u002F2694164006\u002F":468,"related:\u002Fjavascript\u002F20200412\u002F2694164006\u002F":477},"\u002Fen\u002Fjavascript\u002F2020\u002F04\u002F12\u002Fjavascript-core-03-lexical-scope\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":452,"date":453,"description":18,"extension":454,"lang":455,"meta":456,"navigation":165,"path":457,"readingMinutes":458,"seo":459,"standalone":460,"stem":461,"tags":462,"tldr":465,"updated":465,"url":466,"__hash__":467},"content\u002FJavaScript 核心觀念\u002F1.執行環境與作用域\u002FJavaScript-核心觀念-3-執行環境與作用域-語法作用域.md","JavaScript 核心觀念(3)-執行環境與作用域-語法作用域","2694164006",{"type":9,"value":10,"toc":446},"minimark",[11,15,19,22,28,31,34,37,105,108,111,179,183,186,192,195,201,204,207,305,330,333,409,426,429,442],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"JavaScript 採用的是語法作用域，所謂的語法作用域就是你宣告時就已經決定好他的作用域。",[12,20,21],{"id":21},"語法作用域",[16,23,24],{},[25,26],"img",{"alt":21,"src":27},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-04-12%2015.50.21.png",[16,29,30],{},"語法作用域是 JavaScript 中的一個很重要的觀念，當你在宣告語法時，就已經決定了他作用域，在這邊先提一下什麼叫做作用域",[16,32,33],{},"所謂的語法作用域就是它實際存在的位置，例如所謂的全域環境及區域環境。",[16,35,36],{},"這邊舉例一個區域環境的範例",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-themes github-dark-high-contrast","function sayHi() {\n  var name = 'Ray';\n}\nconsole.log(name); \u002F\u002F name is not defined;\n","js","",[45,46,47,64,83,89],"code",{"__ignoreMap":43},[48,49,52,56,60],"span",{"class":50,"line":51},"line",1,[48,53,55],{"class":54},"sWyjQ","function",[48,57,59],{"class":58},"sj_SG"," sayHi",[48,61,63],{"class":62},"sMAXC","() {\n",[48,65,67,70,73,76,80],{"class":50,"line":66},2,[48,68,69],{"class":54},"  var",[48,71,72],{"class":62}," name ",[48,74,75],{"class":54},"=",[48,77,79],{"class":78},"sTRMh"," 'Ray'",[48,81,82],{"class":62},";\n",[48,84,86],{"class":50,"line":85},3,[48,87,88],{"class":62},"}\n",[48,90,92,95,98,101],{"class":50,"line":91},4,[48,93,94],{"class":62},"console.",[48,96,97],{"class":58},"log",[48,99,100],{"class":62},"(name); ",[48,102,104],{"class":103},"sQrFR","\u002F\u002F name is not defined;\n",[16,106,107],{},"當語法宣告位置是在函式內，你將會無法取用。",[16,109,110],{},"除此之外函式也會受到語法作用域影響",[38,112,114],{"className":40,"code":113,"language":42,"meta":43,"style":43},"function sayHi() {\n  function sayName() {\n    console.log('Ray');\n  }\n}\n\nsayName(); \u002F\u002F sayName is not defined;\n",[45,115,116,124,134,150,155,160,167],{"__ignoreMap":43},[48,117,118,120,122],{"class":50,"line":51},[48,119,55],{"class":54},[48,121,59],{"class":58},[48,123,63],{"class":62},[48,125,126,129,132],{"class":50,"line":66},[48,127,128],{"class":54},"  function",[48,130,131],{"class":58}," sayName",[48,133,63],{"class":62},[48,135,136,139,141,144,147],{"class":50,"line":85},[48,137,138],{"class":62},"    console.",[48,140,97],{"class":58},[48,142,143],{"class":62},"(",[48,145,146],{"class":78},"'Ray'",[48,148,149],{"class":62},");\n",[48,151,152],{"class":50,"line":91},[48,153,154],{"class":62},"  }\n",[48,156,158],{"class":50,"line":157},5,[48,159,88],{"class":62},[48,161,163],{"class":50,"line":162},6,[48,164,166],{"emptyLinePlaceholder":165},true,"\n",[48,168,170,173,176],{"class":50,"line":169},7,[48,171,172],{"class":58},"sayName",[48,174,175],{"class":62},"(); ",[48,177,178],{"class":103},"\u002F\u002F sayName is not defined;\n",[12,180,182],{"id":181},"靜態作用域-動態作用域","靜態作用域 & 動態作用域",[16,184,185],{},"說到語法作用域就又會牽扯到 JavaScript 的運作方式，其中 JavaScript 就屬於靜態作用域，所謂的靜態作用域的意思就是當語法解析時就決定了作用域。",[16,187,188],{},[25,189],{"alt":190,"src":191},"靜態作用域","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-04-12%2015.53.54.png",[16,193,194],{},"而動態作用域則是相反，動態作用域只有在函式呼叫的時候才會決定它的作用域",[16,196,197],{},[25,198],{"alt":199,"src":200},"重點整理","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-04-12%2015.55.14.png",[16,202,203],{},"舉例來講大多數程式語言都是採用靜態作用域，例如：C、C++、C#、Python、Java 等等就是採用靜態作用域。",[16,205,206],{},"這邊舉例來講因為 JavaScript 採用的是靜態作用域，所以當程式碼在運行時，就已經決定了作用域，在前面已經重複很多，所以這邊提供範例程式碼",[38,208,210],{"className":40,"code":209,"language":42,"meta":43,"style":43},"var value = 1; \u002F\u002F 全域變數\nfunction fu1 {\n  console.log(value); \u002F\u002F 1\n}\nfunction fu2 {\n  var value = 2; \u002F\u002F 區域變數\n  fu1();\n}\nfu2();\n",[45,211,212,232,242,255,259,268,284,292,297],{"__ignoreMap":43},[48,213,214,217,220,222,226,229],{"class":50,"line":51},[48,215,216],{"class":54},"var",[48,218,219],{"class":62}," value ",[48,221,75],{"class":54},[48,223,225],{"class":224},"sCcAr"," 1",[48,227,228],{"class":62},"; ",[48,230,231],{"class":103},"\u002F\u002F 全域變數\n",[48,233,234,236,239],{"class":50,"line":66},[48,235,55],{"class":54},[48,237,238],{"class":58}," fu1",[48,240,241],{"class":62}," {\n",[48,243,244,247,249,252],{"class":50,"line":85},[48,245,246],{"class":62},"  console.",[48,248,97],{"class":58},[48,250,251],{"class":62},"(value); ",[48,253,254],{"class":103},"\u002F\u002F 1\n",[48,256,257],{"class":50,"line":91},[48,258,88],{"class":62},[48,260,261,263,266],{"class":50,"line":157},[48,262,55],{"class":54},[48,264,265],{"class":58}," fu2",[48,267,241],{"class":62},[48,269,270,272,274,276,279,281],{"class":50,"line":162},[48,271,69],{"class":54},[48,273,219],{"class":62},[48,275,75],{"class":54},[48,277,278],{"class":224}," 2",[48,280,228],{"class":62},[48,282,283],{"class":103},"\u002F\u002F 區域變數\n",[48,285,286,289],{"class":50,"line":169},[48,287,288],{"class":58},"  fu1",[48,290,291],{"class":62},"();\n",[48,293,295],{"class":50,"line":294},8,[48,296,88],{"class":62},[48,298,300,303],{"class":50,"line":299},9,[48,301,302],{"class":58},"fu2",[48,304,291],{"class":62},[16,306,307,308,310,311,314,315,317,318,321,322,325,326,329],{},"在前面有講到當程式碼運行時，就已經決定了程式碼的作用域，所以在 ",[45,309,302],{}," 中的 ",[45,312,313],{},"var value = 2"," 就只會存活於 ",[45,316,302],{}," 中，而 ",[45,319,320],{},"var value = 1;"," 則是全域環境，所以 ",[45,323,324],{},"fu1"," 才會出現 ",[45,327,328],{},"1","，在這邊也會有額外的觀念，也就是所謂的範圍鍊，這個觀念後面再提，只需要了解到一件事情，當「當前作用域沒有這個變數時 JavaScript 將會一層一層向外查找」。",[16,331,332],{},"那動態作用域呢？動態作用域「只有當程式碼運行時才會知道作用域」",[38,334,336],{"className":40,"code":335,"language":42,"meta":43,"style":43},"var value = 1;\nfunction fu1 {\n  console.log(value); \u002F\u002F 2\n}\nfunction fu2 {\n  var value = 2;\n  fu1();\n}\nfu2();\n",[45,337,338,350,358,369,373,381,393,399,403],{"__ignoreMap":43},[48,339,340,342,344,346,348],{"class":50,"line":51},[48,341,216],{"class":54},[48,343,219],{"class":62},[48,345,75],{"class":54},[48,347,225],{"class":224},[48,349,82],{"class":62},[48,351,352,354,356],{"class":50,"line":66},[48,353,55],{"class":54},[48,355,238],{"class":58},[48,357,241],{"class":62},[48,359,360,362,364,366],{"class":50,"line":85},[48,361,246],{"class":62},[48,363,97],{"class":58},[48,365,251],{"class":62},[48,367,368],{"class":103},"\u002F\u002F 2\n",[48,370,371],{"class":50,"line":91},[48,372,88],{"class":62},[48,374,375,377,379],{"class":50,"line":157},[48,376,55],{"class":54},[48,378,265],{"class":58},[48,380,241],{"class":62},[48,382,383,385,387,389,391],{"class":50,"line":162},[48,384,69],{"class":54},[48,386,219],{"class":62},[48,388,75],{"class":54},[48,390,278],{"class":224},[48,392,82],{"class":62},[48,394,395,397],{"class":50,"line":169},[48,396,288],{"class":58},[48,398,291],{"class":62},[48,400,401],{"class":50,"line":294},[48,402,88],{"class":62},[48,404,405,407],{"class":50,"line":299},[48,406,302],{"class":58},[48,408,291],{"class":62},[16,410