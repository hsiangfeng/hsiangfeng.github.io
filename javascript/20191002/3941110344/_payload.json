[{"data":1,"prerenderedAt":170},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20191002\u002F3941110344\u002F":3,"page:\u002Fjavascript\u002F20191002\u002F3941110344\u002F":4,"alt:\u002Fjavascript\u002F20191002\u002F3941110344\u002F":3,"prev-next:\u002Fjavascript\u002F20191002\u002F3941110344\u002F":145,"related:\u002Fjavascript\u002F20191002\u002F3941110344\u002F":154},"\u002Fen\u002Fjavascript\u002F2019\u002F10\u002F02\u002Fjs-from-zero-ep17-cookie\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":128,"date":129,"description":18,"extension":130,"lang":131,"meta":132,"navigation":133,"path":134,"readingMinutes":135,"seo":136,"standalone":137,"stem":138,"tags":139,"tldr":142,"updated":142,"url":143,"__hash__":144},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-17-RE：從零開始的學習-JS-生活-第十七日.md","EP.17 RE：從零開始的學習 JS 生活-第十七日之 Cookie","3941110344",{"type":9,"value":10,"toc":120},"minimark",[11,15,19,23,26,36,39,42,52,55,59,67,70,77,84,87,93,96,102,114,117],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第十七日，這一篇將會介紹 Cookie。",[12,20,22],{"id":21},"cookie","Cookie",[16,24,25],{},"Cookie 中文又稱為餅乾，通常 Cookie 會很常見於與 Session 搭配，而最主要常見的場所是使用於帳號登入的部分，那 Cookie 其實又分為兩種",[27,28,29,33],"ul",{},[30,31,32],"li",{},"記憶體 Cookie",[30,34,35],{},"硬碟 Cookie",[16,37,38],{},"這兩種差異非常好辨認，首先記憶體 Cookie 會隨著使用者瀏覽器關閉而消失，而硬碟 Cookie 好比儲存空間(隨身硬碟 or 隨身碟等)，儲存我們的資料直到使用者手動清除，不然就是等到它的過期時間到期自動刪除，另外 Cookie 的大小限制在 4KB 左右，所以若太複雜是無法使用的。",[16,40,41],{},"那麼 Session 在實務上都會比較常見於記錄使用者 UUID 資訊，通常來講都會搭配 Cookie + Session 來達到驗證機制，進而避免偽造 Cookie。",[16,43,44,45],{},"更詳細的 Cookie & Session，我推薦這一篇文章 ",[46,47,51],"a",{"href":48,"rel":49},"https:\u002F\u002Fmedium.com\u002F@hulitw\u002Fsession-and-cookie-15e47ed838bc",[50],"nofollow","白話 Session 與 Cookie：從經營雜貨店開始",[16,53,54],{},"但是這篇會比較著重於 Cookie，畢竟 Session 是儲存在 Server 端。",[12,56,58],{"id":57},"cookie-cline-設置","Cookie Cline 設置",[16,60,61,62,66],{},"在 JavaScript 我們可以將 Cookie 給寫入到瀏覽器內，最主要的語法是使用到 ",[63,64,65],"code",{},"document.cookie","，並且還可以設置過期時間，所以說我們就可以使用以下模式來設置 Cookie。",[16,68,69],{},"首先第一種是設置 Cookie 過期的日期 ↓",[16,71,72],{},[73,74],"img",{"alt":75,"src":76},"Cookie 過期的日期","https:\u002F\u002Fi.imgur.com\u002FDtfteNU.png",[16,78,79,80,83],{},"(GMT 時間取得方式 ",[63,81,82],{},"new Date().toGMTString();",")",[16,85,86],{},"第二種是設置秒數 ↓",[16,88,89],{},[73,90],{"alt":91,"src":92},"設置秒數","https:\u002F\u002Fi.imgur.com\u002FHKIWC2a.png",[16,94,95],{},"如果只是想單純寫入 Cookie 而不需要消滅，就只需要這樣寫即可 ↓",[16,97,98],{},[73,99],{"alt":100,"src":101},"單純存入 Cookie","https:\u002F\u002Fi.imgur.com\u002FO86ejOW.png",[16,103,104,105,108,109],{},"最後取出 Cookie 的方法就是使用 ",[63,106,107],{},"document.cookie;"," 即可取得，如果 Cookie 裡面很多東西的話，就會需要再額外處理就是了，範例可以詳見 ",[46,110,113],{"href":111,"rel":112},"http:\u002F\u002Fwww.runoob.com\u002Fjs\u002Fjs-cookies.html",[50],"這裡",[12,115,116],{"id":116},"結尾",[16,118,119],{},"下一篇的 RE：從零開始的學習 JS 生活-第十八日 將會介紹 localStorage。",{"title":121,"searchDepth":122,"depth":122,"links":123},"",2,[124,125,126,127],{"id":14,"depth":122,"text":14},{"id":21,"depth":122,"text":22},{"id":57,"depth":122,"text":58},{"id":116,"depth":122,"text":116},"JavaScript","2019-10-02 00:00:01","md","zh-Hant",{},true,"\u002Fre-js\u002Fep-17-re-js","1",{"title":6,"description":18},false,"RE：從零開始的學習 JS 生活\u002FEP-17-RE：從零開始的學習-JS-生活-第十七日",[128,140,141],"RE：從零開始的學習 JS 生活","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fjavascript\u002F20191002\u002F3941110344\u002F","PI68PsZa0Bnpy9xynhXgemJwDVBwH8Zwoz3N_I67ncY",{"newer":146,"older":150},{"url":147,"title":148,"date":149},"\u002Fphp\u002F20191002\u002F3041589016\u002F","Day31-從基礎學習 ThinkPHP-結束只是另一個開始","2019-10-02 00:00:02",{"url":151,"title":152,"date":153},"\u002Fjavascript\u002F20191001\u002F4074116676\u002F","EP.16 RE：從零開始的學習 JS 生活-第十六日之優先性與相依性","2019-10-01 00:00:03",[155,160,165],{"url":156,"title":157,"date":158,"readingMinutes":159},"\u002Fjavascript\u002F20260310\u002F2118283166\u002F","前端加密不求人！Web Crypto API 完整教學：雜湊、AES 加解密、HMAC 簽章","2026-03-10 09:45:08","7",{"url":161,"title":162,"date":163,"readingMinutes":164},"\u002Fjavas