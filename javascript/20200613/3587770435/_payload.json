{"class":52},"=",[46,62,63],{"class":56}," {\n",[46,65,67,70,74],{"class":48,"line":66},2,[46,68,69],{"class":56},"  qq: ",[46,71,73],{"class":72},"sTRMh","'123'",[46,75,76],{"class":56},",\n",[46,78,80],{"class":48,"line":79},3,[46,81,82],{"class":56},"}\n",[46,84,86,89,93,96],{"class":48,"line":85},4,[46,87,88],{"class":56},"console.",[46,90,92],{"class":91},"sj_SG","log",[46,94,95],{"class":56},"(a.qq); ",[46,97,99],{"class":98},"sQrFR","\u002F\u002F 123\n",[16,101,102],{},"ASI 機制相當的方便，其中 JavaScript 的風格管理器 ESLint 中的 Standard 就是採用此方式。",[16,104,105],{},"但是以一個工程師來講，自動這種東西其實相當的危險，舉例來講",[36,107,109],{"className":38,"code":108,"language":40,"meta":41,"style":41},"var a = function() {\n  return\n  'ASI is Good!'\n}\n\nconsole.log(a())\n",[43,110,111,127,132,137,141,148],{"__ignoreMap":41},[46,112,113,115,118,121,124],{"class":48,"line":49},[46,114,53],{"class":52},[46,116,117],{"class":91}," a",[46,119,120],{"class":52}," =",[46,122,123],{"class":52}," function",[46,125,126],{"class":56},"() {\n",[46,128,129],{"class":48,"line":66},[46,130,131],{"class":52},"  return\n",[46,133,134],{"class":48,"line":79},[46,135,136],{"class":72},"  'ASI is Good!'\n",[46,138,139],{"class":48,"line":85},[46,140,82],{"class":56},[46,142,144],{"class":48,"line":143},5,[46,145,147],{"emptyLinePlaceholder":146},true,"\n",[46,149,151,153,155,158,161],{"class":48,"line":150},6,[46,152,88],{"class":56},[46,154,92],{"class":91},[46,156,157],{"class":56},"(",[46,159,160],{"class":91},"a",[46,162,163],{"class":56},"())\n",[16,165,166,167,169,170,173,174,177,178,180,181],{},"在上面程式碼我們將函式儲存在變數 ",[43,168,160],{}," 中，並透過 ",[43,171,172],{},"console.log()"," 回傳顯示 ",[43,175,176],{},"ASI is Good!","，但這時候你若實際執行程式碼，應該會發現一個很奇怪的現象，不但沒有回傳 ",[43,179,176],{}," 反而是出現了 ",[43,182,183],{},"undefined",[16,185,186],{},[26,187],{"alt":183,"src":188},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-06-14%2020.47.34.png",[16,190,191],{},"其主要原因在於 ASI 所導致，因為 ASI 機制會在結尾處補上分號，因此上面程式碼實際的運行狀況如下",[36,193,195],{"className":38,"code":194,"language":40,"meta":41,"style":41},"var a = function() {\n  return; 'ASI is Good!';\n}\n\nconsole.log(a());\n",[43,196,197,209,223,227,231],{"__ignoreMap":41},[46,198,199,201,203,205,207],{"class":48,"line":49},[46,200,53],{"class":52},[46,202,117],{"class":91},[46,204,120],{"class":52},[46,206,123],{"class":52},[46,208,126],{"class":56},[46,210,211,214,217,220],{"class":48,"line":66},[46,212,213],{"class":52},"  return",[46,215,216],{"class":56},"; ",[46,218,219],{"class":72},"'ASI is Good!'",[46,221,222],{"class":56},";\n",[46,224,225],{"class":48,"line":79},[46,226,82],{"class":56},[46,228,229],{"class":48,"line":85},[46,230,147],{"emptyLinePlaceholder":146},[46,232,233,235,237,239,241],{"class":48,"line":143},[46,234,88],{"class":56},[46,236,92],{"class":91},[46,238,157],{"class":56},[46,240,160],{"class":91},[46,242,243],{"class":56},"());\n",[16,245,246,247,249],{},"因此才會回傳一個 ",[43,248,183],{},"，因為根本沒有回傳任何東西。",[16,251,252],{},"其中 ASI 也有另一個常見的經典錯誤，也就是立即函式",[36,254,256],{"className":38,"code":255,"language":40,"meta":41,"style":41},"(function() {\n  console.log('one')\n})()\n\n(function() {\n  console.log('two')\n})()\n",[43,257,258,267,282,287,291,299,312],{"__ignoreMap":41},[46,259,260,262,265],{"class":48,"line":49},[46,261,157],{"class":56},[46,263,264],{"class":52},"function",[46,266,126],{"class":56},[46,268,269,272,274,276,279],{"class":48,"line":66},[46,270,271],{"class":56},"  console.",[46,273,92],{"class":91},[46,275,157],{"class":56},[46,277,278],{"class":72},"'one'",[46,280,281],{"class":56},")\n",[46,283,284],{"class":48,"line":79},[46,285,286],{"class":56},"})()\n",[46,288,289],{"class":48,"line":85},[46,290,147],{"emptyLinePlaceholder":146},[46,292,293,295,297],{"class":48,"line":143},[46,294,157],{"class":56},[46,296,264],{"class":52},[46,298,126],{"class":56},[46,300,301,303,305,307,310],{"class":48,"line":150},[46,302,271],{"c