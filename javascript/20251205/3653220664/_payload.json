,522],{"class":63},"\u002F\u002F 輸出 \"小明, 你預計今天要完成什麼任務？\"\n",[12,524,525,526,528,529,531],{},"很有趣吧？你可以隨時呼叫 ",[25,527,371],{}," 來取得下一個 ",[25,530,337],{}," 的值，這樣就能讓函式的執行變得更加靈活。",[12,533,534,535,537,538,540],{},"另外 ",[25,536,371],{}," 還能夠傳入一個參數，這個參數會成為上一個 ",[25,539,337],{}," 表達式的回傳值，這樣就能讓函式在每次恢復執行時，根據外部傳入的值來決定下一步的行為。",[48,542,544],{"className":50,"code":543,"language":52,"meta":53,"style":53},"function* myGenerator(name) {\n  const task = yield `Hello, ${name}`;\n  console.log(task);\n  yield `${name}, 你預計今天要完成什麼任務？ ${task}`;\n}\nconst gen = myGenerator(\"小明\");\nconsole.log(gen.next().value); \u002F\u002F 輸出 \"Hello, 小明\"\nconsole.log(gen.next(\"寫程式\").value); \u002F\u002F 輸出 \"小明, 你預計今天要完成什麼任務？ 寫程式\"\n",[25,545,546,558,579,588,606,610,626,640],{"__ignoreMap":53},[57,547,548,550,552,554,556],{"class":59,"line":60},[57,549,27],{"class":70},[57,551,74],{"class":73},[57,553,90],{"class":77},[57,555,436],{"class":435},[57,557,439],{"class":77},[57,559,560,563,566,568,571,573,575,577],{"class":59,"line":67},[57,561,562],{"class":70},"  const",[57,564,565],{"class":353}," task",[57,567,153],{"class":70},[57,569,570],{"class":70}," yield",[57,572,446],{"class":93},[57,574,436],{"class":77},[57,576,451],{"class":93},[57,578,454],{"class":77},[57,580,581,583,585],{"class":59,"line":81},[57,582,84],{"class":77},[57,584,87],{"class":73},[57,586,587],{"class":77},"(task);\n",[57,589,590,592,594,596,599,602,604],{"class":59,"line":100},[57,591,103],{"class":70},[57,593,461],{"class":93},[57,595,436],{"class":77},[57,597,598],{"class":93},"}, 你預計今天要完成什麼任務？ ${",[57,600,601],{"class":77},"task",[57,603,451],{"class":93},[57,605,454],{"class":77},[57,607,608],{"class":59,"line":112},[57,609,129],{"class":77},[57,611,612,614,616,618,620,622,624],{"class":59,"line":126},[57,613,148],{"class":70},[57,615,354],{"class":353},[57,617,153],{"class":70},[57,619,74],{"class":73},[57,621,90],{"class":77},[57,623,487],{"class":93},[57,625,97],{"class":77},[57,627,628,630,632,634,636,638],{"class