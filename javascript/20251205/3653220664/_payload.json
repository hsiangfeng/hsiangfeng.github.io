\u002F 暫停點\n  console.log(\"World\");\n}\n",[25,287,288,296,308,316,328],{"__ignoreMap":53},[57,289,290,292,294],{"class":59,"line":60},[57,291,27],{"class":70},[57,293,74],{"class":73},[57,295,78],{"class":77},[57,297,298,300,302,304,306],{"class":59,"line":67},[57,299,84],{"class":77},[57,301,87],{"class":73},[57,303,90],{"class":77},[57,305,94],{"class":93},[57,307,97],{"class":77},[57,309,310,312,314],{"class":59,"line":81},[57,311,103],{"class":70},[57,313,106],{"class":77},[57,315,109],{"class":63},[57,317,318,320,322,324,326],{"class":59,"line":100},[57,319,84],{"class":77},[57,321,87],{"class":73},[57,323,90],{"class":77},[57,325,121],{"class":93},[57,327,97],{"class":77},[57,329,330],{"class":59,"line":112},[57,331,129],{"class":77},[12,333,334,335,338,339,341],{},"你只需要在你想要暫停的地方使用 ",[25,336,337],{},"yield"," 關鍵字，這樣當函式執行到 ",[25,340,337],{}," 時就會暫停，等待下一次的呼叫。",[48,343,345],{"className":50,"code":344,"language":52,"meta":53,"style":53},"const gen = myGenerator(); \u002F\u002F 建立生成器物件\ngen.next(); \u002F\u002F 輸出 \"Hello\"\ngen.next(); \u002F\u002F 輸出 \"World\"\n",[25,346,347,364,377],{"__ignoreMap":53},[57,348,349,351,355,357,359,361],{"class":59,"line":60},[57,350,148],{"class":70},[57,352,354],{"class":353},"sCcAr"," gen",[57,356,153],{"class":70},[57,358,74],{"class":73},[57,360,267],{"class":77},[57,362,363],{"class":63},"\u002F\u002F 建立生成器物件\n",[57,365,366,369,372,374],{"class":59,"line":67},[57,367,368],{"class":77},"gen.",[57,370,371],{"class":73},"next",[57,373,267],{"class":77},[57,375,376],{"class":63},"\u002F\u002F 輸出 \"Hello\"\n",[57,378,379,381,383,385],{"class":59,"line":81},[57,380,368],{"class":77},[57,382,371],{"class":73},[57,384,267],{"class":77},[57,386,387],{"class":63},"\u002F\u002F 輸出 \"World\"\n",[12,389,390,391,394,395,397,398,400,401,403],{},"你會發現 ",[25,392,393],{},"gen"," 並不會像一般函式一樣直接執行，而是回傳一個生成器物件，這個物件有一個 ",[25,396,371],{}," 方法，每次呼叫 ",[25,399,371],{}," 都會讓函式從上次暫停的地方繼續執行，直到遇到下一個 ",[25,402,337],{}," 或是函式結束。",[12,405,406,407,409,410,413