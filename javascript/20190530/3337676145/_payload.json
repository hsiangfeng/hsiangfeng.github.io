[{"data":1,"prerenderedAt":918},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190530\u002F3337676145\u002F":3,"page:\u002Fjavascript\u002F20190530\u002F3337676145\u002F":4,"alt:\u002Fjavascript\u002F20190530\u002F3337676145\u002F":3,"prev-next:\u002Fjavascript\u002F20190530\u002F3337676145\u002F":893,"related:\u002Fjavascript\u002F20190530\u002F3337676145\u002F":902},"\u002Fen\u002Fjavascript\u002F2019\u002F05\u002F30\u002Fjavascript-async-sync-promise\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":878,"date":879,"description":18,"extension":880,"lang":881,"meta":882,"navigation":883,"path":884,"readingMinutes":885,"seo":886,"standalone":887,"stem":888,"tags":889,"tldr":890,"updated":890,"url":891,"__hash__":892},"content\u002FJavaScript\u002FJavaScript-非同步與同步事件之Promise.md","JavaScript 非同步與同步事件之 Promise","3337676145",{"type":9,"value":10,"toc":866},"minimark",[11,15,19,22,33,36,39,45,48,51,54,58,61,67,72,75,149,152,489,492,498,501,507,515,518,527,798,804,808,812,815,824,831,838,841,844,847,853,856,862],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"async 與 await 是 JavaScript 中常見的東西，其中也與 Promise 也有關係，所以這邊也會先講一下 Promise 是什麼。",[12,20,21],{"id":21},"非同步與同步事件",[16,23,24,25,28,29,32],{},"首先到底",[26,27,21],"strong",{},"是什麼東西呢?我們在 JavaScript 奇怪的部分有瞭解到 JavaScript 是",[26,30,31],{},"單進程的程式語言","(意旨一次只能做一件事情)",[12,34,35],{"id":35},"同步事件",[16,37,38],{},"舉例來講 JavaScript 就像下廚差不多，以同步來講就像我要一定要先切菜 → 再切香菇 → 然後倒高湯 → 最後一定是上菜。",[16,40,41],{},[42,43],"img",{"alt":35,"src":44},"https:\u002F\u002Fi.imgur.com\u002FRjBzQZb.png",[12,46,47],{"id":47},"非同步事件",[16,49,50],{},"那非同步呢?做菜過程除了最後上菜之外，難道我們就一定要先切菜 → 再切香菇 → 然後倒高湯嗎?不一定，我們可以先切香菇或者先到高湯又或者在最後才切菜等等，簡單來說就是我們可以先做其他可以先做的事情，然後其他事情不會受到影響。",[16,52,53],{},"那剛剛前面有講到 JavaScript 是單進程程式語言，那他又是如何處理非同步事件的?在 JavaScript 中，他會先將應該要先處理的東西先處理完，然後再把需要做非同步處理的事情放進一個叫做事件佇(ㄓㄨˋ)列，又稱事件對列中，直到前面應該先處理完的事情處理完後再看事件佇列有什麼是準備要做的。",[12,55,57],{"id":56},"promise","Promise",[16,59,60],{},"由於 JavaScript 中有非常多的非同步事件，所以就會有一個東西叫做 Callback Hell (回呼地獄)，當我們希望這件事情可以處理之後在往下處理的時候就會這個恐怖的 Callback Hell。",[16,62,63],{},[42,64],{"alt":65,"src":66},"Callback Hell","https:\u002F\u002Fi.imgur.com\u002FEuE1Sqr.png",[68,69,71],"h3",{"id":70},"那-promise-該如何撰寫呢","那 Promise 該如何撰寫呢?",[16,73,74],{},"首先 Promise 是 ES6 新增的一個功能，所以必須使用函式來呼叫，常見的寫法就像這樣 ↓",[76,77,82],"pre",{"className":78,"code":79,"language":80,"meta":81,"style":81},"language-js shiki shiki-themes github-dark-high-contrast","let newPromise = new Promise((resolve, reject) => {\n  \u002F\u002F resolve → 代表操作成功，並將值回傳回去\n  \u002F\u002F reject → 代表失敗，回傳錯誤訊息\n})\n","js","",[83,84,85,130,137,143],"code",{"__ignoreMap":81},[86,87,90,94,98,101,104,108,111,115,118,121,124,127],"span",{"class":88,"line":89},"line",1,[86,91,93],{"class":92},"sWyjQ","let",[86,95,97],{"class":96},"sMAXC"," newPromise ",[86,99,100],{"class":92},"=",[86,102,103],{"class":92}," new",[86,105,107],{"class":106},"sCcAr"," Promise",[86,109,110],{"class":96},"((",[86,112,114],{"class":113},"s_sBn","resolve",[86,116,117],{"class":96},", ",[86,119,120],{"class":113},"reject",[86,122,123],{"class":96},") ",[86,125,126],{"class":92},"=>",[86,128,129],{"class":96}," {\n",[86,131,133],{"class":88,"line":132},2,[86,134,136],{"class":135},"sQrFR","  \u002F\u002F resolve → 代表操作成功，並將值回傳回去\n",[86,138,140],{"class":88,"line":139},3,[86,141,142],{"class":135},"  \u002F\u002F reject → 代表失敗，回傳錯誤訊息\n",[86,144,146],{"class":88,"line":145},4,[86,147,148],{"class":96},"})\n",[16,150,151],{},"一開始我們無法知道哪一個函式會先被執行完，但是我們又希望他可以照順序來運作，那就可以這樣子寫 ↓",[76,153,155],{"className":78,"code":154,"language":80,"meta":81,"style":81},"let runPromiss = (name, time, status) => {\n  return new Promise((resolve, reject) => {\n    if(status) {\n      console.log(`${name} 起跑了!`)\n      return setTimeout(() => {\n        resolve(`${name} 衝了 ${time \u002F 1000}秒`)\n      },time);\n    } else {\n     reject(new Error(`${name} 出現錯誤`));\n    };\n  });\n};\n\u002F\u002F 小明失敗，就回傳錯誤訊息\nrunPromiss('小明', 3000, false).then((res) => {\n  console.log(res);\n  r