[{"data":1,"prerenderedAt":378},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20210807\u002F3551792061\u002F":3,"page:\u002Fjavascript\u002F20210807\u002F3551792061\u002F":4,"alt:\u002Fjavascript\u002F20210807\u002F3551792061\u002F":3,"prev-next:\u002Fjavascript\u002F20210807\u002F3551792061\u002F":353,"related:\u002Fjavascript\u002F20210807\u002F3551792061\u002F":362},"\u002Fen\u002Fjavascript\u002F2021\u002F08\u002F07\u002Fjavascript-core-64-arrow-functions-intro\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":338,"date":339,"description":18,"extension":340,"lang":341,"meta":342,"navigation":103,"path":343,"readingMinutes":344,"seo":345,"standalone":346,"stem":347,"tags":348,"tldr":350,"updated":350,"url":351,"__hash__":352},"content\u002FJavaScript 核心觀念\u002F8.ES6 章節：箭頭函式\u002FJavaScript-核心觀念-64-ES6-章節：箭頭函式-箭頭函式簡介.md","JavaScript 核心觀念(64) - ES6 章節：箭頭函式 - 箭頭函式簡介","3551792061",{"type":9,"value":10,"toc":333},"minimark",[11,15,19,22,34,37,131,134,197,208,257,260,307,313,316,329],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來是一個新的章節，也就是箭頭函式。",[12,20,21],{"id":21},"箭頭函式簡介",[16,23,24,25,29,30,33],{},"箭頭函式又稱之為 Arrow Function，請注意箭頭函式是一個表達式，因此正確名稱是箭頭函式表達式(arrow function expression)，而箭頭函式是 ES6 所新增的語法，基本上 ES6 語法滿多都是屬於語法糖的一種，什麼是語法糖呢？簡單來講就是跟糖果一樣甜，很方便你開發與撰寫，通常特色會是簡短、好用以及好閱讀不等，例如以往建議原型時必須寫一大推 ",[26,27,28],"code",{},"prototype","，但是 ES6 之後出了一個 ",[26,31,32],{},"class"," 語法方便使用，當然還有一些是屬於新的語法，而本篇並不著重於講這個，所以拉回箭頭函式。",[16,35,36],{},"那麼以下是一個基本的範例：",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-themes github-dark-high-contrast","const myName = function(name) {\n  return 'myName is :' + name;\n}\n\nconsole.log(myName('Ray')); \u002F\u002F myName is Ray\n","js","",[26,45,46,76,92,98,105],{"__ignoreMap":43},[47,48,51,55,59,62,65,69,73],"span",{"class":49,"line":50},"line",1,[47,52,54],{"class":53},"sWyjQ","const",[47,56,58],{"class":57},"sj_SG"," myName",[47,60,61],{"class":53}," =",[47,63,64],{"class":53}," function",[47,66,68],{"class":67},"sMAXC","(",[47,70,72],{"class":71},"s_sBn","name",[47,74,75],{"class":67},") {\n",[47,77,79,82,86,89],{"class":49,"line":78},2,[47,80,81],{"class":53},"  return",[47,83,85],{"class":84},"sTRMh"," 'myName is :'",[47,87,88],{"class":53}," +",[47,90,91],{"class":67}," name;\n",[47,93,95],{"class":49,"line":94},3,[47,96,97],{"class":67},"}\n",[47,99,101],{"class":49,"line":100},4,[47,102,104],{"emptyLinePlaceholder":103},true,"\n",[47,106,108,111,114,116,119,121,124,127],{"class":49,"line":107},5,[47,109,110],{"class":67},"console.",[47,112,113],{"class":57},"log",[47,115,68],{"class":67},[47,117,118],{"class":57},"myName",[47,120,68],{"class":67},[47,122,123],{"class":84},"'Ray'",[47,125,126],{"class":67},")); ",[47,128,130],{"class":129},"sQrFR","\u002F\u002F myName is Ray\n",[16,132,133],{},"透過 ES6 的箭頭函式我們可以將上面程式碼改成以下：",[38,135,137],{"className":40,"code":136,"language":42,"meta":43,"style":43},"const myName = (name) => {\n  return 'myName is :' + name;\n}\n\nconsole.log(myName('Ray')); \u002F\u002F myName is Ray\n",[26,138,139,161,171,175,179],{"__ignoreMap":43},[47,140,141,143,145,147,150,152,155,158],{"class":49,"line":50},[47,142,54],{"class":53},[47,144,58],{"class":57},[47,146,61],{"class":53},[47,148,149],{"class":67}," (",[47,151,72],{"class":71},[47,153,154],{"class":67},") ",[47,156,157],{"class":53},"=>",[47,159,160],{"class":67}," {\n",[47,162,163,165,167,169],{"class":49,"line":78},[47,164,81],{"class":53},[47,166,85],{"class":84},[47,168,88],{"class":53},[47,170,91],{"class":67},[47,172,173],{"class":49,"line":94},[47,174,97],{"class":67},[47,176,177],{"class":49,"line":100},[47,178,104],{"emptyLinePlaceholder":103},[47,180,181,183,185,187,189,191,193,195],{"class":49,"line":107},[47,182,110],{"class":67},[47,184,113],{"class":57},[47,186,68],{"class":67},[47,188,118],{"class":57},[47,190,68],{"class":67},[47,192,123],{"class":84},[47,194,126],{"class":67},[47,196,130],{"class":129},[16,198,199,200,203,204,207],{},"而箭頭函式還具備縮寫能力，當裡面的程式碼內容是屬於表達式時，你就可以省略 ",[26,201,202],{},"return"," 與 ",[26,205,206],{},"{ }","：",[38,209,211],{"className":40,"code":210,"language":42,"meta":43,"style":43},"const myName = (name) => 'myName is :' + name;\n\nconsole.log(myName('Ray')); \u002F\u002F myName is Ray\n",[26,212,213,235,239],{"__ignoreMap":43},[47,214,215,217,219,221,223,225,227,229,231,233],{"class":49,"line":50},[47,216,54],{"class":53},[47,218,58],{"class":57},[47,220,61],{"class":53},[47,222,149],{"class":67},[47,224,72],{"class":71},[47,226,154],{"class":67},[47,228,157],{"class":53},[47,230,85],{"class":84},[47,232,88],{"class":53},[47,234,91],{"class":67},[47,236,237],{"class":49,"line":78},[47,238,104],{"emptyLinePlaceholder":103},[47,240,241,243,245,247,249,251,253,255],{"class":49,"line":94},[47,242,110],{"class":67},[47,244,113],{"class":57},[47,246,68],{"class":67},[47,248,118],{"class":57},[47,250,68],{"class":67},[47,252,123],{"class":84},[47,254,126],{"class":67},[47,256,130],{"class":129},[16,258,259],{},"除此之外當箭頭函式的參數只有一個時，可以連參數括號都省略：",[38,261,263],{"className":40,"code":262,"language":42,"meta":43,"style":43},"const myName = name => 'myName is :' + name;\n\nconsole.log(myName('Ray')); \u002F\u002F myName is Ray\n",[26,264,265,285,289],{"__ignoreMap":43},[47,266,267,269,271,273,276,279,281,283],{"class":49,"line":50},[47,268,54],{"class":53},[47,270,58],{"class":57},[47,272,61],{"class":53},[47,274,275],{"class":71}," name",[47,277,278],{"class":53}," =>",[47,280,85],{"class":84},[47,282,88],{"class":53},[47,284,91],{"class":67},[47,286,287],{"class":49,"line":78},[47,288,104],{"emptyLinePlaceholder":103},[47,290,291,293,295,297,299,301,303,305],{"class":49,"line":94},[47,292,110],{"class":67},[47,294,113],{"class":57},[47,296,68],{"class":67},[47,298,118],{"class":57},[47,300,68],{"class":67},[47,302,123],{"class":84},[47,304,126],{"class":67},[47,306,130],{"class":129},[16,308,309],{},[310,311,312],"strong",{},"但是要注意如果沒有參數或者有兩個參數時，參數括號是無法省略的唷。",[12,314,315],