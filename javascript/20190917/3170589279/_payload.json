[{"data":1,"prerenderedAt":493},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190917\u002F3170589279\u002F":3,"page:\u002Fjavascript\u002F20190917\u002F3170589279\u002F":4,"alt:\u002Fjavascript\u002F20190917\u002F3170589279\u002F":3,"prev-next:\u002Fjavascript\u002F20190917\u002F3170589279\u002F":468,"related:\u002Fjavascript\u002F20190917\u002F3170589279\u002F":477},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F17\u002Fre-zero-js-day-02-variables\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":452,"date":453,"description":18,"extension":454,"lang":455,"meta":456,"navigation":457,"path":458,"readingMinutes":194,"seo":459,"standalone":460,"stem":461,"tags":462,"tldr":465,"updated":465,"url":466,"__hash__":467},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-2-RE：從零開始的學習-JS-生活-第二日.md","EP.2 RE：從零開始的學習 JS 生活-第二日之變數","3170589279",{"type":9,"value":10,"toc":437},"minimark",[11,15,19,22,42,67,124,131,134,137,144,158,161,167,174,177,180,213,229,235,238,246,294,298,301,321,327,330,333,352,355,358,368,374,377,381,392,398,402,417,421,427,430,433],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第二日，我們必須先學習如何建立一個變數，而變數也是我們開發系統常常使用的一個東西，你可以理解成我們的必點基礎技能。",[12,20,21],{"id":21},"變數",[16,23,24,25,29,30,32,33,37,38,41],{},"在系統開發時，通常我們都會需要將資料 ",[26,27,28],"strong",{},"暫時儲存"," 在記憶體空間內，那麼此時就會使用到 ",[26,31,21],{}," 這個東西，實際開發的時候你也會很長看到 ",[34,35,36],"code",{},"var a = 1;"," 或是 ",[34,39,40],{},"var b = '王小明';"," 這種神奇的單字。",[16,43,44,45,48,49,52,53,56,57,59,60,63,64,66],{},"那麼變數的意思是什麼呢?簡單來講變數它可以隨著我們的使用而不停地",[26,46,47],{},"重新賦予值","，舉例來講原本變數 ",[34,50,51],{},"a"," 已經賦予 ",[34,54,55],{},"1"," 的值，那麼我們也可以針對變數 ",[34,58,51],{}," 重新再賦予另一個值，例如 ",[34,61,62],{},"2","，並且不用再重新建立變數另一個變數儲存 ",[34,65,62],{},"，來實際看一下範例：",[68,69,74],"pre",{"className":70,"code":71,"language":72,"meta":73,"style":73},"language-js shiki shiki-themes github-dark-high-contrast","var a = 1;\na = 2;\na = 3.14759;\n","js","",[34,75,76,99,112],{"__ignoreMap":73},[77,78,81,85,89,92,96],"span",{"class":79,"line":80},"line",1,[77,82,84],{"class":83},"sWyjQ","var",[77,86,88],{"class":87},"sMAXC"," a ",[77,90,91],{"class":83},"=",[77,93,95],{"class":94},"sCcAr"," 1",[77,97,98],{"class":87},";\n",[77,100,102,105,107,110],{"class":79,"line":101},2,[77,103,104],{"class":87},"a ",[77,106,91],{"class":83},[77,108,109],{"class":94}," 2",[77,111,98],{"class":87},[77,113,115,117,119,122],{"class":79,"line":114},3,[77,116,104],{"class":87},[77,118,91],{"class":83},[77,120,121],{"class":94}," 3.14759",[77,123,98],{"class":87},[16,125,126,127,130],{},"當然原本的 ",[34,128,129],{},"a = 1;"," 就會消失，畢竟你清除它了。",[12,132,133],{"id":133},"如何建立變數",[16,135,136],{},"在 JavaScript 的變數的建立方式是有一定的基本法則，而這法則不外乎就是像這樣建立 ↓",[16,138,139],{},[140,141],"img",{"alt":142,"src":143},"宣告變數","https:\u002F\u002Fi.imgur.com\u002Fq6EZCxi.png",[16,145,146,147,149,150,153,154,157],{},"通常我們會將建立變數的過程稱之為 ",[26,148,142],{}," or ",[26,151,152],{},"定義一個變數","，例如我們宣告了一個變數叫 ",[34,155,156],{},"myname","，並賦予一個值等等。",[16,159,160],{},"那麼該如何賦予變數值呢?賦予值的方式會使用到一個運算子也就是等號運算子(後面會介紹)，形式如下 ↓",[16,162,163],{},[140,164],{"alt":165,"src":166},"賦予變數值","https:\u002F\u002Fi.imgur.com\u002FCtV767O.png",[16,168,169,170,173],{},"通常來講如果你沒有賦予值的話，你會發現 JavaScript 預設會給變數賦予 ",[34,171,172],{},"undefined"," 這個關鍵字，那過程 JavaScript 就會將右邊的值儲存進入至左邊的變數名稱內。",[12,175,176],{"id":176},"變數型別",[16,178,179],{},"JavaScript 在賦予變數值的時候，通常有這三種基本(基礎)型別",[181,182,183,199,202],"ul",{},[184,185,186,187,189,190,189,192,37,195,198],"li",{},"數字型別 (Number) - 純粹的數字，如: ",[34,188,55],{},"、",[34,191,62],{},[34,193,194],{},"3",[34,196,197],{},"3.14759"," 等等。",[184,200,201],{},"字串型別 (String) - 只要是使用單引號或雙引號包覆的都是字串型別。",[184,203,204,205,208,209,212],{},"布林型別 (Boolean) - 只有 ",[34,206,207],{},"true"," & ",[34,210,211],{},"false","。",[16,214,215,216,219,220,223,224,149,226,228],{},"唯獨字串型別在賦予值時，一定要記得帶上單引號(",[34,217,218],{},"''",")或是雙引號(",[34,221,222],{},"\"\"",")，其他則可以直接輸入數字或是布林的 ",[34,225,207],{},[34,227,211],{}," ↓",[16,230,231],{},[140,232],{"alt":233,"src":234},"資料型別","https:\u002F\u002Fi.imgur.com\u002FAmaA2mc.png",[12,236,237],{"id":237},"變數命名規則",[16,239,240,241,245],{},"一般來講變數在命名時，是有幾個重點必須要注意，如果能夠遵守這些重點，基本上也能夠減少 ",[242,243,244],"del",{},"被X瞧"," 發生 BUG 的機會。",[181,247,248,257,260,263,278,284],{},[184,249,250,251,189,254,256],{},"不能使用關鍵字 or 保留字當變數名稱，如 ",[34,252,253],{},"if",[34,255,84],{}," 等。",[184,258,259],{},"變數值如果是字串需記得使用單引號或雙引號包覆。",[184,261,262],{},"變數名稱大小寫需清楚。",[184,264,265,266,269,270,273,274,277],{},"變數名稱需以英文字母或 ",[34,267,268],{},"$"," 符號當作開頭，開頭不可以使用數字，也不能使用特殊符號(如 ",[34,271,272],{},"."," 或 ",[34,275,276],{},"-"," 等)當變數名稱。",[184,279,280,281,212],{},"變數名稱盡可能語意化，",[242,282,283],{},"否則鬼才知道你這個變數用途",[184,285,286,287,289,290,293],{},"不要將變數賦予 ",[34,288,172],{}," ，但可以賦予 ",[34,291,292],{},"Null","(很重要，後面會在講解)。",[295,296,297],"h3",{"id":297},"不能使用關鍵字當變數名稱",[16,299,300],{},"意思就是使用 JavaScript 中本身保留的關鍵字做命名，例如：",[68,302,304],{"className":70,"code":303,"language":72,"meta":73,"style":73},"var function = 'doc';\n",[34,305,306],{"__ignoreMap":73},[77,307,308,310,313,315,319],{"class":79,"line":80},[77,309,84],{"class":83},[77,311,312],{"class":87}," function ",[77,314,91],{"class":83},[77,316,318],{"class":317},"sTRMh"," 'doc'",[77,320,98],{"class":87},[16,322,323],{},[140,324],{"alt":325,"src":326},"SyntaxError","https:\u002F\u002Fi.imgur.com\u002FPDgJbjQ.png",[295,328,329],{"id":329},"字串需記得使用單引號或雙引號包覆",[16,331,332],{},"後期開發者通常會搭配風格管理統一自己的 JavaScript 風格，所以如果是純粹字串，我會建議使用單引號：",[68,334,336],{"className":70,"code":335,"language":72,"meta":73,"style":73},"var myname = 'Ray';\n",[34,337,338],{"__ignoreMap":73},[77,339,340,342,345,347,350],{"class":79,"line":80},[77,341,84],{"class":83},[77,343,344],{"class":87}," myname ",[77,346,91],{"class":83},[77,348,349],{"class":317}," 'Ray'",[77,351,98],{"class":87},[16,353,354],{},"當然雙引號也是沒問題的，只是我個人建議可以先習慣該模式，這樣子後面接觸風格管理時才不會覺得有夠麻煩。",[295,356,357],{"id":357},"變數名稱大小寫需清楚",[16,359,360,361,364,365,367],{},"如果變數原本是叫做 ",[34,362,363],{},"myName"," 但是你呼叫時卻是輸入 ",[34,366,156],{},"，那麼就一定會出現錯誤 ↓",[16,369,370],{},[140,371],{"alt":372,"src":373},"myname is not defined","https:\u002F\u002Fi.imgur.com\u002FtPOfvcr.png",[16,375,376],{},"所以變數的大小寫必須清楚。",[295,378,380],{"id":379},"變數名稱需以英文字母或-符號當開頭不可以使用數字當變數名稱開頭","變數名稱需以英文字母或 $ 符號當開頭，不可以使用數字當變數名稱開頭",[16,382,383,384,386,387,273,389,391],{},"變數的命名開頭你可以使用底線、",[34,385,268],{}," 字號，但是就是不能使用數字 or ",[34,388,272],{},[34,390,276],{}," 等特殊符號當作變數開頭 ↓",[16,393,394],{},[140,395],{"alt":396,"src":397},"SyntaxError: identifier starts immediately after numeric literal","https:\u002F\u002Fi.imgur.com\u002FzjbfDA2.png",[295,399,401],{"id":400},"不要將變數賦予-undefined","不要將變數賦予 undefined",[16,403,404,405,407,408,410,411,413,414,416],{},"通常 JavaScript 預設會替變數準備好一個空間並賦予一個預設的關鍵字，而這個關鍵是就是 ",[34,406,172],{},"，通常我們在實際開發時若看到 ",[34,409,172],{}," 就會第一直覺知道「oh! 我的變數還沒賦值!」，所以如果你若將變數賦予 ",[34,412,172],{}," 就很難辨別你到底有沒有替該變數賦予值，當然若你替變數賦予 ",[34,415,172],{}," 也不會出現錯誤訊息，所以如果你這麼做將會導致你完全不知道到底是哪裡出現問題。",[12,418,420],{"id":419},"關鍵字保留字","關鍵字?保留字",[16,422,423,424,212],{},"最後補充前面講到的一些術語，也就是關鍵字，關鍵字又可以稱之為保留字，而這個意思是說程式語言在建立的時候就已經存在的東西，舉例來講假設異世界中如果要使用的魔法，你就要念出咒語，而咒語得前面必須加上「出來吧!」這三個字，所以當你要召喚前鬼時就是「出來吧!前鬼」(咦?!)，而「出來吧!」這三個字就是保留字 & 關鍵字，那你就不能夠將它拿來這樣念咒語「出來吧!出來吧!」，",[242,425,426],{},"那這樣子鬼才知道你想做什麼",[12,428,429],{"id":429},"結尾",[16,431,432],{},"下一篇的 RE：從零開始的學習 JS 生活-第三日 將會介紹選取器。",[434,435,436],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}",{"title":73,"searchDepth":101,"depth":101,"links":438},[439,440,441,442,443,450,451],{"id":14,"depth":101,"text":14},{"id":21,"depth":101,"text":21},{"id":133,"depth":101,"text":133},{"id":176,"depth":101,"text":176},{"id":237,"depth":101,"text":237,"children":444},[445,446,447,448,449],{"id":297,"depth":114,"text":297},{"id":329,"depth":114,"text":329},{"id":357,"depth":114,"text":357},{"id":379,"depth":114,"text":380},{"id":400,"depth":114,"text":401},{"id":419,"depth":101,"text":420},{"id":429,"depth":101,"text":429},"JavaScript","2019-09-17 00:01:20","md","zh-Hant",{},true,"\u002Fre-js\u002Fep-2-re-js",{"title":6,"description":18},false,"RE：從零開始的學習 JS 生活\u002FEP-2-RE：從零開始的學習-JS-生活-第二日",[452,463,464],"RE：從零開始的學習 JS 生活","第 11 屆 iT邦幫忙鐵人賽",null,"\u002Fjavascript\u002F20190917\u002F3170589279\u002F","ivDYFW0JOBZFQh4CGFWNVMncbbeCKHRr2riMyiDfUhA",{"newer":469,"older":473},{"url":470,"title":471,"date":472},"\u002Fphp\u002F20190918\u002F629335687\u002F","Day17-從基礎學習 ThinkPHP-資料操作(2)","2019-09-18 00:01:02",{"url":474,"title":475,"date":476},"\u002Fphp\u002F20190917\u002F3037813271\u002F","Day16-從基礎學習 ThinkPHP-資料操作(1)","2019-09-17 00:01:10",[478,483,488],{"url":479,"title":480,"date":481,"readingMinutes":482},"\u002Fjavascript\u002F20260310\u002F2118283166\u002F","前端加密不求人！Web Crypto API 完整教學：雜湊、AES 加解密、HMAC 簽章","2026-03-10 09:45:08","7",{"url":484,"title":485,"date":486,"readingMinutes":487},"\u002Fjavascript\u002F20251208\u002F3781527973\u002F","一個時代的王者 jQuery，為什麼沒落了？","2025-12-08 21:35:24","5",{"url":489,"title":490,"date":491,"readingMinutes":492},"\u002Fjavascript\u002F20251205\u002F3653220664\u002F","什麼是 JavaScript 的 Generator Functions (function*)？","2025-12-05 13:40:31","4",1784020386857]