[{"data":1,"prerenderedAt":487},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200621\u002F3160672433\u002F":3,"page:\u002Fjavascript\u002F20200621\u002F3160672433\u002F":4,"alt:\u002Fjavascript\u002F20200621\u002F3160672433\u002F":3,"prev-next:\u002Fjavascript\u002F20200621\u002F3160672433\u002F":462,"related:\u002Fjavascript\u002F20200621\u002F3160672433\u002F":471},"\u002Fen\u002Fjavascript\u002F2020\u002F06\u002F21\u002Fjavascript-core-13-dynamic-typing\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":448,"date":449,"description":18,"extension":450,"lang":451,"meta":452,"navigation":174,"path":453,"readingMinutes":347,"seo":454,"standalone":455,"stem":456,"tags":457,"tldr":459,"updated":459,"url":460,"__hash__":461},"content\u002FJavaScript 核心觀念\u002F2.運算子、型別與文法\u002FJavaScript-核心觀念-13-運算子、型別與文法-動態型別.md","JavaScript 核心觀念(13)-運算子、型別與文法-動態型別","3160672433",{"type":9,"value":10,"toc":443},"minimark",[11,15,19,22,25,49,52,61,64,121,128,232,235,295,298,301,304,342,362,417,420,423,426,439],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"當我們在轉寫 JavaScript 的時候，完全不用去宣告該變數是什麼型別，而這主要原因在於 JavaScript 是一個動態型別的語言。",[12,20,21],{"id":21},"動態型別",[16,23,24],{},"何謂動態型別呢？這邊舉例 C 語言的宣告變數，當假使今天要宣告一個 int 數字類型的變數，那麼就要像以下這樣宣告",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-c shiki shiki-themes github-dark-high-contrast","int a = 4;\nint b = 3;\n","c","",[33,34,35,43],"code",{"__ignoreMap":31},[36,37,40],"span",{"class":38,"line":39},"line",1,[36,41,42],{},"int a = 4;\n",[36,44,46],{"class":38,"line":45},2,[36,47,48],{},"int b = 3;\n",[16,50,51],{},"而字串呢？在 C 語言中字串是使用 char 宣告(C 語言中字串是採用陣列形式呈現)",[26,53,55],{"className":28,"code":54,"language":30,"meta":31,"style":31},"char str[6] = \"hello\";\n",[33,56,57],{"__ignoreMap":31},[36,58,59],{"class":38,"line":39},[36,60,54],{},[16,62,63],{},"而 JavaScript 呢？在上述範例中 JavaScript 在執行階段就會自己辨別賦予正確的型別",[26,65,69],{"className":66,"code":67,"language":68,"meta":31,"style":31},"language-js shiki shiki-themes github-dark-high-contrast","var a = 4;\nvar b = 3;\nvar str = 'hello';\n","js",[33,70,71,91,105],{"__ignoreMap":31},[36,72,73,77,81,84,88],{"class":38,"line":39},[36,74,76],{"class":75},"sWyjQ","var",[36,78,80],{"class":79},"sMAXC"," a ",[36,82,83],{"class":75},"=",[36,85,87],{"class":86},"sCcAr"," 4",[36,89,90],{"class":79},";\n",[36,92,93,95,98,100,103],{"class":38,"line":45},[36,94,76],{"class":75},[36,96,97],{"class":79}," b ",[36,99,83],{"class":75},[36,101,102],{"class":86}," 3",[36,104,90],{"class":79},[36,106,108,110,113,115,119],{"class":38,"line":107},3,[36,109,76],{"class":75},[36,111,112],{"class":79}," str ",[36,114,83],{"class":75},[36,116,118],{"class":117},"sTRMh"," 'hello'",[36,120,90],{"class":79},[16,122,123,124,127],{},"在這邊我們可以透過 ",[33,125,126],{},"typeof"," 來確定型別",[26,129,131],{"className":66,"code":130,"language":68,"meta":31,"style":31},"var a = 4;\nvar b = 3;\nvar str = 'hello';\n\nconsole.log(typeof(a)); \u002F\u002F number 就是 int、float。\nconsole.log(typeof(b)); \u002F\u002F number\nconsole.log(typeof(str)); \u002F\u002F string\n",[33,132,133,145,157,169,176,198,215],{"__ignoreMap":31},[36,134,135,137,139,141,143],{"class":38,"line":39},[36,136,76],{"class":75},[36,138,80],{"class":79},[36,140,83],{"class":75},[36,142,87],{"class":86},[36,144,90],{"class":79},[36,146,147,149,151,153,155],{"class":38,"line":45},[36,148,76],{"class":75},[36,150,97],{"class":79},[36,152,83],{"class":75},[36,154,102],{"class":86},[36,156,90],{"class":79},[36,158,159,161,163,165,167],{"class":38,"line":107},[36,160,76],{"class":75},[36,162,112],{"class":79},[36,164,83],{"class":75},[36,166,118],{"class":117},[36,168,90],{"class":79},[36,170,172],{"class":38,"line":171},4,[36,173,175],{"emptyLinePlaceholder":174},true,"\n",[36,177,179,182,186,189,191,194],{"class":38,"line":178},5,[36,180,181],{"class":79},"console.",[36,183,185],{"class":184},"sj_SG","log",[36,187,188],{"class":79},"(",[36,190,126],{"class":75},[36,192,193],{"class":79},"(a)); ",[36,195,197],{"class":196},"sQrFR","\u002F\u002F number 就是 int、float。\n",[36,199,201,203,205,207,209,212],{"class":38,"line":200},6,[36,202,181],{"class":79},[36,204,185],{"class":184},[36,206,188],{"class":79},[36,208,126],{"class":75},[36,210,211],{"class":79},"(b)); ",[36,213,214],{"class":196},"\u002F\u002F number\n",[36,216,218,220,222,224,226,229],{"class":38,"line":217},7,[36,219,181],{"class":79},[36,221,185],{"class":184},[36,223,188],{"class":79},[36,225,126],{"class":75},[36,227,228],{"class":79},"(str)); ",[36,230,231],{"class":196},"\u002F\u002F string\n",[16,233,234],{},"而這邊 JavaScript 也有所謂的型別轉換，例如原本的 string 變成 number",[26,236,238],{"className":66,"code":237,"language":68,"meta":31,"style":31},"var a = 4;\nconsole.log(typeof(a)); \u002F\u002F number\n\na = 'hello';\nconsole.log(typeof(a)); \u002F\u002F string\n",[33,239,240,252,266,270,281],{"__ignoreMap":31},[36,241,242,244,246,248,250],{"class":38,"line":39},[36,243,76],{"class":75},[36,245,80],{"class":79},[36,247,83],{"class":75},[36,249,87],{"class":86},[36,251,90],{"class":79},[36,253,254,256,258,260,262,264],{"class":38,"line":45},[36,255,181],{"class":79},[36,257,185],{"class":184},[36,259,188],{"class":79},[36,261,126],{"class":75},[36,263,193],{"class":79},[36,265,214],{"class":196},[36,267,268],{"class":38,"line":107},[36,269,175],{"emptyLinePlaceholder":174},[36,271,272,275,277,279],{"class":38,"line":171},[36,273,274],{"class":79},"a ",[36,276,83],{"class":75},[36,278,118],{"class":117},[36,280,90],{"class":79},[36,282,283,285,287,289,291,293],{"class":38,"line":178},[36,284,181],{"class":79},[36,286,185],{"class":184},[36,288,188],{"class":79},[36,290,126],{"class":75},[36,292,193],{"class":79},[36,294,231],{"class":196},[16,296,297],{},"因此 JavaScript 有兩個很危險的陷阱，也就是顯性的轉換(Explicit conversion)以及隱性的轉換(Implicit conversion)。",[16,299,300],{},"當我們無法確定型別時，其實在開發時會有很嚴重的問題發生，也就是 bug，我們會無法確認變數的型別，而顯性的轉換簡單來講就是你可以看到的轉換，以上面的範例來講，我們從程式碼可以推斷出它轉換成了 number 接下來又因為重新賦予值轉換成 string，這就是所謂的顯性轉換。",[16,302,303],{},"而隱性的轉換呢？簡單來講當你不確定 JavaScript 規則時，就很容易發生這種狀況，例如最常見的問題",[26,305,307],{"className":66,"code":306,"language":68,"meta":31,"style":31},"var a = 1;\n\na = a + '1';\n",[33,308,309,322,326],{"__ignoreMap":31},[36,310,311,313,315,317,320],{"class":38,"line":39},[36,312,76],{"class":75},[36,314,80],{"class":79},[36,316,83],{"class":75},[36,318,319],{"class":86}," 1",[36,321,90],{"class":79},[36,323,324],{"class":38,"line":45},[36,325,175],{"emptyLinePlaceholder":174},[36,327,328,330,332,334,337,340],{"class":38,"line":107},[36,329,274],{"class":79},[36,331,83],{"class":75},[36,333,80],{"class":79},[36,335,336],{"class":75},"+",[36,338,339],{"class":117}," '1'",[36,341,90],{"class":79},[16,343,344,345,348,349,353,354,357,358,361],{},"通常來講我們可能會認知為 ",[33,346,347],{},"2","，但是相信你看這一篇文章應該會疑惑 number 要怎麼跟 string 相加？因此這時候 JavaScript 就會很",[350,351,352],"strong",{},"雞婆","的依照一些規則幫你做型別轉換，例如加號運算子的規則是當「number 遇到 string 時，number 會被轉換成 string」，因此 ",[33,355,356],{},"a + '1';"," 會變成 ",[33,359,360],{},"11","，並且是一個字串。",[26,363,365],{"className":66,"code":364,"language":68,"meta":31,"style":31},"var a = 1;\n\na = a + '1';\n\nconsole.log(a, typeof(a)); \u002F\u002F 11, string\n",[33,366,367,379,383,397,401],{"__ignoreMap":31},[36,368,369,371,373,375,377],{"class":38,"line":39},[36,370,76],{"class":75},[36,372,80],{"class":79},[36,374,83],{"class":75},[36,376,319],{"class":86},[36,378,90],{"class":79},[36,380,381],{"class":38,"line":45},[36,382,175],{"emptyLinePlaceholder":174},[36,384,385,387,389,391,393,395],{"class":38,"line":107},[36,386,274],{"class":79},[36,388,83],{"class":75},[36,390,80],{"class":79},[36,392,336],{"class":75},[36,394,339],{"class":117},[36,396,90],{"class":79},[36,398,399],{"class":38,"line":171},[36,400,175],{"emptyLinePlaceholder":174},[36,402,403,405,407,410,412,414],{"class":38,"line":178},[36,404,181],{"class":79},[36,406,185],{"class":184},[36,408,409],{"class":79},"(a, ",[36,411,126],{"class":75},[36,413,193],{"class":79},[36,415,416],{"class":196},"\u002F\u002F 11, string\n",[16,418,419],{},"而這就是所謂的隱性轉換。",[16,421,422],{},"當我們可以理解這些規則後也就可以避免一些開發上的 bug。",[12,424,425],{"id":425},"參考文獻",[427,428,429],"ul",{},[430,431,432],"li",{},[433,434,438],"a",{"href":435,"rel":436},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[437],"nofollow","JavaScript 核心篇",[440,441,442],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":31,"searchDepth":45,"depth":45,"links":444},[445,446,447],{"id":14,"depth":45,"text":14},{"id":21,"depth":45,"text":21},{"id":425,"depth":45,"text":425},"JavaScript","2020-06-21 16:41:54","md","zh-Hant",{},"\u002Fjavascript\u002F\u002Fjavascript-13",{"title":6,"description":18},false,"JavaScript 核心觀念\u002F2.運算子、型別與文法\u002FJavaScript-核心觀念-13-運算子、型別與文法-動態型別",[448,438,458],"運算子、型別與文法",null,"\u002Fjavascript\u002F20200621\u002F3160672433\u002F","md-SxiYmX5I2YPEe2eUTgZUS_OLmYLYhB1HCgrDCRdE",{"newer":463,"older":467},{"url":464,"title":465,"date":466},"\u002Fjavascript\u002F20200621\u002F3684249269\u002F","JavaScript 核心觀念(14)-運算子、型別與文法-原始型別及物件型別","2020-06-21 20:41:52",{"url":468,"title":469,"date":470},"\u002Fjavascript\u002F20