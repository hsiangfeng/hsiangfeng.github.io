],{"class":72},"sCcAr"," 1",[55,75,76],{"class":65},";\n",[55,78,80,83,87,90,94,97],{"class":57,"line":79},2,[55,81,82],{"class":65},"console.",[55,84,86],{"class":85},"sj_SG","log",[55,88,89],{"class":65},"(",[55,91,93],{"class":92},"sTRMh","'a:'",[55,95,96],{"class":61}," +",[55,98,99],{"class":65}," a);\n",[16,101,102,103,106],{},"一開始我們正常運行可以預先知道我們將會得到 ",[26,104,105],{},"a:1"," 的答案 ↓",[16,108,109],{},[110,111],"img",{"alt":105,"src":112},"https:\u002F\u002Fi.imgur.com\u002FdaUmYwF.png",[16,114,115,116,119,120,123],{},"但是如果此時我們再將 ",[26,117,118],{},"console.log('a:' + a);"," 丟到 ",[26,121,122],{},"var a = 1;"," 的前面呢?那此時會發生何事?",[46,125,127],{"className":48,"code":126,"language":50,"meta":51,"style":51},"console.log('a:' + a);\nvar a = 1;\nconsole.log('a:' + a);\n",[26,128,129,143,155],{"__ignoreMap":51},[55,130,131,133,135,137,139,141],{"class":57,"line":58},[55,132,82],{"class":65},[55,134,86],{"class":85},[55,136,89],{"class":65},[55,138,93],{"class":92},[55,140,96],{"class":61},[55,142,99],{"class":65},[55,144,145,147,149,151,153],{"class":57,"line":79},[55,146,62],{"class":61},[55,148,66],{"class":65},[55,150,69],{"class":61},[55,152,73],{"class":72},[55,154,76],{"class":65},[55,156,158,160,162,164,166,168],{"class":57,"line":157},3,[55,159,82],{"class":65},[55,161,86],{"class":85},[55,163,89],{"class":65},[55,165,93],{"class":92},[55,167,96],{"class":61},[55,169,99],{"class":65},[16,171,172,173,176,177,179],{},"我們會發現第一個 ",[26,174,175],{},"a"," 會輸出 ",[26,178,21],{}," ↓",[16,181,182],{},[110,183],{"alt":21,"src":184},"https:\u002F\u002Fi.imgur.com\u002F10tl7si.png",[16,186,187],{},"讓我們回頭思考一下 Hoisting 的階段，並將上面程式碼做拆解，首先變數會被提升至最前面，所以實際程式碼會是這個樣子：",[46,189,191],{"className":48,"code":190,"language":50,"meta":51,"style":51},"\u002F\u002F 創造階段\nvar a;\n\n\u002F\u002F 執行階段\nconsole.log('a:' + a);\na = 1;\nconsole.log('a:' + a);\n",[26,192,193,199,206,212,218,233,245],{"__ignoreMap":51},[55,194,195],{"class":57,"line":58},[55,196,198],{"class":197},"sQrFR","\u002F\u002F 創造階段\n",[55,200,201,203],{"class":57,"line":79},[55,202,62],{"class":61},[55,204,205],{"class":65}," a;\n",[55,207,208],{"class":57,"line":157},[55,209,211],{"emptyLinePlaceholder":210},true,"\n",[55,213,215],{"class":57,"line":214},4,[55,216,217],{"class":197},"\u002F\u002F 執行階段\n",[55,219,221,223,225,227,229,231],{"class":57,"line":220},5,[55,222,82],{"class":65},[55,224,86],{"class":85},[55,226,89],{"class":65},[55,228,93],{"class":92},[55,230,96],{"class":61},[55,232,99],{"class":65},[55,234,236,239,241,243],{"class":57,"line":235},6,[55,237,238],{"class":65},"a ",[55,240,69],{"class":61},[55,242,73],{"class":72},[55,244,76],{"class":65},[55,246,248,250,252,254,256,258],{"class":57,"line":247},7,[55,249,82],{"class":65},[55,251,86],{"class":85},[55,253,89],{"class":65},[55,255,93],{"class":92},[55,257,96],{"class":61},[55,259,99],{"class":65},[16,261,262,263,267,268,270,271,273,274,179],{},"那由於 JavaScript 有 Hoisting 特性，所以通常 JavaScript 會預設替提升的變數賦予一個特殊關鍵字，注意是",[264,265,266],"strong",{},"特殊關鍵字","，也就是 ",[26,269,21],{},"，所以若你只輸入以下程式碼，其實就可以看到 ",[26,272,175],{}," 會被預設賦予 ",[26,275,21],{},[46,277,279],{"className":48,"code":278,"language":50,"meta":51,"style":51},"var a\nconsole.log(a);\n",[26,280,281,288],{"__ignoreMap":51},[55,282,283,285],{"class":57,"line":58},[55,284,62],{"class":61},[55,286,287],{"class":65}," a\n",[55,289,290,292,294],{"class":57,"line":79},[55,291,82],{"class":65},[55,293,86],{"class":85},[55,295,296],{"class":65},"(a);\n",[16,298,299],{},[110,300],{"alt":21,"src":301},"https:\u002F\u002Fi.imgur.com\u002FAvcHQHM.png",[16,303,304,305,307,308,313],{},"由此可知我們可以理解一件事情，變數在還沒賦予值之前是會被賦予預設值，也就是 ",[26,306,21],{},"，但是這邊要注意一件事情",[264,309,310,311],{},"千萬不要替變數賦予 ",[26,312,21],{},"，這將會導致你搞不清楚該變數到底有沒有被賦值。",[16,315,316,317,320],{},"如果你真的要賦值，我會建議改用 ",[26,318,319],{},"null","。",[16,322,323,324,326,327,320],{},"我們可以看到若單純只建立變數而不賦予值就會得到 ",[26,325,21],{},"，反之若沒有建立變數則會出現 ",[26,328,31],{},[12,330,31],{"id":331},"not-defined",[16,333,334,336],{},[26,335,31],{}," 以字面上來看就是未定義的意思，什麼叫未定義?我們可以從程式碼來觀看：",[46,338,340],{"className":48,"code":339,"language":50,"meta":51,"style":51},"console.log(mon);\n",[26,341,342],{"__ignoreMap":51},[55,343,344,346,348],{"class":57,"line":58},[55,345,82],{"class":65},[55,347,86],{"class":85},[55,349,350],{"class":65},"(mon);\n",[16,352,353,354,356,357],{},"從上述程式碼我們可以理解到一件事情，",[26,355,31],{}," 的白話文意思就是",[264,358,359],{},"沒有這個東西啦!!",[16,361,362],{},[110,363],{"alt":364,"src":365},"兇，怕豹.jpg","https:\u002F\u002Fi.imgur.com\u002FrKGPPtJ.png",[16,367,368,369,372],{},"所以當你以後看到 ",[26,370,371],{},"XXX is not defined","，就代表你忘記宣告變數(函式)或是名子打錯囉~",[16,374,375],{},[110,376],{"alt":377,"src":378},"mon is not defined","https:\u002F\u002Fi.imgur.com\u002FPIjIMYs.png",[12,380,381],{"id":381},"結尾",[16,383,384],{},"下一篇的 RE：從零開始的學習 JS 生活-第二十四日將會介紹 Callback Hell。",[386,387,388],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":51,"searchDepth":79,"depth":79,"links":390},[391,392,393,394],{"id":14,"depth":79,"text":14},{"id":21,"depth":79,"text":21},{"id":331,"depth":79,"text":31},{"id":381,"depth":79,"text":381},"JavaScript","2019-10-09 00:00:01","md","zh-Hant",