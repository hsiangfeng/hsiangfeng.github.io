[{"data":1,"prerenderedAt":972},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20211126\u002F12988607\u002F":3,"page:\u002Fjavascript\u002F20211126\u002F12988607\u002F":4,"alt:\u002Fjavascript\u002F20211126\u002F12988607\u002F":3,"prev-next:\u002Fjavascript\u002F20211126\u002F12988607\u002F":947,"related:\u002Fjavascript\u002F20211126\u002F12988607\u002F":956},"\u002Fen\u002Fjavascript\u002F2021\u002F11\u002F26\u002Fjavascript-error-types-reference\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":932,"date":933,"description":18,"extension":934,"lang":935,"meta":936,"navigation":494,"path":937,"readingMinutes":938,"seo":939,"standalone":940,"stem":941,"tags":942,"tldr":944,"updated":944,"url":945,"__hash__":946},"content\u002FJavaScript\u002FJavaScript-錯誤類型-JavaScript-Error-Reference.md","JavaScript 錯誤類型(JavaScript Error Reference)","12988607",{"type":9,"value":10,"toc":921},"minimark",[11,15,19,23,26,45,49,52,55,106,109,133,136,182,185,232,243,311,319,337,340,344,347,381,384,426,430,433,453,460,521,524,549,552,607,611,614,617,649,652,689,698,708,745,750,784,788,791,794,841,844,847,875,878,900,903,906,917],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"這一篇稍微整理一下 JavaScript 中各種錯誤的訊息，畢竟開發上我們是很常看到紅色的錯誤訊息，若能夠快速掌握錯誤訊息的類型的話，其實也可以幫助我們 debug。",[12,20,22],{"id":21},"錯誤類型error-reference","錯誤類型(Error Reference)",[16,24,25],{},"JavaScript 中的錯誤類型有以下",[27,28,29,33,36,39,42],"ul",{},[30,31,32],"li",{},"SyntaxError",[30,34,35],{},"RangeError",[30,37,38],{},"ReferenceError",[30,40,41],{},"TypeError",[30,43,44],{},"URIError",[12,46,48],{"id":47},"syntaxerror-語法錯誤","SyntaxError (語法錯誤)",[16,50,51],{},"SyntaxError 非常顧名思義就是語法使用上的錯誤",[16,53,54],{},"使用了不正確的命名宣告：",[56,57,62],"pre",{"className":58,"code":59,"language":60,"meta":61,"style":61},"language-js shiki shiki-themes github-dark-high-contrast","\u002F\u002F Uncaught SyntaxError: missing variable name\nvar 1;\n\u002F\u002F Uncaught SyntaxError: missing variable name\nvar '小明' = 1;\n","js","",[63,64,65,74,85,90],"code",{"__ignoreMap":61},[66,67,70],"span",{"class":68,"line":69},"line",1,[66,71,73],{"class":72},"sQrFR","\u002F\u002F Uncaught SyntaxError: missing variable name\n",[66,75,77,81],{"class":68,"line":76},2,[66,78,80],{"class":79},"sWyjQ","var",[66,82,84],{"class":83},"sMAXC"," 1;\n",[66,86,88],{"class":68,"line":87},3,[66,89,73],{"class":72},[66,91,93,95,98,102],{"class":68,"line":92},4,[66,94,80],{"class":79},[66,96,97],{"class":83}," '小明",[66,99,101],{"class":100},"sTRMh","' = 1",[66,103,105],{"class":104},"szH_Z",";\n",[16,107,108],{},"常見的 LHS (Left-Head Side) 錯誤：",[56,110,112],{"className":58,"code":111,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: invalid assignment left-hand side\n'小明' = 1;\n",[63,113,114,119],{"__ignoreMap":61},[66,115,116],{"class":68,"line":69},[66,117,118],{"class":72},"\u002F\u002F Uncaught SyntaxError: invalid assignment left-hand side\n",[66,120,121,124,127,131],{"class":68,"line":76},[66,122,123],{"class":100},"'小明'",[66,125,126],{"class":79}," =",[66,128,130],{"class":129},"sCcAr"," 1",[66,132,105],{"class":83},[16,134,135],{},"沒有正確撰寫括號：",[56,137,139],{"className":58,"code":138,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: expected expression, got '}'\nif(true) \n  console.log('Ray');\n}\n",[63,140,141,146,160,177],{"__ignoreMap":61},[66,142,143],{"class":68,"line":69},[66,144,145],{"class":72},"\u002F\u002F Uncaught SyntaxError: expected expression, got '}'\n",[66,147,148,151,154,157],{"class":68,"line":76},[66,149,150],{"class":79},"if",[66,152,153],{"class":83},"(",[66,155,156],{"class":129},"true",[66,158,159],{"class":83},") \n",[66,161,162,165,169,171,174],{"class":68,"line":87},[66,163,164],{"class":83},"  console.",[66,166,168],{"class":167},"sj_SG","log",[66,170,153],{"class":83},[66,172,173],{"class":100},"'Ray'",[66,175,176],{"class":83},");\n",[66,178,179],{"class":68,"line":92},[66,180,181],{"class":83},"}\n",[16,183,184],{},"缺少逗號：",[56,186,188],{"className":58,"code":187,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: missing } after property list\nvar obj = {\n  myName: 'Ray' \n  Url: 'https:\u002F\u002Fisraynotarray.com\u002F'\n};\n",[63,189,190,195,208,218,226],{"__ignoreMap":61},[66,191,192],{"class":68,"line":69},[66,193,194],{"class":72},"\u002F\u002F Uncaught SyntaxError: missing } after property list\n",[66,196,197,199,202,205],{"class":68,"line":76},[66,198,80],{"class":79},[66,200,201],{"class":83}," obj ",[66,203,204],{"class":79},"=",[66,206,207],{"class":83}," {\n",[66,209,210,213,215],{"class":68,"line":87},[66,211,212],{"class":83},"  myName: ",[66,214,173],{"class":100},[66,216,217],{"class":83}," \n",[66,219,220,223],{"class":68,"line":92},[66,221,222],{"class":83},"  Url: ",[66,224,225],{"class":100},"'https:\u002F\u002Fisraynotarray.com\u002F'\n",[66,227,229],{"class":68,"line":228},5,[66,230,231],{"class":83},"};\n",[16,233,234,235,238,239,242],{},"使用 ",[63,236,237],{},"const","、",[63,240,241],{},"let"," 重複宣告：",[56,244,246],{"className":58,"code":245,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: redeclaration of const myName\nconst myName = 'Ray';\nconst myName = 'Array';\n\u002F\u002F Uncaught SyntaxError: redeclaration of let myName\nlet myName = 'Ray';\nlet myName = 'Array';\n",[63,247,248,253,267,280,285,298],{"__ignoreMap":61},[66,249,250],{"class":68,"line":69},[66,251,252],{"class":72},"\u002F\u002F Uncaught SyntaxError: redeclaration of const myName\n",[66,254,255,257,260,262,265],{"class":68,"line":76},[66,256,237],{"class":79},[66,258,259],{"class":129}," myName",[66,261,126],{"class":79},[66,263,264],{"class":100}," 'Ray'",[66,266,105],{"class":83},[66,268,269,271,273,275,278],{"class":68,"line":87},[66,270,237],{"class":79},[66,272,259],{"class":129},[66,274,126],{"class":79},[66,276,277],{"class":100}," 'Array'",[66,279,105],{"class":83},[66,281,282],{"class":68,"line":92},[66,283,284],{"class":72},"\u002F\u002F Uncaught SyntaxError: redeclaration of let myName\n",[66,286,287,289,292,294,296],{"class":68,"line":228},[66,288,241],{"class":79},[66,290,291],{"class":83}," myName ",[66,293,204],{"class":79},[66,295,264],{"class":100},[66,297,105],{"class":83},[66,299,301,303,305,307,309],{"class":68,"line":300},6,[66,302,241],{"class":79},[66,304,291],{"class":83},[66,306,204],{"class":79},[66,308,277],{"class":100},[66,310,105],{"class":83},[16,312,313,315,316,318],{},[63,314,237],{}," 缺少初始值(",[63,317,241],{}," 並不會有此問題)：",[56,320,322],{"className":58,"code":321,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught SyntaxError: missing = in const declaration\nconst myName;\n",[63,323,324,329],{"__ignoreMap":61},[66,325,326],{"class":68,"line":69},[66,327,328],{"class":72},"\u002F\u002F Uncaught SyntaxError: missing = in const declaration\n",[66,330,331,333,335],{"class":68,"line":76},[66,332,237],{"class":79},[66,334,259],{"class":129},[66,336,105],{"class":83},[16,338,339],{},"語法錯誤的錯誤狀況非常多，所以只列出特定幾種常見的。",[12,341,343],{"id":342},"rangeerror-範圍錯誤","RangeError (範圍錯誤)",[16,345,346],{},"基本上這個錯誤很少見，主要常見於無效的陣列長度，例如：",[56,348,350],{"className":58,"code":349,"language":60,"meta":61,"style":61},"const array = new Array(-1); \u002F\u002F Uncaught RangeError: invalid array length\n",[63,351,352],{"__ignoreMap":61},[66,353,354,356,359,361,364,367,369,372,375,378],{"class":68,"line":69},[66,355,237],{"class":79},[66,357,358],{"class":129}," array",[66,360,126],{"class":79},[66,362,363],{"class":79}," new",[66,365,366],{"class":167}," Array",[66,368,153],{"class":83},[66,370,371],{"class":79},"-",[66,373,374],{"class":129},"1",[66,376,377],{"class":83},"); ",[66,379,380],{"class":72},"\u002F\u002F Uncaught RangeError: invalid array length\n",[16,382,383],{},"又或者是這樣子：",[56,385,387],{"className":58,"code":386,"language":60,"meta":61,"style":61},"let arr = [];\narr.length = arr.length - 1; \u002F\u002F Uncaught RangeError: invalid array length\n",[63,388,389,401],{"__ignoreMap":61},[66,390,391,393,396,398],{"class":68,"line":69},[66,392,241],{"class":79},[66,394,395],{"class":83}," arr ",[66,397,204],{"class":79},[66,399,400],{"class":83}," [];\n",[66,402,403,406,409,411,414,416,419,421,424],{"class":68,"line":76},[66,404,405],{"class":83},"arr.",[66,407,408],{"class":129},"length",[66,410,126],{"class":79},[66,412,413],{"class":83}," arr.",[66,415,408],{"class":129},[66,417,418],{"class":79}," -",[66,420,130],{"class":129},[66,422,423],{"class":83},"; ",[66,425,380],{"class":72},[12,427,429],{"id":428},"referenceerror-參考引用錯誤","ReferenceError (參考、引用錯誤)",[16,431,432],{},"呼叫一個不存在的變數或函式：",[56,434,436],{"className":58,"code":435,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught ReferenceError: myName is not defined\nconsole.log(myName);\n",[63,437,438,443],{"__ignoreMap":61},[66,439,440],{"class":68,"line":69},[66,441,442],{"class":72},"\u002F\u002F Uncaught ReferenceError: myName is not defined\n",[66,444,445,448,450],{"class":68,"line":76},[66,446,447],{"class":83},"console.",[66,449,168],{"class":167},[66,451,452],{"class":83},"(myName);\n",[16,454,455,238,457,459],{},[63,456,241],{},[63,458,237],{}," 宣告之前呼叫：",[56,461,463],{"className":58,"code":462,"language":60,"meta":61,"style":61},"\u002F\u002F Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization\nconsole.log(myName);\nconst myName = 'Ray';\n\n\u002F\u002F Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization\nconsole.log(myName);\nlet myName = 'Ray';\n",[63,464,465,470,478,490,496,500,508],{"__ignoreMap":61},[66,466,467],{"class":68,"line":69},[66,468,469],{"class":72},"\u002F\u002F Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization\n",[66,471,472,474,476],{"class":68,"line":76},[66,473,447],{"class":83},[66,475,168],{"class":167},[66,477,452],{"class":83},[66,479,480,482,484,486,488],{"class":68,"line":87},[66,481,237],{"class":79},[66,483,259],{"class":129},[66,485,126],{"class":79},[66,487,264],{"clas