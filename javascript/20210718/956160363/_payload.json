lass":48,"line":67},2,[46,69,71],{"class":70},"sWyjQ","var",[46,73,74],{"class":52}," myName ",[46,76,77],{"class":70},"=",[46,79,81],{"class":80},"sTRMh"," 'Ray'",[46,83,84],{"class":52},";\n",[46,86,88,90,92,94],{"class":48,"line":87},3,[46,89,53],{"class":52},[46,91,57],{"class":56},[46,93,60],{"class":52},[46,95,96],{"class":63},"\u002F\u002F Ray\n",[16,98,99],{},"這邊也算是簡單的複習一下非常前面的章節，否則看到現在可能都已經忘記了。",[16,101,102],{},"基本上 Hoisting 會區分為創造階段與執行階段：",[37,104,106],{"className":39,"code":105,"language":41,"meta":42,"style":42},"\u002F\u002F 創造階段\nvar myName;\n\u002F\u002F 執行階段\nconsole.log(myName); \u002F\u002F undefined\nmyName = 'Ray';\nconsole.log(myName); \u002F\u002F Ray\n",[20,107,108,113,120,125,136,148],{"__ignoreMap":42},[46,109,110],{"class":48,"line":49},[46,111,112],{"class":63},"\u002F\u002F 創造階段\n",[46,114,115,117],{"class":48,"line":67},[46,116,71],{"class":70},[46,118,119],{"class":52}," myName;\n",[46,121,122],{"class":48,"line":87},[46,123,124],{"class":63},"\u002F\u002F 執行階段\n",[46,126,128,130,132,134],{"class":48,"line":127},4,[46,129,53],{"class":52},[46,131,57],{"class":56},[46,133,60],{"class":52},[46,135,64],{"class":63},[46,137,139,142,144,146],{"class":48,"line":138},5,[46,140,141],{"class":52},"myName ",[46,143,77],{"class":70},[46,145,81],{"class":80},[46,147,84],{"class":52},[46,149,151,153,155,157],{"class":48,"line":150},6,[46,152,53],{"class":52},[46,154,57],{"class":56},[46,156,60],{"class":52},[46,158,96],{"class":63},[16,160,161,162,164,165,167,168,170],{},"而上面的範例是基於 ",[20,163,71],{}," 來宣告變數的情況，那麼 ",[20,166,22],{}," 呢？",[20,169,22],{}," 也會有相同問題嗎？你可以試著將程式碼修改成以下：",[37,172,174],{"className":39,"code":173,"language":41,"meta":42,"style":42},"console.log(myName); \u002F\u002F ?\nlet myName = 'Ray';\n",[20,175,176,187],{"__ignoreMap":42},[46,177,178,180,182,184],{"class":48,"line":49},[46,179,53],{"class":52},[46,181,57],{"class":56},[46,183,60],{"class":52},[46,185,186],{"class":63},"\u002F\u002F ?\n",[46,188,189,191,193,195,197],{"class":48,"line":67},[46,190,22],{"class":70},[46,192,74],{"class":52},[46,194,77],{"class":70},[46,196,81],{"class":80},[46,198,84],{"class":52},[16,200,201,202,205,206,209,210,213],{},"相信你輸入以上程式碼的時候應該要出現 ",[20,203,204],{},"Uncaught ReferenceError: Cannot access 'myName' brfore initialization.","，如果你是在較新版的 Chrome 瀏覽器輸入你會發現實際上出現的是則是會出現 ",[20,207,208],{},"Uncaught ReferenceError: myName is not defined","，而 Firefox 目前我測試 89.0.2（64 位元）版本則是 ",[20,211,212],{},"Uncaught ReferenceError: can't access lexical declaration 'myName' before initialization","。",[16,215,216],{},"因此這代表著瀏覽器更新之後是會更新錯誤訊息的，這一點要多加注意一下，雖然我覺得 Chrome 的錯誤訊息比較直覺就是了：",[37,218,220],{"className":39,"code":219,"language":41,"meta":42,"style":42},"\u002F\u002F Chrome：\nconsole.log(a); \u002F\u002F Uncaught ReferenceError: a is not defined\nlet a = '1';\n\n\u002F\u002F Firefox：\nconsole.log(a); \u002F\u002F ReferenceError: can't access lexical declaration `a' before initialization\nlet a = '1';\n",[20,221,222,227,239,253,259,264,275],{"__ignoreMap":42},[46,223,224],{"class":48,"line":49},[46,225,226],{"class":63},"\u002F\u002F Chrome：\n",[46,228,229,231,233,236],{"class":48,"line":67},[46,230,53],{"class":52},[46,232,57],{"class":56},[46,234,235],{"class":52},"(a); ",[46,237,238],{"class":63},"\u002F\u002F Uncaught ReferenceError: a is not defined\n",[46,240,241,243,246,248,251],{"class":48,"line":87},[46,242,22],{"class":70},[46,244,245],{"class":52}," a ",[46,247,77],{"class":70},[46,249,250],{"class":80}," '1'",[46,252,84],{"class":52},[46,254,255],{"class":48,"line":127},[46,256,258],{"emptyLinePlaceholder":257},true,"\n",[46,260,261],{"class":48,"line":138},[46,262,263],{"class":63},"\u002F\u002F Firefox：\n",[46,265,266,268,270,272],{"class":48,"line":150},[46,267,53],{"class":52},[46,269,57],{"class":56},[46,271,235],{"class":52},[46,273,274],{"class":63},"\u002F\u002F ReferenceError: can't access lexical declaration `a' before initialization\n",[46,276,278,280,282,284,286],{"class":48,"line":277},7,[46,279,22],{"class":70},[46,281,245],{"class":52},[46,283,77],{"class":70},[46,285,250],{"class":80},[46,287,84],{"class":52},[16,289,290],{},"但是如果是 const 的話，錯誤訊息就沒有太大差異：",[37,292,294],{"className":39,"code":293,"language":41,"meta":42,"style":42},"\u002F\u002F Chrome：\nconsole.log(a); \u002F\u002F Uncaught ReferenceError: Cannot access 'a' before initialization\nconst a = '1';\n\n\u002F\u002F Firefox：\nconsole.log(a); \u002F\u002F ReferenceError: can't access lexical declaration `a' before initialization\nconst a = '1';\n",[20,295,296,300,311,327,331,335,345],{"__ignoreMap":42},[46,297,298],{"class":48,"line":49},[46,299,226],{"class":63},[46,301,302,304,306,308],{"class":48,"line":67},[46,303,53],{"class":52},[46,305,57],{"class":56},[46,307,235],{"class":52},[46,309,310],{"class":63},"\u002F\u002F Uncaught ReferenceError: Cannot access 'a' before initialization\n",[46,312,313,316,320,323,325],{"class":48,"line":87},[46,314,315],{"class":70},"const",[46,317,319],{"class":318},"sCcAr"," a",[46,321,322],{"class":70}," =",[46,324,250],{"class":80},[46,326,84],{"class":52},[46,328,329],{"class":48,"line":127},[46,330,258],{"emptyLinePlaceholder":257},[46,332,333],{"class":48,"line":138},[46,334,263],{"class":63},[46,336,337,339,341,343],{"class":48,"line":150},[46,338,53],{"class":52},[46,340,57],{"class":56},[46,342,235],{"class":52},[46,344,274],{"class":63},[46,346,347,349,351,353,355],{"class":48,"line":277},[46,348,315],{"class":70},[46,350,319],{"class":318},[46,352,322],{"class":70},[46,354,250],{"class":80},[46,356,84],{"class":52},[16,358,359,360,366],{},"那麼我們明白了瀏覽器會更新錯誤訊息之後，那我們怎麼知道它有沒有提升呢？其實我們可以翻一下 ",[31,361,365],{"href":362,"rel":363},"https:\u002F\u002Fdeveloper.mozilla.org\u002Fzh-TW\u002Fdocs\u002FWeb\u002FJavaScript\u002FReference\u002FStatements\u002Flet#temporal_dead_zone_and_errors_with_let",[364],"nofollow","MDN"," 文件，有一句話是關鍵：",[368,369,370],"blockquote",{},[16,371,372],{},"The variable is in a \"temporal dead zone\" from the start of the block until the initialization is processed.",[16,374,375,376,379,380,382,383,385],{},"在變數完成初始化之前呼叫的話，是會處於暫時性死區 (TDZ)，這也就是為什麼會出現 ",[20,377,378],{},"ReferenceError"," 錯誤，而實際上 ",[20,381,22],{}," 運作模式有變嗎？其實並沒有，只是會變成 ",[20,384,378],{}," 暫時性死區錯誤：",[37,387,389],{"className":39,"code":388,"language":41,"meta":42,"style":42},"\u002F\u002F 創造階段\nlet myName;\n\n\u002F\u002F 執行階段\nconsole.log(myName); \u002F\u002F Uncaught ReferenceError: a is not defined\nmyName = 'Ray';\nconsole.log(myName);\n",[20,390,391,395,401,405,409,419,429],{"__ignoreMap":42},[46,392,393],{"class":48,"line":49},[46,394,112],{"class":63},[46,396,397,399],{"class":48,"line":67},[46,398,22],{"class":70},[46,400,119],{"class":52},[46,402,403],{"class":48,"line":87},[46,404,258],{"emptyLinePlaceholder":257},[46,406,407],{"class":48,"line":127},[46,408,124],{"class":63},[46,410,411,413,415,417],{"class":48,"line":138},[46,412,53],{"class":52},[46,414,57],{"class":56},[46,416,60],{"class":52},[46,418,238],{"class":63},[46,420,421,423,425,427],{"class":48,"line":150},[46,422,141],{"class":52},[46,424,77],{"class":70},[46,426,81],{"class":80},[46,428,84],{"class":52},[46,430,431,433,435],{"class":48,"line":277},[46,432,53],{"class":52},[46,434,57],{"class":56},[46,436,437],{"class":52},"(myName);\n",[16,439,440,441,443,444,447,448,450,451,453],{},"這邊要注意 ",[20,442,22],{}," 會在 ",[20,445,446],{},"myName = 'Ray';"," 之前建立一個暫時性死區的階段，所以你在 ",[20,449,446],{}," 勢必都會出現 ",[20,452,378],{}," 錯誤的。",[16,455,456,457,459,460,463,464,467],{},"那麼我們該怎麼驗證 ",[20,458,22],{}," 有提升呢？首先一般來說如果你想要 ",[20,461,462],{},"console.log"," 一個不存在的變數是會得到 ",[20,465,466],{},"Uncaught ReferenceError: xxx is not defined"," 的，例如：",[37,469,471],{"className":39,"code":470,"language":41,"meta":42,"style":42},"console.log(a); \u002F\u002F Uncaught ReferenceError: a is not defined\n",[20,472,473],{"__ignoreMap":42},[46,474,475,477,479,481],{"class":48,"line":49},[46,476,53],{"class":52},[46,478,57],{"class":56},[46,480,235],{"class":52},[46,482,238],{"class":63},[16,484,485,486,489,490,493],{},"但是如果你使用 ",[20,487,488],{},"console.log(typeof(a))"," 則是會出現 ",[20,491,492],{},"undefined","，因此我們可以這樣子驗證：",[37,495,497],{"className":39,"code":496,"language":41,"meta":42,"style":42},"console.log(typeof(a)); \u002F\u002F undefined\nconsole.log(typeof(myName)); \u002F\u002F Uncaught ReferenceError: myName is not defined\nlet myName = 'Ray';\n",[20,498,499,516,532],{"__ignoreMap":42},[46,500,501,503,505,508,511,514],{"class":48,"line":49},[46,502,53],{"class":52},[46,504,57],{"class":56},[46,506,507],{"class":52},"(",[46,509,510],{"class":70},"typeof",[46,512,513],{"class":52},"(a)); ",[46,515,64],{"class":63},[46,517,518,520,522,524,526,529],{"class":48,"line":67},[46,519,53],{"class":52},[46,521,57],{"class":56},[46,523,507],{"class":52},[46,525,510],{"class":70},[46,527,528],{"class":52},"(myName)); ",[46,530,531],{"class":63},"\u002F\u002F Uncaught ReferenceError: myName is not defined\n",[46,533,534,536,538,540,542],{"class":48,"line":87},[46,535,22],{"class":70},[46,537,74],{"class":52},[46,539,77],{"class":70},[46,541,81],{"class":80},[46,543,84],{"class":52},[16,545,546],{},"因此這邊就可以得到一個結論是「在變數初始化的中間過程，是會生成一個 TDZ 暫時性死區的」。",[12,548,549],{"id":549},"參考文獻",[551,552,553],"ul",{},[554,555,556],"li",{},[31,557,560],{"href":558,"rel":559},"https:\u002F\u002Fwww.hexschool.com\u002Fcourses\u002Fjs-core.html",[364],"JavaScript 核心篇",[562,563,564],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}htm