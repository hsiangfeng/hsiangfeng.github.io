":116},[36,205,206],{"class":46},"(a ",[36,208,209],{"class":42},"===",[36,211,212],{"class":46}," b); ",[36,214,215],{"class":56},"true\n",[16,217,218],{},"這邊也附上動畫繪畫",[16,220,221],{},[158,222],{"alt":223,"src":224},"動畫效果","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%8F%90%E5%8D%87%E8%A8%98%E6%86%B6%E9%AB%94.gif",[12,226,227],{"id":227},"第二步驟",[16,229,230,231,233,234],{},"接下來是執行階段的記憶體賦予，因此這邊同時物件會建立一個記憶體位置，並且 ",[33,232,145],{}," 的記憶體位置會被賦予到 ",[33,235,149],{},[26,237,239],{"className":28,"code":238,"language":30,"meta":31,"style":31},"a = { x: 1};\nb = a;\n",[33,240,241,254],{"__ignoreMap":31},[36,242,243,246,248,250,252],{"class":38,"line":39},[36,244,245],{"class":46},"a ",[36,247,50],{"class":42},[36,249,53],{"class":46},[36,251,57],{"class":56},[36,253,60],{"class":46},[36,255,256,259,261],{"class":38,"line":63},[36,257,258],{"class":46},"b ",[36,260,50],{"class":42},[36,262,73],{"class":46},[16,264,265],{},[158,266],{"alt":267,"src":268},"記憶體建立與賦予","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-08-30%2000.29.12.png",[16,270,271],{},"在這邊的過程如果不清楚的話，可以回顧我上一章節。",[16,273,274],{},[158,275],{"alt":276,"src":277},"動畫運作","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E8%AE%8A%E6%95%B8%E8%B3%A6%E4%BA%88%E9%81%8E%E7%A8%8B.gif",[12,279,280],{"id":280},"第三階段",[16,282,283,284,287,288,291,292,295,296,299,300,302],{},"在這邊接下來的行為會稍微複雜一點，其中因為針對 ",[33,285,286],{},"a.x"," 賦予到另一個新的物件記憶體空間，並且額外新增了一個屬性叫做 ",[33,289,290],{},"a.y"," 並在最後同時執行了 ",[33,293,294],{},"a.y = a = { y: 1};"," 的新的記憶體空間，但是在這邊說同時執行可能會很混亂，因此可以用相依性特性來看，等號的相依性是從右邊開始，因此 ",[33,297,298],{},"a = { y: 1};"," 會優先執行，並且會因為表達式會回傳結果，所以 ",[33,301,290],{}," 其實是接收表達式的結果，因此你可以看成以下",[26,304,306],{"className":28,"code":305,"language":30,"meta":31,"styl