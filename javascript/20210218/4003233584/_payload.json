5,56],{},"node -v\n",[50,58,60],{"class":52,"line":59},2,[50,61,62],{},"npm -v\n",[16,64,65],{},"如果有出現版本號就代表你有安裝，如果沒有的話就建議你安裝，因此我這邊提供我的其他文章給您參考。",[67,68,69,77],"ul",{},[70,71,72],"li",{},[73,74,76],"a",{"href":75},"\u002Fnodejs\u002F20200124\u002F3404456418\u002F","Mac OS X 安裝 nvm",[70,78,79],{},[73,80,82],{"href":81},"\u002Fnodejs\u002F20200107\u002F3738078915\u002F","Windows 10 安裝並使用 nvm 切換 NodeJS 版本",[16,84,85],{},"當確定安裝完畢 Node.js 與 npm 之後在終端機輸入以下指令",[40,87,89],{"className":42,"code":88,"language":44,"meta":45,"style":45},"npm install eslint --global\n",[47,90,91],{"__ignoreMap":45},[50,92,93],{"class":52,"line":53},[50,94,88],{},[16,96,97,98,102],{},"(如果對於 npm 指令不熟悉的話，可參考我這一篇「",[73,99,101],{"href":100},"\u002Fnodejs\u002F20190626\u002F1317979814\u002F","npm 安裝指令差異","」)",[16,104,105,106,109,110,113],{},"安裝完畢之後你就可以輸入 ",[47,107,108],{},"eslint -v"," 查看是否有跳出版本號，若沒有跳出來代表沒有安裝成功，就在麻煩返回上一步重新輸入 ",[47,111,112],{},"npm install eslint --global","。",[12,115,117],{"id":116},"使用-eslint","使用 ESLint",[16,119,120],{},"接下來建立一個新的專案資料夾，只有一個檔案",[67,122,123],{},[70,124,125],{},"a.js",[16,127,128],{},"a.js 內容",[40,130,134],{"className":131,"code":132,"language":133,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","var a = 'Ray'\n\nfn()\n\nfunction fn() {\n  console.log(\"Hello Ray\");\n}\n","js",[47,135,136,153,159,169,174,186,204],{"__ignoreMap":45},[50,137,138,142,146,149],{"class":52,"line":53},[50,139,141],{"class":140},"sWyjQ","var",[50,143,145],{"class":144},"sMAXC"," a ",[50,147,148],{"class":140},"=",[50,150,152],{"class":151},"sTRMh"," 'Ray'\n",[50,154,155],{"class":52,"line":59},[50,156,158],{"emptyLinePlaceholder":157},true,"\n",[50,160,162,166],{"class":52,"line":161},3,[50,163,165],{"class":164},"sj_SG","fn",[50,167,168],{"class":144},"()\n",[50,170,172],{"class":52,"line":171},4,[50,173,158],{"emptyLinePlaceholder":157},[50,175,177,180,183],{"class":52,"line":176},5,[50,178,179],{"class":140},"function",[50,181,182],{"class":164}," fn",[50,