[{"data":1,"prerenderedAt":349},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20190918\u002F4058380557\u002F":3,"page:\u002Fjavascript\u002F20190918\u002F4058380557\u002F":4,"alt:\u002Fjavascript\u002F20190918\u002F4058380557\u002F":3,"prev-next:\u002Fjavascript\u002F20190918\u002F4058380557\u002F":324,"related:\u002Fjavascript\u002F20190918\u002F4058380557\u002F":333},"\u002Fen\u002Fjavascript\u002F2019\u002F09\u002F18\u002Fjs-from-zero-03-dom-selectors\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":307,"date":308,"description":18,"extension":309,"lang":310,"meta":311,"navigation":312,"path":313,"readingMinutes":314,"seo":315,"standalone":316,"stem":317,"tags":318,"tldr":321,"updated":321,"url":322,"__hash__":323},"content\u002FRE：從零開始的學習 JS 生活\u002FEP-3-RE：從零開始的學習-JS-生活-第三日.md","EP.3 RE：從零開始的學習 JS 生活-第三日之選取器","4058380557",{"type":9,"value":10,"toc":302},"minimark",[11,15,19,22,25,31,39,81,88,94,100,103,156,167,179,184,189,195,198,223,226,231,243,249,259,276,285,292,295,298],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"轉生第三日，這一篇要來認識該如何選取 HTML 的元素，所以將會來介紹選取器。",[12,20,21],{"id":21},"選取器",[16,23,24],{},"選取 HTML 元素的方式有很多種語法，但是最常見的方式有兩種，一種是只能夠使用 ID 選擇，另一種則是可以選擇 ID 也可以選擇 ClassName，而以我個人開發習慣來講都是使用選擇 ID 的方式比較多，通常選取器的撰寫模式不外乎是這樣子 ↓",[16,26,27],{},[28,29],"img",{"alt":21,"src":30},"https:\u002F\u002Fi.imgur.com\u002FNreQdeO.png",[16,32,33,34,38],{},"首先先來講講選取 ID 的語法，而這個語法也是我個人比較習慣的方式，那麼也就是 ",[35,36,37],"code",{},"getElementById()","：",[40,41,46],"pre",{"className":42,"code":43,"language":44,"meta":45,"style":45},"language-js shiki shiki-themes github-dark-high-contrast","var boxId = document.getElementById('box');\n","js","",[35,47,48],{"__ignoreMap":45},[49,50,53,57,61,64,67,71,74,78],"span",{"class":51,"line":52},"line",1,[49,54,56],{"class":55},"sWyjQ","var",[49,58,60],{"class":59},"sMAXC"," boxId ",[49,62,63],{"class":55},"=",[49,65,66],{"class":59}," document.",[49,68,70],{"class":69},"sj_SG","getElementById",[49,72,73],{"class":59},"(",[49,75,77],{"class":76},"sTRMh","'box'",[49,79,80],{"class":59},");\n",[16,82,83,84,87],{},"那麼使用了這個選取器選取元素後會出現什麼呢?我們可以試著將 Code 丟到 codepen 上，然後再輸入 ",[35,85,86],{},"boxId"," 來看看它選取了什麼東西 ↓",[16,89,90],{},[28,91],{"alt":92,"src":93},"box","https:\u002F\u002Fi.imgur.com\u002F7ayMq0b.png",[16,95,96,97,99],{},"而這裡面就是關於 ",[35,98,92],{}," 的元素，這又稱之為 DOM 元素，你可以將選取器的概念想像成你是一位持有鑑定眼技能的人，而這個鑑定眼就是選取器的概念，那你就可以拿來查看(選取)別人的狀態、數值與技能，只是這個鑑定眼很 OP 還可以偷用別人技能就是了(被揍)。",[16,101,102],{},"接下來是另一種寫法，這種寫法可以選擇使用 ID 或是 ClassName 來當作選取器，寫過 jQuery 的人可能會覺得有點神似：",[40,104,106],{"className":42,"code":105,"language":44,"meta":45,"style":45},"var boxId = document.querySelector('#box'); \u002F\u002F 選取 ID 就帶上 # 字號\nvar boxId = document.querySelector('.box'); \u002F\u002F 選取 Class 就用 . 字號\n",[35,107,108,133],{"__ignoreMap":45},[49,109,110,112,114,116,118,121,123,126,129],{"class":51,"line":52},[49,111,56],{"class":55},[49,113,60],{"class":59},[49,115,63],{"class":55},[49,117,66],{"class":59},[49,119,120],{"class":69},"querySelector",[49,122,73],{"class":59},[49,124,125],{"class":76},"'#box'",[49,127,128],{"class":59},"); ",[49,130,132],{"class":131},"sQrFR","\u002F\u002F 選取 ID 就帶上 # 字號\n",[49,134,136,138,140,142,144,146,148,151,153],{"class":51,"line":135},2,[49,137,56],{"class":55},[49,139,60],{"class":59},[49,141,63],{"class":55},[49,143,66],{"class":59},[49,145,120],{"class":69},[49,147,73],{"class":59},[49,149,150],{"class":76},"'.box'",[49,152,128],{"class":59},[49,154,155],{"class":131},"\u002F\u002F 選取 Class 就用 . 字號\n",[16,157,158,159,162,163,166],{},"那麼上面這個結果是與單純選取 ID 是一樣的，所以我就不多做示範，那麼你可能會問 「那使用 ",[35,160,161],{},"querySelector();"," 還是 ",[35,164,165],{},"getElementById();"," 哪一個好?」",[16,168,169,170,172,173,175,176,178],{},"如果你希望可以比較完整支援所有瀏覽器的話，我個人會建議使用 ",[35,171,165],{},"，雖然 ",[35,174,161],{}," 目前支援性也非常高，只有部分很舊的瀏覽器不支援，所以主要還是看個人習慣哪一種選取方式擇一即可，但是如果專案的使用者偏向使用較舊的瀏覽器，那麼我就會建議使用 ",[35,177,165],{}," ↓",[16,180,181],{},[28,182],{"alt":161,"src":183},"https:\u002F\u002Fi.imgur.com\u002FWQJYX1p.png",[16,185,186],{},[28,187],{"alt":165,"src":188},"https:\u002F\u002Fi.imgur.com\u002F3lZP8Fq.png",[16,190,191,192,194],{},"如果是以我個人開發習慣來講，我會比較習慣使用 ",[35,193,165],{},"，畢竟整個 HTML ID 是唯一一個。",[16,196,197],{},"當然 JavaScript 還有提供其他選取 DOM 元素的方式，例如 JavaScript 還有提供針對選取 tagName 的方式：",[40,199,201],{"className":42,"code":200,"language":44,"meta":45,"style":45},"var boxId = document.getElementsByTagName('div');\n",[35,202,203],{"__ignoreMap":45},[49,204,205,207,209,211,213,216,218,221],{"class":51,"line":52},[49,206,56],{"class":55},[49,208,60],{"class":59},[49,210,63],{"class":55},[49,212,66],{"class":59},[49,214,215],{"class":69},"getElementsByTagName",[49,217,73],{"class":59},[49,219,220],{"class":76},"'div'",[49,222,80],{"class":59},[16,224,225],{},"結果當然會是一樣的，但是你可以看到結構會稍微不太一樣，會有點類似陣列的東西 ↓",[16,227,228],{},[28,229],{"alt":215,"src":230},"https:\u002F\u002Fi.imgur.com\u002FS9AZ8zS.png",[16,232,233,234,236,237,239,240,242],{},"當然 ",[35,235,215],{}," 的支援性也是非常高的，所以也可以使用 ",[35,238,215],{}," 來選取 DOM，但是一般來講 ",[35,241,215],{}," 比較常見用於選取多個 tagName ↓",[16,244,245],{},[28,246],{"alt":247,"src":248},"ID 請忽略我忘記改了","https:\u002F\u002Fi.imgur.com\u002FsfhDFxD.png",[16,250,251,252,255,256,258],{},"但是一般來講會比較常使用 ",[35,253,254],{},"querySelector()"," 以及 ",[35,257,37],{},"。",[16,260,261,262,264,265,268,269,272,273,275],{},"最後補充一件事情，",[35,263,161],{}," 也有與 ",[35,266,267],{},"getElementsByTagName();"," 類似的語法，也就是 ",[35,270,271],{},"querySelectorAll();","，那這個寫法跟 ",[35,274,161],{}," 是一樣的，只是多了一個 All 而已。",[16,277,278,279],{},"codepen：",[280,281,282],"a",{"href":282,"rel":283},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FzYORxNv",[284],"nofollow",[286,287],"code-pen",{"default-tab":288,"height":289,"slug":290,"title":21,"user":291},"js,result",265,"zYORxNv","hsiangfeng",[12,293,294],{"id":294},"結尾",[16,296,297],{},"下一篇的 RE：從零開始的學習 JS 生活-第四日 將會介紹事件。",[299,300,301],"style",{},"html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAX