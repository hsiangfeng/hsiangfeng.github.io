[{"data":1,"prerenderedAt":615},["ShallowReactive",2],{"header-locale:\u002Fjavascript\u002F20200524\u002F995184384\u002F":3,"page:\u002Fjavascript\u002F20200524\u002F995184384\u002F":4,"alt:\u002Fjavascript\u002F20200524\u002F995184384\u002F":3,"prev-next:\u002Fjavascript\u002F20200524\u002F995184384\u002F":590,"related:\u002Fjavascript\u002F20200524\u002F995184384\u002F":599},"\u002Fen\u002Fjavascript\u002F2020\u002F05\u002F24\u002Fjs-core-08-memory-allocation-garbage-collection\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":574,"date":575,"description":18,"extension":576,"lang":577,"meta":578,"navigation":79,"path":579,"readingMinutes":580,"seo":581,"standalone":582,"stem":583,"tags":584,"tldr":587,"updated":587,"url":588,"__hash__":589},"content\u002FJavaScript 核心觀念\u002F1.執行環境與作用域\u002FJavaScript-核心觀念-8-執行環境與作用域-記憶體存放與釋放.md","JavaScript 核心觀念(8)-執行環境與作用域-記憶體存放與釋放","995184384",{"type":9,"value":10,"toc":567},"minimark",[11,15,19,23,30,33,36,40,43,110,121,127,130,133,139,142,145,302,305,409,416,422,425,515,524,528,534,540,543,563],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來講一下記憶體的回收機制。",[12,20,22],{"id":21},"garbage-collection","Garbage collection",[16,24,25],{},[26,27],"img",{"alt":28,"src":29},"回收機制","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E6%88%AA%E5%9C%96%202020-05-24%2011.07.15.png",[16,31,32],{},"Garbage collection 中文名稱又稱為垃圾回收，垃圾回收是一個自動化記憶體管理機制，當某一段程式碼行時，都會暫用一些記憶體，如果沒有 Garbage collection 的機制，那麼記憶體就會很快速的滿出來導致出現所謂的 Lag 等問題，拿生活面的舉例來講，回收機制就像一個契約，當你租一台汽車兩天，那麼你就必須在第二天時歸還汽車(回收)，否則汽車車商就沒有汽車可以租給別人。",[16,34,35],{},"在早期的程式語言其實並沒有 Garbage collection 的機制，因此在開發系統上對於記憶體的管理就會相對注重，你可以看到以前相當多的技術書本都會提到記憶體管理，因此 Garbage collection 的存在可以大大減少工程師的負擔，相對在撰寫 JavaScript 這也是一個相當重要的觀念。",[12,37,39],{"id":38},"javascript-是如何回收記憶體","JavaScript 是如何回收記憶體",[16,41,42],{},"前面章節我們了解到每一個函式都有屬於它的記憶體空間",[44,45,50],"pre",{"className":46,"code":47,"language":48,"meta":49,"style":49},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","function a() { \u002F\u002F a 的記憶體空間\n\n}\nfunction b() { \u002F\u002F b 的記憶體空間\n\n}\n","js","",[51,52,53,74,81,87,100,105],"code",{"__ignoreMap":49},[54,55,58,62,66,70],"span",{"class":56,"line":57},"line",1,[54,59,61],{"class":60},"sOudu","function",[54,63,65],{"class":64},"scAaK"," a",[54,67,69],{"class":68},"s8XSl","() { ",[54,71,73],{"class":72},"sGBqm","\u002F\u002F a 的記憶體空間\n",[54,75,77],{"class":56,"line":76},2,[54,78,80],{"emptyLinePlaceholder":79},true,"\n",[54,82,84],{"class":56,"line":83},3,[54,85,86],{"class":68},"}\n",[54,88,90,92,95,97],{"class":56,"line":89},4,[54,91,61],{"class":60},[54,93,94],{"class":64}," b",[54,96,69],{"class":68},[54,98,99],{"class":72},"\u002F\u002F b 的記憶體空間\n",[54,101,103],{"class":56,"line":102},5,[54,104,80],{"emptyLinePlaceholder":79},[54,106,108],{"class":56,"line":107},6,[54,109,86],{"class":68},[16,111,112,113,116,117,120],{},"當我們執行 ",[51,114,115],{},"a()"," 或 ",[51,118,119],{},"b()"," 就會佔用一些記憶體空間，當執行完畢後就會像前面的執行堆疊中的函式釋放一樣釋放記憶體",[16,122,123],{},[26,124],{"alt":125,"src":126},"函式釋放","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002FJavaScript%20%E6%A0%B8%E5%BF%83%E8%A7%80%E5%BF%B5\u002F%E9%87%8B%E6%94%BE%E5%9F%B7%E8%A1%8C%E5%A0%86%E7%96%8A.gif",[16,128,129],{},"但是這邊有一個重點要注意 Garbage collection 要回收的記憶體的依據是依照「當物件不再被使用或是不再被其他物件參考時」，它才會被視為一個可回收的記憶體。",[16,131,132],{},"以下截至 MDN",[134,135,136],"blockquote",{},[16,137,138],{},"這個演算法將原本「這個物件再也不會被使用」的廣泛定義縮減到「沒有其他任何物件參考它」。如果一個物件不在被任何物件參考，它將被視為可回收記憶體的垃圾。",[12,140,141],{"id":141},"驗證範例",[16,143,144],{},"課程中也有提供一個相當不錯的驗證範例。",[44,146,148],{"className":46,"code":147,"language":48,"meta":49,"style":49},"function randomString(length) {\n  var result = '';\n  var characters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789';\n  var charactersLength = characters.length;\n  for (var i = 0; i \u003C length; i++) {\n    result += characters.charAt(Math.floor(Mat