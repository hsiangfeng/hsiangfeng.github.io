.3 版，過程 Pixi 官方可能會瘋狂改版，在我撰寫這段期間 Pixi 已經默默突破了 5.1 以上版本，但是基本上差異並不大，所以這系列會集中在 5.1.3。",[16,72,73,74,79],{},"而本篇將會以 ",[38,75,78],{"href":76,"rel":77},"https:\u002F\u002Fwww.pixijs.com\u002F",[42],"PixiJS v5"," 快速簡單入門學習這個框架，過程若有錯誤就請多指教囉。",[12,81,83],{"id":82},"建立-pixi","建立 Pixi",[16,85,86,87,91],{},"當你掛載 Pixi CDN 或是引入 Pixi 之後，我們就可以準備正式撰寫程式碼，而建立 Pixi 的起手式語法非常簡單，主要使用 ",[88,89,90],"code",{},"new PIXI.Application()"," 來實例化 Pixi，而實例化的方式主要有兩種",[93,94,96],"h3",{"id":95},"使用-javascript-建立","使用 JavaScript 建立",[98,99,104],"pre",{"className":100,"code":101,"language":102,"meta":103,"style":103},"language-js shiki shiki-themes github-dark-high-contrast","const app = new PIXI.Application();\ndocument.body.appendChild(app.view);\n","js","",[88,105,106,139],{"__ignoreMap":103},[107,108,111,115,119,122,125,128,132,136],"span",{"class":109,"line":110},"line",1,[107,112,114],{"class":113},"sWyjQ","const",[107,116,118],{"class":117},"sCcAr"," app",[107,120,121],{"class":113}," =",[107,123,124],{"class":113}," new",[107,126,127],{"class":117}," PIXI",[107,129,131],{"class":130},"sMAXC",".",[107,133,135],{"class":134},"sj_SG","Application",[107,137,138],{"class":130},"();\n",[107,140,142,145,148],{"class":109,"line":141},2,[107,143,144],{"class":130},"document.body.",[107,146,147],{"class":134},"appendChild",[107,149,150],{"class":130},"(app.view);\n",[16,152,153],{},[38,154,157],{"href":155,"rel":156},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FNWPKoYo",[42],"Codepen",[159,160,167],"iframe",{"height":161,"style":162,"scrolling":163,"title":164,"src":165,"frameBorder":163,"allowTransparency":166,"allowFullScreen":166},265,"width: 100%;","no","PIXI 建立(1)","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FNWPKoYo?height=265&theme-id=default&default-tab=js,result","true","\n  See the Pen \u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FNWPKoYo'>PIXI 建立(1)\u003C\u002Fa> by HF\n  (\u003Ca href='https:\u002F\u002Fcodepen.io\u002Fhsiangfeng'>@hsian