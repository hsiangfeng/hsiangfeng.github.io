[{"data":1,"prerenderedAt":175},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20190802\u002F1198998279\u002F":3,"page:\u002Fgit\u002F20190802\u002F1198998279\u002F":4,"alt:\u002Fgit\u002F20190802\u002F1198998279\u002F":3,"prev-next:\u002Fgit\u002F20190802\u002F1198998279\u002F":151,"related:\u002Fgit\u002F20190802\u002F1198998279\u002F":160},"\u002Fen\u002Fgit\u002F2019\u002F08\u002F02\u002Frename-github-branch\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":135,"date":136,"description":18,"extension":137,"lang":138,"meta":139,"navigation":140,"path":141,"readingMinutes":142,"seo":143,"standalone":144,"stem":145,"tags":146,"tldr":148,"updated":148,"url":149,"__hash__":150},"content\u002FGit\u002FGitHub-重新命名分支名稱.md","GitHub 重新命名分支名稱","1198998279",{"type":9,"value":10,"toc":128},"minimark",[11,15,19,22,25,34,37,45,52,59,65,71,77,83,89,95,101,104,110,113,119,122],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"有時候我們在開發的時候會遇到需要重新命名 GitHub 分支，但是總不能用刪除分支的方式來做處理，這樣子會導致先前的 commit 紀錄都消失，所以就來記錄一下該如何重新命名分支並 push 到 GitHub 上吧",[12,20,21],{"id":21},"起手式",[16,23,24],{},"首先我拿我這一個 Repo 作範例",[16,26,27,28],{},"Repo: ",[29,30,31],"a",{"href":31,"rel":32},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002FotherCSS",[33],"nofollow",[12,35,36],{"id":36},"重新命名方式",[16,38,39,40,44],{},"首先會先 ",[41,42,43],"code",{},"cd"," 到該目錄下",[16,46,47],{},[48,49],"img",{"alt":50,"src":51},"移動目錄","https:\u002F\u002Fi.imgur.com\u002FcIYSA9L.png",[16,53,54,55,58],{},"接下來先輸入 ",[41,56,57],{},"git branch -a"," 確定一下全部分支狀況",[16,60,61],{},[48,62],{"alt":63,"src":64},"全部分支","https:\u002F\u002Fi.imgur.com\u002FY6fSm0Z.png",[16,66,67,68],{},"假設我今天希望我的分支修改成 master → develop，那麼就輸入 ",[41,69,70],{},"git branch -m master develop",[16,72,73,74],{},"※ 指令說明： ",[41,75,76],{},"git branch -m [old branch name] [new branch name]",[16,78,79],{},[48,80],{"alt":81,"src":82},"修改分支","https:\u002F\u002Fi.imgur.com\u002FM1bnyFl.png",[16,84,85,86],{},"接下來就是 push 到 GitHub，",[41,87,88],{},"git push origin develop :master",[16,90,73,91,94],{},[41,92,93],{},"git push origin -m [new branch name] :[old branch name]"," (注意前面有一個舊分支前面還有一個分號)",[16,96,97],{},[48,98],{"alt":99,"src":100},"push","https:\u002F\u002Fi.imgur.com\u002F9YBR2HM.png",[16,102,103],{},"你會發現我的畫面是出現紅字是正常的，因為 master 分支是不能隨便改名變更的，所以你會看到 GitHub 自動幫你新增了一個分支",[16,105,106],{},[48,107],{"alt":108,"src":109},"ERROR","https:\u002F\u002Fi.imgur.com\u002FnFhVxEz.png",[16,111,112],{},"所以我們就可以嘗試用以上流程來將 develop 改成它的名稱，例如 css_develop",[16,114,115],{},[48,116],{"alt":117,"src":118},"css_develop","https:\u002F\u002Fi.imgur.com\u002FdSRiVYX.png",[16,120,121],{},"那麼我們回到 GitHub 就可以看到 branch 已經修改了，而且 commit 都有保留唷~",[16,123,124],{},[48,125],{"alt":126,"src":127},"branch 更名","https:\u002F\u002Fi.imgur.com\u002FQEpkYPn.png",{"title":129,"searchDepth":130,"depth":130,"links":131},"",2,[132,133,134],{"id":14,"depth":130,"text":14},{"id":21,"depth":130,"text":21},{"id":36,"depth":130,"text":36},"Git","2019-08-02 10:52:04","md","zh-Hant",{},true,"\u002Fgit\u002Fgithub","1",{"title":6,"description":18},false,"Git\u002FGitHub-重新命名分支名稱",[147,135],"GitHub",null,"\u002Fgit\u002F20190802\u002F1198998279\u002F","1chx8R0G6O1r2ioEXochtu-LKpNpnwV_anMfsrzUT28",{"newer":152,"older":156},{"url":153,"title":154,"date":155},"\u002Fcss\u002F20190803\u002F1860685658\u002F","純 CSS 愛心繪畫方式","2019-08-03 16:40:36",{"url":157,"title":158,"date":159},"\u002Fvue\u002F20190801\u002F1336347183\u002F","Vue 出一個女友吧!-中場休息","2019-08-01 10:54:29",[161,166,171],{"url":162,"title":163,"date":164,"readingMinutes":165},"\u002Fgit\u002F20260226\u002F799954596\u002F","取代 git push --force 更好的方式，git push --force-with-lease","2026-02-26 09:39:40","4",{"url":167,"title":168,"date":169,"readingMinutes":170},"\u002Fgit\u002F20260122\u002F21277993\u002F","Git init 出現 master 分支提示？教你設定預設分支為 main","2026-01-22 16:20:40","2",{"url":172,"title":173,"date":174,"readingMinutes":165},"\u002Fgit\u002F20260121\u002F2025687513\u002F","Git Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣","2026-01-21 16:04:27",1784011717341]