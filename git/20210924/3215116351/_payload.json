[{"data":1,"prerenderedAt":188},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20210924\u002F3215116351\u002F":3,"page:\u002Fgit\u002F20210924\u002F3215116351\u002F":4,"alt:\u002Fgit\u002F20210924\u002F3215116351\u002F":3,"prev-next:\u002Fgit\u002F20210924\u002F3215116351\u002F":164,"related:\u002Fgit\u002F20210924\u002F3215116351\u002F":173},"\u002Fen\u002Fgit\u002F2021\u002F09\u002F24\u002Fgithub-download-specific-branch-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":147,"date":148,"description":18,"extension":149,"lang":150,"meta":151,"navigation":152,"path":153,"readingMinutes":154,"seo":155,"standalone":156,"stem":157,"tags":158,"tldr":161,"updated":161,"url":162,"__hash__":163},"content\u002FGit\u002F解決-GitHub-無法指定-branch-downloads-的問題.md","解決 GitHub 無法指定 branch downloads 的問題","3215116351",{"type":9,"value":10,"toc":136},"minimark",[11,15,19,22,42,45,53,60,63,69,72,74,80,83,86,89,94,105,108,111,117,127,133],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"近期 GitHub 下載程式碼的時候會無法指定 branch 下載，所以這邊紀錄一下該如何解決這個問題。",[12,20,21],{"id":21},"事發原因",[16,23,24,25,29,30,33,34,37,38,41],{},"近期 GitHub 似乎調整 Downloads 的下載按鈕怪怪的，以往我們在切換分支後 Downloads 按鈕就會對應相對應的分支來下載，但是目前似乎已經變成你不管怎麼切換分支，依然會是當前預設(",[26,27,28],"code",{},"Master","、",[26,31,32],{},"Main",")的分支下載，而這邊可以注意一下下載時的檔案名稱是否正確，通常會依照你的分支去命名，例如： ",[26,35,36],{},"xxx-master.zip"," or ",[26,39,40],{},"xxx-main.zip","。",[16,43,44],{},"這邊以底下這一份專案來講",[16,46,47],{},[48,49,50],"a",{"href":50,"rel":51},"https:\u002F\u002Fgithub.com\u002Fhexschool\u002Fweb-layout-training-gulp",[52],"nofollow",[16,54,55,56,59],{},"正常來講我切換到 ",[26,57,58],{},"feature\u002Fbs5-fix"," 應該下載的時候是這樣：",[16,61,62],{},"(請注意檔案名稱)",[16,64,65],{},[66,67],"img",{"alt":58,"src":68},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002F202109240934.png",[16,70,71],{},"但現在不管怎麼切換分支下載的檔案永遠都會是預設分支：",[16,73,62],{},[16,75,76],{},[66,77],{"alt":78,"src":79},"default branch","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002F202109240933.png",[16,81,82],{},"所以這邊紀錄一下解決方式。",[12,84,85],{"id":85},"解決方式",[16,87,88],{},"最簡單的方式有兩種，所以一併紀錄一下。",[90,91,93],"h3",{"id":92},"改用-git-方式","改用 Git 方式",[16,95,96,97,100,101,104],{},"如果你熟悉 Git 的話，建議直接使用 ",[26,98,99],{},"git clone"," 下來然後 ",[26,102,103],{},"git checkout [branch]"," 到你要的分支就可以立刻取得你要的程式碼了，這是屬於比較簡單的方式。",[90,106,107],{"id":107},"調整下載連結",[16,109,110],{},"如果對於 Git 不熟悉的話可以考慮改用調整下載連結的方式，首先你先針對 Downloads 按鈕複製下載連結，以剛剛的範例來講你會取得這一串：",[16,112,113],{},[48,114,115],{"href":115,"rel":116},"https:\u002F\u002Fgithub.com\u002Fhexschool\u002Fweb-layout-training-gulp\u002Farchive\u002Frefs\u002Fheads\u002Fmaster.zip",[52],[16,118,119,120,122,123,126],{},"那麼當你想要下載的分支是 ",[26,121,58],{}," 的話，就只需要將 ",[26,124,125],{},"master"," 改掉，換成以下就可以了：",[16,128,129],{},[48,130,131],{"href":131,"rel":132},"https:\u002F\u002Fgithub.com\u002Fhexschool\u002Fweb-layout-training-gulp\u002Farchive\u002Frefs\u002Fheads\u002Ffeature\u002Fbs5-fix.zip",[52],[16,134,135],{},"基本上就可以解決你無法下載特定分支的方式囉。",{"title":137,"searchDepth":138,"depth":138,"links":139},"",2,[140,141,142],{"id":14,"depth":138,"text":14},{"id":21,"depth":138,"text":21},{"id":85,"depth":138,"text":85,"children":143},[144,146],{"id":92,"depth":145,"text":93},3,{"id":107,"depth":145,"text":107},"Git","2021-09-24 09:25:15","md","zh-Hant",{},true,"\u002Fgit\u002Fgithub-branch-downloads","1",{"title":6,"description":18},false,"Git\u002F解決-GitHub-無法指定-branch-downloads-的問題",[159,147,160],"GitHub","障礙排除",null,"\u002Fgit\u002F20210924\u002F3215116351\u002F","It4ka1jZPRQt08TS34eQSkfpLxIwKwhPuiUUyB5NR9Y",{"newer":165,"older":169},{"url":166,"title":167,"date":168},"\u002Fpython\u002F20210925\u002F2051252749\u002F","從 JavaScript 角度學 Python(24) - 繼承","2021-09-25 00:00:10",{"url":170,"title":171,"date":172},"\u002Fpython\u002F20210924\u002F2221702568\u002F","從 JavaScript 角度學 Python(23) - Class","2021-09-24 00:00:10",[174,179,184],{"url":175,"title":176,"date":177,"readingMinutes":178},"\u002Fgit\u002F20260226\u002F799954596\u002F","取代 git push --force 更好的方式，git push --force-with-lease","2026-02-26 09:39:40","4",{"url":180,"title":181,"date":182,"readingMinutes":183},"\u002Fgit\u002F20260122\u002F21277993\u002F","Git init 出現 master 分支提示？教你設定預設分支為 main","2026-01-22 16:20:40","2",{"url":185,"title":186,"date":187,"readingMinutes":178},"\u002Fgit\u002F20260121\u002F2025687513\u002F","Git Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣","2026-01-21 16:04:27",1784013081337]