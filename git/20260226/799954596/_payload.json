[{"data":1,"prerenderedAt":771},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20260226\u002F799954596\u002F":3,"page:\u002Fgit\u002F20260226\u002F799954596\u002F":4,"alt:\u002Fgit\u002F20260226\u002F799954596\u002F":3,"prev-next:\u002Fgit\u002F20260226\u002F799954596\u002F":747,"related:\u002Fgit\u002F20260226\u002F799954596\u002F":756},"\u002Fen\u002Fgit\u002F2026\u002F02\u002F26\u002Fgit-push-force-with-lease-better-than-force\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":731,"date":732,"description":733,"extension":734,"lang":735,"meta":736,"navigation":482,"path":737,"readingMinutes":738,"seo":739,"standalone":740,"stem":741,"tags":742,"tldr":744,"updated":732,"url":745,"__hash__":746},"content\u002FGit\u002F取代-git-push-force-更好的方式，git-push-force-with-lease.md","取代 git push --force 更好的方式，git push --force-with-lease","799954596",{"type":9,"value":10,"toc":720},"minimark",[11,19,23,39,45,48,54,57,87,90,108,111,160,177,181,199,205,217,222,237,243,325,341,346,363,376,383,401,419,423,431,451,454,527,531,540,543,563,566,587,590,606,609,681,684,713,716],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"git push --force-with-lease","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fgit\u002Fgit-push\u002FGemini_Generated_Image_vtds81vtds81vtds_1280x698.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25,26,30,31,34,35,38],{},"我們在開發上，經常會使用 ",[27,28,29],"code",{},"git rebase"," 或 ",[27,32,33],{},"git commit --amend"," 來整理 commit 歷史，但這些操作會重寫已經推送過的 commit，導致本地的歷史與遠端不同，這時候普通的 ",[27,36,37],{},"git push"," 會被拒絕，必須使用強制推送。",[12,40,41,42,44],{},"所以這一篇來聊一下 ",[27,43,17],{},"，這是一個更安全的強制推送方式，它會在推送前先確認遠端沒有新的變更，才允許你強制推送。",[20,46,37],{"id":47},"git-push",[12,49,50,51,53],{},"我相信大家應該非常熟悉 ",[27,52,37],{}," 這個指令了，基本上就是把你當前的修改進度推到遠端的 Git 儲存庫上（GitHub、GitLab、Bitbucket 等等），這樣其他同事就可以看到你的修改了。",[12,55,56],{},"所以大多人對於這指令只認識這幾個用法：",[58,59,60,66,72,81],"ul",{},[61,62,63,65],"li",{},[27,64,37],{},"：把當前分支的修改推到遠端。",[61,67,68,71],{},[27,69,70],{},"git push origin \u003Cbranch>","：把指定分支的修改推到遠端。",[61,73,74,77,78,80],{},[27,75,76],{},"git push -u origin \u003Cbranch>","：把指定分支的修改推到遠端，並且設定上游分支，以便於以後可以直接使用 ",[27,79,37],{}," 而不需要指定分支。",[61,82,83,86],{},[27,84,85],{},"git push --force","：強制推送修改到遠端，會覆蓋掉遠端的修改（今天介紹的主角）。",[12,88,89],{},"但其實它有非常多的進階用法，例如：",[58,91,92,102],{},[61,93,94,97,98,101],{},[27,95,96],{},"git push --all"," or ",[27,99,100],{},"git push --branches","：把所有分支的修改推到遠端。",[61,103,104,107],{},[27,105,106],{},"git push --tags","：把所有標籤推到遠端。",[12,109,110],{},"因此你可以這樣做：",[112,113,118],"pre",{"className":114,"code":115,"language":116,"meta":117,"style":117},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","# 刪除遠端分支\ngit push origin :\u003Cbranch>\n","bash","",[27,119,120,129],{"__ignoreMap":117},[121,122,125],"span",{"class":123,"line":124},"line",1,[121,126,128],{"class":127},"sGBqm","# 刪除遠端分支\n",[121,130,132,136,140,143,146,150,153,157],{"class":123,"line":131},2,[121,133,135],{"class":134},"smYoP","git",[121,137,139],{"class":138},"sWayO"," push",[121,141,142],{"class":138}," origin",[121,144,145],{"class":138}," :",[121,147,149],{"class":148},"sOudu","\u003C",[121,151,152],{"class":138},"branc",[121,154,156],{"class":155},"s8XSl","h",[121,158,159],{"class":148},">\n",[12,161,162,163,165,166,168,169,176],{},"等等，這些都是一些比較進階的用法，但今天我們要聊的重點是 ",[27,164,85],{}," 和 ",[27,167,17],{},"，對於其他有興趣可以直接觀看 ",[170,171,175],"a",{"href":172,"rel":173},"https:\u002F\u002Fgit-scm.com\u002Fdocs\u002Fgit-push\u002F",[174],"nofollow","Git 官方文件","。",[20,178,180],{"id":179},"git-push-force-git-push-force-with-lease","git push --force & git push --force-with-lease",[12,182,183,184,187,188,187,190,193,194,198],{},"這個大概是萬惡的用法，你可以輸入 ",[27,185,186],{},"git push -f","、",[27,189,85],{},[27,191,192],{},"git push origin +\u003Cbranch>"," 等等這些指令來 ",[195,196,197],"strong",{},"強制"," 把你的當前修改進度推到遠端上，這樣就算遠端上有其他同事的修改了，你也會直接覆蓋掉他們的修改（簡單來講，就是讓你同事今天做白工）。",[12,200,201,202,204],{},"所以許多公司跟單位是直接禁止使用 ",[27,203,85],{}," 的。",[12,206,207,208,210,211,213,214,216],{},"但我們實際開發上不可能完全不使用 ",[27,209,85],{},"，因為有時候我們可能會需要重寫 commit 歷史（例如使用 ",[27,212,29],{},"），這時候就會需要使用 ",[27,215,85],{}," 來把修改推到遠端上。",[12,218,219,220,176],{},"所以 Git 官方就提供了一個更安全的方式，也就是 ",[27,221,17],{},[12,223,224,225,228,229,232,233,236],{},"它的運作機制是：在你強制推送之前，Git 會比對遠端分支目前指向的 commit 是否與你",[195,226,227],{},"本地記錄的遠端追蹤分支","（例如 ",[27,230,231],{},"origin\u002Fmain","）一致。如果一致，代表在你上次 ",[27,234,235],{},"git fetch"," 之後沒有其他人推過新的 commit，就允許強制推送；如果不一致，就代表有人在這段期間推了新的東西，Git 會拒絕你的推送，避免你覆蓋掉別人的工作。",[12,238,239,240,242],{},"因此當你使用 ",[27,241,17],{}," 的時候，如果遠端上有其他同事在你之後推了新的 commit，你就會看到類似下面的錯誤訊息：",[112,244,246],{"className":114,"code":245,"language":116,"meta":117,"style":117},"To \u003Cremote>\n ! [rejected]        \u003Cbranch> -> \u003Cbranch> (stale info)\nerror: failed to push some refs to '\u003Cremote>'\n",[27,247,248,264,300],{"__ignoreMap":117},[121,249,250,253,256,259,262],{"class":123,"line":124},[121,251,252],{"class":134},"To",[121,254,255],{"class":148}," \u003C",[121,257,258],{"class":138},"remot",[121,260,261],{"class":155},"e",[121,263,159],{"class":148},[121,265,266,269,272,274,277,280,283,285,287,289,291,294,297],{"class":123,"line":131},[121,267,268],{"class":148}," !",[121,270,271],{"class":155}," [rejected]        ",[121,273,149],{"class":148},[121,275,276],{"class":134},"branch",[121,278,279],{"class":155},"> -",[121,281,282],{"class":148},">",[121,284,255],{"class":148},[121,286,152],{"class":138},[121,288,156],{"class":155},[121,290,282],{"class":148},[121,292,293],{"class":155}," (stale ",[121,295,296],{"class":138},"info",[121,298,299],{"class":155},")\n",[121,301,303,306,309,312,314,317,320,322],{"class":123,"line":302},3,[121,304,305],{"class":134},"error:",[121,307,308],{"class":138}," failed",[121,310,311],{"class":138}," to",[121,313,139],{"class":138},[121,315,316],{"class":138}," some",[121,318,319],{"class":138}," refs",[121,321,311],{"class":138},[121,323,324],{"class":138}," '\u003Cremote>'\n",[12,326,327,328,331,332,334,335,337,338,340],{},"這裡的 ",[27,329,330],{},"(stale info)"," 代表你本地記錄的遠端狀態已經過時了，這時候你就需要先 ",[27,333,235],{}," 拉取遠端的最新狀態，重新整理你的修改（例如重新 ",[27,336,29],{},"），最後再使用 ",[27,339,17],{}," 來推送。",[342,343,345],"h3",{"id":344},"什麼時候需要強制推送","什麼時候需要強制推送？",[12,347,348,349,351,352,355,356,358,359,362],{},"你可能會想：「我只要 ",[27,350,37],{}," 被拒絕的時候，先 ",[27,353,354],{},"git pull"," 然後再 ",[27,357,37],{}," 就好了啊？那幹嘛用 ",[27,360,361],{},"--force","？」",[12,364,365,366,369,370,372,373,375],{},"沒錯，如果你的 commit 歷史跟遠端只是",[195,367,368],{},"單純的分叉","（例如你跟同事同時在同一個分支上各自 commit），確實用 ",[27,371,354],{}," + ",[27,374,37],{}," 就可以解決。",[12,377,378,379,382],{},"但當你使用了以下這些",[195,380,381],{},"會改寫 commit 歷史","的操作時，情況就不同了：",[58,384,385,390,395],{},[61,386,387,389],{},[27,388,29],{},"：變基，重新排列 commit",[61,391,392,394],{},[27,393,33],{},"：修改最後一個 commit",[61,396,397,400],{},[27,398,399],{},"git reset"," 後重新 commit：重置後重寫歷史",[12,402,403,404,407,408,411,412,415,416,418],{},"這些操作會產生全新的 commit SHA，導致你本地的歷史跟遠端的歷史",[195,405,406],{},"完全不同","，不是單純的「落後」而是「分叉且無法合併」，所以",[195,409,410],{},"必須","強制推送。而這時候用 ",[27,413,414],{},"--force-with-lease"," 就比 ",[27,417,361],{}," 安全得多。",[20,420,422],{"id":421},"force-with-lease-的已知陷阱","--force-with-lease 的已知陷阱",[12,424,425,427,428,430],{},[27,426,414],{}," 雖然比 ",[27,429,361],{}," 安全，但它並不是萬無一失的。",[12,432,433,434,228,436,438,439,441,442,444,445,447,448,176],{},"它的保護機制是比對你",[195,435,227],{},[27,437,231],{},"），而不是即時去查詢遠端。所以如果你在強制推送之前做了 ",[27,440,235],{},"（或 ",[27,443,354],{},"），你本地的遠端追蹤分支就會被更新到最新狀態，這時候 ",[27,446,414],{}," 會認為「你已經知道遠端的最新狀態了」，就會允許強制推送——",[195,449,450],{},"保護就失效了",[12,452,453],{},"舉個例子：",[112,455,457],{"className":114,"code":456,"language":116,"meta":117,"style":117},"# 你做了 rebase，準備強制推送\ngit rebase -i HEAD~3\n\n# 習慣性先 fetch 一下（這一步讓保護失效！）\ngit fetch origin\n\n# 這時候 --force-with-lease 不會阻止你，即使遠端有新的 commit\ngit push --force-with-lease origin main\n",[27,458,459,464,478,484,490,501,506,512],{"__ignoreMap":117},[121,460,461],{"class":123,"line":124},[121,462,463],{"class":127},"# 你做了 rebase，準備強制推送\n",[121,465,466,468,471,475],{"class":123,"line":131},[121,467,135],{"class":134},[121,469,470],{"class":138}," rebase",[121,472,474],{"class":473},"stw71"," -i",[121,476,477],{"class":138}," HEAD~3\n",[121,479,480],{"class":123,"line":302},[121,481,483],{"emptyLinePlaceholder":482},true,"\n",[121,485,487],{"class":123,"line":486},4,[121,488,489],{"class":127},"# 習慣性先 fetch 一下（這一步讓保護失效！）\n",[121,491,493,495,498],{"class":123,"line":492},5,[121,494,135],{"class":134},[121,496,497],{"class":138}," fetch",[121,499,500],{"class":138}," origin\n",[121,502,504],{"class":123,"line":503},6,[121,505,483],{"emptyLinePlaceholder":482},[121,507,509],{"class":123,"line":508},7,[121,510,511],{"class":127},"# 這時候 --force-with-lease 不會阻止你，即使遠端有新的 commit\n",[121,513,515,517,519,522,524],{"class":123,"line":514},8,[121,516,135],{"class":134},[121,518,139],{"class":138},[121,520,521],{"class":473}," --force-with-lease",[121,523,142],{"class":138},[121,525,526],{"class":138}," main\n",[342,528,530],{"id":529},"force-if-includes","--force-if-includes",[12,532,533,534,536,537,539],{},"為了解決這個陷阱，Git 2.30 之後提供了 ",[27,535,530],{},"，它會額外檢查：遠端追蹤分支的最新 commit 是否已經被整合到你的本地分支中。如果你只是 ",[27,538,235],{}," 但沒有實際把遠端的變更整合進來，推送就會被拒絕。",[12,541,542],{},"建議搭配使用：",[112,544,546],{"className":114,"code":545,"language":116,"meta":117,"style":117},"git push --force-with-lease --force-if-includes origin main\n",[27,547,548],{"__ignoreMap":117},[121,549,550,552,554,556,559,561],{"class":123,"line":124},[121,551,135],{"class":134},[121,553,139],{"class":138},[121,555,521],{"class":473},[121,557,558],{"class":473}," --force-if-includes",[121,560,142],{"class":138},[121,562,526],{"class":138},[12,564,565],{},"如果你覺得每次都要打這麼長太麻煩，可以設定 Git alias：",[112,567,569],{"className":114,"code":568,"language":116,"meta":117,"style":117},"git config --global alias.pushfl \"push --force-with-lease --force-if-includes\"\n",[27,570,571],{"__ignoreMap":117},[121,572,573,575,578,581,584],{"class":123,"line":124},[121,574,135],{"class":134},[121,576,577],{"class":138}," config",[121,579,580],{"class":473}," --global",[121,582,583],{"class":138}," alias.pushfl",[121,585,586],{"class":138}," \"push --force-with-lease --force-if-includes\"\n",[12,588,589],{},"之後就可以直接使用：",[112,591,593],{"className":114,"code":592,"language":116,"meta":117,"style":117},"git pushfl origin main\n",[27,594,595],{"__ignoreMap":117},[121,596,597,599,602,604],{"class":123,"line":124},[121,598,135],{"class":134},[121,600,601],{"class":138}," pushfl",[121,603,142],{"class":138},[121,605,526],{"class":138},[20,607,608],{"id":608},"總結",[610,611,612,628],"table",{},[613,614,615],"thead",{},[616,617,618,622,625],"tr",{},[619,620,621],"th",{},"指令",[619,623,624],{},"行為",[619,626,627],{},"安全性",[629,630,631,644,656,669],"tbody",{},[616,632,633,638,641],{},[634,635,636],"td",{},[27,637,37],{},[634,639,640],{},"只允許快轉（fast-forward）更新",[634,642,643],{},"最安全",[616,645,646,650,653],{},[634,647,648],{},[27,649,17],{},[634,651,652],{},"比對本地遠端追蹤分支，一致才允許強制推送",[634,654,655],{},"安全",[616,657,658,663,666],{},[634,659,660],{},[27,661,662],{},"git push --force-with-lease --force-if-includes",[634,664,665],{},"額外確認遠端變更已被整合到本地",[634,667,668],{},"更安全",[616,670,671,675,678],{},[634,672,673],{},[27,674,85],{},[634,676,677],{},"無條件覆蓋遠端",[634,679,680],{},"危險",[12,682,683],{},"簡單來說：",[58,685,686,694,705],{},[61,687,688,693],{},[195,689,690,691],{},"永遠不要用 ",[27,692,85],{},"，除非你非常確定你在做什麼。",[61,695,696,704],{},[195,697,698,699,701,702],{},"用 ",[27,700,17],{}," 取代 ",[27,703,361],{},"，這是最基本的安全措施。",[61,706,707,712],{},[195,708,709,710],{},"搭配 ",[27,711,530],{}," 可以獲得更完整的保護。",[12,714,715],{},"養成好習慣，保護自己也保護同事的心血。",[717,718,719],"style",{},"html pre.shiki code .sGBqm, html code.shiki .sGBqm{--shiki-light:#6A737D;--shiki-default:#6A737D;--shiki-dark:#BDC4CC}html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shik