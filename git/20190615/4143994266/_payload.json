[{"data":1,"prerenderedAt":593},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20190615\u002F4143994266\u002F":3,"page:\u002Fgit\u002F20190615\u002F4143994266\u002F":4,"alt:\u002Fgit\u002F20190615\u002F4143994266\u002F":3,"prev-next:\u002Fgit\u002F20190615\u002F4143994266\u002F":570,"related:\u002Fgit\u002F20190615\u002F4143994266\u002F":578},"\u002Fen\u002Fgit\u002F2019\u002F06\u002F15\u002Fhow-to-send-github-pull-request\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":554,"date":555,"description":18,"extension":556,"lang":557,"meta":558,"navigation":559,"path":560,"readingMinutes":561,"seo":562,"standalone":563,"stem":564,"tags":565,"tldr":567,"updated":567,"url":568,"__hash__":569},"content\u002FGit\u002FGitHub-該如何發-PR-pull-request.md","GitHub 該如何發 PR(pull request)","4143994266",{"type":9,"value":10,"toc":535},"minimark",[11,15,19,23,30,41,44,52,55,62,91,94,97,102,105,112,115,121,125,128,134,137,154,159,163,169,174,177,183,186,190,193,215,221,224,230,234,237,243,246,251,258,263,266,272,275,280,283,288,291,296,299,304,307,310,313,318,321,326,329,334,339,342,347,350,355,358,364,367,372,375,380,383,388,392,395,399,402,406,409,412,421,424,430,433,438,442,445,451,454,459,463,466,471,474,478,481,484,489,492,497,500,505,508,516,519,525,528,531],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"PR 是一個很特別的 GitHub 機制，當然 Gitlab 也有相同的機制，可是我這邊主要只會介紹使用 GitHub 如何發 PR 唷。",[12,20,22],{"id":21},"pull-request","pull request",[16,24,25,26,29],{},"在 GitHub 上有非常多的開源專案，有些專案如果你有興趣也很想要幫忙貢獻自己的力量的時候，就可以使用 ",[27,28,22],"strong",{}," (後面簡稱 PR) 這個機制，讓我們先了解一下流程",[16,31,32,33,36,37,40],{},"找到自己喜歡的專案 → ",[27,34,35],{},"Fork 到自己 repository 底下修改"," → 修改完畢後推回 (Push) 自己專案底下 → ",[27,38,39],{},"發 PR 給原作者"," → 作者看過沒問題 → 合併 (merge) 到他的專案內",[16,42,43],{},"接下來就來實際模擬一下吧!",[16,45,46,47],{},"※ 基本上這邊會用到很多 Git 基礎指令，如果對於 Git 指令不清楚者，可以看我這一篇",[48,49,51],"a",{"href":50},"\u002Fgit\u002F20190615\u002F1148594701\u002F","Git 基礎指令",[12,53,54],{"id":54},"模擬情境",[16,56,57,58,61],{},"以下情境都是我拿自己小帳的唷~\n(沒事不要發 PR 給我，因為我不會理你 ",[59,60],"d",{}," )",[63,64,65,75,83],"ul",{},[66,67,68,69],"li",{},"感興趣的專案網址：",[48,70,74],{"href":71,"rel":72},"https:\u002F\u002Fgithub.com\u002Fjc-eng\u002Ftest-repos",[73],"nofollow","test-repos",[66,76,77,78],{},"專案作者：",[48,79,82],{"href":80,"rel":81},"https:\u002F\u002Fgithub.com\u002Fjc-eng",[73],"jc-eng(我的小分身)",[66,84,85,86],{},"合作路人：",[48,87,90],{"href":88,"rel":89},"https:\u002F\u002Fgithub.com\u002Fhsiangfeng",[73],"就是我自己",[16,92,93],{},"接下來就實際來玩一次吧!",[12,95,96],{"id":96},"合作路人",[98,99,101],"h3",{"id":100},"第一步驟-fork-專案","第一步驟 Fork 專案",[16,103,104],{},"廢話不多說，先進入到我們感興趣的專案 repo，然後點上面 Fork",[16,106,107],{},[108,109],"img",{"alt":110,"src":111},"Fork","https:\u002F\u002Fi.imgur.com\u002FvUn18CO.png",[16,113,114],{},"當你按下 Fork 之後就會出現這個畫面 (影印中...)",[16,116,117],{},[108,118],{"alt":119,"src":120},"Image","https:\u002F\u002Fi.imgur.com\u002FmU1TqCx.png",[98,122,124],{"id":123},"第二步驟-clone下來到本地端修改","第二步驟 Clone下來到本地端修改",[16,126,127],{},"首先先取得 Clone 網址(記得一定要在自己 Fork 的 repo 下使用，所以務必確認自己的 repo)",[16,129,130],{},[108,131],{"alt":132,"src":133},"clone","https:\u002F\u002Fi.imgur.com\u002Fe6Lnsz3.png",[16,135,136],{},"接下來輸入指令 Clone 到本地端",[138,139,144],"pre",{"className":140,"code":141,"language":142,"meta":143,"style":143},"language-git shiki shiki-themes github-light github-light github-dark-high-contrast","git clone https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Ftest-repos.git\n","git","",[145,146,147],"code",{"__ignoreMap":143},[148,149,152],"span",{"class":150,"line":151},"line",1,[148,153,141],{},[16,155,156],{},[108,157],{"alt":132,"src":158},"https:\u002F\u002Fi.imgur.com\u002FXjbZUJT.png",[98,160,162],{"id":161},"第三步驟-修改專案","第三步驟 修改專案",[16,164,165,166,168],{},"clone 下來後就可以看到多了一個 ",[145,167,74],{}," 資料夾",[16,170,171],{},[108,172],{"alt":132,"src":173},"https:\u002F\u002Fi.imgur.com\u002FFMc6QoG.png",[16,175,176],{},"點進去後可以看到一個 README.md 檔案，讓我們打開來修改一下",[16,178,179],{},[108,180],{"alt":181,"src":182},"README","https:\u002F\u002Fi.imgur.com\u002F5i60Zjl.png",[16,184,185],{},"修改完畢後存檔",[98,187,189],{"id":188},"第四步驟-推回自己專案","第四步驟 推回自己專案",[16,191,192],{},"基本上因為我們是使用 Clone 下來，所以可以直接 Push 回去，但是輸入以下指令",[138,194,196],{"className":140,"code":195,"language":142,"meta":143,"style":143},"git add .\ngit commit -m '我增加了一段話到 README'\ngit push\n",[145,197,198,203,209],{"__ignoreMap":143},[148,199,200],{"class":150,"line":151},[148,201,202],{},"git add .\n",[148,204,206],{"class":150,"line":205},2,[148,207,208],{},"git commit -m '我增加了一段話到 README'\n",[148,210,212],{"class":150,"line":211},3,[148,213,214],{},"git push\n",[16,216,217],{},[108,218],{"alt":219,"src":220},"push","https:\u002F\u002Fi.imgur.com\u002Fw11xR72.png",[16,222,223],{},"那我們就可以看到自己線上 repo 也更新了",[16,225,226],{},[108,227],{"alt":228,"src":229},"repo","https:\u002F\u002Fi.imgur.com\u002F5VhnELf.png",[98,231,233],{"id":232},"第五步驟-發送-pr","第五步驟 發送 PR",[16,235,236],{},"終於到了發 PR 階段，讓我們回到自己專案的線上 repo 畫面，點一下上方 PR",[16,238,239],{},[108,240],{"alt":241,"src":242},"PR","https:\u002F\u002Fi.imgur.com\u002FZrCjgW7.png",[16,244,245],{},"接下來點擊 New pull request",[16,247,248],{},[108,249],{"alt":241,"src":250},"https:\u002F\u002Fi.imgur.com\u002Fk3le9yQ.png",[16,252,253,254,257],{},"請務必",[27,255,256],{},"確認自己的修改內容","，然後確定一下上方要發 PR 的對象 repo 分支以及自己的 repo 分支是否正確",[16,259,260],{},[108,261],{"alt":241,"src":262},"https:\u002F\u002Fi.imgur.com\u002Fl8j8WJ8.png",[16,264,265],{},"如果確認沒問題就按下 Create pull request",[16,267,268],{},[108,269],{"alt":270,"src":271},"Create pull request","https:\u002F\u002Fi.imgur.com\u002FublmQJf.png",[16,273,274],{},"通常 title 會是你剛剛 commit 的訊息，如果你有什麼特別的話要跟原作者講也可以在下方 Leava comment 留言給他",[16,276,277],{},[108,278],{"alt":270,"src":279},"https:\u002F\u002Fi.imgur.com\u002FiEcT8A6.png",[16,281,282],{},"接下來沒問題就按下 Create pull request",[16,284,285],{},[108,286],{"alt":270,"src":287},"https:\u002F\u002Fi.imgur.com\u002FOjbRxnz.png",[16,289,290],{},"送出之後就會跳到原本作者的 repo PR 畫面，這樣 PR 就發成功囉~",[16,292,293],{},[108,294],{"alt":119,"src":295},"https:\u002F\u002Fi.imgur.com\u002FTFVX6qJ.png",[16,297,298],{},"如果分支有任何狀況下方這邊也會提示你",[16,300,301],{},[108,302],{"alt":119,"src":303},"https:\u002F\u002Fi.imgur.com\u002F5Ib9znU.png",[16,305,306],{},"接下來就等作者來看過原始碼有沒有問題，若沒問題就會被 merge 了",[12,308,309],{"id":309},"專案作者",[16,311,312],{},"當你發送 PR 之後專案作者就會收到通知(通常都是 Email)，接下來專案作者只需要進入專案，點擊 PR",[16,314,315],{},[108,316],{"alt":241,"src":317},"https:\u002F\u002Fi.imgur.com\u002F8xCCH9n.png",[16,319,320],{},"這邊就可以有哪些人發送了 PR",[16,322,323],{},[108,324],{"alt":241,"src":325},"https:\u002F\u002Fi.imgur.com\u002FqWcasQP.png",[16,327,328],{},"我們點進去看之後，可以點上方 Commits 來看他的修改了什麼",[16,330,331],{},[108,332],{"alt":241,"src":333},"https:\u002F\u002Fi.imgur.com\u002FtjIOxVj.png",[16,335,336],{},[108,337],{"alt":241,"src":338},"https:\u002F\u002Fi.imgur.com\u002FGwEiByT.png",[16,340,341],{},"點進來後可以查看他的修改內容",[16,343,344],{},[108,345],{"alt":241,"src":346},"https:\u002F\u002Fi.imgur.com\u002FbthBBqN.png",[16,348,349],{},"我們可以看到路人新增了一段話",[16,351,352],{},[108,353],{"alt":241,"src":354},"https:\u002F\u002Fi.imgur.com\u002Fm9OYgdE.png",[16,356,357],{},"檢查過沒問題後可以直接按下 Merge pull request",[16,359,360],{},[108,361],{"alt":362,"src":363},"merge","https:\u002F\u002Fi.imgur.com\u002F9NQMuqO.png",[16,365,366],{},"接下來就依照自己決定是否修改合併訊息及內容，若沒問題就可以按下 Confirm merge",[16,368,369],{},[108,370],{"alt":362,"src":371},"https:\u002F\u002Fi.imgur.com\u002FQGbDCg1.png",[16,373,374],{},"按下 Confirm merge 之後也可以看到原本的 OPEN 狀態變成 Merged，這樣就合併成功囉~",[16,376,377],{},[108,378],{"alt":362,"src":379},"https:\u002F\u002Fi.imgur.com\u002FALKetsq.png",[16,381,382],{},"回到專案首頁也可以看到路人發送的 PR 也加入到專案內了",[16,384,385],{},[108,386],{"alt":362,"src":387},"https:\u002F\u002Fi.imgur.com\u002Fr5wZigF.png",[12,389,391],{"id":390},"但是如果是多個分支呢","但是如果是多個分支呢?",[16,393,394],{},"一般來講系統開發的時候都會分成兩個分支 Master (主要分支)、Develop (開發分支)，通常系統開發上並不會直接 PR 到 Master，而是發到 Develop，然後測試沒問題後專案作者才會將 Develop 合併進 Master，所以在這邊選擇發 PR 的時候要多加留意一下自己的分支",[16,396,397],{},[108,398],{"alt":241,"src":262},[16,400,401],{},"這一段絕對很模糊，所以實際操作一次給各位看看",[98,403,405],{"id":404},"第一步驟-指定-clone-分支","第一步驟 指定 Clone 分支",[16,407,408],{},"這邊就不再附上 Fork & Clone 畫面了，因為是一樣的...",[16,410,411],{},"但是這邊要注意到一件事情 Clone 的時候指令會稍稍不太一樣",[138,413,415],{"className":140,"code":414,"language":142,"meta":143,"style":143},"git clone -b develop https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Ftest-repos.git\n",[145,416,417],{"__ignoreMap":143},[148,418,419],{"class":150,"line":151},[148,420,414],{},[16,422,423],{},"這樣子才會正確拉到我們要的 develop 分支",[16,425,426],{},[108,427],{"alt":428,"src":429},"develop","https:\u002F\u002Fi.imgur.com\u002F1Jr7smZ.png",[16,431,432],{},"改完之後一樣 加入索引 & commit 訊息並 push 出去",[16,434,435],{},[108,436],{"alt":219,"src":437},"https:\u002F\u002Fi.imgur.com\u002FfLd9VjP.png",[98,439,441],{"id":440},"第二步驟-檢查-push-資料","第二步驟 檢查 Push 資料",[16,443,444],{},"我們可以打開自己的 repo，可以發現 Master 分支並沒有任何變化",[16,446,447],{},[108,448],{"alt":449,"src":450},"branch","https:\u002F\u002Fi.imgur.com\u002FCrC953g.png",[16,452,453],{},"接下來切換到 develop，可以發現多了一段我們剛剛 push 的資料",[16,455,456],{},[108,457],{"alt":219,"src":458},"https:\u002F\u002Fi.imgur.com\u002Fta34JJ9.png",[98,460,462],{"id":461},"第三步驟-發送-pr","第三步驟 發送 PR",[16,464,465],{},"發送 PR 的流程基本上與上面相同，唯獨有一個地方要注意，要記得切換自己分支以及對方分支",[16,467,468],{},[108,469],{"alt":241,"src":470},"https:\u002F\u002Fi.imgur.com\u002FakKwTex.png",[16,472,473],{},"切換完畢就可以發 PR 啦，後面流程大致上相同只是會發到對方專案的 develop 分支",[12,475,477],{"id":476},"發生衝突怎麼辦","發生衝突怎麼辦?",[16,479,480],{},"這種狀況其實在兩人以上的專案是非常常見的，但是解決衝突也是一個學習方式",[16,482,483],{},"假設我目前 Fork 當前專案",[16,485,486],{},[108,487],{"alt":110,"src":488},"https:\u002F\u002Fi.imgur.com\u002FArS16oG.png",[16,490,491],{},"結果過程中有其他人修改同一個檔案內容，而你又要發 PR 回去專案，那你就會得到這個訊息",[16,493,494],{},[108,495],{"alt":241,"src":496},"https:\u002F\u002Fi.imgur.com\u002Fm2BVOQ1.png",[16,498,499],{},"雖然一樣可以按下 Create pull request，但是你是會得到一個提示是在跟你說 README 檔案現在有衝突",[16,501,502],{},[108,503],{"alt":181,"src":504},"https:\u002F\u002Fi.imgur.com\u002F5HDqmaA.png",[16,506,507],{},"解法有這兩種方法",[63,509,510,513],{},[66,511,512],{},"點 Resolve conflicts 線上手痛解決衝突問題 (我跟你保證會等很久，等了快半小時還沒開好...)",[66,514,515],{},"刪除 Fork 的專案 repo，重新再 Fork 一次 (我推薦這個做法，解決速度最快，程式碼複製出來就好)",[16,517,518],{},"這篇也附上發生衝突時的參考解決文章唷:D",[16,520,521],{},[48,522,524],{"href":523},"\u002Fgit\u002F20190621\u002F4239571950\u002F","衝突解決參考",[16,526,527],{},"所以基本上衝突問題是需要溝通，盡可能減少修改到同一支檔案。",[16,529,530],{},"以上都是直接針對開源專案發 PR 流程~",[532,533,534],"style",{},"html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}",{"title":143,"searchDepth":205,"depth":205,"links":536},[537,538,539,540,547,548,553],{"id":14,"depth":205,"text":14},{"id":21,"depth":205,"text":22},{"id":54,"depth":205,"text":54},{"id":96,"depth":205,"text":96,"children":541},[542,543,544,545,546],{"id":100,"depth":211,"text":101},{"id":123,"depth":211,"text":124},{"id":161,"depth":211,"text":162},{"id":188,"depth":211,"text":189},{"id":232,"depth":211,"text":233},{"id":309,"depth":205,"text":309},{"id":390,"depth":205,"text":391,"children":549},[550,551,552],{"id":404,"depth":211,"text":405},{"id":440,"depth":211,"text":441},{"id":461,"depth":211,"text":462},{"id":476,"depth":205,"text":477},"Git","2019-06-15 21:33:52","md","zh-Hant",{},true,"\u002Fgit\u002Fgithub-pr-pull-request","3",{"title":6,"description":18},false,"Git\u002FGitHub-該如何發-PR-pull-request",[566,554],"GitHub",null,"\u002Fgit\u002F20190615\u002F4143994266\u002F","xlmtdRNHXkKp2qDJvv3BLlfQCk8sy6_SmaPcHq20E00",{"newer":571,"older":575},{"url":572,"title":573,"date":574},"\u002Fhexo\u002F20190616\u002F2530364388\u002F","hexo-generator-search 搜尋套件 & 問題","2019-06-16 15:48:32",{"url":50,"title":576,"date":577},"基礎 Git 指令","2019-06-15 13:59:25",[579,584,589],{"url":580,"title":581,"date":582,"readingMinutes":583},"\u002Fgit\u002F20260226\u002F799954596\u002F","取代 git push --force 更好的方式，git push --force-with-lease","2026-02-26 09:39:40","4",{"url":585,"title":586,"date":587,"readingMinutes":588},"\u002Fgit\u002F20260122\u002F21277993\u002F","Git init 出現 master 分支提示？教你設定預設分支為 main","2026-01-22 16:20:40","2",{"url":590,"title":591,"date":592,"readingMinutes":583},"\u002Fgit\u002F20260121\u002F2025687513\u002F","Git Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣","2026-01-21 16:04:27",1784087349996]