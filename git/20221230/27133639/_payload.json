[{"data":1,"prerenderedAt":873},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20221230\u002F27133639\u002F":3,"page:\u002Fgit\u002F20221230\u002F27133639\u002F":4,"alt:\u002Fgit\u002F20221230\u002F27133639\u002F":3,"prev-next:\u002Fgit\u002F20221230\u002F27133639\u002F":849,"related:\u002Fgit\u002F20221230\u002F27133639\u002F":858},"\u002Fen\u002Fgit\u002F2022\u002F12\u002F30\u002Fgit-filename-case-sensitivity-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":527,"date":833,"description":834,"extension":835,"lang":836,"meta":837,"navigation":199,"path":838,"readingMinutes":839,"seo":840,"standalone":841,"stem":842,"tags":843,"tldr":845,"updated":846,"url":847,"__hash__":848},"content\u002FGit\u002F關於-Git-的檔案大小寫問題與修正.md","關於 Git 的檔案名稱大小寫問題與修正","27133639",{"type":9,"value":10,"toc":824},"minimark",[11,15,19,22,25,66,69,119,122,129,132,148,155,220,227,230,233,238,245,248,262,268,289,314,325,359,369,375,391,396,523,529,540,547,551,565,568,586,599,604,684,694,794,801,807,810,820],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"滿多人都會被 Git 的一個雷點給雷到，也就是檔案名稱大小寫不敏感的問題，所以這一篇我特別寫一篇來紀錄與分享怎麼解決這個問題。",[12,20,21],{"id":21},"檔案名稱問題",[16,23,24],{},"首先我們先嘗試觸發這個問題，這樣子才會比較印象深刻，我們先建立一個資料夾與檔案",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-bash shiki shiki-themes github-dark-high-contrast","mkdir test\ncd test\ntouch readme.md\n","bash","",[33,34,35,48,57],"code",{"__ignoreMap":31},[36,37,40,44],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"s_sBn","mkdir",[36,45,47],{"class":46},"sTRMh"," test\n",[36,49,51,55],{"class":38,"line":50},2,[36,52,54],{"class":53},"sCcAr","cd",[36,56,47],{"class":46},[36,58,60,63],{"class":38,"line":59},3,[36,61,62],{"class":42},"touch",[36,64,65],{"class":46}," readme.md\n",[16,67,68],{},"接下來我們先把這個資料夾加入 Git 並且傳到遠端儲存庫 GitHub 上",[26,70,72],{"className":28,"code":71,"language":30,"meta":31,"style":31},"git init\ngit add .\ngit commit -m \"init\"\ngit push origin main\n",[33,73,74,82,92,105],{"__ignoreMap":31},[36,75,76,79],{"class":38,"line":39},[36,77,78],{"class":42},"git",[36,80,81],{"class":46}," init\n",[36,83,84,86,89],{"class":38,"line":50},[36,85,78],{"class":42},[36,87,88],{"class":46}," add",[36,90,91],{"class":46}," .\n",[36,93,94,96,99,102],{"class":38,"line":59},[36,95,78],{"class":42},[36,97,98],{"class":46}," commit",[36,100,101],{"class":53}," -m",[36,103,104],{"class":46}," \"init\"\n",[36,106,108,110,113,116],{"class":38,"line":107},4,[36,109,78],{"class":42},[36,111,112],{"class":46}," push",[36,114,115],{"class":46}," origin",[36,117,118],{"class":46}," main\n",[16,120,121],{},"此時你的遠端儲存庫應該是這樣",[16,123,124],{},[125,126],"img",{"alt":127,"src":128},"GitHub","https:\u002F\u002Fi.imgur.com\u002FGoZjV4a.png",[16,130,131],{},"接著我們要來做什麼事？我們要把檔案名稱改成 README.md",[26,133,135],{"className":28,"code":134,"language":30,"meta":31,"style":31},"mv readme.md README.md\n",[33,136,137],{"__ignoreMap":31},[36,138,139,142,145],{"class":38,"line":39},[36,140,141],{"class":42},"mv",[36,143,144],{"class":46}," readme.md",[36,146,147],{"class":46}," README.md\n",[16,149,150,151,154],{},"接著你再輸入 ",[33,152,153],{},"git status"," 你會看到以下訊息",[26,156,158],{"className":28,"code":157,"language":30,"meta":31,"style":31},"On branch main\nYour branch is up to date with 'origin\u002Fmain'.\n\nnothing to commit, working tree clean\n",[33,159,160,170,195,201],{"__ignoreMap":31},[36,161,162,165,168],{"class":38,"line":39},[36,163,164],{"class":42},"On",[36,166,167],{"class":46}," branch",[36,169,118],{"class":46},[36,171,172,175,177,180,183,186,189,192],{"class":38,"line":50},[36,173,174],{"class":42},"Your",[36,176,167],{"class":46},[36,178,179],{"class":46}," is",[36,181,182],{"class":46}," up",[36,184,185],{"class":46}," to",[36,187,188],{"class":46}," date",[36,190,191],{"class":46}," with",[36,193,194],{"class":46}," 'origin\u002Fmain'.\n",[36,196,197],{"class":38,"line":59},[36,198,200],{"emptyLinePlaceholder":199},true,"\n",[36,202,203,206,208,211,214,217],{"class":38,"line":107},[36,204,205],{"class":42},"nothing",[36,207,185],{"class":46},[36,209,210],{"class":46}," commit,",[36,212,213],{"class":46}," working",[36,215,216],{"class":46}," tree",[36,218,219],{"class":46}," clean\n",[16,221,222,223,226],{},"這時候你再輸入 ",[33,224,225],{},"git add ."," 你會發現 Git 一點反應也沒有，為什麼會這樣呢？因為預設狀況下 Git 認為 readme.md 與 README.md 是同一個檔案，所以 Git 會視為沒有任何變更，因此 Git 會忽略這個變更。",[12,228,229],{"id":229},"解決方法",[16,231,232],{},"這邊我會列出兩種方式，一種其實比較偏向 Git 的設定，另一種則是比較偏向於 Git 的操作。",[234,235,237],"h3",{"id":236},"git-設定","Git 設定",[16,239,240,241,244],{},"首先 Git 有提供一個指令可以去設定檔案名稱大小寫敏感，這個指令就是 ",[33,242,243],{},"git config core.ignorecase","，這個指令可以讓 Git 認為大小寫不同的檔案是不同的檔案，所以 Git 會正常的去偵測檔案的變更，而預設情況下 Git 是會忽略大小寫的。",[16,246,247],{},"因此我們先將剛剛改成 README.md 的檔案改回來",[26,249,251],{"className":28,"code":250,"language":30,"meta":31,"style":31},"mv README.md readme.md\n",[33,252,253],{"__ignoreMap":31},[36,254,255,257,260],{"class":38,"line":39},[36,256,141],{"class":42},[36,258,259],{"class":46}," README.md",[36,261,65],{"class":46},[16,263,264,265],{},"接著輸入 ",[33,266,267],{},"git config core.ignorecase false",[26,269,271],{"className":28,"code":270,"language":30,"meta":31,"style":31},"git config --local core.ignorecase false\n",[33,272,273],{"__ignoreMap":31},[36,274,275,277,280,283,286],{"class":38,"line":39},[36,276,78],{"class":42},[36,278,279],{"class":46}," config",[36,281,282],{"class":53}," --local",[36,284,285],{"class":46}," core.ignorecase",[36,287,288],{"class":53}," false\n",[290,291,292],"blockquote",{},[16,293,294,298,299,302,303,306,307,309,310,313],{},[295,296,297],"strong",{},"Note","\n雖然也有 Global 設定可以使用，但是這必須額外去設定一個 Global 的 Git 設定檔，而且這個設定檔會影響到你輸入 ",[33,300,301],{},"git init"," 以及所有的 Git 專案，所以個人會建議使用 Local 設定就好，這樣子只會影響到當前這個專案。\n另外，如果你針對你的本地專案設定了 ",[33,304,305],{},"git config --local core.ignorecase false","，那麼當你推到遠端儲存庫時，你的遠端儲存庫也會跟著變成 ",[33,308,305],{},"，這樣子你 ",[33,311,312],{},"git clone"," 時就不用再去設定一次了。",[16,315,316,317,320,321,324],{},"先來講講 ",[33,318,319],{},"true"," 與 ",[33,322,323],{},"false","差異",[326,327,328,345],"ul",{},[329,330,331,333,334],"li",{},[33,332,319],{},"：Git 會忽略大小寫\n",[326,335,336],{},[329,337,338,320,341,344],{},[33,339,340],{},"readme.md",[33,342,343],{},"README.md"," 是同一個檔案",[329,346,347,349,350],{},[33,348,323],{},"：Git 會認為大小寫不同的檔案是不同的檔案\n",[326,351,352],{},[329,353,354,320,356,358],{},[33,355,340],{},[33,357,343],{}," 是不同的檔案",[290,360,361],{},[16,362,363,365,366,368],{},[295,364,297],{},"\n如果你在專案底下單純輸入 ",[33,367,243],{},"，是可以看到當前專案的設定",[16,370,371,372,374],{},"接著我們來更改檔案名稱，這邊示範使用 ",[33,373,141],{}," 的方式",[26,376,378],{"className":28,"code":377,"language":30,"meta":31,"style":31},"mv -f readme.md README.md\n",[33,379,380],{"__ignoreMap":31},[36,381,382,384,387,389],{"class":38,"line":39},[36,383,141],{"class":42},[36,385,386],{"class":53}," -f",[36,388,144],{"class":46},[36,390,147],{"class":46},[16,392,393,394,154],{},"接著我們再輸入 ",[33,395,153],{},[26,397,399],{"className":28,"code":398,"language":30,"meta":31,"style":31},"On branch main\nYour branch is up to date with 'origin\u002Fmain'.\n\nUntracked files:\n  (use \"git add \u003Cfile>...\" to include in what will be committed)\n        README.md\n\nnothing added to commit but untracked files present (use \"git add\" to track)\n",[33,400,401,409,427,431,439,475,481,486],{"__ignoreMap":31},[36,402,403,405,407],{"class":38,"line":39},[36,404,164],{"class":42},[36,406,167],{"class":46},[36,408,118],{"class":46},[36,410,411,413,415,417,419,421,423,425],{"class":38,"line":50},[36,412,174],{"class":42},[36,414,167],{"class":46},[36,416,179],{"class":46},[36,418,182],{"class":46},[36,420,185],{"class":46},[36,422,188],{"class":46},[36,424,191],{"class":46},[36,426,194],{"class":46},[36,428,429],{"class":38,"line":59},[36,430,200],{"emptyLinePlaceholder":199},[36,432,433,436],{"class":38,"line":107},[36,434,435],{"class":42},"Untracked",[36,437,438],{"class":46}," files:\n",[36,440,442,446,449,452,454,457,460,463,466,469,472],{"class":38,"line":441},5,[36,443,445],{"class":444},"sMAXC","  (",[36,447,448],{"class":42},"use",[36,450,451],{"class":46}," \"git add \u003Cfile>...\"",[36,453,185],{"class":46},[36,455,456],{"class":46}," include",[36,458,459],{"class":46}," in",[36,461,462],{"class":46}," what",[36,464,465],{"class":46}," will",[36,467,468],{"class":46}," be",[36,470,471],{"class":46}," committed",[36,473,474],{"class":444},")\n",[36,476,478],{"class":38,"line":477},6,[36,479,480],{"class":42},"        README.md\n",[36,482,484],{"class":38,"line":483},7,[36,485,200],{"emptyLinePlaceholder":199},[36,487,489,491,494,496,498,501,504,507,510,513,516,518,521],{"class":38,"line":488},8,[36,490,205],{"class":42},[36,492,493],{"class":46}," added",[36,495,185],{"class":46},[36,497,98],{"class":46},[36,499,500],{"class":46}," but",[36,502,503],{"class":46}," untracked",[36,505,506],{"class":46}," files",[36,508,509],{"class":46}," present",[36,511,512],{"class":444}," (use ",[36,514,515],{"class":46},"\"git add\"",[36,517,185],{"class":46},[36,519,520],{"class":46}," track",[36,522,474],{"class":444},[16,524,525],{},[125,526],{"alt":527,"src":528},"Git","https:\u002F\u002Fi.imgur.com\u002FiAwhXj3.png",[16,530,531,532,535,536,539],{},"這樣子 Git 才能夠正常偵測到檔案名稱的變更，這時候你才有辦法輸入 ",[33,533,534],{},"git add.","、",[33,537,538],{},"git commit"," ... 等指令唷。",[290,541,542],{},[16,543,544,546],{},[295,545,297],{},"\n請注意「Git 設定」必須在專案初始化時就設定，否則你有很高機會遇到一些雷點，例如上傳到 GitHub 後結果出現同名的兩個檔案，如：README.md、readme.md\n所以請記得在專案初始化時就設定好 Git 設定，這樣子才能夠避免一些雷點。",[234,548,550],{"id":549},"git-操作","Git 操作",[16,552,553,554,557,558,561,562],{},"其實 Git 也有提供一個指令可以讓你去更改檔案名稱，這個指令就是 ",[33,555,556],{},"git mv","，這個指令可以讓你更改檔案名稱，並且 Git 也會正常的去偵測檔案的變更，而這個方式最簡單的也是",[295,559,560],{},"最推薦","的，使用方式就是 ",[33,563,564],{},"git mv \u003C舊檔案名稱> \u003C新檔案名稱>",[16,566,567],{},"因此你可以試著輸入以下指令",[26,569,571],{"className":28,"code":570,"language":30,"meta":31,"style":31},"git mv -f readme.md README.md\n",[33,572,573],{"__ignoreMap":31},[36,574,575,577,580,582,584],{"class":38,