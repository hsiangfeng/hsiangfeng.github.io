[{"data":1,"prerenderedAt":908},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20260121\u002F2025687513\u002F":3,"page:\u002Fgit\u002F20260121\u002F2025687513\u002F":4,"alt:\u002Fgit\u002F20260121\u002F2025687513\u002F":3,"prev-next:\u002Fgit\u002F20260121\u002F2025687513\u002F":884,"related:\u002Fgit\u002F20260121\u002F2025687513\u002F":893},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F21\u002Fgit-worktree-multiple-ai-agents-one-project\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":120,"date":864,"description":865,"extension":866,"lang":867,"meta":868,"navigation":639,"path":869,"readingMinutes":870,"seo":871,"standalone":872,"stem":873,"tags":874,"tldr":880,"updated":881,"url":882,"__hash__":883},"content\u002FGit\u002FGit Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣.md","Git Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣","2025687513",{"type":9,"value":10,"toc":854},"minimark",[11,18,28,32,35,39,42,58,61,69,76,79,116,122,133,138,143,149,188,202,226,230,233,267,285,311,325,328,331,334,342,349,355,366,373,376,382,385,480,486,492,498,501,555,562,568,571,577,584,590,597,685,696,702,705,711,714,824,827,830,850],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002FGemini_Generated_Image_dbbxwrdbbxwrdbbx.png",[19,20,21],"blockquote",{},[12,22,23,27],{},[24,25,26],"strong",{},"Note","\nGit Worktree 是 Git 2.5 開始提供的功能，可以讓你在同一個 Repository 之下同時擁有多個工作目錄，每個目錄 checkout 不同分支。不用 stash 也不用切分支，搭配 AI Agent 同時跑不同任務超方便。",[29,30,31],"h2",{"id":31},"前言",[12,33,34],{},"相信許多人都已經在使用 AI Agent 來協助完成各種任務，但在實際應用上，我們總是手上會有很多需求，一個專案可能就要同時負責 N 個功能開發，這時候就會有一個疑問：「一個專案只能跑一個 AI Agent 嗎？」，所以這一篇就來聊聊一下該怎麼做到在一個專案中同時運行多個 AI Agent。",[29,36,38],{"id":37},"多個任務-ai-agent","多個任務 AI Agent",[12,40,41],{},"廢話就不多說，我們直接切入正題，假設我們今天要製作一個 TodoList，這個 TodoList 會有四個主要功能：",[43,44,45,49,52,55],"ul",{},[46,47,48],"li",{},"新增待辦事項",[46,50,51],{},"查詢待辦事項",[46,53,54],{},"更新待辦事項",[46,56,57],{},"刪除待辦事項",[12,59,60],{},"在普通狀況下我們可能是先完成新增待辦事項的功能，接著再來完成查詢、更新、刪除等功能，所以 AI Agent 就會一個接著一個的跑，這樣雖然可以達成目標，但如果新增的功能很複雜的話，那是不是要跑很久才能接著往下一個功能去？",[12,62,63,64,68],{},"所以這邊就要介紹一個東西，也就是 ",[65,66,67],"code",{},"Git WorkTree","。",[12,70,71,72,75],{},"這個是 Git 的一個功能，是在 ",[65,73,74],{},"2.5"," 時釋出的功能，簡單來講，他可以讓我們在同一個 Git 倉庫中，同時存在多個工作目錄，這樣我們就可以在同一個專案中，同時跑多個 AI Agent 來處理不同的任務。",[12,77,78],{},"那麼通常我們會輸入以下指令初始化專案 Git：",[80,81,86],"pre",{"className":82,"code":83,"language":84,"meta":85,"style":85},"language-bash shiki shiki-themes github-dark-high-contrast","git init\ngit switch -c feature\n","bash","",[65,87,88,101],{"__ignoreMap":85},[89,90,93,97],"span",{"class":91,"line":92},"line",1,[89,94,96],{"class":95},"s_sBn","git",[89,98,100],{"class":99},"sTRMh"," init\n",[89,102,104,106,109,113],{"class":91,"line":103},2,[89,105,96],{"class":95},[89,107,108],{"class":99}," switch",[89,110,112],{"class":111},"sCcAr"," -c",[89,114,115],{"class":99}," feature\n",[12,117,118],{},[15,119],{"alt":120,"src":121},"Git","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-worktree\u002F20260121112418.png",[12,123,124,125,128,129,132],{},"這時候就會停在 ",[65,126,127],{},"feature"," 分支，接著我們就可以使用 ",[65,130,131],{},"git worktree"," 來建立多個工作目錄。",[12,134,135,137],{},[65,136,131],{}," 有兩種常見用法：",[139,140,142],"h3",{"id":141},"情境一使用現有分支建立工作目錄","情境一：使用現有分支建立工作目錄",[12,144,145,146,148],{},"如果你已經有一個分支（例如 ",[65,147,127],{},"），想為它建立一個獨立的工作目錄：",[80,150,152],{"className":82,"code":151,"language":84,"meta":85,"style":85},"git worktree add \u003Cpath> \u003Cexisting-branch>\n",[65,153,154],{"__ignoreMap":85},[89,155,156,158,161,164,168,171,175,178,180,183,185],{"class":91,"line":92},[89,157,96],{"class":95},[89,159,160],{"class":99}," worktree",[89,162,163],{"class":99}," add",[89,165,167],{"class":166},"sWyjQ"," \u003C",[89,169,170],{"class":99},"pat",[89,172,174],{"class":173},"sMAXC","h",[89,176,177],{"class":166},">",[89,179,167],{"class":166},[89,181,182],{"class":99},"existing-branc",[89,184,174],{"class":173},[89,186,187],{"class":166},">\n",[43,189,190,196],{},[46,191,192,195],{},[65,193,194],{},"\u003Cpath>","：要建立的工作目錄路徑",[46,197,198,201],{},[65,199,200],{},"\u003Cexisting-branch>","：現有的分支名稱",[80,203,205],{"className":82,"code":204,"language":84,"meta":85,"style":85},"# 範例：為現有的 feature 分支建立工作目錄\ngit worktree add ..\u002Ffeature-worktree feature\n",[65,206,207,213],{"__ignoreMap":85},[89,208,209],{"class":91,"line":92},[89,210,212],{"class":211},"sQrFR","# 範例：為現有的 feature 分支建立工作目錄\n",[89,214,215,217,219,221,224],{"class":91,"line":103},[89,216,96],{"class":95},[89,218,160],{"class":99},[89,220,163],{"class":99},[89,222,223],{"class":99}," ..\u002Ffeature-worktree",[89,225,115],{"class":99},[139,227,229],{"id":228},"情境二建立新分支並同時建立工作目錄","情境二：建立新分支並同時建立工作目錄",[12,231,232],{},"如果你想建立一個新分支，並同時建立工作目錄：",[80,234,236],{"className":82,"code":235,"language":84,"meta":85,"style":85},"git worktree add \u003Cpath> -b \u003Cnew-branch-name>\n",[65,237,238],{"__ignoreMap":85},[89,239,240,242,244,246,248,250,252,254,257,259,262,265],{"class":91,"line":92},[89,241,96],{"class":95},[89,243,160],{"class":99},[89,245,163],{"class":99},[89,247,167],{"class":166},[89,249,170],{"class":99},[89,251,174],{"class":173},[89,253,177],{"class":166},[89,255,256],{"class":111}," -b",[89,258,167],{"class":166},[89,260,261],{"class":99},"new-branch-nam",[89,263,264],{"class":173},"e",[89,266,187],{"class":166},[43,268,269,273,279],{},[46,270,271,195],{},[65,272,194],{},[46,274,275,278],{},[65,276,277],{},"-b","：表示要建立新分支",[46,280,281,284],{},[65,282,283],{},"\u003Cnew-branch-name>","：要建立的新分支名稱",[80,286,288],{"className":82,"code":287,"language":84,"meta":85,"style":85},"# 範例：建立新的 feature-new 分支和工作目錄\ngit worktree add ..\u002Ffeature-new-worktree -b feature-new\n",[65,289,290,295],{"__ignoreMap":85},[89,291,292],{"class":91,"line":92},[89,293,294],{"class":211},"# 範例：建立新的 feature-new 分支和工作目錄\n",[89,296,297,299,301,303,306,308],{"class":91,"line":103},[89,298,96],{"class":95},[89,300,160],{"class":99},[89,302,163],{"class":99},[89,304,305],{"class":99}," ..\u002Ffeature-new-worktree",[89,307,256],{"class":111},[89,309,310],{"class":99}," feature-new\n",[19,312,313],{},[12,314,315,318,319,321,322,324],{},[24,316,317],{},"關鍵差異","：有 ",[65,320,277],{}," 是「建立新分支」，沒有 ",[65,323,277],{}," 是「使用現有分支」。",[139,326,327],{"id":327},"何謂工作目錄",[12,329,330],{},"看到這邊應該會對於工作目錄感到困惑，簡單來說，工作目錄就是我們平常在電腦上看到的專案資料夾。",[12,332,333],{},"假設你的專案結構長這樣：",[80,335,340],{"className":336,"code":338,"language":339,"meta":85},[337],"language-text","\u002FUsers\u002Fray\u002F\n└── my-project\u002F       ← 你的主專案（main 分支）\n","text",[65,341,338],{"__ignoreMap":85},[12,343,344,345,348],{},"當你執行 ",[65,346,347],{},"git worktree add ..\u002Fmy-project-feature feature"," 後，資料夾結構會變成：",[80,350,353],{"className":351,"code":352,"language":339,"meta":85},[337],"\u002FUsers\u002Fray\u002F\n├── my-project\u002F           ← 主專案（main 分支）\n└── my-project-feature\u002F   ← 新的工作目錄（feature 分支）\n",[65,354,352],{"__ignoreMap":85},[12,356,357,358,361,362,365],{},"這兩個資料夾",[24,359,360],{},"共享同一個 Git 歷史","，但可以",[24,363,364],{},"同時切換到不同分支","工作。你可以把它想像成：同一份專案開了兩個視窗，各自編輯不同版本，互不干擾。",[19,367,368],{},[12,369,370,372],{},[24,371,26],{},"\n更白話一點其實就是 Copy 一份專案出來，不過這份專案是跟原本的專案共用同一個 Git 倉庫。",[29,374,375],{"id":375},"實戰示範",[12,377,378,379,381],{},"接著我們就來實際示範如何使用 ",[65,380,67],{}," 來同時跑多個 AI Agent。",[12,383,384],{},"這邊就使用了剛剛建立的 TodoList 專案，並且針對每個功能建立一個工作目錄。",[80,386,388],{"className":82,"code":387,"language":84,"meta":85,"style":85},"# 建立新增待辦事項的工作目錄，並建立新分支 feature-add\ngit worktree add ..\u002Ftodo-add -b feature-add\n# 建立查詢待辦事項的工作目錄，並建立新分支 feature-query\ngit worktree add ..\u002Ftodo-query -b feature-query\n# 建立更新待辦事項的工作目錄，並建立新分支 feature-update\ngit worktree add ..\u002Ftodo-update -b feature-update\n# 建立刪除待辦事項的工作目錄，並建立新分支 feature-delete\ngit worktree add ..\u002Ftodo-delete -b feature-delete\n",[65,389,390,395,411,417,434,440,457,463],{"__ignoreMap":85},[89,391,392],{"class":91,"line":92},[89,393,394],{"class":211},"# 建立新增待辦事項的工作目錄，並建立新分支 feature-add\n",[89,396,397,399,401,403,406,408],{"class":91,"line":103},[89,398,96],{"class":95},[89,400,160],{"class":99},[89,402,163],{"class":99},[89,404,405],{"class":99}," ..\u002Ftodo-add",[89,407,256],{"class":111},[89,409,410],{"class":99}," feature-add\n",[89,412,414],{"class":91,"line":413},3,[89,415,416],{"class":211},"# 建立查詢待辦事項的工作目錄，並建立新分支 feature-query\n",[89,418,420,422,424,426,429,431],{"class":91,"line":419},4,[89,421,96],{"class":95},[89,423,160],{"class":99},[89,425,163],{"class":99},[89,427,428],{"class":99}," ..\u002Ftodo-query",[89,430,256],{"class":111},[89,432,433],{"class":99}," feature-query\n",[89,435,437],{"class":91,"line":436},5,[89,438,439],{"class":211},"# 建立更新待辦事項的工作目錄，並建立新分支 feature-update\n",[89,441,443,445,447,449,452,454],{"class":91,"line":442},6,[89,444,96],{"class":95},[89,446,160],{"class":99},[89,448,163],{"class":99},[89,450,451],{"class":99}," ..\u002Ftodo-update",[89,453,256],{"class":111},[89,455,456],{"class":99}," feature-update\n",[89,458,460],{"class":91,"line":459},7,[89,461,462],{"class":211},"# 建立刪除待辦事項的工作目錄，並建立新分支 feature-delete\n",[89,464,466,468,470,472,475,477],{"class":91,"line":465},8,[89,467,96],{"class":95},[89,469,160],{"class":99},[89,471,163],{"class":99},[89,473,474],{"class":99}," ..\u002Ftodo-delete",[89,476,256],{"class":111},[89,478,479],{"class":99}," feature-delete\n",[12,481,482,483],{},"接下來都輸入完畢後，我們就會在專案目錄的上層看到四個新的資料夾，分別對應到我們剛剛建立的工作目錄，以我的路徑來講是 ",[65,484,485],{},"\u002FUsers\u002Frayxu\u002FGitHub\u002Ftodolist-worktree\u002F",[80,487,490],{"className":488,"code":489,"language":339,"meta":85},[337],"\u002FUsers\u002Frayxu\u002FGitHub\u002F\n├── todolist-worktree\u002F        ← 主專案（main 分支）\n├── todo-add\u002F                 ← 新增待辦事項工作目錄（feature-add 分支）\n├── todo-query\u002F               ← 查詢待辦事項工作目錄（feature-query 分支）\n├── todo-update\u002F              ← 更新待辦事項工作目錄（feature-update 分支）\n└── todo-delete\u002F              ← 刪除待辦事項工作目錄（feature-delete 分支）\n",[65,491,489],{"__ignoreMap":85},[12,493,494],{},[15,495],{"alt":496,"src":497},"工作目錄","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121153351.png",[12,499,500],{},"然後接著你就可以打開四個終端機視窗，分別切換到四個工作目錄",[80,502,504],{"className":82,"code":503,"language":84,"meta":85,"style":85},"# 切換到新增待辦事項工作目錄\ncd ..\u002Ftodo-add\n# 切換到查詢待辦事項工作目錄\ncd ..\u002Ftodo-query\n# 切換到更新待辦事項工作目錄\ncd ..\u002Ftodo-update\n# 切換到刪除待辦事項工作目錄\ncd ..\u002Ftodo-delete\n",[65,505,506,511,519,524,531,536,543,548],{"__ignoreMap":85},[89,507,508],{"class":91,"line":92},[89,509,510],{"class":211},"# 切換到新增待辦事項工作目錄\n",[89,512,513,516],{"class":91,"line":103},[89,514,515],{"class":111},"cd",[89,517,518],{"class":99}," ..\u002Ftodo-add\n",[89,520,521],{"class":91,"line":413},[89,522,523],{"class":211},"# 切換到查詢待辦事項工作目錄\n",[89,525,526,528],{"class":91,"line":419},[89,527,515],{"class":111},[89,529,530],{"class":99}," ..\u002Ftodo-query\n",[89,532,533],{"class":91,"line":436},[89,534,535],{"class":211},"# 切換到更新待辦事項工作目錄\n",[89,537,538,540],{"class":91,"line":442},[89,539,515],{"class":111},[89,541,542],{"class":99}," ..\u002Ftodo-update\n",[89,544,545],{"class":91,"line":459},[89,546,547],{"class":211},"# 切換到刪除待辦事項工作目錄\n",[89,549,550,552],{"class":91,"line":465},[89,551,515],{"class":111},[89,553,554],{"class":99}," ..\u002Ftodo-delete\n",[12,556,557,558,561],{},"接著就可以在各自的終端機輸入 ",[65,559,560],{},"claude"," 指令來啟動 AI Agent，並且針對各自的功能進行開發。",[12,563,564],{},[15,565],{"alt":566,"src":567},"claude 啟動","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121153708.png",[12,569,570],{},"接著底下我簡單四個都同時叫他們做「幫我建立一個 xxx.js 的檔案」",[12,572,573],{},[15,574],{"alt":575,"src":576},"各自運作","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121153820.png",[12,578,579,580,583],{},"接下來你可以回到各自的工作目錄中查看結果，你應該會看到各自的檔案都已經被建立完成，唯獨原本的 ",[65,581,582],{},"todolist-worktree"," 主專案資料夾中是不會有這些檔案的，因為這些檔案都是在各自的工作目錄中被建立的。",[12,585,586],{},[15,587],{"alt":588,"src":589},"結果展示","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121154116.gif",[12,591,592,593,596],{},"那接下來我們該怎麼把這些功能合併回主專案呢？你要先針對這些檔案進行 commit，接著再回到主專案中使用 ",[65,594,595],{},"git merge"," 來合併這些分支。",[80,598,600],{"className":82,"code":599,"language":84,"meta":85,"style":85},"# 1. 在 worktree 中提交變更\ncd ..\u002Ftodo-add\ngit add .\ngit commit -m \"feat: 新增待辦事項功能\"\n\n# 2. 移除 worktree（釋放分支）\ncd ..\u002Ftodolist-worktree\ngit worktree remove ..\u002Ftodo-add\n\n# 3. 合併分支\ngit merge feature-add\n",[65,601,602,607,613,622,635,641,646,653,664,669,675],{"__ignoreMap":85},[89,603,604],{"class":91,"line":92},[89,605,606],{"class":211},"# 1. 在 worktree 中提交變更\n",[89,608,609,611],{"class":91,"line":103},[89,610,515],{"class":111},[89,612,518],{"class":99},[89,614,615,617,619],{"class":91,"line":413},[89,616,96],{"class":95},[89,618,163],{"class":99},[89,620,621],{"class":99}," .\n",[89,623,624,626,629,632],{"class":91,"line":419},[89,625,96],{"class":95},[89,627,628],{"class":99}," commit",[89,630,631],{"class":111}," -m",[89,633,634],{"class":99}," \"feat: 新增待辦事項功能\"\n",[89,636,637],{"class":91,"line":436},[89,638,640],{"emptyLinePlaceholder":639},true,"\n",[89,642,643],{"class":91,"line":442},[89,644,645],{"class":211},"# 2. 移除 worktree（釋放分支）\n",[89,647,648,650],{"class":91,"line":459},[89,649,515],{"class":111},[89,651,652],{"class":99}," ..\u002Ftodolist-worktree\n",[89,654,655,657,659,662],{"class":91,"line":465},[89,656,96],{"class":95},[89,658,160],{"class":99},[89,660,661],{"class":99}," remove",[89,663,518],{"class":99},[89,665,667],{"class":91,"line":666},9,[89,668,640],{"emptyLinePlaceholder":639},[89,670,672],{"class":91,"line":671},10,[89,673,674],{"class":211},"# 3. 合併分支\n",[89,676,678,680,683],{"class":91,"line":677},11,[89,679,96],{"class":95},[89,681,682],{"class":99}," merge",[89,684,410],{"class":99},[19,686,687],{},[12,688,689,691,692,695],{},[24,690,26],{},"\n如果出現「致命錯誤: 拒絕合併無關的歷史」，代表你需要在合併時改成 ",[65,693,694],{},"git merge feature-add --allow-unrelated-histories"," 參數。因為正常來講，你必須要在建立 worktree 之前（todolist-worktree），主專案應該要先有一個初始 commit。",[12,697,698],{},[15,699],{"alt":700,"src":701},"合併過程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121155102.png",[12,703,704],{},"如果你打開 commit 線圖，你會發現就跟你發 PR 一樣，會多出一個分支，然後 Merge 回主分支。",[12,706,707],{},[15,708],{"alt":709,"src":710},"線圖展示","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121155213.png",[12,712,713],{},"最後這邊也提供一下相關的 Git 指令給大家參考：",[715,716,717,730],"table",{},[718,719,720],"thead",{},[721,722,723,727],"tr",{},[724,725,726],"th",{},"指令",[724,728,729],{},"說明",[731,732,733,744,754,764,774,784,794,804,814],"tbody",{},[721,734,735,741],{},[736,737,738],"td",{},[65,739,740],{},"git init",[736,742,743],{},"初始化專案 Git",[721,745,746,751],{},[736,747,748],{},[65,749,750],{},"git switch -c \u003Cbranch>",[736,752,753],{},"建立並切換到新分支",[721,755,756,761],{},[736,757,758],{},[65,759,760],{},"git worktree add \u003Cpath> \u003Cexisting-branch>",[736,762,763],{},"使用現有分支建立工作目錄",[721,765,766,771],{},[736,767,768],{},[65,769,770],{},"git worktree add \u003Cpath> -b \u003Cnew-branch>",[736,772,773],{},"建立新分支並同時建立工作目錄",[721,775,776,781],{},[736,777,778],{},[65,779,780],{},"git worktree remove \u003Cpath>",[736,782,783],{},"移除 worktree（釋放分支）",[721,785,786,791],{},[736,787,788],{},[65,789,790],{},"git add .",[736,792,793],{},"將所有變更加入暫存區",[721,795,796,801],{},[736,797,798],{},[65,799,800],{},"git commit -m \"message\"",[736,802,803],{},"提交變更",[721,805,806,811],{},[736,807,808],{},[65,809,810],{},"git merge \u003Cbranch>",[736,812,813],{},"合併分支",[721,815,816,821],{},[736,817,818],{},[65,819,820],{},"git merge \u003Cbranch> --allow-unrelated-histories",[736,822,823],{},"合併無關歷史的分支（解決拒絕合併錯誤）",[29,825,826],{"id":826},"延伸閱讀",[12,828,829],{},"Worktree 跟 AI Agent 真的是絕配，如果你想把這個組合玩得更深，可以接著看：",[43,831,832,842],{},[46,833,834,841],{},[835,836,840],"a",{"href":837,"rel":838},"https:\u002F\u002Fisraynotarray.com\u002Fai\u002F20260128\u002F374686091\u002F",[839],"nofollow","想用 Claude Code 開發？這篇帶你從入門到進階","：Claude Code 完整入門與進階技巧，搭配 Worktree 效益最大化。",[46,843,844,849],{},[835,845,848],{"href":846,"rel":847},"https:\u002F\u002Fisraynotarray.com\u002Fai\u002F20260319\u002F738324368\u002F",[839],"Claude Cowork Dispatch 與 Remote Control - 用手機遠端控制你的 AI Agent","：多個 Worktree 加上手機遠端派發任務，並行開發體驗會差很多。",[851,852,853],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}",{"title":85,"searchDepth":103,"depth":103,"links":855},[856,857,862,863],{"id":31,"depth":103,"text":31},{"id":37,"depth":103,"text":38,"children":858},[859,860,861],{"id":141,"depth":413,"text":142},{"id":228,"depth":413,"text":229},{"id":327,"depth":413,"text":327},{"id":375,"depth":103,"text":375},{"id":826,"depth":103,"text":826},"2026-01-21 16:04:27","Git Worktree 完整教學：Git 2.5 開始的功能，讓你在同一個 repo 開出多個工作目錄、各自停在不同分支，不用 stash、不用切分支就能平行開發。這篇示範怎麼用 worktree 一次跑多支 Claude Code Agent 處理不同功能，附 add、remove、merge 指令對照表與「拒絕合併無關歷史」解法。","md","zh-Hant",{},"\u002Fgit\u002Fgit-worktree-ai-agent","4",{"title":6,"description":865},false,"Git\u002FGit Worktree 是什麼？一個專