[{"data":1,"prerenderedAt":904},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20260121\u002F2025687513\u002F":3,"page:\u002Fgit\u002F20260121\u002F2025687513\u002F":4,"alt:\u002Fgit\u002F20260121\u002F2025687513\u002F":3,"prev-next:\u002Fgit\u002F20260121\u002F2025687513\u002F":880,"related:\u002Fgit\u002F20260121\u002F2025687513\u002F":889},"\u002Fen\u002Fgit\u002F2026\u002F01\u002F21\u002Fgit-worktree-multiple-ai-agents-one-project\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":118,"date":860,"description":861,"extension":862,"lang":863,"meta":864,"navigation":637,"path":865,"readingMinutes":866,"seo":867,"standalone":868,"stem":869,"tags":870,"tldr":876,"updated":877,"url":878,"__hash__":879},"content\u002FGit\u002FGit Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣.md","Git Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣","2025687513",{"type":9,"value":10,"toc":850},"minimark",[11,18,26,30,33,37,40,56,59,67,74,77,114,120,131,136,141,147,186,200,224,228,231,265,283,309,325,328,331,334,342,349,355,366,371,374,380,383,478,484,490,496,499,553,560,566,569,575,582,588,595,683,692,698,701,707,710,820,823,826,846],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002FGemini_Generated_Image_dbbxwrdbbxwrdbbx.png",[19,20,23],"callout",{"title":21,"type":22},"Note","note",[12,24,25],{},"Git Worktree 是 Git 2.5 開始提供的功能，可以讓你在同一個 Repository 之下同時擁有多個工作目錄，每個目錄 checkout 不同分支。不用 stash 也不用切分支，搭配 AI Agent 同時跑不同任務超方便。",[27,28,29],"h2",{"id":29},"前言",[12,31,32],{},"相信許多人都已經在使用 AI Agent 來協助完成各種任務，但在實際應用上，我們總是手上會有很多需求，一個專案可能就要同時負責 N 個功能開發，這時候就會有一個疑問：「一個專案只能跑一個 AI Agent 嗎？」，所以這一篇就來聊聊一下該怎麼做到在一個專案中同時運行多個 AI Agent。",[27,34,36],{"id":35},"多個任務-ai-agent","多個任務 AI Agent",[12,38,39],{},"廢話就不多說，我們直接切入正題，假設我們今天要製作一個 TodoList，這個 TodoList 會有四個主要功能：",[41,42,43,47,50,53],"ul",{},[44,45,46],"li",{},"新增待辦事項",[44,48,49],{},"查詢待辦事項",[44,51,52],{},"更新待辦事項",[44,54,55],{},"刪除待辦事項",[12,57,58],{},"在普通狀況下我們可能是先完成新增待辦事項的功能，接著再來完成查詢、更新、刪除等功能，所以 AI Agent 就會一個接著一個的跑，這樣雖然可以達成目標，但如果新增的功能很複雜的話，那是不是要跑很久才能接著往下一個功能去？",[12,60,61,62,66],{},"所以這邊就要介紹一個東西，也就是 ",[63,64,65],"code",{},"Git WorkTree","。",[12,68,69,70,73],{},"這個是 Git 的一個功能，是在 ",[63,71,72],{},"2.5"," 時釋出的功能，簡單來講，他可以讓我們在同一個 Git 倉庫中，同時存在多個工作目錄，這樣我們就可以在同一個專案中，同時跑多個 AI Agent 來處理不同的任務。",[12,75,76],{},"那麼通常我們會輸入以下指令初始化專案 Git：",[78,79,84],"pre",{"className":80,"code":81,"language":82,"meta":83,"style":83},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","git init\ngit switch -c feature\n","bash","",[63,85,86,99],{"__ignoreMap":83},[87,88,91,95],"span",{"class":89,"line":90},"line",1,[87,92,94],{"class":93},"smYoP","git",[87,96,98],{"class":97},"sWayO"," init\n",[87,100,102,104,107,111],{"class":89,"line":101},2,[87,103,94],{"class":93},[87,105,106],{"class":97}," switch",[87,108,110],{"class":109},"stw71"," -c",[87,112,113],{"class":97}," feature\n",[12,115,116],{},[15,117],{"alt":118,"src":119},"Git","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-worktree\u002F20260121112418.png",[12,121,122,123,126,127,130],{},"這時候就會停在 ",[63,124,125],{},"feature"," 分支，接著我們就可以使用 ",[63,128,129],{},"git worktree"," 來建立多個工作目錄。",[12,132,133,135],{},[63,134,129],{}," 有兩種常見用法：",[137,138,140],"h3",{"id":139},"情境一使用現有分支建立工作目錄","情境一：使用現有分支建立工作目錄",[12,142,143,144,146],{},"如果你已經有一個分支（例如 ",[63,145,125],{},"），想為它建立一個獨立的工作目錄：",[78,148,150],{"className":80,"code":149,"language":82,"meta":83,"style":83},"git worktree add \u003Cpath> \u003Cexisting-branch>\n",[63,151,152],{"__ignoreMap":83},[87,153,154,156,159,162,166,169,173,176,178,181,183],{"class":89,"line":90},[87,155,94],{"class":93},[87,157,158],{"class":97}," worktree",[87,160,161],{"class":97}," add",[87,163,165],{"class":164},"sOudu"," \u003C",[87,167,168],{"class":97},"pat",[87,170,172],{"class":171},"s8XSl","h",[87,174,175],{"class":164},">",[87,177,165],{"class":164},[87,179,180],{"class":97},"existing-branc",[87,182,172],{"class":171},[87,184,185],{"class":164},">\n",[41,187,188,194],{},[44,189,190,193],{},[63,191,192],{},"\u003Cpath>","：要建立的工作目錄路徑",[44,195,196,199],{},[63,197,198],{},"\u003Cexisting-branch>","：現有的分支名稱",[78,201,203],{"className":80,"code":202,"language":82,"meta":83,"style":83},"# 範例：為現有的 feature 分支建立工作目錄\ngit worktree add ..\u002Ffeature-worktree feature\n",[63,204,205,211],{"__ignoreMap":83},[87,206,207],{"class":89,"line":90},[87,208,210],{"class":209},"sGBqm","# 範例：為現有的 feature 分支建立工作目錄\n",[87,212,213,215,217,219,222],{"class":89,"line":101},[87,214,94],{"class":93},[87,216,158],{"class":97},[87,218,161],{"class":97},[87,220,221],{"class":97}," ..\u002Ffeature-worktree",[87,223,113],{"class":97},[137,225,227],{"id":226},"情境二建立新分支並同時建立工作目錄","情境二：建立新分支並同時建立工作目錄",[12,229,230],{},"如果你想建立一個新分支，並同時建立工作目錄：",[78,232,234],{"className":80,"code":233,"language":82,"meta":83,"style":83},"git worktree add \u003Cpath> -b \u003Cnew-branch-name>\n",[63,235,236],{"__ignoreMap":83},[87,237,238,240,242,244,246,248,250,252,255,257,260,263],{"class":89,"line":90},[87,239,94],{"class":93},[87,241,158],{"class":97},[87,243,161],{"class":97},[87,245,165],{"class":164},[87,247,168],{"class":97},[87,249,172],{"class":171},[87,251,175],{"class":164},[87,253,254],{"class":109}," -b",[87,256,165],{"class":164},[87,258,259],{"class":97},"new-branch-nam",[87,261,262],{"class":171},"e",[87,264,185],{"class":164},[41,266,267,271,277],{},[44,268,269,193],{},[63,270,192],{},[44,272,273,276],{},[63,274,275],{},"-b","：表示要建立新分支",[44,278,279,282],{},[63,280,281],{},"\u003Cnew-branch-name>","：要建立的新分支名稱",[78,284,286],{"className":80,"code":285,"language":82,"meta":83,"style":83},"# 範例：建立新的 feature-new 分支和工作目錄\ngit worktree add ..\u002Ffeature-new-worktree -b feature-new\n",[63,287,288,293],{"__ignoreMap":83},[87,289,290],{"class":89,"line":90},[87,291,292],{"class":209},"# 範例：建立新的 feature-new 分支和工作目錄\n",[87,294,295,297,299,301,304,306],{"class":89,"line":101},[87,296,94],{"class":93},[87,298,158],{"class":97},[87,300,161],{"class":97},[87,302,303],{"class":97}," ..\u002Ffeature-new-worktree",[87,305,254],{"class":109},[87,307,308],{"class":97}," feature-new\n",[310,311,312],"blockquote",{},[12,313,314,318,319,321,322,324],{},[315,316,317],"strong",{},"關鍵差異","：有 ",[63,320,275],{}," 是「建立新分支」，沒有 ",[63,323,275],{}," 是「使用現有分支」。",[137,326,327],{"id":327},"何謂工作目錄",[12,329,330],{},"看到這邊應該會對於工作目錄感到困惑，簡單來說，工作目錄就是我們平常在電腦上看到的專案資料夾。",[12,332,333],{},"假設你的專案結構長這樣：",[78,335,340],{"className":336,"code":338,"language":339,"meta":83},[337],"language-text","\u002FUsers\u002Fray\u002F\n└── my-project\u002F       ← 你的主專案（main 分支）\n","text",[63,341,338],{"__ignoreMap":83},[12,343,344,345,348],{},"當你執行 ",[63,346,347],{},"git worktree add ..\u002Fmy-project-feature feature"," 後，資料夾結構會變成：",[78,350,353],{"className":351,"code":352,"language":339,"meta":83},[337],"\u002FUsers\u002Fray\u002F\n├── my-project\u002F           ← 主專案（main 分支）\n└── my-project-feature\u002F   ← 新的工作目錄（feature 分支）\n",[63,354,352],{"__ignoreMap":83},[12,356,357,358,361,362,365],{},"這兩個資料夾",[315,359,360],{},"共享同一個 Git 歷史","，但可以",[315,363,364],{},"同時切換到不同分支","工作。你可以把它想像成：同一份專案開了兩個視窗，各自編輯不同版本，互不干擾。",[19,367,368],{"title":21,"type":22},[12,369,370],{},"更白話一點其實就是 Copy 一份專案出來，不過這份專案是跟原本的專案共用同一個 Git 倉庫。",[27,372,373],{"id":373},"實戰示範",[12,375,376,377,379],{},"接著我們就來實際示範如何使用 ",[63,378,65],{}," 來同時跑多個 AI Agent。",[12,381,382],{},"這邊就使用了剛剛建立的 TodoList 專案，並且針對每個功能建立一個工作目錄。",[78,384,386],{"className":80,"code":385,"language":82,"meta":83,"style":83},"# 建立新增待辦事項的工作目錄，並建立新分支 feature-add\ngit worktree add ..\u002Ftodo-add -b feature-add\n# 建立查詢待辦事項的工作目錄，並建立新分支 feature-query\ngit worktree add ..\u002Ftodo-query -b feature-query\n# 建立更新待辦事項的工作目錄，並建立新分支 feature-update\ngit worktree add ..\u002Ftodo-update -b feature-update\n# 建立刪除待辦事項的工作目錄，並建立新分支 feature-delete\ngit worktree add ..\u002Ftodo-delete -b feature-delete\n",[63,387,388,393,409,415,432,438,455,461],{"__ignoreMap":83},[87,389,390],{"class":89,"line":90},[87,391,392],{"class":209},"# 建立新增待辦事項的工作目錄，並建立新分支 feature-add\n",[87,394,395,397,399,401,404,406],{"class":89,"line":101},[87,396,94],{"class":93},[87,398,158],{"class":97},[87,400,161],{"class":97},[87,402,403],{"class":97}," ..\u002Ftodo-add",[87,405,254],{"class":109},[87,407,408],{"class":97}," feature-add\n",[87,410,412],{"class":89,"line":411},3,[87,413,414],{"class":209},"# 建立查詢待辦事項的工作目錄，並建立新分支 feature-query\n",[87,416,418,420,422,424,427,429],{"class":89,"line":417},4,[87,419,94],{"class":93},[87,421,158],{"class":97},[87,423,161],{"class":97},[87,425,426],{"class":97}," ..\u002Ftodo-query",[87,428,254],{"class":109},[87,430,431],{"class":97}," feature-query\n",[87,433,435],{"class":89,"line":434},5,[87,436,437],{"class":209},"# 建立更新待辦事項的工作目錄，並建立新分支 feature-update\n",[87,439,441,443,445,447,450,452],{"class":89,"line":440},6,[87,442,94],{"class":93},[87,444,158],{"class":97},[87,446,161],{"class":97},[87,448,449],{"class":97}," ..\u002Ftodo-update",[87,451,254],{"class":109},[87,453,454],{"class":97}," feature-update\n",[87,456,458],{"class":89,"line":457},7,[87,459,460],{"class":209},"# 建立刪除待辦事項的工作目錄，並建立新分支 feature-delete\n",[87,462,464,466,468,470,473,475],{"class":89,"line":463},8,[87,465,94],{"class":93},[87,467,158],{"class":97},[87,469,161],{"class":97},[87,471,472],{"class":97}," ..\u002Ftodo-delete",[87,474,254],{"class":109},[87,476,477],{"class":97}," feature-delete\n",[12,479,480,481],{},"接下來都輸入完畢後，我們就會在專案目錄的上層看到四個新的資料夾，分別對應到我們剛剛建立的工作目錄，以我的路徑來講是 ",[63,482,483],{},"\u002FUsers\u002Frayxu\u002FGitHub\u002Ftodolist-worktree\u002F",[78,485,488],{"className":486,"code":487,"language":339,"meta":83},[337],"\u002FUsers\u002Frayxu\u002FGitHub\u002F\n├── todolist-worktree\u002F        ← 主專案（main 分支）\n├── todo-add\u002F                 ← 新增待辦事項工作目錄（feature-add 分支）\n├── todo-query\u002F               ← 查詢待辦事項工作目錄（feature-query 分支）\n├── todo-update\u002F              ← 更新待辦事項工作目錄（feature-update 分支）\n└── todo-delete\u002F              ← 刪除待辦事項工作目錄（feature-delete 分支）\n",[63,489,487],{"__ignoreMap":83},[12,491,492],{},[15,493],{"alt":494,"src":495},"工作目錄","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121153351.png",[12,497,498],{},"然後接著你就可以打開四個終端機視窗，分別切換到四個工作目錄",[78,500,502],{"className":80,"code":501,"language":82,"meta":83,"style":83},"# 切換到新增待辦事項工作目錄\ncd ..\u002Ftodo-add\n# 切換到查詢待辦事項工作目錄\ncd ..\u002Ftodo-query\n# 切換到更新待辦事項工作目錄\ncd ..\u002Ftodo-update\n# 切換到刪除待辦事項工作目錄\ncd ..\u002Ftodo-delete\n",[63,503,504,509,517,522,529,534,541,546],{"__ignoreMap":83},[87,505,506],{"class":89,"line":90},[87,507,508],{"class":209},"# 切換到新增待辦事項工作目錄\n",[87,510,511,514],{"class":89,"line":101},[87,512,513],{"class":109},"cd",[87,515,516],{"class":97}," ..\u002Ftodo-add\n",[87,518,519],{"class":89,"line":411},[87,520,521],{"class":209},"# 切換到查詢待辦事項工作目錄\n",[87,523,524,526],{"class":89,"line":417},[87,525,513],{"class":109},[87,527,528],{"class":97}," ..\u002Ftodo-query\n",[87,530,531],{"class":89,"line":434},[87,532,533],{"class":209},"# 切換到更新待辦事項工作目錄\n",[87,535,536,538],{"class":89,"line":440},[87,537,513],{"class":109},[87,539,540],{"class":97}," ..\u002Ftodo-update\n",[87,542,543],{"class":89,"line":457},[87,544,545],{"class":209},"# 切換到刪除待辦事項工作目錄\n",[87,547,548,550],{"class":89,"line":463},[87,549,513],{"class":109},[87,551,552],{"class":97}," ..\u002Ftodo-delete\n",[12,554,555,556,559],{},"接著就可以在各自的終端機輸入 ",[63,557,558],{},"claude"," 指令來啟動 AI Agent，並且針對各自的功能進行開發。",[12,561,562],{},[15,563],{"alt":564,"src":565},"claude 啟動","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121153708.png",[12,567,568],{},"接著底下我簡單四個都同時叫他們做「幫我建立一個 xxx.js 的檔案」",[12,570,571],{},[15,572],{"alt":573,"src":574},"各自運作","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121153820.png",[12,576,577,578,581],{},"接下來你可以回到各自的工作目錄中查看結果，你應該會看到各自的檔案都已經被建立完成，唯獨原本的 ",[63,579,580],{},"todolist-worktree"," 主專案資料夾中是不會有這些檔案的，因為這些檔案都是在各自的工作目錄中被建立的。",[12,583,584],{},[15,585],{"alt":586,"src":587},"結果展示","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121154116.gif",[12,589,590,591,594],{},"那接下來我們該怎麼把這些功能合併回主專案呢？你要先針對這些檔案進行 commit，接著再回到主專案中使用 ",[63,592,593],{},"git merge"," 來合併這些分支。",[78,596,598],{"className":80,"code":597,"language":82,"meta":83,"style":83},"# 1. 在 worktree 中提交變更\ncd ..\u002Ftodo-add\ngit add .\ngit commit -m \"feat: 新增待辦事項功能\"\n\n# 2. 移除 worktree（釋放分支）\ncd ..\u002Ftodolist-worktree\ngit worktree remove ..\u002Ftodo-add\n\n# 3. 合併分支\ngit merge feature-add\n",[63,599,600,605,611,620,633,639,644,651,662,667,673],{"__ignoreMap":83},[87,601,602],{"class":89,"line":90},[87,603,604],{"class":209},"# 1. 在 worktree 中提交變更\n",[87,606,607,609],{"class":89,"line":101},[87,608,513],{"class":109},[87,610,516],{"class":97},[87,612,613,615,617],{"class":89,"line":411},[87,614,94],{"class":93},[87,616,161],{"class":97},[87,618,619],{"class":97}," .\n",[87,621,622,624,627,630],{"class":89,"line":417},[87,623,94],{"class":93},[87,625,626],{"class":97}," commit",[87,628,629],{"class":109}," -m",[87,631,632],{"class":97}," \"feat: 新增待辦事項功能\"\n",[87,634,635],{"class":89,"line":434},[87,636,638],{"emptyLinePlaceholder":637},true,"\n",[87,640,641],{"class":89,"line":440},[87,642,643],{"class":209},"# 2. 移除 worktree（釋放分支）\n",[87,645,646,648],{"class":89,"line":457},[87,647,513],{"class":109},[87,649,650],{"class":97}," ..\u002Ftodolist-worktree\n",[87,652,653,655,657,660],{"class":89,"line":463},[87,654,94],{"class":93},[87,656,158],{"class":97},[87,658,659],{"class":97}," remove",[87,661,516],{"class":97},[87,663,665],{"class":89,"line":664},9,[87,666,638],{"emptyLinePlaceholder":637},[87,668,670],{"class":89,"line":669},10,[87,671,672],{"class":209},"# 3. 合併分支\n",[87,674,676,678,681],{"class":89,"line":675},11,[87,677,94],{"class":93},[87,679,680],{"class":97}," merge",[87,682,408],{"class":97},[19,684,685],{"title":21,"type":22},[12,686,687,688,691],{},"如果出現「致命錯誤: 拒絕合併無關的歷史」，代表你需要在合併時改成 ",[63,689,690],{},"git merge feature-add --allow-unrelated-histories"," 參數。因為正常來講，你必須要在建立 worktree 之前（todolist-worktree），主專案應該要先有一個初始 commit。",[12,693,694],{},[15,695],{"alt":696,"src":697},"合併過程","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121155102.png",[12,699,700],{},"如果你打開 commit 線圖，你會發現就跟你發 PR 一樣，會多出一個分支，然後 Merge 回主分支。",[12,702,703],{},[15,704],{"alt":705,"src":706},"線圖展示","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fai\u002Fai-agent-git-worktree\u002F20260121155213.png",[12,708,709],{},"最後這邊也提供一下相關的 Git 指令給大家參考：",[711,712,713,726],"table",{},[714,715,716],"thead",{},[717,718,719,723],"tr",{},[720,721,722],"th",{},"指令",[720,724,725],{},"說明",[727,728,729,740,750,760,770,780,790,800,810],"tbody",{},[717,730,731,737],{},[732,733,734],"td",{},[63,735,736],{},"git init",[732,738,739],{},"初始化專案 Git",[717,741,742,747],{},[732,743,744],{},[63,745,746],{},"git switch -c \u003Cbranch>",[732,748,749],{},"建立並切換到新分支",[717,751,752,757],{},[732,753,754],{},[63,755,756],{},"git worktree add \u003Cpath> \u003Cexisting-branch>",[732,758,759],{},"使用現有分支建立工作目錄",[717,761,762,767],{},[732,763,764],{},[63,765,766],{},"git worktree add \u003Cpath> -b \u003Cnew-branch>",[732,768,769],{},"建立新分支並同時建立工作目錄",[717,771,772,777],{},[732,773,774],{},[63,775,776],{},"git worktree remove \u003Cpath>",[732,778,779],{},"移除 worktree（釋放分支）",[717,781,782,787],{},[732,783,784],{},[63,785,786],{},"git add .",[732,788,789],{},"將所有變更加入暫存區",[717,791,792,797],{},[732,793,794],{},[63,795,796],{},"git commit -m \"message\"",[732,798,799],{},"提交變更",[717,801,802,807],{},[732,803,804],{},[63,805,806],{},"git merge \u003Cbranch>",[732,808,809],{},"合併分支",[717,811,812,817],{},[732,813,814],{},[63,815,816],{},"git merge \u003Cbranch> --allow-unrelated-histories",[732,818,819],{},"合併無關歷史的分支（解決拒絕合併錯誤）",[27,821,822],{"id":822},"延伸閱讀",[12,824,825],{},"Worktree 跟 AI Agent 真的是絕配，如果你想把這個組合玩得更深，可以接著看：",[41,827,828,838],{},[44,829,830,837],{},[831,832,836]