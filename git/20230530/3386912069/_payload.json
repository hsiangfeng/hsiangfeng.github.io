59},10,[189,361,213],{"class":195},[189,363,364],{"class":199},"body",[189,366,207],{"class":195},[189,368,370,372,375,378,380],{"class":191,"line":369},11,[189,371,243],{"class":195},[189,373,374],{"class":199},"h1",[189,376,377],{"class":195},">這是一個單純的示範網頁\u003C\u002F",[189,379,374],{"class":199},[189,381,207],{"class":195},[189,383,385,387,389],{"class":191,"line":384},12,[189,386,352],{"class":195},[189,388,364],{"class":199},[189,390,207],{"class":195},[189,392,394,396,398],{"class":191,"line":393},13,[189,395,352],{"class":195},[189,397,185],{"class":199},[189,399,207],{"class":195},[12,401,402],{},"而 style.css 也很單純",[64,404,408],{"className":405,"code":406,"language":407,"meta":70,"style":70},"language-css shiki shiki-themes github-light github-light github-dark-high-contrast","body {\n  background-color: black;\n  color: white;\n}\n","css",[40,409,410,417,432,444],{"__ignoreMap":70},[189,411,412,414],{"class":191,"line":192},[189,413,364],{"class":199},[189,415,416],{"class":195}," {\n",[189,418,419,423,426,429],{"class":191,"line":210},[189,420,422],{"class":421},"stw71","  background-color",[189,424,425],{"class":195},": ",[189,427,428],{"class":421},"black",[189,430,431],{"class":195},";\n",[189,433,434,437,439,442],{"class":191,"line":230},[189,435,436],{"class":421},"  color",[189,438,425],{"class":195},[189,440,441],{"class":421},"white",[189,443,431],{"class":195},[189,445,446],{"class":191,"line":240},[189,447,448],{"class":195},"}\n",[175,450,452],{"id":451},"初始化-git","初始化 git",[12,454,455,456],{},"接下來這邊我會建立一個空的儲存庫叫做 ",[40,457,458],{},"example-gh-pages",[12,460,461],{},[15,462],{"alt":458,"src":463},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2009.59.39.png",[12,465,466],{},"然後我會在 example 資料夾下面初始化 git 並將它推送到 GitHub",[64,468,472],{"className":469,"code":470,"language":471,"meta":70,"style":70},"language-bash shiki shiki-themes github-light github-light github-dark-high-contrast","git init # 初始化 git\ngit add . # 將所有檔案加入 git 索引\ngit commit -m \"first commit\" # 加上 commit 訊息\ngit branch -M main # 將分支名稱改成 main\ngit remote add origin git@github.com:hsiangfeng\u002Fexample-gh-pages.git # 新增遠端儲存庫路徑\ngit push -u origin main # 將本地端的 main 分支推送到遠端儲存庫，並且設定為預設分支，下次就可以直接使用 git push\n","bash",[40,473,474,487,500,516,532,550],{"__ignoreMap":70},[189,475,476,480,483],{"class":191,"line":192},[189,477,479],{"class":478},"smYoP","git",[189,481,482],{"class":224}," init",[189,484,486],{"class":485},"sGBqm"," # 初始化 git\n",[189,488,489,491,494,497],{"class":191,"line":210},[189,490,479],{"class":478},[189,492,493],{"class":224}," add",[189,495,496],{"class":224}," .",[189,498,499],{"class":485}," # 將所有檔案加入 git 索引\n",[189,501,502,504,507,510,513],{"class":191,"line":230},[189,503,479],{"class":478},[189,505,506],{"class":224}," commit",[189,508,509],{"class":421}," -m",[189,511,512],{"class":224}," \"first commit\"",[189,514,515],{"class":485}," # 加上 commit 訊息\n",[189,517,518,520,523,526,529],{"class":191,"line":240},[189,519,479],{"class":478},[189,521,522],{"class":224}," branch",[189,524,525],{"class":421}," -M",[189,527,528],{"class":224}," main",[189,530,531],{"class":485}," # 將分支名稱改成 main\n",[189,533,534,536,539,541,544,547],{"class":191,"line":259},[189,535,479],{"class":478},[189,537,538],{"class":224}," remote",[189,540,493],{"class":224},[189,542,543],{"class":224}," origin",[189,545,546],{"class":224}," git@github.com:hsiangfeng\u002Fexample-gh-pages.git",[189,548,549],{"class":485}," # 新增遠端儲存庫路徑\n",[189,551,552,554,557,560,562,564],{"class":191,"line":284},[189,553,479],{"class":478},[189,555,556],{"class":224}," push",[189,558,559],{"class":421}," -u",[189,561,543],{"class":224},[189,563,528],{"class":224},[189,565,566],{"class":485}," # 將本地端的 main 分支推送到遠端儲存庫，並且設定為預設分支，下次就可以直接使用 git push\n",[74,568,569],{"title":76,"type":77},[12,570,571,572,575],{},"請注意 ",[40,573,574],{},"git remote add origin git@github.com:hsiangfeng\u002Fexample-gh-pages.git"," 會隨著你的帳號與儲存庫名稱而有所不同，請自行替換。",[12,577,578,579,582],{},"目前來講，只要你有做到 ",[40,580,581],{},"git push -u origin main"," 這一步之後，你的 GitHub 儲存庫就會長這樣",[12,584,585],{},[15,586],{"alt":587,"src":588},"GitHub","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2010.07.51.png",[175,590,592],{"id":591},"使用-gh-pages-套件","使用 gh-pages 套件",[12,594,595],{},"接下來呢？接下來我該怎麼做呢？如果你是單純的靜態網頁而非需要編譯的網頁，那麼你只需要在你的儲存庫下面建立一個 gh-pages 分支，然後將你的網頁推送到這個分支 GitHub 就會自動幫你部署了，但是這種做法我認為有一個問題點，變成你除了要將原始碼推到 main 分支之外，還要將編譯後的檔案推到 gh-pages 分支，身為一個人類來講，基本上是會有很高機會失誤的，那麼為了減少失誤的機會，我們可以使用 gh-pages 套件來幫助我們部署 gh-pages 網頁。",[12,597,598],{},"首先請你回到你桌面上的專案資料夾，然後輸入以下指令",[64,600,602],{"className":469,"code":601,"language":471,"meta":70,"style":70},"npm init -y # 初始化 npm\nnpm install gh-pages # 安裝 gh-pages 套件\n",[40,603,604,617],{"__ignoreMap":70},[189,605,606,609,611,614],{"class":191,"line":192},[189,607,608],{"class":478},"npm",[189,610,482],{"class":224},[189,612,613],{"class":421}," -y",[189,615,616],{"class":485}," # 初始化 npm\n",[189,618,619,621,624,627],{"class":191,"line":210},[189,620,608],{"class":478},[189,622,623],{"class":224}," install",[189,625,626],{"class":224}," gh-pages",[189,628,629],{"class":485}," # 安裝 gh-pages 套件\n",[12,631,632],{},"接著請你優先建立 .gitignore 檔案，並且加入以下內容",[64,634,637],{"className":635,"code":636,"language":69,"meta":70},[67],"node_modules\n",[40,638,636],{"__ignoreMap":70},[12,640,641],{},".gitignore 主要是用來忽略不需要加入 git 索引的檔案，例如 node_modules 資料夾，因為這個資料夾通常都會很大，而且裡面的檔案都是可以透過 npm install 來安裝，因此我們可以透過 .gitignore 來忽略它。",[12,643,644],{},"接下來我們要修改 package.json 檔案，將它修改成以下內容",[64,646,650],{"className":647,"code":648,"language":649,"meta":70,"style":70},"language-json shiki shiki-themes github-light github-light github-dark-high-contrast","{\n  \"name\": \"example\",\n  \"version\": \"1.0.0\",\n  \"description\": \"\",\n  \"main\": \"index.js\",\n  \"scripts\": {\n    \"test\": \"echo \\\"Error: no test specified\\\" && exit 1\",\n    \"deploy\": \"gh-pages -d src\" \u002F\u002F 增加這一行\n  },\n  \"repository\": {\n    \"type\": \"git\",\n    \"url\": \"git+https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages.git\"\n  },\n  \"keywords\": [],\n  \"author\": \"\",\n  \"license\": \"ISC\",\n  \"bugs\": {\n    \"url\": \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages\u002Fissues\"\n  },\n  \"homepage\": \"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages#readme\",\n  \"dependencies\": {\n    \"gh-pages\": \"^5.0.0\"\n  }\n}\n\n","json",[40,651,652,657,671,683,695,707,715,739,752,757,764,776,786,790,799,811,824,832,842,847,860,868,879,885],{"__ignoreMap":70},[189,653,654],{"class":191,"line":192},[189,655,656],{"class":195},"{\n",[189,658,659,663,665,668],{"class":191,"line":210},[189,660,662],{"class":661},"sWTrB","  \"name\"",[189,664,425],{"class":195},[189,666,667],{"class":224},"\"example\"",[189,669,670],{"class":195},",\n",[189,672,673,676,678,681],{"class":191,"line":230},[189,674,675],{"class":661},"  \"version\"",[189,677,425],{"class":195},[189,679,680],{"class":224},"\"1.0.0\"",[189,682,670],{"class":195},[189,684,685,688,690,693],{"class":191,"line":240},[189,686,687],{"class":661},"  \"description\"",[189,689,425],{"class":195},[189,691,692],{"class":224},"\"\"",[189,694,670],{"class":195},[189,696,697,700,702,705],{"class":191,"line":259},[189,698,699],{"class":661},"  \"main\"",[189,701,425],{"class":195},[189,703,704],{"class":224},"\"index.js\"",[189,706,670],{"class":195},[189,708,709,712],{"class":191,"line":284},[189,710,711],{"class":661},"  \"scripts\"",[189,713,714],{"class":195},": {\n",[189,716,717,720,722,725,729,732,734,737],{"class":191,"line":308},[189,718,719],{"class":661},"    \"test\"",[189,721,425],{"class":195},[189,723,724],{"class":224},"\"echo ",[189,726,728],{"class":727},"sbsOT","\\\"",[189,730,731],{"class":224},"Error: no test specified",[189,733,728],{"class":727},[189,735,736],{"class":224}," && exit 1\"",[189,738,670],{"class":195},[189,740,741,744,746,749],{"class":191,"line":323},[189,742,743],{"class":661},"    \"deploy\"",[189,745,425],{"class":195},[189,747,748],{"class":224},"\"gh-pages -d src\"",[189,750,751],{"class":485}," \u002F\u002F 增加這一行\n",[189,753,754],{"class":191,"line":349},[189,755,756],{"class":195},"  },\n",[189,758,759,762],{"class":191,"line":359},[189,760,761],{"class":661},"  \"repository\"",[189,763,714],{"class":195},[189,765,766,769,771,774],{"class":191,"line":369},[189,767,768],{"class":661},"    \"type\"",[189,770,425],{"class":195},[189,772,773],{"class":224},"\"git\"",[189,775,670],{"class":195},[189,777,778,781,783],{"class":191,"line":384},[189,779,780],{"class":661},"    \"url\"",[189,782,425],{"class":195},[189,784,785],{"class":224},"\"git+https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages.git\"\n",[189,787,788],{"class":191,"line":393},[189,789,756],{"class":195},[189,791,793,796],{"class":191,"line":792},14,[189,794,795],{"class":661},"  \"keywords\"",[189,797,798],{"class":195},": [],\n",[189,800,802,805,807,809],{"class":191,"line":801},15,[189,803,804],{"class":661},"  \"author\"",[189,806,425],{"class":195},[189,808,692],{"class":224},[189,810,670],{"class":195},[189,812,814,817,819,822],{"class":191,"line":813},16,[189,815,816],{"class":661},"  \"license\"",[189,818,425],{"class":195},[189,820,821],{"class":224},"\"ISC\"",[189,823,670],{"class":195},[189,825,827,830],{"class":191,"line":826},17,[189,828,829],{"class":661},"  \"bugs\"",[189,831,714],{"class":195},[189,833,835,837,839],{"class":191,"line":834},18,[189,836,780],{"class":661},[189,838,425],{"class":195},[189,840,841],{"class":224},"\"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages\u002Fissues\"\n",[189,843,845],{"class":191,"line":844},19,[189,846,756],{"class":195},[189,848,850,853,855,858],{"class":191,"line":849},20,[189,851,852],{"class":661},"  \"homepage\"",[189,854,425],{"class":195},[189,856,857],{"class":224},"\"https:\u002F\u002Fgithub.com\u002Fhsiangfeng\u002Fexample-gh-pages#readme\"",[189,859,670],{"class":195},[189,861,863,866],{"class":191,"line":862},21,[189,864,865],{"class":661},"  \"dependencies\"",[189,867,714],{"class":195},[189,869,871,874,876],{"class":191,"line":870},22,[189,872,873],{"class":661},"    \"gh-pages\"",[189,875,425],{"class":195},[189,877,878],{"class":224},"\"^5.0.0\"\n",[189,880,882],{"class":191,"line":881},23,[189,883,884],{"class":195},"  }\n",[189,886,888],{"class":191,"line":887},24,[189,889,448],{"class":195},[12,891,892],{},"接著把 index.html 與 style.css 檔案移動到 src 資料夾下面",[12,894,895],{},[15,896],{"alt":897,"src":898},"src","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2010.13.50.png",[12,900,901],{},"接著請你回到終端機，然後輸入以下指令",[64,903,905],{"className":469,"code":904,"language":471,"meta":70,"style":70},"npm run deploy\n",[40,906,907],{"__ignoreMap":70},[189,908,909,911,914],{"class":191,"line":192},[189,910,608],{"class":478},[189,912,913],{"class":224}," run",[189,915,916],{"class":224}," deploy\n",[12,918,919,920,923],{},"接下來你只要看到終端機畫面出現 ",[40,921,922],{},"Published"," 就代表部署成功了",[12,925,926],{},[15,927],{"alt":922,"src":928},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2010.14.47.png",[12,930,931],{},"接著你就可以到你的 GitHub 儲存庫看一下，你會發現多了一個 gh-pages 分支",[12,933,934],{},[15,935],{"alt":17,"src":936},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FGit\u002Fgh-paegs\u002F%E6%88%AA%E5%9C%96%202023-05-30%2010.16.03.png",[12,938,939,940,942,943],{},"而且你也可以透過 ",[40,941,42],{}," 來觀看你的網頁，以這個範例來講就是 ",[40,944,945],{},"https:\u002F\u002Fhsiangfeng.github.io\u002Fexample-gh-pages",[74,947,948],{"title":76,"type":77},[12,949,950],{},"GitHub 會自動偵測 gh-pages 分支，只要你有這個分支，那麼它就會自動部署，而部署過程你可以在儲存庫的 Actions 中看到，通常名稱叫做「pages build and deployment」，等到它變成綠色的勾勾就代表部署成功了。",[12,952,953,954,957,958,961,962,964,965,967],{},"接下來我們回頭聊一下 gh-pages 套件是怎麼做到的，首先我們剛剛在 package.json 中新增了一行指令 ",[40,955,956],{},"gh-pages -d src","，這行指令的意思呼叫 gh-pages 套件，並且將 src 資料夾下面的檔案推送到 gh-pages 分支，",[40,959,960],{},"-d"," 呢？",[40,963,960],{}," 的意思是 directory（目錄），也就是說我們可以透過 ",[40,966,960],{}," 來指定要推送的目錄，如果沒有指定的話，預設會是根目錄，但我們並不希望把所有檔案都推送到 gh-pages 分支，因此我們就指定 src 資料夾。",[12,969,970],{},"接著它是如何辨別要推到哪一個儲存庫呢？預設的狀況下，它會去讀取你的專案資料夾下面的 .git 資料夾，然後去讀取裡面的 remote 設定，也就是說它會去讀取你的遠端儲存庫路徑，然後推送到 gh-pages 分支，這也是為什麼我們在 package.json 中沒有指定遠端儲存庫路徑，但是它還是可以正確推送的原因。",[74,972,973],{"title":76,"type":77},[12,974,975,976,981],{},"如果你是使用 CRA、Vite 等開發工具的話，你必須閱讀一下 gh-pages 文件，因為它有相對應的設定，否則你的網頁可能會無法正常運作，這一點要稍微注意一下，這個就建議你直接閱讀",[128,977,980],{"href":978,"rel":979},"https:\u002F\u002Fgithub.com\u002Ftschaub\u002Fgh-pages#github-pages-project-sites",[132],"官方文件","比較好。",[20,983,984],{"id":984},"額外補充",[12,986,987,988,991,992,995],{},"如果你是使用 Vite 這類編譯工具，你可以將 ",[40,989,990],{},"\"deploy\": \"gh-pages -d dist\""," 改成 ",[40,993,994],{},"\"deploy\": \"vite build && gh-pages -d dist\"","，這樣子就可以在部署之前先編譯後部署囉~",[997,998,999],"style",{},"html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--shiki-default:#24292E;--shiki-dark:#F0F3F6}html pre.shiki code .syv7_, html code.shiki .syv7_{--shiki-light:#22863A;--shiki-default:#22863A;--shiki-dark:#72F088}html pre.shiki code .sK3KL, html code.shiki .sK3KL{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#91CBFF}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki