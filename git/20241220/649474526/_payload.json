[{"data":1,"prerenderedAt":682},["ShallowReactive",2],{"header-locale:\u002Fgit\u002F20241220\u002F649474526\u002F":3,"page:\u002Fgit\u002F20241220\u002F649474526\u002F":4,"alt:\u002Fgit\u002F20241220\u002F649474526\u002F":3,"prev-next:\u002Fgit\u002F20241220\u002F649474526\u002F":658,"related:\u002Fgit\u002F20241220\u002F649474526\u002F":667},"\u002Fen\u002Fgit\u002F2024\u002F12\u002F20\u002Fnew-git-commands-you-should-try\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":641,"date":642,"description":24,"extension":643,"lang":644,"meta":645,"navigation":646,"path":647,"readingMinutes":648,"seo":649,"standalone":650,"stem":651,"tags":652,"tldr":655,"updated":642,"url":656,"__hash__":657},"content\u002FGit\u002F新-Git-指令之你該試試看了.md","新 Git 指令之你該試試看了","649474526",{"type":9,"value":10,"toc":628},"minimark",[11,18,22,25,28,54,59,70,104,113,124,142,154,157,287,290,298,324,327,464,470,474,495,526,542,548,559,565,568,571,613,616,619],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fgit\u002Fgit-new-commit\u002Fgit_new.png",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"這一篇來記錄與分享 Git 後來出的一些新指令，我個人覺得滿實用的。",[19,26,27],{"id":27},"新指令",[12,29,30,31,35,36,35,39,35,42,45,46,53],{},"基本上我們實戰上常用的 Git 指令，不外乎就是 ",[32,33,34],"code",{},"git add","、",[32,37,38],{},"git commit",[32,40,41],{},"git push",[32,43,44],{},"git pull"," 等等（更詳細",[47,48,52],"a",{"href":49,"rel":50},"https:\u002F\u002Fisraynotarray.com\u002Fgit\u002F20190615\u002F1148594701\u002F",[51],"nofollow","可見此文","），但是 Git 後來也出了一些新指令，這邊我就來分享一下。",[55,56,58],"h3",{"id":57},"git-switch","git switch",[12,60,61,62,65,66,69],{},"原本我們在切換分支時，都會使用 ",[32,63,64],{},"git checkout"," 這個指令，當時我在初學 Git 的時候，我對於 ",[32,67,68],{},"checkout"," 這個單字感到很混淆，因為直面翻譯過來是「結帳」，但是在 Git 中的意思是「切換」，而且這個指令不單只有切換分支，還有...",[71,72,73,80,86,92,98],"ul",{},[74,75,76,79],"li",{},[32,77,78],{},"git checkout \u003Cbranch>",": 切換到指定分支",[74,81,82,85],{},[32,83,84],{},"git checkout -b \u003Cbranch>",": 創建並切換到新分支",[74,87,88,91],{},[32,89,90],{},"git checkout -",": 切換到上一個分支",[74,93,94,97],{},[32,95,96],{},"git checkout -- \u003Cfile>",": 棄用工作目錄中的修改",[74,99,100,103],{},[32,101,102],{},"git checkout \u003Ccommit>",": 檢視指定 commit 的內容",[12,105,106,107,109,110,112],{},"可以看到 ",[32,108,64],{}," 的功能非常強大可以做的事情非常多，但是這卻也造成了初學者的困擾，因為這個指令太多功能了，所以這邊要來介紹一個新指令 ",[32,111,58],{},"。",[12,114,115,117,118,120,121,123],{},[32,116,58],{}," 指令是在 Git 2.23 版本後才出現的，而這個指令是專門「切換分支」的指令，所以不像 ",[32,119,64],{}," 這麼多功能，只要是切換分支的事情，就可以使用 ",[32,122,58],{}," 這個指令，而且他的功能也比較單純，所以初學者使用起來會比較容易。",[71,125,126,131,136],{},[74,127,128,79],{},[32,129,130],{},"git switch \u003Cbranch>",[74,132,133,85],{},[32,134,135],{},"git switch -c \u003Cbranch>",[74,137,138,141],{},[32,139,140],{},"git switch -",": 切換到上一個分支，例如：develop 切換到 master",[12,143,144,145,147,148,150,151,153],{},"是的，就是如此的簡單單純，",[32,146,58],{}," 就是專門用於切換分支、創建並切換到新分支、切換到上一個分支上，相較於 ",[32,149,64],{}," 這個指令，",[32,152,58],{}," 就是專注在「切換分支」上。",[12,155,156],{},"這邊我也出一個表格來做一個比較：",[158,159,160,178],"table",{},[161,162,163],"thead",{},[164,165,166,170,174],"tr",{},[167,168,169],"th",{},"功能",[167,171,172],{},[32,173,58],{},[167,175,176],{},[32,177,64],{},[179,180,181,198,215,230,248,261,274],"tbody",{},[164,182,183,190,194],{},[184,185,186],"td",{},[187,188,189],"strong",{},"切換分支",[184,191,192],{},[32,193,130],{},[184,195,196],{},[32,197,78],{},[164,199,200,205,210],{},[184,201,202],{},[187,203,204],{},"建立並切換新分支",[184,206,207],{},[32,208,209],{},"git switch -c \u003Cnew-branch>",[184,211,212],{},[32,213,214],{},"git checkout -b \u003Cnew-branch>",[164,216,217,222,226],{},[184,218,219],{},[187,220,221],{},"切換到上一個分支",[184,223,224],{},[32,225,140],{},[184,227,228],{},[32,229,90],{},[164,231,232,237,243],{},[184,233,234],{},[187,235,236],{},"恢復檔案",[184,238,239,240],{},"不支援，需使用 ",[32,241,242],{},"git restore",[184,244,245],{},[32,246,247],{},"git checkout \u003Cfile>",[164,249,250,255,258],{},[184,251,252],{},[187,253,254],{},"語意清晰",[184,256,257],{},"更專注於「分支操作」",[184,259,260],{},"功能多樣，可能造成混淆",[164,262,263,268,271],{},[184,264,265],{},[187,266,267],{},"Git 版本要求",[184,269,270],{},"Git 2.23 以上",[184,272,273],{},"Git 所有版本皆支援",[164,275,276,281,284],{},[184,277,278],{},[187,279,280],{},"專用性",[184,282,283],{},"專注於分支相關操作",[184,285,286],{},"同時負責分支切換與檔案恢復",[55,288,242],{"id":289},"git-restore",[12,291,292,294,295,297],{},[32,293,242],{}," 其實也是為了切割 ",[32,296,64],{}," 的功能而出現的，也是讓指令語意更清晰，主要的用途就是「恢復檔案」。",[71,299,300,306,312,318],{},[74,301,302,305],{},[32,303,304],{},"git restore \u003Cfile>",": 恢復檔案",[74,307,308,311],{},[32,309,310],{},"git restore --staged \u003Cfile>",": 取消暫存檔案",[74,313,314,317],{},[32,315,316],{},"git restore --source=HEAD --staged --worktree \u003Cfile>",": 將暫存區與工作目錄的檔案恢復到原本的狀態",[74,319,320,323],{},[32,321,322],{},"git restore .",": 恢復所有檔案",[12,325,326],{},"這邊也提供一個表格來做一個比較：",[158,328,329,343],{},[161,330,331],{},[164,332,333,335,339],{},[167,334,169],{},[167,336,337],{},[32,338,64],{},[167,340,341],{},[32,342,242],{},[179,344,345,360,376,393,408,424,439,452],{},[164,346,347,352,356],{},[184,348,349],{},[187,350,351],{},"恢復工作目錄中的檔案",[184,353,354],{},[32,355,247],{},[184,357,358],{},[32,359,304],{},[164,361,362,367,372],{},[184,363,364],{},[187,365,366],{},"撤銷已暫存的檔案變更",[184,368,369],{},[32,370,371],{},"git reset \u003Cfile>",[184,373,374],{},[32,375,310],{},[164,377,378,383,388],{},[184,379,380],{},[187,381,382],{},"恢復到指定提交版本",[184,384,385],{},[32,386,387],{},"git checkout \u003Ccommit> -- \u003Cfile>",[184,389,390],{},[32,391,392],{},"git restore --source=\u003Ccommit> \u003Cfile>",[164,394,395,400,404],{},[184,396,397],{},[187,398,399],{},"恢復工作目錄 + 暫存區",[184,401,402],{},[32,403,387],{},[184,405,406],{},[32,407,316],{},[164,409,410,415,419],{},[184,411,412],{},[187,413,414],{},"分支切換",[184,416,417],{},[32,418,78],{},[184,420,421,422],{},"不支援，需用 ",[32,423,58],{},[164,425,426,430,434],{},[184,427,428],{},[187,429,204],{},[184,431,432],{},[32,433,214],{},[184,435,421,436],{},[32,437,438],{},"git switch -c",[164,440,441,446,449],{},[184,442,443],{},[187,444,445],{},"適用場景",[184,447,448],{},"分支切換、檔案恢復",[184,450,451],{},"專注於檔案恢復",[164,453,454,459,462],{},[184,455,456],{},[187,457,458],{},"適用 Git 版本",[184,460,461],{},"所有 Git 版本",[184,463,270],{},[12,465,466,467,469],{},"透過兩者比較其實可以看到 ",[32,468,64],{}," 的指令相對比較容易讓人混淆。",[55,471,473],{"id":472},"git-maintenance","git maintenance",[12,475,476,477,35,480,483,484,35,487,490,491,494],{},"隨著我們專案越來越肥大，我們肯定會在專案內使用 ",[32,478,479],{},"git status",[32,481,482],{},"git log"," 等這類指令，而這些指令將會導致 Git 的讀取效能下降，所以早期要解決這問題時，必須去手動輸入 ",[32,485,486],{},"git gc",[32,488,489],{},"git repack"," 等指令來處理，但是後來在 Git 2.30 版本後，我們可以直接透過輸入 ",[32,492,493],{},"git maintenance start"," 來自動化這些工作。",[71,496,497,503,508,514,520],{},[74,498,499,502],{},[32,500,501],{},"git maintenance run",": 開始執行 Git 的維護工作",[74,504,505,507],{},[32,506,493],{},": 後台背景執行 Git 的維護工作",[74,509,510,513],{},[32,511,512],{},"git maintenance stop",": 停止 Git 的維護工作",[74,515,516,519],{},[32,517,518],{},"git maintenance register",": 註冊 Git 的維護工作",[74,521,522,525],{},[32,523,524],{},"git maintenance unregister",": 取消註冊 Git 的維護工作",[12,527,528,529,531,532,534,535,537,538,541],{},"這時候可能會有人好奇 ",[32,530,493],{}," 跟  ",[32,533,518],{}," 差異，簡單來講就是一個是將當前的 Git 儲存庫註冊為維護工作，但是不會立即執行，而 ",[32,536,493],{}," 則是立即執行，而這個 ",[32,539,540],{},"start"," 是針對有註冊過的 Git 儲存庫為主。",[12,543,544,545,547],{},"所以 ",[32,546,473],{}," 的正確使用流程是：",[549,550,551,555],"ol",{},[74,552,553,519],{},[32,554,518],{},[74,556,557,502],{},[32,558,493],{},[12,560,561,562,564],{},"就這樣，如果你想要立即執行的話，只需要使用 ",[32,563,501],{}," 就可以了。",[55,566,567],{"id":567},"其他指令",[12,569,570],{},"以上算是我個人有使用並且正在使用的指令，當然不只有這些，還有一些其他指令：",[71,572,573,578,583,588,593,598,603,608],{},[74,574,575],{},[32,576,577],{},"git sparse-checkout",[74,579,580],{},[32,581,582],{},"git log --remerge-diff",[74,584,585],{},[32,586,587],{},"git blame --ignore-rev",[74,589,590],{},[32,591,592],{},"git range-diff",[74,594,595],{},[32,596,597],{},"git worktree",[74,599,600],{},[32,601,602],{},"git rebase --update-refs",[74,604,605],{},[32,606,607],{},"git bugreport",[74,609,610],{},[32,611,612],{},"git for-each-repo",[12,614,615],{},"這幾個指令是相對比較新的指令，但是我個人沒有使用過，所以這邊就不多做介紹，畢竟還是以實務面的 80\u002F20 原則為主。",[19,617,618],{"id":618},"參考文件",[71,620,621],{},[74,622,623],{},[47,624,627],{"href":625,"rel":626},"https:\u002F\u002Fappwrite.io\u002Fblog\u002Fpost\u002F10-git-commands-you-should-start-using?ref=dailydev",[51],"10 new Git commands you should start using today",{"title":629,"searchDepth":630,"depth":630,"links":631},"",2,[632,633,640],{"id":21,"depth":630,"text":21},{"id":27,"depth":630,"text":27,"children":634},[635,637,638,639],{"id":57,"depth":636,"text":58},3,{"id":289,"depth":636,"text":242},{"id":472,"depth":636,"text":473},{"id":567,"depth":636,"text":567},{"id":618,"depth":630,"text":618},"Git","2024-12-20 23:30:28","md","zh-Hant",{},true,"\u002Fgit\u002Fgit","3",{"title":6,"description":24},false,"Git\u002F新-Git-指令之你該試試看了",[641,27,653,654],"Git 指令","Git 新指令",null,"\u002Fgit\u002F20241220\u002F649474526\u002F","-zUVACTG8Rb70Km52UTwQ09grrWjxbF59Jok9hCr4Qg",{"newer":659,"older":663},{"url":660,"title":661,"date":662},"\u002Flearnexp\u002F20241221\u002F1324056530\u002F","發生車禍了怎麼辦？ - 承認與求助 - 3","2024-12-21 14:18:53",{"url":664,"title":665,"date":666},"\u002Fdocker\u002F20241219\u002F2070727594\u002F","如何將 Vite+Vue 封裝到 Docker 並運行？","2024-12-19 16:36:18",[668,673,678],{"url":669,"title":670,"date":671,"readingMinutes":672},"\u002Fgit\u002F20260226\u002F799954596\u002F","取代 git push --force 更好的方式，git push --force-with-lease","2026-02-26 09:39:40","4",{"url":674,"title":675,"date":676,"readingMinutes":677},"\u002Fgit\u002F20260122\u002F21277993\u002F","Git init 出現 master 分支提示？教你設定預設分支為 main","2026-01-22 16:20:40","2",{"url":679,"title":680,"date":681,"readingMinutes":672},"\u002Fgit\u002F20260121\u002F2025687513\u002F","Git Worktree 是什麼？一個專案同時跑多個 AI Agent 的秘訣","2026-01-21 16:04:27",1784020384803]