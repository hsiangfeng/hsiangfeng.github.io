[{"data":1,"prerenderedAt":522},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20230208\u002F3652684018\u002F":3,"page:\u002Fgsap\u002F20230208\u002F3652684018\u002F":4,"alt:\u002Fgsap\u002F20230208\u002F3652684018\u002F":3,"prev-next:\u002Fgsap\u002F20230208\u002F3652684018\u002F":500,"related:\u002Fgsap\u002F20230208\u002F3652684018\u002F":509},"\u002Fen\u002Fgsap\u002F2023\u002F02\u002F08\u002Fgsap3-fx-17-scrolltrigger\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":480,"date":481,"description":482,"extension":483,"lang":484,"meta":485,"navigation":107,"path":486,"readingMinutes":487,"seo":488,"standalone":489,"stem":490,"tags":491,"tldr":497,"updated":481,"url":498,"__hash__":499},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F17-前端好好玩用-GSAP-做一個特效-ScrollTrigger.md","(17)前端好好玩用 GSAP 做一個特效 - ScrollTrigger","3652684018",{"type":9,"value":10,"toc":473},"minimark",[11,15,19,23,26,29,33,44,55,58,62,65,77,189,192,241,244,248,267,340,360,367,461,466,469],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面快速認識了如何註冊套件後，接下來將會針對 ScrollTrigger 套件是做個介紹，而 ScrollTrigger 套件可以說是非常的實用，因此才特別拉一篇來介紹它。",[12,20,22],{"id":21},"scrolltrigger-是什麼","ScrollTrigger 是什麼？",[16,24,25],{},"ScrollTrigger 是由 GSAP 官方所推出的套件之一，其中主要用途是用於滾動動畫。",[16,27,28],{},"基本上許多你所看到的滾動效果網站，滿多都是使用到了 ScrollTrigger 套件，那麼廢話就不多說，這邊就準備開始吧！",[12,30,32],{"id":31},"scrolltrigger-基本環境","ScrollTrigger 基本環境",[16,34,35,36,43],{},"基本上前一章節已經有說過 ScrollTrigger 的環境有哪兩種安裝方式了，而這邊將為採用 CDN 方式來示範，因此我就直接提供這一份 ",[37,38,42],"a",{"href":39,"rel":40},"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FJjZZOdR",[41],"nofollow","CodePen"," 方便到時候使用",[45,46,54],"iframe",{"height":47,"style":48,"scrolling":49,"title":50,"src":51,"frameBorder":49,"loading":52,"allowTransparency":53,"allowFullScreen":53},300,"width: 100%;","no","GSAP  - 42","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FJjZZOdR?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FJjZZOdR\">\n  GSAP  - 42\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,56,57],{},"那麼這一份環境內我有先準備好基本的 HTML 方便讓你練習用。",[12,59,61],{"id":60},"scrolltrigger-基本使用","ScrollTrigger 基本使用",[16,63,64],{},"首先我們先來看看 ScrollTrigger 的基本使用方式，這邊我們先來看看如何使用 ScrollTrigger 套件來做一個簡單的滾動動畫。",[16,66,67,68,72,73,76],{},"ScrollTrigger 的使用方式非常簡單，只需要在你的 ",[69,70,71],"code",{},"gsap.to"," 裡面補個屬性 ",[69,74,75],{},"scrollTrigger"," 就可以了，而裡面的參數則是用來設定觸發的條件。",[78,79,84],"pre",{"className":80,"code":81,"language":82,"meta":83,"style":83},"language-js shiki shiki-themes github-dark-high-contrast","gsap.registerPlugin(ScrollTrigger);\n\ngsap.to(\"#target\", {\n  scrollTrigger: {\n    trigger: \"#target\",\n    start: \"top\",\n    end: \"bottom\",\n    scrub: true,\n  },\n});\n","js","",[69,85,86,102,109,127,133,144,155,166,177,183],{"__ignoreMap":83},[87,88,91,95,99],"span",{"class":89,"line":90},"line",1,[87,92,94],{"class":93},"sMAXC","gsap.",[87,96,98],{"class":97},"sj_SG","registerPlugin",[87,100,101],{"class":93},"(ScrollTrigger);\n",[87,103,105],{"class":89,"line":104},2,[87,106,108],{"emptyLinePlaceholder":107},true,"\n",[87,110,112,114,117,120,124],{"class":89,"line":111},3,[87,113,94],{"class":93},[87,115,116],{"class":97},"to",[87,118,119],{"class":93},"(",[87,121,123],{"class":122},"sTRMh","\"#target\"",[87,125,126],{"class":93},", {\n",[87,128,130],{"class":89,"line":129},4,[87,131,132],{"class":93},"  scrollTrigger: {\n",[87,134,136,139,141],{"class":89,"line":135},5,[87,137,138],{"class":93},"    trigger: ",[87,140,123],{"class":122},[87,142,143],{"class":93},",\n",[87,145,147,150,153],{"class":89,"line":146},6,[87,148,149],{"class":93},"    start: ",[87,151,152],{"class":122},"\"top\"",[87,154,143],{"class":93},[87,156,158,161,164],{"class":89,"line":157},7,[87,159,160],{"class":93},"    end: ",[87,162,163],{"class":122},"\"bottom\"",[87,165,143],{"class":93},[87,167,169,172,175],{"class":89,"line":168},8,[87,170,171],{"class":93},"    scrub: ",[87,173,53],{"class":174},"sCcAr",[87,176,143],{"class":93},[87,178,180],{"class":89,"line":179},9,[87,181,182],{"class":93},"  },\n",[87,184,186],{"class":89,"line":185},10,[87,187,188],{"class":93},"});\n",[16,190,191],{},"那麼裡面的參數各自代表什麼意思呢？讓我們來認識一下：",[193,194,195,202,214,225],"ul",{},[196,197,198,201],"li",{},[69,199,200],{},"trigger","：觸發的元素，也就是當滾動到這個元素時，就會觸發動畫。",[196,203,204,207,208,210,211,213],{},[69,205,206],{},"start","：觸發的開始位置，也就是當滾動到 ",[69,209,200],{}," 元素的 ",[69,212,206],{}," 時，就會觸發動畫。",[196,215,216,219,220,210,222,224],{},[69,217,218],{},"end","：觸發的結束位置，也就是當滾動到 ",[69,221,200],{},[69,223,218],{}," 時，就會結束動畫。",[196,226,227,230,231,233,234,237,238,240],{},[69,228,229],{},"scrub","：是否要啟用滾動動畫，如果設定為 ",[69,232,53],{},"，則會在滾動時，動畫會跟著滾動，如果設定為 ",[69,235,236],{},"false","，則會在滾動到 ",[69,239,218],{}," 時，才會觸發動畫。",[16,242,243],{},"那麼就這樣子而已嗎？其實還有更多的參數可以設定，後面我們再來慢慢介紹，這邊就先認識這幾個就好。",[12,245,247],{"id":246},"scrolltrigger-基本範例","ScrollTrigger 基本範例",[16,249,250,251,254,255,258,259,262,263,266],{},"那麼這邊就來簡單示範一個範例，首先我們可以試著製作一個簡單的滾動動畫，當畫面滾動到 ",[69,252,253],{},"#box2"," 的區塊時，",[69,256,257],{},"#text2"," 就會從 ",[69,260,261],{},"opacity: 0"," 變成 ",[69,264,265],{},"opacity: 1","，那麼該怎麼寫呢？很簡單，只需要這樣寫即可：",[78,268,270],{"className":80,"code":269,"language":82,"meta":83,"style":83},"gsap.to(\"#text2\", {\n  scrollTrigger: {\n    trigger: \"#box2\",\n    start: \"top\",\n    end: \"bottom\",\n    scrub: true,\n  },\n  opacity: 1,\n});\n",[69,271,272,285,289,298,306,314,322,326,336],{"__ignoreMap":83},[87,273,274,276,278,280,283],{"class":89,"line":90},[87,275,94],{"class":93},[87,277,116],{"class":97},[87,279,119],{"class":93},[87,281,282],{"class":122},"\"#text2\"",[87,284,126],{"class":93},[87,286,287],{"class":89,"line":104},[87,288,132],{"class":93},[87,290,291,293,296],{"class":89,"line":111},[87,292,138],{"class":93},[87,294,295],{"class":122},"\"#box2\"",[87,297,143],{"