[{"data":1,"prerenderedAt":396},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20221127\u002F1252086867\u002F":3,"page:\u002Fgsap\u002F20221127\u002F1252086867\u002F":4,"alt:\u002Fgsap\u002F20221127\u002F1252086867\u002F":3,"prev-next:\u002Fgsap\u002F20221127\u002F1252086867\u002F":373,"related:\u002Fgsap\u002F20221127\u002F1252086867\u002F":382},"\u002Fen\u002Fgsap\u002F2022\u002F11\u002F27\u002Fgsap3-fx-05-animation-properties\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":354,"date":355,"description":18,"extension":356,"lang":357,"meta":358,"navigation":359,"path":360,"readingMinutes":220,"seo":361,"standalone":362,"stem":363,"tags":364,"tldr":370,"updated":355,"url":371,"__hash__":372},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F5-前端好好玩用-GSAP-做一個特效-動畫屬性.md","(5)前端好好玩用 GSAP 做一個特效 - 動畫屬性","1252086867",{"type":9,"value":10,"toc":349},"minimark",[11,15,19,22,25,35,38,84,101,110,137,148,154,157,188,193,196,227,232,235,242,273,278,289,300,331,336,342,345],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接著我們要來認識一下關於 GSAP 可以使用的動畫屬性。",[12,20,21],{"id":21},"動畫屬性",[16,23,24],{},"GSAP 提供了非常多的動畫屬性，而這些動畫屬性沒有一個非常明確的表，因為大部分都是基於 CSS 屬性為主，因此 GSAP 的動畫屬性分別兩大類：",[26,27,28,32],"ul",{},[29,30,31],"li",{},"CSS 屬性",[29,33,34],{},"自訂屬性",[16,36,37],{},"以前面的範例來講",[39,40,45],"pre",{"className":41,"code":42,"language":43,"meta":44,"style":44},"language-js shiki shiki-themes github-dark-high-contrast","gsap.to('.box', { x: 100, duration: 3 })\n","js","",[46,47,48],"code",{"__ignoreMap":44},[49,50,53,57,61,64,68,71,75,78,81],"span",{"class":51,"line":52},"line",1,[49,54,56],{"class":55},"sMAXC","gsap.",[49,58,60],{"class":59},"sj_SG","to",[49,62,63],{"class":55},"(",[49,65,67],{"class":66},"sTRMh","'.box'",[49,69,70],{"class":55},", { x: ",[49,72,74],{"class":73},"sCcAr","100",[49,76,77],{"class":55},", duration: ",[49,79,80],{"class":73},"3",[49,82,83],{"class":55}," })\n",[16,85,86,87,90,91,93,94,96,97,100],{},"其實就是使用了 ",[46,88,89],{},"x"," 這個 CSS 屬性，而這個 ",[46,92,89],{}," 就是 GSAP 的動畫屬性，而 ",[46,95,89],{}," 這個屬性就是 CSS 的 ",[46,98,99],{},"transform: translateX(100px)"," 的縮寫。",[16,102,103,104,106,107,109],{},"當然你也可以乾脆不使用 ",[46,105,89],{}," 這個屬性，而是使用 ",[46,108,99],{}," 這個屬性，這樣寫起來就會長這樣：",[39,111,113],{"className":41,"code":112,"language":43,"meta":44,"style":44},"gsap.to('.box', { transform: 'translateX(100px)', duration: 3 })\n",[46,114,115],{"__ignoreMap":44},[49,116,117,119,121,123,125,128,131,133,135],{"class":51,"line":52},[49,118,56],{"class":55},[49,120,60],{"class":59},[49,122,63],{"class":55},[49,124,67],{"class":66},[49,126,127],{"class":55},", { transform: ",[49,129,130],{"class":66},"'translateX(100px)'",[49,132,77],{"class":55},[49,134,80],{"class":73},[49,136,83],{"class":55},[138,139,147],"iframe",{"height":140,"style":141,"scrolling":142,"title":143,"src":144,"frameBorder":142,"loading":145,"allowTransparency":146,"allowFullScreen":146},300,"width: 100%;","no","GSAP 基礎語法 - 7","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FabKmVMx?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FabKmVMx\">\n  GSAP 基礎語法 - 7\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,149,150,151,153],{},"說真的這樣子寫起來會很辛苦，因此實際上來講，我們會使用 ",[46,152,89],{}," 這個屬性，因為這樣子寫起來會比較簡單。",[16,155,156],{},"那麼剛剛有提到 GSAP 支援 CSS 屬性，那麼這些 CSS 屬性都有哪些呢？只要你是一名前端工程師，基本上你所熟悉的 CSS 屬性都是可以被 GSAP 使用的，例如邊移動邊旋轉 360 度的動畫：",[39,158,160],{"className":41,"code":159,"language":43,"meta":44,"style":44},"gsap.to('.box', { x: 100, rotate: 360, duration: 3 })\n",[46,161,162],{"__ignoreMap":44},[49,163,164,166,168,170,172,174,176,179,182,184,186],{"class":51,"line":52},[49,165,56],{"class":55},[49,167,60],{"class":59},[49,169,63],{"class":55},[49,171,67],{"class":66},[49,173,70],{"class":55},[49,175,74],{"class":73},[49,177,178],{"class":55},", rotate: ",[49,180,181],{"class":73},"360",[49,183,77],{"class":55},[49,185,80],{"class":73},[49,187,83],{"class":55},[138,189,192],{"height":140,"style":141,"scrolling":142,"title":190,"src":191,"frameBorder":142,"loading":145,"allowTransparency":146,"allowFullScreen":146},"GSAP  - 8","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FpoKEpbO?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FpoKEpbO\">\n  GSAP  - 8\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,194,195],{},"又或者是邊移動邊縮放的動畫：",[39,197,199],{"className":41,"code":198,"language":43,"meta":44,"style":44},"gsap.to('.box', { x: 100, scale: 2, duration: 3 })\n",[46,200,201],{"__ignoreMap":44},[49,202,203,205,207,209,211,213,215,218,221,223,225],{"class":51,"line":52},[49,204,56],{"class":55},[49,206,60],{"class":59},[49,208,63],{"class":55},[49,210,67],{"class":66},[49,212,70],{"class":55},[49,214,74],{"class":73},[49,216,217],{"class":55},", scale: ",[49,219,220],{"class":73},"2",[49,222,77],{"class":55},[49,224,80],{"class":73},[49,226,83],{"class":55},[138,228,231],{"height":140,"style":141,"scrolling":142,"title":229,"src":230,"frameBorder":142,"loading":145,"allowTransparency":146,"allowFullScreen":146},"GSAP  - 9","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FLYrReRp?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FLYrReRp\">\n  GSAP  - 9\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,233,234],{},"這些屬性都是你所熟悉的 CSS 屬性，因此你可以使用這些屬性來做出你想要的動畫效果。",[16,236,237,238,241],{},"但是這邊要注意一下，假設你所使用的 CSS 屬性有「",[46,239,240],{},"-","」字號的話，請使用駝峰式命名法，例如：",[39,243,245],{"className":41,"code":244,"language":43,"meta":44,"style":44},"gsap.to('.box', { x: 100, backgroundColor: 'red', duration: 3 })\n",[46,246,247],{"__ignoreMap":44},[49,248,249,251,253,255,257,259,261,264,267,269,271],{"class":51,"line":52},[49,250,56],{"class":55},[49,252,60],{"class":59},[49,254,63],{"class":55},[49,256,67],{"class":66},[49,258,70],{"class":55},[49,260,74],{"class":73},[49,262,263],{"class":55},", backgroundColor: ",[49,265,266],{"class":66},"'red'",[49,268,77],{"class":55},[49,270,80],{"class":73},[49,272,83],{"class":55},[138,274,277],{"height":140,"style":141,"scrolling":142,"title":275,"src":276,"frameBorder":142,"loading":145,"allowTransparency":146,"allowFullScreen":146},"GSAP  - 10","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FYzvGYNG?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FYzvGYNG\">\n  GSAP  - 10\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,279,280,281,284,285,288],{},"因此這邊的 ",[46,282,283],{},"backgroundColor"," 就是 ",[46,286,287],{},"background-color"," 的縮寫，只要你遇到這種情況，請使用駝峰式命名法。",[16,290,291,292,295,296,299],{},"前面我們都是直接在 ",[46,293,294],{},"to()"," 方法的第一個物件中撰寫 CSS 動畫屬性，但是實際上我們也可以使用 ",[46,297,298],{},"css"," 物件來撰寫 CSS 動畫屬性，例如：",[39,301,303],{"className":41,"code":302,"language":43,"meta":44,"style":44},"gsap.to('.box', { css: { x: 100, backgroundColor: 'red' }, duration: 3 })\n",[46,304,305],{"__ignoreMap":44},[49,306,307,309,311,313,315,318,320,322,324,327,329],{"class":51,"line":52},[49,308,56],{"class":55},[49,310,60],{"class":59},[49,312,63],{"class":55},[49,314,67],{"class":66},[49,316,317],{"class":55},", { css: { x: ",[49,319,74],{"class":73},[49,321,263],{"class":55},[49,323,266],{"class":66},[49,325,326],{"class":55}," }, duration: ",[49,328,80],{"class":73},[49,330,83],{"class":55},[138,332,335],{"height":140,"st