[{"data":1,"prerenderedAt":291},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20230115\u002F2064110448\u002F":3,"page:\u002Fgsap\u002F20230115\u002F2064110448\u002F":4,"alt:\u002Fgsap\u002F20230115\u002F2064110448\u002F":3,"prev-next:\u002Fgsap\u002F20230115\u002F2064110448\u002F":271,"related:\u002Fgsap\u002F20230115\u002F2064110448\u002F":280},"\u002Fen\u002Fgsap\u002F2023\u002F01\u002F15\u002Fgsap3-fx-16-registering-plugins\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":240,"date":253,"description":18,"extension":254,"lang":255,"meta":256,"navigation":98,"path":257,"readingMinutes":258,"seo":259,"standalone":260,"stem":261,"tags":262,"tldr":268,"updated":253,"url":269,"__hash__":270},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F16-前端好好玩用-GSAP-做一個特效-註冊-Plugins.md","(16)前端好好玩用 GSAP 做一個特效 - 註冊 Plugins","2064110448",{"type":9,"value":10,"toc":249},"minimark",[11,15,19,23,26,29,71,74,124,127,130,164,167,186,189,235,242,245],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前一篇簡單的認識了一些 GSAP 官方套件，所以這一篇就會簡單的介紹一下該如何讓這些套件可以用在我們的專案中。",[12,20,22],{"id":21},"註冊-plugins","註冊 Plugins",[16,24,25],{},"註冊套件的方式有兩種，一種是直接在 HTML 中引入，另一種是透過 npm 安裝，而通常語法非常簡單，只需要在執行 GSAP 相關動畫操作之前撰寫一行程式碼就好了。",[16,27,28],{},"這邊舉例 ScrollTrigger 註冊方式，假使你是使用 CDN 方式載入 ScrollTrigger 的話，其實很簡單，只需要掛入以下 CDN",[30,31,36],"pre",{"className":32,"code":33,"language":34,"meta":35,"style":35},"language-html shiki shiki-themes github-dark-high-contrast","\u003Cscript src=\"https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002Fgsap\u002F3.11.3\u002FScrollTrigger.min.js\">\u003C\u002Fscript>\n","html","",[37,38,39],"code",{"__ignoreMap":35},[40,41,44,48,52,56,59,63,66,68],"span",{"class":42,"line":43},"line",1,[40,45,47],{"class":46},"sMAXC","\u003C",[40,49,51],{"class":50},"sKpQp","script",[40,53,55],{"class":54},"sCcAr"," src",[40,57,58],{"class":46},"=",[40,60,62],{"class":61},"sTRMh","\"https:\u002F\u002Fcdnjs.cloudflare.com\u002Fajax\u002Flibs\u002Fgsap\u002F3.11.3\u002FScrollTrigger.min.js\"",[40,64,65],{"class":46},">\u003C\u002F",[40,67,51],{"class":50},[40,69,70],{"class":46},">\n",[16,72,73],{},"接著並撰寫以下程式碼",[30,75,79],{"className":76,"code":77,"language":78,"meta":35,"style":35},"language-js shiki shiki-themes github-dark-high-contrast","gsap.registerPlugin(ScrollTrigger);\n\ngsap.to(\".box\", { ... })\n","js",[37,80,81,93,100],{"__ignoreMap":35},[40,82,83,86,90],{"class":42,"line":43},[40,84,85],{"class":46},"gsap.",[40,87,89],{"class":88},"sj_SG","registerPlugin",[40,91,92],{"class":46},"(ScrollTrigger);\n",[40,94,96],{"class":42,"line":95},2,[40,97,99],{"emptyLinePlaceholder":98},true,"\n",[40,101,103,105,108,111,114,117,121],{"class":42,"line":102},3,[40,104,85],{"class":46},[40,106,107],{"class":88},"to",[40,109,110],{"class":46},"(",[40,112,113],{"class":61},"\".box\"",[40,115,116],{"class":46},", { ",[40,118,120],{"class":119},"sWyjQ","...",[40,122,123],{"class":46}," })\n",[16,125,126],{},"這樣子就成功把 ScrollTrigger 注入到 GSAP 中，然後你就可以使用 ScrollTrigger 相關功能了。",[16,128,129],{},"但如果你要註冊多個套件，則是可以這樣寫",[30,131,133],{"className":76,"code":132,"language":78,"meta":35,"style":35},"gsap.registerPlugin(Plugin Name, Plugin Name, Plugin Name);\n\ngsap.to(\".box\", { ... })\n",[37,134,135,144,148],{"__ignoreMap":35},[40,136,137,139,141],{"class":42,"line":43},[40,138,85],{"class":46},[40,140,89],{"class":88},[40,142,143],{"class":46},"(Plugin Name, Plugin Name, Plugin Name);\n",[40,145,146],{"class":42,"line":95},[40,147,99],{"emptyLinePlaceholder":98},[40,149,150,152,154,156,158,160,162],{"class":42,"line":102},[40,151,85],{"class":46},[40,153,107],{"class":88},[40,155,110],{"class":46},[40,157,113],{"class":61},[40,159,116],{"class":46},[40,161,120],{"class":119},[40,163,123],{"class":46},[16,165,166],{},"如果是使用 npm 的話，則會有一點不同，雖然你是輸入以下 npm 指令來安裝套件",[30,168,172],{"className":169,"code":170,"language":171,"meta":35,"style":35},"language-bash shiki shiki-themes github-dark-high-contrast","npm install gsap\n","bash",[37,173,174],{"__ignoreMap":35},[40,175,176,180,183],{"class":42,"line":43},[40,177,179],{"class":178},"s_sBn","npm",[40,181,182],{"class":61}," install",[40,184,185],{"class":61}," gsap\n",[16,187,188],{},"接著呢？其實當你安裝 GSAP 時，本身就會自動安裝 ScrollTrigger，所以你不需要再安裝 ScrollTrigger 了，只需要在你的專案中引入 GSAP 就好",[30,190,192],{"className":76,"code":191,"language":78,"meta":35,"style":35},"import { gsap } from \"gsap\";\nimport { ScrollTrigger } from \"gsap\u002FScrollTrigger\";\n\n...\n",[37,193,194,211,225,229],{"__ignoreMap":35},[40,195,196,199,202,205,208],{"class":42,"line":43},[40,197,198],{"class":119},"import",[40,200,201],{"class":46}," { gsap } ",[40,203,204],{"class":119},"from",[40,206,207],{"class":61}," \"gsap\"",[40,209,210],{"class":46},";\n",[40,212,213,215,218,220,223],{"class":42,"line":95},[40,214,198],{"class":119},[40,216,217],{"class":46}," { ScrollTrigger } ",[40,219,204],{"class":119},[40,221,222],{"class":61}," \"gsap\u002FScrollTrigger\"",[40,224,210],{"class":46},[40,226,227],{"class":42,"line":102},[40,228,99],{"emptyLinePlaceholder":98},[40,230,232],{"class":42,"line":231},4,[40,233,234],{"class":119},"...\n",[16,236,237],{},[238,239],"img",{"alt":240,"src":241},"GSAP","https:\u002F\u002Fi.imgur.com\u002F5irbonJ.png",[16,243,244],{},"那麼這一篇就差不多到這邊，算是一個非常簡單的章節，我們下一篇見囉。",[246,247,248],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decora