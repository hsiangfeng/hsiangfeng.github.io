[{"data":1,"prerenderedAt":233},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20230111\u002F3792800951\u002F":3,"page:\u002Fgsap\u002F20230111\u002F3792800951\u002F":4,"alt:\u002Fgsap\u002F20230111\u002F3792800951\u002F":3,"prev-next:\u002Fgsap\u002F20230111\u002F3792800951\u002F":216,"related:\u002Fgsap\u002F20230111\u002F3792800951\u002F":225},"\u002Fen\u002Fgsap\u002F2023\u002F01\u002F11\u002Fgsap3-fx-15-plugins\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":196,"date":197,"description":18,"extension":198,"lang":199,"meta":200,"navigation":201,"path":202,"readingMinutes":203,"seo":204,"standalone":205,"stem":206,"tags":207,"tldr":213,"updated":197,"url":214,"__hash__":215},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F15-前端好好玩用-GSAP-做一個特效-Plugins.md","(15)前端好好玩用 GSAP 做一個特效 - Plugins","3792800951",{"type":9,"value":10,"toc":189},"minimark",[11,15,19,23,26,29,173,182,186],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"我們在實際開發上一定有更多複雜的動畫，但那些動畫行為如果叫我們手動自幹，其實非常的痛苦，好在 GSAP 官方本身就有提供相當多套件，因此這一篇會著重於分享有哪些套件。",[12,20,22],{"id":21},"gsap-plugins","GSAP Plugins",[16,24,25],{},"那麼由於後面我們會介紹一些 GSAP Plugin 跟使用方法，所以這一篇會先來介紹一下 GSAP 本身有哪些 Plugin 可以使用。",[16,27,28],{},"GSAP 官方本身提供許多套件，而且都有持續在更新並維護，下面這邊我也列出有哪些套件可以使用",[30,31,32,42,49,56,63,70,77,84,91,103,110,117,124,131,138,145,152,159,166],"ul",{},[33,34,35],"li",{},[36,37,41],"a",{"href":38,"rel":39},"https:\u002F\u002Fgreensock.com\u002Fflip",[40],"nofollow","Flip Plugin",[33,43,44],{},[36,45,48],{"href":46,"rel":47},"https:\u002F\u002Fgreensock.com\u002Fscrolltrigger\u002F",[40],"ScrollTrigger Plugin",[33,50,51],{},[36,52,55],{"href":53,"rel":54},"https:\u002F\u002Fgreensock.com\u002Fmotionpath\u002F",[40],"MotionPath Plugin",[33,57,58],{},[36,59,62],{"href":60,"rel":61},"https:\u002F\u002Fgreensock.com\u002Finertia\u002F",[40],"Inertia Plugin",[33,64,65],{},[36,66,69],{"href":67,"rel":68},"https:\u002F\u002Fgreensock.com\u002Fjs-pixiplugin\u002F",[40],"PixiPlugin",[33,71,72],{},[36,73,76],{"href":74,"rel":75},"https:\u002F\u002Fgreensock.com\u002Fmodifiers\u002F",[40],"ModifiersPlugin",[33,78,79],{},[36,80,83],{"href":81,"rel":82},"https:\u002F\u002Fgreensock.com\u002Fmorphsvg\u002F",[40],"MorphSVGPlugin",[33,85,86],{},[36,87,90],{"href":88,"rel":89},"https:\u002F\u002Fgreensock.com\u002Fdrawsvg\u002F",[40],"DrawSVGPlugin",[33,92,93,98],{},[36,94,97],{"href":95,"rel":96},"https:\u002F\u002Fgreensock.com\u002Fjquerygsapjs\u002F",[40],"jquery.gsap.js",[30,99,100],{},[33,101,102],{},"GSAP 已經沒有在支援了",[33,104,105],{},[36,106,109],{"href":107,"rel":108},"https:\u002F\u002Fgreensock.com\u002Ftext\u002F",[40],"TextPlugin",[33,111,112],{},[36,113,116],{"href":114,"rel":115},"https:\u002F\u002Fgreensock.com\u002Fscrolltoplugin\u002F",[40],"ScrollToPlugin",[33,118,119],{},[36,120,123],{"href":121,"rel":122},"https:\u002F\u002Fgreensock.com\u002Fscrambletext\u002F",[40],"ScrambleTextPlugin",[33,125,126],{},[36,127,130],{"href":128,"rel":129},"https:\u002F\u002Fgreensock.com\u002Fphysicsprops\u002F",[40],"PhysicsPropsPlugin",[33,132,133],{},[36,134,137],{"href":135,"rel":136},"https:\u002F\u002Fgreensock.com\u002Fphysics2d\u002F",[40],"Physics2DPlugin",[33,139,140],{},[36,141,144],{"href":142,"rel":143},"https:\u002F\u002Fgreensock.com\u002Feasel\u002F",[40],"EaselPlugin",[33,146,147],{},[36,148,151],{"href":149,"rel":150},"https:\u002F\u002Fgreensock.com\u002Fcssrule\u002F",[40],"CSSRulePlugin",[33,153,154],{},[36,155,158],{"href":156,"rel":157},"https:\u002F\u002Fgreensock.com\u002Fcssplugin\u002F",[40],"CSSPlugin",[33,160,161],{},[36,162,165],{"href":163,"rel":164},"https:\u002F\u002Fgreensock.com\u002Fbezier\u002F",[40],"BezierPlugin",[33,167,168],{},[36,169,172],{"href":170,"rel":171},"https:\u002F\u002Fgreensock.com\u002Fattr\u002F",[40],"AttrPlugin",[16,174,175,176,181],{},"而這些套件其實都在",[36,177,180],{"href":178,"rel":179},"https:\u002F\u002Fgreensock.com\u002Fgsap-plugins\u002F",[40],"官方網站","上面有列出來，有沒有覺得很意外？原來 GSAP 本身有這麼多的套件可以使用，而且都是官方所維護並提供的，因此這件事情對於開發者是非常友善的。",[12,183,185],