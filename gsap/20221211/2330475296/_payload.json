[{"data":1,"prerenderedAt":539},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20221211\u002F2330475296\u002F":3,"page:\u002Fgsap\u002F20221211\u002F2330475296\u002F":4,"alt:\u002Fgsap\u002F20221211\u002F2330475296\u002F":3,"prev-next:\u002Fgsap\u002F20221211\u002F2330475296\u002F":517,"related:\u002Fgsap\u002F20221211\u002F2330475296\u002F":526},"\u002Fen\u002Fgsap\u002F2022\u002F12\u002F11\u002Fgsap3-fx-08-special-properties\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":497,"date":498,"description":18,"extension":499,"lang":500,"meta":501,"navigation":502,"path":503,"readingMinutes":504,"seo":505,"standalone":506,"stem":507,"tags":508,"tldr":514,"updated":498,"url":515,"__hash__":516},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F8-前端好好玩用-GSAP-做一個特效-特殊屬性.md","(8)前端好好玩用 GSAP 做一個特效 - 特殊屬性","2330475296",{"type":9,"value":10,"toc":490},"minimark",[11,15,19,22,25,111,122,125,149,160,185,195,197,202,205,250,255,257,274,319,324,327,330,333,335,347,356,410,414,417,423,475,480,483,486],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"前面有提到 GSAP 基本上可以替你想得到的 CSS 屬性做動畫效果之外，其實還有一些特殊屬性可以使用，所以這一篇就來講一下 GSAP 的特殊屬性。",[12,20,21],{"id":21},"特殊屬性",[16,23,24],{},"其實前面文章中，就已經有使用到一些特殊屬性",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-js shiki shiki-themes github-dark-high-contrast","gsap.to('#box', {\n  x: 100,\n  duration: 1,\n  repeat: -1,\n  yoyo: true\n})\n","js","",[33,34,35,58,71,82,96,105],"code",{"__ignoreMap":31},[36,37,40,44,48,51,55],"span",{"class":38,"line":39},"line",1,[36,41,43],{"class":42},"sMAXC","gsap.",[36,45,47],{"class":46},"sj_SG","to",[36,49,50],{"class":42},"(",[36,52,54],{"class":53},"sTRMh","'#box'",[36,56,57],{"class":42},", {\n",[36,59,61,64,68],{"class":38,"line":60},2,[36,62,63],{"class":42},"  x: ",[36,65,67],{"class":66},"sCcAr","100",[36,69,70],{"class":42},",\n",[36,72,74,77,80],{"class":38,"line":73},3,[36,75,76],{"class":42},"  duration: ",[36,78,79],{"class":66},"1",[36,81,70],{"class":42},[36,83,85,88,92,94],{"class":38,"line":84},4,[36,86,87],{"class":42},"  repeat: ",[36,89,91],{"class":90},"sWyjQ","-",[36,93,79],{"class":66},[36,95,70],{"class":42},[36,97,99,102],{"class":38,"line":98},5,[36,100,101],{"class":42},"  yoyo: ",[36,103,104],{"class":66},"true\n",[36,106,108],{"class":38,"line":107},6,[36,109,110],{"class":42},"})\n",[112,113,121],"iframe",{"height":114,"style":115,"scrolling":116,"title":117,"src":118,"frameBorder":116,"loading":119,"allowTransparency":120,"allowFullScreen":120},300,"width: 100%;","no","GSAP  - 19","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FYzvQzGQ?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FYzvQzGQ\">\n  GSAP  - 19\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,123,124],{},"那麼上面有哪些是特殊屬性呢？基本上只要是你沒有在 CSS 中看過的屬性，都可以稱之為特殊屬性，因此上方的範例程式碼中以下都是特殊屬性",[126,127,128,134,139,144],"ul",{},[129,130,131],"li",{},[33,132,133],{},"x",[129,135,136],{},[33,137,138],{},"duration",[129,140,141],{},[33,142,143],{},"repeat",[129,145,146],{},[33,147,148],{},"yoyo",[16,150,151,152,159],{},"那麼特殊屬性其實非常的多，這一篇系列不太可能一一介紹，所以這邊就只介紹一些常用的特殊屬性，如果有需要的話，可以參考 ",[153,154,158],"a",{"href":155,"rel":156},"https:\u002F\u002Fgreensock.com\u002Fdocs\u002Fv3\u002FGSAP\u002Fgsap.to()",[157],"nofollow","GSAP 官方文件","。",[16,161,162,163,165,166,169,170,173,174,177,178,173,181,184],{},"但是這邊有一件事情要提一下，",[33,164,133],{}," 嚴格來說並不是特殊屬性，因為它其實是 ",[33,167,168],{},"transform: translateX()"," 的縮寫，所以這邊就不會再介紹了，其中也包含 ",[33,171,172],{},"y","、",[33,175,176],{},"z"," 都是 ",[33,179,180],{},"transform: translateY()",[33,182,183],{},"transform: translateZ()"," 的縮寫唷。",[16,186,187,188,173,190,173,192,194],{},"接著就讓我們稍微認識一下常見屬性 ",[33,189,138],{},[33,191,143],{},[33,193,148],{}," 吧！",[12,196,138],{"id":138},[16,198,199,201],{},[33,200,138],{}," 是動畫執行的持續時間，這個單位是秒，所以假設你設置成一秒的話，代表動畫會在一秒之內完成，而如果你設置成 0.x 秒的話，就代表動畫會在 0.x 秒之內完成。",[16,203,204],{},"請注意！這個屬性如果你沒有填寫的話，預設值會是 0.5 秒唷。",[26,206,208],{"className":28,"code":207,"language":30,"meta":31,"style":31},"gsap.to('#box', {\n  x: 100,\n  repeat: -1,\n  yoyo: true\n})\n",[33,209,210,222,230,240,246],{"__ignoreMap":31},[36,211,212,214,216,218,220],{"class":38,"line":39},[36,213,43],{"class":42},[36,215,47],{"class":46},[36,217,50],{"class":42},[36,219,54],{"class":53},[36,221,57],{"class":42},[36,223,224,226,228],{"class":38,"line":60},[36,225,63],{"class":42},[36,227,67],{"class":66},[36,229,70],{"class":42},[36,231,232,234,236,238],{"class":38,"line":73},[36,233,87],{"class":42},[36,235,91],{"class":90},[36,237,79],{"class":66},[36,239,70],{"class":42},[36,241,242,244],{"class":38,"line":84},[36,243,101],{"class":42},[36,245,104],{"class":66},[36,247,248],{"class":38,"line":98},[36,249,110],{"class":42},[112,251,254],{"height":114,"style":115,"scrolling":116,"title":252,"src":253,"frameBorder":116,"loading":119,"allowTransparency":120,"allowFullScreen":120},"GSAP  - 20","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FyLEXLKL?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FyLEXLKL\">\n  GSAP  - 20\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[12,256,143],{"id":143},[16,258,259,261,262,265,266,269,270,273],{},[33,260,143],{}," 簡單來講就是說明這個動畫要重複幾次的意思，假使你設置為 ",[33,263,264],{},"-1"," 代表著這個動畫會無限重複，如果你設置為 ",[33,267,268],{},"0"," 就不會重複，但如果你設置為 ",[33,271,272],{},"5","，就代表著這個動畫會重複 6 次。",[26,275,277],{"className":28,"code":276,"language":30,"meta":31,"style":31},"gsap.to('#box', {\n  x: 100,\n  duration: 1,\n  repeat: 5,\n})\n",[33,278,279,291,299,307,315],{"__ignoreMap":31},[36,280,281,283,285,287,289],{"class":38,"line":39},[36,282,43],{"class":42}