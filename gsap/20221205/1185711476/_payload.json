[{"data":1,"prerenderedAt":427},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20221205\u002F1185711476\u002F":3,"page:\u002Fgsap\u002F20221205\u002F1185711476\u002F":4,"alt:\u002Fgsap\u002F20221205\u002F1185711476\u002F":3,"prev-next:\u002Fgsap\u002F20221205\u002F1185711476\u002F":405,"related:\u002Fgsap\u002F20221205\u002F1185711476\u002F":414},"\u002Fen\u002Fgsap\u002F2022\u002F12\u002F05\u002Fgsap3-fx-07-axes\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":385,"date":386,"description":18,"extension":387,"lang":388,"meta":389,"navigation":390,"path":391,"readingMinutes":392,"seo":393,"standalone":394,"stem":395,"tags":396,"tldr":402,"updated":386,"url":403,"__hash__":404},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F7-前端好好玩用-GSAP-做一個特效-座標軸.md","(7)前端好好玩用 GSAP 做一個特效 - 座標軸","1185711476",{"type":9,"value":10,"toc":381},"minimark",[11,15,19,22,25,31,34,37,100,111,132,135,182,187,200,206,212,218,224,227,233,236,300,305,311,317,323,328,334,337,343,346,352,355,360,374,377],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接下來我們要來認識一個製作動畫時，非常重要的觀念，座標軸。",[12,20,21],{"id":21},"座標軸",[16,23,24],{},"座標軸是一個二維平面的概念，主要劃分為 X 軸與 Y 軸，X 軸為水平軸，Y 軸為垂直軸。",[16,26,27],{},[28,29],"img",{"alt":21,"src":30},"https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002F%E6%88%AA%E5%9C%96%202022-11-08%2021.03.04.png",[16,32,33],{},"為什麼要特別提到座標軸呢？因為在 GSAP 中，所有的動畫都是以座標軸為基礎，來進行動畫的製作，因此這個觀念非常重要。",[16,35,36],{},"首先，我們來看一個簡單的範例：",[38,39,44],"pre",{"className":40,"code":41,"language":42,"meta":43,"style":43},"language-js shiki shiki-themes github-dark-high-contrast","gsap.to(\".box\", {\n  x: 100,\n  duration: 3,\n});\n","js","",[45,46,47,70,83,94],"code",{"__ignoreMap":43},[48,49,52,56,60,63,67],"span",{"class":50,"line":51},"line",1,[48,53,55],{"class":54},"sMAXC","gsap.",[48,57,59],{"class":58},"sj_SG","to",[48,61,62],{"class":54},"(",[48,64,66],{"class":65},"sTRMh","\".box\"",[48,68,69],{"class":54},", {\n",[48,71,73,76,80],{"class":50,"line":72},2,[48,74,75],{"class":54},"  x: ",[48,77,79],{"class":78},"sCcAr","100",[48,81,82],{"class":54},",\n",[48,84,86,89,92],{"class":50,"line":85},3,[48,87,88],{"class":54},"  duration: ",[48,90,91],{"class":78},"3",[48,93,82],{"class":54},[48,95,97],{"class":50,"line":96},4,[48,98,99],{"class":54},"});\n",[101,102,110],"iframe",{"height":103,"style":104,"scrolling":105,"title":106,"src":107,"frameBorder":105,"loading":108,"allowTransparency":109,"allowFullScreen":109},300,"width: 100%;","no","GSAP  - 15","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FpoKNqvp?default-tab=html%2Cresult","lazy","true","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FpoKNqvp\">\n  GSAP  - 15\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,112,113,114,117,118,121,122,124,125,127,128,131],{},"在這個範例中，我們使用 ",[45,115,116],{},"gsap.to()"," 來設定動畫，並且設定了 ",[45,119,120],{},"x"," 的值為 ",[45,123,79],{},"，這個 ",[45,126,120],{}," 就是指 X 軸的座標，因此當我們執行這段程式碼時，會發現 ",[45,129,130],{},".box"," 會從原本的位置，向右移動 100 的距離。",[16,133,134],{},"接下來，我們來看一個稍微複雜一點的範例：",[38,136,138],{"className":40,"code":137,"language":42,"meta":43,"style":43},"gsap.to(\".box\", {\n  x: 100,\n  y: 100,\n  duration: 3,\n});\n",[45,139,140,152,160,169,177],{"__ignoreMap":43},[48,141,142,144,146,148,150],{"class":50,"line":51},[48,143,55],{"class":54},[48,145,59],{"class":58},[48,147,62],{"class":54},[48,149,66],{"class":65},[48,151,69],{"class":54},[48,153,154,156,158],{"class":50,"line":72},[48,155,75],{"class":54},[48,157,79],{"class":78},[48,159,82],{"class":54},[48,161,162,165,167],{"class":50,"line":85},[48,163,164],{"class":54},"  y: ",[48,166,79],{"class":78},[48,168,82],{"class":54},[48,170,171,173,175],{"class":50,"line":96},[48,172,88],{"class":54},[48,174,91],{"class":78},[48,176,82],{"class":54},[48,178,180],{"class":50,"line":179},5,[48,181,99],{"class":54},[101,183,186],{"height":103,"style":104,"scrolling":105,"title":184,"src":185,"frameBorder":105,"loading":108,"allowTransparency":109,"allowFullScreen":109},"GSAP  - 16","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FYzvpdbN?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FYzvpdbN\">\n  GSAP  - 16\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,188,189,190,193,194,196,197,199],{},"你可以發現，這次我們多設定了 ",[45,191,192],{},"y"," 的值，這個 ",[45,195,192],{}," 就是指 Y 軸的座標，因此當我們執行這段程式碼時，會發現 ",[45,198,130],{}," 會從原本的位置，向右移動 100 的距離，並且向下移動 100 的距離，而這就形成了一個二維的座標軸。",[16,201,202,203,205],{},"接著讓我們回來看一下 Gif 圖，一開始當我們設置 ",[45,204,120],{}," 為 100 時，會往右移動 100 的距離",[16,207,208],{},[28,209],{"alt":210,"src":211},"X 移動 100","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002Fx100.gif",[16,213,214,215,217],{},"接著當我們設置 ",[45,216,192],{}," 為 100 時，會往下移動 100 的距離",[16,219,220],{},[28,221],{"alt":222,"src":223},"加入 Y 移動 100","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002FXY%E7%A7%BB%E5%8B%95.gif",[16,225,226],{},"那麼我們這邊輸入的都是一個正數，所以我們可以得知座標軸的方向往右與往下都是正的",[16,228,229],{},[28,230],{"alt":231,"src":232},"正數","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002F%E6%88%AA%E5%9C%96%202022-11-08%2021.53.43.png",[16,234,235],{},"那麼如果變成 X & Y 改輸入負數呢？",[38,237,239],{"className":40,"code":238,"language":42,"meta":43,"style":43},"gsap.to(\".box\", {\n  repeat: -1,\n  x: -100,\n  y: -100,\n  duration: 3,\n});\n",[45,240,241,253,267,277,287,295],{"__ignoreMap":43},[48,242,243,245,247,249,251],{"class":50,"line":51},[48,244,55],{"class":54},[48,246,59],{"class":58},[48,248,62],{"class":54},[48,250,66],{"class":65},[48,252,69],{"class":54},[48,254,255,258,262,265],{"class":50,"line":72},[48,256,257],{"class":54},"  repeat: ",[48,259,261],{"class":260},"sWyjQ","-",[48,263,264],{"class":78},"1",[48,266,82],{"class":54},[48,268,269,271,273,275],{"class":50,"line":85},[48,270,75],{"class":54},[48,272,261],{"class":260},[48,274,79],{"class":78},[48,276,82],{"class":54},[48,278,279,281,283,285],{"class":50,"line":96},[48,280,164],{"class":54},[48,282,261],{"class":260},[48,284,79],{"class":78},[48,286,82],{"class":54},[48,288,289,291,293],{"class":50,"line":179},[48,290,88],{"class":54},[48,292,91],{"class":78},[48,294,82],{"class":54},[48,296,298],{"class":50,"line":297},6,[48,299,99],{"class":54},[101,301,304],{"height":103,"style":104,"scrolling":105,"title":302,"src":303,"frameBorder":105,"loading":108,"allowTransparency":109,"allowFullScreen":109},"GSAP  - 17","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FvYrybye?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FvYrybye\">\n  GSAP  - 17\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,306,307,308,310],{},"我們可以看到 ",[45,309,130],{}," 會從原本的位置，向左移動 100 的距離，並且向上移動 100 的距離。",[16,312,313,314,316],{},"接著讓我們來看圖解，首先當我們設置 ",[45,315,120],{}," 為 -100 時，會往左移動 100 的距離",[16,318,319],{},[28,320],{"alt":321,"src":322},"往左移動","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002Fx-100.gif",[16,324,214,325,327],{},[45,326,192],{}," 為 -100 時，會往上移動 100 的距離",[16,329,330],{},[28,331],{"alt":332,"src":333},"往上移動","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002Fxy-100.gif",[16,335,336],{},"因此我們就可以知道，座標軸的方向往左與往上都是負的，那麼完整的圖就像這樣",[16,338,339],{},[28,340],{"alt":341,"src":342},"座標圖","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002F%E6%88%AA%E5%9C%96%202022-11-08%2022.26.07.png",[16,344,345],{},"如果覺得這張圖有點複雜的話，可以改看這一張圖或許會比較好懂一點（？）",[16,347,348],{},[28,349],{"alt":350,"src":351},"移動方位圖","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002F%E5%89%8D%E7%AB%AF%E5%A5%BD%E5%A5%BD%E7%8E%A9%E7%94%A8%20GSAP%20%E5%81%9A%E4%B8%80%E5%80%8B%E7%89%B9%E6%95%88\u002F%E6%88%AA%E5%9C%96%202022-11-08%2022.29.42.png",[16,353,354],{},"底下我也附上各種方向移動的範例，這邊程式碼可以先不用理會，後面會再陸續介紹，可以先看看效果即可",[101,356,359],{"height":103,"style":104,"scrolling":105,"title":357,"src":358,"frameBorder":105,"loading":108,"allowTransparency":109,"allowFullScreen":109},"GSAP  - 18","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FdyKOrXq?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FdyKOrXq\">\n  GSAP  - 18\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,361,362,363,365,366,368,369,365,371,373],{},"最後提醒一下，網頁的座標軸是從左上角開始算起，所以往左上方向移動的話，",[45,364,120],{}," 與 ",[45,367,192],{}," 都是負的，往右下方向移動的話，",[45,370,120],{},[45,372,192],{}," 都是正的，而這邊為了方便觀看所以將畫面的中心點設置在畫面的中間唷。",[16,375,376],{},"那麼這一篇就到這邊結束，我們這一篇見。",[378,379,380],"style",{