[{"data":1,"prerenderedAt":428},["ShallowReactive",2],{"header-locale:\u002Fgsap\u002F20221119\u002F1174983119\u002F":3,"page:\u002Fgsap\u002F20221119\u002F1174983119\u002F":4,"alt:\u002Fgsap\u002F20221119\u002F1174983119\u002F":3,"prev-next:\u002Fgsap\u002F20221119\u002F1174983119\u002F":406,"related:\u002Fgsap\u002F20221119\u002F1174983119\u002F":415},"\u002Fen\u002Fgsap\u002F2022\u002F11\u002F19\u002Fgsap3-fx-03-first-animation\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":177,"date":387,"description":18,"extension":388,"lang":389,"meta":390,"navigation":391,"path":392,"readingMinutes":393,"seo":394,"standalone":395,"stem":396,"tags":397,"tldr":403,"updated":387,"url":404,"__hash__":405},"content\u002F前端好好玩用 GSAP3 做一個特效\u002F3-前端好好玩用-GSAP-做一個特效-第一個動畫.md","(3)前端好好玩用 GSAP 做一個特效 - 第一個動畫","1174983119",{"type":9,"value":10,"toc":377},"minimark",[11,15,19,23,41,44,103,110,113,116,169,172,179,182,185,193,219,229,231,246,271,276,282,285,290,321,326,331,333,338,359,364,370,373],[12,13,14],"h2",{"id":14},"前言",[16,17,18],"p",{},"接著這一篇開始我們要來做一個最簡單的動畫以及認識最基本的 GSAP 語法。",[12,20,22],{"id":21},"gsap-基礎語法","GSAP 基礎語法",[16,24,25,26,30,31,30,34,30,37,40],{},"首先 GSAP 有四種主要語法，分別是 ",[27,28,29],"code",{},"to","、",[27,32,33],{},"from",[27,35,36],{},"fromTo",[27,38,39],{},"set"," 四種。",[16,42,43],{},"而撰寫方式非常簡單，讓我們來看一下範例：",[45,46,51],"pre",{"className":47,"code":48,"language":49,"meta":50,"style":50},"language-js shiki shiki-themes github-dark-high-contrast","gsap.to('#box', { x: 100, duration: 1, repeat: -1, yoyo: true })\n","js","",[27,52,53],{"__ignoreMap":50},[54,55,58,62,65,68,72,75,79,82,85,88,92,94,97,100],"span",{"class":56,"line":57},"line",1,[54,59,61],{"class":60},"sMAXC","gsap.",[54,63,29],{"class":64},"sj_SG",[54,66,67],{"class":60},"(",[54,69,71],{"class":70},"sTRMh","'#box'",[54,73,74],{"class":60},", { x: ",[54,76,78],{"class":77},"sCcAr","100",[54,80,81],{"class":60},", duration: ",[54,83,84],{"class":77},"1",[54,86,87],{"class":60},", repeat: ",[54,89,91],{"class":90},"sWyjQ","-",[54,93,84],{"class":77},[54,95,96],{"class":60},", yoyo: ",[54,98,99],{"class":77},"true",[54,101,102],{"class":60}," })\n",[16,104,105,106,109],{},"上方這個範例是前面章節的範例程式碼，基本上我們都是從 ",[27,107,108],{},"gsap"," 這個物件去呼叫底下的方法。",[16,111,112],{},"這邊有件事情要提醒，在此並不建議使用物件解構的方式來撰寫，因為這樣會造成程式碼的可讀性降低，而且也不利於後續的維護，甚至可能發生衝突問題。",[16,114,115],{},"因此實際開發上並不建議你這樣撰寫",[45,117,119],{"className":47,"code":118,"language":49,"meta":50,"style":50},"const { to } = gsap\nto('#box', { x: 100, duration: 1, repeat: -1, yoyo: true })\n",[27,120,121,140],{"__ignoreMap":50},[54,122,123,126,129,131,134,137],{"class":56,"line":57},[54,124,125],{"class":90},"const",[54,127,128],{"class":60}," { ",[54,130,29],{"class":77},[54,132,133],{"class":60}," } ",[54,135,136],{"class":90},"=",[54,138,139],{"class":60}," gsap\n",[54,141,143,145,147,149,151,153,155,157,159,161,163,165,167],{"class":56,"line":142},2,[54,144,29],{"class":64},[54,146,67],{"class":60},[54,148,71],{"class":70},[54,150,74],{"class":60},[54,152,78],{"class":77},[54,154,81],{"class":60},[54,156,84],{"class":77},[54,158,87],{"class":60},[54,160,91],{"class":90},[54,162,84],{"class":77},[54,164,96],{"class":60},[54,166,99],{"class":77},[54,168,102],{"class":60},[16,170,171],{},"拉回到正題，這邊我也附上一張圖簡單描述一下 GSAP 語法",[16,173,174],{},[175,176],"img",{"alt":177,"src":178},"GSAP","https:\u002F\u002Fimages.israynotarray.com\u002FblogImg\u002FJavaScript\u002Ffrontend-gsap-good\u002F%E6%88%AA%E5%9C%96%202022-10-30%2015.06.18.png",[16,180,181],{},"那麼剛剛有提到四種主要語法，那麼這四種語法的差別在哪呢？",[183,184,29],"h3",{"id":29},[16,186,187,189,190,192],{},[27,188,29],{}," 這個語法非常常見，它的特性是只會執行一次，並且會從當前狀態到目標狀態，舉例來講你原本在 A 點，而你移動到 B 點，那麼 ",[27,191,29],{}," 就是從 A 點到 B 點，當它執行完畢後就會停止。",[45,194,196],{"className":47,"code":195,"language":49,"meta":50,"style":50},"gsap.to('#box', { x: 100, duration: 3 })\n",[27,197,198],{"__ignoreMap":50},[54,199,200,202,204,206,208,210,212,214,217],{"class":56,"line":57},[54,201,61],{"class":60},[54,203,29],{"class":64},[54,205,67],{"class":60},[54,207,71],{"class":70},[54,209,74],{"class":60},[54,211,78],{"class":77},[54,213,81],{"class":60},[54,215,216],{"class":77},"3",[54,218,102],{"class":60},[220,221,228],"iframe",{"height":222,"style":223,"scrolling":224,"title":225,"src":226,"frameBorder":224,"loading":227,"allowTransparency":99,"allowFullScreen":99},300,"width: 100%;","no","GSAP 初始環境 - 1","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FQWxjGbv?default-tab=html%2Cresult","lazy","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FQWxjGbv\">\n  GSAP 初始環境 - 1\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[183,230,33],{"id":33},[16,232,233,236,237,239,240,242,243,245],{},[27,234,235],{},"form"," 與 ",[27,238,29],{}," 非常像，也很容易讓人搞混，但是它們的差別在於 ",[27,241,33],{}," 是從目標狀態到當前狀態，舉例來講你原本在 A 點，而你移動到 B 點，那麼 ",[27,244,33],{}," 就是從 B 點到 A 點，當它執行完畢後就會停止。",[45,247,249],{"className":47,"code":248,"language":49,"meta":50,"style":50},"gsap.from('#box', { x: 100, duration: 3 })\n",[27,250,251],{"__ignoreMap":50},[54,252,253,255,257,259,261,263,265,267,269],{"class":56,"line":57},[54,254,61],{"class":60},[54,256,33],{"class":64},[54,258,67],{"class":60},[54,260,71],{"class":70},[54,262,74],{"class":60},[54,264,78],{"class":77},[54,266,81],{"class":60},[54,268,216],{"class":77},[54,270,102],{"class":60},[220,272,275],{"height":222,"style":223,"scrolling":224,"title":273,"src":274,"frameBorder":224,"loading":227,"allowTransparency":99,"allowFullScreen":99},"GSAP 基礎語法 - 1","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FMWXabwQ?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FMWXabwQ\">\n  GSAP 基礎語法 - 1\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,277,278,279,281],{},"其實就是反向的 ",[27,280,29],{}," 語法。",[183,283,36],{"id":284},"fromto",[16,286,287,289],{},[27,288,36],{}," 的寫法稍微有一點不一樣，它會需要傳入兩個物件，第一個物件是當前狀態，第二個物件是目標狀態，當它執行完畢後就會停止。",[45,291,293],{"className":47,"code":292,"language":49,"meta":50,"style":50},"gsap.fromTo('#box', { x: 0 }, { x: 100, duration: 3 })\n",[27,294,295],{"__ignoreMap":50},[54,296,297,299,301,303,305,307,310,313,315,317,319],{"class":56,"line":57},[54,298,61],{"class":60},[54,300,36],{"class":64},[54,302,67],{"class":60},[54,304,71],{"class":70},[54,306,74],{"class":60},[54,308,309],{"class":77},"0",[54,311,312],{"class":60}," }, { x: ",[54,314,78],{"class":77},[54,316,81],{"class":60},[54,318,216],{"class":77},[54,320,102],{"class":60},[220,322,325],{"height":222,"style":223,"scrolling":224,"title":323,"src":324,"frameBorder":224,"loading":227,"allowTransparency":99,"allowFullScreen":99},"GSAP 基礎語法 - 2","https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fembed\u002FRwJWoWN?default-tab=html%2Cresult","\n  See the Pen \u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\u002Fpen\u002FRwJWoWN\">\n  GSAP 基礎語法 - 2\u003C\u002Fa> by Ray (\u003Ca href=\"https:\u002F\u002Fcodepen.io\u002Fhsiangfeng\">@hsiangfeng\u003C\u002Fa>)\n  on \u003Ca href=\"https:\u002F\u002Fcodepen.io\">CodePen\u003C\u002Fa>.\n",[16,327,328,330],{},[27,329,36],{}," 的概念非常接近影格概念，你必須定義當前狀態與目標狀態。",[183,332,39],{"id":39},[16,334,335,337],{},[27,336,39],{}," 語法沒有任何動畫效果，僅僅只是定義動畫的初始狀態而已，通常必須搭配前面三種語法使用。",[45,339,341],{"className":47,"code":340,"language":49,"meta":50,"style":50},"gsap.set('#box', { x: 100 })\n",[27,342,343],{"__ignoreMap":50},[54,344,345,347,349,351,353,355,357],{"class":56,"line":57},[54,346,61],{"class":60},[54,348,39],{"class":64},[54,350,67],{"class":60},[54,352,71],{"class":70},[54,354,74],{"class":60},[54,356,78],{"class":77},[54,358,102],{"class":60},[220,360,363],{"height":222,"style":223,"scrolling":224,"title":361,"src":362,"frameBorder":224,"loading":2