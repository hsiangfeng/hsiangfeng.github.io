[{"data":1,"prerenderedAt":76},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fjsweirdworld\u002Fpage\u002F6\u002F":3,"category-page:zh-Hant:jsweirdworld:6":4,"author-stats:zh-Hant:full":73},null,{"category":5,"posts":6,"total":71,"totalPages":72},"克服JS奇怪的部分系列",[7,16,23,29,35,41,47,53,59,65],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190517\u002F3849161770\u002F","[JS奇怪的世界]No.19 存在與布林值","2019-05-17 11:16:35",[12,13],"JavaScript","JavaScript 全攻略:克服JS奇怪的部分","一般來講我們可以手動使用 Boolean、Number 等函數來做強制轉型的動作，但是課程也是強調不要這樣做(手動轉型)，但是用來展示效果是可以的，舉例我們將 undefined 轉換成布林值 ↓","1",{"url":17,"title":18,"date":19,"updated":3,"category":5,"tags":20,"description":21,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190516\u002F803766782\u002F","[JS奇怪的世界]No.18 比較運算子","2019-05-16 21:16:35",[12,13],"將下來講講 小於運算子，讓我們試著用程式碼來講解。","2",{"url":24,"title":25,"date":26,"updated":3,"category":5,"tags":27,"description":28,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190516\u002F3588659278\u002F","[JS奇怪的世界]No.17 觀念小叮嚀:強制轉型","2019-05-16 21:01:35",[12,13],"強制轉型的意思是什麼?就是將原本的型別轉換成另一種，例如 String 變成 Boolean。",{"url":30,"title":31,"date":32,"updated":3,"category":5,"tags":33,"description":34,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190516\u002F3658238475\u002F","[JS奇怪的世界]No.16 運算子的優先性與相依性","2019-05-16 20:34:35",[12,13],"這兩個在 JavaScript 是一個非常重要的名詞，其實非常重要的觀念，如果能瞭解其觀念，對於 debug 上是有一定幫助的。",{"url":36,"title":37,"date":38,"updated":3,"category":5,"tags":39,"description":40,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190516\u002F2821553635\u002F","[JS奇怪的世界]No.15 觀念小叮嚀:運算子","2019-05-16 20:00:35",[12,13],"運算子可以說是 JavaScript 中提供的特殊方法也可以稱之為函數，並且可以協助我們做一些計算，那怎麼寫呢?",{"url":42,"title":43,"date":44,"updated":3,"category":5,"tags":45,"description":46,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190516\u002F890725015\u002F","[JS奇怪的世界]No.14 純值","2019-05-16 19:30:35",[12,13],"前面已經針對 JavaScript 的型別做的一個簡易的介紹，而這章節課程將針對 JavaScript 動態型別瞭解以及其優缺點深入瞭解。",{"url":48,"title":49,"date":50,"updated":3,"category":5,"tags":51,"description":52,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190516\u002F3276239225\u002F","[JS奇怪的世界]No.13 觀念小叮嚀-型別與JavaScript","2019-05-16 19:00:35",[12,13],"這一個章節是新的章節「型別與運算子」。",{"url":54,"title":55,"date":56,"updated":3,"category":5,"tags":57,"description":58,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190516\u002F3421234703\u002F","[JS奇怪的世界]No.12 關於非同步回呼","2019-05-16 15:30:35",[12,13],"前面某一章節我有講過 JavaScipt 的同步執行，想必你也聽過很多所謂的非同步，但非同步是什麼?",{"url":60,"title":61,"date":62,"updated":3,"category":5,"tags":63,"description":64,"readingMinutes":15},"\u002Fjsweirdworld\u002F20190516\u002F2522156098\u002F","[JS奇怪的世界]No.11 範圍、ES6與let","2019-05-16 14:30:35",[12,13],"範圍所代表的意思是變數可以被取用的區域。",{"url":66,"title":67,"date":68,"updated":3,"category":5,"tags":69,"description":70,"readingMinutes":22},"\u002Fjsweirdworld\u002F20190516\u002F4036061119\u002F","[JS奇怪的世界]No.10 範圍鏈","2019-05-16 14:00:35",[12,13],"接下來要講得是「範圍鏈」，而這觀念並不會太難，因為在前面已經練習很多次了，更不用說上一章其實有講到範圍鏈(The Scope Chain)，一樣從課堂範例程式碼學習 ↓",69,7,{"postCount":74,"tagCount":75},1035,1009,1784020339981]