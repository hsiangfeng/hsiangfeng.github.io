[{"data":1,"prerenderedAt":80},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fvue\u002Fpage\u002F5\u002F":3,"category-page:zh-Hant:vue:5":4,"author-stats:zh-Hant:full":77},null,{"category":5,"posts":6,"total":75,"totalPages":76},"Vue",[7,14,21,28,34,40,47,56,62,69],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":9,"readingMinutes":13},"\u002Fvue\u002F20190725\u002F1960407570\u002F","Vue 出一個女友吧!-Login API","2019-07-25 16:16:05",[5,12],"Vue 出一個女友吧","3",{"url":15,"title":16,"date":17,"updated":3,"category":5,"tags":18,"description":19,"readingMinutes":20},"\u002Fvue\u002F20190725\u002F1014459828\u002F","Vue 出一個女友吧!-Admin Page","2019-07-25 15:08:18",[5,12],"這一篇將會講到 Route 的部分，順便也會講到 Admin Page","2",{"url":22,"title":23,"date":24,"updated":3,"category":5,"tags":25,"description":26,"readingMinutes":27},"\u002Fvue\u002F20190725\u002F3887985161\u002F","Vue 出一個女友吧!-PUG Template","2019-07-25 14:50:49",[5,12],"PUG Template 是我非常愛用的 HTML Template，所以講一下該如何使用在 Vue 中撰寫 PUG 吧","1",{"url":29,"title":30,"date":31,"updated":3,"category":5,"tags":32,"description":33,"readingMinutes":20},"\u002Fvue\u002F20190725\u002F1126109994\u002F","Vue 出一個女友吧!-SCSS & Boostrap 引入","2019-07-25 14:12:27",[5,12],"接下來的專案將會使用 Boostrap 幫助我們加速快速開發，所以就會需要引入 Boostrap",{"url":35,"title":36,"date":37,"updated":3,"category":5,"tags":38,"description":39,"readingMinutes":20},"\u002Fvue\u002F20190725\u002F3896075321\u002F","Vue 出一個女友吧!","2019-07-25 11:42:07",[5,12],"這是一個非常奇特的主題，至於為什麼會製作這個主題呢?後面再來講原因，這一系列將會講解紀錄使用 Vue Cli3 開發出一個平台唷",{"url":41,"title":42,"date":43,"updated":3,"category":5,"tags":44,"description":46,"readingMinutes":20},"\u002Fvue\u002F20190605\u002F1250642062\u002F","線上撰寫 Vue Cli 好物 CodeSandbox","2019-06-05 09:59:46",[45,5],"CodeSandbox","以往我們撰寫程式碼都是使用 codepen、jsbin 或是 jsfiddle，但是如果我們今天要撰寫 Vue Cli 的話，那這些線上平台就沒有辦法撰寫，但是 CodeSandbox 就可以做到這個需求，讓我們來線上撰寫 Vue Cli 吧!(~~有夠像業配~~)",{"url":48,"title":49,"date":50,"updated":3,"category":5,"tags":51,"description":55,"readingMinutes":13},"\u002Fvue\u002F20190513\u002F948497494\u002F","Vuejs部屬GitHub Pages","2019-05-13 19:34:56",[52,5,53,54],"JavaScript","Git","GitHub","開發 Vue.js 結束後接下來就是部屬上 GitHub，這邊紀錄一下指令該如何部屬到 GitHub Pages 吧~",{"url":57,"title":58,"date":59,"updated":3,"category":5,"tags":60,"description":61,"readingMinutes":20},"\u002Fvue\u002F20190510\u002F1766915506\u002F","props與emit的傳遞方式","2019-05-10 19:04:33",[52,5],"這幾天自己突然又開始使用 Vue 來製作一個小東西，因為我都是用 components 來製作，所以勢必要了解 props 與 emit 之間是如何傳遞的。",{"url":63,"title":64,"date":65,"updated":66,"category":5,"tags":67,"description":68,"readingMinutes":20},"\u002Fvue\u002F20190510\u002F86469050\u002F","Vue 的 @（小老鼠）符號是什麼？src 路徑別名與 .. 的差異","2019-05-10 10:30:35","2026-06-11 09:00:00",[52,5],"在 Vue 專案的 import 路徑常看到 @ 這個小老鼠符號，它其實是 Vue CLI 幫你設定好的 src 路徑別名（alias）。這篇講清楚 @ 跟相對路徑 .. 的差異，以及 Vue CLI 2 與 3 的設定位置在哪。",{"url":70,"title":71,"date":72,"updated":3,"category":5,"tags":73,"description":74,"readingMinutes":27},"\u002Fvue\u002F20190508\u002F40080850\u002F","vuejs(cli)中使用wowjs","2019-05-08 22:10:45",[52,5],"最近正在製作一個小作品，因為是使用 Vue Cli 開發，這邊紀錄一下該如何在 Vue Cli 中使用 WOWJS",50,5,{"postCount":78,"tagCount":79},1036,1011,1784087314453]