[{"data":1,"prerenderedAt":60},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fnodejs\u002Fpage\u002F16\u002F":3,"category-page:zh-Hant:nodejs:16":4,"author-stats:zh-Hant:full":57},null,{"category":5,"posts":6,"total":55,"totalPages":56},"Nodejs",[7,16,23,31,37,43,49],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20190626\u002F1885201810\u002F","全端勇士之路 Node.js 基礎學習-基礎篇","2019-06-26 12:02:21",[12,13],"Node.js","全端勇士之路 Node.js","又是一篇基礎學習系列的開啟，這是為了讓自己對 Node.js 觀念及開發更清楚所撰寫的系列文章，廢話不多說就開始吧~","2",{"url":17,"title":18,"date":19,"updated":3,"category":5,"tags":20,"description":22,"readingMinutes":15},"\u002Fnodejs\u002F20190530\u002F957018086\u002F","Koajs安裝及架設","2019-05-30 13:05:22",[21],"Koa.js","因為工作上需要，將會接觸到 Koajs 這個框架，所以就自己來試著架設摸摸看，雖然主管說本質上與 Express 很像，但是自己還是要摸一下才知道所以然，因為這框架似乎使用了非常多的非同步與同步的做法，裡面也主要使用 ES6、ES7 寫法，所以說如果是寫 Express 的人是可以直接轉用這個沒問題。",{"url":24,"title":25,"date":26,"updated":3,"category":5,"tags":27,"description":29,"readingMinutes":30},"\u002Fnodejs\u002F20190503\u002F2483499053\u002F","nodejs出現錯誤代碼500","2019-05-03 09:06:26",[12,28],"障礙排除","昨天在弄 nodejs 的時候發生一件很奇妙的事情，前一天使用 ajax 還很正常，昨天突然 ajax 掛掉了...最後今天發現原因紀錄一下自己多白癡。","1",{"url":32,"title":33,"date":34,"updated":3,"category":5,"tags":35,"description":36,"readingMinutes":30},"\u002Fnodejs\u002F20190429\u002F1130866276\u002F","nodejs神奇的兩次Request","2019-04-29 20:06:34",[12,28],"由於最近再進修 Nodejs + firebase ，所以也挪不太出時間來寫文章，但是練習 Nodejs 過程中遇到一個很低級&智障問題，結果因此卡了三天，所以這邊做一下紀錄。",{"url":38,"title":39,"date":40,"updated":3,"category":5,"tags":41,"description":42,"readingMinutes":15},"\u002Fnodejs\u002F20190425\u002F3663458445\u002F","Express自訂SASS\u002FSCSS路徑","2019-04-25 13:57:16",[12,28],"前面有撰寫一篇如何Nodejs-Express中撰寫SCSS，剛寫完就遇到一個問題...所以這邊果斷再寫一篇該如何自訂 SASS\u002FSCSS 路徑",{"url":44,"title":45,"date":46,"updated":3,"category":5,"tags":47,"description":48,"readingMinutes":30},"\u002Fnodejs\u002F20190425\u002F1258950236\u002F","Nodejs-Express中撰寫SCSS"