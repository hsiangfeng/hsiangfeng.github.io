[{"data":1,"prerenderedAt":77},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fnodejs\u002Fpage\u002F2\u002F":3,"category-page:zh-Hant:nodejs:2":4,"author-stats:zh-Hant:full":74},null,{"category":5,"posts":6,"total":72,"totalPages":73},"Nodejs",[7,16,22,29,35,41,47,53,60,66],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20231012\u002F3543796485\u002F","Day28-Google Extension 與 Google Apps Script 蹦再一起","2023-10-12 00:00:01",[12,13],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","為了讓我們熟悉 Google Apps Script 的環境，那麼最快的方式就是實作，因此這邊就來整合 Google Extension 吧～","3",{"url":17,"title":18,"date":19,"updated":19,"category":5,"tags":20,"description":21,"readingMinutes":15},"\u002Fnodejs\u002F20231011\u002F1771923912\u002F","Day27-遇見 Google Apps Script","2023-10-11 00:00:01",[12,13],"OMG，這又是什麼新玩意了，接下來這一篇我們會稍微輕鬆一點來認識 Google Apps Script 是什麼東西，而且實戰上來講，也是非常的方便，因此我們就來看看 Google Apps Script 是什麼東西吧！",{"url":23,"title":24,"date":25,"updated":25,"category":5,"tags":26,"description":27,"readingMinutes":28},"\u002Fnodejs\u002F20231010\u002F3798507505\u002F","Day26-Google Extension 與 Vite","2023-10-10 00:00:01",[12,13],"前一篇我們對於 Google Extension 有了初步的認識，但我們實際開發上來講，必定會使用到人家開發好的套件，所以這一篇就會來使用 Vite 來開發 Google Extension。","5",{"url":30,"title":31,"date":32,"updated":32,"category":5,"tags":33,"description":34,"readingMinutes":15},"\u002Fnodejs\u002F20231009\u002F609773828\u002F","Day25-Google Extension","2023-10-09 00:00:01",[12,13],"又進入新的章節了，這章節我們要來介紹 Google Extension，那麼 Google Extension 是什麼呢？這一篇就讓我們來簡單的認識一下吧！",{"url":36,"title":37,"date":38,"updated":38,"category":5,"tags":39,"description":40,"readingMinutes":28},"\u002Fnodejs\u002F20231008\u002F2016996949\u002F","Day24-部署到 Zeabur","2023-10-08 00:00:01",[12,13],"前一面我們對於伺服器有基本概念後，接下來當然是要實際部署專案到伺服器上囉～",{"url":42,"title":43,"date":44,"updated":44,"category":5,"tags":45,"description":46,"readingMinutes":15},"\u002Fnodejs\u002F20231007\u002F3219221834\u002F","Day23 - 關於伺服器","2023-10-07 00:00:01",[12,13],"我們介紹了許多知識點，並且也將爬蟲整合進去 Discord Bot 中，但是實際上來講我們不可能都用本地端來啟動 Discord Bot，所以接下來將會來介紹一些關於伺服器與主機的知識點，所以這一篇會相對比較簡單，也算是讓腦袋放鬆一下。",{"url":48,"title":49,"date":50,"updated":50,"category":5,"tags":51,"description":52,"readingMinutes":28},"\u002Fnodejs\u002F20231006\u002F4255357825\u002F","Day22 - Discord Bot 整合","2023-10-06 00:00:01",[12,13],"前一篇對於 Discord 已經具有一定基礎後，當然要來做一點小東西了，當然不會太難，大多都是前面所寫過跟使用過的東西哩。",{"url":54,"title":55,"date":56,"updated":56,"category":5,"tags":57,"description":58,"readingMinutes":59},"\u002Fnodejs\u002F20231005\u002F1512925992\u002F","Day21 - Discord 基礎","2023-10-05 00:00:01",[12,13],"在前一篇我們準備好了 Discord 基本的一些東西與設定，接下來當然要繼續聊 Discord 的部分囉～","4",{"url":61,"title":62,"date":63,"updated":63,"category":5,"tags":64,"description":65,"readingMinutes":15},"\u002Fnodejs\u002F20231004\u002F1031795777\u002F","Day20 - Discord Bot？","2023-10-04 00:00:01",[12,13],"除了爬蟲之外，Node.js 可以做的事情其實非常多，所以接下來將會介紹一些其他的應用的實作，也就是 Bot。",{"url":67,"title":68,"date":69,"updated":69,"category":5,"tags":70,"description":71,"readingMinutes":59},"\u002Fnodejs\u002F20231003\u002F1830434204\u002F","Day19 - Crontab + Node.js","2023-10-03 00:00:01",[12,13],"前一篇我們對於 Crontab 已經有一個基本的概念，接下來當然要套用到實戰上，不然認識了也沒用，所以這一篇我們就來實作一個 Crontab + Node.js 的範例。",157,16,{"postCount":75,"tagCount":76},1035,1009,1784011689638]