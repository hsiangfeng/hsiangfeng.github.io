[{"data":1,"prerenderedAt":79},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fnodejs\u002Fpage\u002F3\u002F":3,"category-page:zh-Hant:nodejs:3":4,"author-stats:zh-Hant:full":76},null,{"category":5,"posts":6,"total":74,"totalPages":75},"Nodejs",[7,16,23,29,37,43,50,56,62,68],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fnodejs\u002F20231002\u002F2297973079\u002F","Day18 - 初識 Crontab","2023-10-02 00:00:01",[12,13],"Node.js","《Node.js 不負責系列：把前端人員當作後端來用，就算是前端也能嘗試寫的後端～原來 Node.js 可以做這麼多事～》","看到現在，你也應該學了不少知識了，你應該會發現有些系統好像都會「自動」去做某些事情，所以接下來將會來介紹例行性工作排程 (crontab) 這個東西。","3",{"url":17,"title":18,"date":19,"updated":19,"category":5,"tags":20,"description":21,"readingMinutes":22},"\u002Fnodejs\u002F20231001\u002F2119244773\u002F","Day17 - 續談爬蟲（下）","2023-10-01 00:00:01",[12,13],"這一篇將會接續前一篇的文章內容，繼續把前一篇沒講完的爬蟲內容給補完。","6",{"url":24,"title":25,"date":26,"updated":26,"category":5,"tags":27,"description":28,"readingMinutes":22},"\u002Fnodejs\u002F20230930\u002F4076915411\u002F","Day16 - 續談爬蟲（上）","2023-09-30 00:00:01",[12,13],"接下來這一篇也是針對爬蟲來介紹，但是會去撈一些比較複雜的資料。",{"url":30,"title":31,"date":32,"updated":33,"category":5,"tags":34,"description":35,"readingMinutes":36},"\u002Fnodejs\u002F20230929\u002F3878806252\u002F","Day15 - 第一個爬蟲","2023-09-29 00:00:01","2023-11-19 00:00:01",[12,13],"前一篇我們對於爬蟲應該有一些基本的概念與認知了，接下來當然就是要來實作一下囉。","5",{"url":38,"title":39,"date":40,"updated":40,"category":5,"tags":41,"description":42,"readingMinutes":15},"\u002Fnodejs\u002F20230928\u002F2824059455\u002F","Day14 - 網頁爬蟲？","2023-09-28 00:00:01",[12,13],"這一篇基本上我打算輕鬆一點介紹爬蟲就好，所以這一篇的篇幅或許會比以往前面少很多，主要也是讓大腦可以輕鬆一點。",{"url":44,"title":45,"date":46,"updated":46,"category":5,"tags":47,"description":48,"readingMinutes":49},"\u002Fnodejs\u002F20230927\u002F4133508926\u002F","Day13 - 替你的 Express 戴上頭盔吧！","2023-09-27 00:00:01",[12,13],"前面介紹了 CORS 跟 Env 可以說是基本的基本，接下來要來介紹一個很特別的東西，叫做 Helmet。","4",{"url":51,"title":52,"date":53,"updated":53,"category":5,"tags":54,"description":55,"readingMinutes":22},"\u002Fnodejs\u002F20230926\u002F1829302614\u002F","Day12 - 關於 CORS 與 Env","2023-09-26 00:00:01",[12,13],"前一篇我們完成了 Express + Mongoose 的整合，接下來我們要來處理一些環境變數的問題，以及 CORS 的問題。",{"url":57,"title":58,"date":59,"updated":59,"category":5,"tags":60,"description":61,"readingMinutes":36},"\u002Fnodejs\u002F20230925\u002F3347882734\u002F","Day11 - Express 與 Mongoose","2023-09-25 00:00:01",[12,13],"在上一篇文章中，我們初步建立了 MongoDB Atlas 的帳號，並且快速認識了 Mongoose，接下來當然就是要來整合再一起啦～",{"url":63,"title":64,"date":65,"updated":65,"category":5,"tags":66,"description":67,"readingMinutes":36},"\u002Fnodejs\u002F20230924\u002F3283299199\u002F","Day10 - MongoDB 與 Mongoose","2023-09-24 00:00:01",[12,13],"前一篇我們初步對於資料庫有了一點概念後，接下來當然要進入資料庫章節啦～",{"url":69,"title":70,"date":71,"updated":71,"category":5,"tags":72,"description":73,"readingMinutes":36},"\u002Fnodejs\u002F20230923\u002F264010765\u002F","Day9 - What is a database？","2023-09-23 00:00:01",[12,13],"對於一個網站或者服務來講，資料庫是不可或缺的一個元素，那麼什麼是資料庫呢？接下來我們就來聊聊什麼是資料庫。",157,16,{"postCount":77,"tagCount":78},1036,1011,1784087312753]