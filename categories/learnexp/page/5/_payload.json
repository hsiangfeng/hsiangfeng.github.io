[{"data":1,"prerenderedAt":101},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Flearnexp\u002Fpage\u002F5\u002F":3,"category-page:zh-Hant:learnexp:5":4,"author-stats:zh-Hant:full":98},null,{"category":5,"posts":6,"total":96,"totalPages":97},"學習經驗",[7,17,26,36,44,56,68,75,83,89],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":15,"readingMinutes":16},"\u002Flearnexp\u002F20220926\u002F1334824747\u002F","關於時間的分配，如何成為時間管理大師？","2022-09-26 23:52:12",[12,13,14],"時間管理","時間分配","時間管理大師","該如何分配自己的時間？該如何最大化自己的時間？這一篇就來簡單分享一下時間。","3",{"url":18,"title":19,"date":20,"updated":21,"category":5,"tags":22,"description":24,"readingMinutes":25},"\u002Flearnexp\u002F20220912\u002F479385029\u002F","達克效應是什麼？自以為懂，但其實根本不懂","2022-09-12 10:51:48","2026-06-11 09:00:00",[23],"達克效應","達克效應（Dunning-Kruger Effect）到底是什麼？這一篇從初學者、轉職者最常踩到的「自以為懂、但其實根本不懂」現象切入，聊四個典型階段——愚昧之山、 絕望之谷、開悟之坡到大師之路。","4",{"url":27,"title":28,"date":29,"updated":29,"category":5,"tags":30,"description":35,"readingMinutes":16},"\u002Flearnexp\u002F20220908\u002F503806414\u002F","為什麼推薦工程師寫部落格呢？","2022-09-08 14:06:33",[31,32,33,34],"部落格","Hexo","Medium","WordPress","其實很多人在學習與開發過程中總是會遇到一些雷點、Bug，而這些其實都是一個很好的經驗。因此如果你沒有記錄下來是一件非常很可惜的事情，更不用說或許哪一天你又會遇到相同的問題，而我個人是非常推薦撰寫部落格的，至於為什麼推薦呢？後面我們再來細談。",{"url":37,"title":38,"date":39,"updated":39,"category":5,"tags":40,"description":43,"readingMinutes":16},"\u002Flearnexp\u002F20211122\u002F1862504277\u002F","【91 極速開發+】課後心得","2021-11-22 17:34:18",[41,42,5],"91 極速開發+","課後心得","其實認真講【91 極速開發+】就是想要解決開發上總是在哀嚎的一個問題「時間不夠」，所以就被公司推坑去上了，那不免也寫一篇新的來分享課後心得。",{"url":45,"title":46,"date":47,"updated":47,"category":5,"tags":48,"description":54,"readingMinutes":55},"\u002Flearnexp\u002F20211117\u002F407591854\u002F","提高你在社群上的提問技巧","2021-11-17 16:53:59",[49,50,51,52,53],"提問","提問的修辭","提問的技巧","提問的智慧","社群","這一篇其實是「掌握提問的技巧，減少欠人教訓的提問」這一篇文章的延續版，主要是針對在社群上的提問，畢竟在社群上提問是非常常見的狀況。","5",{"url":57,"title":58,"date":59,"updated":59,"category":5,"tags":60,"description":67,"readingMinutes":55},"\u002Flearnexp\u002F20211107\u002F2178120796\u002F","只要十分鐘你也可以懂的股票入門基礎 - 以台股為例","2021-11-07 14:20:02",[61,62,63,64,65,66],"投資","被動收入","股票","技能","薪水","台股","這一篇主要是給自己朋友的文章，因為身邊許多朋友都在詢問該怎麼股票入門，因為股票有許多專業術語，因此就乾脆寫成一篇文章也順便紀錄筆記。",{"url":69,"title":70,"date":71,"updated":71,"category":5,"tags":72,"description":74,"readingMinutes":25},"\u002Flearnexp\u002F20211008\u002F2688902488\u002F","關於學習的本質這件事","2021-10-08 21:26:49",[73,5],"其他","學習真的是一件痛苦的事嗎？這一篇聊聊我對「學習本質」的觀察，包含為什麼大家容易陷入焦慮、怎麼判斷自己有沒有真的學會，以及怎麼把學習變成一件比較不那麼痛苦的事。",{"url":76,"title":77,"date":78,"updated":79,"category":5,"tags":80,"description":81,"readingMinutes":82},"\u002Flearnexp\u002F20210710\u002F1926104502\u002F","創造被動收入之前的準備與理財入門","2021-07-10 10:28:14","2022-12-29 09:24:14",[61,62,63,64,65],"這一篇比較偏向聊聊不一樣的角度，比較偏向如何創造被動收入的各種思維與思考，那麼會寫這一篇主要是朋友問我「想創造被動收入該怎麼做？」，所以我就想說將我那天與他聊的記錄下來，將來若還有其他朋友詢問的話，就可以直接給他這一篇文章。","9",{"url":84,"title":85,"date":86,"updated":86,"category":5,"tags":87,"description":88,"readingMinutes":25},"\u002Flearnexp\u002F20200612\u002F341747575\u002F","入職後發現技術不足怎麼辦？","2020-06-12 22:06:31",[73,5],"這幾天有幾位類似相同境遇的學員來跟我小聊一下自己工作近況，話題大多都是關於「入職後發現自己技術完全跟不上，同事開會時也幫不上忙，是不是該離職了。」",{"url":90,"title":91,"date":92,"updated":92,"category":5,"tags":93,"description":95,"readingMinutes":25},"\u002Flearnexp\u002F20200317\u002F2499808266\u002F","履歷該放什麼？作業還是作品？","2020-03-17 08:27:48",[94,5],"履歷","身為一名跨行轉職的新人工程師，往往都會犯一個很嚴重的錯誤，也就是將課堂上的作業當作作品集來使用。",63,7,{"postCount":99,"tagCount":100},1035,1009,1784013046781]