[{"data":1,"prerenderedAt":33},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Flearnexp\u002Fpage\u002F7\u002F":3,"category-page:zh-Hant:learnexp:7":4,"author-stats:zh-Hant:full":30},null,{"category":5,"posts":6,"total":28,"totalPages":29},"學習經驗",[7,15,21],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":13,"readingMinutes":14},"\u002Flearnexp\u002F20190502\u002F4023370690\u002F","你願意犧牲多少來得到你想要的事物?","2019-05-02 10:24:41",[12,5],"其他","許多時候我們都必須去作出選擇，先前六角學院的廖老師有分享過前端求職履歷面試全攻略的影音心得，其中裡面有講到你願意為了達到目標犧牲多少?","3",{"url":16,"title":17,"date":18,"updated":18,"category":5,"tags":19,"description":20,"readingMinutes":14},"\u002Flearnexp\u002F20190426\u002F43778186\u002F","學習時的心態調整","2019-04-26 15:35:12",[12,5],"最近在幫忙幾位朋友解決學習上的問題時，發現很常出現幾種問題，也跟自己當初的狀況很類似，所以就乾脆寫一下自己的心得分享...",{"url":22,"title":23,"date":24,"updated":24,"category":5,"tags":25,"description":26,"readingMinutes":27},"\u002Flearnexp\u002F20190416\u002F3782185665\u002F","該如何正確的學習前端技術或程式語言","2019-04-16 22:36:38",[12,5],"先講講為什麼我會寫這一篇文章，自從加入六角學院轉行走前端工程師，陸陸續續都有朋友、網友及同學等都來請教該如何像我一樣學習前端技術，我思考了好一陣子才決定寫這一篇文章作為經驗分享。","5",63,7,{"postCount":31,"tagCount":32},1035,1009,1784020340268]