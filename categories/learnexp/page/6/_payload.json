[{"data":1,"prerenderedAt":86},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Flearnexp\u002Fpage\u002F6\u002F":3,"category-page:zh-Hant:learnexp:6":4,"author-stats:zh-Hant:full":83},null,{"category":5,"posts":6,"total":81,"totalPages":82},"學習經驗",[7,21,29,36,43,49,55,62,68,74],{"url":8,"title":9,"date":10,"updated":11,"category":5,"tags":12,"description":19,"readingMinutes":20},"\u002Flearnexp\u002F20200112\u002F1752686187\u002F","來聊聊那些非常欠人教訓的提問 & 發問","2020-01-12 12:33:01","2023-01-05 20:52:38",[13,14,15,16,17,18],"提問","提問的修辭","提問的技巧","提問的智慧","欠人教訓的提問 & 發問","培養良好的提問與發問","身為一名工程師在開發上遇到問題並發問是一件非常常見的事情，但是許多人都會忽略所謂的「提問的智慧」，但是「該如何提問」卻又是一門學問甚至可以說是技能，當然更不用說有些人的提問方式真的真的非常欠人教訓以及翻白眼，所以今天就來分享一篇該如何提問會比較合適。","12",{"url":22,"title":23,"date":24,"updated":24,"category":5,"tags":25,"description":27,"readingMinutes":28},"\u002Flearnexp\u002F20191020\u002F1606493563\u002F","2019 MOPCON 一日遊記","2019-10-20 18:02:46",[26,5],"其他","由於 MOPCON 第一天有點事情所以只去第二天，這一篇就來記錄一下 MOPCON 第二天的一日遊吧。","4",{"url":30,"title":31,"date":32,"updated":32,"category":5,"tags":33,"description":34,"readingMinutes":35},"\u002Flearnexp\u002F20190930\u002F236119363\u002F","被車輪戰的六角同學會","2019-09-30 12:06:42",[26,5],"在 107\u002F09\u002F29 教師節當天六角學院舉辦了六角同學會，過程有一個自由聊天時間，所以這一篇就來記錄一下我被學員們車輪戰的過程吧(?!)","5",{"url":37,"title":38,"date":39,"updated":39,"category":5,"tags":40,"description":41,"readingMinutes":42},"\u002Flearnexp\u002F20190918\u002F2622329192\u002F","關於接案服務的這件事","2019-09-18 12:53:13",[26,5],"最近六角學院即將推出新服務，而這個服務本身就與我目前所做的事情有點關係，所以就寫這一篇文章來談談即將推出的新服務吧!","3",{"url":44,"title":45,"date":46,"updated":46,"category":5,"tags":47,"description":48,"readingMinutes":35},"\u002Flearnexp\u002F20190807\u002F1019052281\u002F","邀請講師的許多不小的小細節","2019-08-07 15:21:42",[26,5],"這一篇主要會記錄關於我邀請講師時，許多細節部分，因為大多時候我們都會忽略這些細節",{"url":50,"title":51,"date":52,"updated":52,"category":5,"tags":53,"description":54,"readingMinutes":42},"\u002Flearnexp\u002F20190723\u002F2343571780\u002F","關於寫部落格的心法","2019-07-23 21:14:06",[26,5],"最近都有人在詢問撰寫部落格到底對於自己求職 & 工作有沒有幫助，也有人問說該如何起手，所以我就稍微講一下我自己的寫部落格心法囉~",{"url":56,"title":57,"date":58,"updated":58,"category":5,"tags":59,"description":61,"readingMinutes":35},"\u002Flearnexp\u002F20190627\u002F2015018446\u002F","我在六角實習試著開發一個小專案這件事","2019-06-27 14:51:31",[60],"六角學院實習","這一篇是在回顧我在六角學院開發六角人才牆的過程與經驗，其中過程充滿著各種緊張與害怕阿阿阿阿阿~",{"url":63,"title":64,"date":65,"updated":65,"category":5,"tags":66,"description":64,"readingMinutes":67},"\u002Flearnexp\u002F20190608\u002F1415931352\u002F","學習不要預設目標及未來","2019-06-08 16:53:43",[26,5],"2",{"url":69,"title":70,"date":71,"updated":71,"category":5,"tags":72,"description":73,"readingMinutes":67},"\u002Flearnexp\u002F20190509\u002F3880255625\u002F","適當的休息也是學習的一種方式","2019-05-09 22:18:55",[26,5],"這陣子準備一個小作品同時也不停地幫忙一些私下找我聊聊的朋友們，發現有很多朋友都有一種不太好的習慣，這邊分享一下經驗:D",{"url":75,"title":76,"date":77,"updated":77,"category":5,"tags":78,"description":79,"readingMinutes":80},"\u002Flearnexp\u002F20190503\u002F3738458215\u002F","該如何制定自己的學習","2019-05-03 09:53:55",[26,5],"今天又寫了一篇心得分享，主要原因出在先前所撰寫的三篇文章該如何正確的學習前端技術&程式語言、學習心態調整及你願意犧牲多少來得到你想要的事物，很多人都來詢問該如何學習及撰寫筆記這方面的問題，所以我也寫一下我提供的建議。","6",63,7,{"postCount":84,"tagCount":85},1035,1009,1784011689317]