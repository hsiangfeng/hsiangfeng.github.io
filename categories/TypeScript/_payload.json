[{"data":1,"prerenderedAt":69},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002FTypeScript\u002F":3,"category-page:zh-Hant:TypeScript:1":4,"author-stats:zh-Hant:full":66},null,{"category":5,"posts":6,"total":64,"totalPages":65},"TypeScript",[7,17,25,32,39,45,51,57],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":15,"readingMinutes":16},"\u002FTypeScript\u002F20240930\u002F1917741270\u002F","掌握 TypeScript 泛型（Generics） & Vue3 泛型","2024-09-30 17:31:32",[5,12,13,14],"Generics","泛型","Vue3","泛型（Generics）是 TypeScript 中很重要的特性，它可以大幅度簡化程式碼的撰寫，並提高程式碼的可讀性，但是 TypeScript 的泛型也是初學者最難理解的部分之一，所以就來寫一篇文章來介紹 TypeScript 的泛型。","3",{"url":18,"title":19,"date":20,"updated":20,"category":5,"tags":21,"description":23,"readingMinutes":24},"\u002FTypeScript\u002F20231215\u002F812573601\u002F","閒聊 TypeScript 這個東西與為什麼用","2023-12-15 10:17:49",[5,22],"JavaScript","基本上 TypeScript 已經變成了許多開發者的必備技能之一，但是實際上專案滿多專案都還是處於 JavaScript 的狀態，並猶豫著要不要轉換成 TypeScript，所以這一篇我就來簡單分享自己對於 TypeScript 的看法，以及為什麼要用 TypeScript。","9",{"url":26,"title":27,"date":28,"updated":3,"category":5,"tags":29,"description":31,"readingMinutes":16},"\u002FTypeScript\u002F20190623\u002F3262185960\u002F","TypeScript 基礎入門-Class","2019-06-23 11:43:56",[30,22,5],"TypeScript 基礎入門","類別(class)這個是在 ES6 引入的，而這個功能又有何用處呢?讓我們來研究一下",{"url":33,"title":34,"date":35,"updated":3,"category":5,"tags":36,"description":37,"readingMinutes":38},"\u002FTypeScript\u002F20190622\u002F2385966784\u002F","TypeScript 基礎入門-Array","2019-06-22 22:27:26",[30,22,5],"接下來講到陣列的撰寫方式，其實與撰寫變數是太大的差異，這邊就來了解一下 TypeScript 中應該怎麼寫陣列吧","1",{"url":40,"title":41,"date":42,"updated":3,"category":5,"tags":43,"description":44,"readingMinutes":38},"\u002FTypeScript\u002F20190622\u002F3741788460\u002F","TypeScript 基礎入門-Function","2019-06-22 22:14:41",[30,22,5],"寫 JavaScript 的時候會非常撰寫 function，但 TypeScript 也有它的撰寫方式，讓我們來了解一下",{"url":46,"title":47,"date":48,"updated":3,"category":5,"tags":49,"description":50,"readingMinutes":38},"\u002FTypeScript\u002F20190622\u002F2982589304\u002F","TypeScript 基礎入門-混和型別","2019-06-22 21:56:38",[30,22,5],"前面講到 TypeScript 有所謂的型別推論的能力，在這邊再來講一個東西混和型別，這個東西又是什麼呢?讓我們來了解一下",{"url":52,"title":53,"date":54,"updated":3,"category":5,"tags":55,"description":56,"readingMinutes":38},"\u002FTypeScript\u002F20190622\u002F2739569432\u002F","TypeScript 基礎入門-型別推論","2019-06-22 15:49:05",[30,22,5],"前面已經了解該如何設置變數型別的方式，但是尾段其實也有講到如果不設置型別也是會編譯成功，但是實際上真的是這樣子嗎?這邊就來講講 TypeScript 裡面有一個很特別的東西，叫做型別推論，就算你不宣告型別 TypeScript 也會自己判定，來了解看看吧~",{"url":58,"title":59,"date":60,"updated":3,"category":5,"tags":61,"description":62,"readingMinutes":63},"\u002FTypeScript\u002F20190622\u002F3955309115\u002F","TypeScript 基礎入門-變數篇","2019-06-22 15:06:22",[30,22,5],"身邊滿多前端工程師都會接觸到 TypeScript，所以這邊紀錄一下 TypeScript 基礎入門","2",8,1,{"postCount":67,"tagCount":68},1035,1009,1784013044539]