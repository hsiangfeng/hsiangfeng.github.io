[{"data":1,"prerenderedAt":84},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fjavascript\u002Fpage\u002F16\u002F":3,"category-page:zh-Hant:javascript:16":4,"author-stats:zh-Hant:full":81},null,{"category":5,"posts":6,"total":79,"totalPages":80},"JavaScript",[7,18,27,35,42,48,54,60,67,73],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20200309\u002F2684951958\u002F","PixiJS V5 教學 (5) - Texture","2020-03-09 08:15:00",[12,13,5,14,15],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","有引入文字那麼就會有引入圖片啦~而 PIXI 會使用 GPU 以及 WebGL 來渲染圖片，而圖片需要經過處理才能夠使用的，而通常處理好的圖片都會稱為 Texture。","2",{"url":19,"title":20,"date":21,"updated":3,"category":5,"tags":22,"description":25,"readingMinutes":26},"\u002Fjavascript\u002F20200308\u002F3384986223\u002F","Fetch API 到底是 ESMAScript6 還是 Web APIs?","2020-03-08 12:07:26",[5,23,24],"ESMAScript6","Fetch API","Fetch API 是一個很多人會誤解的一個語法，最大誤解大概就是無法區分這一個語法到底是屬於 ECMAScript6 還是 Web APIs，所以這一篇來詳解一下吧。","3",{"url":28,"title":29,"date":30,"updated":3,"category":5,"tags":31,"description":34,"readingMinutes":26},"\u002Fjavascript\u002F20200307\u002F1405700237\u002F","JavaScript 核心觀念(1)-執行環境與作用域-JavaScript 運作方式","2020-03-07 21:37:04",[5,32,33],"JavaScript 核心篇","執行環境與作用域","第一篇將會來了解 JavaScript 的運作模式，",{"url":36,"title":37,"date":38,"updated":3,"category":5,"tags":39,"description":40,"readingMinutes":41},"\u002Fjavascript\u002F20200307\u002F318160061\u002F","JavaScript 核心觀念(0)-目錄及前言","2020-03-07 21:27:49",[5,32],"JavaScript 核心篇是基於六角學院的線上影音課程而撰寫的系列文章，雖然自己本身已經有上過 JavaScript 奇怪的部份，但每一位講者都有屬於他的講解方式，所以這一篇也來開始做一次紀錄以及學習囉。","4",{"url":43,"title":44,"date":45,"updated":3,"category":5,"tags":46,"description":47,"readingMinutes":17},"\u002Fjavascript\u002F20200302\u002F3104976087\u002F","PixiJS V5 教學 (4) - Text","2020-03-02 09:00:10",[12,13,5,14,15],"前一篇介紹了 Container，接下來要來看介紹前一篇所使用到的語法，也就是 new PIXI.Text()。",{"url":49,"title":50,"date":51,"updated":3,"category":5,"tags":52,"description":53,"readingMinutes":17},"\u002Fjavascript\u002F20200224\u002F4132682256\u002F","PixiJS V5 教學 (3) - Container","2020-02-24 08:17:13",[12,13,5,14,15],"前面基本知識也算是講得差不多，接下來將會介紹 PIXI 中的一個重要的東西，也就是 Container。",{"url":55,"title":56,"date":57,"updated":3,"category":5,"tags":58,"description":59,"readingMinutes":17},"\u002Fjavascript\u002F20200217\u002F4014508881\u002F","PixiJS V5 教學 (2) - WebGL 以及 Renderer","2020-02-17 00:05:28",[12,13,5,14,15],"這一篇會介紹一下前一篇沒有介紹的地方，舉例來講 WebGL 是什麼以及 Renderer 等語法跟說明。",{"url":61,"title":62,"date":63,"updated":3,"category":5,"tags":64,"description":66,"readingMinutes":17},"\u002Fjavascript\u002F20200210\u002F3949702627\u002F","PixiJS V5 教學 (1) - PixiJS 建立","2020-02-10 00:00:10",[12,13,5,65,15],"Canvasgit","Pixi.js 是一款基於 JavaScript 的 2D 引擎所開發的框架，主要常見於開發 2D 網頁遊戲，接下來就來快速入門學習吧 :D",{"url":68,"title":69,"date":70,"updated":3,"category":5,"tags":71,"description":72,"readingMinutes":17},"\u002Fjavascript\u002F20200203\u002F3949702627\u002F","PixiJS V5 教學 (0) - 前言＆目錄","2020-02-03 08:36:41",[12,13,5,14,15],"為什麼要寫一個 PixiJS V5 系列教學？這一篇是六角學院鼠年全馬鐵人挑戰的開頭文，聊聊我為什麼會踩進 PixiJS、適合用在哪些情境， 以及這個系列接下來會涵蓋哪些章節主題。",{"url":74,"title":75,"date":76,"updated":3,"category":5,"tags":77,"description":78,"readingMinutes":17},"\u002Fjavascript\u002F20200117\u002F3217748743\u002F","JavaScript 的 if 跟 switch 效能","2020-01-17 13:28:36",[5],"該使用 if 還是 switch 一直以來都是一個話題，所以這時候就來驗證一下這兩者差異以及效能上的差別。",220,22,{"postCount":82,"tagCount":83},1035,1009,1784012761152]