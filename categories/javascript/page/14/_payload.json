[{"data":1,"prerenderedAt":81},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fjavascript\u002Fpage\u002F14\u002F":3,"category-page:zh-Hant:javascript:14":4,"author-stats:zh-Hant:full":78},null,{"category":5,"posts":6,"total":76,"totalPages":77},"JavaScript",[7,18,27,33,39,45,51,58,64,70],{"url":8,"title":9,"date":10,"updated":3,"category":5,"tags":11,"description":16,"readingMinutes":17},"\u002Fjavascript\u002F20200525\u002F1127214799\u002F","PixiJS V5 教學 (16) - Game HP","2020-05-25 09:00:08",[12,13,5,14,15],"PixiJS V5 教學","PixiJS","Canvas","w3HexSchool","前一篇開始我們開始有那麼一點像是在製作遊戲，所以接下來會來介紹一下遊戲中的血條該如何製作。","1",{"url":19,"title":20,"date":21,"updated":3,"category":5,"tags":22,"description":25,"readingMinutes":26},"\u002Fjavascript\u002F20200524\u002F995184384\u002F","JavaScript 核心觀念(8)-執行環境與作用域-記憶體存放與釋放","2020-05-24 10:56:06",[5,23,24],"JavaScript 核心篇","執行環境與作用域","接下來講一下記憶體的回收機制。","2",{"url":28,"title":29,"date":30,"updated":3,"category":5,"tags":31,"description":32,"readingMinutes":26},"\u002Fjavascript\u002F20200518\u002F1745009932\u002F","PixiJS V5 教學 (15) - Bump","2020-05-18 08:20:50",[12,13,5,14,15],"前一篇我們學習如何使用 PIXI 建立幾何圖形，那麼接下來要學習 PIXI 中一個我認為滿特別的東西，也就是碰撞檢測。",{"url":34,"title":35,"date":36,"updated":3,"category":5,"tags":37,"description":38,"readingMinutes":26},"\u002Fjavascript\u002F20200511\u002F1897499725\u002F","PixiJS V5 教學 (14) - Graphics(2)","2020-05-11 07:30:15",[12,13,5,14,15],"前一篇介紹了基本的幾何圖形的繪畫，但是只介紹矩形，其實 PIXI 還有其他幾何圖形的繪畫，所以接下來就來講其他的幾何圖形囉",{"url":40,"title":41,"date":42,"updated":3,"category":5,"tags":43,"description":44,"readingMinutes":26},"\u002Fjavascript\u002F20200510\u002F2581786882\u002F","JavaScript 核心觀念(7)-執行環境與作用域-not defined VS undefined","2020-05-10 21:27:11",[5,23,24],"not defined 以及 undefined 也是 JavaScript 中相當重要的觀念，若可以搞懂這兩者的差異，對於 debug 上是非常有幫助的。",{"url":46,"title":47,"date":48,"updated":3,"category":5,"tags":49,"description":50,"readingMinutes":26},"\u002Fjavascript\u002F20200504\u002F1045961354\u002F","PixiJS V5 教學 (13) - Graphics(1)","2020-05-04 08:10:50",[12,13,5,14,15],"接下來將會來介紹一點使用 PIXI 繪畫幾何圖形，最後會再來試著整合前面的技巧。",{"url":52,"title":53,"date":54,"updated":3,"category":5,"tags":55,"description":56,"readingMinutes":57},"\u002Fjavascript\u002F20200503\u002F1924910570\u002F","JavaScript 核心觀念(6)-執行環境與作用域-提升","2020-05-03 14:45:13",[5,23,24],"提升(Hoisting) 可以說是我最喜好的一個觀念，JavaScript 中舉凡函式、變數都有這個觀念存在。","3",{"url":59,"title":60,"date":61,"updated":3,"category":5,"tags":62,"description":63,"readingMinutes":17},"\u002Fjavascript\u002F20200502\u002F1231063032\u002F","JavaScript 核心觀念(5)-執行環境與作用域-範圍鍊","2020-05-02 21:36:56",[5,23,24],"接下來講講為什麼明明宣告在外層的變數甚至是不同地方的函式，卻可以正確的呼叫與執行。",{"url":65,"title":66,"date":67,"updated":3,"category":5,"tags":68,"description":69,"readingMinutes":26},"\u002Fjavascript\u002F20200502\u002F2917226562\u002F","JavaScript 核心觀念(4)-執行環境與作用域-執行環境與執行堆疊","2020-05-02 15:29:53",[5,23,24],"若沒有搞清楚執行環境與執行堆疊的觀念在後續開發上其實會很混亂。",{"url":71,"title":72,"date":73,"updated":3,"category":5,"tags":74,"description":75,"readingMinutes":17},"\u002Fjavascript\u002F20200427\u002F658713547\u002F","PixiJS V5 教學 (12) - mousemoveEvent(2)","2020-04-27 08:59:26",[12,13,5,14,15],"接下來講講關於 PIXI 其他的滑鼠操作吧~",220,22,{"postCount":79,"tagCount":80},1036,1011,1784087311063]