[{"data":1,"prerenderedAt":92},["ShallowReactive",2],{"header-locale:\u002Fcategories\u002Fvscode\u002F":3,"category-page:zh-Hant:vscode:1":4,"author-stats:zh-Hant:full":89},null,{"category":5,"posts":6,"total":87,"totalPages":88},"VSCode",[7,16,26,33,43,49,57,63,73,80],{"url":8,"title":9,"date":10,"updated":10,"category":5,"tags":11,"description":14,"readingMinutes":15},"\u002Fvscode\u002F20250424\u002F4258825567\u002F","VSCode 找不到 Git，安裝它或使用 \"git.path\" 設置","2025-04-24 09:52:23",[5,12,13],"Git","障礙排除","VSCode 久違打開就噴「找不到 Git，請安裝它或使用 git.path 設置」？這一篇分享在 Git 明明已經裝好的情況下，怎麼透過修改 VSCode setting.json 的 git.path 手動指定 Git 路徑解決問題。","1",{"url":17,"title":18,"date":19,"updated":19,"category":5,"tags":20,"description":24,"readingMinutes":25},"\u002Fvscode\u002F20240908\u002F3488366595\u002F","GitHub Copilot 好難用？說不定是你不懂 Copilot 之技巧全攻略不藏私！","2024-09-08 13:06:00",[21,22,23],"GitHub Copilot","Visual Studio Code","開發技巧","身為用了 GitHub Copilot 一陣子的使用者，這一篇我將會分享一些我使用 GitHub Copilot 的心得與技巧，讓大家開發時更加得心應手，那麼廢話就不多說，我們來聊聊 GitHub Copilot 吧！","5",{"url":27,"title":28,"date":29,"updated":29,"category":5,"tags":30,"description":32,"readingMinutes":15},"\u002Fvscode\u002F20231026\u002F54606935\u002F","VSCode 上 Vue 自訂元件失去高亮","2023-10-26 11:03:07",[13,5,31],"Vue","最近開發發現 Volar 的自訂元件高亮功能好像怪怪的，所以記錄一下原因。",{"url":34,"title":35,"date":36,"updated":36,"category":5,"tags":37,"description":41,"readingMinutes":42},"\u002Fvscode\u002F20230921\u002F1985180173\u002F","Visual Studio Code 自訂折疊區塊","2023-09-21 09:43:55",[5,38,39,40],"實用設定","Setting","開發","VSCode 預設可以折疊函式但不能自訂區塊？其實只要用 #region 跟 #endregion 包住程式碼就能自訂折疊範圍，這一篇示範這個少人知道但相當實用的小技巧。","2",{"url":44,"title":45,"date":46,"updated":3,"category":5,"tags":47,"description":48,"readingMinutes":15},"\u002Fvscode\u002F20220712\u002F2790345819\u002F","VSCode 1.69 !+tab 無效問題(更新)","2022-07-12 09:55:45",[5,13],"最近 VSCode 更新到 1.69 之後以往常用的 !+tab 會失去效用，所以這邊紀錄一下解決方式。",{"url":50,"title":51,"date":52,"updated":3,"category":5,"tags":53,"description":56,"readingMinutes":15},"\u002Fvscode\u002F20211123\u002F335355052\u002F","將 VSCode 的程式碼行數改成相對(值)行數","2021-11-23 14:29:07",[54,55,5],"Vim","Vi","最近開始已經慢慢在嘗試使用 vim\u002Fvi 在 VSCode 上面開發以及撰寫文章，所以這邊就順便紀錄一下如何開啟 VSCode 的相對行數顯示。",{"url":58,"title":59,"date":60,"updated":3,"category":5,"tags":61,"description":62,"readingMinutes":15},"\u002Fvscode\u002F20210927\u002F2674618084\u002F","VSCode terminal.integrated.shell.osx 屬性失效","2021-09-27 10:08:06",[5,13],"最近 VSCode 發現終端機的 terminal.integrated.shell.osx 設置失效了，所以記錄一下問題跟解決方式。",{"url":64,"title":65,"date":66,"updated":3,"category":5,"tags":67,"description":71,"readingMinutes":72},"\u002Fvscode\u002F20210709\u002F4359299\u002F","VSCode 自動修正 ESLint 錯誤","2021-07-09 09:41:16",[5,68,69,70],"ESLint","Prettier ESLint","Prettier","這篇稍微寫一下如何使用 VSCode 做到自動修正 ESLint 警告與錯誤，其中也包含格式化的方式。","3",{"url":74,"title":75,"date":76,"updated":3,"category":5,"tags":77,"description":79,"readingMinutes":42},"\u002Fvscode\u002F20210704\u002F1752541725\u002F","簡單幾步驟中文化 VS Code 或是切換語系！","2021-07-04 11:34:50",[5,78],"中文化","這一篇稍微紀錄一下自己很常用的 VS Code(Visual Studio Code) 如何中文化以及切換其他國家語系。",{"url":81,"title":82,"date":83,"updated":84,"category":5,"tags":85,"description":86,"readingMinutes":72},"\u002Fvscode\u002F20210512\u002F2779926364\u002F","身為開發者，我會建議你使用的 VSCode 的實用設定","2021-05-12 09:02:38","2023-04-16 20:01:00",[5,38,39,40],"工欲善必先利其器，身為長期有在 VSCode 的工程師來講，如果可以多了解自己的編輯器設定，其實可以幫助自己在實際開發上的方便性以及除錯，因此這一篇我就紀錄與分享一下有哪些 VSCode 的實用設定吧！",14,2,{"postCount":90,"tagCount":91},1035,1009,1784013048480]