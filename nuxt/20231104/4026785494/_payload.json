386],{"class":75},[69,651,652],{"class":71,"line":205},[69,653,175],{"class":75},[69,655,656,658,660],{"class":71,"line":215},[69,657,193],{"class":75},[69,659,80],{"class":79},[69,661,87],{"class":75},[12,663,664],{},"透過這個最簡單的方式，當你 API 發生錯誤之後，也可以繼續觸發 API 了！",[12,666,667],{},[15,668],{"alt":669,"src":670},"恢復正常","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt_usefetch_error\u002FNov-04-2023%2000-49-30(1).gif",[12,672,673,674,676,677,680,681,684],{},"基本上 ",[48,675,522],{}," 回傳的資料會是一個 ",[48,678,679],{},"ref","，所以我們就是利用 Proxy 的特性來解決這個問題，也剛好 Nuxt3 官方沒有替回傳的資料加上 ",[48,682,683],{},"readonly","，不然我們就無法這樣子做了。",[12,686,687],{},"但是這樣子做有一個問題，就是當你的 API 有發生錯誤時，你就無法吐出相對應後端給予的錯誤訊息，所以其實你可以這樣改寫：",[60,689,691],{"className":62,"code":690,"language":64,"meta":65,"style":65},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n\n  if(error.value) {\n    const cacheError = JSON.parse(JSON.stringify(error.value))\n    error.value = null\n    console.log(cacheError)\n  }\n}\n\u003C\u002Fscript>\n",[48,692,693,703,717,737,745,757,761,765,769,775,804,812,821,825,829],{"__ignoreMap":65},[69,694,695,697,699,701],{"class":71,"line":72},[69,696,76],{"class":75},[69,698,80],{"class":79},[69,700,84],{"class":83},[69,702,87],{"class":75},[69,704,705,707,709,711,713,715],{"class":71,"line":90},[69,706,94],{"class":93},[69,708,98],{"class":97},[69,710,101],{"class":93},[69,712,104],{"class":75},[69,714,107],{"class":93},[69,716,110],{"class":75},[69,718,719,721,723,725,727,729,731,733,735],{"class":71,"line":113},[69,720,312],{"class":93},[69,722,569],{"class":75},[69,724,526],{"class":147},[69,726,574],{"class":75},[69,728,238],{"class":93},[69,730,579],{"class":97},[69,732,119],{"class":75},[69,734,123],{"class":122},[69,736,126],{"class":75},[69,738,739,741,743],{"class":71,"line":129},[69,740,132],{"class":75},[69,742,135],{"class":122},[69,744,138],{"class":75},[69,746,747,749,751,753,755],{"class":71,"line":141},[69,748,144],{"class":75},[69,750,148],{"class":147},[69,752,151],{"class":75},[69,754,154],{"class":97},[69,756,157],{"class":75},[69,758,759],{"class":71,"line":160},[69,760,163],{"class":75},[69,762,763],{"class":71,"line":166},[69,764,169],{"class":75},[69,766,767],{"class":71,"line":172},[69,768,182],{"emptyLinePlaceholder":181},[69,770,771,773],{"class":71,"line":178},[69,772,332],{"class":93},[69,774,624],{"class":75},[69,776,777,780,783,785,788,790,793,795,797,799,801],{"class":71,"line":185},[69,778,779],{"class":93},"    const",[69,781,782],{"class":147}," cacheError",[69,784,101],{"class":93},[69,786,787],{"class":147}," JSON",[69,789,151],{"class":75},[69,791,792],{"class":97},"parse",[69,794,119],{"class":75},[69,796,148],{"class":147},[69,798,151],{"class":75},[69,800,154],{"class":97},[69,802,803],{"class":75},"(error.value))\n",[69,805,806,808,810],{"class":71,"line":190},[69,807,629],{"class":75},[69,809,238],{"class":93},[69,811,634],{"class":147},[69,813,814,816,818],{"class":71,"line":200},[69,815,639],{"class":75},[69,817,642],{"class":97},[69,819,820],{"class":75},"(cacheError)\n",[69,822,823],{"class":71,"line":205},[69,824,386],{"class":75},[69,826,827],{"class":71,"line":215},[69,828,175],{"class":75},[69,830,831,833,835],{"class":71,"line":226},[69,832,193],{"class":75},[69,834,80],{"class":79},[69,836,87],{"class":75},[12,838,839],{},"這樣至少你就可以拿到後端給予的錯誤訊息並吐出來給使用者。",[12,841,842,843,845],{},"那麼這個解法也只是一個過渡期而已，官方預計下個版本就會修正了，所以如果可以的話，我滿推薦你直接升級至 3.8.0 以上，因為這個問題其實會影響到很多地方，舉凡...像是登入、表單驗證等等，因此如果你的專案有使用到 ",[48,844,522],{}," 的話，那麼我會建議你注意一下唷～",[847,848,851],"callout",{"title":849,"type":850},"Note","note",[12,852,853,854,859],{},"目前這個問題 Nuxt 官方已經在 ",[433,855,858],{"href":856,"rel":857},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Freleases\u002Ftag\u002Fv3.8.1",[437],"3.8.1"," 修正囉～",[861,862,863],"style",{},"html pre.shiki code .s8XSl, html code.shiki .s8XSl{--shiki-light:#24292E;--s