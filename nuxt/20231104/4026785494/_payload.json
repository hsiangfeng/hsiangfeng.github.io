[69,189,191,194,196],{"class":71,"line":190},11,[69,192,193],{"class":75},"\u003C\u002F",[69,195,80],{"class":79},[69,197,87],{"class":75},[69,199,201],{"class":71,"line":200},12,[69,202,182],{"emptyLinePlaceholder":181},[69,204,206,208,211],{"class":71,"line":205},13,[69,207,76],{"class":75},[69,209,210],{"class":79},"template",[69,212,87],{"class":75},[69,214,216,219,222],{"class":71,"line":215},14,[69,217,218],{"class":75},"  \u003C",[69,220,221],{"class":79},"div",[69,223,87],{"class":75},[69,225,227,230,233,236,239,242,245,247],{"class":71,"line":226},15,[69,228,229],{"class":75},"    \u003C",[69,231,232],{"class":79},"button",[69,234,235],{"class":83}," @click",[69,237,238],{"class":75},"=",[69,240,241],{"class":122},"\"apiPostError\"",[69,243,244],{"class":75},">點我發生錯誤\u003C\u002F",[69,246,232],{"class":79},[69,248,87],{"class":75},[69,250,252,255,257],{"class":71,"line":251},16,[69,253,254],{"class":75},"  \u003C\u002F",[69,256,221],{"class":79},[69,258,87],{"class":75},[69,260,262,264,266],{"class":71,"line":261},17,[69,263,193],{"class":75},[69,265,210],{"class":79},[69,267,87],{"class":75},[12,269,270,271,274],{},"而這個 ",[48,272,273],{},"\u002Fapi\u002Fhello"," 也只是我用 Nuxt3 的 API Routes 建立的一個 API",[60,276,280],{"className":277,"code":278,"language":279,"meta":65,"style":65},"language-js shiki shiki-themes github-light github-light github-dark-high-contrast","export default defineEventHandler((event) => {\n  const id = parseInt(event.context.params.id)\n\n  if (!Number.isInteger(id)) {\n    throw createError({\n      statusCode: 400,\n      statusMessage: 'ID should be an integer',\n    })\n  }\n  return 'All good'\n})\n","js",[48,281,282,308,324,328,348,358,367,377,382,387,395],{"__ignoreMap":65},[69,283,284,287,290,293,297,301,304,306],{"class":71,"line":72},[69,285,286],{"class":93},"export",[69,288,289],{"class":93}," default",[69,291,292],{"class":97}," defineEventHandler",[69,294,296],{"class":295},"sTzn1","((",[69,298,300],{"class":299},"syBk-","event",[69,302,303],{"class":295},") ",[69,305,107],{"class":93},[69,307,110],{"class":75},[69,309,310,313,316,318,321],{"class":71,"line":90},[69,311,312],{"class":93},"  const",[69,314,315],{"class":147}," id",[69,317,101],{"class":93},[69,319,320],{"class":97}," parseInt",[69,322,323],{"class":75},"(event.context.params.id)\n",[69,325,326],{"class":71,"line":113},[69,327,182],{"emptyLinePlaceholder":181},[69,329,330,333,336,339,342,345],{"class":71,"line":129},[69,331,332],{"class":93},"  if",[69,334,335],{"class":75}," (",[69,337,338],{"class":93},"!",[69,340,341],{"class":75},"Number.",[69,343,344],{"class":97},"isInteger",[69,346,347],{"class":75},"(id)) {\n",[69,349,350,353,356],{"class":71,"line":141},[69,351,352],{"class":93},"    throw",[69,354,355],{"class":97}," createError",[69,357,157],{"class":75},[69,359,360,363,365],{"class":71,"line":160},[69,361,362],{"class":75},"      statusCode: ",[69,364,54],{"class":147},[69,366,138],{"class":75},[69,368,369,372,375],{"class":71,"line":166},[69,370,371],{"class":75},"      statusMessage: ",[69,373,374],{"class":122},"'ID should be an integer'",[69,376,138],{"class":75},[69,378,379],{"class":71,"line":172},[69,380,381],{"class":75},"    })\n",[69,383,384],{"class":71,"line":178},[69,385,386],{"class":75},"  }\n",[69,388,389,392],{"class":71,"line":185},[69,390,391],{"class":93},"  return",[69,393,394],{"class":122}," 'All good'\n",[69,396,397,400],{"class":71,"line":190},[69,398,399],{"class":75},"}",[69,401,402],{"class":295},")\n",[12,404,405],{},"那...這個問題會影響在哪邊呢？如果使用者在你的畫面上登入時，第一次輸入錯誤的帳號密碼，接著第二次輸入正確的帳號密碼，那麼就會發生無法登入的問題，因為 API 無法被觸發。",[20,407,408],{"id":408},"解決方式",[12,410,411],{},"剛剛有提到一個情境是關於登入的問題，我們使用者一定是很容易會輸入錯誤的帳號密碼，所以不管怎樣這個問題是必須被解決的。",[12,413,414,415,418,419,422],{},"基本上只要發生 ",[48,416,417],{},"4xx"," or ",[48,420,421],{},"5xx"," 都是會觸發這個問題的，但是我們只要重新整理畫面後，就又可以再次觸發 API，這樣就代表一件事情，也就是我們的 Error 被 Catch 住了。",[12,424,425],{},"剛好我也有在官方 Issues 找到相關問題",[427,428,429],"ul",{},[430,431,432],"li",{},[433,434,438],"a",{"href":435,"rel":436},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fissues\u002F24008",[437],"nofollow","useFetch cache Error response and never load it again",[12,440,441,442,447],{},"而官方也發起了一個 PR（",[433,443,446],{"href":444,"rel":445},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fpull\u002F23889\u002Ffiles",[437],"fix(nuxt): only skip refetching errors when hydrating","）來解決這個問題，內容主要是將...",[60,449,451],{"className":277,"code":450,"language":279,"meta":65,"style":65},"if (asyncData.error.value || (fetchOnServer && nuxt.isHydrating && hasCachedData())) ...\n",[48,452,453],{"__ignoreMap":65},[69,454,455,458,461,464,467,470,473,475,478,481],{"class":71,"line":72},[69,456,457],{"class":93},"if",[69,459,460],{"class":75}," (asyncData.error.value ",[69,462,463],{"class":93},"||",[69,465,466],{"class":75}," (fetchOnServer ",[69,468,469],{"class":93},"&&",[69,471,472],{"class":75}," nuxt.isHydrating ",[69,474,469],{"class":93},[69,476,477],{"class":97}," hasCachedData",[69,479,480],{"class":75},"())) ",[69,482,483],{"class":93},"...\n",[12,485,486],{},"調整為",[60,488,490],{"className":277,"code":489,"language":279,"meta":65,"style":65},"if (fetchOnServer && nuxt.isHydrating && (asyncData.error.value || hasCachedData())) ...\n",[48,491,492],{"__ignoreMap":65},[69,493,494,496,498,500,502,504,506,508,510,512],{"class":71,"line":72},[69,495,457],{"class":93},[69,497,466],{"class":75},[69,499,469],{"class":93},[69,501,472],{"class":75},[69,503,469],{"class":93},[69,505,460],{"class":75},[69,507,463],{"class":93},[69,509,477],{"class":97},[69,511,480],{"class":75},[69,513,483],{"class":93},[12,515,516],{},"雖然官方已經 Merge 進去了，但還沒有釋出新的版本，所以我們只能先自己解決這個問題 QQ",[12,518,519,520,523,524,527,528,530,531],{},"講了那麼多，我們該怎麼解決呢？這邊我們可以用最簡單的方式，也就是將 ",[48,521,522],{},"useFetch"," 的 ",[48,525,526],{},"error"," 解構出來，接著當 ",[48,529,526],{}," 發生錯誤時，就將它設定為 ",[48,532,533],{},"null",[60,535,537],{"className":62,"code":536,"language":64,"meta":65,"style":65},"\u003Cscript setup>\nconst apiPostEr