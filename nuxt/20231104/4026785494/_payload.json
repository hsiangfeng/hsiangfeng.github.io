 and never load it again",[12,432,433,434,439],{},"而官方也發起了一個 PR（",[425,435,438],{"href":436,"rel":437},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fpull\u002F23889\u002Ffiles",[429],"fix(nuxt): only skip refetching errors when hydrating","）來解決這個問題，內容主要是將...",[60,441,443],{"className":276,"code":442,"language":278,"meta":65,"style":65},"if (asyncData.error.value || (fetchOnServer && nuxt.isHydrating && hasCachedData())) ...\n",[48,444,445],{"__ignoreMap":65},[69,446,447,450,453,456,459,462,465,467,470,473],{"class":71,"line":72},[69,448,449],{"class":93},"if",[69,451,452],{"class":75}," (asyncData.error.value ",[69,454,455],{"class":93},"||",[69,457,458],{"class":75}," (fetchOnServer ",[69,460,461],{"class":93},"&&",[69,463,464],{"class":75}," nuxt.isHydrating ",[69,466,461],{"class":93},[69,468,469],{"class":97}," hasCachedData",[69,471,472],{"class":75},"())) ",[69,474,475],{"class":93},"...\n",[12,477,478],{},"調整為",[60,480,482],{"className":276,"code":481,"language":278,"meta":65,"style":65},"if (fetchOnServer && nuxt.isHydrating && (asyncData.error.value || hasCachedData())) ...\n",[48,483,484],{"__ignoreMap":65},[69,485,486,488,490,492,494,496,498,500,502,504],{"class":71,"line":72},[69,487,449],{"class":93},[69,489,458],{"class":75},[69,491,461],{"class":93},[69,493,464],{"class":75},[69,495,461],{"class":93},[69,497,452],{"class":75},[69,499,455],{"class":93},[69,501,469],{"class":97},[69,503,472],{"class":75},[69,505,475],{"class":93},[12,507,508],{},"雖然官方已經 Merge 進去了，但還沒有釋出新的版本，所以我們只能先自己解決這個問題 QQ",[12,510,511,512,515,516,519,520,522,523],{},"講了那麼多，我們該怎麼解決呢？這邊我們可以用最簡單的方式，也就是將 ",[48,513,514],{},"useFetch"," 的 ",[48,517,518],{},"error"," 解構出來，接著當 ",[48,521,518],{}," 發生錯誤時，就將它設定為 ",[48,524,525],{},"null",[60,527,529],{"className":62,"code":528,"language":64,"meta":65,"style":65},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n\n  