lass":75},[69,651,80],{"class":79},[69,653,87],{"class":75},[12,655,656],{},"透過這個最簡單的方式，當你 API 發生錯誤之後，也可以繼續觸發 API 了！",[12,658,659],{},[15,660],{"alt":661,"src":662},"恢復正常","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt_usefetch_error\u002FNov-04-2023%2000-49-30(1).gif",[12,664,665,666,668,669,672,673,676],{},"基本上 ",[48,667,514],{}," 回傳的資料會是一個 ",[48,670,671],{},"ref","，所以我們就是利用 Proxy 的特性來解決這個問題，也剛好 Nuxt3 官方沒有替回傳的資料加上 ",[48,674,675],{},"readonly","，不然我們就無法這樣子做了。",[12,678,679],{},"但是這樣子做有一個問題，就是當你的 API 有發生錯誤時，你就無法吐出相對應後端給予的錯誤訊息，所以其實你可以這樣改寫：",[60,681,683],{"className":62,"code":682,"language":64,"meta":65,"style":65},"\u003Cscript setup>\nconst apiPostError = () => {\n  const { error } = useFetch('\u002Fapi\u002Fhello', {\n    method: 'POST',\n    body: JSON.stringify({\n    }),\n  })\n\n  if(error.value) {\n    const cacheError = JSON.parse(JSON.stringify(error.value))\n    error.value = null\n    console.log(cacheError)\n  }\n}\n\u003C\u002Fscript>\n",[48,684,685,695,709,729,737,749,753,757,761,767,796,804,813,817,821],{"__ignoreMap":65},[69,686,687,689,691,693],{"class":71,"line":72},[69,688,76],{"class":75},[69,690,80],{"class":79},[69,692,84],{"class":83},[69,694,87],{"class":75},[69,696,697,699,701,703,705,707],{"class":71,"line":90},[69,698,94],{"class":93},[69,700,98],{"class":97},[69,702,101],{"class":93},[69,704,104],{"class":75},[69,706,107],{"class":93},[69,708,110],{"class":75},[69,710,711,713,715,717,719,721,723,725,727],{"class":71,"line":113},[69,712,304],{"class":93},[69,714,561],{"class":75},[69,716,518],{"class":83},[69,718,566],{"class":75},[69,720,237],{"class":93},[69,722,571],{"class":97},[69,724,119],{"class":75},[69,726,123],{"class":122},[69,728,126],{"class":75},[69,730,731,733,735],{"class":71,"line":129},[69,732,132],{"class":75},[69,734,135],{"class":122},[69,736,138],{"class":75},[69,738,739,741,743,745,747],{"class":71,"line":141},[69,740,144],{"class":75},[69,742,147],{"class":83},[69,744,150],{"class":75},[69,746,153],{"class":97},[69,748,156],{"class":75},[69,750,751],{"class":71,"line":159},[69,752,162],{"class":75},[69,754,755],{"class":71,"line":165},[69,756,168],{"class":75},[69,758,759],{"class":71,"line":171},[69,760,181],{"emptyLinePlaceholder":180},[69,762,763,765],{"class":71,"line":177},[69,764,324],{"class":93},[69,766,616],{"class":75},[69,768,769,772,775,777,780,782,785,787,789,791,793],{"class":71,"line":184},[69,770,771],{"class":93},"    const",[69,773,774],{"class":83}," cacheError",[69,776,101],{"class":93},[69,778,779],{"class":83}," JSON",[69,781,150],{"class":75},[69,783,784],{"class":97},"parse",[69,786,119],{"class":75},[69,788,147],{"class":83},[69,790,150],{"class":75},[69,792,153],{"class":97},[69,794,795],{"class":75},"(error.value))\n",[69,797,798,800,802],{"class":71,"line":189},[69,799,621],{"class":75},[69,801,237],{"class":93},[69,803,626],{"class":83},[69,805,806,808,810],{"class":71,"line":199},[69,807,631],{"class":75},[69,809,634],{"class":97},[69,811,812],{"class":75},"(cacheError)\n",[69,814,815],{"class":71,"line":204},[69,816,378],{"class":75},[69,818,819],{"class":71,"line":214},[69,820,174],{"class":75},[69,822,823,825,827],{"class":71,"line":225},[69,824,192],{"class":75},[69,826,80],{"class":79},[69,828,87],{"class":75},[12,830,831],{},"這樣至少你就可以拿到後端給予的錯誤訊息並吐出來給使用者。",[12,833,834,835,837],{},"那麼這個解法也只是一個過渡期而已，官方預計下個版本就會修正了，所以如果可以的話，我滿推薦你直接升級至 3.8.0 以上，因為這個問題其實會影響到很多地方，舉凡...像是登入、表單驗證等等，因此如果你的專案有使用到 ",[48,836,514],{}," 的話，那麼我會建議你注意一下唷～",[839,840,841],"blockquote",{},[12,842,843,847,848,853],{},[844,845,846],"strong",{},"Note","\n目前這個問題 Nuxt 官方已經在 ",[425,849,852],{"href":850,"rel":851},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Freleases\u002Ftag\u002Fv3.8.1",[429],"3.8.1"," 修正囉～",[855,856,857],"style",{},"html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sKpQp, html code.shiki .sKpQp{--shiki-default:#72F088}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#