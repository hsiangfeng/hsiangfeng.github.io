className":28,"code":78,"language":30,"meta":31,"style":31},"pnpm install\n",[33,80,81],{"__ignoreMap":31},[36,82,83,85],{"class":38,"line":39},[36,84,75],{"class":42},[36,86,87],{"class":46}," install\n",[16,89,90],{},"安裝完畢後，就可以看到終端機出現以下提示",[26,92,94],{"className":28,"code":93,"language":30,"meta":31,"style":31}," WARN  Issues with peer dependencies found\n.\n└─┬ @nuxt\u002Fdevtools 0.7.5\n  ├── ✕ missing peer vite@\"*\"\n  ├─┬ vite-plugin-inspect 0.7.35\n  │ └── ✕ missing peer vite@\"^3.1.0 || ^4.0.0\"\n  ├─┬ vite-plugin-vue-inspector 3.5.0\n  │ └── ✕ missing peer vite@\"^3.0.0-0 || ^4.0.0-0\"\n  └─┬ @nuxt\u002Fdevtools-kit 0.7.5\n    └── ✕ missing peer vite@\"*\"\n✕ Conflicting peer dependencies:\n  vite\n",[33,95,96,116,122,134,151,163,181,192,208,219,233,247],{"__ignoreMap":31},[36,97,98,101,104,107,110,113],{"class":38,"line":39},[36,99,100],{"class":42}," WARN ",[36,102,103],{"class":46}," Issues",[36,105,106],{"class":46}," with",[36,108,109],{"class":46}," peer",[36,111,112],{"class":46}," dependencies",[36,114,115],{"class":46}," found\n",[36,117,119],{"class":38,"line":118},2,[36,120,121],{"class":66},".\n",[36,123,125,128,131],{"class":38,"line":124},3,[36,126,127],{"class":42},"└─┬",[36,129,130],{"class":46}," @nuxt\u002Fdevtools",[36,132,133],{"class":66}," 0.7.5\n",[36,135,137,140,143,146,148],{"class":38,"line":136},4,[36,138,139],{"class":42},"  ├──",[36,141,142],{"class":46}," ✕",[36,144,145],{"class":46}," missing",[36,147,109],{"class":46},[36,149,150],{"class":46}," vite@\"*\"\n",[36,152,154,157,160],{"class":38,"line":153},5,[36,155,156],{"class":42},"  ├─┬",[36,158,159],{"class":46}," vite-plugin-inspect",[36,161,162],{"class":66}," 0.7.35\n",[36,164,166,169,172,174,176,178],{"class":38,"line":165},6,[36,167,168],{"class":42},"  │",[36,170,171],{"class":46}," └──",[36,173,142],{"class":46},[36,175,145],{"class":46},[36,177,109],{"class":46},[36,179,180],{"class":46}," vite@\"^3.1.0 || ^4.0.0\"\n",[36,182,184,186,189],{"class":38,"line":183},7,[36,185,156],{"class":42},[36,187,188],{"class":46}," vite-plugin-vue-inspector",[36,190,191],{"class":66}," 3.5.0\n",[36,193,195,197,199,201,203,205],{"class":38,"line":194},8,[36,196,168],{"class":42},[36,198,171],{"class":46},[36,200,142],{"class":46},[36,202,145],{"class":46},[36,204,109],{"class":46},[36,206,207],{"class":46}," vite@\"^3.0.0-0 || ^4.0.0-0\"\n",[36,209,211,214,217],{"class":38,"line":210},9,[36,212,213],{"class":42},"  └─┬",[36,215,216],{"class":46}," @nuxt\u002Fdevtools-kit",[36,218,133],{"class":66},[36,220,222,225,227,229,231],{"class":38,"line":221},10,[36,223,224],{"class":42},"    └──",[36,226,142],{"class":46},[36,228,145],{"class":46},[36,230,109],{"class":46},[36,232,150],{"class":46},[36,234,236,239,242,244],{"class":38,"line":235},11,[36,237,238],{"class":42},"✕",[36,240,241],{"class":46}," Conflicting",[36,243,109],{"class":46},[36,245,246],{"class":46}," dependencies:\n",[36,248,250],{"class":38,"line":249},12,[36,251,252],{"class":42},"  vite\n",[16,254,255],{},[256,257],"img",{"alt":258,"src":259},"Issues with peer dependencies found","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt-init-warn\u002F2023-08-08%2013.52.05.png",[12,261,262],{"id":262},"解決方式",[16,264,265,266,269],{},"雖然運行 ",[33,267,268],{},"pnpm run dev"," 是沒有任何問題",[26,271,273],{"className":28,"code":272,"language":30,"meta":31,"style":31},"[下午1:55:04] Nuxi 3.6.5\n[下午1:55:04] Nuxt 3.6.5 with Nitro 2.5.2\n[下午1:55:06] \n  > Local:    http:\u002F\u002Flocalhost:3000\u002F \n  > Network:  http:\u002F\u002F192.168.100.38:3000\u002F\n\n[下午1:55:06] ✔ Nuxt Devtools is enabled v0.7.5 (experimental)\n",[33,274,275,281,286,291,306,316,322],{"__ignoreMap":31},[36,276,277],{"class":38,"line":39},[36,278,280],{"class":279},"s8XSl","[下午1:55:04] Nuxi 3.6.5\n",[36,282,283],{"class":38,"line":118},[36,284,285],{"class":279},"[下午1:55:04] Nuxt 3.6.5 with Nitro 2.5.2\n",[36,287,288],{"class":38,"line":124},[36,289,290],{"class":279},"[下午1:55:06] \n",[36,292,293,297,300,303],{"class":38,"line":136},[36,294,296],{"class":295},"sOudu","  >",[36,298,299],{"class":42}," Local:",[36,301,302],{"class":46},"    http:\u002F\u002Flocalhost:3000\u002F",[36,304,305],{"class":279}," \n",[36,307,308,310,313],{"class":38,"line":153},[36,309,296],{"class":295},[36,311,312],{"class":42}," Network:",[36,314,315],{"class":46},"  http:\u002F\u002F192.168.100.38:3000\u002F\n",[36,317,318],{"class":38,"line":165},[36,319,321],{"emptyLinePlaceholder":320},true,"\n",[36,323,324,327,330],{"class":38,"line":183},[36,325,326],{"class":279},"[下午1:55:06] ✔ Nuxt Devtools is enabled v0.7.5 (",[36,328,329],{"class":42},"experimental",[36,331,332],{"class":279},")\n",[16,334,335],{},"只是看到這個問題就還是會想知道為什麼，然後會想要處理一下，所以就找了一下原因。",[16,337,338,339,342],{},"首先套件管理工具在安裝的時候，其實都會檢查一下相依性，而這邊的警告就是因為 ",[33,340,341],{},"@nuxt\u002Fdevtools"," 這個專案缺少了 Vite 這個依賴套件，所以就會出現這個警告。",[16,344,345],{},"解決方式有兩種，一種是輸入以下指令安裝 Vite",[26,347,349],{"className":28,"code":348,"language":30,"meta":31,"style":31},"pnpm install vite\n",[33,350,351],{"__ignoreMap":31},[36,352,353,355,358],{"class":38,"line":39},[36,354,75],{"class":42},[36,356,357],{"class":46}," install",[36,359,360],{"class":46}," vite\n",[16,362,363,364,366],{},"但我個人是覺得沒必要，因為 Nuxt 本身有 vite，純粹只是因為 ",[33,365,341],{}," 檢測不到而已。",[16,368,369,370,373],{},"第二種方式是在你的 Nuxt3 專案中找到 ",[33,371,372],{},".npmrc"," 檔案，然後把它改成以下",[26,375,377],{"className":28,"code":376,"language":30,"meta":31,"style":31},"shamefully-hoist=true\nstrict-peer-dependencies=false\nauto-install-peers=true # 加入這一行\n",[33,378,379,390,400],{"__ignoreMap":31},[36,380,381,384,387],{"class":38,"line":39},[36,382,383],{"class":279},"shamefully-hoist",[36,385,386],{"class":295},"=",[36,388,389],{"class":46},"true\n",[36,391,392,395,397],{"class":38,"line":118},[36,393,394],{"class":279},"strict-peer-dependencies",[36,396,386],{"class":295},[36,398,399],{"class":46},"false\n",[36,401,402,405,407,410],{"class":38,"line":124},[36,403,404],{"class":279},"auto-install-peers",[36,406,386],{"class":295},[36,408,409],{"class":46},"true",[36,411,413],{"class":412},"sGBqm"," # 加入這一行\n",[16,415,416],{},"這樣子問題也就解決了～",[12,418,419],{"id":419},"參考資料",[421,422,423],"ul",{},[424,425,426],"li",{},[427,428,432],"a",{"href":429,"rel":430},"https:\u002F\u002Fgithub.com\u002Fnuxt\u002Fnuxt\u002Fissues\u002F22054",[431],"nofollow","Conflicting peer dependencies",[434,435,436],"style",{},"html pre.shiki code .smYoP, html code.shiki .smYoP{--shiki-light:#6F42C1;--shiki-default:#6F42C1;--shiki-dark:#FFB757}html pre.shiki code .sWayO, html code.shiki .sWayO{--shiki-light:#032F62;--shiki-default:#032F62;--shiki-dark:#ADDCFF}html .light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html.light .shiki span {color: var(--shiki-light);background: var(--shiki-light-bg);font-style: var(--shiki-light-font-style);font-weight: var(--shiki-light-font-weight);text-decoration: var(--shiki-light-text-decoration);}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html.dark .shiki span {color: var(--shiki-dark);background: var(--shiki-dark-bg);font-style: var(--shiki-dark-font-style);font-weight: var(--shiki-dark-font-weight);text-decoration: var(--shiki-dark-text-decoration);}html pre.shiki code .