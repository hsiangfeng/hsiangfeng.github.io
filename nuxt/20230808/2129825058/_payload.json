[{"data":1,"prerenderedAt":509},["ShallowReactive",2],{"header-locale:\u002Fnuxt\u002F20230808\u002F2129825058\u002F":3,"page:\u002Fnuxt\u002F20230808\u002F2129825058\u002F":4,"alt:\u002Fnuxt\u002F20230808\u002F2129825058\u002F":3,"prev-next:\u002Fnuxt\u002F20230808\u002F2129825058\u002F":485,"related:\u002Fnuxt\u002F20230808\u002F2129825058\u002F":494},"\u002Fen\u002Fnuxt\u002F2023\u002F08\u002F08\u002Fnuxt3-nitro-proxy-cors-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":467,"date":468,"description":469,"extension":470,"lang":471,"meta":472,"navigation":473,"path":474,"readingMinutes":475,"seo":476,"standalone":477,"stem":478,"tags":479,"tldr":482,"updated":468,"url":483,"__hash__":484},"content\u002FNuxt\u002FNuxt3-使用-Nitro-Proxy-解決跨域問題.md","Nuxt3 使用 Nitro Proxy 解決跨域問題","2129825058",{"type":9,"value":10,"toc":462},"minimark",[11,19,23,26,30,41,44,47,141,163,166,177,180,244,247,250,253,262,269,325,328,335,346,350,353,440,449,458],[12,13,14],"p",{},[15,16],"img",{"alt":17,"src":18},"Nuxt Proxy","https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt-proxy\u002F2023-08-08%2010.06.33.png",[20,21,22],"h2",{"id":22},"前言",[12,24,25],{},"這一篇來記錄一下如何使用 Nitro Proxy 來解決 Nuxt3 的跨域問題。",[20,27,29],{"id":28},"nitro-proxy","Nitro Proxy",[12,31,32,33,40],{},"首先 Nuxt3 使用了一個全新的伺服器引擎，也就是 ",[34,35,39],"a",{"href":36,"rel":37},"https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fguide\u002Fconcepts\u002Fserver-engine",[38],"nofollow","Nitro","，而 Nitro 本身也提供了一個 Proxy 的功能，可以讓我們在開發時可以輕鬆的解決跨域問題。",[12,42,43],{},"剛好我最近在說鞥 Nitro Proxy 的時候發生了一點雷點，所以就順便記錄下來。",[12,45,46],{},"依照 Nitro 官方範例來講，只需要這樣寫即可：",[48,49,54],"pre",{"className":50,"code":51,"language":52,"meta":53,"style":53},"language-ts shiki shiki-themes github-dark-high-contrast","\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  devProxy: {\n    '\u002Fproxy\u002Ftest': 'http:\u002F\u002Flocalhost:3001',\n    '\u002Fproxy\u002Fexample': { target: 'https:\u002F\u002Fexample.com', changeOrigin: true }\n  }\n})\n","ts","",[55,56,57,66,84,91,107,129,135],"code",{"__ignoreMap":53},[58,59,62],"span",{"class":60,"line":61},"line",1,[58,63,65],{"class":64},"sQrFR","\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\n",[58,67,69,73,76,80],{"class":60,"line":68},2,[58,70,72],{"class":71},"sWyjQ","export",[58,74,75],{"class":71}," default",[58,77,79],{"class":78},"sj_SG"," defineNuxtConfig",[58,81,83],{"class":82},"s_sBn","({\n",[58,85,87],{"class":60,"line":86},3,[58,88,90],{"class":89},"sMAXC","  devProxy: {\n",[58,92,94,98,101,104],{"class":60,"line":93},4,[58,95,97],{"class":96},"sTRMh","    '\u002Fproxy\u002Ftest'",[58,99,100],{"class":89},": ",[58,102,103],{"class":96},"'http:\u002F\u002Flocalhost:3001'",[58,105,106],{"class":89},",\n",[58,108,110,113,116,119,122,126],{"class":60,"line":109},5,[58,111,112],{"class":96},"    '\u002Fproxy\u002Fexample'",[58,114,115],{"class":89},": { target: ",[58,117,118],{"class":96},"'https:\u002F\u002Fexample.com'",[58,120,121],{"class":89},", changeOrigin: ",[58,123,125],{"class":124},"sCcAr","true",[58,127,128],{"class":89}," }\n",[58,130,132],{"class":60,"line":131},6,[58,133,134],{"class":89},"  }\n",[58,136,138],{"class":60,"line":137},7,[58,139,140],{"class":82},"})\n",[142,143,144],"blockquote",{},[12,145,146,150,151,156,157,162],{},[147,148,149],"strong",{},"Note","\nNitro 的 Proxy 本身是基於 ",[34,152,155],{"href":153,"rel":154},"https:\u002F\u002Fgithub.com\u002Fhttp-party\u002Fnode-http-proxy",[38],"node-http-proxy"," 的；其他參數選項你可以參考 ",[34,158,161],{"href":159,"rel":160},"https:\u002F\u002Fgithub.com\u002Fhttp-party\u002Fnode-http-proxy#options",[38],"node-http-proxy#options","。",[12,164,165],{},"那麼假設我們遠端 API 是長這樣",[48,167,171],{"className":168,"code":169,"language":170,"meta":53,"style":53},"language-bash shiki shiki-themes github-dark-high-contrast","https:\u002F\u002Fapi-example.com\u002Fapi\u002Fv1\u002Fusers\u002Fprofile\n","bash",[55,172,173],{"__ignoreMap":53},[58,174,175],{"class":60,"line":61},[58,176,169],{"class":82},[12,178,179],{},"你可能就會這樣寫：",[48,181,183],{"className":50,"code":182,"language":52,"meta":53,"style":53},"\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  devProxy: {\n    '\u002Fapi': {\n      target: 'https:\u002F\u002Fapi-example.com',\n      changeOrigin: true\n    }\n  }\n})\n",[55,184,185,189,199,203,211,221,229,234,239],{"__ignoreMap":53},[58,186,187],{"class":60,"line":61},[58,188,65],{"class":64},[58,190,191,193,195,197],{"class":60,"line":68},[58,192,72],{"class":71},[58,194,75],{"class":71},[58,196,79],{"class":78},[58,198,83],{"class":82},[58,200,201],{"class":60,"line":86},[58,202,90],{"class":89},[58,204,205,208],{"class":60,"line":93},[58,206,207],{"class":96},"    '\u002Fapi'",[58,209,210],{"class":89},": {\n",[58,212,213,216,219],{"class":60,"line":109},[58,214,215],{"class":89},"      target: ",[58,217,218],{"class":96},"'https:\u002F\u002Fapi-example.com'",[58,220,106],{"class":89},[58,222,223,226],{"class":60,"line":131},[58,224,225],{"class":89},"      changeOrigin: ",[58,227,228],{"class":124},"true\n",[58,230,231],{"class":60,"line":137},[58,232,233],{"class":89},"    }\n",[58,235,237],{"class":60,"line":236},8,[58,238,134],{"class":89},[58,240,242],{"class":60,"line":241},9,[58,243,140],{"class":82},[12,245,246],{},"（畢竟許多 Proxy 套件都是這樣寫）",[12,248,249],{},"這樣確實是會解決跨域的問題，但是這時候你會發生另一個問題...",[12,251,252],{},"也就是不管怎麼打都會變成這樣：",[48,254,256],{"className":168,"code":255,"language":170,"meta":53,"style":53},"http:\u002F\u002Flocalhost:3000\u002Fv1\u002Fusers\u002Fprofile\n",[55,257,258],{"__ignoreMap":53},[58,259,260],{"class":60,"line":61},[58,261,255],{"class":82},[12,263,264,265,268],{},"這是我一直覺得滿奇怪的地方，所以我就檢查了一下 Proxy Request，發現 Nitro Proxy 會把 ",[55,266,267],{},"\u002Fapi"," 給 rewrite 掉變成空白，所以你必須要這樣寫：",[48,270,272],{"className":50,"code":271,"language":52,"meta":53,"style":53},"\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  devProxy: {\n    '\u002Fapi': {\n      target: 'https:\u002F\u002Fapi-example.com\u002Fv1',\n      changeOrigin: true\n    }\n  }\n})\n",[55,273,274,278,288,292,298,307,313,317,321],{"__ignoreMap":53},[58,275,276],{"class":60,"line":61},[58,277,65],{"class":64},[58,279,280,282,284,286],{"class":60,"line":68},[58,281,72],{"class":71},[58,283,75],{"class":71},[58,285,79],{"class":78},[58,287,83],{"class":82},[58,289,290],{"class":60,"line":86},[58,291,90],{"class":89},[58,293,294,296],{"class":60,"line":93},[58,295,207],{"class":96},[58,297,210],{"class":89},[58,299,300,302,305],{"class":60,"line":109},[58,301,215],{"class":89},[58,303,304],{"class":96},"'https:\u002F\u002Fapi-example.com\u002Fv1'",[58,306,106],{"class":89},[58,308,309,311],{"class":60,"line":131},[58,310,225],{"class":89},[58,312,228],{"class":124},[58,314,315],{"class":60,"line":137},[58,316,233],{"class":89},[58,318,319],{"class":60,"line":236},[58,320,134],{"class":89},[58,322,323],{"class":60,"line":241},[58,324,140],{"class":82},[12,326,327],{},"這樣子在打出去時，才會是正確的網址。",[142,329,330],{},[12,331,332,334],{},[147,333,149],{},"\nNitro Proxy 是為了開發時的跨域問題所設計的，因此請勿在正式環境使用；Nitro Proxy 是針對前端打 API 時所使用的，因為後端（SSR）並不會有跨域問題。",[12,336,337,338,341,342,345],{},"那麼有些文章會推薦使用 ",[55,339,340],{},"routeRules","，但我看官方文件目前是標注為「",[147,343,344],{},"Experimental！","（實驗）」，所以我就沒特別去使用它了。",[20,347,349],{"id":348},"vite-proxy","Vite Proxy",[12,351,352],{},"如果你不想使用 Nitro 的 Proxy 而是想使用 Vite 的 Proxy 的話，依照剛剛的範例來講，你就要這樣寫：",[48,354,356],{"className":50,"code":355,"language":52,"meta":53,"style":53},"\u002F\u002F https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fconfiguration\u002Fnuxt-config\nexport default defineNuxtConfig({\n  vite: {\n    server: {\n      proxy: {\n        '\u002Fapi': {\n          target: 'https:\u002F\u002Fapi-example.com',\n          changeOrigin: true\n        }\n      }\n    }\n  }\n});\n",[55,357,358,362,372,377,382,387,394,403,410,415,421,426,431],{"__ignoreMap":53},[58,359,360],{"class":60,"line":61},[58,361,65],{"class":64},[58,363,364,366,368,370],{"class":60,"line":68},[58,365,72],{"class":71},[58,367,75],{"class":71},[58,369,79],{"class":78},[58,371,83],{"class":82},[58,373,374],{"class":60,"line":86},[58,375,376],{"class":89},"  vite: {\n",[58,378,379],{"class":60,"line":93},[58,380,381],{"class":89},"    server: {\n",[58,383,384],{"class":60,"line":109},[58,385,386],{"class":89},"      proxy: {\n",[58,388,389,392],{"class":60,"line":131},[58,390,391],{"class":96},"        '\u002Fapi'",[58,393,210],{"class":89},[58,395,396,399,401],{"class":60,"line":137},[58,397,398],{"class":89},"          target: ",[58,400,218],{"class":96},[58,402,106],{"class":89},[58,404,405,408],{"class":60,"line":236},[58,406,407],{"class":89},"          changeOrigin: ",[58,409,228],{"class":124},[58,411,412],{"class":60,"line":241},[58,413,414],{"class":89},"        }\n",[58,416,418],{"class":60,"line":417},10,[58,419,420],{"class":89},"      }\n",[58,422,424],{"class":60,"line":423},11,[58,425,233],{"class":89},[58,427,429],{"class":60,"line":428},12,[58,430,134],{"class":89},[58,432,434,437],{"class":60,"line":433},13,[58,435,436],{"class":82},"})",[58,438,439],{"class":89},";\n",[12,441,442,443,446,447,162],{},"這邊是不用補上 ",[55,444,445],{},"\u002Fv1"," 的，因為 Vite 本身就不會 rewrite 掉 ",[55,448,267],{},[12,450,451,452,457],{},"這邊也順便分享我先前寫過的 ",[34,453,456],{"href":454,"rel":455},"https:\u002F\u002Fisraynotarray.com\u002Fnodejs\u002F20230407\u002F1216067379\u002F",[38],"Vite 中使用 Proxy 解決 CORS 問題","，基本上設定都是相同的，你是可以直接參考並使用。",[459,460,461],"style",{},"html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-te