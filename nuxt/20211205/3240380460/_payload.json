4,96],{},"因為以上這幾個生命週期階段都是還在 Server 上，因此並不存在 ",[32,95,67],{},"。",[12,98,100],{"id":99},"nuxtserverinit-伺服器初始化","nuxtServerInit (伺服器初始化)",[16,102,103,105],{},[32,104,34],{}," 主要運作於 Nuxt.js 環境初始化時才會觸發的生命週期，而你可以在這個階段初始化 Vuex。",[107,108,113],"pre",{"className":109,"code":110,"language":111,"meta":112,"style":112},"language-js shiki shiki-themes github-dark-high-contrast","export default {\n  nuxtServerInit (store, content) {\n    console.log('nuxtServerInit');\n  },\n}\n","js","",[32,114,115,131,145,164,173],{"__ignoreMap":112},[116,117,120,124,127],"span",{"class":118,"line":119},"line",1,[116,121,123],{"class":122},"sWyjQ","export",[116,125,126],{"class":122}," default",[116,128,130],{"class":129},"s_sBn"," {\n",[116,132,134,138,141],{"class":118,"line":133},2,[116,135,137],{"class":136},"sj_SG","  nuxtServerInit",[116,139,140],{"class":129}," (store, content) ",[116,142,144],{"class":143},"sMAXC","{\n",[116,146,148,151,154,157,161],{"class":118,"line":147},3,[116,149,150],{"class":143},"    console.",[116,152,153],{"class":136},"log",[116,155,156],{"class":143},"(",[116,158,160],{"class":159},"sTRMh","'nuxtServerInit'",[116,162,163],{"class":143},");\n",[116,165,167,170],{"class":118,"line":166},4,[116,168,169],{"class":143},"  }",[116,171,172],{"class":129},",\n",[116,174,176],{"class":118,"line":175},5,[116,177,178],{"class":129},"}\n",[12,180,182],{"id":181},"middleware-中間組件","middleware (中間組件)",[16,184,185,187],{},[32,186,40],{}," 分別有 Global、Layout、Page，但是這邊要注意一下 middleware 的執行順序，Nuxt.js 中 middleware 執行順序是 Global → Layout → Page，這件事情非常重要請務必記得。",[16,189,190],{},"那麼什麼是 Global middleware 呢？你可以試著在 Nuxt.js 專案下建立一個 middleware 資料夾，並建立一個檔案叫做 global.js，內容如下：",[107,192,194],{"className":109,"code":193,"language":111,"meta":112,"style":112},"export default ({ store, route, redirect, params, query, req, res }) => {\n  console.log('Global middleware');\n}\n",[32,195,196,210,224],{"__ignoreMap":112},[116,197,198,200,202,205,208],{"class":118,"line":119},[116,199,123],{"class":1