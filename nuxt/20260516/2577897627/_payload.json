[{"data":1,"prerenderedAt":489},["ShallowReactive",2],{"header-locale:\u002Fnuxt\u002F20260516\u002F2577897627\u002F":3,"page:\u002Fnuxt\u002F20260516\u002F2577897627\u002F":4,"alt:\u002Fnuxt\u002F20260516\u002F2577897627\u002F":3,"prev-next:\u002Fnuxt\u002F20260516\u002F2577897627\u002F":465,"related:\u002Fnuxt\u002F20260516\u002F2577897627\u002F":474},"\u002Fen\u002Fnuxt\u002F2026\u002F05\u002F16\u002Fnuxt3-ngrok-blocked-request-fix\u002F",{"id":5,"title":6,"abbrlink":7,"altUrl":3,"body":8,"category":444,"date":445,"description":446,"extension":447,"lang":448,"meta":449,"navigation":450,"path":451,"readingMinutes":452,"seo":453,"standalone":454,"stem":455,"tags":456,"tldr":462,"updated":445,"url":463,"__hash__":464},"content\u002FNuxt\u002FNuxt3-使用-ngrok-對外時出現-Blocked-request-的解法.md","Nuxt3 使用 ngrok 對外時出現 Blocked request 的解法","2577897627",{"type":9,"value":10,"toc":436},"minimark",[11,18,22,25,49,64,75,78,93,170,186,189,192,204,271,285,288,292,307,359,368,371,374,407,414,417,432],[12,13,14],"p",{},[15,16],"img",{"alt":6,"src":17},"https:\u002F\u002Fimages.israynotarray.com\u002Fblog\u002Fnuxt\u002Fnuxt-ngrok\u002FChatGPT%20Image%202026%E5%B9%B45%E6%9C%8817%E6%97%A5%20%E4%B8%8A%E5%8D%8810_52_16.png",[19,20,21],"h2",{"id":21},"前言",[12,23,24],{},"如果你有在用 ngrok 把本機 dev server 暴露出去給人看的話，最近升級到 Nuxt 3（或者把 Vite 升到 6.x 以上）之後，應該會撞到一個訊息：",[26,27,32],"pre",{"className":28,"code":29,"language":30,"meta":31,"style":31},"language-txt shiki shiki-themes github-dark-high-contrast","Blocked request. This host (\"xxxx-xx-xx-xx-xx.ngrok-free.app\") is not allowed.\nTo allow this host, add \"xxxx-xx-xx-xx-xx.ngrok-free.app\" to `server.allowedHosts` in vite.config.js.\n","txt","",[33,34,35,43],"code",{"__ignoreMap":31},[36,37,40],"span",{"class":38,"line":39},"line",1,[36,41,42],{},"Blocked request. This host (\"xxxx-xx-xx-xx-xx.ngrok-free.app\") is not allowed.\n",[36,44,46],{"class":38,"line":45},2,[36,47,48],{},"To allow this host, add \"xxxx-xx-xx-xx-xx.ngrok-free.app\" to `server.allowedHosts` in vite.config.js.\n",[12,50,51,52,55,56,63],{},"我第一次看到也愣了一下，想說 Nuxt 不是用 Nitro 嗎？怎麼會冒出 ",[33,53,54],{},"vite.config.js"," 來叫我改設定。後來想想 Nuxt 3 client 端其實是 Vite 在跑，這個 host check 是 Vite 從 6.x 開始補上的安全機制，主要是要避免 ",[57,58,62],"a",{"href":59,"rel":60},"https:\u002F\u002Fvite.dev\u002Fconfig\u002Fserver-options.html#server-allowedhosts",[61],"nofollow","DNS Rebinding 攻擊","。",[12,65,66,67,69,70,74],{},"可是 Nuxt 3 不是純 Vite 專案，根本沒有 ",[33,68,54],{}," 可以改，所以這篇就來記錄一下要在哪裡設定。順帶一提，之前我有寫過一篇 ",[57,71,73],{"href":72},"\u002Fnuxt\u002F20230808\u002F2129825058\u002F","Nuxt3 使用 Nitro Proxy 解決跨域問題","，也是在處理 Nuxt 3 dev server 的設定問題，可以一起服用。",[19,76,77],{"id":77},"解決方式",[12,79,80,81,84,85,88,89,92],{},"直接把 ",[33,82,83],{},"server.allowedHosts"," 加到 ",[33,86,87],{},"nuxt.config.ts"," 的 ",[33,90,91],{},"vite"," key 底下就行了：",[26,94,98],{"className":95,"code":96,"language":97,"meta":31,"style":31},"language-ts shiki shiki-themes github-dark-high-contrast","\u002F\u002F nuxt.config.ts\nexport default defineNuxtConfig({\n  vite: {\n    server: {\n      allowedHosts: ['xxxx-xx-xx-xx-xx.ngrok-free.app'],\n    },\n  },\n})\n","ts",[33,99,100,106,123,130,136,149,155,164],{"__ignoreMap":31},[36,101,102],{"class":38,"line":39},[36,103,105],{"class":104},"sQrFR","\u002F\u002F nuxt.config.ts\n",[36,107,108,112,115,119],{"class":38,"line":45},[36,109,111],{"class":110},"sWyjQ","export",[36,113,114],{"class":110}," default",[36,116,118],{"class":117},"sj_SG"," defineNuxtConfig",[36,120,122],{"class":121},"s_sBn","({\n",[36,124,126],{"class":38,"line":125},3,[36,127,129],{"class":128},"sMAXC","  vite: {\n",[36,131,133],{"class":38,"line":132},4,[36,134,135],{"class":128},"    server: {\n",[36,137,139,142,146],{"class":38,"line":138},5,[36,140,141],{"class":128},"      allowedHosts: [",[36,143,145],{"class":144},"sTRMh","'xxxx-xx-xx-xx-xx.ngrok-free.app'",[36,147,148],{"class":128},"],\n",[36,150,152],{"class":38,"line":151},6,[36,153,154],{"class":128},"    },\n",[36,156,158,161],{"class":38,"line":157},7,[36,159,160],{"class":128},"  }",[36,162,163],{"class":121},",\n",[36,165,167],{"class":38,"line":166},8,[36,168,169],{"class":121},"})\n",[12,171,172,173,175,176,178,179,181,182,185],{},"Nuxt 3 的設定統一寫在 ",[33,174,87],{},"，Vite 相關的設定都收在 ",[33,177,91],{}," 這個 key 底下，所以錯誤訊息叫你改 ",[33,180,54],{},"，對 Nuxt 專案來講就是改這個位置。存檔後重啟 ",[33,183,184],{},"pnpm dev","，再打開 ngrok 的網址就正常了。",[19,187,188],{"id":188},"用萬用語法一勞永逸",[12,190,191],{},"不過 ngrok 免費版每次重啟隧道都會給你一個新的 subdomain，總不能每次都回來改設定吧？",[12,193,194,195,203],{},"這時候可以用 Vite 的萬用語法，",[196,197,198,199,202],"strong",{},"字串開頭加一個 ",[33,200,201],{},"."," 就會涵蓋所有子網域","：",[26,205,207],{"className":95,"code":206,"language":97,"meta":31,"style":31},"\u002F\u002F nuxt.config.ts\nexport default defineNuxtConfig({\n  vite: {\n    server: {\n      \u002F\u002F 開頭的 `.` 是 Vite 的萬用語法，會涵蓋所有子網域\n      allowedHosts: ['.ngrok-free.app', '.ngrok.app', '.ngrok.io'],\n    },\n  },\n})\n",[33,208,209,213,223,227,231,236,256,260,266],{"__ignoreMap":31},[36,210,211],{"class":38,"line":39},[36,212,105],{"class":104},[36,214,215,217,219,221],{"class":38,"line":45},[36,216,111],{"class":110},[36,218,114],{"class":110},[36,220,118],{"class":117},[36,222,122],{"class":121},[36,224,225],{"class":38,"line":125},[36,226,129],{"class":128},[36,228,229],{"class":38,"line":132},[36,230,135],{"class":128},[36,232,233],{"class":38,"line":138},[36,234,235],{"class":104},"      \u002F\u002F 開頭的 `.` 是 Vite 的萬用語法，會涵蓋所有子網域\n",[36,237,238,240,243,246,249,251,254],{"class":38,"line":151},[36,239,141],{"class":128},[36,241,242],{"class":144},"'.ngrok-free.app'",[36,244,245],{"class":128},", ",[36,247,248],{"class":144},"'.ngrok.app'",[36,250,245],{"class":128},[36,252,253],{"class":144},"'.ngrok.io'",[36,255,148],{"class":128},[36,257,258],{"class":38,"line":157},[36,259,154],{"class":128},[36,261,262,264],{"class":38,"line":166},[36,263,160],{"class":128},[36,265,163],{"class":121},[36,267,269],{"class":38,"line":268},9,[36,270,169],{"class":121},[12,272,273,274,277,278,277,281,284],{},"這樣不管 ngrok 給你什麼新網址都會放行。以我自己來講，會把 ",[33,275,276],{},".ngrok-free.app","、",[33,279,280],{},".ngrok.app",[33,282,283],{},".ngrok.io"," 三個都加進去，免得之後換成付費版的網域又要回來改一次。",[12,286,287],{},"如果你還會用其他穿透工具像 Cloudflare Tunnel、Tailscale Funnel，把對應的網域加進這個陣列即可。",[19,289,291],{"id":290},"為什麼不直接全部放行","為什麼不直接全部放行？",[12,293,294,295,298,299,302,303,306],{},"Vite 其實有提供一個更暴力的選項，把 ",[33,296,297],{},"allowedHosts"," 直接設成 ",[33,300,301],{},"true"," 就會放行",[196,304,305],{},"所有","來源：",[26,308,310],{"className":95,"code":309,"language":97,"meta":31,"style":31},"\u002F\u002F 不建議\nexport default defineNuxtConfig({\n  vite: {\n    server: {\n      allowedHosts: true,\n    },\n  },\n})\n",[33,311,312,317,327,331,335,345,349,355],{"__ignoreMap":31},[36,313,314],{"class":38,"line":39},[36,315,316],{"class":104},"\u002F\u002F 不建議\n",[36,318,319,321,323,325],{"class":38,"line":45},[36,320,111],{"class":110},[36,322,114],{"class":110},[36,324,118],{"class":117},[36,326,122],{"class":121},[36,328,329],{"class":38,"line":125},[36,330,129],{"class":128},[36,332,333],{"class":38,"line":132},[36,334,135],{"class":128},[36,336,337,340,343],{"class":38,"line":138},[36,338,339],{"class":128},"      allowedHosts: ",[36,341,301],{"class":342},"sCcAr",[36,344,163],{"class":128},[36,346,347],{"class":38,"line":151},[36,348,154],{"class":128},[36,350,351,353],{"class":38,"line":157},[36,352,160],{"class":128},[36,354,163],{"class":121},[36,356,357],{"class":38,"line":166},[36,358,169],{"class":121},[360,361,362],"blockquote",{},[12,363,364,367],{},[196,365,366],{},"Note","\n我自己很不喜歡這樣寫，因為這等於把 Vite 加上 host check 的安全意義整個關掉。雖然 dev server 只在本機跑，可是只要你開了 ngrok、Cloudflare Tunnel 之類的穿透服務，這台 dev server 就等於是對外的，多花十秒鐘設個白名單其實不虧。",[19,369,370],{"id":370},"結語",[12,372,373],{},"簡單整理一下這篇講的事情：",[375,376,377,389,397,404],"ul",{},[378,379,380,381,383,384,88,386,388],"li",{},"Nuxt 3 沒有 ",[33,382,54],{},"，Vite 的設定要寫在 ",[33,385,87],{},[33,387,91],{}," key 底下",[378,390,391,393,394,396],{},[33,392,297],{}," 用陣列指定允許的 host，開頭加 ",[33,395,201],{}," 可以萬用涵蓋子網域",[378,398,399,400,403],{},"不要為了方便直接 ",[33,401,402],{},"allowedHosts: true","，乖乖列白名單比較香",[378,405,406],{},"這個設定只影響 dev server，production build 完全不受影響",[12,408,409,410,63],{},"希望這一篇有幫到剛好被 ngrok + Nuxt 3 擋下來的你哩～如果你也在踩 Nuxt 3 的環境坑，可以順手翻一下 ",[57,411,413],{"href":412},"\u002Fnuxt\u002F20230808\u002F3162324445\u002F","初始化 Nuxt3 專案時出現 Issues with peer dependencies found 警告",[19,415,416],{"id":416},"參考資料",[375,418,419,425],{},[378,420,421],{},[57,422,424],{"href":59,"rel":423},[61],"Vite｜server.allowedHosts",[378,426,427],{},[57,428,431],{"href":429,"rel":430},"https:\u002F\u002Fnuxt.com\u002Fdocs\u002Fapi\u002Fnuxt-config#vite",[61],"Nuxt 3｜Configuration - vite",[433,434,435],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .sQrFR, html code.shiki .sQrFR{--shiki-default:#BDC4CC}html pre.shiki code .sWyjQ, html code.shiki .sWyjQ{--shiki-default:#FF9492}html pre.shiki code .sj_SG, html code.shiki .sj_SG{--shiki-default:#DBB7FF}html pre.shiki code .s_sBn, html code.shiki .s_sBn{--shiki-default:#FFB757}html pre.shiki code .sMAXC, html code.shiki .sMAXC{--shiki-default:#F0F3F6}html pre.shiki code .sTRMh, html code.shiki .sTRMh{--shiki-default:#ADDCFF}html pre.shiki code .sCcAr, html code.shiki .sCcAr{--shiki-default:#91CBFF}",{"title":31,"searchDepth":45,"depth":45,"links":437},[438,439,440,441,442,443],{"id":21,"depth":45,"text":21},{"id":77,"depth":45,"text":77},{"id":188,"depth":45,"text":188},{"id":290,"depth":45,"text":291},{"id":370,"depth":45,"text":370},{"id":416,"depth":45,"text":416},"Nuxt","2026-05-16 10:00:00","這篇記錄一下用 ngrok 把 Nuxt 3 dev server 對外開放時出現「Blocked request. This host is not allowed」的解決方式， 包含為什麼 Nuxt 會冒出 vite.config.js 的錯誤訊息、要在 nuxt.config.ts 的 vite key 底下加 server.allowedHosts、 用開頭加 . 的萬用語法涵蓋所有 ngrok 子網域，以及為什麼不建議直接把 allowedHosts 設成 true。","md","zh-Hant",{},true,"\u002Fnuxt\u002Fnuxt3-ngrok-blocked-request","2",{"title":6,"description":446},false,"Nuxt\u002FNuxt3-使用-ngrok-對外時出現-Blocked-request-的解法",[444,457,458,459,460,297,461],"Nuxt3","Vue","Vite","ngrok","dev server",null,"\u002Fnuxt\u002F20260516\u002F2577897627\u002F","xA232C1nQBqW7PXKlhzHoYTAYYpX5yYkajy4hxzXXjA",{"newer":466,"older":470},{"url":467,"title":468,"date":469},"\u002Fai\u002F20260517\u002F3851629074\u002F","Vibe Coding 升級教學：2026 Agentic Engineering 六階段實戰 SOP（含範本與案例）","2026-05-17 14:30:00",{"url":471,"title":472,"date":473},"\u002Fother\u002F20260514\u002F7521893064\u002F","分享網址到 LINE、Discord 沒預覽圖？用 ?v=1 強制重抓社群 OG cache","2026-05-14 10:00:00",[475,480,485],{"url":476,"title":477,"date":478,"readingMinutes":479},"\u002Fnuxt\u002F20240919\u002F4102603832\u002F","還原專案噴 Cannot find module @rollup\u002Frollup-darwin-arm64 錯誤","2024-09-19 10:08:07","1",{"url":481,"title":482,"date":483,"readingMinutes":484},"\u002Fnuxt\u002F20231104\u002F4026785494\u002F","Nuxt 3.8.0 useFetch Error Cache 的問題","2023-11-04 00:00:19","3",{"url":486,"title":487,"date":488,"readingMinutes":484},"\u002Fnuxt\u002F20231023\u002F2419347402\u002F","Nuxt3 綁定表單後無限觸發 API","2023-10-23 17:04:45",1784020395171]